      <SOURCE BUSINESSNAME="" DATABASETYPE="Teradata" DBDNAME="TD_DSN" NAME="SRC_TD_TABLE" OBJECTVERSION="1" OWNERNAME="SRC_DB" VERSIONNUMBER="1">
        <!-- Replace these FIELDs with your real source columns -->
        <SOURCEFIELD NAME="COL1" DATATYPE="string" PRECISION="50" SCALE="0" NULLABLE="NULL" FIELDNUMBER="1" PHYSICALOFFSET="0" PHYSICALLENGTH="50"/>
        <SOURCEFIELD NAME="COL2" DATATYPE="decimal" PRECISION="18" SCALE="2" NULLABLE="NULL" FIELDNUMBER="2" PHYSICALOFFSET="50" PHYSICALLENGTH="9"/>
      </SOURCE>

      <!-- ========== TARGET DEFINITION (Teradata) ========== -->
      <TARGET DATABASETYPE="Teradata" DBDNAME="TD_DSN" NAME="TGT_TD_TABLE" OBJECTVERSION="1" OWNERNAME="TGT_DB" VERSIONNUMBER="1">
        <!-- Replace these FIELDs with your real target columns -->
        <TARGETFIELD NAME="COL1" DATATYPE="string" PRECISION="50" SCALE="0" NULLABLE="NULL" KEYTYPE="NOT A KEY" FIELDNUMBER="1"/>
        <TARGETFIELD NAME="COL2" DATATYPE="decimal" PRECISION="18" SCALE="2" NULLABLE="NULL" KEYTYPE="NOT A KEY" FIELDNUMBER="2"/>
      </TARGET>

      <!-- ========== MAPPING ========== -->
      <MAPPING DESCRIPTION="Read from Teradata and load to Teradata with pre/post SQL" ISVALID="YES" NAME="m_TD_to_TD" OBJECTVERSION="1" VERSIONNUMBER="1">

        <!-- Source Qualifier (optionally add SQL override in the transformation if needed) -->
        <TRANSFORMATION NAME="SQ_SRC_TD_TABLE" OBJECTVERSION="1" REUSABLE="NO" TYPE="Source Qualifier" VERSIONNUMBER="1">
          <TRANSFORMFIELD DATATYPE="string" DEFAULTVALUE="" DESCRIPTION="" NAME="COL1" PORTTYPE="INPUT/OUTPUT" PRECISION="50" SCALE="0"/>
          <TRANSFORMFIELD DATATYPE="decimal" DEFAULTVALUE="" DESCRIPTION="" NAME="COL2" PORTTYPE="INPUT/OUTPUT" PRECISION="18" SCALE="2"/>
          <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT COL1, COL2 FROM SRC_DB.SRC_TD_TABLE"/>
        </TRANSFORMATION>

        <!-- Expression (pass-through; add business logic here if needed) -->
        <TRANSFORMATION NAME="EXP_PASSTHRU" OBJECTVERSION="1" REUSABLE="NO" TYPE="Expression" VERSIONNUMBER="1">
          <TRANSFORMFIELD DATATYPE="string" DEFAULTVALUE="" DESCRIPTION="" EXPRESSION="COL1" NAME="COL1" PORTTYPE="OUTPUT" PRECISION="50" SCALE="0"/>
          <TRANSFORMFIELD DATATYPE="decimal" DEFAULTVALUE="" DESCRIPTION="" EXPRESSION="COL2" NAME="COL2" PORTTYPE="OUTPUT" PRECISION="18" SCALE="2"/>
          <TRANSFORMFIELD DATATYPE="string" DEFAULTVALUE="" DESCRIPTION="" NAME="COL1_IN" PORTTYPE="INPUT" PRECISION="50" SCALE="0"/>
          <TRANSFORMFIELD DATATYPE="decimal" DEFAULTVALUE="" DESCRIPTION="" NAME="COL2_IN" PORTTYPE="INPUT" PRECISION="18" SCALE="2"/>
          <CONNECTOR FROMFIELD="COL1" FROMINSTANCE="SQ_SRC_TD_TABLE" FROMINSTANCETYPE="Source Qualifier" TOFIELD="COL1_IN" TOINSTANCE="EXP_PASSTHRU" TOINSTANCETYPE="Expression"/>
          <CONNECTOR FROMFIELD="COL2" FROMINSTANCE="SQ_SRC_TD_TABLE" FROMINSTANCETYPE="Source Qualifier" TOFIELD="COL2_IN" TOINSTANCE="EXP_PASSTHRU" TOINSTANCETYPE="Expression"/>
        </TRANSFORMATION>

        <!-- Target Definition instance -->
        <INSTANCE NAME="SRC_TD_TABLE" OBJECTTYPE="SOURCE" TRANSFORMATION_NAME="SRC_TD_TABLE" TRANSFORMATION_TYPE="Source Definition"/>
        <INSTANCE NAME="TGT_TD_TABLE" OBJECTTYPE="TARGET" TRANSFORMATION_NAME="TGT_TD_TABLE" TRANSFORMATION_TYPE="Target Definition"/>
        <INSTANCE NAME="SQ_SRC_TD_TABLE" OBJECTTYPE="TRANSFORMATION" TRANSFORMATION_NAME="SQ_SRC_TD_TABLE" TRANSFORMATION_TYPE="Source Qualifier"/>
        <INSTANCE NAME="EXP_PASSTHRU" OBJECTTYPE="TRANSFORMATION" TRANSFORMATION_NAME="EXP_PASSTHRU" TRANSFORMATION_TYPE="Expression"/>

        <!-- Connect Expression outputs to Target -->
        <CONNECTOR FROMFIELD="COL1" FROMINSTANCE="EXP_PASSTHRU" FROMINSTANCETYPE="Expression" TOFIELD="COL1" TOINSTANCE="TGT_TD_TABLE" TOINSTANCETYPE="Target Definition"/>
        <CONNECTOR FROMFIELD="COL2" FROMINSTANCE="EXP_PASSTHRU" FROMINSTANCETYPE="Expression" TOFIELD="COL2" TOINSTANCE="TGT_TD_TABLE" TOINSTANCETYPE="Target Definition"/>

      </MAPPING>

      <!-- ========== SESSION + WORKFLOW (with PRE/POST SQL) ========== -->
      <WORKFLOW DESCRIPTION="TD->TD workflow" ISVALID="YES" NAME="wf_TD_to_TD" OBJECTVERSION="1" VERSIONNUMBER="1">
        <TASK INSTANCE="s_m_TD_to_TD" NAME="s_m_TD_to_TD" TASKTYPE="Session"/>

        <SESSION DESCRIPTION="Session for m_TD_to_TD" ISVALID="YES" MAPPINGNAME="m_TD_to_TD" NAME="s_m_TD_to_TD" OBJECTVERSION="1" VERSIONNUMBER="1">
          <!-- Connection references (set to your PowerCenter connection object names) -->
          <CONNECTIONREFERENCE CONNECTIONNAME="TD_SRC_CONN" CONNECTIONTYPE="Relational" NAME="SRC_TD_TABLE" VARIABLE=""/>
          <CONNECTIONREFERENCE CONNECTIONNAME="TD_TGT_CONN" CONNECTIONTYPE="Relational" NAME="TGT_TD_TABLE" VARIABLE=""/>

          <!-- Target load settings + Pre/Post SQL are typically stored in SESSIONEXTENSION -->
          <SESSIONEXTENSION NAME="Relational Writer" OBJECTVERSION="1" SAPPROGRAMNAME="" TYPE="WRITER" VERSIONNUMBER="1">
            <!-- Change Insert/Update strategy as needed -->
            <ATTRIBUTE NAME="Insert" VALUE="YES"/>
            <ATTRIBUTE NAME="Update" VALUE="NO"/>
            <ATTRIBUTE NAME="Delete" VALUE="NO"/>
            <ATTRIBUTE NAME="Truncate target table option" VALUE="NO"/>

            <!-- Pre/Post SQL: replace with your actual statements (multi-statement supported; separate with semicolons if allowed in your setup) -->
            <ATTRIBUTE NAME="Pre SQL" VALUE="/* PRE-SQL */ DELETE FROM TGT_DB.TGT_TD_TABLE WHERE LOAD_DT = CURRENT_DATE;"/>
            <ATTRIBUTE NAME="Post SQL" VALUE="/* POST-SQL */ COLLECT STATISTICS ON TGT_DB.TGT_TD_TABLE COLUMN (COL1);"/>
          </SESSIONEXTENSION>

        </SESSION>

        <!-- Start the session (simple linear workflow) -->
        <WORKFLOWLINK CONDITION="" FROMTASK="Start" TOINSTANCE="s_m_TD_to_TD"/>
      </WORKFLOW>

    </FOLDER>
  </REPOSITORY>
