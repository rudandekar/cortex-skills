      "attributes": {
        "Sql Query": "SELECT \r\n BOOKINGS_MEASURE_KEY\r\n,BOOKINGS_PROCESS_DATE\r\n,BKGS_MEASURE_TRANS_TYPE_CODE\r\n,COALESCE(GOODS_PRODUCT_KEY,-999) AS GOODS_PRODUCT_KEY\r\n,DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n,CASE\r\nWHEN RECORD_TYPE = 'MS_BP' THEN 3001\r\nWHEN RECORD_TYPE = 'MS' THEN 3002\r\nWHEN RECORD_TYPE = 'DS_PSG' THEN 3003\r\nWHEN RECORD_TYPE = 'DS_SQ_PSG' THEN 3004\r\nWHEN RECORD_TYPE = 'DS_NPSG' THEN 3005\r\nWHEN RECORD_TYPE = 'DS_SQ_NPSG' THEN 3006\r\nWHEN RECORD_TYPE = 'PRIOR PERIOD' THEN 3007\r\nWHEN RECORD_TYPE = 'POS_DS' THEN 3008\r\n\r\nWHEN RECORD_TYPE = 'ACQ_SKU_PID' THEN 3009\r\n\r\nWHEN RECORD_TYPE = 'POS_DUMMY_PID' THEN 3010\r\nWHEN RECORD_TYPE = 'POS_ISO_SKU' THEN 3011\r\nWHEN RECORD_TYPE = 'POS_SKU' THEN 3012\r\nWHEN RECORD_TYPE = 'POS_ISO' THEN 3013\r\n\r\nWHEN RECORD_TYPE = 'UA_DUMMY_PID' THEN 3014\r\nWHEN RECORD_TYPE = 'UA_CTRY_PID' THEN 3015\r\n\r\nWHEN RECORD_TYPE = 'UOWQ_DUMMY_PID' THEN 3016\r\nWHEN RECORD_TYPE = 'UOWQ_CTRY_PID' THEN 3017\r\n\r\nWHEN RECORD_TYPE = 'PSG_BE_PID' THEN 3018\r\nWHEN RECORD_TYPE = 'BIZ MAPPING' THEN 3019\r\n\r\nEND  AS TSS_ALLCTN_METHOD_TYPE_ID_INT\r\n,COALESCE(DV_REVENUE_RECOGNITION_FLG,'N') REVENUE_RECOGNITION_FLG\r\n,COALESCE(DV_NET_SPREAD_FLG,'=') DV_NET_SPREAD_FLG\r\n,COALESCE(CORPORATE_BOOKINGS_FLG,'N') CORPORATE_BOOKINGS_FLG\r\n,SUM(COALESCE(TRADE_IN_AMOUNT,0.0)) TRADE_IN_AMOUNT\r\n,SUM(COALESCE(TSS_BOOKINGS_AMOUNT,0.0)) DD_COMP_US_NET_PRICE_AMOUNT\r\n,SUM(COALESCE(DD_COMP_US_LIST_PRICE_AMOUNT,0.0)) DD_COMP_US_LIST_PRICE_AMOUNT\r\n,SUM(COALESCE(DD_COMP_US_COST_AMOUNT,0.0)) DD_COMP_US_COST_AMOUNT\r\n,SUM(COALESCE(DD_EXTENDED_QUANTITY,0.0)) DD_EXTENDED_QUANTITY \r\n,SUM(COALESCE(DD_COMP_US_HOLD_NET_PRICE_AMT,0.0)) DD_COMP_US_HOLD_NET_PRICE_AMT\r\n,SUM(COALESCE(DD_COMP_US_HOLD_LIST_PRICE_AMT,0.0)) DD_COMP_US_HOLD_LIST_PRICE_AMT\r\n,SUM(COALESCE(DD_COMP_US_HOLD_COST_AMOUNT,0.0)) DD_COMP_US_HOLD_COST_AMOUNT\r\n,SUM(COALESCE(DD_EXTENDED_HOLD_QUANTITY,0.0)) DD_EXTENDED_HOLD_QUANTITY\r\n,SUM(COALESCE(DD_COMP_US_STANDARD_PRICE_AMT,0.0)) DD_COMP_US_STANDARD_PRICE_AMT\r\n,SALES_TERRITORY_KEY\r\n,SALES_REP_NUMBER\r\n,CURRENT_TIMESTAMP(0)\r\n,CURRENT_USER\r\n,CURRENT_TIMESTAMP(0)\r\n,CURRENT_USER\r\n,PRODUCT_KEY AS SERVICE_ITEM_KEY\r\nFROM $$STGDB.WI_SERVICE_BOOKINGS_BY_PID\r\nWHERE DV_FISCAL_YEAR_MTH_NUMBER_INT IN (SEL FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_SRVC_BKGS_CNTRL_MNTH)\r\nGROUP BY 1,2,3,4,5,6,7,8,9,20,21,26",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
