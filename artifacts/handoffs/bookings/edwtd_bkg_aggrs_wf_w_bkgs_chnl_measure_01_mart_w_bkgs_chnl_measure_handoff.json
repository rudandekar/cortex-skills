      "attributes": {
        "Sql Query": "SELECT\t\r\nNBCM.BOOKINGS_MEASURE_KEY     ,     \r\nNBCM.DV_DRCT_VAL_ADDED_DSTI_ORD_FLG,\r\nCASE\tWHEN NBCM.AS_OF_FSC_MTH_PTR_STE_PRTY_KEY=-999 THEN RANDOM(1000000,\r\n\t\t\t1003000)* -1 \r\nELSE\tNBCM.AS_OF_FSC_MTH_PTR_STE_PRTY_KEY \r\nEND\tAS_OF_FSC_MTH_PTR_STE_PRTY_KEY1,\r\nNBCM.AS_OF_FSC_MTH_CHANNEL_BKGS_FLG,\r\nNBCM.AS_OF_FSC_MTH_CHNL_DRP_SHP_FLG,\r\nNBCM.EDW_UPDATE_USER               ,\r\nNBCM.EDW_UPDATE_DATETIME           ,\r\nNBCM.BOOKINGS_PROCESS_DATE         ,\r\nNBCM.BKGS_MEASURE_TRANS_TYPE_CODE  ,\r\nCASE\tWHEN NBCM.PARTNER_SITE_PARTY_KEY=-999 THEN RANDOM(1000000,\r\n\t\t1003000)* -1 \r\nELSE\tNBCM.PARTNER_SITE_PARTY_KEY \r\nEND\tPARTNER_SITE_PARTY_KEY1,\r\nNBCM.CHANNEL_BOOKINGS_FLG          ,\r\nNBCM.CHANNEL_DROP_SHIP_FLG         ,\r\nNBCM.DV_ROUTE_TO_MARKET_CD         , /*PNEELRAJ ADDED AS A PART OF ICPM Q2FY16*/\r\nNBCM.DV_AS_OF_FSC_MTH_RTM_CD       ,  /*PNEELRAJ ADDED AS A PART OF ICPM Q2FY16*/\r\nCOALESCE(NBCM.DV_DBT_TYP,'UNKNOWN'),\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE,\r\nNBCM.BOOKING_CHANNEL_TYPE,\r\nNBCM.AS_OF_FSC_MTH_BKGS_CHANNEL_TYPE,\r\n/*Added as part of SFP Q4 FY21 Rel*/\r\nNBCM.MAGIC_KEY_ID,\r\nNBCM.NET_PRICE_FLG,\r\nNBCM.DV_ROUTE_TO_MARKET_DESCRIPTION\r\n\n , MANUAL_PTNR_OVERRIDE_REASON_CD AS MANUAL_PTNR_OVERRIDE_REASON_CD \n , OTM_OVERRIDE_PTNR_SITE_PARTY_KEY AS OTM_OVERRIDE_PTNR_SITE_PARTY_KEY \n , MNL_PTNR_SITE_OVERRIDE_FLG AS MNL_PTNR_SITE_OVERRIDE_FLG FROM\t\r\n$$SLSORDVWDB.N_BOOKINGS_CHANNEL_MEASURE NBCM\r\nINNER JOIN \r\n$$COMREFVWDB.R_FISCAL_DAY_TO_YEAR RFDTY\r\nON  NBCM.BOOKINGS_PROCESS_DATE  =  RFDTY.CALENDAR_DATE  \r\nWHERE RFDTY.FISCAL_YEAR_MONTH_INT= (SELECT FISCAL_YEAR_MONTH_INT FROM $$STGDB.ST_N_BKGS_CHNL_FISCAL_MTH_MAX)\r\nOR\r\nNBCM.EDW_UPDATE_DATETIME > (SELECT\tLAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS WHERE\tJOB_STREAM_ID='wf_N_BKGS_CHNL_MEASURE'  AND\tJOB_GROUP_ID='EDWTD_BMD')",
        "User Defined Join": "",
        "Source Filter": "",
