      "attributes": {
        "Sql Query": "SELECT\r\nCAST('1900/01/01 00:00:00' AS TIMESTAMP(0))  CDB_DEQUEUE_TIME,\r\nTRX_SC.CREATION_DATE,\r\nSC.DEBIT_CREDIT_CODE,\r\nCURRENT_TIMESTAMP(0) AS ETL_PROCESS_DTM,\r\nSOL.GLOBAL_NAME,\r\nTRX_SC.LAST_UPDATE_DATE,\r\nTRX_SC.LATEST_SC_FLAG,\r\nSOL.ORDER_LINE_ID,\r\nEXT.JTF_TERRITORIES_ID AS OTM_TERR_ID, /*  ADDED  AS PART OF  D1FY14*/\r\nTERR.NAME  AS OTM_TERR_NAME, /*  ADDED  AS PART OF  D1FY14*/\r\nTYP.NAME  AS OTM_TERR_TYPE_CODE, /*  ADDED  AS PART OF  D1FY14*/\r\nCASE WHEN ASGN.CLASS_CODE IS NOT NULL THEN 'Y'   \r\nELSE 'N' END AS  REBOK_CHANNEL_FLAG,   /*  ADDED  AS PART OF  D1FY14*/\r\nSC.SALESREP_NUMBER,\r\nSC.SC_ASSIGNMENT_MODE_CODE,\r\nSC.LAST_UPDATE_DATE  AS SC_LAST_UPD_DATE,   /*  ADDED  AS PART OF  D1FY14*/\r\nCOALESCE(SC.SC_REASON_CODE, 'UNKNOWN' ),/*  ADDED  AS PART OF  D1FY14*/\r\nSC.SC_SPLIT_PERCENT,\r\nSC.SC_TYPE_CODE,\r\nSC.SC_UNALLOCATED, /*  ADDED  AS PART OF  D1FY14*/\r\nSC.SC_USAGE_CODE, /*  ADDED  AS PART OF  D1FY14*/\r\nSC.SHR_NODE_ID,\r\nSC.TERRITORY_TYPE_CODE,\r\nTRX_SC.TRX_SC_ID, \r\nUSR.USER_NAME , \r\nEXT.UCRM_CASE_NUM\r\nFROM \r\n(SELECT * FROM $$NRTACCUMVWDB.XXOTM_PHX_TRX_SC \r\nWHERE LAST_UPDATE_DATE>CAST('$$LastExtractDate' AS TIMESTAMP(0))-interval '2' hour\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY TRX_SC_ID ORDER BY REFRESH_DATETIME DESC)=1) TRX_SC\r\nINNER JOIN\r\n(SELECT * FROM $$GGSRCVWDB.XXOTM_PHX_SALES_CREDITS\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY  SC_ID ORDER BY REFRESH_DATETIME DESC)=1) SC\r\nON TRX_SC.SC_ID=SC.SC_ID\r\nINNER JOIN\r\n(SELECT * FROM $$GGSRCVWDB.XXOTM_PHX_ERP_BOOK_LINES\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY  TRX_ID ORDER BY REFRESH_DATETIME DESC)=1) SOL\r\nON TRX_SC.TRX_ID=SOL.TRX_ID\r\nINNER JOIN\r\n(SELECT * FROM $$GGSRCVWDB.FND_USER\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY  USER_NAME ,USER_ID ORDER BY REFRESH_DATETIME DESC)=1) USR\r\nON SC.CREATED_BY=USR.USER_ID\r\nINNER JOIN\r\n(SELECT * FROM $$GGSRCVWDB.XXOTM_PHX_SALES_CREDITS_EXT\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY  SC_EXT_ID ORDER BY REFRESH_DATETIME DESC)=1) EXT\r\nON SC.SC_ID=EXT.SC_ID\r\nLEFT JOIN\r\n(SELECT * FROM $$GGSRCVWDB.JTF_TERR_ALL\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY  TERR_ID,ORG_ID ORDER BY REFRESH_DATETIME DESC)=1) TERR\r\nON EXT.JTF_TERRITORIES_ID=TERR.TERR_ID\r\nLEFT JOIN\r\n(SELECT * FROM $$GGSRCVWDB.JTF_TERR_TYPES_ALL\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY  TERR_TYPE_ID,ORG_ID ORDER BY REFRESH_DATETIME DESC)=1) TYP\r\nON EXT.JTF_TERR_TYPE_ID=TYP.TERR_TYPE_ID\r\nLEFT JOIN\r\n(SELECT * FROM $$GGSRCVWDB.XXOTM_PHX_CODE_ASSIGNMENTS\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY  CODE_ASSIGNMENT_ID ORDER BY REFRESH_DATETIME DESC)=1) ASGN\r\nON ASGN.OWNER_TABLE_NAME='XXOTM_PHX_TRX_SC'\r\nAND ASGN.CLASS_CATEGORY= 'XXOTM_PHX_CB_FLAG'\r\nAND TRX_SC.TRX_SC_ID = ASGN.OWNER_TABLE_ID\r\nWHERE 1=2",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
  ],
