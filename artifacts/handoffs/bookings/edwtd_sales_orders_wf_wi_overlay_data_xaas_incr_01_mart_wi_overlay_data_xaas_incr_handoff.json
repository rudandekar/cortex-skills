      "attributes": {
        "Sql Query": "SELECT\r\nNAOVRLYTV.SK_TRX_SC_ID_INT,\r\nNAOVRLYTV.SLS_CREDIT_ASGNMT_SLS_TRX_KEY,\r\nNAOVRLYTV.BK_SLS_TERR_ASGNMT_TYPE_CD  AS  BK_SLS_TERR_ASSIGNMENT_TYPE_CD, \r\nNAOVRLYTV.DV_SCA_CREATE_DT AS PD_SCAA_CREATION_DT,\r\nNAOVRLYTV.BK_SALES_REP_NUM AS  PD_SALES_REP_NUM, \r\nNAOVRLYTV.SALES_TERRITORY_KEY AS  PD_SALES_TERRITORY_KEY, \r\nNAOVRLYTV.SO_SBSCRPTN_ITM_SLS_TRX_KEY AS   SO_SBSCRPTN_ITM_SLS_TRX_KEY , \r\nNAOVRLYTV.SPLIT_PCT  AS PD_SALES_COMMISSION_PCT,\r\nNAOVRLYTV.EFFECTIVE_START_DTM           ,\r\nNAOVRLYTV.EFFECTIVE_END_DTM             ,\r\nNAOVRLYTV.EDW_CREATE_DTM as SRC_EDW_CREATE_DTM,\r\nNAOVRLYTV.EDW_UPDATE_DTM as SRC_EDW_UPDATE_DTM,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nNAOVRLYTV.SCA_LAST_UPDATE_DTM            ,\r\nNAOVRLYTV.SALES_CREDIT_USAGE_CD AS PD_SALES_CREDIT_USAGE_CD,\r\nNAOVRLYTV.BK_OFFER_ATTRIBUTION_ID_INT AS SK_OFFER_ATTRIBUTION_ID_INT,\r\nCAST ('UNKNOWN' AS VARCHAR(50)) AS RTNR_UNIQUE_ID,\r\nNSOL.LINE_CREATION_DATE,\r\n'REG_OVL' AS SRC_INDICATOR,\r\nNAOVRLYTV.SPLIT_PCT  AS PD_SALES_COMMISSION_PCT_ORIG\r\nFROM \r\n $$SLSORDVWDB.N_XAAS_SLS_CRDT_ASGNMT_SLS_TRX NAOVRLYTV\r\n INNER JOIN (SEL SO_SBSCRPTN_ITM_SLS_TRX_KEY,CAST(DV_TRX_LINE_CREATION_DT AS DATE FORMAT'yyyy-mm-dd') AS LINE_CREATION_DATE FROM $$SLSORDVWDB.N_XAAS_SO_SBSCR_ITM_SLS_TRX NSOL GROUP BY 1,2 ) NSOL\r\n \t \t   ON NSOL.SO_SBSCRPTN_ITM_SLS_TRX_KEY = NAOVRLYTV.SO_SBSCRPTN_ITM_SLS_TRX_KEY\r\nWHERE     \r\n     NAOVRLYTV.SALES_CREDIT_USAGE_CD IN ('R','CR')   \r\n     AND NAOVRLYTV.BK_SLS_TERR_ASGNMT_TYPE_CD NOT IN ('DR','CX')\r\nAND NAOVRLYTV.EDW_UPDATE_DTM> (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.CTL_ETL_LAST_EXTRACT_DATES \r\nWHERE JOB_STREAM_ID = 'wf_WI_OVERLAY_DATA_XAAS_INCR' AND TABLE_NAME ='N_XAAS_SLS_CRDT_ASGNMT_SLS_TRX')\r\nAND NOT EXISTS (SELECT 1 FROM $$ETLVWDB.EL_OVERLAY_SUB_LINE_INCLUSION EL \r\n \t \tWHERE EL.BK_SLS_TERR_ASSIGNMENT_TYPE_CD=NAOVRLYTV.BK_SLS_TERR_ASGNMT_TYPE_CD\r\n \t \tAND NSOL.LINE_CREATION_DATE BETWEEN EFFECTIVE_START_DATE AND EFFECTIVE_END_DATE)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
