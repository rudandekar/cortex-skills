      "attributes": {
        "Sql Query": "SELECT \r\nASGN.LAST_UPDATE_DATE,\r\nNVL2(ASGN.CLASS_CODE,'Y','N') REBOK_CHANNEL_FLAG,   /*  ADDED  AS PART OF  D1FY14*/\r\nSC.TERRITORY_TYPE_CODE,\r\nTRX_SC.TRX_SC_ID   \r\nFROM \r\n(SELECT * FROM $$NRTACCUMVWDB.XXOTM_PHX_TRX_SC \r\nQUALIFY ROW_NUMBER()  OVER(PARTITION BY TRX_SC_ID ORDER BY REFRESH_DATETIME DESC)=1) TRX_SC\r\nINNER JOIN\r\n(SELECT * FROM $$GGSRCVWDB.XXOTM_PHX_SALES_CREDITS\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY  SC_ID ORDER BY REFRESH_DATETIME DESC)=1) SC\r\nON TRX_SC.SC_ID=SC.SC_ID\r\nLEFT JOIN\r\n(SELECT * FROM $$GGSRCVWDB.XXOTM_PHX_CODE_ASSIGNMENTS\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY  CODE_ASSIGNMENT_ID ORDER BY REFRESH_DATETIME DESC)=1) ASGN\r\nON  ASGN.OWNER_TABLE_NAME ='XXOTM_PHX_TRX_SC'\r\nAND ASGN.CLASS_CATEGORY= 'XXOTM_PHX_CB_FLAG'\r\nAND TRX_SC.TRX_SC_ID=ASGN.OWNER_TABLE_ID\r\nWHERE ASGN.LAST_UPDATE_DATE>CAST('$$LastExtractDate' AS TIMESTAMP(0))-interval '2' hour\r\n/* QUALIFY ROW_NUMBER() OVER (PARTITION BY TRX_SC.TRX_SC_ID ORDER BY TRX_SC.LAST_UPDATE_DATE DESC)=1 */",
