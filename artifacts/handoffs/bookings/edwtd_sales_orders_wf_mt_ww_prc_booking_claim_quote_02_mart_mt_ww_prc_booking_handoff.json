        "Sql Query": "SELECT \r\n COALESCE(RU_BK_POS_TRANSACTION_ID_INT,-999) RU_BK_POS_TRANSACTION_ID_INT , \r\n COALESCE(DV_DEAL_CD,'') BK_DEAL_ID ,\r\n PRODUCT_KEY, \r\n DV_PROMOTION_CD, \r\n CURRENT_TIMESTAMP(0)  AS  EDW_CREATE_DTM,\r\n USER  AS EDW_CREATE_USER,\r\n CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n USER AS EDW_UPDATE_USER,\r\n ADJUSTMENT_TYPE_CD,\r\n DV_SOURCE_CD,\r\n DV_PROGRAM_CD,\r\n DV_DEAL_PROMOTION_CD,\r\n DV_DEAL_PROGRAM_CD,\r\n DV_SEQ_INT\r\nFROM \r\n(\r\n--Line Level Codes\r\nSELECT \r\n  booking.DV_SO_NUMBER_INT  RU_BK_POS_TRANSACTION_ID_INT , \r\n  CAST(booking.DV_DEAL_CD AS VARCHAR(50)) DV_DEAL_CD, \r\n  booking.PRODUCT_KEY PRODUCT_KEY, \r\n  CAST(case when Source_Reported_Promotion_Cd='UNKNOWN' then BK_Concession_Type_Name else Source_Reported_Promotion_Cd   end  AS VARCHAR(50)) DV_PROMOTION_CD, \r\n  CAST(booking.ADJUSTMENT_TYPE_CD AS CHAR(30)) ADJUSTMENT_TYPE_CD,\r\n  CAST( 'Quote Line Level' AS VARCHAR(20)) DV_SOURCE_CD  ,\r\n  CAST(NULL AS VARCHAR(200)) DV_PROGRAM_CD, \r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROMOTION_CD, \r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROGRAM_CD,\r\n  NULL DV_SEQ_INT\r\nFROM \r\n$$SLSORDVWDB.N_DEAL d\r\n  LEFT OUTER JOIN $$SLSORDVWDB.N_DEAL_QUOTE q\r\n    ON d.BK_DEAL_ID = q.BK_DEAL_ID \r\n\tand q.active_flg='Y'\r\n  LEFT OUTER JOIN $$SLSORDVWDB.N_DEAL_QUOTE_LINE ql\r\n    ON q.BK_QUOTE_NUM = ql.BK_QUOTE_NUM \r\n\tAND q.SS_CODE = ql.SS_CODE\r\n\tand ql.active_flg='Y'\r\n  LEFT OUTER JOIN $$SLSORDVWDB.N_DEAL_QUOTE_LINE_CONCESSION qlc\r\n    ON ql.BK_DEAL_QUOTE_LINE_KEY = qlc.BK_DEAL_QUOTE_LINE_KEY\r\n    AND ql.BK_QUOTE_NUM = qlc.BK_QUOTE_NUM\r\n  INNER JOIN $$SLSORDVWDB.MT_WW_PRC_BOOKING  booking\r\n     ON booking.DV_DEAL_CD=d.BK_Deal_ID \r\n\t and booking.PRODUCT_KEY=ql.PRODUCT_KEY\r\nWHERE \r\n  case when Source_Reported_Promotion_Cd='UNKNOWN' then BK_Concession_Type_Name else Source_Reported_Promotion_Cd end is not null\r\n  group by 1,2,3,4,5,6,7,8,9\r\n  \r\n--Deal Level Codes\r\nUNION ALL\r\nSELECT \r\n  booking.DV_SO_NUMBER_INT RU_BK_POS_TRANSACTION_ID_INT,\r\n  CAST(booking.DV_DEAL_CD AS VARCHAR(50)) DV_DEAL_CD,\r\n  booking.PRODUCT_KEY PRODUCT_KEY,\r\n  CAST(NULL AS VARCHAR(50)) DV_PROMOTION_CD,\r\n   CAST(booking.ADJUSTMENT_TYPE_CD AS CHAR(30)) ADJUSTMENT_TYPE_CD,\r\n  CAST('Quote Deal Level' AS VARCHAR(20)) DV_SOURCE_CD,\r\n  CAST(NULL AS VARCHAR(200)) DV_PROGRAM_CD,\r\n  CAST(COALESCE(dp.BK_PROMOTION_CD,\r\n           case when SOURCE_REPORTED_DEAL_TYPE_CD = 'Non-Standard Deal' then 'NON STANDARD OTHER' else SOURCE_REPORTED_DEAL_TYPE_CD end) AS VARCHAR(200)) DV_DEAL_PROMOTION_CD,\r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROGRAM_CD,\r\n  NULL DV_SEQ_INT\r\nFROM   $$SLSORDVWDB.N_DEAL d\r\n  LEFT OUTER JOIN ( SELECT BK_DEAL_ID, BK_PROMOTION_CD FROM $$SLSORDVWDB.N_DEAL_PROMOTION \r\n                  QUALIFY ROW_NUMBER () OVER (PARTITION BY BK_DEAL_ID, BK_PROMOTION_CD ORDER BY BK_PROMOTION_REVISION_NUM_INT DESC) = 1)dp\r\n    ON d.BK_DEAL_ID = dp.BK_DEAL_ID\r\n  INNER JOIN $$SLSORDVWDB.MT_WW_PRC_BOOKING  booking\r\n     ON booking.DV_DEAL_CD=d.BK_Deal_ID\r\n  group by 1,2,3,4,5,6,7,8,9\r\nhaving DV_DEAL_PROMOTION_CD is not null or DV_DEAL_PROMOTION_CD <> ''\r\n\r\n--Manual Claims\r\nUNION ALL\r\nSELECT \r\n  booking.DV_SO_NUMBER_INT RU_BK_POS_TRANSACTION_ID_INT, \r\n  CAST(booking.DV_DEAL_CD AS VARCHAR(50)) DV_DEAL_CD, \r\n  booking.PRODUCT_KEY PRODUCT_KEY,\r\n  CAST(min(claim.DISTI_PROMOTION_NUM) AS VARCHAR(50)) DV_PROMOTION_CD,\r\n  CAST(booking.ADJUSTMENT_TYPE_CD AS CHAR(30)) ADJUSTMENT_TYPE_CD,\r\n  CAST('Manual Claim' AS VARCHAR(20)) DV_SOURCE_CD,  \r\n  CAST(NULL AS VARCHAR(200)) DV_PROGRAM_CD, \r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROMOTION_CD, \r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROGRAM_CD,\r\n  NULL DV_SEQ_INT\r\nFROM \r\n$$SLSORDVWDB.N_DISTRIBUTOR_CLAIM_LINE claim\r\n  INNER JOIN $$SLSORDVWDB.MT_WW_PRC_BOOKING   booking \r\n    ON booking.DV_POS_TRX_ID_INT=claim.RU_BK_POS_TRANSACTION_ID_INT and booking.PRODUCT_KEY=claim.PRODUCT_KEY \r\nWHERE claim.CLAIM_DETAIL_STATUS_CD = 'VALID' AND\r\n  (claim.DISTI_PROMOTION_NUM IS NOT NULL or claim.DISTI_PROMOTION_NUM <> 'UNKNOWN') AND\r\n  claim.RU_BK_POS_TRANSACTION_ID_INT >0\r\n  group by 1,2,3,5,6,7,8,9\r\nHAVING DV_PROMOTION_CD is not null OR DV_PROMOTION_CD <> ''\r\n\r\n--Insert Claim Auth No\r\nUNION ALL\r\nSELECT \r\n  booking.DV_SO_NUMBER_INT RU_BK_POS_TRANSACTION_ID_INT , \r\n  CAST(booking.DV_DEAL_CD AS VARCHAR(50)) DV_DEAL_CD, \r\n  booking.PRODUCT_KEY PRODUCT_KEY, \r\n  CAST(booking.DV_CLAIM_AUTH_NAME AS VARCHAR(50)) DV_PROMOTION_CD,\r\n  CAST(booking.ADJUSTMENT_TYPE_CD AS CHAR(30)) ADJUSTMENT_TYPE_CD,\r\n  CAST('Claim Auth No' AS VARCHAR(20)) DV_SOURCE_CD,  \r\n  CAST(NULL AS VARCHAR(200)) DV_PROGRAM_CD, \r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROMOTION_CD,\r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROGRAM_CD,\r\n  NULL DV_SEQ_INT\r\nFROM \r\n  $$SLSORDVWDB.MT_WW_PRC_BOOKING  booking\r\nWHERE \r\n  (booking.DV_CLAIM_AUTH_NAME like 'PP-%' or\r\n  booking.DV_CLAIM_AUTH_NAME like 'CD-%' or\r\n  booking.DV_CLAIM_AUTH_NAME like 'PCON-%' or\r\n  booking.DV_CLAIM_AUTH_NAME like 'BR-%') and\r\n  DV_POS_TRX_ID_INT >0 \r\nGROUP BY 1,2,3,4,5,6,7,8,9\r\n\r\n--For Net Pricing Countries (IN, KR) use Disti Reported DID\r\nUNION ALL\r\nSELECT \r\n  booking.DV_SO_NUMBER_INT RU_BK_POS_TRANSACTION_ID_INT, --booking.POS_TRANSACTION_ID,\r\n  CAST(booking.DV_DEAL_CD AS VARCHAR(50)) DV_DEAL_CD, \r\n  booking.PRODUCT_KEY PRODUCT_KEY,\r\n  CAST(booking.DISTRIBUTOR_REPORTED_DEAL_ID AS VARCHAR(50)) DV_PROMOTION_CD,\r\n  CAST(booking.ADJUSTMENT_TYPE_CD AS CHAR(30)) ADJUSTMENT_TYPE_CD,\r\n  CAST('Net Country' AS VARCHAR(20)) DV_SOURCE_CD,\r\n  CAST(NULL AS VARCHAR(200)) DV_PROGRAM_CD,\r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROMOTION_CD,\r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROGRAM_CD,\r\n  NULL DV_SEQ_INT\r\nFROM \r\n  $$SLSORDVWDB.MT_WW_PRC_BOOKING  booking\r\n  inner join $$SLSORDVWDB.N_POS_ORIGINATOR_ORG disti  \r\n    on booking.DV_DISTRIBUTOR_ID_INT=disti.BK_WIPS_ORIGINATOR_ID_INT  \r\nWHERE \r\n  (booking.DISTRIBUTOR_REPORTED_DEAL_ID like 'PP-%' or\r\n  booking.DISTRIBUTOR_REPORTED_DEAL_ID like 'CD-%' or\r\n  booking.DISTRIBUTOR_REPORTED_DEAL_ID like 'PCON-%' or\r\n  booking.DISTRIBUTOR_REPORTED_DEAL_ID like 'BR-%') and\r\n  booking.DV_POS_TRX_ID_INT >0 and\r\n  disti.BK_ORIGINATOR_COUNTRY_CODE in ('IN', 'KR') \r\nGROUP BY 1,2,3,4,5,6,7,8,9\r\n\r\n--For DSV Booking not POS out\r\nUNION ALL\r\nSELECT \r\n  booking.DV_SO_NUMBER_INT RU_BK_POS_TRANSACTION_ID_INT, --DSV Booking dont have POST Trnx ID\r\n  CAST(booking.DV_DEAL_CD AS VARCHAR(50)) DV_DEAL_CD, \r\n  booking.PRODUCT_KEY PRODUCT_KEY,\r\n  CAST(booking.DV_DISTI_REPORTED_DEAL_CD AS VARCHAR(50)) DV_PROMOTION_CD, --For DSV Booking, Disti Reported DID is stored in BK_DEAL_ID column  \r\n  CAST(booking.ADJUSTMENT_TYPE_CD AS CHAR(30)) ADJUSTMENT_TYPE_CD,\r\n  CAST('DSV Booking' AS VARCHAR(20)) DV_SOURCE_CD,\r\n  CAST(NULL AS VARCHAR(200)) DV_PROGRAM_CD,\r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROMOTION_CD,\r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROGRAM_CD,\r\n  NULL DV_SEQ_INT\r\nFROM \r\n  $$SLSORDVWDB.MT_WW_PRC_BOOKING  booking\r\n  INNER JOIN $$SLSORDVWDB.N_POS_ORIGINATOR_ORG disti  \r\n    on booking.DV_DISTRIBUTOR_ID_INT=disti.BK_WIPS_ORIGINATOR_ID_INT  \r\nWHERE \r\n  (booking.DV_DISTI_REPORTED_DEAL_CD like 'PP-%' or\r\n    booking.DV_DISTI_REPORTED_DEAL_CD like 'CD-%' or\r\n    booking.DV_DISTI_REPORTED_DEAL_CD like 'PCON-%' or\r\n    booking.DV_DISTI_REPORTED_DEAL_CD like 'BR-%') and \r\n  booking.ADJUSTMENT_TYPE_CD = 'DSV Booking' and \r\n  booking.DV_POSTED_DT is null and\r\n  booking.DV_SO_NUMBER_INT>0\r\ngroup by 1,2,3,4,5,6,7,8,9\r\n\r\n--FT in WPL\r\nUNION ALL\r\nSELECT \r\n  booking.DV_SO_NUMBER_INT RU_BK_POS_TRANSACTION_ID_INT, --DSV Booking dont have POST Trnx ID\r\n  CAST(booking.DV_DEAL_CD AS VARCHAR(50)) DV_DEAL_CD, \r\n  booking.PRODUCT_KEY PRODUCT_KEY,\r\n  CAST(NULL AS VARCHAR(50)) DV_PROMOTION_CD,  \r\n  CAST(booking.ADJUSTMENT_TYPE_CD AS CHAR(30)) ADJUSTMENT_TYPE_CD,\r\n  CAST('FT in WPL' AS VARCHAR(20)) DV_SOURCE_CD,\r\n  CAST('Fast Track' AS VARCHAR(200)) DV_PROGRAM_CD, \r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROMOTION_CD, \r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROGRAM_CD,\r\n  NULL DV_SEQ_INT\r\nFROM \r\n  $$SLSORDVWDB.MT_WW_PRC_BOOKING  booking\r\n     --Fiscal\r\n  INNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR fiscal\r\n     ON booking.BOOKINGS_PROCESS_DT=fiscal.CALENDAR_DATE\r\n     --Share\r\n  INNER JOIN $$COMREFVWDB.R_SALES_HIERARCHY_ME share  \r\n     ON booking.SALES_TERRITORY_KEY=share.SALES_TERRITORY_KEY\r\n      --and share.AS_OF_DATE = case when fiscal.fiscal_year_number_int=2017 then 201701 else 201612 end \r\n  INNER JOIN $$COMREFVWDB.N_ISO_COUNTRY shareCtry  \r\n     ON shareCtry.BK_ISO_COUNTRY_CODE=share.ISO_COUNTRY_CODE  \r\n     --Product\r\n  INNER JOIN (SELECT RTP.PRODUCT_KEY ITEM_KEY, RPFIN.BK_PRODUCT_ID\r\n                FROM $$COMREFVWDB.R_PRODUCTS_FIN RPFIN \r\n              INNER JOIN $$COMREFVWDB.R_TRX_PRODUCT RTP\r\n              ON RPFIN.ITEM_KEY=RTP.PRODUCT_KEY) product  \r\n     ON booking.PRODUCT_KEY = product.ITEM_KEY  \r\n     --Disti\r\n  LEFT OUTER JOIN $$SLSORDVWDB.N_POS_ORIGINATOR_ORG disti  \r\n     ON booking.DV_DISTRIBUTOR_ID_INT=disti.BK_WIPS_ORIGINATOR_ID_INT  \r\n  LEFT OUTER JOIN $$COMREFVWDB.N_ISO_COUNTRY distiCtry  \r\n     ON disti.BK_ORIGINATOR_COUNTRY_CODE=distiCtry.ISO_COUNTRY_SHORT_CODE  \r\n     --FT AsWas\r\n  INNER JOIN $$APJPDATAVWDB.N_APSP_APJ_PRODUCT_PROMOTION ft\r\n     ON product.BK_PRODUCT_ID = ft.BK_PRODUCT_ID \r\n     and COALESCE(distiCtry.BK_ISO_COUNTRY_CODE, shareCtry.BK_ISO_COUNTRY_CODE) = ft.BK_ISO_COUNTRY_NAME\r\n      and fiscal.DV_FISCAL_QUARTER_ID=ft.BK_FISCAL_QTR_CD  \r\nWHERE \r\n  booking.ADJUSTMENT_TYPE_CD in ('DSV Booking','Regular POS', 'ERP')\r\ngroup by 1,2,3,4,5,6,7,8,9\r\n\r\n--WPL based on Base Discount\r\nUNION ALL\r\nSELECT \r\n  booking.DV_SO_NUMBER_INT RU_BK_POS_TRANSACTION_ID_INT, \r\n  CAST(booking.DV_DEAL_CD AS VARCHAR(50)) DV_DEAL_CD, \r\n  booking.PRODUCT_KEY PRODUCT_KEY,\r\n  CAST(NULL AS VARCHAR(50)) DV_PROMOTION_CD,  \r\n  CAST(booking.ADJUSTMENT_TYPE_CD AS CHAR(30)) ADJUSTMENT_TYPE_CD,\r\n  CAST('WPL' AS VARCHAR(20)) DV_SOURCE_CD,\r\n  CAST(NULL AS VARCHAR(200)) DV_PROGRAM_CD,\r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROMOTION_CD,\r\n  CAST(NULL AS VARCHAR(200)) DV_DEAL_PROGRAM_CD,\r\n  NULL DV_SEQ_INT\r\nFROM \r\n  $$SLSORDVWDB.MT_WW_PRC_BOOKING  booking\r\n  INNER JOIN $$COMREFVWDB.N_PRODUCT product\r\n    on booking.PRODUCT_KEY=product.ITEM_KEY\r\nWHERE \r\n  booking.DV_BOOK_NET_AMT >= (1-product.BASE_DISCOUNT_PCT/100)*booking.DV_BOOK_LIST_AMT and\r\n  booking.DV_BOOK_NET_AMT >0 and booking.DV_BOOK_LIST_AMT >0 and booking.DV_BOOK_QTY >0 \r\n  and booking.DV_BOOK_NET_AMT < booking.DV_BOOK_LIST_AMT and\r\n  booking.DV_SO_NUMBER_INT>0\r\ngroup by 1,2,3,4,5,6,7,8,9) a",
        "User Defined Join": "",
