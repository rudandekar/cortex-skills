      "attributes": {
        "Sql Query": "SELECT \r\n\t  SMAR.SUBSCR_AUTO_RNWL_CHANGE_KEY AS SUBSCR_AUTO_RNWL_CHANGE_KEY ,\r\n\t  SUBUI_AR.WEB_ORDER_ID AS BK_WEB_ORDER_ID,\r\n\t  COALESCE(SUBUI_AR.SUBSCRIPTION_REFERENCE_ID,'UNKNOWN') AS BK_SUBSCRIPTION_REF_ID,\r\n\t  COALESCE(SUBUI_AR.TRANSACTION_TYPE,'UNKNOWN') AS BK_TRX_TYPE_NAME,\r\n      COALESCE(SUBUI_AR.TRANSACTION_SUB_TYPE,'UNKNOWN') AS BK_TRX_SUB_TYPE_NAME,\r\n\t  COALESCE(SUBUI_AR.SK_SUBUI_REF_TRANSACTION_ID,-999) AS SK_SUBUI_TRX_ID,\r\n      COALESCE(SUBUI_AR.SUBSCRIPTION_CODE,'UNKNOWN') AS SUBSCRIPTION_CD,\r\n\t  COALESCE(SUBUI_AR.TIER1_REASON_DESCRIPTION,'UNKNOWN') AS TIER_1_REASON_DESCR,\r\n\t  COALESCE(SUBUI_AR.TIER2_REASON_DESCRIPTION,'UNKNOWN') AS TIER_2_REASON_DESCR,\r\n\t  COALESCE(SUBUI_AR.COMMENTS,'UNKNOWN') AS COMMENTS_TXT,\r\n      COALESCE(SUBUI_AR.TIER1_REASON_CODE,'UNKNOWN') AS TIER_1_REASON_CD,\r\n      COALESCE(SUBUI_AR.TIER2_REASON_CODE,'UNKNOWN') AS TIER_2_REASON_CD,\r\n      CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\n\t  USER AS  EDW_CREATE_USER,\r\n\t  CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n      USER AS  EDW_UPDATE_USER,\r\n\t  COALESCE(SUBUI_AR.ADDITIONAL_INFO,'UNKNOWN') AS AUTO_RNWL_ADDNL_INFO_TXT ,/*Q4 FY21 Annuity REl*/\r\n\t  'I' AS ACTION_CODE,\r\n      CASE WHEN ( NSAR.SUBSCR_AUTO_RNWL_CHANGE_KEY IS NULL) THEN 'I' ELSE 'U' END AS DML_TYPE\r\n\r\n\tFROM \r\n    $$STGDB.ST_SUBUI_AR_TRANSACTIONS SUBUI_AR   \r\n    INNER JOIN $$ETLVWdb.SM_SUBSCR_AUTO_RNWL_CHG SMAR ON\r\n          SUBUI_AR.SK_SUBUI_REF_TRANSACTION_ID=SMAR.SK_SUBUI_TRX_ID\r\n     AND  SUBUI_AR.WEB_ORDER_ID=SMAR.BK_WEB_ORDER_ID\r\n\t    LEFT JOIN $$SLSORDDB.N_SUBSCR_AUTO_RNWL_CHG NSAR\r\n  ON NSAR.SUBSCR_AUTO_RNWL_CHANGE_KEY=SMAR.SUBSCR_AUTO_RNWL_CHANGE_KEY",
        "User Defined Join": "",
