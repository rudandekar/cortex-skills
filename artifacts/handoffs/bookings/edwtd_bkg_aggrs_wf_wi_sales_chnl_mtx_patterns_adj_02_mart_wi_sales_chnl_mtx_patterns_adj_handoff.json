      "attributes": {
        "Sql Query": "SELECT \r\n  SALES_TERRITORY_KEY,\r\n  SOLD_TO_CUSTOMER_KEY,\r\n  END_CUSTOMER_KEY,\r\n  BILL_TO_CUSTOMER_KEY,\r\n  EDW_CREATE_USER,\r\n  EDW_CREATE_DATETIME,\r\n  SHIP_TO_CUSTOMER_KEY\r\n FROM    $$STGDB.WI_CHNL_PATTERN_BKG_SLS_ADJ\r\n \r\n     QUALIFY ROW_NUMBER () OVER (PARTITION BY \r\n      SOLD_TO_CUSTOMER_KEY,\r\n      END_CUSTOMER_KEY,\r\n      BILL_TO_CUSTOMER_KEY,\r\n      SALES_TERRITORY_KEY,\r\n\t  SHIP_TO_CUSTOMER_KEY\r\n   \r\n   ORDER BY PROCESS_DATE DESC )  =1",
