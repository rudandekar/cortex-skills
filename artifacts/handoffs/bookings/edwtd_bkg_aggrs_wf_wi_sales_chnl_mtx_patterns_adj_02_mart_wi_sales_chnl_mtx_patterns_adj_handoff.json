      "attributes": {
        "Sql Query": "SELECT\r\n N_BOOKINGS_MEASURE.SALES_TERRITORY_KEY  ,         \r\nN_BOOKINGS_MEASURE.SOLD_TO_CUSTOMER_KEY,\r\nN_BOOKINGS_MEASURE.END_CUSTOMER_KEY,\r\nN_BOOKINGS_MEASURE.BILL_TO_CUSTOMER_KEY,\r\nN_BOOKINGS_MEASURE.BOOKINGS_PROCESS_DATE,\r\n  USER,\r\n  CURRENT_TIMESTAMP(0),\r\nN_BOOKINGS_MEASURE.SHIP_TO_CUSTOMER_KEY  \r\nFROM\r\n$$SLSORDVWDB.N_BOOKINGS_MEASURE N_BOOKINGS_MEASURE\r\n --INNER JOIN $$STGDB.WI_PROCESS_DATES_CHNL_MTX_ADJ NFM_CURR\r\n  /*ON NDNBT.PROCESS_DATE = BK_CALENDAR_DATE */\r\n -- ON N_BOOKINGS_MEASURE.BOOKINGS_PROCESS_DATE = BK_CALENDAR_DATE \r\n  \r\n WHERE N_BOOKINGS_MEASURE.SALES_CHANNEL_CODE <> 'DVAD' \r\n AND BKGS_MEASURE_TRANS_TYPE_CODE='SLS_ADJ'\r\n AND SALES_ADJUSTMENT_SOURCE_CODE  NOT IN ('PPP','CPI')\r\n\r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY \r\n  N_BOOKINGS_MEASURE.SALES_TERRITORY_KEY  ,         \r\nN_BOOKINGS_MEASURE.SOLD_TO_CUSTOMER_KEY,\r\nN_BOOKINGS_MEASURE.END_CUSTOMER_KEY,\r\nN_BOOKINGS_MEASURE.BILL_TO_CUSTOMER_KEY,\r\nN_BOOKINGS_MEASURE.BOOKINGS_PROCESS_DATE,\r\nN_BOOKINGS_MEASURE.SHIP_TO_CUSTOMER_KEY\r\n   ORDER BY N_BOOKINGS_MEASURE.BOOKINGS_PROCESS_DATE DESC \r\n   )  =1",
