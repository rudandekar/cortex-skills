        {
          "name": "EDW_CREATE_USER",
          "datatype": "string",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "SELECT \r\n RANK() OVER (ORDER BY SK_SUBUI_REF_TRANSACTION_ID,WEB_ORDER_ID) + SMAR.MAX_KEY AS SUBSCR_AUTO_RNWL_CHANGE_KEY,\r\n WEB_ORDER_ID AS BK_WEB_ORDER_ID,\r\n SK_SUBUI_REF_TRANSACTION_ID AS SK_SUBUI_TRX_ID, \r\n CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\n USER AS  EDW_CREATE_USER\r\n FROM \r\n (SELECT * FROM $$STGDB.ST_SUBUI_AR_TRANSACTIONS  \r\n QUALIFY ROW_NUMBER() OVER (PARTITION BY SK_SUBUI_REF_TRANSACTION_ID,WEB_ORDER_ID ORDER BY EDW_CREATE_DTM DESC)=1) SUAR ,\r\n (SELECT COALESCE(MAX(SUBSCR_AUTO_RNWL_CHANGE_KEY),0 )  MAX_KEY FROM  $$ETLVWdb.SM_SUBSCR_AUTO_RNWL_CHG) SMAR\r\n WHERE  NOT EXISTS \r\n ( SELECT 1 FROM $$ETLVWdb.SM_SUBSCR_AUTO_RNWL_CHG SMART\r\n WHERE SUAR.SK_SUBUI_REF_TRANSACTION_ID=SMART.SK_SUBUI_TRX_ID\r\n AND  SUAR.WEB_ORDER_ID=SMART.BK_WEB_ORDER_ID\r\n )",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
