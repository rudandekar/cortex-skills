      "attributes": {
        "Sql Query": "SELECT \r\n\t  COALESCE(SUBUI_AR.SK_SUBUI_REF_TRANSACTION_ID,-999) AS SK_SUBUI_REF_TRANSACTION_ID ,\r\n      SUBUI_AR.TRANSACTION_TYPE,\r\n      SUBUI_AR.TRANSACTION_SUB_TYPE,\r\n      SUBUI_AR.SUBSCRIPTION_REFERENCE_ID ,\r\n      SUBUI_AR.SUBSCRIPTION_CODE ,\r\n      SUBUI_AR.TIER1_REASON_CODE ,\r\n      SUBUI_AR.TIER1_REASON_DESCRIPTION ,\r\n      SUBUI_AR.COMMENTS,\r\n      SUBUI_AR.TIER2_REASON_CODE,\r\n      SUBUI_AR.TIER2_REASON_DESCRIPTION ,\r\n      COALESCE(SUBUI_AR.WEB_ORDER_ID,'UNKNOWN') AS WEB_ORDER_ID,\r\n      CAST(CAST(SUBUI_AR.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) EDW_CREATE_DTM,\r\n\t  SUBUI_AR.ADDITIONAL_INFO /* Q4FY21 Annuity Rel*/\r\n\tFROM \r\n   (SEL * FROM $$ETLVWDB.ST_SI_SUBUI_AR_TRANSACTIONS    \r\n   QUALIFY ROW_NUMBER() OVER (PARTITION BY SUBSCRIPTION_REFERENCE_ID,SUBSCRIPTION_CODE,WEB_ORDER_ID ORDER BY EDW_CREATE_DTM DESC)=1) SUBUI_AR\r\n   WHERE \r\n   CAST(CAST(SUBUI_AR.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) \r\n   >CAST('$$LastExtractDate' AS TIMESTAMP(0))",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
