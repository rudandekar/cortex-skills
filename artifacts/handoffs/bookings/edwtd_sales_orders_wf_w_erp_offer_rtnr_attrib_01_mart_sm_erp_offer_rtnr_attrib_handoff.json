      "attributes": {
        "Sql Query": "SELECT \r\n  RANK() OVER (ORDER BY RTNR_UNIQUE_ID) + SXSB.MAX_KEY AS OFFER_ATTRIB_ACV_RTNR_ERP_KEY,\r\n  RTNR_UNIQUE_ID(CASESPECIFIC), \r\n  CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\n  USER AS  EDW_CREATE_USER\r\n  FROM \r\n  (SELECT * FROM $$STGDB.WI_ERP_OFFER_RTNR_ATTRIB where RTNR_UNIQUE_ID<>'  -999')WIERP ,\r\n (SELECT COALESCE(MAX(OFFER_ATTRIB_ACV_RTNR_ERP_KEY),60000000000001 )   MAX_KEY FROM  $$TRANSLATIONDB.SM_ERP_OFFER_RTNR_ATTRIB) SXSB\r\n  WHERE  NOT EXISTS \r\n  ( \r\n  SELECT 1 FROM $$TRANSLATIONDB.SM_ERP_OFFER_RTNR_ATTRIB SMERP\r\n  WHERE WIERP.RTNR_UNIQUE_ID=SMERP.RTNR_UNIQUE_ID \r\n  )",
