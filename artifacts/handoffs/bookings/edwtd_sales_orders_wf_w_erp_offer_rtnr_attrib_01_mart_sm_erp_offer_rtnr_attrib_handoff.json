      "attributes": {
        "Sql Query": "SELECT\r\n TV_OUTPUT.OFFER_ATTRIB_ACV_RTNR_ERP_KEY\r\n,TV_OUTPUT.BK_OFFER_ATTRIBUTION_ID_INT\r\n,TV_OUTPUT.ATTRIBUTION_SS_CD \r\n,TV_OUTPUT.DV_TOPSKU_SALES_ORDER_LINE_KEY\r\n,TV_OUTPUT.ATTR_PRDT_AS_NEW_OR_RNWL_KEY\r\n,TV_OUTPUT.DV_ATTRIBUTION_CD \r\n,TV_OUTPUT.ATTRIBUTION_PCT  \r\n,TV_OUTPUT.RTNR_UNIQUE_ID \r\n,TV_OUTPUT.SALES_MOTION_CD\r\n,TV_OUTPUT.SK_RTNR_ATTRIBUTION_ID_INT \r\n,TV_OUTPUT.SK_TRX_ID_INT \r\n,TV_OUTPUT.SALES_ORDER_LINE_KEY \r\n,TV_OUTPUT.TRANSACTION_TYPE_NAME\r\n,TV_OUTPUT.PRODUCT_KEY\r\n,TV_OUTPUT.DV_TOP_SKU_PRODUCT_KEY\r\n,TV_OUTPUT.ENTERPRISE_SKU_PRDT_KEY\r\n,TV_OUTPUT.DV_ALLOCATION_PCT  \r\n,-999 AS SK_SALES_MOTION_ATTRIB_KEY\r\n,TV_OUTPUT.START_TV_DTM\r\n,COALESCE(MAX (CAST( TV_OUTPUT.START_TV_DTM AS TIMESTAMP(0)) - INTERVAL '1' SECOND) Over (PARTITION BY TV_OUTPUT.OFFER_ATTRIB_ACV_RTNR_ERP_KEY\r\nORDER BY TV_OUTPUT.START_TV_DTM ASC ROWS BETWEEN 1 Following AND 1 Following), CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))) AS END_TV_DTM\r\n,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM\r\n,USER  EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0) AS  EDW_UPDATE_DTM\r\n,USER EDW_UPDATE_USER\r\n,'N' ACTION_CODE\r\n,(CASE WHEN ROW_NUMBER () Over (PARTITION BY TV_OUTPUT.OFFER_ATTRIB_ACV_RTNR_ERP_KEY  ORDER BY TV_OUTPUT.START_TV_DTM ASC) = 1 AND  NERP.OFFER_ATTRIB_ACV_RTNR_ERP_KEY IS NOT NULL \r\n THEN 'U' ELSE 'I' END) AS DML_TYPE \r\nFROM\r\n(\r\n\tSELECT\r\n   TV_INPUT.OFFER_ATTRIB_ACV_RTNR_ERP_KEY\r\n   ,TV_INPUT.BK_OFFER_ATTRIBUTION_ID_INT\r\n   ,TV_INPUT.ATTRIBUTION_SS_CD \r\n   ,TV_INPUT.DV_TOPSKU_SALES_ORDER_LINE_KEY\r\n   ,TV_INPUT.ATTR_PRDT_AS_NEW_OR_RNWL_KEY\r\n   ,TV_INPUT.DV_ATTRIBUTION_CD\r\n   ,TV_INPUT.ATTRIBUTION_PCT\r\n   ,TV_INPUT.RTNR_UNIQUE_ID\r\n   ,TV_INPUT.SALES_MOTION_CD\r\n   ,TV_INPUT.SK_RTNR_ATTRIBUTION_ID_INT\r\n   ,TV_INPUT.SK_TRX_ID_INT\r\n   ,TV_INPUT.SALES_ORDER_LINE_KEY\r\n   ,TV_INPUT.TRANSACTION_TYPE_NAME\r\n   ,TV_INPUT.PRODUCT_KEY\r\n   ,TV_INPUT.DV_TOP_SKU_PRODUCT_KEY\r\n   ,TV_INPUT.ENTERPRISE_SKU_PRDT_KEY\r\n   ,TV_INPUT.DV_ALLOCATION_PCT  \r\n   ,TV_INPUT.START_TV_DTM\r\n\tFROM\r\n\t(\r\n\t\tSELECT\r\n   SM.OFFER_ATTRIB_ACV_RTNR_ERP_KEY\r\n   ,WI.BK_OFFER_ATTRIBUTION_ID_INT\r\n   ,WI.ATTRIBUTION_SS_CD \r\n   ,WI.DV_TOPSKU_SALES_ORDER_LINE_KEY\r\n   ,WI.ATTR_PRDT_AS_NEW_OR_RNWL_KEY\r\n   ,WI.DV_ATTRIBUTION_CD\r\n   ,WI.ATTRIBUTION_PCT\r\n   ,WI.RTNR_UNIQUE_ID\r\n   ,WI.SALES_MOTION_CD\r\n   ,WI.SK_RTNR_ATTRIBUTION_ID_INT\r\n   ,WI.SK_TRX_ID_INT\r\n   ,WI.SALES_ORDER_LINE_KEY\r\n   ,WI.TRANSACTION_TYPE_NAME\r\n   ,WI.PRODUCT_KEY\r\n   ,WI.DV_TOP_SKU_PRODUCT_KEY\r\n   ,WI.ENTERPRISE_SKU_PRDT_KEY\r\n   ,WI.DV_ALLOCATION_PCT  \r\n   ,WI.START_TV_DTM\r\n\t\tFROM\r\n\t\t$$STGDB.WI_ERP_OFFER_RTNR_ATTRIB WI\r\n\t\tINNER JOIN $$ETLVWDB.SM_ERP_OFFER_RTNR_ATTRIB SM\r\n\t\tON SM.RTNR_UNIQUE_ID=WI.RTNR_UNIQUE_ID\r\n\r\n\t\tUNION ALL\r\n\r\n\t\tSELECT\r\n    NERP.OFFER_ATTRIB_ACV_RTNR_ERP_KEY\r\n   ,NERP.BK_OFFER_ATTRIBUTION_ID_INT\r\n   ,NERP.ATTRIBUTION_SS_CD \r\n   ,NERP.DV_TOPSKU_SALES_ORDER_LINE_KEY\r\n   ,NERP.ATTR_PRDT_AS_NEW_OR_RNWL_KEY\r\n   ,NERP.DV_ATTRIBUTION_CD\r\n   ,NERP.ATTRIBUTION_PCT\r\n   ,NERP.RTNR_UNIQUE_ID\r\n   ,NERP.SALES_MOTION_CD\r\n   ,NERP.SK_RTNR_ATTRIBUTION_ID_INT\r\n   ,NERP.SK_TRX_ID_INT\r\n   ,NERP.SALES_ORDER_LINE_KEY\r\n   ,NERP.TRANSACTION_TYPE_NAME\r\n   ,NERP.PRODUCT_KEY\r\n   ,NERP.DV_TOP_SKU_PRODUCT_KEY\r\n   ,NERP.ENTERPRISE_SKU_PRDT_KEY\r\n   ,NERP.DV_ALLOCATION_PCT  \r\n   ,NERP.START_TV_DTM\r\n\t\tFROM\r\n\t\t$$SLSORDVWDB.N_ERP_OFFER_RTNR_ATTRIB_TV NERP\r\n\t\tWHERE EXISTS (SELECT 1 FROM $$STGDB.WI_ERP_OFFER_RTNR_ATTRIB WIERP  WHERE \r\n\t\t\t\t\t\tWIERP.DV_TOPSKU_SALES_ORDER_LINE_KEY=NERP.DV_TOPSKU_SALES_ORDER_LINE_KEY\r\n\t\t\t\t\t\t-- AND WIERP.BK_OFFER_ATTRIBUTION_ID_INT=NERP.BK_OFFER_ATTRIBUTION_ID_INT\r\n\t\t\t\t\t\t)\r\n\t\t\t\t\t\tAND NERP.END_TV_DTM='3500-01-01 00:00:00'\r\n\t)TV_INPUT\r\n\tQUALIFY ROW_NUMBER () OVER (PARTITION BY TV_INPUT.OFFER_ATTRIB_ACV_RTNR_ERP_KEY, TV_INPUT.START_TV_DTM \r\n    ORDER BY TV_INPUT.START_TV_DTM DESC) = 1\r\n)TV_OUTPUT\r\nLEFT JOIN \r\n$$SLSORDVWDB.N_ERP_OFFER_RTNR_ATTRIB_TV NERP\r\nON NERP.OFFER_ATTRIB_ACV_RTNR_ERP_KEY=TV_OUTPUT.OFFER_ATTRIB_ACV_RTNR_ERP_KEY\r\nAND NERP.END_TV_DTM=CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))",
        "User Defined Join": "",
