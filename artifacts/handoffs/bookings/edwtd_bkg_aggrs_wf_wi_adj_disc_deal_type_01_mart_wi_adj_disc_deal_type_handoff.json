      ],
      "attributes": {
        "Sql Query": "SELECT \r\n-9999 AS BK_QUOTE_NUM,\r\nQUOTE.BK_DEAL_ID AS DEAL_ID,  \r\nCASE WHEN TRIM(DEAL.DEAL_TYPE) ='7' OR TRIM(DEAL.DEAL_TYPE) ='5' OR TRIM(DEAL.DEAL_TYPE) ='2' THEN 'MDM'\r\n WHEN  TRIM(DEAL.DEAL_TYPE) ='1' THEN 'SFDC'\r\n WHEN  TRIM(DEAL.DEAL_TYPE) ='3' THEN 'PDR' \r\n WHEN  TRIM(DEAL.DEAL_TYPE) ='4' THEN 'ICW'\r\n WHEN  TRIM(DEAL.DEAL_TYPE) ='6' THEN'Converted Deal'\r\n ELSE 'Unspecified' END  AS BOM_SOURCE_CD,\r\nQUOTE.INCREMENTAL_DISCOUNT_FLG    AS STD_INCR_FLG,\r\nSOURCE_REPORTED_DEAL_TYPE_CD,\r\nCASE WHEN TRIM(DEAL.DEAL_TYPE)='1' THEN 'SFDC'\r\nWHEN TRIM(DEAL.DEAL_TYPE)='2' THEN 'MDM'\r\nWHEN TRIM(DEAL.DEAL_TYPE)='3' THEN 'PDR'\r\nWHEN TRIM(DEAL.DEAL_TYPE)='4' THEN 'ICW'\r\nWHEN TRIM(DEAL.DEAL_TYPE)='5' THEN 'Converted Deal'\r\nWHEN TRIM(DEAL.DEAL_TYPE)='6' THEN 'Converted Deal'\r\nWHEN TRIM(DEAL.DEAL_TYPE)='6' THEN 'Disti Exception Deal'\r\nWHEN TRIM(DEAL.DEAL_TYPE)='7' THEN 'SMB'\r\nELSE 'Unspecified' END DEAL_SUBTYPE,\r\nGDR_FLG,\r\nDEAL_PROM.BK_PROMOTION_CD,\r\nCHANNEL_PROGRAM_NAME,\r\nPROMOTION_NAME,\r\nREUSABLE_NON_STNDRD_DSCNT_ROLE  RNSD_FLG,\r\nSUM(CASE WHEN (QUOTE_LINE.ACTIVE_FLG='Y' AND QUOTE.ACTIVE_FLG ='Y' AND DEAL.SOURCE_REPORTED_DEAL_TYPE_CD <>'Standard Deal') THEN (NON_STANDARD_DISCOUNT_USD_AMT) ELSE 0 END )NON_STANDARD_DISCOUNT_USD_AMT,\r\nCASE WHEN QUOTE.BK_DEAL_ID<>QUOTE.DV_RNSD_PARENT_ID \r\nAND COALESCE(QUOTE.REUSABLE_NON_STNDRD_DSCNT_ROLE,'N')='N' \r\nTHEN 'Y' ELSE 'N' END   TRANSCATION_RNSD_FLG,\r\n'N' SOURCE_MDM_FLG,\r\n'N' NON_STD_DISC_FLG,\r\n'N' NON_STD_CON_FLG,\r\nCAST ('Standard' as VARCHAR(20)) DEAL_TYPE\r\nFROM $$SLSORDVWDB.N_DEAL_QUOTE    QUOTE\r\nINNER JOIN $$SLSORDVWDB.N_DEAL DEAL\r\nON  QUOTE.BK_DEAL_ID=DEAL.BK_DEAL_ID \t \r\nAND   ( QUOTE.IS_FINALIZED_FLG = 'Y' OR  QUOTE.IS_STRINGENT_FLG = 'Y')\r\nAND QUOTE.ACTIVE_FLG ='Y'\r\nLEFT OUTER JOIN $$SLSORDVWDB.N_DEAL_QUOTE_LINE    QUOTE_LINE   \r\nON QUOTE.BK_QUOTE_NUM=QUOTE_LINE.BK_QUOTE_NUM\r\nLEFT OUTER JOIN $$SLSORDVWDB.N_DEAL_PROMOTION  DEAL_PROM\r\nON DEAL_PROM.BK_DEAL_ID=QUOTE.BK_DEAL_ID\r\nAND (DEAL_PROM.BK_DEAL_ID, DEAL_PROM.BK_PROMOTION_REVISION_NUM_INT )\r\nIN (SELECT BK_DEAL_ID, MAX(BK_PROMOTION_REVISION_NUM_INT) FROM $$SLSORDVWDB.N_DEAL_PROMOTION GROUP BY BK_DEAL_ID)\r\nLEFT OUTER JOIN $$SLSORDVWDB.N_PROMOTION PROM\r\nON  PROM.BK_PROMOTION_CD               =DEAL_PROM.BK_PROMOTION_CD     \r\nAND PROM.BK_PROMOTION_REVISION_NUM_INT=DEAL_PROM.BK_PROMOTION_REVISION_NUM_INT\r\nGROUP BY \r\nQUOTE.BK_DEAL_ID ,  \r\nBOM_SOURCE_CD,\r\nQUOTE.INCREMENTAL_DISCOUNT_FLG,\r\nSOURCE_REPORTED_DEAL_TYPE_CD,\r\nDEAL.DEAL_TYPE,\r\nGDR_FLG,\r\nDEAL_PROM.BK_PROMOTION_CD,\r\nCHANNEL_PROGRAM_NAME,\r\nPROMOTION_NAME,\r\nRNSD_FLG,\r\nTRANSCATION_RNSD_FLG",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
  ],
