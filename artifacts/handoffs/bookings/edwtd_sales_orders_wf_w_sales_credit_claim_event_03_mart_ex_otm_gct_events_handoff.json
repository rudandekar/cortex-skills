      "attributes": {
        "Sql Query": "SELECT\r\nSSCC.SALES_CREDIT_CLAIM_EVENT_KEY  AS SALES_CREDIT_CLAIM_EVENT_KEY\r\n,COALESCE(NLDR.LDAP_USER_ID,'UNKNOWN') AS CLAIM_EVENT_DONE_BY_USER_ID   \r\n,NSCC.BK_SALES_CREDIT_CLAIM_ID_INT AS BK_SALES_CREDIT_CLAIM_ID_INT  \r\n,CREATED_DATE                  AS CLAIM_EVENT_DTM               \r\n,EVENT_DESCRIPTION             AS CLAIM_EVENT_TYPE_DESCR        \r\n,EVENT_ID                      AS SK_EVENT_ID_INT\r\n,CURRENT_TIMESTAMP(0) \t\t\tEDW_CREATE_DTM\r\n,USER  \t\t\t\t\tEDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0) \t\t\tEDW_UPDATE_DTM\r\n,USER  \t\t\t\t\tEDW_UPDATE_USER\r\n,'I'\t\t\t\tACTION_CODE\r\n,'='\t\t\t\t\tDML_TYPE               \r\nFROM $$STGDB.ST_OTM_GCT_EVENTS SOGE\r\nINNER JOIN $$ETLVWDB.SM_SALES_CREDIT_CLAIM_EVENT SSCC\r\nON SOGE.EVENT_ID=SSCC.SK_EVENT_ID_INT\r\nLEFT JOIN $$SERVICEVWDB.N_LDAP_USER NLDR\r\nON NLDR.LDAP_USER_ID=SOGE.CREATED_BY\r\nINNER JOIN $$SLSORDVWDB.N_SALES_CREDIT_CLAIM NSCC\r\nON SOGE.CLAIM_ID=NSCC.BK_SALES_CREDIT_CLAIM_ID_INT",
