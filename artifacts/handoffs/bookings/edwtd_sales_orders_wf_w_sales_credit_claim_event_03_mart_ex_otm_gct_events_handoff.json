      "attributes": {
        "Sql Query": "SELECT\r\nEVENT_ID,                      \r\nCLAIM_ID,                      \r\nCREATED_BY,                    \r\nCREATED_DATE,                  \r\nEVENT_DESCRIPTION,       \r\nBATCH_ID,                      \r\nCREATE_DATETIME   \r\nFROM \r\n$$EXCEPDB.EX_OTM_GCT_EVENTS EOGE\r\nWHERE EOGE.EXCEPTION_TYPE='RI'  AND NOT EXISTS\r\n(\r\nSELECT 1 FROM $$STGDB.ST_OTM_GCT_EVENTS SOGE\r\nWHERE SOGE.EVENT_ID=EOGE.EVENT_ID)",
