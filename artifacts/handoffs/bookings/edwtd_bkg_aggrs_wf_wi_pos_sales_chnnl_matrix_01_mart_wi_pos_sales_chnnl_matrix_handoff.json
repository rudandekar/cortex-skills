      "attributes": {
        "Sql Query": "SELECT \r\n\t BK_SOLD_TO_WIPS_SITE_USE_KEY\tSOLD_TO_CUSTOMER_KEY\r\n\t,DV_BK_END_USER_SITE_USE_KEY\tDV_END_CUSTOMER_KEY\r\n\t,DSI.SALES_TERRITORY_KEY\r\n\t\r\n\t,CASE WHEN CDW.BCF_PARTNER_SITE_PARTY_KEY IS NOT NULL THEN CDW.BCF_PARTNER_SITE_PARTY_KEY \r\n\tWHEN PARTNER_SITE_PARTY_KEY_INT = -999 THEN -999 \r\n\t\tELSE CASE WHEN PARTNER_SITE_PARTY_KEY_INT = DV_END_CUSTOMER_PARTY_KEY THEN PARTNER_SITE_PARTY_KEY_INT \r\n\t\t\tELSE CASE WHEN PARTNER_COUNTRY = DV_END_CUST_COUNTRY THEN  PARTNER_SITE_PARTY_KEY_INT \r\n\t\t\tELSE CASE WHEN DROP_SHIP_PARTY_SITE_KEY = -999 THEN PARTNER_SITE_PARTY_KEY_INT \r\n\t\t\t\tELSE DROP_SHIP_PARTY_SITE_KEY \r\n\t\t\tEND\r\n\t\t\tEND\r\n\t\tEND\r\n\tEND AS PARTNER_PARTY_SITE_KEY\r\n\t\r\n\t,CASE \tWHEN PARTNER_SITE_PARTY_KEY_INT = -999 THEN 'N' \r\n\t\tELSE CASE WHEN PARTNER_SITE_PARTY_KEY_INT = DV_END_CUSTOMER_PARTY_KEY THEN 'N' \r\n\t\tELSE CASE WHEN DV_END_CUST_COUNTRY = 'UNK' THEN 'N'\r\n\t\tELSE CASE WHEN PARTNER_COUNTRY = DV_END_CUST_COUNTRY THEN  'N' \r\n\t\t\tELSE 'Y' \r\n\t\tEND\r\n\t\tEND\r\n\t\tEND\r\n\tEND AS CHANNEL_DROP_SHIP_FLG\r\n\t\r\n\t,CASE WHEN RSH.L1_SALES_TERRITORY_NAME_CODE ='WW Distribution' THEN 'N' ELSE 'Y' END AS \tCHANNEL_BOOKINGS_FLG\r\n\t,USER EDW_CREATE_USER\r\n\t,CURRENT_TIMESTAMP(0)\tEDW_CREATE_DATETIME\r\n\t,DSI.BK_WIPS_ORIGINATOR_ID_INT AS BK_WIPS_ORIGINATOR_ID_INT\r\n    ,BK_SHIP_TO_WIPS_SITE_USE_KEY AS SHIP_TO_CUSTOMER_KEY\t\r\n\tFROM $$STGDB.WI_INC_POS_PART_DROP_SHIP  DSI\r\n\t\t\r\n\tINNER JOIN $$COMREFVWDB.R_SALES_HIERARCHY  RSH\r\n\tON DSI.SALES_TERRITORY_KEY = RSH.SALES_TERRITORY_KEY\r\n\t\r\n\tLEFT JOIN $$STGDB.WI_CDW_PSPK CDW\r\n    ON DSI.BK_WIPS_ORIGINATOR_ID_INT=CDW.BK_WIPS_ORIGINATOR_ID_INT",
