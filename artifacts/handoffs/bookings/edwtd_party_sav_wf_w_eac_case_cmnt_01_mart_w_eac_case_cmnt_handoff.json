      "attributes": {
        "Sql Query": "SELECT \r\nST_XXFSAM_EAC_CASE_COMMENTS_V.COMMENT_ID, \r\nCOALESCE(NCWP_CRTD.CISCO_WORKER_PARTY_KEY,-999) AS CRTD_BY_CSCO_WRKR_PRTY_KEY, \r\nST_XXFSAM_EAC_CASE_COMMENTS_V.CASE_ID, \r\nCOALESCE(ST_XXFSAM_EAC_CASE_COMMENTS_V.TEXT,'UNKNOWN'), \r\nCOALESCE(ST_XXFSAM_EAC_CASE_COMMENTS_V.COMMENT_LAST_UPDATE_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))),\r\nCOALESCE(ST_XXFSAM_EAC_CASE_COMMENTS_V.COMMENT_LAST_UPDATE_DATE,CAST('3500-01-01' AS DATE)),\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\n'I' ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM\r\n$$STGDB.ST_XXFSAM_EAC_CASE_COMMENTS_V ST_XXFSAM_EAC_CASE_COMMENTS_V\r\nINNER JOIN  $$SLSORDVWDB.N_EAC_CASE CASE1 \r\nON CASE1.BK_EAC_CASE_ID = ST_XXFSAM_EAC_CASE_COMMENTS_V.CASE_ID\r\nLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP_CRTD\r\nON COALESCE(ST_XXFSAM_EAC_CASE_COMMENTS_V.COMMENTED_BY,'UNKNOWN')= NCWP_CRTD.CEC_ID AND NCWP_CRTD.CISCO_WORKER_PARTY_KEY<>-999",
