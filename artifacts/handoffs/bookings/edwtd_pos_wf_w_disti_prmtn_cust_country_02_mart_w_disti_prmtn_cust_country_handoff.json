      "attributes": {
        "Sql Query": "SELECT ST.PROMO_ID, ST.PROMO_LOC_DETAIL_ID, ST.LOCATION_TYPE, ST.WHOSE_LOCATION, ST.ACTIVE_FLAG, ST.CREATED_BY, ST.CREATED_DATE, ST.UPDATED_BY, ST.LAST_UPDATE_DATE, ST.IT_COMMENTS, ST.LOCATION_VALUE, ST.BATCH_ID, ST.ACTION_CD, ST.CREATE_DATETIME, ST.CREATED_BY \r\nFROM\r\n ST_DCA_PROMO_LOCATION_DETAILS\r\nFROM $$STGDB.ST_DCA_PROMO_LOCATION_DETAILS  ST\r\n WHERE ST.LOCATION_TYPE='COUNTRY'\r\nAND\r\n(\r\n NOT EXISTS\r\n(SELECT 1 FROM $$SLSORDVWDB.N_DISTRIBUTOR_PROMOTION NDP\r\nWHERE NDP.SK_PROMO_ID_INT = ST.PROMO_ID)\r\nOR NOT EXISTS\r\n(SELECT 1 FROM $$COMREFVWDB.N_ISO_COUNTRY NISO\r\nWHERE NISO.ISO_COUNTRY_SHORT_CODE = ST.LOCATION_VALUE)\r\n)",
