      "attributes": {
        "Sql Query": "SELECT \r\nNDP.BK_PROMOTION_NUM AS BK_PROMOTION_NUM,\r\nNDP.BK_PROMOTION_REVISION_NUM_INT  AS  BK_PROMOTION_REVISION_NUM_INT,\r\nNDP.BK_PROMOTION_TYPE_CD  AS BK_PROMOTION_TYPE_CD,\r\nST.WHOSE_LOCATION AS BK_DISTI_PRMTN_CUST_TYPE_CD,\r\nNISO.BK_ISO_COUNTRY_CODE AS BK_ISO_COUNTRY_CD,\r\nCURRENT_TIMESTAMP(0)  AS   EDW_CREATE_DTM ,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS   EDW_UPDATE_USER\r\nFROM\r\n$$STGDB.ST_DCA_PROMO_LOCATION_DETAILS  ST\r\nINNER JOIN $$SLSORDVWDB.N_DISTRIBUTOR_PROMOTION NDP\r\nON NDP.SK_PROMO_ID_INT = ST.PROMO_ID\r\nINNER JOIN $$COMREFVWDB.N_ISO_COUNTRY NISO\r\nON NISO.ISO_COUNTRY_SHORT_CODE = ST.LOCATION_VALUE\r\nWHERE ST.LOCATION_TYPE='COUNTRY'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY BK_PROMOTION_NUM ,\r\nBK_PROMOTION_REVISION_NUM_INT ,BK_PROMOTION_TYPE_CD ,BK_DISTI_PRMTN_CUST_TYPE_CD ,\r\nBK_ISO_COUNTRY_CD  ORDER BY ST.LAST_UPDATE_DATE DESC) =1\r\n\r\n\r\nUNION \r\n\r\n\r\nSELECT \r\nNDP.BK_PROMOTION_NUM AS BK_PROMOTION_NUM,\r\nNDP.BK_PROMOTION_REVISION_NUM_INT  AS  BK_PROMOTION_REVISION_NUM_INT,\r\nNDP.BK_PROMOTION_TYPE_CD  AS BK_PROMOTION_TYPE_CD,\r\nEX.WHOSE_LOCATION AS BK_DISTI_PRMTN_CUST_TYPE_CD,\r\nNISO.BK_ISO_COUNTRY_CODE AS BK_ISO_COUNTRY_CD,\r\nCURRENT_TIMESTAMP(0)  AS   EDW_CREATE_DTM ,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS   EDW_UPDATE_USER\r\nFROM\r\n$$EXCEPDB.EX_DISTI_PRMTN_CUST_COUNTRY  EX\r\nINNER JOIN $$SLSORDVWDB.N_DISTRIBUTOR_PROMOTION NDP\r\nON NDP.SK_PROMO_ID_INT = EX.PROMO_ID\r\nINNER JOIN $$COMREFVWDB.N_ISO_COUNTRY NISO\r\nON NISO.ISO_COUNTRY_SHORT_CODE = EX.LOCATION_VALUE\r\nWHERE EX.LOCATION_TYPE='COUNTRY'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY BK_PROMOTION_NUM ,\r\nBK_PROMOTION_REVISION_NUM_INT ,BK_PROMOTION_TYPE_CD ,BK_DISTI_PRMTN_CUST_TYPE_CD ,\r\nBK_ISO_COUNTRY_CD  ORDER BY EX.LAST_UPDATE_DATE DESC) =1",
