      "attributes": {
        "Sql Query": "SELECT\r\n\tEFL.LOOKUP_CODE as BK_DEMAND_CLASS_CD,\r\n\tEFL.DESCRIPTION as DEMAND_CLASS_DESCR,\r\n\tEFL.MEANING as DEMAND_CLASS_NAME,\r\n\tCURRENT_TIMESTAMP(0),\r\n\tUSER,\r\n\tCURRENT_TIMESTAMP(0),\r\n\tUSER,\r\n\t'I' as ACTION_CODE,\r\n\tCASE WHEN NSOD.BK_DEMAND_CLASS_CD IS NOT NULL THEN 'U' ELSE 'I' END DML_TYPE\r\n\tFROM \r\n\t$$ETLVWDB.EL_FND_LOOKUP_VALUES EFL\r\n\tLEFT OUTER JOIN $$SLSORDDB.N_SALES_ORDER_DEMAND_CLASS NSOD\r\nON NSOD.BK_DEMAND_CLASS_CD=EFL.LOOKUP_CODE\r\nWHERE \r\n\tLOOKUP_TYPE = 'DEMAND_CLASS' \r\n/* SJ PROD RETIREMENT Q1FY14 */\r\nAND GLOBAL_NAME = 'CG' \r\nGROUP BY 1,2,3,4,5,6,7,8,9",
