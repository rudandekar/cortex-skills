      "attributes": {
        "Sql Query": "SELECT \r\nWI.BK_DEAL_ID,                   \r\nWI.BK_REBATE_QUESTION_ID_INT   , \r\nWI.BK_QUESTION_RESPONSE_TXT ,    \r\nWI.SRC_CRTD_CSCO_WRKR_PRTY_KEY   ,\r\nWI.SRC_CREATED_DTM         ,     \r\nWI.DV_SRC_CREATED_DT    ,        \r\nWI.SRC_UPDTD_CSCO_WRKR_PRTY_KEY  ,\r\nWI.SRC_UPDATED_DTM     ,         \r\nWI.DV_SRS_UPDATED_DT ,\r\nWI.EDW_CREATE_DTM,\r\nWI.EDW_CREATE_USER,\r\nWI.EDW_UPDATE_DTM,\r\nWI.EDW_UPDATE_USER\r\nFROM \r\n$$WORKDB.W_DEAL_QUALI_FORM_RESPONSE WI\r\nWHERE DML_TYPE='I'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "CALL COLLECT_STATS_WRAP('$$WORKDB','W_DEAL_QUALI_FORM_RESPONSE','D');\r\n\r\n\r\n\r\nUPDATE NDQFR FROM $$SLSORDVWDB.N_DEAL_QUALI_FORM_RESPONSE NDQFR, $$WORKDB.W_DEAL_QUALI_FORM_RESPONSE WDQFR\r\nSET \r\nSRC_CRTD_CSCO_WRKR_PRTY_KEY = WDQFR.SRC_CRTD_CSCO_WRKR_PRTY_KEY,\r\nSRC_CREATED_DTM = WDQFR.SRC_CREATED_DTM    ,\r\nDV_SRC_CREATED_DT  = WDQFR.DV_SRC_CREATED_DT      , \r\nSRC_UPDTD_CSCO_WRKR_PRTY_KEY  = WDQFR.SRC_UPDTD_CSCO_WRKR_PRTY_KEY ,\r\nSRC_UPDATED_DTM  = WDQFR.SRC_UPDATED_DTM         ,\r\nDV_SRS_UPDATED_DT  = WDQFR.DV_SRS_UPDATED_DT ,\r\nEDW_UPDATE_DTM = CURRENT_TIMESTAMP(0),\r\nEDW_UPDATE_USER = USER\r\nWHERE WDQFR.DML_TYPE= 'U'\r\nAND NDQFR.BK_DEAL_ID= WDQFR.BK_DEAL_ID\r\nAND NDQFR.BK_REBATE_QUESTION_ID_INT = WDQFR.BK_REBATE_QUESTION_ID_INT\r\nAND NDQFR.BK_QUESTION_RESPONSE_TXT = WDQFR.BK_QUESTION_RESPONSE_TXT;",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
