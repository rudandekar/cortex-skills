      "attributes": {
        "Sql Query": "/*\r\nSELECT \r\nARCH_PLAY.L1_ARCH_PLAY_NODE_NAME\r\n,ARCH_PLAY.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n,ARCH_PLAY.DD_COMP_US_NET_PRICE_AMOUNT\r\n,SUM(ARCH_PLAY.DD_COMP_US_NET_PRICE_AMOUNT ) OVER ( PARTITION BY DV_FISCAL_YEAR_MTH_NUMBER_INT ) TOTAL_COMP_US_NET_PRICE_AMOUNT  \r\n,CAST( ARCH_PLAY.DD_COMP_US_NET_PRICE_AMOUNT    AS DECIMAL(27,14)) /CAST(TOTAL_COMP_US_NET_PRICE_AMOUNT AS DECIMAL(27,14)) ARCH_TO_PID_ALLOC_RATIO\r\n,EATGM.GOODS_PRODUCT_KEY             \r\nFROM\r\n(\r\nSELECT\r\nPAPH.L1_ARCH_PLAY_NODE_NAME\r\n,WITBM.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n,SUM(DD_COMP_US_NET_PRICE_AMOUNT*ARCH_PLY_HIER_ND_ALOC_FCTR_AMT ) DD_COMP_US_NET_PRICE_AMOUNT \r\nFROM $$STGDB.WI_QTR_TSS_BKGS_MEASURE WITBM\r\nINNER JOIN $$STGDB.WI_QTR_SRVC_BKGS_PERIOD_CNTL  WISBPC   \r\nON( WISBPC.FISCAL_YEAR_MTH_NUMBER_INT    =WITBM.DV_FISCAL_YEAR_MTH_NUMBER_INT)\r\nINNER JOIN   $$COMREFVWDB.N_PRD_ARCH_PLY_HIER_ND_ALOC   PPAPHNA    \r\nON ( WITBM.GOODS_PRODUCT_KEY =PPAPHNA.PRODUCT_KEY)\r\nINNER JOIN  $$COMREFVWDB.MT_ARCHITECTURE_PLAY_HIER   PAPH\r\nON ( PPAPHNA.BK_ARCH_PLAY_HIER_NODE_CD  = PAPH.BK_ARCH_PLAY_HIER_NODE_CD\r\nAND PAPH.DV_FISCAL_YR_MTH_NUM_INT IN ( SELECT FISCAL_MONTH_AGO_MONTH_NUMBER FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR WHERE FISCAL_YEAR_MONTH_INT = (SELECT MAX(FISCAL_YEAR_MTH_NUMBER_INT) FROM $$STGDB.WI_QTR_SRVC_BKGS_PERIOD_CNTL) ) ) \r\nGROUP BY PAPH.L1_ARCH_PLAY_NODE_NAME,WITBM.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n) ARCH_PLAY,\r\n$$ETLVWDB.EL_ARCH_TO_GOODS_MAPPING EATGM\r\nWHERE ARCH_PLAY.L1_ARCH_PLAY_NODE_NAME=EATGM.L1_ARCH_PLAY_NODE_NAME\r\n*/\r\n\r\nSELECT \r\nARCH_PLAY.BK_SUB_BUSINESS_ENTITY_NAME\r\n,ARCH_PLAY.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n,ARCH_PLAY.DD_COMP_US_NET_PRICE_AMOUNT\r\n,SUM(ARCH_PLAY.DD_COMP_US_NET_PRICE_AMOUNT ) OVER ( PARTITION BY DV_FISCAL_YEAR_MTH_NUMBER_INT ) TOTAL_COMP_US_NET_PRICE_AMOUNT  \r\n,CAST( ARCH_PLAY.DD_COMP_US_NET_PRICE_AMOUNT    AS DECIMAL(27,14)) /CAST(TOTAL_COMP_US_NET_PRICE_AMOUNT AS DECIMAL(27,14)) ARCH_TO_PID_ALLOC_RATIO\r\n,ELESGTBM.PRODUCT_KEY             \r\nFROM\r\n(\r\nSELECT\r\nBE_ALLOC.BK_SUB_BUSINESS_ENTITY_NAME\r\n,WITBM.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n,SUM(DD_COMP_US_NET_PRICE_AMOUNT*PRDT_FAMILY_ALLOCATION_PCT ) DD_COMP_US_NET_PRICE_AMOUNT \r\nFROM $$STGDB.WI_QTR_TSS_BKGS_MEASURE WITBM\r\nINNER JOIN $$STGDB.WI_QTR_SRVC_BKGS_PERIOD_CNTL  WISBPC   \r\nON( WISBPC.FISCAL_YEAR_MTH_NUMBER_INT    =WITBM.DV_FISCAL_YEAR_MTH_NUMBER_INT)\r\n\r\n/*\r\nINNER JOIN   COMREFVWDB.N_PRD_ARCH_PLY_HIER_ND_ALOC   PPAPHNA    \r\nON ( WITBM.GOODS_PRODUCT_KEY =PPAPHNA.PRODUCT_KEY)\r\nINNER JOIN  COMREFVWDB.MT_ARCHITECTURE_PLAY_HIER   PAPH\r\nON ( PPAPHNA.BK_ARCH_PLAY_HIER_NODE_CD  = PAPH.BK_ARCH_PLAY_HIER_NODE_CD\r\nAND PAPH.DV_FISCAL_YR_MTH_NUM_INT IN ( SELECT FISCAL_MONTH_AGO_MONTH_NUMBER FROM COMREFVWDB.R_FISCAL_MONTH_TO_YEAR WHERE FISCAL_YEAR_MONTH_INT = (SELECT MAX(FISCAL_YEAR_MTH_NUMBER_INT) FROM STGDB.WI_QTR_SRVC_BKGS_PERIOD_CNTL) ) ) \r\nGROUP BY PAPH.L1_ARCH_PLAY_NODE_NAME,WITBM.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n) ARCH_PLAY,*/\r\n\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nON RFM.FISCAL_YEAR_MONTH_INT         =WISBPC.FISCAL_YEAR_MTH_NUMBER_INT\r\n\r\nINNER JOIN $$COMREFDB.MT_BE_HIER_PRDT_FAMILY_ALLOC BE_ALLOC\r\nON WITBM.GOODS_PRODUCT_KEY=BE_ALLOC.ITEM_KEY\r\nAND BE_ALLOC.DV_FISCAL_QUARTER_ID=RFM.DV_FISCAL_QUARTER_ID\r\nAND BE_ALLOC.BK_BUSINESS_ENTITY_TYPE_CD  = 'I'\r\n\r\nGROUP BY \r\nBE_ALLOC.BK_SUB_BUSINESS_ENTITY_NAME\r\n,WITBM.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n\r\n) ARCH_PLAY,\r\n$$FINLGLVWDB.N_SVC_GM_BY_BE  ELESGTBM \r\nWHERE  ARCH_PLAY.BK_SUB_BUSINESS_ENTITY_NAME = ELESGTBM.BK_SUB_BUSINESS_ENTITY_NAME\r\nAND ARCH_PLAY. DV_FISCAL_YEAR_MTH_NUMBER_INT= (ELESGTBM. BK_FISCAL_YEAR_NUM_INT * 100 + ELESGTBM .BK_FISCAL_MONTH_NUM_INT )\r\nAND ELESGTBM .BK_DATA_SET_CD='CISCO'",
        "User Defined Join": "",
