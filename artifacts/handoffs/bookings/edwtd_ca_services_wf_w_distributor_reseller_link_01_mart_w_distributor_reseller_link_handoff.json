      "attributes": {
        "Sql Query": "SELECT\r\na.DSTRBTR_PARTNER_SITE_PARTY_KEY,\r\na.RESELLER_PRTNR_SITE_PARTY_KEY,\r\na.BK_DSTRBTR_RPRTD_RESELLER_ID,\r\na.LAST_REPORTED_POS_DT,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\n'I' ACTION_CODE,\r\nCASE \r\nWHEN NDRL.DSTRBTR_PARTNER_SITE_PARTY_KEY IS NULL AND NDRL.RESELLER_PRTNR_SITE_PARTY_KEY IS NULL AND NDRL.BK_DSTRBTR_RPRTD_RESELLER_ID IS NULL\r\nTHEN 'I' ELSE 'U' END AS DML_TYPE\r\nFROM\r\n(\r\nSELECT\r\ncoalesce(NPOS.BILL_TO_CUST_ACCT_LOC_USE_KEY,-999) as DSTRBTR_PARTNER_SITE_PARTY_KEY,\r\nNP.party_key as RESELLER_PRTNR_SITE_PARTY_KEY,\r\nRESELLER_ID as BK_DSTRBTR_RPRTD_RESELLER_ID,\r\nLAST_REPORTED_POS_DATE as LAST_REPORTED_POS_DT\r\nFROM $$stgDB.ST_XXCCR_RESELLER_DATA_MV ST\r\nLEFT OUTER JOIN (sel coalesce (bk_wips_originator_id_int,-999) as bk_wips_originator_id_int,BILL_TO_CUST_ACCT_LOC_USE_KEY\r\n\t\t\t\tFROM $$SERVICEVWDB.N_SMS3_DISTRIBUTOR_TV SDT\r\n\t\t\t\tLEFT OUTER JOIN $$SLSORDVWDB.N_POS_ORIGINATOR_ORG NPOS\r\n\t\t\t\ton npos.bill_to_erp_cust_acct_loc_key = SDT.BILL_TO_CUST_ACCT_LOC_USE_KEY) NPOS\r\nON NPOS.bk_wips_originator_id_int = ST.DISTI_ID\r\nINNER JOIN $$COMREFVWDB.N_PARTY NP\r\nON NP.PARTY_SSOT_PARTY_ID_INT = ST.CR_PARTY_ID\r\n) A\r\nLEFT OUTER JOIN $$SLSORDDB.N_DISTRIBUTOR_RESELLER_LINK NDRL\r\nON A.DSTRBTR_PARTNER_SITE_PARTY_KEY=NDRL.DSTRBTR_PARTNER_SITE_PARTY_KEY\r\nAND A.RESELLER_PRTNR_SITE_PARTY_KEY=NDRL.RESELLER_PRTNR_SITE_PARTY_KEY\r\nAND A.BK_DSTRBTR_RPRTD_RESELLER_ID=NDRL.BK_DSTRBTR_RPRTD_RESELLER_ID\r\nqualify row_number() over (partition by a.DSTRBTR_PARTNER_SITE_PARTY_KEY,a.RESELLER_PRTNR_SITE_PARTY_KEY,a.BK_DSTRBTR_RPRTD_RESELLER_ID \r\norder by a.LAST_REPORTED_POS_DT desc)=1",
        "User Defined Join": "",
