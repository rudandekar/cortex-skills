      "attributes": {
        "Sql Query": "SELECT \r\nCLN.SVC_CNTRCT_LN_TECH_SVCS_KEY,\r\nCLN.IP_KEY,\r\nCLN.SERVICE_PRODUCT_KEY,\r\nCLN.TERMINATED_DTM,\r\nCLN.rnwd_svc_cntrct_ln_tch_svc_key,\r\nCLN.SOURCE_CREATE_DTM,\r\nCLN.SERVICE_STATUS_CD,\r\nCLN.SK_ID_LINT,\r\n--CASE WHEN SHIP_HIER.HQ_BRANCH_CODE='HQ' THEN SHIP_HIER.PARTY_KEY ELSE SHIP_HIER.HQ_CUSTOMER_PARTY_KEY END AS CX_CUSTOMER_BU_ID,\r\nCX.CX_CUSTOMER_BU_ID AS CX_CUSTOMER_BU_ID,--ADDED AS PART OF DAY1 FY22\r\nIP.SK_INVENTORY_ITEM_ID_INT as CL_INVENTORY_ITEM_ID,\r\nP.BK_PRODUCT_ID AS CL_SERVICE_LEVEL,\r\n--CLN.SVC_CNTRCT_LINE_END_DTM AS SVC_CNTRCT_LINE_END_DTM,\r\nCASE WHEN CLN.TERMINATED_DTM IS NOT NULL AND CLN.TERMINATED_DTM <>'1900-01-01 00:00:00' THEN CLN.TERMINATED_DTM ELSE CLN.SVC_CNTRCT_LINE_END_DTM END AS SVC_CNTRCT_LN_END_DTM,--ADDED AS PART OF DAY1 FY22\r\n/*CHANGES AS PART OF AUG 16 2020 REL*/\r\nCLN.BK_SVC_CNTRCT_LINE_START_DTM  ,\r\nMAINTENANCE_ORDER_NUM,\r\nIP.BK_PRODUCT_ID AS COVERED_PRODUCT_ID, --03/04/2019\r\nDV_LINE_STYLE_ID_INT\r\nFROM $$SERVICEVWDB.N_SVC_CNTRCT_LN_TECH_SERVICES  CLN\r\nleft JOIN $$IBVWDB.N_INSTALLED_PRODUCT I ON i.IP_KEY=CLN.IP_KEY \r\nINNER JOIN $$COMREFVWDB.MT_ERP_POS_SHIPTO  SHIP ON I.INSTALLED_CUSTOMER_PARTY_KEY=SHIP.SHIP_TO_CUSTOMER_KEY\r\nINNER JOIN $$COMREFVWDB.MT_ERP_POS_SHIPTO_HIER  SHIP_HIER ON SHIP_HIER.SHIP_TO_CUSTOMER_KEY=SHIP.SHIP_TO_CUSTOMER_KEY\r\nINNER JOIN $$COMREFVWDB.R_PRODUCTS P ON CLN.SERVICE_PRODUCT_KEY  =P.ITEM_KEY \r\nINNER JOIN $$COMREFVWDB.MT_CXCUST_BU_PARTY_MAPPING CX ON SHIP_HIER.PARTY_SSOT_PARTY_ID_INT=CX.CR_PARTY_ID --ADDED AS PART OF DAY1 FY22\r\nleft JOIN $$COMREFVWDB.R_PRODUCTS IP --03/04/2019\r\nON IP.ITEM_KEY = I.GOODS_PRODUCT_KEY --03/04/2019\r\nWHERE \r\n1=1\r\nAND P.BK_PRODUCT_ID  IN (SELECT DISTINCT BK_PRODUCT_SUBGROUP_ID FROM $$COMREFVWDB.MT_SVC_FINANCE_HIERARCHY H\r\nWHERE\r\n1=1\r\nAND BK_ALLOCATED_SERVC_GROUP_ID  IN  ('FOCUSED TECHNICAL SUPPORT SERVICES')\r\n)\r\n--AND SHIP_HIER.HQ_CUSTOMER_PARTY_KEY>0\r\nAND SVC_CNTRCT_LN_TECH_SVCS_KEY NOT IN (SEL SVC_CNTRCT_LN_TECH_SVCS_KEY FROM $$STGDB.WI_SUMMARY_QUOTE_FTSS_2)\r\n/*ADDED AS PART OF AUG 16 2020 REL*/\r\nAND CLN.SVC_CNTRCT_LINE_END_DTM >=\r\n(SELECT MIN(CAST(BK_SVC_CNTRCT_LINE_START_DTM AS DATE))-370 FROM $$STGDB.WI_SUMMARY_QUOTE_FTSS_2) \r\nAND CLN.SVC_CNTRCT_LINE_END_DTM <(SELECT MAX(BK_SVC_CNTRCT_LINE_START_DTM ) FROM $$STGDB.WI_SUMMARY_QUOTE_FTSS_2)\r\n--This filter limits the amount of data,at any point we are interested in last 1 year history\r\n/*CHANGES AS PART OF AUG 16 2020 REL*/\r\n/*START*/\r\nGROUP BY\r\nCLN.SVC_CNTRCT_LN_TECH_SVCS_KEY,\r\nCLN.IP_KEY,\r\nCLN.SERVICE_PRODUCT_KEY,\r\nCLN.TERMINATED_DTM,\r\nCLN.rnwd_svc_cntrct_ln_tch_svc_key,\r\nCLN.SOURCE_CREATE_DTM,\r\nCLN.SERVICE_STATUS_CD,\r\nCLN.SK_ID_LINT,\r\nCX_CUSTOMER_BU_ID,\r\nIP.SK_INVENTORY_ITEM_ID_INT,\r\nP.BK_PRODUCT_ID,\r\nCLN.BK_SVC_CNTRCT_LINE_START_DTM  ,\r\nCLN.SVC_CNTRCT_LINE_END_DTM,\r\nMAINTENANCE_ORDER_NUM,\r\nIP.BK_PRODUCT_ID, --03/04/2019\r\nDV_LINE_STYLE_ID_INT\r\n/*END*/",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
