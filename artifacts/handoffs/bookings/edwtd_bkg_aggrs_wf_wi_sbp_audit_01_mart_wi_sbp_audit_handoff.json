      "attributes": {
        "Sql Query": "SELECT \r\n SRC.DV_FISCAL_YEAR_MTH_NUMBER_INT, \r\n'MT_SERVICES_BOOKINGS' AS AUDIT_TABLE \r\n,CURRENT_DATE  \r\n,ABS(ROUND(COALESCE(SRC.SRC_BKGS_AMOUNT,1)-COALESCE(TGT.TGT_BKGS_AMOUNT,1),4))  AS BKGS_MISMATCH_AMT \r\nFROM\r\n(\r\nSEL DV_FISCAL_YEAR_MTH_NUMBER_INT, SUM (DD_COMP_US_NET_PRICE_AMOUNT) AS SRC_BKGS_AMOUNT\r\nFROM $$SLSORDVWDB.MT_RSTD_BKGS_MEASURE BKGS \r\niNNER JOIN $$COMREFVWDB.R_SALES_HIERARCHY  SALES_HIER\r\nON  BKGS.SALES_TERRITORY_KEY = SALES_HIER.SALES_TERRITORY_KEY\r\nINNER JOIN $$COMREFVWDB.N_PRODUCT PROD\r\nON PROD.ITEM_KEY = BKGS.PRODUCT_KEY\r\n/*INNER JOIN $$SLSORDVWDB.N_BOOKINGS_CHANNEL_MEASURE CHANNEL\r\nON CHANNEL.BOOKINGS_MEASURE_KEY = BKGS.BOOKINGS_MEASURE_KEY\r\nAND BKGS.BOOKINGS_PROCESS_DATE = CHANNEL.BOOKINGS_PROCESS_DATE\r\nAND BKGS.BKGS_MEASURE_TRANS_TYPE_CODE = CHANNEL.BKGS_MEASURE_TRANS_TYPE_CODE*/\r\n INNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDTY\r\nON FDTY.CALENDAR_DATE = BKGS.BOOKINGS_PROCESS_DATE \r\nWHERE\r\n SALES_HIER.SALES_TERRITORY_TYPE_CODE IN ('CORP. REVENUE','UNKNOWN') AND \r\n BKGS.DV_REVENUE_RECOGNITION_FLG = 'Y'\r\n AND PROD.BK_PRODUCT_TYPE_ID NOT IN ('TECHDOC', 'TRAINING' )\r\n AND BKGS.SERVICE_FLG = 'Y' \r\nAND  BKGS.DD_COMP_US_NET_PRICE_AMOUNT < >0 \r\n AND FDTY.FISCAL_YEAR_MONTH_INT = (SEL FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_SRVC_BKGS_CNTRL_MNTH) \r\n AND BKGS.DV_FISCAL_YEAR_MTH_NUMBER_INT = (SEL FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_SRVC_BKGS_CNTRL_MNTH)\r\nGROUP BY 1\r\n) SRC \r\n\r\nFULL JOIN\r\n(\r\nSEL  DV_FISCAL_YEAR_MTH_NUMBER_INT,SUM (DD_COMP_US_NET_PRICE_AMT      )  AS TGT_BKGS_AMOUNT FROM  $$SLSORDVWDB.MT_SERVICES_BOOKINGS  A  \r\n INNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDTY\r\nON FDTY.CALENDAR_DATE = A.BOOKINGS_PROCESS_DT\r\nWHERE FDTY.FISCAL_YEAR_MONTH_INT =(SEL FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_SRVC_BKGS_CNTRL_MNTH)  AND \r\n  A.DV_FISCAL_YEAR_MTH_NUMBER_INT= (SEL FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_SRVC_BKGS_CNTRL_MNTH)\r\nGROUP BY 1 \r\n) TGT\r\n\r\nON SRC.DV_FISCAL_YEAR_MTH_NUMBER_INT=TGT.DV_FISCAL_YEAR_MTH_NUMBER_INT",
        "User Defined Join": "",
