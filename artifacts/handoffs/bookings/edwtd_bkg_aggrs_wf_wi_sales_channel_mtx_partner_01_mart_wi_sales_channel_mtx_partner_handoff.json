      "attributes": {
        "Sql Query": "SELECT  \r\n\tWCMP.SALES_TERRITORY_KEY  \t\t\t\tSALES_TERRITORY_KEY,\r\n\tWCMP.SOLD_TO_CUSTOMER_KEY  \t\t\t\tSOLD_TO_CUSTOMER_KEY,\r\n\tWCMP.END_CUSTOMER_KEY  \t\t\t\t\tEND_CUSTOMER_KEY,\r\n\tWCMP.DV_END_CUSTOMER_KEY\t\t\t\tDV_END_CUSTOMER_KEY,\r\n\tWCMP.END_CUSTOMER_TYPE_CODE  \t\t\t\tEND_CUSTOMER_TYPE_CODE,\r\n\tWCMP.BILL_TO_CUSTOMER_KEY  \t\t\t\tBILL_TO_CUSTOMER_KEY,\r\n\tNEP.PARTY_KEY \t\t\t\t\t\tSOLD_TO_PARTY_KEY,\r\n\tNECAL.CUSTOMER_PARTY_KEY \t\t\t\tBILL_TO_PARTY_KEY,\r\n\tCASE WHEN END_CUSTOMER_TYPE_CODE='ACCOUNT' THEN COALESCE(NEP_END_CUST.PARTY_KEY,-999)\r\n\t     WHEN END_CUSTOMER_TYPE_CODE='ACCOUNT_LOCATION' THEN COALESCE(NECAL_END_CUST_LOC.CUSTOMER_PARTY_KEY,-999)\r\n\t     ELSE -999\r\n\tEND  \t\t\t\t\t\t\tDV_END_CUST_PARTY_KEY ,\r\n\t\r\n\t  /* ADDED AS PART OF ATHENA */\r\n  CASE WHEN PB_PARTY.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NOT NULL AND PB_PARTY.DD_GRNDPARNT_PARTNER_PARTY_KEY > 0 THEN\r\n  PB_PARTY.PARTNER_SITE_PARTY_KEY\r\n  /*END */ \r\n\tWHEN SOLD_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NULL \r\n\t\t\tTHEN -999\r\n     \t     WHEN BILL_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NULL\r\n\t     \t\tTHEN COALESCE(SOLD_TO_PARENT.PARTNER_SITE_PARTY_KEY ,-999)\r\n     \t     WHEN  SOLD_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY =BILL_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY \r\n\t     \t\tTHEN BILL_TO_PARENT.PARTNER_SITE_PARTY_KEY\r\n             WHEN  SOLD_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY  <> BILL_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY \r\n\t     \t\tTHEN SOLD_TO_PARENT.PARTNER_SITE_PARTY_KEY\r\n\t     ELSE \t-999\r\n        END         PARTNER_PARTY_KEY_AS_IS,\r\n\t\tCASE WHEN PARTNER_PARTY_KEY_AS_IS =-999 AND NEP.ERP_PARTY_NAME LIKE ANY  ('%CS CAPITAL%','%CISCO SYSTEMS CAPITAL%', 'CISCO SYSTEMS FINANCE %','EXPEDIA INC')\r\n  THEN COALESCE(SHIPS.PARTNER_SITE_PARTY_KEY,-999) \r\n  ELSE PARTNER_PARTY_KEY_AS_IS END AS PARTNER_PARTY_KEY,\r\n  \r\n /* ADDED AS PART OF ATHENA */\r\n CASE WHEN PB_PARTY.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NOT NULL AND PB_PARTY.DD_GRNDPARNT_PARTNER_PARTY_KEY > 0 THEN\r\n  'PBILL_TO' /* END */\r\nWHEN SOLD_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NULL \r\n\t\t\tTHEN 'SOLD_TO'\r\n\t     WHEN BILL_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NULL \t\r\n\t     \t\tTHEN 'SOLD_TO' \r\n\t     WHEN  SOLD_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY =BILL_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY \r\n\t     \t\tTHEN 'BILL_TO'\r\n\t     WHEN  SOLD_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY  <> BILL_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY \r\n\t     \t\tTHEN 'SOLD_TO'\r\n\t     ELSE 'SOLD_TO'\r\n\tEND \t\t\t\t\t\t\t PARTNER,\r\n\tCOALESCE(SOLD_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY,-999) SOLD_TO_GRAND_PRNT_PTY_KEY ,\r\n\tBILL_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY  \t\t BILL_TO_GRAND_PRNT_PTY_KEY,\r\n\tUSER   \t\t\t\t\t\t    \t EDW_CREATE_USER,\r\n\tCURRENT_TIMESTAMP(0) \t\t\t\t\t EDW_CREATE_DATETIME,\r\nWCMP.SHIP_TO_CUSTOMER_KEY,\r\nWCMP.PARTNER_BILL_TO_CUST_PARTY_KEY\t\r\nFROM  $$STGDB.WI_SALES_CHANNEL_MTX_PATTERNS WCMP\r\nINNER JOIN ( $$COMREFVWDB.N_CUSTOMER_ACCOUNT NCA\r\n\t\tINNER JOIN $$COMREFVWDB.N_ERP_PARTY NEP\r\n\t\tON(NEP.ERP_PARTY_NUMBER = NCA.ERP_CUSTOMER_NUMBER) \r\n\t\t\t\t)\r\n\tON (NCA.CUSTOMER_ACCOUNT_KEY= WCMP.SOLD_TO_CUSTOMER_KEY )\r\nINNER JOIN $$COMREFVWDB.N_ERP_CUST_ACCT_LOC_USE NECAL\r\n\tON(NECAL.ERP_CUST_ACCOUNT_LOCATION_KEY = WCMP.BILL_TO_CUSTOMER_KEY )\r\nLEFT OUTER JOIN ( $$COMREFVWDB.N_CUSTOMER_ACCOUNT NCA_END_CUST\r\n\t\t  INNER JOIN $$COMREFVWDB.N_ERP_PARTY NEP_END_CUST\r\n\t\t  ON(NEP_END_CUST.ERP_PARTY_NUMBER = NCA_END_CUST.ERP_CUSTOMER_NUMBER) \r\n\t\t\t\t)\r\n\tON (NCA_END_CUST.CUSTOMER_ACCOUNT_KEY= WCMP.DV_END_CUSTOMER_KEY )\r\nLEFT OUTER JOIN $$COMREFVWDB.N_ERP_CUST_ACCT_LOC_USE NECAL_END_CUST_LOC\r\n\tON(NECAL_END_CUST_LOC.ERP_CUST_ACCOUNT_LOCATION_KEY = WCMP.DV_END_CUSTOMER_KEY )\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE  SOLD_TO_PARENT\r\n\tON(NEP.PARTY_KEY=SOLD_TO_PARENT.PARTNER_SITE_PARTY_KEY)\r\n\tAND SOLD_TO_PARENT.SOURCE_DELETED_FLG='N'\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE  BILL_TO_PARENT\r\n\tON(NECAL.CUSTOMER_PARTY_KEY=BILL_TO_PARENT.PARTNER_SITE_PARTY_KEY)\r\n\tAND BILL_TO_PARENT.SOURCE_DELETED_FLG='N'  \r\n LEFT OUTER JOIN $$COMREFVWDB.N_ERP_CUST_ACCT_LOC_USE STP\r\n  ON STP.ERP_CUST_ACCOUNT_LOCATION_KEY = WCMP.SHIP_TO_CUSTOMER_KEY\r\n  LEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE SHIPS\r\n  ON STP.CUSTOMER_PARTY_KEY=SHIPS.PARTNER_SITE_PARTY_KEY\r\n  AND SHIPS.SOURCE_DELETED_FLG='N'\r\n    \r\n  /* ADDED AS PART OF ATHENA */\r\n LEFT JOIN $$COMREFVWDB.N_ERP_CUST_ACCT_LOC_USE PART_BILL\r\n ON(PART_BILL.ERP_CUST_ACCOUNT_LOCATION_KEY = WCMP.PARTNER_BILL_TO_CUST_PARTY_KEY )\r\n LEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE PB_PARTY\r\n ON PART_BILL.CUSTOMER_PARTY_KEY=PB_PARTY.PARTNER_SITE_PARTY_KEY\r\n AND PB_PARTY.SOURCE_DELETED_FLG='N' \r\n /* END */",
        "User Defined Join": "",
