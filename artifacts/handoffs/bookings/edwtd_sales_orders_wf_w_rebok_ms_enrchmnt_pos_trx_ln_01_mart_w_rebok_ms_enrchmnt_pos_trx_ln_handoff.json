      "attributes": {
        "Sql Query": "SELECT \r\nNPTL.BK_POS_TRANSACTION_ID_INT\t AS BK_POS_TRANSACTION_ID_INT,\r\nNCPT.PARTNER_PARTY_KEY AS MS_PARTNER_PARTY_KEY,\r\nCAST(ST.CLASS_CODE AS INTEGER) AS MS_IDENTIFICATION_METHOD_INT,\r\nNEU.ERP_USER_NAME AS MODIFIED_BY_USER_ID,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM ,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE \r\nFROM $$STGDB.ST_OTM_PHX_TRX_POS ST\r\nINNER JOIN  $$SLSORDVWDB.N_POS_TRANSACTION_LINE NPTL\r\nON ST.POS_TRANS_ID = NPTL.BK_POS_TRANSACTION_ID_INT\r\nINNER JOIN $$COMREFVWDB.N_ERP_USER NEU\r\nON NEU.ERP_USER_NAME=ST.USER_NAME\r\nINNER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER NCPT\r\nON ST.PGTMV_PARTY_BE_ID = NCPT.BK_PGTMV_PARTNER_ID_INT\r\n\r\nUNION\r\n\r\nSELECT \r\nNPTL.BK_POS_TRANSACTION_ID_INT\t AS BK_POS_TRANSACTION_ID_INT,\r\nNCPT.PARTNER_PARTY_KEY AS MS_PARTNER_PARTY_KEY,\r\nCAST(ST.CLASS_CODE AS INTEGER) AS MS_IDENTIFICATION_METHOD_INT,\r\nNEU.ERP_USER_NAME AS MODIFIED_BY_USER_ID,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM ,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE \r\nFROM $$STGDB.ST_OTM_PHX_TRX_POS ST\r\nINNER JOIN  $$SLSORDVWDB.N_BKG_POS_TRANSACTION_LINE NPTL\r\nON ST.POS_TRANS_ID = NPTL.BK_POS_TRANSACTION_ID_INT\r\nINNER JOIN $$COMREFVWDB.N_ERP_USER NEU\r\nON NEU.ERP_USER_NAME=ST.USER_NAME\r\nINNER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER NCPT\r\nON ST.PGTMV_PARTY_BE_ID = NCPT.BK_PGTMV_PARTNER_ID_INT",
