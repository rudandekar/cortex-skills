      "attributes": {
        "Sql Query": "SELECT\r\nCOALESCE(STG.BK_AS_QUOTE_RSRC_JOB_ROLE_NAME,'UNKNOWN')  AS JOB_ROLE_CODE,\r\nCOALESCE(STG.BK_DELIVERABLE_NAME,'UNKNOWN') AS DELIVERABLE_NAME,\r\nCOALESCE(STG.BK_DELIVERY_GROUP_NAME,'UNKNOWN' ) AS BK_DEL_GRP_NAME,\r\nCOALESCE(STG.BK_RESOURCE_TYPE_CD,'UNKNOWN') AS RESOURCE_TYPE  ,\r\nCOALESCE(STG.BK_JOB_ROLE_GRADE_LVL_CD,'UNKNOWN') AS BK_JOB_ROLE_GRADE_LVL_CD,\r\nCOALESCE(STG.WORK_HRS_PCT,0.00)  AS WORK_HRS_PCT,\r\nCOALESCE(STG.TRVL_HRS_PCT,0.00)  AS TRVL_HRS_PCT,\r\nCOALESCE(STG.DLVRY_TYPE_CD,'UNKNOWN')  AS  DLVRY_TYPE_CD,\r\nCOALESCE(STG.SOURCE_DELETED_FLG,'N') AS  SOURCE_DELETED_FLG ,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\nSTG.BK_SS_CD,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NJBRL.BK_AS_QUOTE_RSRC_JOB_ROLE_NAME IS NULL  \r\nAND  NJBRL.BK_DELIVERABLE_NAME IS NULL  \r\nAND NJBRL.BK_DELIVERY_GROUP_NAME  IS NULL \r\nAND NJBRL.BK_RESOURCE_TYPE_CD IS NULL  \r\nAND NJBRL.BK_SS_CD IS NULL\r\n            THEN 'I' \r\n            ELSE 'U' \r\n            END AS DML_TYPE\r\nFROM $$STGDB.ST_AS_QT_JB_ROLE_DLVRBL_ASGNMNT_HDP STG\r\nLEFT OUTER JOIN $$SERVICEVWDB.N_AS_QT_JB_ROLE_DLVRBL_ASGNMNT  NJBRL\r\nON  NJBRL.BK_AS_QUOTE_RSRC_JOB_ROLE_NAME = STG.BK_AS_QUOTE_RSRC_JOB_ROLE_NAME\r\nAND NJBRL.BK_DELIVERABLE_NAME  = STG.BK_DELIVERABLE_NAME\r\nAND NJBRL.BK_DELIVERY_GROUP_NAME = STG.BK_DELIVERY_GROUP_NAME\r\nAND NJBRL.BK_RESOURCE_TYPE_CD  = STG.BK_RESOURCE_TYPE_CD\r\nAND NJBRL.BK_JOB_ROLE_GRADE_LVL_CD = STG.BK_JOB_ROLE_GRADE_LVL_CD\r\nAND NJBRL.BK_SS_CD=STG.BK_SS_CD",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "COLLECT STATS ON $$STGDB.ST_AS_QT_JB_ROLE_DLVRBL_ASGNMNT_HDP;\r\n\r\nDELETE FROM $$WORKDB.W_AS_QT_JB_RL_DLV_ASGNMNT_SEP  ALL;",
        "Post SQL": "",
        "Output is deterministic": "NO",
