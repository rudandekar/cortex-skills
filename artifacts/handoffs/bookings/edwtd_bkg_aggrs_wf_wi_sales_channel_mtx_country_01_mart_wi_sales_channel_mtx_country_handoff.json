      "attributes": {
        "Sql Query": "SELECT \r\n\tWCMP.SALES_TERRITORY_KEY,\r\n\tWCMP.SOLD_TO_CUSTOMER_KEY,\r\n\tWCMP.END_CUSTOMER_KEY,\r\n\tWCMP.DV_END_CUSTOMER_KEY, \r\n\tWCMP.END_CUSTOMER_TYPE_CODE,\r\n\tWCMP.BILL_TO_CUSTOMER_KEY,\r\n\tWCMP.SOLD_TO_PARTY_KEY,\r\n\tWCMP.BILL_TO_PARTY_KEY,\r\n\tWCMP.DV_END_CUST_PARTY_KEY,\r\n\tWCMP.PARTNER_PARTY_KEY,\r\n\tWCMP.PARTNER,\r\n\tWCMP.SOLD_TO_GRAND_PRNT_PTY_KEY\t,\r\n\tWCMP.BILL_TO_GRAND_PRNT_PTY_KEY\t,\r\n\tWCMP.EDW_CREATE_USER,\r\n\tWCMP.EDW_CREATE_DATETIME,\r\n\tCOALESCE(PART_CTRY.ISO_COUNTRY_CODE, 'UNK') PRTN_CNTRY_CD,\r\n\tCOALESCE(END_CTRY.ISO_COUNTRY_CODE, 'UNK') DV_END_CUST_COUNTRY,\t\r\n\tWCMP.SHIP_TO_CUSTOMER_KEY,\r\n\tWCMP.PARTNER_BILL_TO_CUST_PARTY_KEY /* ADDED AS PART OF ATHENA */\r\nFROM $$STGDB.WI_SALES_CHANNEL_MTX_PARTNER WCMP\r\nLEFT OUTER JOIN ( SELECT \t\r\n\t\t\t     NPAL.ISO_COUNTRY_CODE,NPLA.PARTY_KEY\r\n\t\t  FROM       $$COMREFVWDB.N_PARTY_LOCATOR_ASGN NPLA\r\n\t\t  INNER JOIN $$COMREFVWDB.N_LOCATOR NLOC\r\n\t\t  ON \t     NPLA.LOCATOR_KEY=NLOC.LOCATOR_KEY\r\n\t\t  AND \t     NLOC.SS_CODE='CR'\r\n\t\t  AND \t     NPLA.LOCATION_TYPE_CODE='POSTAL ADDRESS'\r\n\t\t  INNER JOIN $$COMREFVWDB.N_POSTAL_ADDRESS_LOCATOR NPAL\r\n\t\t  ON \t     NLOC.LOCATOR_KEY=NPAL.LOCATOR_KEY \r\n\t\t ) PART_CTRY\r\nON \t     WCMP.PARTNER_PARTY_KEY = PART_CTRY.PARTY_KEY \r\nLEFT OUTER JOIN ( SELECT     NPAL.ISO_COUNTRY_CODE, NPLA.PARTY_KEY\r\n \t\t  FROM \t     $$COMREFVWDB.N_PARTY_LOCATOR_ASGN NPLA\r\n \t\t  INNER JOIN $$COMREFVWDB.N_LOCATOR NLOC\r\n\t\t  ON \t     NPLA.LOCATOR_KEY=NLOC.LOCATOR_KEY\r\n\t\t  AND \t     NLOC.SS_CODE='CR'\r\n\t\t  AND \t     NPLA.LOCATION_TYPE_CODE='POSTAL ADDRESS'\r\n\t\t  INNER JOIN $$COMREFVWDB.N_POSTAL_ADDRESS_LOCATOR NPAL\r\n\t\t  ON \t     NLOC.LOCATOR_KEY=NPAL.LOCATOR_KEY \r\n\t\t) END_CTRY\r\nON \t     WCMP.DV_END_CUST_PARTY_KEY = END_CTRY.PARTY_KEY",
