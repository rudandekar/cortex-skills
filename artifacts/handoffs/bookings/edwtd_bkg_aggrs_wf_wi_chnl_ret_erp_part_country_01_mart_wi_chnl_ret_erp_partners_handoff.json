      "attributes": {
        "Sql Query": "SELECT \r\n\tEDPI.SOLD_TO_CUSTOMER_KEY\tAS SOLD_TO_CUSTOMER_KEY,\r\n\tEDPI.BILL_TO_CUSTOMER_KEY\tAS BILL_TO_CUSTOMER_KEY,\r\n\tEDPI.END_CUSTOMER_KEY\t\tAS END_CUSTOMER_KEY,\r\n\tEDPI.DV_END_CUSTOMER_KEY\tAS DV_END_CUSTOMER_KEY,\r\n\tEDPI.SALES_TERRITORY_KEY\tAS SALES_TERRITORY_KEY, \r\n\tEDPI.DV_END_CUSTOMER_PARTY_KEY AS DV_END_CUSTOMER_PARTY_KEY, \r\n\tEDPI.BILL_TO_PARTY_KEY\t\tAS BILL_TO_PARTY_KEY,\r\n\tEDPI.SOLD_TO_PARTY_KEY\t\tAS SOLD_TO_PARTY_KEY,\r\n\tEDPI.PARTNER_SITE_PARTY_KEY_INT AS PARTNER_SITE_PARTY_KEY_INT,\r\n\tEDPI.DD_GRNDPARNT_PARTNER_PARTY_KEY\t\tAS DD_GRNDPARNT_PARTNER_PARTY_KEY,\r\n\tCOALESCE(PART_CTRY.ISO_COUNTRY_CODE, 'UNK') AS PARTNER_COUNTRY,\r\n\tCOALESCE(END_CTRY.ISO_COUNTRY_CODE, 'UNK') AS DV_END_CUST_COUNTRY,\r\n\tEDPI.SHIP_TO_CUSTOMER_KEY\tAS SHIP_TO_CUSTOMER_KEY,\r\n\tEDPI.PARTNER_BILL_TO_CUST_PARTY_KEY AS PARTNER_BILL_TO_CUST_PARTY_KEY  /* ADDED AS PART OF ATHENA */\r\n\tFROM $$STGDB.WI_CHNL_RET_ERP_PARTNERS  EDPI\r\n\tLEFT OUTER JOIN (\r\n\t\tSEL NPLA.PARTY_KEY, NPAL.ISO_COUNTRY_CODE\r\n\t\tFROM $$COMREFVWDB.N_PARTY_LOCATOR_ASGN NPLA\r\n\t\tINNER JOIN $$COMREFVWDB.N_LOCATOR  NL\r\n\t\t\tON NPLA.LOCATOR_KEY = NL.LOCATOR_KEY\r\n\t\t\tAND NL.SS_CODE = 'CR'\r\n\t\t\tAND NPLA.LOCATION_TYPE_CODE = 'POSTAL ADDRESS'\r\n\t\tINNER JOIN $$COMREFVWDB.N_POSTAL_ADDRESS_LOCATOR NPAL\r\n\t\t\tON NPLA.LOCATOR_KEY = NPAL.LOCATOR_KEY) PART_CTRY\r\n\tON EDPI.PARTNER_SITE_PARTY_KEY_INT = PART_CTRY.PARTY_KEY \r\n\tLEFT OUTER JOIN (\r\n\t\tSEL NPLA.PARTY_KEY, NPAL.ISO_COUNTRY_CODE\r\n\t\tFROM $$COMREFVWDB.N_PARTY_LOCATOR_ASGN NPLA\r\n\t\tINNER JOIN $$COMREFVWDB.N_LOCATOR  NL\r\n\t\t\tON NPLA.LOCATOR_KEY = NL.LOCATOR_KEY\r\n\t\t\tAND NL.SS_CODE = 'CR'\r\n\t\t\tAND NPLA.LOCATION_TYPE_CODE = 'POSTAL ADDRESS'\r\n\t\tINNER JOIN $$COMREFVWDB.N_POSTAL_ADDRESS_LOCATOR NPAL\r\n\t\t\tON NPLA.LOCATOR_KEY = NPAL.LOCATOR_KEY\t) END_CTRY\r\n\tON EDPI.DV_END_CUSTOMER_PARTY_KEY = END_CTRY.PARTY_KEY",
        "User Defined Join": "",
