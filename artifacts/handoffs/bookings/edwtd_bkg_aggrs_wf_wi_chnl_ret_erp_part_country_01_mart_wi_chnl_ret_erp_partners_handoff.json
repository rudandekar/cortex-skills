        "Sql Query": "SELECT \r\n\tREP.SOLD_TO_CUSTOMER_KEY \tAS SOLD_TO_CUSTOMER_KEY,\r\n\tREP.BILL_TO_CUSTOMER_KEY\tAS BILL_TO_CUSTOMER_KEY,\r\n\tREP.END_CUSTOMER_KEY\t\tAS END_CUSTOMER_KEY,\r\n\tREP.DV_END_CUSTOMER_KEY\t\tAS DV_END_CUSTOMER_KEY,\r\n\tREP.SALES_TERRITORY_KEY \tAS SALES_TERRITORY_KEY, \r\n\tEBT.DD_CUSTOMER_PARTY_KEY \tAS DV_END_CUSTOMER_PARTY_KEY, \r\n\tBTP.CUSTOMER_PARTY_KEY \t\tAS BILL_TO_PARTY_KEY,\r\n\tSPK.PARTY_KEY \t\t\tAS SOLD_TO_PARTY_KEY,\r\n\tCASE \r\n\t   WHEN PB_PARTY.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NOT NULL AND PB_PARTY.DD_GRNDPARNT_PARTNER_PARTY_KEY > 0 THEN PB_PARTY.PARTNER_SITE_PARTY_KEY /* ADDED AS PART OF ATHENA */ \r\n\t\tWHEN SPS.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NULL THEN -999\r\n\t\tWHEN BPS.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NULL THEN COALESCE(SPS.PARTNER_SITE_PARTY_KEY ,-999)\r\n\t\tWHEN SPS.DD_GRNDPARNT_PARTNER_PARTY_KEY = BPS.DD_GRNDPARNT_PARTNER_PARTY_KEY \r\n\t\t         THEN BPS.PARTNER_SITE_PARTY_KEY \r\n\t\tWHEN SPS.DD_GRNDPARNT_PARTNER_PARTY_KEY  <> BPS.DD_GRNDPARNT_PARTNER_PARTY_KEY \r\n\t\t         THEN SPS.PARTNER_SITE_PARTY_KEY\r\n\t     ELSE -999\r\n\tEND  AS PARTNER_SITE_PARTY_KEY_INT_AS_IS,\r\n\tCASE WHEN PARTNER_SITE_PARTY_KEY_INT_AS_IS = -999 AND SPK.ERP_PARTY_NAME LIKE ANY  ('%CS CAPITAL%','%CISCO SYSTEMS CAPITAL%', 'CISCO SYSTEMS FINANCE %','EXPEDIA INC') THEN COALESCE(SHIPS.PARTNER_SITE_PARTY_KEY,-999)\r\n\tELSE PARTNER_SITE_PARTY_KEY_INT_AS_IS END AS PARTNER_SITE_PARTY_KEY_INT,\r\n\t\r\n\tCOALESCE(SPS.DD_GRNDPARNT_PARTNER_PARTY_KEY,-999) AS DD_GRNDPARNT_PARTNER_PARTY_KEY,\r\n\tREP.SHIP_TO_CUSTOMER_KEY \tAS SHIP_TO_CUSTOMER_KEY,\r\n\tREP.PARTNER_BILL_TO_CUST_PARTY_KEY AS PARTNER_BILL_TO_CUST_PARTY_KEY /* ADDED AS PART OF ATHENA */\r\n\tFROM $$STGDB.WI_CHNL_RET_ERP_PATTERNS REP\r\n\r\n\tINNER JOIN $$ETLVWDB.BT_END_CUSTOMER_BRIDGE EBT\r\n\tON REP.DV_END_CUSTOMER_KEY = EBT.END_CUSTOMER_KEY\r\n\r\n\tINNER JOIN $$COMREFVWDB.N_ERP_CUST_ACCT_LOC_USE BTP\r\n\tON BTP.ERP_CUST_ACCOUNT_LOCATION_KEY  =  REP.BILL_TO_CUSTOMER_KEY \r\n\r\n\tINNER JOIN   (SELECT NCA.CUSTOMER_ACCOUNT_KEY, NEP.PARTY_KEY, NEP.ERP_PARTY_NAME\r\n\tFROM $$COMREFVWDB.N_CUSTOMER_ACCOUNT NCA\r\n\tINNER JOIN  $$COMREFVWDB.N_ERP_PARTY NEP\r\n\tON NEP.ERP_PARTY_NUMBER = NCA.ERP_CUSTOMER_NUMBER) SPK\r\n\r\n\tON REP.SOLD_TO_CUSTOMER_KEY = SPK.CUSTOMER_ACCOUNT_KEY\r\n\r\n\tLEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE  SPS\r\n\tON SPK.PARTY_KEY=SPS.PARTNER_SITE_PARTY_KEY\r\n\tAND SPS.SOURCE_DELETED_FLG='N'\r\n\r\n\tLEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE  BPS\r\n\tON BTP.CUSTOMER_PARTY_KEY=BPS.PARTNER_SITE_PARTY_KEY\r\n\tAND BPS.SOURCE_DELETED_FLG='N'\r\n\t\r\n    LEFT OUTER JOIN $$COMREFVWDB.N_ERP_CUST_ACCT_LOC_USE STP\r\n    ON STP.ERP_CUST_ACCOUNT_LOCATION_KEY = REP.SHIP_TO_CUSTOMER_KEY\r\n  \r\n    LEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE SHIPS\r\n    ON STP.CUSTOMER_PARTY_KEY=SHIPS.PARTNER_SITE_PARTY_KEY\r\n    AND SHIPS.SOURCE_DELETED_FLG='N'\r\n\t  /* ADDED AS PART OF ATHENA */\r\n  \r\n     LEFT OUTER JOIN $$COMREFVWDB.N_ERP_CUST_ACCT_LOC_USE PART_BILL\r\n     ON PART_BILL.ERP_CUST_ACCOUNT_LOCATION_KEY = REP.PARTNER_BILL_TO_CUST_PARTY_KEY\r\n   \r\n     LEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE PB_PARTY\r\n     ON PART_BILL.CUSTOMER_PARTY_KEY=PB_PARTY.PARTNER_SITE_PARTY_KEY\r\n     AND PB_PARTY.SOURCE_DELETED_FLG='N'",
        "User Defined Join": "",
