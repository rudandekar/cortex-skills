      "attributes": {
        "Sql Query": "SELECT SOLVI.SALES_ORDER_LINE_KEY,\r\nSOLVI.SALES_ORDER_LINE_KEY AS RU_CONFIG_SUB_PARENT_SOL_KEY\r\nFROM  $$STGDB.WI_SALES_ORDER_LINE_V1_UPD1 SOLVI, \r\n$$SLSORDVWDB.N_SALES_ORDER_LINE_TV NSOL, \r\n$$COMREFVWDB.N_PRODUCT NP\r\nWHERE NSOL.SALES_ORDER_LINE_KEY=SOLVI.SALES_ORDER_LINE_KEY\r\nAND NSOL.PRODUCT_KEY=NP.ITEM_KEY\r\nAND NP.RU_BK_PRODUCT_FAMILY_ID IN ('UCS','UCSB','UCSC','UCSX','UCSE','UCSV')       \r\nAND NP.BK_PRODUCT_TYPE_ID  ='SERVER'\r\nAND NP.BK_ITEM_TYPE_CODE  <>'OPTION CLASS'\r\nAND SOLVI.RU_CONFIG_PRNT_SLS_ORDR_LN_KEY = -999\r\nAND NOT EXISTS\r\n(\r\nSELECT 1 FROM  $$STGDB.WI_SALES_ORDER_LINE_V1_UPD2 SOLVU\r\nWHERE SOLVU.SALES_ORDER_LINE_KEY=SOLVI.SALES_ORDER_LINE_KEY)",
