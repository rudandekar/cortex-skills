      "attributes": {
        "Sql Query": "SELECT\r\nPRODUCT_FAMILY AS BK_PRODUCT_FAMILY_ID,\r\nRFWY.FISCAL_WEEK_NUMBER_INT AS BK_FISCAL_WEEK_NUM_INT,\r\nRFWY.FISCAL_YEAR_NUMBER_INT AS BK_FISCAL_YEAR_NUM_INT,\r\nRFWY.fiscal_CALENDAR_CODE AS BK_FISCAL_CALENDAR_CD,\r\n'UNKNOWN' AS BK_SALES_CHANNEL_SRC_TYPE,\r\nDIMENSION AS BK_SALES_CHANNEL_CD,\r\nPHYSICAL_GROSS_PLAN AS PHYSICAL_GROSS_PLAN_USD_AMT,\r\nTOTAL_GROSS_PLAN AS TOTAL_GROSS_PLAN_USD_AMT,\r\nRFDTY.FISCAL_MONTH_START_DATE AS BK_PLAN_PUBLISH_DT,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' as ACTION_CODE,\r\n'I' AS DML_TYPE \r\n\r\nfrom $$STGDB.ST_XXCMF_SP_CRP_GROSS_BKGS ST\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_WEEK_TO_YEAR RFWY\r\nON ST.FISCAL_WEEK_START_DATE BETWEEN RFWY.FISCAL_WEEK_START_DATE AND RFWY.FISCAL_WEEK_END_DATE\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR RFDTY\r\non CREATION_DATE=CALENDAR_DATE",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
