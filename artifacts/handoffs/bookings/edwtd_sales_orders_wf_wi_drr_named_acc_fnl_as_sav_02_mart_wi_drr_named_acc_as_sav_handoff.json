      "attributes": {
        "Sql Query": "SELECT \r\n MT.BOOKINGS_MEASURE_KEY  ,        \r\n MT.BOOKINGS_PROCESS_DATE  ,       \r\n MT.BKGS_MEASURE_TRANS_TYPE_CODE  ,\r\n MT.SALES_ACCOUNT_GROUP_PARTY_KEY  AS OLD_SALES_ACCNT_GRP_PARTY_KEY,\r\n WI_NA.DV_END_CUST_PARTY_KEY ,\r\n WI_NA.LINK_CUSTOMER_PARTY_KEY,\r\n WI_NA.NEW_SA_MEMBER_ID_INT,\r\n WI_NA.REASON_DESC_END_CUST,\r\n ENRICH_SAV.REASON_DESCR AS REASON_DESCR,  \r\n SALES_CREDIT_SPLIT_PCT,\r\n /*added the below columns as part of April CD release */\r\n  WI_NA.SLS_ACCT_GROUP_SALES_TERR_KEY,\r\n WI_NA.SALES_REP_NUM ,\r\n WI_NA.EP_OTM_TERRITORY_ID_INT,\r\n WI_NA.FIN_ADJ_KEY,\r\n WI_NA.PROCESS_TYPE\r\nFROM \r\n ( SELECT\r\n    BOOKINGS_MEASURE_KEY,\r\n BKGS_MEASURE_TRANS_TYPE_CODE,\r\n BOOKINGS_PROCESS_DATE,\r\n SALES_ACCOUNT_GROUP_PARTY_KEY,\r\n ISO_COUNTRY_CODE,\r\n FIN_ADJ_KEY,\r\n PROCESS_TYPE\r\n   FROM $$STGDB.$$WI_DRR_BOOKINGS_INCRMENTAL\r\n   GROUP BY 1,2,3,4,5,6,7) MT\r\n INNER JOIN \r\n (\r\n SELECT BOOKINGS_MEASURE_KEY  ,        \r\n BOOKINGS_PROCESS_DATE  ,       \r\n BKGS_MEASURE_TRANS_TYPE_CODE ,\r\n DV_END_CUST_PARTY_KEY ,\r\n SALES_ACCOUNT_GROUP_PARTY_KEY,\r\n LINK_CUSTOMER_PARTY_KEY,\r\n NEW_SA_MEMBER_ID_INT,\r\n REASON_DESC_END_CUST,\r\n ISO_COUNTRY_CODE,\r\n SALES_CREDIT_SPLIT_PCT,\r\n /*added the below columns as part of April CD release */\r\n  SLS_ACCT_GROUP_SALES_TERR_KEY,\r\n SALES_REP_NUM ,\r\nEP_OTM_TERRITORY_ID_INT,\r\nFIN_ADJ_KEY,\r\nPROCESS_TYPE\r\n FROM $$STGDB.WI_DRR_NAMED_ACCOUNT\r\n WHERE (BOOKINGS_MEASURE_KEY  , BOOKINGS_PROCESS_DATE  ,BKGS_MEASURE_TRANS_TYPE_CODE)\r\n IN ( SELECT BOOKINGS_MEASURE_KEY ,BOOKINGS_PROCESS_DATE ,BKGS_MEASURE_TRANS_TYPE_CODE\r\n  FROM $$STGDB.WI_DRR_NAMED_ACCOUNT NM,$$SLSORDVWDB.N_DYN_RESTMT_ENRICH_REASON ENRICH_SAV\r\n    WHERE NM.REASON_DESCR = ENRICH_SAV.REASON_DESCR\r\n\tAND ENRICH_SAV.BK_REASON_CD='NA_SINGLE'\r\n    GROUP BY 1,2,3 \r\n    HAVING ROUND(SUM(SALES_CREDIT_SPLIT_PCT))>100 \r\n    ))WI_NA\r\n ON  WI_NA.BOOKINGS_MEASURE_KEY=MT.BOOKINGS_MEASURE_KEY\r\n AND   WI_NA.BKGS_MEASURE_TRANS_TYPE_CODE=MT.BKGS_MEASURE_TRANS_TYPE_CODE\r\n AND   WI_NA.BOOKINGS_PROCESS_DATE=MT.BOOKINGS_PROCESS_DATE\r\n AND WI_NA.SALES_ACCOUNT_GROUP_PARTY_KEY=MT.SALES_ACCOUNT_GROUP_PARTY_KEY\r\n INNER JOIN $$SLSORDVWDB.N_DYN_RESTMT_ENRICH_REASON ENRICH_SAV\r\n ON ENRICH_SAV.BK_REASON_CD='NA_VLTD_SAV'\r\n /*AND WI_NA.ISO_COUNTRY_CODE = MT.ISO_COUNTRY_CODE*/",
        "User Defined Join": "",
