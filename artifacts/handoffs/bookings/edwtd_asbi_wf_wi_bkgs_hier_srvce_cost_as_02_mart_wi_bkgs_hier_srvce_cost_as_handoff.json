      "attributes": {
        "Sql Query": "SEL\r\nCASE WHEN RFDTY.WORKDAY_IN_FISCAL_YTD_COUNT <=15 \r\nTHEN\r\n 'R_SALES_HIERARCHY_ME'\r\nWHEN RFDTY.WORKDAY_IN_FISCAL_MTD_COUNT<=5 \r\nTHEN \r\n'R_SALES_HIERARCHY_ME'\r\nELSE \r\n'R_SALES_HIERARCHY_FIN'\r\n END AS TABLE_NAME1,\r\nCASE WHEN RFDTY.WORKDAY_IN_FISCAL_YTD_COUNT <=15 \r\nTHEN \r\n'R_PRODUCTS_ME'\r\nWHEN RFDTY.WORKDAY_IN_FISCAL_MTD_COUNT<=5 \r\nTHEN \r\n'R_PRODUCTS_ME'\r\nELSE \r\n'R_PRODUCTS_FIN' \r\nEND AS TABLE_NAME2\r\nFROM $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR rfdty\r\nWHERE rfdty.CALENDAR_DATE =current_date()",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
