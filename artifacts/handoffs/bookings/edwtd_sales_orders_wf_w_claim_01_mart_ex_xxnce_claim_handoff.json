      "attributes": {
        "Sql Query": "SELECT\r\nST_CLAIM.CLAIM_ID                      \r\n,ST_CLAIM.CLAIM_STATUS                  \r\n,ST_CLAIM.TERRITORY_TYPE_CODE           \r\n,ST_CLAIM.CREATION_DATE                 \r\n,ST_CLAIM.CREATED_BY                    \r\n,ST_CLAIM.LAST_UPDATED_DATE             \r\n,ST_CLAIM.LAST_UPDATED_BY               \r\n,ST_CLAIM.OBJECT_VERSION_NUMBER         \r\n,ST_CLAIM.CLAIM_REASON_CODE             \r\n,ST_CLAIM.CLAIM_COMMENT                 \r\n,ST_CLAIM.CLAIM_VALUE                \r\nFROM\r\n$$STGDB.ST_XXNCE_CLAIM ST_CLAIM\r\nWHERE NOT EXISTS \r\n( SELECT 1 FROM $$STGDB.WI_CLM_FND_USER CRCD_BY\r\n   WHERE CRCD_BY.USER_ID = CASE WHEN ST_CLAIM.CREATED_BY IS NULL THEN -999 \r\n\t\t\t\t\t\t\t\t\tWHEN ST_CLAIM.CREATED_BY=999 THEN -999 \r\n\t\t\t\t\t\t\t\t\tELSE ST_CLAIM.CREATED_BY END)\r\nOR NOT EXISTS\r\n( SELECT 1 FROM $$STGDB.WI_CLM_FND_USER UPTD_BY\r\n  WHERE UPTD_BY.USER_ID = CASE WHEN ST_CLAIM.LAST_UPDATED_BY IS NULL THEN -999 \r\n\t\t\t\t\t\t\t\t    WHEN ST_CLAIM.LAST_UPDATED_BY=999 THEN -999 \r\n\t\t\t\t\t\t\t\t\tELSE ST_CLAIM.LAST_UPDATED_BY END)",
