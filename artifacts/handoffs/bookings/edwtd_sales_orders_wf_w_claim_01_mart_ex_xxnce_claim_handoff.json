      "attributes": {
        "Sql Query": "SELECT\r\nSMC.CLAIM_KEY,\r\nSXC.CLAIM_ID AS SK_CLAIM_ID,\r\nSXC.CLAIM_COMMENT AS CLAIM_COMMENTS_TXT,\r\nSXC.CLAIM_REASON_CODE AS CLAIM_REASON_TXT,\r\nSXC.TERRITORY_TYPE_CODE AS SALES_TERR_ASGMT_TYPE_CD,\r\nSXC.CLAIM_STATUS AS CLAIM_STATUS_NAME,\r\nSXC.CREATION_DATE AS CREATE_DTM,\r\nSXC.LAST_UPDATED_DATE AS LAST_UPDATE_DTM,\r\nSXC.CLAIM_VALUE AS CLAIM_USD_AMT,\r\nSXC.CLAIM_REASON_CODE AS CLAIM_REASON_DESCR,\r\nCOALESCE(CRCD_BY.CISCO_WORKER_PARTY_KEY,-999) AS CRTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE(UPTD_BY.CISCO_WORKER_PARTY_KEY,-999) AS LST_UPTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' AS ACTION_CODE,\r\n'=' AS DML_TYPE\r\n\r\nFROM\r\n$$STGDB.ST_XXNCE_CLAIM SXC\r\n\r\nINNER JOIN $$ETLVWDB.SM_CLAIM SMC\r\nON SXC.CLAIM_ID=SMC.SK_CLAIM_ID\r\n\r\nLEFT OUTER JOIN $$STGDB.WI_CLM_FND_USER CRCD_BY\r\n  ON CRCD_BY.USER_ID = SXC.CREATED_BY \r\n \r\nLEFT OUTER JOIN $$STGDB.WI_CLM_FND_USER UPTD_BY\r\n  ON UPTD_BY.USER_ID = SXC.LAST_UPDATED_BY",
        "User Defined Join": "",
