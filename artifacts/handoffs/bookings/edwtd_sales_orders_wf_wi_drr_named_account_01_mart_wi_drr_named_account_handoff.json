      "attributes": {
        "Sql Query": "SELECT\r\n  NABM.BOOKINGS_MEASURE_KEY    ,      \r\n  NABM.BOOKINGS_PROCESS_DATE   ,      \r\n  NABM.BKGS_MEASURE_TRANS_TYPE_CODE  ,\r\n  NABM.DV_END_CUST_PARTY_KEY,\r\n  NABM.REASON_DESC_END_CUST,             \r\n  COALESCE (NM_ACCNT.BK_SA_MEMBER_ID_INT,-999) AS NEW_SA_MEMBER_ID_INT,\r\n  NM_ACCNT.LINK_CUSTOMER_PARTY_KEY,\r\n  NABM.ISO_COUNTRY_CODE,\r\n  NM_ACCNT.SALES_ACCOUNT_GROUP_PARTY_KEY,\r\n  NM_ACCNT.SALES_CREDIT_SPLIT_PCT,\r\n  ENRICH_SAV.REASON_DESCR AS REASON_DESCR,\r\n  /*added the below columns as part of April CD release */\r\n  NM_ACCNT.SLS_ACCT_GROUP_SALES_TERR_KEY,\r\n  NM_ACCNT.SALES_REP_NUM,\r\n  -999 as EP_OTM_TERRITORY_ID_INT,\r\n  'N' as NA_PROCESSED_FLG,\r\n  NABM.FIN_ADJ_KEY,\r\n  NABM.PROCESS_TYPE,\r\n  CASE WHEN  NABM.ISO_COUNTRY_CODE= NM_ACCNT.ISO_COUNTRY_CODE  THEN 'Y' ELSE 'N' END COUNTRY_MATCH\r\n FROM\r\n ( SELECT BOOKINGS_MEASURE_KEY,BOOKINGS_PROCESS_DATE,BKGS_MEASURE_TRANS_TYPE_CODE,DV_END_CUST_PARTY_KEY,ISO_COUNTRY_CODE,REASON_DESC AS REASON_DESC_END_CUST,FIN_ADJ_KEY,PROCESS_TYPE\r\n     FROM $$STGDB.WI_DRR_BOOKINGS_PARTY_ENRICH\r\n  WHERE RULE_PROCESS_FLAG='N'\r\n  QUALIFY ROW_NUMBER() OVER (PARTITION BY BOOKINGS_MEASURE_KEY,BOOKINGS_PROCESS_DATE,BKGS_MEASURE_TRANS_TYPE_CODE,DV_END_CUST_PARTY_KEY ORDER BY REASON_DESC)=1\r\n ) NABM\r\n INNER JOIN \r\n ( \r\n  SELECT \r\n   SYS.CUSTOMER_PARTY_KEY,\r\n   SYS.SALES_ACCOUNT_GROUP_PARTY_KEY,\r\n   SYS.LINK_CUSTOMER_PARTY_KEY,\r\n   SYS.BK_SA_MEMBER_ID_INT,\r\n   SYS.ISO_COUNTRY_CODE ,\r\n   SYS.SALES_CREDIT_SPLIT_PCT,\r\n   SYS.SALES_REP_NUM,\r\n   SYS.SLS_ACCT_GROUP_SALES_TERR_KEY,\r\n   SYS.HIBERNATION_FLG,\r\nCASE WHEN SAOA.BK_OWNER_SALES_REP_NUM IS NOT NULL THEN 'Y' ELSE 'N' END ORPHANED_FLG\r\n  FROM \r\n   $$STGDB.$$WI_DRR_SYSVIEW_PARTY SYS  inner join ( \r\n  SELECT * \r\n  FROM \r\n  $$ETLVWDB.WI_DRR_PROCESS_CONTROL \r\n  WHERE  PROCESS_TYPE = $$PROCESS_TYPE and ACTIVE_FLAG = 'Y'\r\n ) CTL  on 1=1 \r\n   LEFT JOIN\r\n$$COMREFVWDB.N_SALES_ACCT_OWNER_ASSIGNMENT SAOA \r\nON SYS.SALES_ACCOUNT_GROUP_PARTY_KEY = SAOA.SALES_ACCOUNT_GROUP_PARTY_KEY\r\nAND SAOA.SOURCE_DELETED_FLG = 'N'\r\nAND CTL.PROCESS_DATE BETWEEN SAOA.BK_ASSIGNMENT_START_DT AND SAOA.ASSIGNMENT_END_DT\r\n  WHERE SYS.SALES_ACCOUNT_GROUP_TYPE_CD = 'NAMED_ACCOUNT'\r\n  QUALIFY ROW_NUMBER() OVER (PARTITION BY SYS.CUSTOMER_PARTY_KEY,SYS.SALES_ACCOUNT_GROUP_PARTY_KEY ORDER BY SYS.BK_SA_MEMBER_ID_INT DESC) = 1\r\n  ) NM_ACCNT\r\n   ON NABM.DV_END_CUST_PARTY_KEY= NM_ACCNT.CUSTOMER_PARTY_KEY\r\n   --AND NABM.ISO_COUNTRY_CODE= NM_ACCNT.ISO_COUNTRY_CODE \r\n   AND NM_ACCNT.HIBERNATION_FLG = 'N'  \r\n   and NM_ACCNT.ORPHANED_FLG='Y'\r\n   INNER JOIN $$SLSORDVWDB.N_DYN_RESTMT_ENRICH_REASON ENRICH_SAV\r\n   ON ENRICH_SAV.BK_REASON_CD='NA_SINGLE'\r\n QUALIFY ROW_NUMBER() OVER (PARTITION BY BOOKINGS_MEASURE_KEY,BOOKINGS_PROCESS_DATE,BKGS_MEASURE_TRANS_TYPE_CODE,NEW_SA_MEMBER_ID_INT \r\n ORDER BY  REASON_DESC_END_CUST,DV_END_CUST_PARTY_KEY )=1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
