      "attributes": {
        "Sql Query": "SELECT\r\nNRPT.ADVANCED_TECHNOLOGY_NAME,\r\nNRPT.DD_CUSTOMER_PARTY_KEY,\r\nNRPT.HQ_CUSTOMER_PARTY_KEY,\r\nNRPT.FISCAL_YEAR_QUARTER_NUMBER_INT,\r\nCASE WHEN (MIN(NRPT.NEW_REPEAT_TMS_FLG ) OVER( PARTITION BY  DD_CUSTOMER_PARTY_KEY,NRPT.ADVANCED_TECHNOLOGY_NAME\r\n  ORDER BY NRPT.FISCAL_YEAR_QUARTER_NUMBER_INT  \r\nROWS BETWEEN 1 PRECEDING AND 1 PRECEDING) ) IS NULL THEN 'N' ELSE 'R'  END  NEW_REPEAT_TMS_FLG,\r\nCASE WHEN (MIN(NRPT.LAST_PURCHASE_TMS_FLG ) OVER( PARTITION BY  DD_CUSTOMER_PARTY_KEY, NRPT.ADVANCED_TECHNOLOGY_NAME\r\n ORDER BY NRPT.FISCAL_YEAR_QUARTER_NUMBER_INT  DESC\r\nROWS BETWEEN 1 PRECEDING AND 1 PRECEDING) ) IS NULL THEN 'Y' ELSE 'N'  END  LAST_PURCHASE_TMS_FLG,\r\nNRTHQ.NEW_REPEAT_TMS_HQ_FLG,\r\nNRTHQ.LAST_PURCHASE_TMS_HQ_FLG\r\nFROM\r\n(SELECT\r\nADVANCED_TECHNOLOGY_NAME, \r\nDD_CUSTOMER_PARTY_KEY,\r\nHQ_CUSTOMER_PARTY_KEY,\r\nFISCAL_YEAR_QUARTER_NUMBER_INT,\r\nNEW_REPEAT_TMS_FLG,\r\nLAST_PURCHASE_TMS_FLG\r\nFROM\r\n$$STGDB.WI_NR_TRX WNT\r\nGROUP BY\r\nADVANCED_TECHNOLOGY_NAME,\r\nDD_CUSTOMER_PARTY_KEY,\r\nHQ_CUSTOMER_PARTY_KEY,\r\nFISCAL_YEAR_QUARTER_NUMBER_INT,\r\nNEW_REPEAT_TMS_FLG,\r\nLAST_PURCHASE_TMS_FLG\r\nHAVING SUM(WNT.DD_COMP_US_NET_PRICE_AMOUNT) >0) NRPT\r\nLEFT OUTER JOIN\r\n(SELECT\r\nADVANCED_TECHNOLOGY_NAME, \r\nHQ_CUSTOMER_PARTY_KEY,\r\nFISCAL_YEAR_QUARTER_NUMBER_INT,\r\nCASE WHEN (MIN(WNT.NEW_REPEAT_TMS_HQ_FLG ) OVER( PARTITION BY  HQ_CUSTOMER_PARTY_KEY,ADVANCED_TECHNOLOGY_NAME\r\n  ORDER BY FISCAL_YEAR_QUARTER_NUMBER_INT  \r\nROWS BETWEEN 1 PRECEDING AND 1 PRECEDING) ) IS NULL THEN 'N' ELSE 'R'  END  NEW_REPEAT_TMS_HQ_FLG,\r\nCASE WHEN (MIN(WNT.LAST_PURCHASE_TMS_HQ_FLG ) OVER( PARTITION BY  HQ_CUSTOMER_PARTY_KEY, ADVANCED_TECHNOLOGY_NAME\r\n ORDER BY FISCAL_YEAR_QUARTER_NUMBER_INT  DESC\r\nROWS BETWEEN 1 PRECEDING AND 1 PRECEDING) ) IS NULL THEN 'Y' ELSE 'N'  END  LAST_PURCHASE_TMS_HQ_FLG\r\nFROM\r\n$$STGDB.WI_NR_TRX WNT\r\nGROUP BY\r\nADVANCED_TECHNOLOGY_NAME,\r\nHQ_CUSTOMER_PARTY_KEY,\r\nFISCAL_YEAR_QUARTER_NUMBER_INT,\r\nNEW_REPEAT_TMS_HQ_FLG,\r\nLAST_PURCHASE_TMS_HQ_FLG\r\nHAVING SUM(WNT.DD_COMP_US_NET_PRICE_AMOUNT) >0 )NRTHQ\r\nON\r\nNRTHQ.HQ_CUSTOMER_PARTY_KEY = NRPT.HQ_CUSTOMER_PARTY_KEY\r\nAND\r\nNRTHQ.ADVANCED_TECHNOLOGY_NAME = NRPT.ADVANCED_TECHNOLOGY_NAME\r\nAND\r\nNRTHQ.FISCAL_YEAR_QUARTER_NUMBER_INT = NRPT.FISCAL_YEAR_QUARTER_NUMBER_INT",
