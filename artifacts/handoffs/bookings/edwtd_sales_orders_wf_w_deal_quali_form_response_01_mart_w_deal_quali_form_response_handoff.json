      "attributes": {
        "Sql Query": "SELECT \r\nSRC.BK_DEAL_ID,                   \r\nSRC.BK_REBATE_QUESTION_ID_INT   , \r\nSRC.BK_QUESTION_RESPONSE_TXT ,    \r\nSRC.SRC_CRTD_CSCO_WRKR_PRTY_KEY   ,\r\nSRC.SRC_CREATED_DTM         ,     \r\nSRC.DV_SRC_CREATED_DT    ,        \r\nSRC.SRC_UPDTD_CSCO_WRKR_PRTY_KEY  ,\r\nSRC.SRC_UPDATED_DTM     ,         \r\nSRC.DV_SRS_UPDATED_DT ,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NDQFR.BK_DEAL_ID IS NULL AND NDQFR.BK_REBATE_QUESTION_ID_INT IS NULL AND NDQFR.BK_QUESTION_RESPONSE_TXT IS NULL \r\nTHEN 'I' ELSE 'U' END AS DML_TYPE\r\nFROM\r\n(SELECT CAST(SDCQRO.DEAL_OBJECT_ID AS VARCHAR (50)) AS BK_DEAL_ID, \r\nCAST(QUESTION_ID AS BIGINT) AS  BK_REBATE_QUESTION_ID_INT   , \r\nSDCQRO.VALUE_NAME AS BK_QUESTION_RESPONSE_TXT ,    \r\nCOALESCE(NCWP.CISCO_WORKER_PARTY_KEY, '-999') AS SRC_CRTD_CSCO_WRKR_PRTY_KEY   ,\r\nSDCQRO.CREATION_DATE AS SRC_CREATED_DTM         ,     \r\nCAST (SDCQRO.CREATION_DATE AS DATE) DV_SRC_CREATED_DT    ,        \r\nCOALESCE (NCWP1.CISCO_WORKER_PARTY_KEY, '-999') AS SRC_UPDTD_CSCO_WRKR_PRTY_KEY  ,\r\nSDCQRO.LAST_UPDATE_DATE AS SRC_UPDATED_DTM     ,         \r\nCAST (SDCQRO.LAST_UPDATE_DATE AS DATE) DV_SRS_UPDATED_DT \r\nFROM \r\n$$STGDB.ST_DCV_CQ_QTN_RSPNS_OEM SDCQRO\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP\r\nON NCWP.CEC_ID = SDCQRO.CREATED_BY\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP1\r\nON NCWP1.CEC_ID = SDCQRO.LAST_UPDATED_BY ) SRC\r\nLEFT OUTER JOIN $$SLSORDVWDB.N_DEAL_QUALI_FORM_RESPONSE NDQFR\r\nON SRC.BK_DEAL_ID  = NDQFR.BK_DEAL_ID\r\nAND SRC.BK_REBATE_QUESTION_ID_INT = NDQFR.BK_REBATE_QUESTION_ID_INT\r\nAND SRC.BK_QUESTION_RESPONSE_TXT = NDQFR.BK_QUESTION_RESPONSE_TXT",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "DELETE FROM $$WORKDB.W_DEAL_QUALI_FORM_RESPONSE;\r\n\r\nCOLLECT STATS ON $$STGDB.ST_DCV_CQ_QTN_RSPNS_OEM;",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
