      "attributes": {
        "Sql Query": "SELECT \r\nOVRLY.OVERLAY_BOOKINGS_MEASURE_KEY ,\r\nOVRLY.OVERLAY_BOOKINGS_PROCESS_DATE ,\r\nOVRLY.OVRLY_BKGS_MSR_TRANS_TYPE_CODE ,\r\nOVRLY.DV_END_CUST_PARTY_KEY ,\r\nOVRLY.BK_SA_MEMBER_ID_INT ,\r\nOVRLY.LINK_CUSTOMER_PARTY_KEY ,\r\nOVRLY.SALES_ACCOUNT_GROUP_PARTY_KEY ,\r\nOVRLY.DV_END_CUST_REASON_DESCR ,\r\nOVRLY.DV_END_CUST_OWNERSHIP_SPLT_PCT ,\r\nOVRLY.BK_EAC_ORG_ID,\t\r\nOVRLY.BK_EAC_GROUP_ID,\t\r\nOVRLY.BK_EAC_RULE_ID\t,\t\r\nCOALESCE(OVRLY.BK_SALES_REP_NUM, '-999') AS BK_SALES_REP_NUM,\r\nCOALESCE(OVRLY.SALES_TERRITORY_KEY,-999) AS SALES_TERRITORY_KEY,\r\nOVRLY.DV_RSTMT_REASON_CD,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS  EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nOVRLY.LAST_UPDATE_DATE,\r\nOVRLY.PROCESS_DATE,\r\nOVRLY.PROCESS_TYPE,\r\ncoalesce(OVRLY.PARENT_EAC_RULE_ID,-999) as PARENT_EAC_RULE_ID,\r\nOVRLY.PROFILE_CHK_ID as  PROFILE_CHK_ID,\r\nOVRLY.DV_SAV_RSTMT_REASON_CD as DV_SAV_RSTMT_REASON_CD\r\nFROM \r\n$$STGDB.$$WI_OVERLAY_DRR OVRLY\r\nWHERE \r\nNOT EXISTS (SELECT 1 FROM $$SLSORDVWDB.$$MT_OVERLAY_DRR_NG NG\r\nWHERE NG.OVERLAY_BOOKINGS_MEASURE_KEY = OVRLY.OVERLAY_BOOKINGS_MEASURE_KEY\r\nAND NG.OVERLAY_BOOKINGS_PROCESS_DATE = OVRLY.OVERLAY_BOOKINGS_PROCESS_DATE\r\nAND NG.OVRLY_BKGS_MSR_TRANS_TYPE_CODE = OVRLY.OVRLY_BKGS_MSR_TRANS_TYPE_CODE\r\nAND NG.BK_EAC_ORG_ID = OVRLY.BK_EAC_ORG_ID\r\nAND NG.PARENT_EAC_RULE_ID = OVRLY.PARENT_EAC_RULE_ID\r\nAND NG.PROFILE_CHK_ID = OVRLY.PROFILE_CHK_ID\r\n)",
