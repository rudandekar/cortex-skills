      "attributes": {
        "Sql Query": "SELECT\r\n  TVOUTPUT.BK_FREIGHT_TERMS_CODE,\r\n  TVOUTPUT.START_TV_DATE,\r\n  COALESCE( MAX(TVOUTPUT.START_TV_DATE - INTERVAL '1' DAY) \r\n  OVER (PARTITION BY TVOUTPUT.BK_FREIGHT_TERMS_CODE\r\n  ORDER BY TVOUTPUT.START_TV_DATE ASC \r\n  ROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING), DATE '3500-01-01') AS END_TV_DATE,\r\n  TVOUTPUT.FREIGHT_TERMS_NAME,\r\n  TVOUTPUT.FREIGHT_TERMS_DESCRIPTION,\r\n  TVOUTPUT.FREIGHT_TERMS_ENABLED_FLAG,\r\n  TVOUTPUT.FREIGHT_TERMS_START_ACTIVE_DTM,\r\n  TVOUTPUT.FREIGHT_TERMS_END_ACTIVE_DTM,\r\n  TVOUTPUT.SS_CODE,\r\n  TVOUTPUT.ACTION_CODE,\r\n  TVOUTPUT.EDW_UPDATE_DATETIME,\r\n  ROW_NUMBER() OVER (PARTITION BY TVOUTPUT.BK_FREIGHT_TERMS_CODE\r\n   ORDER BY TVOUTPUT.START_TV_DATE ASC) AS RANK_INDEX,\r\n  (CASE WHEN RANK_INDEX = 1 AND NEFTT.BK_FREIGHT_TERMS_CODE IS NOT NULL THEN 'U' ELSE 'I' END) AS DML_TYPE\r\n FROM\r\n (\r\n SELECT\r\n  BK_FREIGHT_TERMS_CODE,\r\n  START_TV_DATE,\r\n  FREIGHT_TERMS_NAME,\r\n  FREIGHT_TERMS_DESCRIPTION,\r\n  FREIGHT_TERMS_ENABLED_FLAG,\r\n  FREIGHT_TERMS_START_ACTIVE_DTM,\r\n  FREIGHT_TERMS_END_ACTIVE_DTM,\r\n  SS_CODE,\r\n  ACTION_CODE,\r\n  EDW_UPDATE_DATETIME,\r\n  ROW_NUMBER() OVER (PARTITION BY BK_FREIGHT_TERMS_CODE,FREIGHT_TERMS_NAME, FREIGHT_TERMS_DESCRIPTION, FREIGHT_TERMS_ENABLED_FLAG\r\n  ORDER BY EDW_UPDATE_DATETIME DESC) AS row_num\r\n FROM\r\n (\r\n SELECT \r\n  EFLV.LOOKUP_CODE BK_FREIGHT_TERMS_CODE,\r\n  CAST(EFLV.GES_UPDATE_DATE AS DATE) START_TV_DATE,\r\n  EFLV.MEANING FREIGHT_TERMS_NAME,\r\n  EFLV.DESCRIPTION FREIGHT_TERMS_DESCRIPTION,\r\n  EFLV.ENABLED_FLAG FREIGHT_TERMS_ENABLED_FLAG,\r\n  EFLV.START_DATE_ACTIVE FREIGHT_TERMS_START_ACTIVE_DTM,\r\n  EFLV.END_DATE_ACTIVE FREIGHT_TERMS_END_ACTIVE_DTM,\r\n  NSSC.SOURCE_SYSTEM_CODE SS_CODE,\r\n  'X'  ACTION_CODE,\r\n  EFLV.GES_UPDATE_DATE EDW_UPDATE_DATETIME\r\n FROM\r\n  $$ETLVWDB.EL_FND_LOOKUP_VALUES EFLV INNER JOIN \r\n  $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC ON (NSSC.GLOBAL_NAME = EFLV.GLOBAL_NAME)\r\n  QUALIFY ROW_NUMBER() OVER (PARTITION BY  EFLV.LOOKUP_CODE ORDER BY EFLV.GES_UPDATE_DATE DESC ) = 1\r\n WHERE EFLV.GES_UPDATE_DATE > (SELECT LAST_EXTRACT_DATE FROM $$CTLDB.DW_JOB_STREAMS WHERE  JOB_STREAM_ID='wf_W_ERP_FREIGHT_TERMS')\r\n AND EFLV.LOOKUP_TYPE='FREIGHT TERMS'\r\n AND NSSC.GLOBAL_NAME='CG'  /* SJPROD RETIREMENT Q1FY14 */\r\n  UNION ALL\r\n  SELECT \r\n  NEFTT.BK_FREIGHT_TERMS_CODE,\r\n  NEFTT.START_TV_DATE,\r\n  NEFTT.FREIGHT_TERMS_NAME,\r\n  NEFTT.FREIGHT_TERMS_DESCRIPTION,\r\n  NEFTT.FREIGHT_TERMS_ENABLED_FLAG,\r\n  NEFTT.FREIGHT_TERMS_START_ACTIVE_DTM,\r\n  NEFTT.FREIGHT_TERMS_END_ACTIVE_DTM,\r\n  NEFTT.SS_CODE,\r\n  'X'  ACTION_CODE,\r\n  NEFTT.EDW_UPDATE_DATETIME\r\n FROM $$SLSORDVWDB.N_ERP_FREIGHT_TERMS_TV NEFTT\r\n WHERE END_TV_DATE = CAST ('3500-01-01' AS DATE)\r\n AND BK_FREIGHT_TERMS_CODE IN\r\n (\r\n SELECT LOOKUP_CODE\r\n FROM $$ETLVWDB.EL_FND_LOOKUP_VALUES EFLV \r\n INNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC ON (NSSC.GLOBAL_NAME = EFLV.GLOBAL_NAME)\r\n WHERE EFLV.GES_UPDATE_DATE > (SELECT LAST_EXTRACT_DATE FROM $$CTLDB.DW_JOB_STREAMS WHERE  JOB_STREAM_ID='wf_W_ERP_FREIGHT_TERMS')\r\n AND EFLV.LOOKUP_TYPE='FREIGHT TERMS'\r\n AND NSSC.GLOBAL_NAME='CG'  /* SJPROD RETIREMENT Q1FY14 */\r\n )\r\n )TVINPUT\r\n QUALIFY ROW_NUMBER() OVER (PARTITION BY \r\n    TVINPUT.BK_FREIGHT_TERMS_CODE,\r\n    TVINPUT.START_TV_DATE\r\n   ORDER BY TVINPUT.EDW_UPDATE_DATETIME DESC) = 1\r\n )TVOUTPUT\r\n LEFT JOIN $$SLSORDVWDB.N_ERP_FREIGHT_TERMS_TV NEFTT\r\n   ON TVOUTPUT.BK_FREIGHT_TERMS_CODE = NEFTT.BK_FREIGHT_TERMS_CODE\r\n   AND NEFTT.END_TV_DATE = CAST('3500-01-01' AS date)\r\n WHERE TVOUTPUT.row_num = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
