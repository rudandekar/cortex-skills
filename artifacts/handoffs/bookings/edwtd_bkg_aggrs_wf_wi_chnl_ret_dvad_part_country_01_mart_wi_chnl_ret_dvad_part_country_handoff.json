      ],
      "attributes": {
        "Sql Query": "SELECT\r\n\tWDVAD.SOLD_TO_CUSTOMER_KEY \tSOLD_TO_CUSTOMER_KEY,\r\n\tWDVAD.DV_END_CUSTOMER_KEY \tDV_END_CUSTOMER_KEY,\r\n\tWDVAD.SALES_ORDER_KEY \t\tSALES_ORDER_KEY,\r\n\tEBT.DD_CUSTOMER_PARTY_KEY \tDV_END_CUST_PARTY_KEY,\r\n\tCASE WHEN COALESCE(NCPS.DD_GRNDPARNT_PARTNER_PARTY_KEY,-999) = -999 THEN \r\n    CASE WHEN NEP.ERP_PARTY_NAME LIKE ANY  ('%CS CAPITAL%','%CISCO SYSTEMS CAPITAL%', 'CISCO SYSTEMS FINANCE %','EXPEDIA INC')\r\n    THEN COALESCE(SHIPS.PARTNER_SITE_PARTY_KEY,-999) \r\n\tELSE -999 END\r\n\t\tELSE COALESCE(NP.PARTY_KEY,-999) \r\n\tEND \t\t\t\tDEALS_PPSK,\r\n\tWDVAD.SHIP_TO_CUSTOMER_KEY \tSHIP_TO_CUSTOMER_KEY\r\n\r\nFROM $$STGDB.WI_CHNL_RET_DVAD_PATTERNS WDVAD\r\n\r\nINNER JOIN $$ETLVWDB.BT_END_CUSTOMER_BRIDGE EBT\r\n\tON WDVAD.DV_END_CUSTOMER_KEY = EBT.END_CUSTOMER_KEY\r\n\t\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER NSO\r\n\tON WDVAD.SALES_ORDER_KEY = NSO.SALES_ORDER_KEY\t\r\n\t\r\nLEFT OUTER JOIN $$ETLVWDB.EL_DM_DEAL_PARTNER_VW STDEALS\t\r\n\tON NSO.BK_DEAL_ID = STDEALS.OPTY_NUMBER \r\n\t\t\r\nLEFT OUTER JOIN $$COMREFVWDB.N_PARTY NP\r\n\tON STDEALS.PARTNER_SITE_ID = NP.PARTY_SSOT_PARTY_ID_INT AND\r\n\tNP.SS_CODE = 'CR'\r\n\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE NCPS\r\n\tON NCPS.PARTNER_SITE_PARTY_KEY = NP.PARTY_KEY\r\n\tAND NCPS.SOURCE_DELETED_FLG='N'\r\n\t\r\nLEFT OUTER JOIN ( $$COMREFVWDB.N_CUSTOMER_ACCOUNT NCA\r\n   INNER JOIN $$COMREFVWDB.N_ERP_PARTY NEP\r\n   ON(NEP.ERP_PARTY_NUMBER = NCA.ERP_CUSTOMER_NUMBER) \r\n     )\r\n  ON (NCA.CUSTOMER_ACCOUNT_KEY= WDVAD.SOLD_TO_CUSTOMER_KEY )\t\r\n\t\r\nLEFT OUTER JOIN $$COMREFVWDB.N_ERP_CUST_ACCT_LOC_USE STP\r\n  ON STP.ERP_CUST_ACCOUNT_LOCATION_KEY = WDVAD.SHIP_TO_CUSTOMER_KEY\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE SHIPS\r\n  ON STP.CUSTOMER_PARTY_KEY=SHIPS.PARTNER_SITE_PARTY_KEY\r\n  AND SHIPS.SOURCE_DELETED_FLG='N'",
        "User Defined Join": "",
