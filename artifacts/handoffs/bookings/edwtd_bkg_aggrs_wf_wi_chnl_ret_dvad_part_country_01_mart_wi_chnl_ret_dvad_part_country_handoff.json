      "attributes": {
        "Sql Query": "SELECT \r\n\tEDPI.SOLD_TO_CUSTOMER_KEY\t\t\tAS SOLD_TO_CUSTOMER_KEY,\r\n\tEDPI.DV_END_CUSTOMER_KEY\t\t\tAS DV_END_CUSTOMER_KEY,\r\n\tEDPI.SALES_ORDER_KEY\t\t\t\tAS SALES_ORDER_KEY, \r\n\tEDPI.DV_END_CUST_PARTY_KEY\t\t\tAS DV_END_CUST_PARTY_KEY, \r\n\tEDPI.DEALS_PPSK \t\t\t\tAS DEALS_PPSK,\r\n\tCOALESCE(END_CTRY.ISO_COUNTRY_CODE, 'UNK') \tAS DV_END_CUST_COUNTRY_CD,\r\n\tCOALESCE(DEALS_CTRY.ISO_COUNTRY_CODE, 'UNK') \tAS DEALS_CNTRY_CD,\r\n\tEDPI.SHIP_TO_CUSTOMER_KEY\t\t\tAS SHIP_TO_CUSTOMER_KEY\r\n\r\nFROM $$STGDB.WI_CHNL_RET_DVAD_PARTNERS  EDPI\r\n\r\nLEFT OUTER JOIN (\r\nSEL NPLA.PARTY_KEY, NPAL.ISO_COUNTRY_CODE\r\nFROM $$COMREFVWDB.N_PARTY_LOCATOR_ASGN NPLA\r\nINNER JOIN $$COMREFVWDB.N_LOCATOR  NL\r\n\tON NPLA.LOCATOR_KEY = NL.LOCATOR_KEY\r\n\tAND NL.SS_CODE = 'CR'\r\n\tAND NPLA.LOCATION_TYPE_CODE = 'POSTAL ADDRESS'\r\nINNER JOIN $$COMREFVWDB.N_POSTAL_ADDRESS_LOCATOR NPAL\r\n\tON NPLA.LOCATOR_KEY = NPAL.LOCATOR_KEY) DEALS_CTRY\r\n\t\r\n\tON EDPI.DEALS_PPSK = DEALS_CTRY.PARTY_KEY \r\n\r\nLEFT OUTER JOIN (\r\nSEL NPLA.PARTY_KEY, NPAL.ISO_COUNTRY_CODE\r\nFROM $$COMREFVWDB.N_PARTY_LOCATOR_ASGN NPLA\r\nINNER JOIN $$COMREFVWDB.N_LOCATOR  NL\r\n\tON NPLA.LOCATOR_KEY = NL.LOCATOR_KEY\r\n\tAND NL.SS_CODE = 'CR'\r\n\tAND NPLA.LOCATION_TYPE_CODE = 'POSTAL ADDRESS'\r\nINNER JOIN $$COMREFVWDB.N_POSTAL_ADDRESS_LOCATOR NPAL\r\n\tON NPLA.LOCATOR_KEY = NPAL.LOCATOR_KEY\t) END_CTRY\r\n\t\r\n\tON EDPI.DV_END_CUST_PARTY_KEY = END_CTRY.PARTY_KEY",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
