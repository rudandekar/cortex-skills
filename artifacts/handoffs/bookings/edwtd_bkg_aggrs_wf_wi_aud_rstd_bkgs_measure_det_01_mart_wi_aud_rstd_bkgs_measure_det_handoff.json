      "attributes": {
        "Sql Query": "SELECT \r\n'MT_RSTD_BKGS_MEASURE', \r\nBOOKINGS_MEASURE_KEY,\r\nDV_FISCAL_YEAR_MTH_NUMBER_INT,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nUSER, \r\nCURRENT_TIMESTAMP(0), \r\nUSER, \r\nCURRENT_TIMESTAMP(0)\r\nFROM $$SLSORDVWDB.MT_RSTD_BKGS_MEASURE NBM\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nON RFM.FISCAL_YEAR_MONTH_INT= NBM.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND CURRENT_FISCAL_MONTH_FLAG     ='Y'\r\n\r\nMINUS\r\n\r\nSELECT \r\n'MT_RSTD_BKGS_MEASURE', \r\nBOOKINGS_MEASURE_KEY,\r\nDV_FISCAL_YEAR_MTH_NUMBER_INT,\r\nBKGS_MEASURE_TRANS_TYPE_CODE, \r\nUSER, \r\nCURRENT_TIMESTAMP(0), \r\nUSER, \r\nCURRENT_TIMESTAMP(0)\r\nFROM $$SLSORDVWDB.N_BKGS_MEASURE NBM\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nON RFM.FISCAL_YEAR_MONTH_INT= NBM.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND CURRENT_FISCAL_MONTH_FLAG     ='Y'",
