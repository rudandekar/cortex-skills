      "attributes": {
        "Sql Query": "SELECT\r\nSALES_ORDER_LINE_KEY,\r\nMAX(CASE WHEN RANK_INDEX = 1 THEN HOLD_NAME END) AS HOLD_NAME_1,\r\nMAX(CASE WHEN RANK_INDEX = 1 THEN HOLD_DATE END) AS HOLD_PLACE_DATE_1,\r\nMAX(CASE WHEN RANK_INDEX = 1 THEN CREATED_BY END) AS HOLD_CREATED_BY_1,\r\nMAX(CASE WHEN RANK_INDEX = 2 THEN HOLD_NAME END) AS HOLD_NAME_2, \r\nMAX(CASE WHEN RANK_INDEX = 2 THEN HOLD_DATE END) AS HOLD_PLACE_DATE_2, \r\nMAX(CASE WHEN RANK_INDEX = 2 THEN CREATED_BY END) AS HOLD_CREATED_BY_2, \r\nMAX(CASE WHEN RANK_INDEX = 3 THEN HOLD_NAME END) AS HOLD_NAME_3,\r\nMAX(CASE WHEN RANK_INDEX = 3 THEN HOLD_DATE END) AS HOLD_PLACE_DATE_3, \r\nMAX(CASE WHEN RANK_INDEX = 3 THEN CREATED_BY END) AS HOLD_CREATED_BY_3, \r\nMAX(CASE WHEN RANK_INDEX = 4 THEN HOLD_NAME END) AS HOLD_NAME_4,\r\nMAX(CASE WHEN RANK_INDEX = 4 THEN HOLD_DATE END) AS HOLD_PLACE_DATE_4, \r\nMAX(CASE WHEN RANK_INDEX = 4 THEN CREATED_BY END) AS HOLD_CREATED_BY_4, \r\nMAX(CASE WHEN RANK_INDEX = 5 THEN HOLD_NAME END) AS HOLD_NAME_5,\r\nMAX(CASE WHEN RANK_INDEX = 5 THEN HOLD_DATE END) AS HOLD_PLACE_DATE_5, \r\nMAX(CASE WHEN RANK_INDEX = 5 THEN CREATED_BY END) AS HOLD_CREATED_BY_5\r\nFROM\r\n(\r\nSELECT \r\nA.SALES_ORDER_LINE_KEY, \r\nA.HOLD_NAME,\r\nA.HOLD_DATE,\r\nA.CREATED_BY,\r\nROW_NUMBER() OVER (PARTITION BY A.SALES_ORDER_LINE_KEY ORDER BY A.HOLD_DATE DESC)  RANK_INDEX\r\nFROM \r\n((SELECT \r\nSOLH.SALES_ORDER_LINE_KEY, \r\nSOLH.BK_SALES_ORDER_HOLD_NAME HOLD_NAME,\r\nSOLH.BK_SOL_HOLD_DATETIME HOLD_DATE,\r\nSOLH.SOL_HOLD_CRTD_BY_ERP_USER_NAME CREATED_BY\r\nFROM \r\n--$$NRTNCRVWDB.N_SALES_ORDER_HOLD_NRT SOH, /*Q4 FY2016 Change to remove SOH */\r\n$$NRTNCRVWDB.N_SALES_ORDER_LINE_HOLD_NRT SOLH\r\nWHERE \r\n--SOH.BK_SALES_ORDER_KEY = SOLH.DD_SALES_ORDER_KEY AND /*Q4 FY2016 Change to remove SOH */\r\nSOLH.RU_SOL_HOLD_RELEASE_DATETIME IS NULL\r\n) \r\nUNION\r\n(SELECT \r\nSOLH.SALES_ORDER_LINE_KEY, \r\nSOH.BK_SALES_ORDER_HOLD_NAME HOLD_NAME,\r\nSOH.BK_SO_HOLD_DTM HOLD_DATE,\r\nSOH.SO_HOLD_CRTD_BY_ERP_USER_NAME CREATED_BY\r\nFROM \r\n$$NRTNCRVWDB.N_SALES_ORDER_HOLD_NRT SOH, \r\n--$$NRTNCRVWDB.N_SALES_ORDER_LINE_HOLD_NRT SOLH /*Q4 FY2016 Change to remove SOLH */\r\n$$NRTNCRVWDB.N_SALES_ORDER_LINE_NRT SOLH    \r\nWHERE \r\nSOH.BK_SALES_ORDER_KEY = SOLH.SALES_ORDER_KEY\r\nAND SOH.RU_SO_HOLD_RELEASE_DTM IS NULL\r\n) \r\n) A\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY A.SALES_ORDER_LINE_KEY ORDER BY A.HOLD_DATE DESC) < 6 )  B\r\nGROUP BY 1",
        "User Defined Join": "",
