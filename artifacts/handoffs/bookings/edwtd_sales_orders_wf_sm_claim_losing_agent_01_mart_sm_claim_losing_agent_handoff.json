      "attributes": {
        "Sql Query": "SELECT \r\n RANK() OVER (ORDER BY SRC.TRX_SC_ID,SRC.SOURCE_TRX_ID,SRC.TRX_SOURCE_TYPE) + MAX_VAL CLAIM_LOSING_AGENT_KEY,\r\n SRC.TRX_SC_ID,\r\n SRC.SOURCE_TRX_ID,\r\n SRC.TRX_SOURCE_TYPE,\r\n CURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\n USER EDW_CREATE_USER\r\n FROM\r\n $$STGDB.ST_XXNCE_CLAIM_TRX_SC SRC,\r\n (SELECT COALESCE(MAX(CLAIM_LOSING_AGENT_KEY),10000) MAX_VAL FROM $$ETLVWDB.SM_CLAIM_LOSING_AGENT\r\n )KEY_SRC\r\n WHERE NOT EXISTS\r\n (\r\n SELECT 1 FROM\r\n $$ETLVWDB.SM_CLAIM_LOSING_AGENT SM_TRXSC\r\n WHERE\r\n SM_TRXSC.SK_TRX_SRC_ID = SRC.TRX_SC_ID\r\n AND SM_TRXSC.SRC_TRX_ID_INT=SRC.SOURCE_TRX_ID\r\n AND SM_TRXSC.TRX_SRC_TYPE_CD=SRC.TRX_SOURCE_TYPE)",
