      "attributes": {
        "Sql Query": "SELECT \r\nST_XXFSAM_EAC_CASE_V.CASE_ID, \r\n ST_XXFSAM_EAC_CASE_V.ORGANIZATION_ID,\r\nCOALESCE(ST_XXFSAM_EAC_CASE_V.CASE_TYPE,'UNKNOWN'),\r\n COALESCE(ST_XXFSAM_EAC_CASE_V.MODULE,'UNKNOWN'), \r\n COALESCE(ST_XXFSAM_EAC_CASE_V.SOURCE,'UNKNOWN'), \r\n COALESCE(ST_XXFSAM_EAC_CASE_V.STATUS,'UNKNOWN'), \r\n COALESCE(ST_XXFSAM_EAC_CASE_V.AUTO_APPROVED,'N'), \r\n COALESCE(ST_XXFSAM_EAC_CASE_V.EFFECTIVE_DATE,CAST('3500-01-01' AS DATE)), \r\n  COALESCE(NCWP_CRTD.CISCO_WORKER_PARTY_KEY,-999) AS CRTD_BY_CSCO_WRKR_PRTY_KEY, \r\n COALESCE(NCWP_APRV.CISCO_WORKER_PARTY_KEY,-999) AS APPROVER_CSCO_WRKR_PRTY_KEY, \r\n COALESCE(NCWP_UPDT.CISCO_WORKER_PARTY_KEY,-999) AS LST_UPTD_BY_CSCO_WRKR_PRTY_KEY, \r\n  COALESCE(ST_XXFSAM_EAC_CASE_V.REASON_CODE,'UNKNOWN'),  \r\n COALESCE(ST_XXFSAM_EAC_CASE_V.CREATION_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))),  \r\n  COALESCE(ST_XXFSAM_EAC_CASE_V.REASON_DESCRIPTION,'UNKNOWN'),  \r\nCOALESCE(ST_XXFSAM_EAC_CASE_V.CREATION_DATE,CAST('3500-01-01' AS DATE)), \r\n COALESCE(ST_XXFSAM_EAC_CASE_V.LAST_UPDATE_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))),\r\nCOALESCE(ST_XXFSAM_EAC_CASE_V.LAST_UPDATE_DATE,CAST('3500-01-01' AS DATE)), \r\n CURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\n'I' ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM\r\n $$STGDB.ST_XXFSAM_EAC_CASE_V ST_XXFSAM_EAC_CASE_V\r\nINNER JOIN $$SLSORDVWDB.N_EAC_ORG ORG \r\nON ORG.BK_EAC_ORG_ID = COALESCE(ST_XXFSAM_EAC_CASE_V.ORGANIZATION_ID,-999) AND ORG.BK_EAC_ORG_ID<>-999\r\nLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP_CRTD\r\nON COALESCE(ST_XXFSAM_EAC_CASE_V.CREATED_BY,'UNKNOWN')= NCWP_CRTD.CEC_ID AND NCWP_CRTD.CISCO_WORKER_PARTY_KEY<>-999\r\nLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP_UPDT\r\nON COALESCE(ST_XXFSAM_EAC_CASE_V.LAST_UPDATED_BY,'UNKNOWN')= NCWP_UPDT.CEC_ID AND NCWP_UPDT.CISCO_WORKER_PARTY_KEY<>-999\r\nLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP_APRV\r\nON COALESCE(ST_XXFSAM_EAC_CASE_V.APPROVER,'UNKNOWN')= NCWP_APRV.CEC_ID AND NCWP_APRV.CISCO_WORKER_PARTY_KEY<>-999",
        "User Defined Join": "",
