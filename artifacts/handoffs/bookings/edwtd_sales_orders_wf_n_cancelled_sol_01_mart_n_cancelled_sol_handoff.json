      "attributes": {
        "Sql Query": "SELECT WCS.SALES_ORDER_LINE_KEY, \r\nCASE \r\nWHEN CANCEL.BK_SO_LINE_CANCEL_REASON_CD IS NOT NULL  AND WCS.SOL_CANCEL_REASON_CODE<>'AUTO CANCELLATION PROCESS'  THEN 'Lost Order'\r\nWHEN WCS.SOL_CANCEL_REASON_CODE='AUTO CANCELLATION PROCESS' AND \r\n(SELECT COUNT(1) FROM $$SLSORDVWDB.N_SALES_ORDER_LINE_HOLD HOLD, $$SLSORDVWDB.N_SOL_HOLD_TYPE_REASON HOLD_REASON\r\nWHERE HOLD.BK_SO_HOLD_TYPE_REASON_CD= HOLD_REASON.BK_SO_HOLD_TYPE_REASON_CD AND HOLD.SALES_ORDER_LINE_KEY=WCS.SALES_ORDER_LINE_KEY AND DEBOOKING_FLG='Y')>=1  THEN 'Lost Order' \r\nELSE 'UNKNOWN'\r\nEND SOL_CANCEL_REASON_CODE,\r\nWCS.SOL_CANCEL_REASON_CODE  BK_SO_LINE_CANCEL_REASON_CD,\r\nWCS.SOL_CANCELLED_DATETIME, \r\nWCS.SOL_CANCELLED_BY_INT, \r\nWCS.SOL_CANCELLED_QUANTITY, \r\nWCS.SOL_ORDER_QUANTITY, \r\nWCS.SALES_ORDER_KEY,\r\nWCS.BK_SHIP_SET_NUM_INT,\r\nWCS.SS_CODE, \r\nWCS.EDW_CREATE_USER, \r\nWCS.EDW_UPDATE_USER, \r\nWCS.EDW_CREATE_DATETIME, \r\nWCS.EDW_UPDATE_DATETIME\r\nFROM\r\n$$WORKDB.W_CANCELLED_SOL WCS\r\nLEFT OUTER JOIN  $$SLSORDVWDB.N_SOL_CANCEL_REASON CANCEL \r\nON WCS.SOL_CANCEL_REASON_CODE=CANCEL.BK_SO_LINE_CANCEL_REASON_CD\r\nAND CANCEL.DEBOOKING_FLG='Y'\r\nWHERE NOT EXISTS\r\n(SELECT 1 FROM $$SLSORDVWDB.N_CANCELLED_SOL NCS \r\nWHERE \r\nSALES_ORDER_LINE_KEY=WCS.SALES_ORDER_LINE_KEY AND\r\nBK_SO_LINE_CANCEL_REASON_CD=WCS.SOL_CANCEL_REASON_CODE AND\r\nSOL_CANCELLED_DATETIME=WCS.SOL_CANCELLED_DATETIME\r\n)",
        "User Defined Join": "",
