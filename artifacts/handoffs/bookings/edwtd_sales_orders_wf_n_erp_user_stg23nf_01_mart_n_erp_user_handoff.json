      "attributes": {
        "Sql Query": "SELECT \r\nSFU.USER_NAME AS USER_NAME,\r\n'=' AS CS_RELATIONSHIP_MANAGER_ROLE,\r\nCOALESCE(NCWP.CISCO_WORKER_PARTY_KEY,-999) AS CISCO_WORKER_PARTY_KEY, \r\n'=' AS SR_RESOURCE_ROLE,\r\n'=' AS CSR_RESOURCE_ROLE,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\n'E_SLSORD_BATCH' AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n'E_SLSORD_BATCH' AS EDW_UPDATE_USER\r\nFROM $$STGDB.ST_OTM_FND_USER SFU \r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP\r\nON SFU.EMPLOYEE_NUMBER=NCWP.BK_EMPLOYEE_ID\r\nWHERE NOT EXISTS (SELECT 1 FROM $$COMREFVWDB.N_ERP_USER NEU \r\n\t\t\t\t\tWHERE NEU.ERP_USER_NAME = SFU.USER_NAME)",
