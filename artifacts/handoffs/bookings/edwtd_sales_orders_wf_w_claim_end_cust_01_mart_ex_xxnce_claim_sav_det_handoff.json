      "attributes": {
        "Sql Query": "SELECT\r\nSM_ECUST.CLAIM_END_CUST_KEY AS CLAIM_END_CUST_KEY,\r\nSAV_DET.SAV_DET_ID AS SK_SRC_SAV_DETAIL_ID,\r\nNCLM.CLAIM_KEY AS CLAIM_KEY,\r\nCOALESCE(RPTD_KEY.PARTY_KEY,-999) AS CUST_SRC_RPTD_PRTY_KEY, \t\t\t\r\nCOALESCE(GRP_KEY.SALES_ACCOUNT_GROUP_PARTY_KEY,-999)AS SLS_ACCT_GRP_PRTY_KEY,       \t\t\r\nCOALESCE(VALD_KEY.PARTY_KEY,-999)  AS CUST_VALIDATED_PRTY_KEY,\t\t\t\r\nSAV_DET.SAV_DET_SEQ AS SRC_SAV_DTL_SEQ_ID_INT,\r\nSAV_DET.END_USER_COUNTRY AS CUST_CNTRY_NAME,\r\nSAV_DET.CREATION_DATE AS CREATE_DTM,\r\nSAV_DET.UPDATED_DATE AS LAST_UPDATE_DTM,\r\nSAV_DET.SAV_SPLIT_PCT AS SPLIT_PCT,\r\nCOALESCE(CRCD_BY.CISCO_WORKER_PARTY_KEY,-999) AS CRTD_BY_CSCO_WRKR_PRTY_KEY,\t\t\r\nCOALESCE(UPTD_BY.CISCO_WORKER_PARTY_KEY,-999) AS LST_UPTD_BY_CSCO_WRKR_PRTY_KEY,\t\t\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' AS ACTION_CODE,\r\n'=' AS DML_TYPE\r\n\r\nFROM\r\n$$STGDB.ST_XXNCE_CLAIM_SAV_DET SAV_DET\r\n\r\nINNER JOIN $$ETLVWDB.SM_CLAIM_END_CUST SM_ECUST\r\nON SAV_DET.SAV_DET_ID=SM_ECUST.SK_SRC_SAV_DETAIL_ID\r\n\r\nINNER JOIN $$SLSORDVWDB.N_CLAIM NCLM\r\nON SAV_DET.CLAIM_ID=NCLM.SK_CLAIM_ID\r\n\r\nLEFT JOIN $$COMREFVWDB.N_PARTY RPTD_KEY\r\nON CAST(RPTD_KEY.PARTY_SSOT_PARTY_ID_INT AS BIGINT)=SAV_DET.END_USER_PARTY_ID\r\nAND RPTD_KEY.SS_CODE IN ('CR','CR_MODS')\r\n\r\nLEFT JOIN $$COMREFVWDB.N_SLS_ACCT_GROUP_SAV_PARTY_TV GRP_KEY\r\nON CAST(GRP_KEY.BK_SALES_ACCOUNT_ID_INT AS BIGINT)=SAV_DET.SAV_ID\r\nAND CURRENT_DATE BETWEEN GRP_KEY.SALES_ACCOUNT_GROUP_START_DT AND GRP_KEY.SALES_ACCOUNT_GROUP_END_DT\r\n\r\nLEFT JOIN $$COMREFVWDB.N_PARTY VALD_KEY\r\nON CAST(VALD_KEY.PARTY_SSOT_PARTY_ID_INT AS BIGINT)=SAV_DET.BIZ_PARTY_ID\r\nAND VALD_KEY.SS_CODE IN ('CR','CR_MODS')\r\n\r\nLEFT OUTER JOIN $$STGDB.WI_CLM_FND_USER CRCD_BY\r\n  ON CRCD_BY.USER_ID = SAV_DET.CREATED_BY \r\n \r\nLEFT OUTER JOIN $$STGDB.WI_CLM_FND_USER UPTD_BY\r\n  ON UPTD_BY.USER_ID = SAV_DET.LAST_UPDATED_BY",
        "User Defined Join": "",
