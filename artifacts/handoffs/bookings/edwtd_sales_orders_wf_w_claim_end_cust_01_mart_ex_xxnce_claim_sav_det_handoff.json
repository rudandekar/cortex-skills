      "attributes": {
        "Sql Query": "SELECT\r\nSTXSD.SAV_DET_ID                    ,\r\nSTXSD.SAV_DET_SEQ                   ,\r\nSTXSD.SAV_ID                        ,\r\nSTXSD.SAV_NAME                      ,\r\nSTXSD.BIZ_PARTY_ID                  ,\r\nSTXSD.BIZ_PARTY_NAME                ,\r\nSTXSD.SAV_SPLIT_PCT                 ,\r\nSTXSD.END_USER_PARTY_ID             ,\r\nSTXSD.END_USER_PARTY_NAME           ,\r\nSTXSD.CREATED_BY                    ,\r\nSTXSD.CREATION_DATE                 ,\r\nSTXSD.LAST_UPDATED_BY               ,\r\nSTXSD.UPDATED_DATE                  ,\r\nSTXSD.OBJECT_VERSION_NUMBER         ,\r\nSTXSD.CLAIM_ID                      ,\r\nSTXSD.END_USER_COUNTRY                   \r\nFROM  $$STGDB.ST_XXNCE_CLAIM_SAV_DET STXSD\r\nWHERE NOT EXISTS\r\n( SELECT 1 FROM $$SLSORDVWDB.N_CLAIM NCLM\r\nWHERE STXSD.CLAIM_ID=NCLM.SK_CLAIM_ID )\r\nOR NOT EXISTS\r\n( SELECT 1 FROM $$COMREFVWDB.N_PARTY RPTD_KEY\r\nWHERE COALESCE(STXSD.END_USER_PARTY_ID,-999)=CAST(RPTD_KEY.PARTY_SSOT_PARTY_ID_INT AS BIGINT)\r\nAND RPTD_KEY.SS_CODE IN ('CR','CR_MODS') )\r\nOR NOT EXISTS\r\n( SELECT 1 FROM $$COMREFVWDB.N_SLS_ACCT_GROUP_SAV_PARTY_TV GRP_KEY\r\nWHERE COALESCE(STXSD.SAV_ID,-999)=CAST(GRP_KEY.BK_SALES_ACCOUNT_ID_INT AS BIGINT)\r\nAND CURRENT_DATE BETWEEN GRP_KEY.SALES_ACCOUNT_GROUP_START_DT AND GRP_KEY.SALES_ACCOUNT_GROUP_END_DT )\r\nOR NOT EXISTS\r\n( SELECT 1 FROM $$COMREFVWDB.N_PARTY VALD_KEY\r\nWHERE COALESCE(STXSD.BIZ_PARTY_ID,-999)=CAST(VALD_KEY.PARTY_SSOT_PARTY_ID_INT AS BIGINT)\r\nAND VALD_KEY.SS_CODE IN ('CR','CR_MODS') )\r\nOR NOT EXISTS\r\n( SELECT 1 FROM $$STGDB.WI_CLM_FND_USER CRCD_BY\r\n WHERE CRCD_BY.USER_ID = CASE WHEN STXSD.CREATED_BY IS NULL THEN -999 \r\n\t\t\t\t\t\t\t\t\tWHEN STXSD.CREATED_BY=999 THEN -999 \r\n\t\t\t\t\t\t\t\t\tELSE STXSD.CREATED_BY END  )\r\nOR NOT EXISTS\r\n( SELECT 1 FROM $$STGDB.WI_CLM_FND_USER UPTD_BY\r\n WHERE UPTD_BY.USER_ID = CASE WHEN STXSD.LAST_UPDATED_BY IS NULL THEN -999 \r\n\t\t\t\t\t\t\t\t\tWHEN STXSD.LAST_UPDATED_BY=999 THEN -999 \r\n\t\t\t\t\t\t\t\t\tELSE STXSD.LAST_UPDATED_BY END )",
        "User Defined Join": "",
