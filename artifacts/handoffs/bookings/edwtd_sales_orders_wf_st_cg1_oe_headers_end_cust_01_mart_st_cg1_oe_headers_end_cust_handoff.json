      "attributes": {
        "Sql Query": "SELECT \r\nCG1_OE_ORDER_HEADERS_ALL.HEADER_ID, \r\nCOALESCE(CG1_OE_ORDER_HEADERS_ALL.END_CUSTOMER_SITE_USE_ID,-999), \r\nCOALESCE(CG1_OE_ORDER_HEADERS_ALL.END_CUSTOMER_ID,-999), \r\nCG1_OE_ORDER_HEADERS_ALL.SOURCE_COMMIT_TIME, \r\n'CG' GLOBAL_NAME \r\nFROM \r\n$$NRTACCUMVWDB.CG1_OE_ORDER_HEADERS_ALL CG1_OE_ORDER_HEADERS_ALL,\r\n$$COMREFVWDB.N_CISCO_OPERATING_UNIT NCOU\r\nWHERE\r\nCG1_OE_ORDER_HEADERS_ALL.ORG_ID = NCOU.SK_ORGANIZATION_ID_INT\r\nAND\r\nNCOU.MOVED_TO_CG1_FLG  = 'Y'     \r\nAND\r\nCG1_OE_ORDER_HEADERS_ALL.SOURCE_COMMIT_TIME >= '$$LastExtractDate' AND CG1_OE_ORDER_HEADERS_ALL.SOURCE_COMMIT_TIME < '$$EndLastExtractDate' \r\nAND\r\nCG1_OE_ORDER_HEADERS_ALL.SOURCE_DML_TYPE <> 'DELETE'\r\n/* AND CG1_OE_ORDER_HEADERS_ALL.ORG_ID  IN (SELECT DISTINCT ORG_ID FROM $$ETLVWDB.CG1_ORD_ID) */\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY CG1_OE_ORDER_HEADERS_ALL.HEADER_ID ORDER BY CG1_OE_ORDER_HEADERS_ALL.REFRESH_DATETIME DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
