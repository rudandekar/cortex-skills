      "attributes": {
        "Sql Query": "SELECT \r\nCG1_OE_ORD_LINES_HIST.LINE_ID,\r\nCG1_OE_ORD_LINES_HIST.SHIP_SET_ID,\r\nORS.REASON_CODE,\r\nCG1_OE_ORD_LINES_HIST.LINE_NUMBER,\r\nCG1_OE_ORD_LINES_HIST.HIST_CREATION_DATE,\r\nCG1_OE_ORD_LINES_HIST.HIST_CREATED_BY,\r\nCG1_OE_ORD_LINES_HIST.LATEST_CANCELLED_QUANTITY,\r\nCG1_OE_ORD_LINES_HIST.SOURCE_COMMIT_TIME,\r\n'CG' GLOBAL_NAME,\r\nCG1_OE_ORD_LINES_HIST.CANCELLED_FLAG,\r\nCG1_OE_ORD_LINES_HIST.CANCELLED_QUANTITY,\r\nCG1_OE_ORD_LINES_HIST.CREATED_BY,\r\nCG1_OE_ORD_LINES_HIST.CREATION_DATE,\r\nCG1_OE_ORD_LINES_HIST.HEADER_ID,\r\nCG1_OE_ORD_LINES_HIST.HIST_COMMENTS,\r\nCG1_OE_ORD_LINES_HIST.HIST_TYPE_CODE,\r\nCG1_OE_ORD_LINES_HIST.LAST_UPDATED_BY,\r\nCG1_OE_ORD_LINES_HIST.LAST_UPDATE_DATE,\r\nCG1_OE_ORD_LINES_HIST.LINE_CATEGORY_CODE,\r\nCG1_OE_ORD_LINES_HIST.LINE_SET_ID,\r\nCG1_OE_ORD_LINES_HIST.LINE_TYPE_ID,\r\nCG1_OE_ORD_LINES_HIST.LINK_TO_LINE_ID,\r\nCG1_OE_ORD_LINES_HIST.ORDERED_QUANTITY,\r\nCG1_OE_ORD_LINES_HIST.REQUEST_DATE,\r\nCG1_OE_ORD_LINES_HIST.REQUEST_ID,\r\nCG1_OE_ORD_LINES_HIST.RETURN_REASON_CODE,\r\nCG1_OE_ORD_LINES_HIST.SALESREP_ID,\r\nCG1_OE_ORD_LINES_HIST.SHIPMENT_NUMBER, \r\nCG1_OE_ORD_LINES_HIST.ORG_ID\r\nFROM\r\n$$NRTACCUMVWDB.CG1_OE_ORD_LINES_HIST CG1_OE_ORD_LINES_HIST,\r\n$$COMREFVWDB.N_CISCO_OPERATING_UNIT NCOU,\r\n$$GGSRCVWDB.GG_CG1_OE_REASONS ORS\r\nWHERE\r\nCG1_OE_ORD_LINES_HIST.ORG_ID = NCOU.SK_ORGANIZATION_ID_INT\r\nAND\r\nNCOU.MOVED_TO_CG1_FLG  = 'Y'     \r\nAND\r\nORS.HEADER_ID = CG1_OE_ORD_LINES_HIST.HEADER_ID\r\nAND\r\nORS.REASON_ID = CG1_OE_ORD_LINES_HIST.REASON_ID\r\nAND\r\nORS.ENTITY_CODE = 'LINE'\r\nAND\r\nCG1_OE_ORD_LINES_HIST.HIST_TYPE_CODE='CANCELLATION'\r\nAND CG1_OE_ORD_LINES_HIST.SOURCE_COMMIT_TIME >= '$$LastExtractDate'\r\nAND\r\nCG1_OE_ORD_LINES_HIST.SOURCE_COMMIT_TIME <'$$EndLastExtractDate'\r\nAND\r\nCG1_OE_ORD_LINES_HIST.SOURCE_DML_TYPE <> 'DELETE'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY CG1_OE_ORD_LINES_HIST.LINE_ID,ORS.REASON_CODE,CG1_OE_ORD_LINES_HIST.HIST_CREATION_DATE ORDER BY CG1_OE_ORD_LINES_HIST.REFRESH_DATETIME DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "CALL COLLECT_STATS_WRAP('$$NRTACCUMDB','CG1_OE_ORD_LINES_HIST','D');",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
