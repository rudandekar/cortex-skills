      "attributes": {
        "Sql Query": "SELECT\r\nSMCE.CLAIM_EVENT_KEY,\r\nSXCE.EVENT_ID AS SK_CLAIM_EVENT_ID,\r\nCOALESCE(PACTOR.CISCO_WORKER_PARTY_KEY,-999) AS CE_ACTN_PNDG_CSCO_WRKR_PTY_KEY,\r\nNCLM.CLAIM_KEY AS CLAIM_KEY,\r\nSXCE.EVENT_TYPE AS CLAIM_EVENT_TYPE_DESCR,\r\nSXCE.CREATION_DATE AS CREATE_DTM,\r\nSXCE.LAST_UPDATED_DATE AS LAST_UPDATE_DTM,\r\nSXCE.CLAIM_TRX_SC_ID AS SK_TRX_SALES_CREDIT_ID,\r\nSXCE.CLAIM_STATUS AS CLAIM_EVENT_STATUS_NAME,\r\nSXCE.TRXN_APPROVAL_STATUS AS CLAIM_EVENT_TRX_STATUS_NAME,\r\nCOALESCE(CRCD_BY.CISCO_WORKER_PARTY_KEY,-999) AS CRTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE(UPTD_BY.CISCO_WORKER_PARTY_KEY,-999) AS LST_UPTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' AS ACTION_CODE,\r\n'=' AS DML_TYPE\r\n\r\nFROM\r\n$$STGDB.ST_XXNCE_CLAIM_EVENT SXCE\r\n\r\nINNER JOIN $$ETLVWDB.SM_CLAIM_EVENT SMCE\r\nON SXCE.EVENT_ID=SMCE.SK_CLAIM_EVENT_ID\r\n\r\nINNER JOIN $$SLSORDVWDB.N_CLAIM NCLM\r\nON NCLM.SK_CLAIM_ID=SXCE.CLAIM_ID\r\n\r\nLEFT OUTER JOIN $$STGDB.WI_CLM_FND_USER PACTOR\r\n  ON PACTOR.USER_ID = SXCE.PENDING_ACTION_ACTOR\r\n  \r\nLEFT OUTER JOIN $$STGDB.WI_CLM_FND_USER CRCD_BY\r\n  ON CRCD_BY.USER_ID = SXCE.CREATED_BY \r\n \r\nLEFT OUTER JOIN $$STGDB.WI_CLM_FND_USER UPTD_BY\r\n  ON UPTD_BY.USER_ID = SXCE.LAST_UPDATED_BY",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
