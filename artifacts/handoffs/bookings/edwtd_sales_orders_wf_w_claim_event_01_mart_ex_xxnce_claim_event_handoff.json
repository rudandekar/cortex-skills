      "attributes": {
        "Sql Query": "SELECT\r\nCLM_EVNT.EVENT_ID                      \r\n,CLM_EVNT.EVENT_TYPE                    \r\n,CLM_EVNT.CREATION_DATE                 \r\n,CLM_EVNT.CREATED_BY                    \r\n,CLM_EVNT.LAST_UPDATED_BY               \r\n,CLM_EVNT.LAST_UPDATED_DATE             \r\n,CLM_EVNT.OBJECT_VERSION_NUMBER         \r\n,CLM_EVNT.CLAIM_ID                      \r\n,CLM_EVNT.PENDING_ACTION_ACTOR          \r\n,CLM_EVNT.ACTOR_TYPE                    \r\n,CLM_EVNT.CLAIM_TRX_SC_ID               \r\n,CLM_EVNT.CLAIM_STATUS                  \r\n,CLM_EVNT.TRXN_APPROVAL_STATUS                      \r\nFROM\r\n$$STGDB.ST_XXNCE_CLAIM_EVENT CLM_EVNT\r\nWHERE NOT EXISTS \r\n( SELECT 1 FROM $$SLSORDVWDB.N_CLAIM NCLM\r\nWHERE CLM_EVNT.CLAIM_ID=NCLM.SK_CLAIM_ID)\r\nOR NOT EXISTS\r\n( SELECT 1 FROM $$STGDB.WI_CLM_FND_USER PACTOR\r\nWHERE PACTOR.USER_ID = CASE WHEN CLM_EVNT.PENDING_ACTION_ACTOR IS NULL THEN -999 \r\n\t\t\t\t\t\t\t\t\tWHEN CLM_EVNT.PENDING_ACTION_ACTOR=999 THEN -999 \r\n\t\t\t\t\t\t\t\t\tELSE CLM_EVNT.PENDING_ACTION_ACTOR END )\r\nOR NOT EXISTS\r\n( SELECT 1 FROM $$STGDB.WI_CLM_FND_USER CRCD_BY\r\nWHERE CRCD_BY.USER_ID = CASE WHEN CLM_EVNT.CREATED_BY IS NULL THEN -999 \r\n\t\t\t\t\t\t\t\t\tWHEN CLM_EVNT.CREATED_BY=999 THEN -999 \r\n\t\t\t\t\t\t\t\t\tELSE CLM_EVNT.CREATED_BY END)\r\nOR NOT EXISTS\r\n( SELECT 1 FROM $$STGDB.WI_CLM_FND_USER UPTD_BY\r\nWHERE UPTD_BY.USER_ID = CASE WHEN CLM_EVNT.LAST_UPDATED_BY IS NULL THEN -999 \r\n\t\t\t\t\t\t\t\t\tWHEN CLM_EVNT.LAST_UPDATED_BY=999 THEN -999 \r\n\t\t\t\t\t\t\t\t\tELSE CLM_EVNT.LAST_UPDATED_BY END )",
