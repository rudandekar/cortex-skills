      "attributes": {
        "Sql Query": "SELECT \r\nFINAL.INVENTORY_TYPE_CD,\r\nFINAL.BK_WIPS_ORIGINATOR_ID_INT,\r\nFINAL.INVENTORY_AS_OF_DT,\r\nMIN(FINAL.START_DATE_ACTIVE) AS DV_START_ACTIVE_DT ,\r\nMIN(FINAL.END_DATE_ACTIVE) AS DV_END_ACTIVE_DT\r\nFROM \r\n(\r\nSELECT \r\nFST.INVENTORY_TYPE_CD\r\n,FST.BK_WIPS_ORIGINATOR_ID_INT\r\n,FST.INVENTORY_AS_OF_DT\r\n,FST.INVENTORY_AS_OF_DT AS START_DATE_ACTIVE\r\n,COALESCE (MAX (FST.INVENTORY_AS_OF_DT - INTERVAL '1' DAY) \r\nOVER (PARTITION BY FST.INVENTORY_TYPE_CD, FST.BK_WIPS_ORIGINATOR_ID_INT ORDER BY FST.INVENTORY_AS_OF_DT ASC ROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING), DATE '3500-01-01') AS END_DATE_ACTIVE\r\n FROM (SELECT INVENTORY_TYPE_CD \r\n\t             ,BK_WIPS_ORIGINATOR_ID_INT\r\n\t\t\t,INVENTORY_AS_OF_DT\r\n\t\tFROM $$STGDB.WI_WIPS_INV_TRANS_ALL\r\n\t\tWHERE ACTIVE_FLG = 'Y' \r\n\t\tQUALIFY ROW_NUMBER () OVER (PARTITION BY INVENTORY_TYPE_CD, BK_WIPS_ORIGINATOR_ID_INT, INVENTORY_AS_OF_DT ORDER BY INVENTORY_AS_OF_DT DESC) =1\r\n\t) FST\r\n) FINAL\r\nGROUP BY 1,2,3",
