      "attributes": {
        "Sql Query": "SELECT \r\nGFLV.LOOKUP_TYPE,\r\nGFLV.LANG,\r\nGFLV.LOOKUP_CODE,\r\nGFLV.MEANING,\r\nGFLV.DESCRIPTION,\r\nGFLV.ENABLED_FLAG,\r\nGFLV.START_DATE_ACTIVE,\r\nGFLV.END_DATE_ACTIVE,\r\nGFLV.CREATED_BY,\r\nGFLV.CREATION_DATE,\r\nGFLV.LAST_UPDATED_BY,\r\nGFLV.LAST_UPDATE_LOGIN,\r\nGFLV.LAST_UPDATE_DATE,\r\nGFLV.SOURCE_LANG,\r\nGFLV.SECURITY_GROUP_ID,\r\nGFLV.VIEW_APPLICATION_ID,\r\nGFLV.TERRITORY_CODE,\r\nGFLV.ATTRIBUTE_CATEGORY,\r\nGFLV.ATTRIBUTE1,\r\nGFLV.ATTRIBUTE2,\r\nGFLV.ATTRIBUTE3,\r\nGFLV.ATTRIBUTE4,\r\nGFLV.ATTRIBUTE5,\r\nGFLV.ATTRIBUTE6,\r\nGFLV.ATTRIBUTE7,\r\nGFLV.ATTRIBUTE8,\r\nGFLV.ATTRIBUTE9,\r\nGFLV.ATTRIBUTE10,\r\nGFLV.ATTRIBUTE11,\r\nGFLV.ATTRIBUTE12,\r\nGFLV.ATTRIBUTE13,\r\nGFLV.ATTRIBUTE14,\r\nGFLV.ATTRIBUTE15,\r\nGFLV.TAG,\r\nGFLV.LEAF_NODE,\r\nGFLV.SOURCE_COMMIT_TIME,\r\n'CG' GLOBAL_NAME \r\nFROM \r\n$$GGSRCVWDB.GG_CG1_FND_LOOKUP_VALUES GFLV\r\nWHERE\r\n/*GFLV.SOURCE_COMMIT_TIME >= '$$LastExtractDate' AND GFLV.SOURCE_COMMIT_TIME < '$$EndLastExtractDate' \r\nAND*/\r\nGFLV.SOURCE_DML_TYPE <> 'DELETE'\r\nAND\r\nGFLV.LANG = 'US'\r\nAND\r\nGFLV.LOOKUP_TYPE = 'XXGCO_PROGRAM_TYPE'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY GFLV.LOOKUP_TYPE ,GFLV.LANG ,GFLV.LOOKUP_CODE ,\r\nGFLV.SECURITY_GROUP_ID ,GFLV.VIEW_APPLICATION_ID ORDER BY GFLV.REFRESH_DATETIME DESC) = 1",
