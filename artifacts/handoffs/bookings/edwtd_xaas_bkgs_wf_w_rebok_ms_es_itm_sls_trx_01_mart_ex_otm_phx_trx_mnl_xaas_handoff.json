      "attributes": {
        "Sql Query": "SELECT\r\nSMXSS.SO_SBSCRPTN_ITM_SLS_TRX_KEY,\r\nNCPT.PARTNER_PARTY_KEY AS MS_PARTNER_PARTY_KEY,\r\nNEU.ERP_USER_NAME AS MODIFIED_BY_USER_ID,\r\nCAST(ST.CLASS_CODE AS INTEGER) AS MS_IDENTIFICATION_METHOD_INT, \r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM ,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM $$STGDB.ST_OTM_PHX_TRX_MNL_XAAS ST\r\nINNER JOIN $$STGDB.ST_OTM_MANUAL_TRX_XAAS  OMTX\r\nON ST.ORDER_LINE_ID=OMTX.ORDER_LINE_ID\r\nAND ST.TRX_ORIG_CODE=OMTX.TRX_ORIG_CODE\r\nINNER JOIN\r\n$$ETLVWDB.SM_XAAS_SO_SBSCR_ITMSLSTRX_NRT  SMXSS\r\nON OMTX.SOURCE_TRX_ID=SMXSS.SK_TRX_ID_INT\r\nINNER JOIN $$COMREFVWDB.N_ERP_USER NEU \r\nON NEU.ERP_USER_NAME=ST.USER_NAME\r\nINNER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER NCPT \r\nON ST.PGTMV_PARTY_BE_ID = NCPT.BK_PGTMV_PARTNER_ID_INT",
