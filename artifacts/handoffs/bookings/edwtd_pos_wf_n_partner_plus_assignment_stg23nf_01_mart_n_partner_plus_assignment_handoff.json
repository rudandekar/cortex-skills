      "attributes": {
        "Sql Query": "SELECT\r\nISO_CTRY.BK_ISO_COUNTRY_CODE AS BK_ISO_COUNTRY_CD\r\n,ST.BE_GEO_ID AS BK_BE_GEO_ID_INT\r\n,TIER AS PARTNER_PLUS_TIER_NAME\r\n,FDY.FISCAL_CALENDAR_CODE AS BK_FISCAL_CALENDAR_CD\r\n,FDY.FISCAL_YEAR_NUMBER_INT AS BK_FISCAL_YEAR_NUM_INT\r\n,FDY.FISCAL_QUARTER_NUMBER_INT AS BK_FISCAL_QTR_NUM_INT\r\n,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM\r\n,USER AS EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM \r\n,USER AS EDW_UPDATE_USER\r\nFROM\r\n$$STGDB.ST_TBL_PARTNER_PLUS_MAPPING ST\r\nINNER JOIN $$COMREFVWDB.N_ISO_COUNTRY ISO_CTRY\r\nON\r\nST.COUNTRY=ISO_CTRY.ISO_COUNTRY_NAME \r\nINNER JOIN\r\n(SELECT\r\nDISTINCT\r\nDV_FISCAL_QUARTER_ID,\r\nFISCAL_CALENDAR_CODE,\r\nFISCAL_YEAR_NUMBER_INT,\r\nFISCAL_QUARTER_NUMBER_INT\r\nFROM\r\n$$COMREFVWDB.R_FISCAL_QUARTER_TO_YEAR WHERE CURRENT_FISCAL_QTR_FLAG='Y') FDY\r\nON ST.FISCAL_QUARTER_ID = FDY.DV_FISCAL_QUARTER_ID\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY BK_ISO_COUNTRY_CD, BK_BE_GEO_ID_INT, BK_FISCAL_CALENDAR_CD, BK_FISCAL_YEAR_NUM_INT, BK_FISCAL_QTR_NUM_INT ORDER BY BK_BE_GEO_ID_INT DESC)=1",
