      "attributes": {
        "Sql Query": "SELECT ST.PROMO_PROD_SPLIT_ID,\r\nST.PROMO_ID,\r\nST.PROMO_PROD_DETAIL_ID,\r\nST.SUB_PROMO_TYPE,ST.\r\nSUB_PROMO_NUMBER,\r\nST.SPLIT_FACTOR,ST.\r\nREQUIRED_PRODUCT,\r\nST.SPLIT_QUANTITY,ST.\r\nACTIVE_FLAG,\r\nST.CREATED_BY,\r\nST.CREATED_DATE,\r\nST.UPDATED_BY,\r\nST.LAST_UPDATE_DATE,\r\nST.IT_COMMENTS,ST.\r\nSUB_PROMO_DESC,\r\nST.BATCH_ID,\r\nST.ACTION_CD,\r\n'RI' AS EXCEPTION_TYPE ,\r\nST.CREATE_DATETIME \r\n FROM $$STGDB.ST_DCA_PROMO_PRODUCT_SPLIT ST\r\nWHERE NOT EXISTS\r\n(SELECT 1 FROM $$SLSORDVWDB.N_DISTRIBUTOR_PROMOTION NDP\r\nWHERE NDP.SK_PROMO_ID_INT = ST.PROMO_ID)\r\nOR NOT EXISTS\r\n(SELECT 1 FROM $$SLSORDDB.N_DISTI_PROMOTION_PRODUCT NDPP WHERE \r\nST.PROMO_PROD_DETAIL_ID = NDPP.SK_PROMO_PROD_DETAIL_ID_INT)",
