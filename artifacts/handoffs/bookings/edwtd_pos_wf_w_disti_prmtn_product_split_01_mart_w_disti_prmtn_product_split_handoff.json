      "attributes": {
        "Sql Query": "SELECT \r\nNDP.BK_PROMOTION_NUM AS BK_PROMOTION_NUM,\r\nNDP. BK_PROMOTION_REVISION_NUM_INT  AS  BK_PROMOTION_REVISION_NUM_INT,\r\nNDP. BK_PROMOTION_TYPE_CD  AS BK_PROMOTION_TYPE_CD,\r\nNDPP.BK_PROMOTION_TYPE_CD AS BK_SPLIT_PROMOTION_TYPE_CD,\r\nNDPP.BK_PROMOTION_REVISION_NUM_INT AS BK_SPLIT_PRMTN_REVSION_NUM_INT,\r\nNDPP.BK_PROMOTION_NUM AS BK_SPLIT_PROMOTION_NUM,\r\nNDPP.PRODUCT_KEY AS \"PRODUCT KEY\",\r\nST.SUB_PROMO_NUMBER AS SUB_PROMOTION_NUM,\r\nST.SUB_PROMO_TYPE AS SUB_PROMOTION_TYPE_CD,\r\nST.SUB_PROMO_DESC AS SUB_PROMOTION_DESCR,\r\nST.SPLIT_QUANTITY AS SPLIT_QTY,\r\nST.SPLIT_FACTOR AS SPLIT_FACTOR_PCT,\r\nST.REQUIRED_PRODUCT AS REQUIRED_PRODUCT_FLG,\r\nCURRENT_TIMESTAMP(0)  AS   EDW_CREATE_DTM ,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS   EDW_UPDATE_USER\r\nFROM $$STGDB.ST_DCA_PROMO_PRODUCT_SPLIT  ST\r\nINNER JOIN $$SLSORDVWDB.N_DISTRIBUTOR_PROMOTION NDP\r\nON NDP.SK_PROMO_ID_INT = ST.PROMO_ID\r\nINNER JOIN $$SLSORDVWDB.N_DISTI_PROMOTION_PRODUCT NDPP ON \r\nST.PROMO_PROD_DETAIL_ID = NDPP.SK_PROMO_PROD_DETAIL_ID_INT\r\n\r\nUNION ALL\r\n\r\nSELECT \r\nNDP.BK_PROMOTION_NUM AS BK_PROMOTION_NUM,\r\nNDP. BK_PROMOTION_REVISION_NUM_INT  AS  BK_PROMOTION_REVISION_NUM_INT,\r\nNDP. BK_PROMOTION_TYPE_CD  AS BK_PROMOTION_TYPE_CD,\r\nNDPP.BK_PROMOTION_TYPE_CD AS BK_SPLIT_PROMOTION_TYPE_CD,\r\nNDPP.BK_PROMOTION_REVISION_NUM_INT AS BK_SPLIT_PRMTN_REVSION_NUM_INT,\r\nNDPP.BK_PROMOTION_NUM AS BK_SPLIT_PROMOTION_NUM,\r\nNDPP.PRODUCT_KEY AS \"PRODUCT KEY\",\r\nEX.SUB_PROMO_NUMBER AS SUB_PROMOTION_NUM,\r\nEX.SUB_PROMO_TYPE AS SUB_PROMOTION_TYPE_CD,\r\nEX.SUB_PROMO_DESC AS SUB_PROMOTION_DESCR,\r\nEX.SPLIT_QUANTITY AS SPLIT_QTY,\r\nEX.SPLIT_FACTOR AS SPLIT_FACTOR_PCT,\r\nEX.REQUIRED_PRODUCT AS REQUIRED_PRODUCT_FLG,\r\nCURRENT_TIMESTAMP(0)  AS   EDW_CREATE_DTM ,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS   EDW_UPDATE_USER\r\nFROM $$EXCEPDB.EX_DISTI_PRMTN_PRODUCT_SPLIT EX\r\nINNER JOIN $$SLSORDVWDB.N_DISTRIBUTOR_PROMOTION NDP\r\nON NDP.SK_PROMO_ID_INT = EX.PROMO_ID\r\nINNER JOIN $$SLSORDVWDB.N_DISTI_PROMOTION_PRODUCT NDPP ON \r\nEX.PROMO_PROD_DETAIL_ID = NDPP.SK_PROMO_PROD_DETAIL_ID_INT",
