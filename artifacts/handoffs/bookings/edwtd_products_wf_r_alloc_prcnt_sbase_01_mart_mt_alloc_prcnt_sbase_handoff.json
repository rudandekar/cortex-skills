      "attributes": {
        "Sql Query": "SELECT PDT.ITEM_KEY,\r\n        (CASE WHEN PDT.GOODS_OR_SERVICE_TYPE ='GOODS' THEN PDT.RU_BK_PRODUCT_SUBGROUP_ID \r\n\t        ELSE PDT.RU_BK_SERVICE_PROD_SUBGROUP_ID   END) RU_BK_PRODUCT_SUBGROUP_ID,\r\n         PDT.RU_BK_PRODUCT_FAMILY_ID , \r\n         PDT.BK_PRODUCT_TYPE_ID , \r\n         PDT.BK_TECHNOLOGY_GROUP_ID,\r\n\t PDT.BK_BUSINESS_UNIT_ID,\r\n         CORP.DOLLAR_ALLOCATION_PERCENTAGE , \r\n         CORP.DV_ACTUAL_UNIT_ALOC_PERCENTAGE , \r\n         TMS.L4_TECHNOLOGY_MKT_SEGMENT_NAME,\r\n         CASE WHEN TMS.HIERARCHY_TYPE ='TMS_CORPORATE' THEN 0\r\n              ELSE 1 END AS HIER_TYPE\r\nFROM\t$$COMREFVWDB.r_products  PDT\r\nINNER JOIN (SELECT PRODUCT_KEY FROM $$SLSORDVWDB.R_BOOKINGS_WK_SBASE GROUP BY 1) TME   \r\nON PDT.ITEM_KEY = TME.PRODUCT_KEY\r\nINNER JOIN\r\n(SELECT ITEM_KEY,\r\n        TECHNOLOGY_MARKET_SEGMENT_KEY,\r\n        DOLLAR_ALLOCATION_PERCENTAGE,\r\n\tDV_ACTUAL_UNIT_ALOC_PERCENTAGE\r\nFROM   \t$$COMREFVWDB.N_TMS_CORP_PRODUCT_ALLOC\r\nUNION ALL\r\nSELECT  ITEM_KEY,\r\n        TECHNOLOGY_MARKET_SEGMENT_KEY,\r\n        DOLLAR_ALLOCATION_PERCENTAGE,\r\n\tDV_ACTUAL_UNIT_ALOC_PERCENTAGE\r\nFROM   \t$$COMREFVWDB.N_TMS_SLS_ALOC_PRD_ALOC) CORP\r\nON      PDT.ITEM_KEY = CORP.ITEM_KEY \r\nINNER JOIN $$COMREFVWDB.R_TECH_MKT_SEGMENT TMS \r\nON      CORP.TECHNOLOGY_MARKET_SEGMENT_KEY = TMS.TECHNOLOGY_MARKET_SEGMENT_KEY\r\nWHERE\tEXISTS ( \r\nSELECT\t1 \r\nFROM\t$$SLSORDVWDB.R_BOOKINGS_WK_SBASE WK\r\nWHERE\tWK.PRODUCT_KEY = PDT.ITEM_KEY )",
        "User Defined Join": "",
