      "attributes": {
        "Sql Query": "SELECT\r\nTVOUTPUT.BK_FOB_POINT_CODE,\r\nTVOUTPUT.START_TV_DATE,\r\nCOALESCE( MAX(TVOUTPUT.START_TV_DATE - INTERVAL '1' DAY) \r\nOVER (PARTITION BY TVOUTPUT.BK_FOB_POINT_CODE\r\nORDER BY TVOUTPUT.START_TV_DATE ASC \r\nROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING), DATE '3500-01-01') AS END_TV_DATE,\r\nTVOUTPUT.FOB_POINT_NAME,\r\nTVOUTPUT.FOB_POINT_DESCRIPTION,\r\nTVOUTPUT.FOB_POINT_ENABLED_FLAG,\r\nTVOUTPUT.FOB_POINT_START_ACTIVE_DTM,\r\nTVOUTPUT.FOB_POINT_END_ACTIVE_DTM,\r\nTVOUTPUT.SS_CODE,\r\nTVOUTPUT.ACTION_CODE,\r\nTVOUTPUT.EDW_UPDATE_DATETIME,\r\nROW_NUMBER() OVER (PARTITION BY \r\n\tTVOUTPUT.BK_FOB_POINT_CODE\r\n\tORDER BY TVOUTPUT.START_TV_DATE ASC) AS RANK_INDEX,\r\n(CASE WHEN RANK_INDEX = 1 AND NEFPT.BK_FOB_POINT_CODE IS NOT NULL THEN 'U' ELSE 'I' END) AS DML_TYPE\r\nFROM\r\n(\r\nSELECT\r\nBK_FOB_POINT_CODE,\r\nSTART_TV_DATE,\r\nFOB_POINT_NAME,\r\nFOB_POINT_DESCRIPTION,\r\nFOB_POINT_ENABLED_FLAG,\r\nFOB_POINT_START_ACTIVE_DTM,\r\nFOB_POINT_END_ACTIVE_DTM,\r\nSS_CODE,\r\nCREATE_DATETIME,\r\nACTION_CODE,\r\nEDW_UPDATE_DATETIME,\r\nROW_NUMBER() OVER (PARTITION BY BK_FOB_POINT_CODE, FOB_POINT_NAME, FOB_POINT_DESCRIPTION, FOB_POINT_ENABLED_FLAG\r\n\tORDER BY EDW_UPDATE_DATETIME DESC) AS row_num\r\nFROM\r\n(\r\nSELECT \r\n\tEFLV.LOOKUP_CODE BK_FOB_POINT_CODE,\r\n\tCAST(EFLV.GES_UPDATE_DATE AS DATE) START_TV_DATE,\r\n\tEFLV.MEANING FOB_POINT_NAME,\r\n\tEFLV.DESCRIPTION FOB_POINT_DESCRIPTION,\r\n\tEFLV.ENABLED_FLAG FOB_POINT_ENABLED_FLAG,\r\n\tEFLV.START_DATE_ACTIVE FOB_POINT_START_ACTIVE_DTM,\t\r\n\tEFLV.END_DATE_ACTIVE FOB_POINT_END_ACTIVE_DTM,\t\t\r\n\tNSSC.SOURCE_SYSTEM_CODE SS_CODE,\t\r\n\tEFLV.CREATE_DATETIME,\r\n\t'X'  ACTION_CODE,\r\n\tEFLV.GES_UPDATE_DATE EDW_UPDATE_DATETIME\r\n\tFROM\r\n\t$$ETLVWDB.EL_FND_LOOKUP_VALUES EFLV\r\n\tINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC ON (NSSC.GLOBAL_NAME = EFLV.GLOBAL_NAME)\r\n\tQUALIFY ROW_NUMBER() OVER (PARTITION BY  EFLV.LOOKUP_CODE ORDER BY EFLV.GES_UPDATE_DATE DESC ) = 1\r\n\tWHERE EFLV.GES_UPDATE_DATE >(SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS WHERE JOB_STREAM_ID='wf_W_ERP_FOB_POINT')\r\n\tAND\tEFLV.LOOKUP_TYPE='FOB'\r\n\tAND NSSC.GLOBAL_NAME='CG' /* SJPROD Retirement Q1FY14 */\r\n\tUNION ALL \r\nSELECT \r\n\tNEFPT.BK_FOB_POINT_CODE,\r\n\tNEFPT.START_TV_DATE,\r\n\tNEFPT.FOB_POINT_NAME,\r\n\tNEFPT.FOB_POINT_DESCRIPTION,\r\n\tNEFPT.FOB_POINT_ENABLED_FLAG,\r\n\tNEFPT.FOB_POINT_START_ACTIVE_DTM,\r\n\tNEFPT.FOB_POINT_END_ACTIVE_DTM,\r\n\tNEFPT.SS_CODE,\r\n\tNEFPT.EDW_CREATE_DATETIME CREATE_DATETIME,\r\n\t'X'  ACTION_CODE,\r\n\tNEFPT.EDW_UPDATE_DATETIME\r\n\tFROM $$SLSORDVWDB.N_ERP_FOB_POINT_TV NEFPT\r\n\tWHERE END_TV_DATE = CAST ('3500-01-01' AS DATE)\r\n\tAND BK_FOB_POINT_CODE IN\r\n\t(\r\n\tSELECT LOOKUP_CODE\r\n\tFROM $$ETLVWDB.EL_FND_LOOKUP_VALUES EFLV\r\n\tINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC ON (NSSC.GLOBAL_NAME = EFLV.GLOBAL_NAME)\r\n        WHERE EFLV.GES_UPDATE_DATE >(SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS WHERE JOB_STREAM_ID='wf_W_ERP_FOB_POINT')\r\n\tAND\tEFLV.LOOKUP_TYPE='FOB'\r\n\tAND NSSC.GLOBAL_NAME='CG' /* SJPROD Retirement Q1FY14 */\r\n\t)\r\n\t)TVINPUT\r\n\tQUALIFY ROW_NUMBER() OVER (PARTITION BY \r\n\t\t\t\tTVINPUT.BK_FOB_POINT_CODE, TVINPUT.START_TV_DATE ORDER BY TVINPUT.EDW_UPDATE_DATETIME desc) = 1\r\n\t)TVOUTPUT\r\n\tLEFT JOIN $$SLSORDVWDB.N_ERP_FOB_POINT_TV NEFPT\r\n\t\t\tON TVOUTPUT.BK_FOB_POINT_CODE = NEFPT.BK_FOB_POINT_CODE\r\n\t\t\tAND NEFPT.END_TV_DATE = CAST('3500-01-01' AS date)\r\n\tWHERE\tTVOUTPUT.row_num = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
