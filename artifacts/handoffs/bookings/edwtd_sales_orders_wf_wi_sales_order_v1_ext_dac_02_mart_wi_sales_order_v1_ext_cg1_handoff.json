      "attributes": {
        "Sql Query": "SELECT \r\nSSO.SALES_ORDER_KEY \t\t\t\tSALES_ORDER_KEY,\r\nSCXOOHE.HEADER_ID \t\t\t\t\tHEADER_ID,\r\nSCXOOHE.ALIGN_FLAG        ALIGN_FLAG,\r\nSCXOOHE.ATTRIBUTE33\t\t\t\tATTRIBUTE33,\r\nSCXOOHE.BILL_TO_DEPT \t\t\tBILL_TO_DEPT,\r\nSCXOOHE.CTMP_QUOTE_NUMBER \t    RU_REPORTED_TMIP_QUOTE_NUM,\r\nNTQ.BK_TMIP_QUOTE_NUM AS RU_CTMP_QUOTE_NUM,\r\nSCXOOHE.INVOICE_PRINT_FORMAT        INVOICE_PRINT_FORMAT,\r\nSCXOOHE.ORDER_ORIGIN                        ORDER_ORIGIN,\r\nSCXOOHE.PROJECT_CODE                        PROJECT_CODE,\r\nSCXOOHE.PROJECT_ID                               PROJECT_ID,\r\nSCXOOHE.RETURN_BY_DATE,\r\nSCXOOHE.AUTO_CANCEL_DATE,\r\nSCXOOHE.FOUNDATION_FLAG,\r\nCASE    WHEN   NRO.BK_REPAIR_ORDER_NUM_INT  IS NOT NULL THEN 'Y' ELSE      'N' END   AS REPAIR_ORDER_ROLE ,\r\nCOALESCE(NRO.BK_REPAIR_ORDER_NUM_INT,-999)  AS RU_BK_REPAIR_ORDER_NUM_INT ,\r\nSCXOOHE.SVO_RMA_NUMBER AS RU_SRC_REPORTED_REPAIR_ORD_NUM ,\r\nUSER \t\t\t\t\t\t\t\tEDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) \t\t\t\tEDW_CREATE_DATETIME,\r\nSCXOOHE.TAXABILITY TAXABILITY,\r\nCOALESCE(SCXOOHE.CISCO_BOOK_RESULT_CODE, '=') AS CISCO_BOOK_RESULT_CODE,\r\nSCXOOHE.CISCO_BOOKED_DATE,\r\nSCXOOHE.CBN_IDENTIFIER  CBN_FLG /* Added as part of Sales_orders changes for August QWN032,2014*/,\r\nSCXOOHE.CUSTOMER_ACCEPTANCE_DATE/*added as part of CPE enhancemnet q2fy2015*/,\r\nDPAS_NUMBER/*added as part of OM LSS CPE enhancement q3fy2015*/\r\n,ORDER_NAME/*added as part of OM LSS CPE enhancement q3fy2015*/\r\n,SCXOOHE.PERIODIC_BILLING_FLAG\r\n,COALESCE(SCXOOHE.SERVICE_ORDER_TYPE_CD,'UNKNOWN') AS SERVICE_ORDER_TYPE_CD\r\nFROM \r\n$$STGDB.ST_CG1_XXGCO_OE_ORD_HDR_EXT SCXOOHE\r\nINNER JOIN \r\n(\r\n$$ETLVWDB.SM_SALES_ORDER SSO\r\nINNER JOIN \r\n$$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\nON\r\n( NSSC.SOURCE_SYSTEM_CODE= SSO.SS_CODE)\r\n)\r\nON \r\n(SCXOOHE.HEADER_ID=SSO.SK_SALES_ORDER_HEADER_ID_INT  AND NSSC.GLOBAL_NAME='CG' )\r\nLEFT JOIN $$SLSORDVWDB.N_TMIP_QUOTE NTQ     \r\nON(NTQ.BK_TMIP_QUOTE_NUM =SCXOOHE.CTMP_QUOTE_NUMBER)\r\nLEFT OUTER JOIN $$SERVICEVWDB.N_REPAIR_ORDER NRO  \r\n                ON          (SCXOOHE.SVO_RMA_NUMBER = CAST(NRO.BK_REPAIR_ORDER_NUM_INT AS VARCHAR(240)) \r\n                AND       SCXOOHE.SVO_RMA_NUMBER IS NOT NULL )\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY SCXOOHE.HEADER_ID ORDER BY SCXOOHE.SOURCE_COMMIT_TIME DESC)=1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    },
    {
      "name": "SQ_WI_SALES_ORDER_V1_EXT_CG11",
