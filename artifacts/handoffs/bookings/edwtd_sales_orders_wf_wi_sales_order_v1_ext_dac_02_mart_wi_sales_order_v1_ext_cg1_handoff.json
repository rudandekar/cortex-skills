          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "SELECT   HDR_INFO.SALES_ORDER_KEY,\r\n\t\t\tHDR_INFO.HEADER_ID, \r\n                                                   HDR_INFO.GLOBAL_NAME,\r\n                                           HDR_INFO.SO_FINANCIAL_COMPANY_CD,\r\n                                                   HDR_INFO.SO_FINANCIAL_DEPARTMENT_CD\r\n                                   FROM   (    \r\n                                   SELECT  SALES_ORDER_KEY,\r\n\t\t\t\t\t\t\t\t   HEADER_ID,\r\n                                                                      'CG' AS GLOBAL_NAME,\r\n                                                                      BILL_TO_DEPT, \r\n                                                                      SUBSTR(TRIM(BILL_TO_DEPT),1,3)  AS SO_FINANCIAL_COMPANY_CD,\r\n                                                                      SUBSTR(TRIM(BILL_TO_DEPT),4 ,6) AS SO_FINANCIAL_DEPARTMENT_CD\r\n                                FROM $$STGDB.WI_SALES_ORDER_V1_EXT_CG1\r\n                                WHERE BILL_TO_DEPT IS NOT NULL  AND  CHAR_LENGTH(TRIM( BILL_TO_DEPT))=9\r\n                                     AND (SUBSTR( TRIM(BILL_TO_DEPT),1,3),SUBSTR(TRIM(BILL_TO_DEPT),4 ,6))     \r\n                                      IN(SELECT TRIM(BK_COMPANY_CODE),TRIM(BK_DEPARTMENT_CODE)     \r\n                                      FROM $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT) \r\n                                         \r\n                                                UNION \r\n                                   SELECT   SALES_ORDER_KEY, HEADER_ID,\r\n                                                        'CG' AS GLOBAL_NAME,\r\n                                                        BILL_TO_DEPT, \r\n                                                        SUBSTR(TRIM(BILL_TO_DEPT),1,3)  AS SO_FINANCIAL_COMPANY_CD,\r\n                                                        SUBSTR(TRIM(BILL_TO_DEPT),5 ,6) AS SO_FINANCIAL_DEPARTMENT_CD\r\n                                FROM $$STGDB.WI_SALES_ORDER_V1_EXT_CG1\r\n                                WHERE BILL_TO_DEPT IS NOT NULL  AND  CHAR_LENGTH(TRIM( BILL_TO_DEPT))=10  AND  INDEX(TRIM(BILL_TO_DEPT),'-') =4\r\n                                     AND (SUBSTR( TRIM(BILL_TO_DEPT),1,3),SUBSTR(TRIM(BILL_TO_DEPT),5,6))     \r\n                                      IN(SELECT TRIM(BK_COMPANY_CODE),TRIM(BK_DEPARTMENT_CODE)     FROM $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT)\r\n                                      \r\n                                    UNION \r\n                                      \r\n                                       SELECT   SALES_ORDER_KEY,HEADER_ID,\r\n                                                         'CG' AS GLOBAL_NAME,\r\n                                                         BILL_TO_DEPT, \r\n                                                        '0'||SUBSTR(TRIM(BILL_TO_DEPT),1,2)  AS SO_FINANCIAL_COMPANY_CD, \r\n                                                         SUBSTR(TRIM(BILL_TO_DEPT),3 ,6) AS SO_FINANCIAL_DEPARTMENT_CD\r\n                                FROM $$STGDB.WI_SALES_ORDER_V1_EXT_CG1\r\n                                WHERE BILL_TO_DEPT IS NOT NULL AND  CHAR_LENGTH(BILL_TO_DEPT)=8\r\n                                       AND ( '0'||SUBSTR( TRIM(BILL_TO_DEPT),1,2), SUBSTR(TRIM(BILL_TO_DEPT),3 ,6))     \r\n                                      IN(SELECT TRIM(BK_COMPANY_CODE),TRIM(BK_DEPARTMENT_CODE)     FROM $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT) \r\n                                      \r\n                                UNION \r\n                                \r\n                                SELECT SALES_ORDER_KEY,HEADER_ID,\r\n                                                'CG' AS GLOBAL_NAME,\r\n                                                BILL_TO_DEPT,\r\n                                                SUBSTR(TRIM(BILL_TO_DEPT),10,3)  AS SO_FINANCIAL_COMPANY_CD,\r\n                                                SUBSTR(TRIM(BILL_TO_DEPT),14 ,6) AS SO_FINANCIAL_DEPARTMENT_CD\r\n                                FROM $$STGDB.WI_SALES_ORDER_V1_EXT_CG1\r\n                                WHERE BILL_TO_DEPT IS NOT NULL  AND  CHAR_LENGTH(TRIM( BILL_TO_DEPT))=19  AND  INDEX(TRIM(BILL_TO_DEPT),'-') =13  \r\n                                AND  INDEX(TRIM(BILL_TO_DEPT),':') =8\r\n                                AND (SUBSTR( TRIM(BILL_TO_DEPT),10,3),SUBSTR(TRIM(BILL_TO_DEPT),14,6))     \r\n                                IN(SELECT TRIM(BK_COMPANY_CODE),TRIM(BK_DEPARTMENT_CODE)     FROM $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT)\r\n                                UNION \r\n                                SELECT SALES_ORDER_KEY,HEADER_ID,\r\n                                                'CG' AS GLOBAL_NAME,\r\n                                                BILL_TO_DEPT,\r\n                                                SUBSTR(TRIM(BILL_TO_DEPT),7,3)  AS SO_FINANCIAL_COMPANY_CD,\r\n                                                SUBSTR(TRIM(BILL_TO_DEPT),10 ,6) AS SO_FINANCIAL_DEPARTMENT_CD\r\n                                FROM $$STGDB.WI_SALES_ORDER_V1_EXT_CG1\r\n                                WHERE BILL_TO_DEPT IS NOT NULL  \r\n                                   AND  CHAR_LENGTH(TRIM( BILL_TO_DEPT))=15 \r\n                                   AND  INDEX(TRIM(BILL_TO_DEPT),'#') =5 \r\n                                   AND INDEX(TRIM(BILL_TO_DEPT),',') =6\r\n                                   AND (SUBSTR( TRIM(BILL_TO_DEPT),7,3),SUBSTR(TRIM(BILL_TO_DEPT),10,6))\r\n                                    IN (  SELECT TRIM(BK_COMPANY_CODE),TRIM(BK_DEPARTMENT_CODE)     \r\n                                FROM $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT) )  HDR_INFO",
