      "attributes": {
        "Sql Query": "SELECT \r\nRSH.SALES_TERRITORY_KEY ORIGINAL_SLS_TERR_KEY, \r\nRSH1.SALES_TERRITORY_KEY AS RSTD_SLS_TERR_KEY, \r\nST.ACT_SALES_TERRITORY_NAME_CODE, \r\nCOALESCE(ST.DEFAULT_LEVEL, -888) AS DEFAULT_LEVEL, \r\nCURRENT_TIMESTAMP(0), \r\nUSER, \r\nCURRENT_TIMESTAMP(0), \r\nUSER,\r\nRESTATEMENT_DT,\r\nSOURCE_DELETED_FLG\r\nFROM \r\n$$STGDB.ST_RESTATE3_EDW_HIER_MAPPING ST\r\nINNER JOIN\r\n$$COMREFVWDB.R_SALES_HIERARCHY_FIN RSH\r\nON \r\n(ST.ACTUAL_SHARE_NODE_ID = RSH.SHARE_NODE_ID_INT /*  AND RSH.SALES_TERRITORY_TYPE_CODE ='CORP. REVENUE'  */  )  /* commented CORP. REVENUE condition as part of Restatements FY16 */ \r\nINNER JOIN\r\n$$COMREFVWDB.R_SALES_HIERARCHY_FIN RSH1\r\nON \r\n(ST.RESTATED_SHARE_NODE_ID = RSH1.SHARE_NODE_ID_INT  /*  AND RSH1.SALES_TERRITORY_TYPE_CODE ='CORP. REVENUE'  */  )",
