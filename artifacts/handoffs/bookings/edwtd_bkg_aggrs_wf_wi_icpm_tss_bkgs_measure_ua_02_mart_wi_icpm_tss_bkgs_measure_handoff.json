      "attributes": {
        "Sql Query": "SELECT \r\nBOK.BOOKINGS_MEASURE_KEY          \r\n,BOK.DV_FISCAL_YEAR_MTH_NUMBER_INT \r\n,BOK.BKGS_MEASURE_TRANS_TYPE_CODE  \r\n,4  \r\n,BOK.BOOKINGS_PROCESS_DATE         \r\n,BOK.PRODUCT_KEY           \r\n,WATGUR.PRODUCT_KEY                   \r\n,DD_BK_SO_NUMBER_INT   \r\n,(BOK.TRADE_IN_AMOUNT*WATGUR.SBE_TO_PID_ALLOC_RATIO ) TRADE_IN_AMOUNT\r\n,(BOK.DD_COMP_US_NET_PRICE_AMOUNT*WATGUR.SBE_TO_PID_ALLOC_RATIO) DD_COMP_US_NET_PRICE_AMOUNT\r\n,(BOK.DD_COMP_US_LIST_PRICE_AMOUNT*WATGUR.SBE_TO_PID_ALLOC_RATIO) DD_COMP_US_LIST_PRICE_AMOUNT\r\n,(BOK.DD_COMP_US_COST_AMOUNT*WATGUR.SBE_TO_PID_ALLOC_RATIO) DD_COMP_US_COST_AMOUNT\r\n,(BOK.DD_EXTENDED_QUANTITY*WATGUR.SBE_TO_PID_ALLOC_RATIO) DD_EXTENDED_QUANTITY\r\n,(BOK.DD_COMP_US_HOLD_NET_PRICE_AMT*WATGUR.SBE_TO_PID_ALLOC_RATIO) DD_COMP_US_HOLD_NET_PRICE_AMT\r\n,(BOK.DD_COMP_US_HOLD_LIST_PRICE_AMT*WATGUR.SBE_TO_PID_ALLOC_RATIO) DD_COMP_US_HOLD_LIST_PRICE_AMT\r\n,(BOK.DD_COMP_US_HOLD_COST_AMOUNT*WATGUR.SBE_TO_PID_ALLOC_RATIO) DD_COMP_US_HOLD_COST_AMOUNT\r\n,(BOK.DD_EXTENDED_HOLD_QUANTITY*WATGUR.SBE_TO_PID_ALLOC_RATIO) DD_EXTENDED_HOLD_QUANTITY\r\n,(BOK.DD_COMP_US_STANDARD_PRICE_AMT*WATGUR.SBE_TO_PID_ALLOC_RATIO)  DD_COMP_US_STANDARD_PRICE_AMT\r\n,BOK.DV_REVENUE_RECOGNITION_FLG       /* Added part of True Demand */\r\n,BOK.DV_NET_SPREAD_FLG                /* Added part of True Demand */\r\n,BOK.CORPORATE_BOOKINGS_FLG           /* Added part of True Demand */\r\nFROM $$STGDB.WI_ICPM_SBE_TO_GOODS_RATIO WATGUR\r\nINNER JOIN $$STGDB.WI_ICPM_SRVC_BKGS_TSS BOK \r\nON BOK.DV_FISCAL_YEAR_MTH_NUMBER_INT = WATGUR.FISCAL_YEAR_MTH_NUMBER_INT\r\nLEFT OUTER JOIN $$STGDB.WI_ICPM_TSS_BKGS_ALLOCATED ALLOC \r\nON ALLOC.BOOKINGS_MEASURE_KEY = BOK.BOOKINGS_MEASURE_KEY\r\nAND ALLOC.BKGS_MEASURE_TRANS_TYPE_CODE = BOK.BKGS_MEASURE_TRANS_TYPE_CODE\r\nAND ALLOC.BOOKINGS_PROCESS_DATE = BOK.BOOKINGS_PROCESS_DATE\r\nWHERE ALLOC.BOOKINGS_MEASURE_KEY IS NULL",
