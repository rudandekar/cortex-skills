      "attributes": {
        "Sql Query": "SELECT\r\n\tTVOUTPUT.BK_SALES_ORDER_HOLD_NAME,\r\n\tTVOUTPUT.START_TV_DATE,\r\n\tCOALESCE( MAX(TVOUTPUT.START_TV_DATE - INTERVAL '1' DAY) \r\n\tOVER (PARTITION BY TVOUTPUT.BK_SALES_ORDER_HOLD_NAME ORDER BY TVOUTPUT.START_TV_DATE ASC \r\n\tROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING), DATE '3500-01-01') AS END_TV_DATE,\r\n\tTVOUTPUT.SALES_ORDER_LINE_HOLD_DESCR,\r\n\tTVOUTPUT.BK_SOL_HOLD_TYPE_CODE,\r\n\tCOALESCE(TVOUTPUT.BK_SOL_HOLD_GROUP_CODE,'UNKNOWN') AS BK_SOL_HOLD_GROUP_CODE,\r\n\tTVOUTPUT.ACTION_CODE,\r\n\tTVOUTPUT.R12_SO_HOLD_SHORT_DESCR,  \r\n\tTVOUTPUT.SHIPPING_HOLD_FLG       ,      \r\n\tTVOUTPUT.MANUFACTURING_HOLD_FLG  ,            \r\n\tTVOUTPUT.MOVE_OUT_WINDOW_DAYS_CNT  ,        \r\n\tTVOUTPUT.MOVE_OUT_DAYS_CNT ,       \r\n\tTVOUTPUT.MOVE_OUT_HOLD_FLG  ,   \r\n\tTVOUTPUT.SEND_HOLD_TO_MPA_FLG ,\r\n\tROW_NUMBER() OVER (PARTITION BY TVOUTPUT.BK_SALES_ORDER_HOLD_NAME ORDER BY TVOUTPUT.START_TV_DATE ASC) AS RANK_INDEX,\r\n\t(CASE WHEN RANK_INDEX = 1 AND NSOHDT.BK_SALES_ORDER_HOLD_NAME IS NOT NULL THEN 'U' ELSE 'I' END) AS DML_TYPE\r\nFROM\r\n(\r\nSELECT\r\n\tSOURCE_COMMIT_TIME,\r\n\tBK_SALES_ORDER_HOLD_NAME,\r\n\tSTART_TV_DATE,\r\n\tSALES_ORDER_LINE_HOLD_DESCR,\r\n\tBK_SOL_HOLD_TYPE_CODE,\r\n\tBK_SOL_HOLD_GROUP_CODE,\r\n\tCREATE_DATETIME,\r\n\t'I' as ACTION_CODE,\r\n\tR12_SO_HOLD_SHORT_DESCR,  \r\n\tSHIPPING_HOLD_FLG       ,      \r\n\tMANUFACTURING_HOLD_FLG  ,            \r\n\tMOVE_OUT_WINDOW_DAYS_CNT  ,        \r\n\tMOVE_OUT_DAYS_CNT ,       \r\n\tMOVE_OUT_HOLD_FLG  ,   \r\n\tSEND_HOLD_TO_MPA_FLG ,\r\n\tROW_NUMBER() OVER (PARTITION BY \r\n\tBK_SALES_ORDER_HOLD_NAME,\r\n\tSALES_ORDER_LINE_HOLD_DESCR,\r\n\tBK_SOL_HOLD_TYPE_CODE,\r\n\tBK_SOL_HOLD_GROUP_CODE,\r\n\tR12_SO_HOLD_SHORT_DESCR,  \r\n\tSHIPPING_HOLD_FLG       ,      \r\n\tMANUFACTURING_HOLD_FLG  ,            \r\n\tMOVE_OUT_WINDOW_DAYS_CNT  ,        \r\n\tMOVE_OUT_DAYS_CNT ,       \r\n\tMOVE_OUT_HOLD_FLG  ,   \r\n\tSEND_HOLD_TO_MPA_FLG \r\n\tORDER BY CREATE_DATETIME DESC) AS row_num  \r\nFROM\r\n(\r\nSELECT\r\n\tSUOHD.SOURCE_COMMIT_TIME,\r\n\tSUOHD.NAME \t\t\t\t\t\t\t\tBK_SALES_ORDER_HOLD_NAME,\r\n\tCAST (SUOHD.CREATE_DATETIME AS DATE) \tSTART_TV_DATE,\r\n\tSUOHD.DESCRIPTION  \t\t\t\t\t\tSALES_ORDER_LINE_HOLD_DESCR ,\r\n\tSUOHD.TYPE_CODE  \t\t\t\t\t\tBK_SOL_HOLD_TYPE_CODE,\r\n\tSUOHD.ATTRIBUTE6  \t\t\t\t\t\tBK_SOL_HOLD_GROUP_CODE,\r\n\tSUOHD.CREATE_DATETIME\t\t\t\t\tCREATE_DATETIME,\r\n\t'I' as ACTION_CODE\t\t\t\t\t\t ,\r\n\tCOALESCE(SEHCS.CG1_HOLD_NAME,'UNKNOWN') R12_SO_HOLD_SHORT_DESCR,  \r\n\tCOALESCE(SEHCS.SHIP_HOLD,'=')        \tSHIPPING_HOLD_FLG       ,      \r\n\tCOALESCE(SEHCS.MFG_HOLD,'=')        \tMANUFACTURING_HOLD_FLG  ,            \r\n\tCOALESCE(SEHCS.MOVE_OUT_WINDOW,0)    MOVE_OUT_WINDOW_DAYS_CNT  ,        \r\n\tCOALESCE(SEHCS.MOVE_OUT_DAYS,0)      MOVE_OUT_DAYS_CNT ,       \r\n\tCOALESCE(SEHCS.MOVE_OUT_HOLD,'=')       MOVE_OUT_HOLD_FLG  ,   \r\n\tCOALESCE(SEHCS.SEND_HOLD_TO_MPA,'=')     SEND_HOLD_TO_MPA_FLG    \r\nFROM\r\n\t( SELECT SOURCE_COMMIT_TIME, NAME , CREATE_DATETIME, DESCRIPTION ,TYPE_CODE,ATTRIBUTE6, 'I' as ACTION_CODE FROM $$STGDB.ST_UO_OE_HOLD_DEFINITIONS \r\n\tQUALIFY ROW_NUMBER() OVER (PARTITION BY NAME\r\n\t\tORDER BY CREATE_DATETIME DESC) = 1 ) SUOHD\r\nLEFT JOIN ( SELECT HOLD_NAME,                     \r\nCG1_HOLD_NAME,\r\nSHIP_HOLD,\r\nMFG_HOLD,\r\nMOVE_OUT_WINDOW,\r\nMOVE_OUT_DAYS,\r\nMOVE_OUT_HOLD,\r\nSEND_HOLD_TO_MPA      FROM              \r\n$$SOPDATAVWDB.SC_EXCEL_HOLD_CLASSIF_STG  \r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY  HOLD_NAME ORDER BY BATCH_ID  DESC) = 1 ) SEHCS \r\nON ( SEHCS.HOLD_NAME = SUOHD.NAME)\r\nUNION ALL\r\nSELECT \r\n\tSBOHD.SOURCE_COMMIT_TIME,\r\n\tSBOHD.NAME \t\t\t\t\t\t\t\tBK_SALES_ORDER_HOLD_NAME,\r\n\tCAST (SBOHD.CREATE_DATETIME AS DATE) \tSTART_TV_DATE,\r\n\tSBOHD.DESCRIPTION  \t\t\t\t\t\tSALES_ORDER_LINE_HOLD_DESCR ,\r\n\tSBOHD.TYPE_CODE  \t\t\t\t\t\tBK_SOL_HOLD_TYPE_CODE,\r\n\tSBOHD.ATTRIBUTE6  \t\t\t\t\t\tBK_SOL_HOLD_GROUP_CODE,\r\n\tSBOHD.CREATE_DATETIME\t\t\t\t\tCREATE_DATETIME,\r\n\t'I' as ACTION_CODE\t\t\t\t\t,\r\n\tCOALESCE(SEHCS.CG1_HOLD_NAME,'UNKNOWN') R12_SO_HOLD_SHORT_DESCR,  \r\n\tCOALESCE(SEHCS.SHIP_HOLD,'=')        \tSHIPPING_HOLD_FLG       ,      \r\n\tCOALESCE(SEHCS.MFG_HOLD,'=')        \tMANUFACTURING_HOLD_FLG  ,            \r\n\tCOALESCE(SEHCS.MOVE_OUT_WINDOW,0)    MOVE_OUT_WINDOW_DAYS_CNT  ,        \r\n\tCOALESCE(SEHCS.MOVE_OUT_DAYS,0)      MOVE_OUT_DAYS_CNT ,       \r\n\tCOALESCE(SEHCS.MOVE_OUT_HOLD,'=')       MOVE_OUT_HOLD_FLG  ,   \r\n\tCOALESCE(SEHCS.SEND_HOLD_TO_MPA,'=')     SEND_HOLD_TO_MPA_FLG     \r\nFROM\r\n\t$$STGDB.ST_BO_OE_HOLD_DEFINITIONS SBOHD \r\n\tLEFT JOIN $$STGDB.ST_UO_OE_HOLD_DEFINITIONS SUOHD\r\n\tON \tSBOHD.NAME = SUOHD.NAME\r\n\tLEFT JOIN ( SELECT HOLD_NAME,                     \r\n\tCG1_HOLD_NAME,\r\n\tSHIP_HOLD,\r\n\tMFG_HOLD,\r\n\tMOVE_OUT_WINDOW,\r\n\tMOVE_OUT_DAYS,\r\n\tMOVE_OUT_HOLD,\r\n\tSEND_HOLD_TO_MPA    FROM                \r\n\t$$SOPDATAVWDB.SC_EXCEL_HOLD_CLASSIF_STG  \r\n\tQUALIFY ROW_NUMBER () OVER (PARTITION BY  HOLD_NAME ORDER BY BATCH_ID  DESC) = 1 ) SEHCS \r\n\tON ( SEHCS.HOLD_NAME = SBOHD.NAME)\r\n\tLEFT OUTER JOIN \r\n\t$$ETLONLYDB.EL_ORDER_HOLD_DEFINITIONS EOHD\r\n\tON (SBOHD.NAME=EOHD.NAME AND EOHD.GLOBAL_NAME ='UO')\r\n\tQUALIFY ROW_NUMBER() OVER (PARTITION BY SBOHD.NAME\r\n\tORDER BY SBOHD.CREATE_DATETIME DESC) = 1 \r\n    WHERE SUOHD.NAME IS NULL AND EOHD.NAME IS NULL\r\n/* Added by OM EDW Team for Q2FY14 Changes Start Point*/ \r\nUNION ALL\r\nSELECT \r\n\tSCOHD.SOURCE_COMMIT_TIME,\r\n\tSCOHD.NAME \t\t\t\t\t\t\t\tBK_SALES_ORDER_HOLD_NAME,\r\n\tCAST (SCOHD.CREATE_DATETIME AS DATE) \tSTART_TV_DATE,\r\n\tSCOHD.DESCRIPTION  \t\t\t\t\t\tSALES_ORDER_LINE_HOLD_DESCR ,\r\n\tSCOHD.TYPE_CODE  \t\t\t\t\t\tBK_SOL_HOLD_TYPE_CODE,\r\n\tSCOHD.ATTRIBUTE6  \t\t\t\t\t\tBK_SOL_HOLD_GROUP_CODE,\r\n\tSCOHD.CREATE_DATETIME\t\t\t\t\tCREATE_DATETIME,\r\n\t'I' as ACTION_CODE\t\t\t\t\t,\r\n\tCOALESCE(SEHCS.CG1_HOLD_NAME,'UNKNOWN') R12_SO_HOLD_SHORT_DESCR,  \r\n\tCOALESCE(SEHCS.SHIP_HOLD,'=')        \tSHIPPING_HOLD_FLG       ,      \r\n\tCOALESCE(SEHCS.MFG_HOLD,'=')        \tMANUFACTURING_HOLD_FLG  ,            \r\n\tCOALESCE(SEHCS.MOVE_OUT_WINDOW,0)    MOVE_OUT_WINDOW_DAYS_CNT  ,        \r\n\tCOALESCE(SEHCS.MOVE_OUT_DAYS,0)      MOVE_OUT_DAYS_CNT ,       \r\n\tCOALESCE(SEHCS.MOVE_OUT_HOLD,'=')       MOVE_OUT_HOLD_FLG  ,   \r\n\tCOALESCE(SEHCS.SEND_HOLD_TO_MPA,'=')     SEND_HOLD_TO_MPA_FLG     \r\nFROM\r\n\t$$STGDB.ST_CG1_OE_HOLD_DEFINITIONS SCOHD \r\n\tLEFT JOIN $$STGDB.ST_UO_OE_HOLD_DEFINITIONS SUOHD\r\n\tON \tSCOHD.NAME = SUOHD.NAME\r\n\tLEFT JOIN $$STGDB.ST_BO_OE_HOLD_DEFINITIONS SBOHD\r\n\tON \tSBOHD.NAME = SCOHD.NAME\r\n\tLEFT JOIN ( SELECT HOLD_NAME,                     \r\n\tCG1_HOLD_NAME,\r\n\tSHIP_HOLD,\r\n\tMFG_HOLD,\r\n\tMOVE_OUT_WINDOW,\r\n\tMOVE_OUT_DAYS,\r\n\tMOVE_OUT_HOLD,\r\n\tSEND_HOLD_TO_MPA    FROM                \r\n\t$$SOPDATAVWDB.SC_EXCEL_HOLD_CLASSIF_STG  \r\n\tQUALIFY ROW_NUMBER () OVER (PARTITION BY  HOLD_NAME ORDER BY BATCH_ID  DESC) = 1 ) SEHCS \r\n\tON ( SEHCS.HOLD_NAME = SCOHD.NAME)\r\n\tLEFT OUTER JOIN \r\n\t$$ETLONLYDB.EL_ORDER_HOLD_DEFINITIONS EOHD\r\n\tON (SCOHD.NAME=EOHD.NAME AND EOHD.GLOBAL_NAME IN ('UO','BO'))\r\n\tQUALIFY ROW_NUMBER() OVER (PARTITION BY SCOHD.NAME\r\n\tORDER BY SCOHD.CREATE_DATETIME DESC) = 1 \r\n    WHERE SUOHD.NAME IS NULL\r\n    AND SBOHD.NAME IS NULL\r\n\tAND EOHD.NAME IS NULL /* Added by OM EDW Team for Q2FY14 Changes End Point */ \r\n\t\r\nUNION ALL\r\n/*\r\nBELOW SQL IS ADDEDD TO PROCESS  THOSE ITEMS WHICH ARE CHANGED IN SC_EXCEL_HOLD_CLASSIF_STG INCREMENTAL DATA BUT NOT IN DEF TABLE . THIS IS TO MAINTAIN THE TV OF THIS COLUMN\r\n*/\r\nSELECT\r\ncast('1900-01-01 00:00:00' as timestamp(0)),/*--999 BATCH_ID,*/\r\n\tNSOHDT.BK_SALES_ORDER_HOLD_NAME,\r\n\tNSOHDT.START_TV_DATE,\r\n\tNSOHDT.SALES_ORDER_LINE_HOLD_DESCR,\r\n\tNSOHDT.BK_SOL_HOLD_TYPE_CODE,\r\n\tNSOHDT.BK_SOL_HOLD_GROUP_CODE,\r\n\tNSOHDT.EDW_CREATE_DATETIME CREATE_DATETIME,\r\n\t'X'  ACTION_CODE,\r\n\tCOALESCE(SEHCS.CG1_HOLD_NAME,'UNKNOWN') R12_SO_HOLD_SHORT_DESCR,  \r\n\tCOALESCE(SEHCS.SHIP_HOLD,'=')        \tSHIPPING_HOLD_FLG       ,      \r\n\tCOALESCE(SEHCS.MFG_HOLD,'=')        \tMANUFACTURING_HOLD_FLG  ,            \r\n\tCOALESCE(SEHCS.MOVE_OUT_WINDOW,0)    MOVE_OUT_WINDOW_DAYS_CNT  ,        \r\n\tCOALESCE(SEHCS.MOVE_OUT_DAYS,0)      MOVE_OUT_DAYS_CNT ,       \r\n\tCOALESCE(SEHCS.MOVE_OUT_HOLD,'=')       MOVE_OUT_HOLD_FLG  ,   \r\n\tCOALESCE(SEHCS.SEND_HOLD_TO_MPA,'=')     SEND_HOLD_TO_MPA_FLG  \r\nFROM $$SLSORDVWDB.N_SALES_ORDER_HOLD_DEF_TV NSOHDT\r\nINNER JOIN\r\n( \tSELECT HOLD_NAME,                     \r\n\tCG1_HOLD_NAME,\r\n\tSHIP_HOLD,\r\n\tMFG_HOLD,\r\n\tMOVE_OUT_WINDOW,\r\n\tMOVE_OUT_DAYS,\r\n\tMOVE_OUT_HOLD,\r\n\tSEND_HOLD_TO_MPA    FROM                \r\n\t$$SOPDATAVWDB.SC_EXCEL_HOLD_CLASSIF_STG \r\n\tQUALIFY ROW_NUMBER () OVER (PARTITION BY  HOLD_NAME ORDER BY BATCH_ID  DESC) = 1 ) SEHCS \r\n\tON ( SEHCS.HOLD_NAME = NSOHDT.BK_SALES_ORDER_HOLD_NAME)\r\nWHERE END_TV_DATE = CAST ('3500-01-01' AS DATE)\r\nAND SEHCS.HOLD_NAME NOT IN ( SELECT DISTINCT NAME \r\nFROM $$STGDB.ST_UO_OE_HOLD_DEFINITIONS\r\nUNION ALL\r\nSELECT DISTINCT SBOHD.NAME\r\nFROM $$STGDB.ST_BO_OE_HOLD_DEFINITIONS SBOHD \r\nUNION ALL\r\nSELECT DISTINCT SCOHD.NAME\r\nFROM $$STGDB.ST_CG1_OE_HOLD_DEFINITIONS SCOHD )\r\nAND ( COALESCE(SEHCS.CG1_HOLD_NAME,'UNKNOWN') <>  NSOHDT.R12_SO_HOLD_SHORT_DESCR OR\r\n\tCOALESCE(SEHCS.SHIP_HOLD,'=') <> NSOHDT.SHIPPING_HOLD_FLG OR\r\n\tCOALESCE(SEHCS.MFG_HOLD,'=') <> NSOHDT.MANUFACTURING_HOLD_FLG OR\r\n\tCOALESCE(SEHCS.MOVE_OUT_WINDOW,0)  <> NSOHDT.MOVE_OUT_WINDOW_DAYS_CNT OR\r\n\tCOALESCE(SEHCS.MOVE_OUT_DAYS,0) <> NSOHDT.MOVE_OUT_DAYS_CNT OR\r\n\tCOALESCE(SEHCS.MOVE_OUT_HOLD,'=') <> NSOHDT.MOVE_OUT_HOLD_FLG OR\r\n\tCOALESCE(SEHCS.SEND_HOLD_TO_MPA,'=') <> NSOHDT.SEND_HOLD_TO_MPA_FLG )\r\nUNION ALL\r\nSELECT\r\n\tcast('1900-01-01 00:00:00' as timestamp(0)) /*BATCH_ID*/,\r\n\tNSOHDT.BK_SALES_ORDER_HOLD_NAME,\r\n\tNSOHDT.START_TV_DATE,\r\n\tNSOHDT.SALES_ORDER_LINE_HOLD_DESCR,\r\n\tNSOHDT.BK_SOL_HOLD_TYPE_CODE,\r\n\tNSOHDT.BK_SOL_HOLD_GROUP_CODE,\r\n\tNSOHDT.EDW_CREATE_DATETIME CREATE_DATETIME,\r\n\t'X'  ACTION_CODE,\r\n\tNSOHDT.R12_SO_HOLD_SHORT_DESCR,  \r\n\tNSOHDT.SHIPPING_HOLD_FLG       ,      \r\n\tNSOHDT.MANUFACTURING_HOLD_FLG  ,            \r\n\tNSOHDT.MOVE_OUT_WINDOW_DAYS_CNT  ,        \r\n\tNSOHDT.MOVE_OUT_DAYS_CNT ,       \r\n\tNSOHDT.MOVE_OUT_HOLD_FLG  ,   \r\n\tNSOHDT.SEND_HOLD_TO_MPA_FLG  \r\nFROM $$SLSORDVWDB.N_SALES_ORDER_HOLD_DEF_TV NSOHDT\r\nWHERE END_TV_DATE = CAST ('3500-01-01' AS DATE)\r\nAND BK_SALES_ORDER_HOLD_NAME IN\r\n(\r\nSELECT DISTINCT NAME \r\nFROM $$STGDB.ST_UO_OE_HOLD_DEFINITIONS\r\nUNION ALL\r\nSELECT DISTINCT SBOHD.NAME\r\nFROM $$STGDB.ST_BO_OE_HOLD_DEFINITIONS SBOHD  \r\nLEFT JOIN $$STGDB.ST_UO_OE_HOLD_DEFINITIONS SUOHD\r\nON \tSBOHD.NAME = SUOHD.NAME\r\nWHERE SUOHD.NAME IS NULL\r\n/* Added by OM EDW Team for Q2FY14 Changes Start Point */ \r\nUNION ALL\r\nSELECT DISTINCT SCOHD.NAME \r\nFROM $$STGDB.ST_CG1_OE_HOLD_DEFINITIONS  SCOHD\r\nLEFT OUTER JOIN $$STGDB.ST_BO_OE_HOLD_DEFINITIONS SBOHD\r\nON SCOHD.NAME = SBOHD.NAME\r\nLEFT OUTER JOIN $$STGDB.ST_UO_OE_HOLD_DEFINITIONS SUOHD\r\nON SCOHD.NAME = SUOHD.NAME\r\nWHERE  SUOHD.NAME IS NULL AND  SBOHD.NAME IS NULL \r\n/* Added by OM EDW Team for Q2FY14 Changes End Point */ \r\n)\r\n\r\n)TVINPUT\r\n\tQUALIFY ROW_NUMBER() OVER (PARTITION BY \r\n\t\t\tTVINPUT.BK_SALES_ORDER_HOLD_NAME,\r\n\t\t\tTVINPUT.START_TV_DATE \r\n\t\tORDER BY TVINPUT.CREATE_DATETIME desc) = 1\r\n)TVOUTPUT\r\n\r\nLEFT JOIN $$SLSORDVWDB.N_SALES_ORDER_HOLD_DEF_TV NSOHDT\r\n\tON TVOUTPUT.BK_SALES_ORDER_HOLD_NAME = NSOHDT.BK_SALES_ORDER_HOLD_NAME\r\n\tAND NSOHDT.END_TV_DATE = CAST('3500-01-01' AS date)\r\nWHERE\tTVOUTPUT.row_num = 1",
