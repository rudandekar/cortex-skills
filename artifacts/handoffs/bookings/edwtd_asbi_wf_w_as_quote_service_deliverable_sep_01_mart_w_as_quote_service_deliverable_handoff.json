      "attributes": {
        "Sql Query": "select\r\nCOALESCE(STG.BK_DELIVERABLE_NAME,'UNKNOWN') AS BK_DELIVERABLE_NAME,\r\nCOALESCE(STG.DELIVERABLE_DESC,'UNKNOWN') AS DELIVERABLE_DESC,\r\nCOALESCE(STG.SOURCE_DELETED_FLG,'N') AS SOURCE_DELETED_FLG ,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\nSTG.BK_SS_CD,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NQSD.BK_DELIVERABLE_NAME IS NULL\r\nAND NQSD.BK_SS_CD IS NULL\r\nTHEN 'I'\r\nELSE 'U'\r\nEND AS DML_TYPE\r\nFROM $$STGDB.ST_AS_QUOTE_SERVICE_DELIVERABLE_HDP STG\r\nLEFT OUTER JOIN $$SERVICEVWDB.N_AS_QUOTE_SERVICE_DELIVERABLE NQSD\r\non NQSD.BK_DELIVERABLE_NAME=STG.BK_DELIVERABLE_NAME\r\nAND NQSD.BK_SS_CD=STG.BK_SS_CD",
