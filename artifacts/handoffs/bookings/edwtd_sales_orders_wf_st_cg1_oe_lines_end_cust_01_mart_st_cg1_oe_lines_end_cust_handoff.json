      "attributes": {
        "Sql Query": "SELECT \r\nCG1_OE_ORDER_LINES_ALL.LINE_ID, \r\nCOALESCE(CG1_OE_ORDER_LINES_ALL.END_CUSTOMER_SITE_USE_ID,-999) ,\r\nCOALESCE(CG1_OE_ORDER_LINES_ALL.END_CUSTOMER_ID, -999),\r\nCG1_OE_ORDER_LINES_ALL.SOURCE_COMMIT_TIME, \r\n'CG' GLOBAL_NAME,\r\nCG1_OE_ORDER_LINES_ALL.END_CUSTOMER_CONTACT_ID /* Added as part of 9th Apr release */\r\nFROM\r\n$$NRTACCUMVWDB.CG1_OE_ORDER_LINES_ALL CG1_OE_ORDER_LINES_ALL,\r\n$$COMREFVWDB.N_CISCO_OPERATING_UNIT NCOU\r\nWHERE\r\nCG1_OE_ORDER_LINES_ALL.ORG_ID = NCOU.SK_ORGANIZATION_ID_INT\r\nAND\r\nNCOU.MOVED_TO_CG1_FLG  = 'Y'     \r\nAND\r\nCG1_OE_ORDER_LINES_ALL.SOURCE_COMMIT_TIME >= '$$LastExtractDate'\r\nAND \r\nCG1_OE_ORDER_LINES_ALL.SOURCE_COMMIT_TIME <'$$EndLastExtractDate'\r\nAND \r\nCG1_OE_ORDER_LINES_ALL.SOURCE_DML_TYPE <> 'DELETE'\r\n/*AND \r\nCG1_OE_ORDER_LINES_ALL.ORG_ID IN (SELECT DISTINCT ORG_ID FROM $$ETLVWDB.CG1_ORD_ID)*/\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY CG1_OE_ORDER_LINES_ALL.LINE_ID ORDER BY CG1_OE_ORDER_LINES_ALL.REFRESH_DATETIME DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "CALL COLLECT_STATS_WRAP('$$NRTACCUMDB','CG1_OE_ORDER_LINES_ALL','D');",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
