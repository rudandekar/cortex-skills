      "attributes": {
        "Sql Query": "SELECT\r\nNSO.SALES_ORDER_KEY,\r\n'UNKNOWN' SO_AM_UNKNOWN_000_CD,\r\nSTO.FOUNDATION_FLAG AS SO_AM_UNKNOWN_001_CD,\r\n'UNKNOWN'  AS SO_AM_UNKNOWN_002_CD,\r\n'UNKNOWN'  AS SO_AM_UNKNOWN_003_CD,\r\nCURRENT_TIMESTAMP(0),\r\n USER,\r\n CURRENT_TIMESTAMP(0),\r\n USER,\r\nSTO.ADJUSTMENT_NUMBER AS SO_AM_UNKNOWN_004_CD\r\nfrom $$STGDB.ST_CG1_XXGCO_OE_ORD_HDR_EXT STO\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_TV NSO\r\nON (NSO.SK_SALES_ORDER_HEADER_ID_INT = STO.HEADER_ID\r\nAND NSO.SS_CODE ='CG') \r\nLEFT OUTER JOIN $$SLSORDVWDB.N_SALES_ORDER_AM_UNKNOWN NSOUN\r\nON NSOUN.SALES_ORDER_KEY= NSO.SALES_ORDER_KEY\r\nWHERE NOT EXISTS (SELECT SALES_ORDER_KEY FROM $$SLSORDVWDB.N_SALES_ORDER_AM_UNKNOWN)",
