      "attributes": {
        "Sql Query": "SELECT\r\nV1.SK_ID_LINT\r\n,ELA.ARCHITECTURE_ID\r\n,ELT.TECHNOLOGY_ID\r\n,ELO.BS_ID AS OFFER_TYPE_ID\r\n,P.PARTY_SSOT_PARTY_ID_INT AS DEAL_END_CR_PARTY_ID\r\n,CASE WHEN BRANCH_HQ_BRANCH_CD='HQ' THEN HIER.BRANCH_PARTY_SSOT_PARTY_ID_INT ELSE HIER.HQ_PARTY_SSOT_PARTY_ID_INT END AS DEAL_END_CR_HQ_PARTY_ID\r\n,SVCS.SOURCE_CREATE_DTM\r\n,SVCS.MAINTENANCE_ORDER_NUM\r\nFROM\r\n$$SERVICEVWDB.N_SVC_CNTRCT_LN_TECH_SVCS_V1 V1\r\nINNER JOIN $$SERVICEVWDB.N_SVC_CNTRCT_LN_TECH_SERVICES SVCS\r\nON SVCS.SVC_CNTRCT_LN_TECH_SVCS_KEY=V1.SVC_CNTRCT_LN_TECH_SVCS_KEY\r\nINNER JOIN $$COMREFVWDB.N_PARTY P\r\nON P.PARTY_KEY=V1.DV_DEAL_END_CUST_PRTY_KEY\r\nINNER JOIN $$ETLVWDB.EL_XXCAS_SLIMCS_ARCH ELA\r\nON (V1.BK_AS_ARCHITECTURE_NAME = ELA.NAME\r\nAND ELA.STATUS='ACTIVE')\r\nLEFT JOIN $$ETLVWDB.EL_XXCAS_SLIMCS_TECH ELT\r\nON (V1.BK_AS_TECHNOLOGY_NAME = ELT.NAME\r\nAND ELT.STATUS='ACTIVE')\r\nINNER JOIN $$ETLVWDB.EL_XXCAS_SLIMCS_BIZ_SERVICES ELO\r\nON (V1.BK_OFFER_TYPE_NAME = ELO.NAME\r\nAND ELO.STATUS='ACTIVE')\r\nINNER JOIN (SELECT \r\nBRANCH_HQ_BRANCH_CD           \r\n,BRANCH_PARTY_SSOT_PARTY_ID_INT\r\n,HQ_PARTY_SSOT_PARTY_ID_INT \r\nFROM\r\n$$COMREFVWDB.MT_CUSTOMER_PARTY_HIERARCHY \r\nGROUP BY \r\nBRANCH_HQ_BRANCH_CD\r\n,BRANCH_PARTY_SSOT_PARTY_ID_INT\r\n,HQ_PARTY_SSOT_PARTY_ID_INT )HIER \r\nON HIER.BRANCH_PARTY_SSOT_PARTY_ID_INT=P.PARTY_SSOT_PARTY_ID_INT\r\nWHERE\r\nSVCS.DV_LINE_STYLE_ID_INT=7\r\nAND SVCS.MAINTENANCE_ORDER_NUM=108744085",
