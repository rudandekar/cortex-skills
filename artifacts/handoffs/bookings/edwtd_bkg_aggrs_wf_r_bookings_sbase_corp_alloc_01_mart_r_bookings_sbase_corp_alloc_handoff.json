      "attributes": {
        "Sql Query": "SELECT  TRIM(COALESCE(SUBSTR(TCPA.BK_TECHNOLOGY_GROUP_ID,1,3), '')) as tech_group,\r\nTME.FISCAL_YEAR_MONTH_INT  trans_fiscal_month,\r\n\r\nTRIM(COALESCE(SUBSTR(CASE     TRIM(TCPA.RU_BK_PRODUCT_SUBGROUP_ID)\r\n                WHEN   'CORP TASK_ADJ_PS' THEN TRIM(TCPA.RU_BK_PRODUCT_SUBGROUP_ID)||'-'||TCPA.BK_TECHNOLOGY_GROUP_ID||' (PS)'\r\n                WHEN   'DLCPLUS_ADJ_PS' THEN TRIM(TCPA.RU_BK_PRODUCT_SUBGROUP_ID)||'-'||TCPA.RU_BK_PRODUCT_FAMILY_ID||'-'||TCPA.BK_BUSINESS_UNIT_ID||' (PS)'\r\nELSE      TRIM(TCPA.RU_BK_PRODUCT_SUBGROUP_ID)||'-'||TCPA.RU_BK_PRODUCT_FAMILY_ID||' (PS)'\r\nEND,1,80)       , '')) AS product_sub_group,\r\n\r\nTRIM(CASE     RBFM.SALES_REP_NUMBER \r\n                WHEN   'UNKNOWN' THEN 'UNDEFINED SALES AGENT - '\r\nELSE      TRIM(LEADING '0' FROM RBFM.SALES_REP_NUMBER) ||' - ' \r\nEND       || (CASE     WHEN SUBSTR(L6_SALES_TERRITORY_NAME_CODE,1,1) IN ('_','-','&') \r\nTHEN SUBSTR( L6_SALES_TERRITORY_NAME_CODE,2, CHAR_LENGTH(L6_SALES_TERRITORY_NAME_CODE)) \r\nELSE      L6_SALES_TERRITORY_NAME_CODE \r\nEND       )) AS salesrep,\r\n\r\nTRIM(COALESCE('FY' || SUBSTR(TME.FISCAL_MONTH_NAME,9,2), '')) AS fiscal_year,\r\n\r\nTRIM(COALESCE(CASE RBFM.ADJUSTMENT_TYPE_CODE \r\n   WHEN 'PA' THEN 'Period Adjustment'\r\n   WHEN 'UNKNOWN' THEN  'NOT AVAILABLE'\r\nELSE RBFM.ADJUSTMENT_TYPE_CODE END, '')) AS measure,\r\n                                \r\nTRIM(COALESCE(SUBSTR(TME.FISCAL_WEEK_NAME,1,8), '')) AS proc_fiscal_week,\r\n\r\n'' AS trans_fiscal_week,\r\n\r\nTRIM(COALESCE(TCPA.L4_TECHNOLOGY_MKT_SEGMENT_NAME || ' (L4)' , '')) AS tms_level4,\r\n\r\nTRIM(COALESCE(\r\nCASE     WHEN RBFM.SERVICE_FLG ='Y' THEN\r\nCASE     WHEN TCPA.BK_PRODUCT_TYPE_ID IN('TRAINING','TECHDOC') THEN 'Training and Documentation' \r\nELSE      \r\nCASE     RBFM.REVENUE_TYPE_CODE \r\n                WHEN   'M' THEN 'M (RS)'\r\n                WHEN   'P' THEN 'P (RS)'\r\n                WHEN   'Q' THEN 'Q (RS)'\r\n                WHEN   'R' THEN 'R (RS)'\r\n                WHEN   '' THEN 'No Revenue Source' \r\nELSE      'Other (RS)' \r\nEND       \r\nEND       \r\nELSE      'Product' \r\nEND       , '')) AS bkg_type,\r\n\r\nTRIM(COALESCE(CASE     WHEN SH.SALES_SUBCOVERAGE_CODE ='OTHER' THEN 'OTHER SC' \r\n                WHEN   SH.SALES_SUBCOVERAGE_CODE ='UNKNOWN' THEN 'UNDEFINED SALES COVERAGE'\r\nELSE      SH.SALES_SUBCOVERAGE_CODE \r\nEND       , '')) AS sub_sc, \r\n\r\nTRIM(COALESCE(CASE     WHEN SH.ISO_COUNTRY_NAME IN ('NO COUNTRY', '', 'UNKNOWN') THEN 'UNDEFINED COUNTRY'\r\nELSE      SH.ISO_COUNTRY_NAME \r\nEND       , '')) AS country,\r\n\r\nTRIM(COALESCE(CASE     WHEN RBFM.CHANNEL_BOOKINGS_FLG ='Y' THEN 'Channel'\r\n                WHEN   RBFM.CHANNEL_BOOKINGS_FLG ='N' THEN 'Direct'\r\nELSE      'Undefined Route to Market'\r\nEND       , '')) AS chanell_type,\r\n\r\nTRIM(COALESCE(\r\nCASE     WHEN TRIM(PH.PARTNER_SUBTYPE_CODE) IN('', 'UNKNOWN') THEN 'UNDEFINED PARTNER TYPE'\r\nELSE      TRIM(PH.PARTNER_SUBTYPE_CODE) || ' (' || TRIM(PH.PARTNER_TYPE_CODE) || ')'\r\nEND       , '')) as partner_sub_type, \r\n\r\nTRIM(COALESCE(CASE     WHEN PH.CERTIFICATION_CODE IN('', 'UNKNOWN')\r\nTHEN 'UNDEFINED PARTNER CERTIFICATION'\r\nELSE      PH.CERTIFICATION_CODE \r\nEND       , '')) AS part_cert,\r\n\r\nph.CHANNEL_PARTNER_NAME  AS partner_global_name\r\n\r\n,TRIM(ARCH.BK_ARCH_PLAY_HIER_NODE_CD) AS BK_ARCH_PLAY_HIER_NODE_CD\r\n\r\n,COALESCE(CAST((RBFM.DD_COMP_US_NET_PRICE_AMOUNT*ARCH_PLY_HIER_ND_ALOC_FCTR_AMT) AS DECIMAL(26,7)) * COALESCE(TCPA.DOLLAR_ALLOCATION_PCT, 1),0)  book_net \r\n\r\n,COALESCE(CAST((RBFM.DD_COMP_US_LIST_PRICE_AMOUNT*ARCH_PLY_HIER_ND_ALOC_FCTR_AMT) AS DECIMAL(26,7)) * COALESCE(TCPA.DOLLAR_ALLOCATION_PCT, 1),0)   book_list\r\n\r\n,COALESCE(CAST((RBFM.DD_COMP_US_COST_AMOUNT*ARCH_PLY_HIER_ND_ALOC_FCTR_AMT) AS DECIMAL(26,7)) * COALESCE(TCPA.DOLLAR_ALLOCATION_PCT, 1),0)   book_cost\r\n\r\n,COALESCE(CAST((RBFM.DD_EXTENDED_QUANTITY*ARCH_PLY_HIER_ND_ALOC_FCTR_AMT) AS DECIMAL(26,7)) * COALESCE(TCPA.DV_ACTUAL_UNIT_ALOC_PCT, 1),0)  book_qty\r\n\r\n,case when RBFM.BKGS_MEASURE_TRANS_TYPE_CODE IN('POS','AR','SLS_ADJ','POS_ADJ') then  0\r\n     when RBFM.BKGS_MEASURE_TRANS_TYPE_CODE IN('ERP') then 1\r\n     end HIER_TYPE\r\n\r\nFROM $$SLSORDVWDB.R_BOOKINGS_WK_SBASE RBFM\r\n\r\nINNER JOIN $$COMREFVWDB.MT_ALLOC_PRCNT_SBASE  TCPA\r\n        ON (TCPA.ITEM_KEY = RBFM.PRODUCT_KEY\r\n        AND TCPA.HIER_TYPE =0) --Corp\r\n        \r\nINNER JOIN (SELECT PRODUCT_KEY,BK_ARCH_PLAY_HIER_NODE_CD,ARCH_PLY_HIER_ND_ALOC_FCTR_AMT\r\n              FROM $$COMREFVWDB.N_PRD_ARCH_PLY_HIER_ND_ALOC\r\n             WHERE ARCH_PLY_HIER_ND_ALOC_FCTR_AMT > 0) ARCH  \r\n        ON (TCPA.ITEM_KEY = ARCH.PRODUCT_KEY)\r\n        \r\nINNER JOIN $$COMREFVWDB.R_FISCAL_WEEK_TO_YEAR TME                 \r\n        ON ( TME.FISCAL_YEAR_MONTH_INT BETWEEN $$FINSTYR AND $$FINENDYR\r\n       AND RBFM.FISCAL_YEAR_WEEK_NUM_INT = TME.FISCAL_YEAR_WEEK_NUM_INT                 \r\n       AND RBFM.DV_FISCAL_YEAR_MTH_NUMBER_INT = TME.FISCAL_YEAR_MONTH_INT)\r\n       \r\nINNER JOIN $$COMREFVWDB.R_PARTNER_DTL  PH                 \r\n        ON (RBFM.PARTNER_SITE_PARTY_KEY = PH.PARTNER_SITE_PARTY_KEY)\r\n        \r\nINNER JOIN (SELECT CNT.ISO_COUNTRY_NAME, SALES_TERRITORY_KEY, \r\n\t\t   L6_SALES_TERRITORY_NAME_CODE,\r\n                   SALES_SUBCOVERAGE_CODE, \r\n                   CASE WHEN ISO_COUNTRY_CODE IS NULL THEN 'UNK' \r\n                        WHEN ISO_COUNTRY_CODE = 'N' THEN 'UNK' \r\n                        ELSE ISO_COUNTRY_CODE END AS SH_ISO_COUNTRY_CODE\r\n              FROM $$COMREFVWDB.R_SALES_HIERARCHY_TV SH , \r\n                   $$COMREFVWDB.N_ISO_COUNTRY CNT \r\n             WHERE SH.SALES_TERRITORY_TYPE_CODE IN ( 'CORP. REVENUE', 'UNKNOWN')\r\n               AND SH.DV_FISCAL_MONTH_TO_YEAR_KEY   = $$SHFISYR\r\n               AND SH_ISO_COUNTRY_CODE  = CNT.BK_ISO_COUNTRY_CODE) SH \r\n        ON (RBFM.SALES_TERRITORY_KEY = SH.SALES_TERRITORY_KEY )",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
  ],
