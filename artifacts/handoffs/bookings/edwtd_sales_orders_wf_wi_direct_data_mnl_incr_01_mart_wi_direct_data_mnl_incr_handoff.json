      "attributes": {
        "Sql Query": "SELECT \r\nNBM.BOOKINGS_MEASURE_KEY,\r\nNBM.SALES_ORDER_KEY,\r\nNBM.SALES_ORDER_LINE_KEY,\r\nNBM.PRODUCT_KEY,\r\nNBM.AR_TRX_LINE_KEY,\r\nNBM.AR_TRX_KEY,\r\nNBM.SALES_TERRITORY_KEY,\r\nNBM.SALES_REP_NUMBER,\r\nNBM.BOOKINGS_PROCESS_DATE,\r\nNBM.DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\nNBM.BK_POS_TRANSACTION_ID_INT,\r\nNBM.BK_SALES_ADJ_LINE_NUMBER_INT,\r\nNBM.BK_SALES_ADJ_NUMBER_INT,\r\nNBM.BKGS_MEASURE_TRANS_TYPE_CODE,\r\nCOALESCE(NSA.DV_FORWARD_REVERSE_FLG,'='),   \r\nNBM.DISTRIBUTOR_OFFSET_FLG,\r\nNBM.DD_COMP_US_NET_PRICE_AMOUNT,\r\nNBM.DD_COMP_US_LIST_PRICE_AMOUNT,\r\nNBM.DD_COMP_US_COST_AMOUNT,\r\nNBM.DD_EXTENDED_QUANTITY,\r\nNBM.DD_COMP_US_STANDARD_PRICE_AMT,\r\nNBM.EDW_CREATE_DATETIME,\r\nNBM.EDW_UPDATE_DATETIME,\r\nNBM.BOOKINGS_SPLIT_PCT,\r\nNBM.DV_SALES_ORDER_LINE_KEY,\r\nNBM.SO_SBSCRPTN_ITM_SLS_TRX_KEY,\r\nNBM.SERVICE_FLG,\r\nNSA.MANUAL_TRX_KEY,\r\nRANK() OVER(PARTITION BY NSA.MANUAL_TRX_KEY ORDER BY NBM.BOOKINGS_PROCESS_DATE DESC )  RK,\r\nNSA.IDE_IFC_ADJ_REPORTING_TYPE_CD,\r\nNBM.SOURCE_REP_ANNUAL_USD_AMT,\r\nNBM.DV_ANNUALIZED_US_NET_AMT,\r\nNBM.DV_MULTIYEAR_US_NET_AMT,\r\nNBM.SK_SALES_MOTION_ATTRIB_KEY\r\nFROM $$SLSORDVWDB.N_BOOKINGS_MEASURE NBM\r\nINNER JOIN \r\n$$SLSORDVWDB.N_SALES_ADJUSTMENT_LINE   NSA\r\nON NBM.BK_SALES_ADJ_LINE_NUMBER_INT =NSA.BK_SALES_ADJ_LINE_NUMBER_INT\r\nWHERE \r\nNBM.BKGS_MEASURE_TRANS_TYPE_CODE  IN ( 'SLS_ADJ','POS_ADJ')   \r\nAND NSA.IDE_IFC_ADJ_REPORTING_TYPE_CD<>'M'\r\nAND\r\nNBM.EDW_CREATE_DATETIME>'$$LastExtractDate'",
        "User Defined Join": "",
        "Source Filter": "",
