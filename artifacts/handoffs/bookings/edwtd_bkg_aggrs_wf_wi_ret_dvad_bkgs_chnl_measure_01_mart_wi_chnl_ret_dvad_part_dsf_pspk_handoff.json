      ],
      "attributes": {
        "Sql Query": "SELECT \r\n   NBM.BOOKINGS_MEASURE_KEY\r\n  ,NBM.BOOKINGS_PROCESS_DATE\r\n  ,NBM.BKGS_MEASURE_TRANS_TYPE_CODE\r\n  ,EDC.PARTNER_SITE_PARTY_KEY\r\n  ,CASE \r\n    --WHEN NBM.ADJUSTMENT_CODE = 'RB' THEN 'REBATES' \r\n            WHEN RSH.L1_SALES_TERRITORY_NAME_CODE = 'WW Distribution' THEN 'N' \r\n\t\t\tELSE 'Y'\r\n       END CHANNEL_BOOKINGS_FLG_AS\r\n  ,EDC.CHANNEL_DROP_SHIP_FLG,\r\n  /*ADDED AS A PART OF ICPM Q2FY16*/\r\n  CASE WHEN CHANNEL_BOOKINGS_FLG_AS='N' AND SOL.BK_SO_NUMBER_INT            < 0 THEN 'OTHERS'\r\n WHEN CHANNEL_BOOKINGS_FLG_AS='N' AND SOL.BK_SO_NUMBER_INT            > 0  THEN 'DIRECT'\r\n WHEN  CHANNEL_BOOKINGS_FLG_AS='Y'   THEN '1-TIER'\r\n \r\n ELSE 'OTHERS'\r\n END  DV_ROUTE_TO_MARKET_CD,\r\n CASE \r\n    --WHEN NBM.ADJUSTMENT_CODE = 'RB' THEN 'REBATES' \r\n            WHEN RSH.L1_SALES_TERRITORY_NAME_CODE = 'WW Distribution' THEN 'NON CHANNEL' \r\n\t\t\tELSE 'CHANNEL'\r\n       END BOOKING_CHANNEL_TYPE  \r\n FROM \r\n $$SLSORDVWDB.N_BOOKINGS_MEASURE NBM,\r\n $$STGDB.WI_CHNL_RET_DATES CRD,\r\n $$STGDB.WI_CHNL_RET_DVAD_PART_DSF_PSPK EDC,\r\n $$SLSORDVWDB.N_BOOKINGS_CHANNEL_MEASURE  RBCM,\r\n $$SLSORDVWDB.N_SALES_ORDER_TV SOL,\r\n $$COMREFVWDB.R_SALES_HIERARCHY RSH\r\n WHERE \r\n  NBM.BOOKINGS_PROCESS_DATE = CRD.CALENDAR_DATE\r\n  AND   NBM.SOLD_TO_CUSTOMER_KEY = EDC.SOLD_TO_CUSTOMER_KEY\r\n  AND   NBM.DV_END_CUSTOMER_KEY = EDC.DV_END_CUSTOMER_KEY\r\n  AND   NBM.SALES_ORDER_KEY = EDC.SALES_ORDER_KEY\r\n  AND   NBM.SHIP_TO_CUSTOMER_KEY = EDC.SHIP_TO_CUSTOMER_KEY\r\n  AND   NBM.BKGS_MEASURE_TRANS_TYPE_CODE IN ('ERP')\r\n  AND   NBM.SALES_CHANNEL_CODE = 'DVAD' /*DVAD records only*/\r\n  AND NBM.BOOKINGS_MEASURE_KEY = RBCM.BOOKINGS_MEASURE_KEY\r\n  AND NBM.BOOKINGS_PROCESS_DATE = RBCM.BOOKINGS_PROCESS_DATE\r\n  AND NBM.BKGS_MEASURE_TRANS_TYPE_CODE = RBCM.BKGS_MEASURE_TRANS_TYPE_CODE\r\n  AND NBM.SALES_ORDER_KEY = SOL.SALES_ORDER_KEY                            \r\n  AND NBM.SALES_TERRITORY_KEY=RSH.SALES_TERRITORY_KEY",
        "User Defined Join": "",
