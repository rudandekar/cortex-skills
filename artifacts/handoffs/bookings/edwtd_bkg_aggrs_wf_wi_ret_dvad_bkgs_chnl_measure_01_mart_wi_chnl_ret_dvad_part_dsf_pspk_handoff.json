      "attributes": {
        "Sql Query": "SELECT \r\n\tEDC.SOLD_TO_CUSTOMER_KEY\tAS SOLD_TO_CUSTOMER_KEY,\r\n\tEDC.DV_END_CUSTOMER_KEY\t\tAS DV_END_CUSTOMER_KEY,\r\n\tEDC.SALES_ORDER_KEY\t\tAS SALES_ORDER_KEY, \r\n\tEDC.DV_END_CUST_PARTY_KEY \tAS DV_END_CUST_PARTY_KEY, \r\n\tEDC.DEALS_PPSK  \t\tAS DEALS_PPSK,  \r\n\tEDC.DV_END_CUST_COUNTRY_CD   \tAS DV_END_CUST_COUNTRY_CD,\r\n\tEDC.DEALS_CNTRY_CD      \tAS DEALS_CNTRY_CD,        \r\n       \r\n        COALESCE(DSHIP.PARTNER_SITE_PARTY_KEY,-999) AS DEALS_PARTY_SITE_KEY,\r\n\tCASE \r\n\t\tWHEN EDC.DEALS_PPSK = -999 THEN -999 \r\n\t\tELSE \r\n\t\t\tCASE \r\n\t\t\t\tWHEN EDC.DEALS_PPSK = EDC.DV_END_CUST_PARTY_KEY THEN EDC.DEALS_PPSK \r\n\t\t\t\tELSE \r\n\t\t\t\t\tCASE \r\n\t\t\t\t\t\tWHEN EDC.DEALS_CNTRY_CD = EDC.DV_END_CUST_COUNTRY_CD THEN  EDC.DEALS_PPSK \r\n\t\t\t\t\t\tELSE \r\n\t\t\t\t\t\t\tCASE \r\n\t\t\t\t\t\t\t\tWHEN COALESCE(DSHIP.PARTNER_SITE_PARTY_KEY,-999) = -999 THEN EDC.DEALS_PPSK \r\n\t\t\t\t\t\t\t\tELSE COALESCE(DSHIP.PARTNER_SITE_PARTY_KEY,-999)\r\n\t\t\t\t\t\t\tEND\r\n\t\t\t\t\tEND\r\n\t\t\tEND\r\n\tEND \t\t\t\t\t\tAS PARTNER_SITE_PARTY_KEY,\r\n\tCASE WHEN EDC.DEALS_PPSK = -999 THEN 'N' \r\n\t\tELSE CASE WHEN EDC.DEALS_PPSK = DV_END_CUST_PARTY_KEY THEN 'N' \r\n\t\t\tELSE CASE WHEN EDC.DV_END_CUST_COUNTRY_CD = 'UNK' THEN 'N'\r\n\t\t\t\tELSE CASE WHEN EDC.DEALS_CNTRY_CD = EDC.DV_END_CUST_COUNTRY_CD THEN  'N' \r\n\t\t\t\t\tELSE 'Y' \r\n\t\t\t\tEND\r\n\t\t\tEND\r\n\t\tEND\r\n\tEND \tAS CHANNEL_DROP_SHIP_FLAG,\r\n\tEDC.SHIP_TO_CUSTOMER_KEY\tAS SHIP_TO_CUSTOMER_KEY\r\nFROM $$STGDB.WI_CHNL_RET_DVAD_PART_COUNTRY EDC\r\n\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE NCPS\r\nON EDC.DEALS_PPSK = NCPS.PARTNER_SITE_PARTY_KEY\r\n\r\nLEFT OUTER JOIN  \r\n(\r\nSELECT \r\n\tPS.PARTNER_SITE_PARTY_KEY, \r\n\tCOALESCE(PS.BK_PARTY_ID_INT,-999) PARTY_ID,\r\n\tCOALESCE(DD_GRNDPARNT_PARTNER_PARTY_KEY,-999) GRNDPARNT_PARTNER_PARTY_KEY,\r\n\tCOALESCE (BK_ISO_COUNTRY_CODE,'UNK')  ISO_COUNTRY_CODE\r\nFROM \r\n\t$$COMREFVWDB.N_CHANNEL_PARTNER_SITE PS,\r\n\t$$COMREFVWDB.N_CHNL_PTNR_COUNTRY PC\r\nWHERE \t1=1\r\n\tAND PS.PARTNER_COUNTRY_PARTY_KEY = PC.PARTNER_COUNTRY_PARTY_KEY\r\n\tAND PS.SOURCE_DELETED_FLG='N'\r\n\tAND PC.SOURCE_DELETED_FLG='N'\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY \r\n\tGRNDPARNT_PARTNER_PARTY_KEY,\r\n\tISO_COUNTRY_CODE \r\n\tORDER BY PARTY_ID ASC) =1\r\n) DSHIP\r\n\tON \tCOALESCE(NCPS.DD_GRNDPARNT_PARTNER_PARTY_KEY,-999) = DSHIP.GRNDPARNT_PARTNER_PARTY_KEY\r\n\tAND \tEDC.DV_END_CUST_COUNTRY_CD = DSHIP.ISO_COUNTRY_CODE",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
