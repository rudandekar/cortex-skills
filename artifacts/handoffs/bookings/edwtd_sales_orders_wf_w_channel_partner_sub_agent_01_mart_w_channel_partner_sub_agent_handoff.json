      "attributes": {
        "Sql Query": "SELECT \r\n SSAD.BE_GEO_ID AS MASTER_AGENT_BE_GEO_ID_INT\r\n,SSAD.CISCO_SUB_AGENT_ID \r\n,SSAD.SUB_AGENT_ID EXTERNAL_SUB_AGENT_ID\r\n,EBG.BE_GEO_NAME AS DD_MASTER_AGENT_PARTNER_NAME\r\n,SSAD.SUB_AGENT_COMPANY AS SUB_AGENT_COMPANY_NAME\r\n,SSAD.FIRST_NAME AS SUB_AGENT_FIRST_NAME\r\n,SSAD.LAST_NAME  AS SUB_AGENT_LAST_NAME\r\n,SSAD.PHONE AS SUB_AGENT_PHONE_NUMBER\r\n,SSAD.EMAIL AS SUB_AGENT_EMAIL_ADDRESS\r\n,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM\r\n,USER AS EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM\r\n,USER AS EDW_UPDATE_USER\r\n,'I' AS ACTION_CODE\r\n,'I' AS DML_TYPE\r\nFROM \r\n $$STGDB.ST_CREG_SUB_AGENT_DTLS SSAD\r\nLEFT OUTER JOIN $$ETLVWDB.EL_BE_GEO EBG\r\nON SSAD.BE_GEO_ID=EBG.BE_GEO_ID",
