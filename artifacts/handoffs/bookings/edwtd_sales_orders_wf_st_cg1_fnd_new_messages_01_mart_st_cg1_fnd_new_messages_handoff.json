      "attributes": {
        "Sql Query": "SELECT \r\nCG1_FND_NEW_MESSAGES.APPLICATION_ID, \r\nCG1_FND_NEW_MESSAGES.LANGUAGE_CODE, \r\nCG1_FND_NEW_MESSAGES.MESSAGE_NUMBER, \r\nCG1_FND_NEW_MESSAGES.MESSAGE_NAME, \r\nCG1_FND_NEW_MESSAGES.MESSAGE_TEXT, \r\n'CG'  AS GLOBAL_NAME, \r\nCG1_FND_NEW_MESSAGES.CREATION_DATE, \r\nCG1_FND_NEW_MESSAGES.CREATED_BY, \r\nCG1_FND_NEW_MESSAGES.LAST_UPDATE_DATE, \r\nCG1_FND_NEW_MESSAGES.LAST_UPDATED_BY, \r\nCG1_FND_NEW_MESSAGES.LAST_UPDATE_LOGIN, \r\nCG1_FND_NEW_MESSAGES.DESCRIPTION, \r\nCG1_FND_NEW_MESSAGES.TYPE1, \r\nCG1_FND_NEW_MESSAGES.MAX_LENGTH, \r\nCG1_FND_NEW_MESSAGES.CATEGORY, \r\nCG1_FND_NEW_MESSAGES.SEVERITY, \r\nCG1_FND_NEW_MESSAGES.FND_LOG_SEVERITY, \r\nCG1_FND_NEW_MESSAGES.SOURCE_COMMIT_TIME \r\nFROM \r\n$$NRTACCUMVWDB.CG1_FND_NEW_MESSAGES CG1_FND_NEW_MESSAGES\r\nWHERE\r\nCG1_FND_NEW_MESSAGES.SOURCE_COMMIT_TIME >= '$$LastExtractDate' AND CG1_FND_NEW_MESSAGES.SOURCE_COMMIT_TIME < '$$EndLastExtractDate' \r\nAND\r\nCG1_FND_NEW_MESSAGES.SOURCE_DML_TYPE <> 'DELETE'\r\nAND\r\nCG1_FND_NEW_MESSAGES.APPLICATION_ID IN (SELECT APPLICATION_ID FROM $$GGSRCVWDB.GG_CG1_FND_APPLICATION WHERE APPLICATION_SHORT_NAME='XXCCP')\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY CG1_FND_NEW_MESSAGES.APPLICATION_ID ,CG1_FND_NEW_MESSAGES.LANGUAGE_CODE ,\r\nCG1_FND_NEW_MESSAGES.MESSAGE_NAME ORDER BY CG1_FND_NEW_MESSAGES.REFRESH_DATETIME DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "CALL COLLECT_STATS_WRAP('$$NRTACCUMDB','CG1_FND_NEW_MESSAGES','D');",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
