      ],
      "attributes": {
        "Sql Query": "SELECT  \r\nWILLNAMES.BK_DEAL_ID,\r\nWILLNAMES.PRODUCT_ID,\r\nWILLNAMES.LIST_OF_PROMOTION_LINE_LEVEL,\r\nSOURCE_REPORTED_PROMOTION_CD BK_PROMOTION_CD\r\nFROM      \r\n$$STGDB.WI_SO_POS_LL_NAMES  WILLNAMES \r\nINNER JOIN \r\n$$COMREFVWDB.R_PRODUCTS R\r\nON R.BK_PRODUCT_ID=WILLNAMES.PRODUCT_ID\r\nLEFT OUTER JOIN \r\n(\r\n\tselect \r\n\tBK_DEAL_ID,\r\n\tACTIVE_FLG,\r\n\tBK_QUOTE_NUM \r\n\tfrom \r\n\t$$SLSORDVWDB.N_DEAL_QUOTE \r\n\twhere \r\n\tACTIVE_FLG = 'Y'\r\n\tAND (IS_STRINGENT_FLG='Y' OR IS_FINALIZED_FLG='Y')\r\n) NDQ\r\nON WILLNAMES.BK_DEAL_ID = NDQ.BK_DEAL_ID\r\nAND NDQ.ACTIVE_FLG = 'Y'\r\nLEFT OUTER JOIN  \r\n(\t\r\n\tselect  \r\n\tBK_DEAL_QUOTE_LINE_KEY,\r\n\tBK_QUOTE_NUM, \r\n\tPRODUCT_KEY,\r\n\tACTIVE_FLG \r\n\tfrom \r\n\t$$SLSORDVWDB.N_DEAL_QUOTE_LINE \r\n\twhere ACTIVE_FLG = 'Y' \r\n)  NDQL\r\nON NDQ.BK_QUOTE_NUM   =NDQL.BK_QUOTE_NUM      \r\nAND R.ITEM_KEY =NDQL.PRODUCT_KEY\r\nAND NDQL.ACTIVE_FLG = 'Y'     \r\nLEFT OUTER JOIN \r\n(\r\n\tselect \r\n\tBK_DEAL_QUOTE_LINE_KEY, \r\n\tCASE   \r\n\t\tWHEN \r\n\t\tQLC.SOURCE_REPORTED_PROMOTION_NAME = 'UNKNOWN' \r\n\t\tTHEN \r\n\t\tQLC.DISCOUNT_NAME \r\n\t\tWHEN \r\n\t\tQLC.SOURCE_REPORTED_PROMOTION_NAME IS NULL \r\n\t\tTHEN \r\n\t\tQLC.DISCOUNT_NAME \r\n\t\tELSE \r\n\t\tQLC.SOURCE_REPORTED_PROMOTION_NAME \r\n\tEND AS DISCOUNT_NAME ,\r\n\tSOURCE_REPORTED_PROMOTION_CD  \r\n\tfrom \r\n\t$$SLSORDVWDB.N_DEAL_QUOTE_LINE_CONCESSION QLC  \r\n)NDQLC\r\nON NDQLC.BK_DEAL_QUOTE_LINE_KEY=NDQL.BK_DEAL_QUOTE_LINE_KEY\r\nWHERE  \r\n1 = 1 \r\nAND WILLNAMES.LIST_OF_PROMOTION_LINE_LEVEL = NDQLC.DISCOUNT_NAME \r\nGROUP BY \r\n1,2,3,4",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
