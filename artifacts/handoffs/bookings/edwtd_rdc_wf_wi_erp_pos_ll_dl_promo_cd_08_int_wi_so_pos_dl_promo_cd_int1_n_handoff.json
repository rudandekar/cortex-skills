          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "WITH RECURSIVE REC_VIEW (BK_DEAL_ID,  ROLL_UP, BK_PROMOTION_CD) \r\nAS\r\n(\r\nSELECT BK_DEAL_ID\r\n          , MIN(BK_PROMOTION_CD) (VARCHAR(1000))\r\n     , MIN(BK_PROMOTION_CD)\r\nFROM  $$STGDB.WI_SO_POS_DL_PROMO_CD_INT1\r\nGROUP BY 1\r\nUNION ALL\r\nSELECT B.BK_DEAL_ID\r\n          , B.ROLL_UP || ',' || A.BK_PROMOTION_CD\r\n     , A.BK_PROMOTION_CD\r\nFROM   $$STGDB.WI_SO_POS_DL_PROMO_CD_INT1 A \r\nINNER JOIN REC_VIEW B\r\nON    A.BK_DEAL_ID = B.BK_DEAL_ID\r\n  AND A.BK_PROMOTION_CD > B.BK_PROMOTION_CD\r\n)\r\n\r\nSELECT BK_DEAL_ID,  ROLL_UP AS BK_PROMOTION_CD\r\nFROM REC_VIEW\r\n\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY BK_DEAL_ID\r\n                           ORDER BY CHARACTER_LENGTH(ROLL_UP) DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
