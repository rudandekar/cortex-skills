      ],
      "attributes": {
        "Sql Query": "WITH RECURSIVE REC_VIEW (BK_DEAL_ID, PRODUCT_ID, ROLL_UP, BK_PROMOTION_CD) \r\nAS\r\n(\r\n\tSELECT \r\n\tBK_DEAL_ID\r\n     , PRODUCT_ID\r\n     , MIN(BK_PROMOTION_CD) (VARCHAR(1000))\r\n     , MIN(BK_PROMOTION_CD)\r\n\tFROM  $$STGDB.WI_SO_POS_LL_PROMO_CD_INT1\r\n\tGROUP BY \r\n\t1,2\r\n\tUNION ALL\r\n\tSELECT \r\n\tB.BK_DEAL_ID\r\n     , B.PRODUCT_ID\r\n     , B.ROLL_UP || ',' || A.BK_PROMOTION_CD\r\n     , A.BK_PROMOTION_CD\r\n\tFROM   $$STGDB.WI_SO_POS_LL_PROMO_CD_INT1 A \r\n\tINNER JOIN \r\n\tREC_VIEW B\r\n\tON    A.BK_DEAL_ID = B.BK_DEAL_ID\r\n\tAND A.PRODUCT_ID = B.PRODUCT_ID\r\n\tAND A.BK_PROMOTION_CD > B.BK_PROMOTION_CD\r\n)\r\nSELECT \r\nBK_DEAL_ID, \r\nPRODUCT_ID, \r\nROLL_UP AS BK_PROMOTION_CD\r\nFROM \r\nREC_VIEW\r\n\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY BK_DEAL_ID, PRODUCT_ID ORDER BY CHARACTER_LENGTH(ROLL_UP) DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
