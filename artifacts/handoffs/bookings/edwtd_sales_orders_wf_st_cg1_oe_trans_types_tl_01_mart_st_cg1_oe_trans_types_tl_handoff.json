      "attributes": {
        "Sql Query": "SELECT \r\nCG1_OE_TRANS_TYPES_TL.TRANSACTION_TYPE_ID,\r\nCG1_OE_TRANS_TYPES_TL.LANGUAGE_1,\r\nCG1_OE_TRANS_TYPES_TL.NAME,\r\nCG1_OE_TRANS_TYPES_TL.CREATION_DATE,\r\nCG1_OE_TRANS_TYPES_TL.DESCRIPTION,\r\nCG1_OE_TRANS_TYPES_TL.LAST_UPDATED_BY,\r\nCG1_OE_TRANS_TYPES_TL.LAST_UPDATE_DATE,\r\nCG1_OE_TRANS_TYPES_TL.LAST_UPDATE_LOGIN,\r\nCG1_OE_TRANS_TYPES_TL.PROGRAM_APPLICATION_ID,\r\nCG1_OE_TRANS_TYPES_TL.PROGRAM_ID,\r\nCG1_OE_TRANS_TYPES_TL.REQUEST_ID,\r\nCG1_OE_TRANS_TYPES_TL.SOURCE_LANG,\r\nCG1_OE_TRANS_TYPES_TL.CREATED_BY,\r\nCG1_OE_TRANS_TYPES_TL.SOURCE_COMMIT_TIME,\r\n'CG' GLOBAL_NAME\r\nFROM\r\n$$NRTACCUMVWDB.CG1_OE_TRANS_TYPES_TL CG1_OE_TRANS_TYPES_TL \r\nWHERE \r\nCG1_OE_TRANS_TYPES_TL.SOURCE_COMMIT_TIME >= '$$LastExtractDate'\r\nAND\r\nCG1_OE_TRANS_TYPES_TL.SOURCE_COMMIT_TIME <'$$EndLastExtractDate'\r\nAND\r\nCG1_OE_TRANS_TYPES_TL.SOURCE_DML_TYPE <> 'DELETE'\r\nAND\r\nCG1_OE_TRANS_TYPES_TL.LANGUAGE_1 = 'US'\r\nAND\r\nCG1_OE_TRANS_TYPES_TL.SOURCE_LANG = 'US'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY CG1_OE_TRANS_TYPES_TL.TRANSACTION_TYPE_ID ORDER BY CG1_OE_TRANS_TYPES_TL.REFRESH_DATETIME DESC) = 1",
