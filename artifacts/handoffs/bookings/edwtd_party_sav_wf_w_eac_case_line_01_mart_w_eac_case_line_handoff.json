      "attributes": {
        "Sql Query": "SELECT \r\nST_XXFSAM_EAC_CASE_DETAILS_V.CASE_DTL_ID,\r\nCOALESCE(NCWP_CRTD.CISCO_WORKER_PARTY_KEY,-999) AS LST_UPTD_BY_CSCO_WRKR_PRTY_KEY,  \r\nCOALESCE(RL.BK_EAC_RULE_ID,-999) AS BK_EAC_RULE_ID, \r\nCOALESCE(GRP.BK_EAC_GROUP_ID,-999) AS BK_EAC_GROUP_ID, \r\nST_XXFSAM_EAC_CASE_DETAILS_V.CASE_ID, \r\nCOALESCE(ST_XXFSAM_EAC_CASE_DETAILS_V.ATTRIBUTE_TYPE,'UNKNOWN'), \r\nCOALESCE(ST_XXFSAM_EAC_CASE_DETAILS_V.ATTRIBUTE_VALUE,-999), \r\nCOALESCE(ST_XXFSAM_EAC_CASE_DETAILS_V.LAST_UPDATE_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))), \r\nCOALESCE(ST_XXFSAM_EAC_CASE_DETAILS_V.LAST_UPDATE_DATE,CAST('3500-01-01 00:00:00' AS DATE)), \r\nCOALESCE(ST_XXFSAM_EAC_CASE_DETAILS_V.CREATION_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))), \r\nCOALESCE(ST_XXFSAM_EAC_CASE_DETAILS_V.CREATION_DATE,CAST('3500-01-01 00:00:00' AS DATE)), \r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\n'I' ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM\r\n$$STGDB.ST_XXFSAM_EAC_CASE_DETAILS_V ST_XXFSAM_EAC_CASE_DETAILS_V\r\nINNER JOIN  $$SLSORDVWDB.N_EAC_CASE CASE1\r\nON CASE1.BK_EAC_CASE_ID = ST_XXFSAM_EAC_CASE_DETAILS_V.CASE_ID\r\nLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP_CRTD\r\nON COALESCE(ST_XXFSAM_EAC_CASE_DETAILS_V.LAST_UPDATED_BY,'UNKNOWN')= NCWP_CRTD.CEC_ID AND NCWP_CRTD.CISCO_WORKER_PARTY_KEY<>-999\r\nLEFT JOIN $$SLSORDVWDB.N_EAC_RULE RL\r\nON COALESCE(ST_XXFSAM_EAC_CASE_DETAILS_V.EAC_RULE_ID,-999)= RL.BK_EAC_RULE_ID AND RL.BK_EAC_RULE_ID<>-999\r\nLEFT JOIN $$SLSORDVWDB.N_EAC_GROUP GRP\r\nON COALESCE(ST_XXFSAM_EAC_CASE_DETAILS_V.EAC_GROUP_ID,-999)= GRP.BK_EAC_GROUP_ID AND GRP.BK_EAC_GROUP_ID<>-999",
