        "Sql Query": "SELECT \r\nCOSS.SET_ID,\r\nCOSS.SET_NAME,\r\nCOSS.SET_TYPE,\r\nCOSS.HEADER_ID,\r\nCOSS.SHIP_FROM_ORG_ID,\r\nCOSS.SHIP_TO_ORG_ID,\r\nCOSS.SCHEDULE_SHIP_DATE,\r\nCOSS.SCHEDULE_ARRIVAL_DATE,\r\nCOSS.FREIGHT_CARRIER_CODE,\r\nCOSS.SHIPPING_METHOD_CODE,\r\nCOSS.SHIPMENT_PRIORITY_CODE,\r\nCOSS.SET_STATUS,\r\nCOSS.CREATED_BY,\r\nCOSS.CREATION_DATE,\r\nCOSS.UPDATED_BY,\r\nCOSS.UPDATE_DATE,\r\nCOSS.UPDATE_LOGIN,\r\nCOSS.INVENTORY_ITEM_ID,\r\nCOSS.ORDERED_QUANTITY_UOM,\r\nCOSS.LINE_TYPE_ID,\r\nCOSS.SHIP_TOLERANCE_ABOVE,\r\nCOSS.SHIP_TOLERANCE_BELOW,\r\nCOSS.SOURCE_COMMIT_TIME,\r\n'CG' GLOBAL_NAME \r\nFROM \r\n$$NRTACCUMVWDB.CG1_OE_SETS COSS\r\nWHERE\r\nCOSS.SOURCE_COMMIT_TIME >= '$$LastExtractDate' AND COSS.SOURCE_COMMIT_TIME < '$$EndLastExtractDate' \r\nAND\r\nCOSS.SOURCE_DML_TYPE <> 'DELETE'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY COSS.SET_ID ORDER BY COSS.REFRESH_DATETIME DESC) = 1",
