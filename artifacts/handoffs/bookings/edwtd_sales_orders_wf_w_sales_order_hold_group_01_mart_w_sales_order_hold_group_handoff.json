      "attributes": {
        "Sql Query": "SELECT \r\nCOALESCE(HOLD_DEF.BK_SOL_HOLD_GROUP_CODE,'ATT6') AS BK_SOL_HOLD_GROUP_CODE,\r\nHOLD_DEF.START_TV_DATE,\r\nHOLD_DEF.END_TV_DATE,\r\nHOLD_DEF.EDW_CREATE_USER,\r\nHOLD_DEF.EDW_CREATE_DATETIME,\r\nHOLD_DEF.EDW_UPDATE_USER,\r\nHOLD_DEF.EDW_UPDATE_DATETIME,\r\nHOLD_DEF.ACTION_CODE,\r\nHOLD_DEF.DML_TYPE\r\n FROM\r\n(\r\nSELECT\r\nSUOHD.ATTRIBUTE6                                BK_SOL_HOLD_GROUP_CODE,\r\nSUOHD.CREATE_DATETIME\t\t\t\t\t\t\tSTART_TV_DATE,\r\n'3500-01-01'\t\t\t\t\t\t\t\t\tEND_TV_DATE,\r\nUSER \t\t\t\t\t\t\t\t\t\t\tEDW_CREATE_USER,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)  ) \tEDW_CREATE_DATETIME,\r\nUSER \t\t\t\t\t\t\t\t\t\t\tEDW_UPDATE_USER,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)  )  \tEDW_UPDATE_DATETIME,\r\n'I' as\t\t\t\t\t\t\t\tACTION_CODE,\r\n'=' \t\t\t\t\t\t\t\t\t\t\tDML_TYPE\r\nFROM \r\n$$STGDB.ST_UO_OE_HOLD_DEFINITIONS SUOHD\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY SUOHD.ATTRIBUTE6\r\n\t\tORDER BY SUOHD.CREATE_DATETIME DESC) = 1\r\n\r\nUNION ALL\r\n\r\nSELECT \r\nSBOHD.ATTRIBUTE6\t\t\t\t\t\t\t\tBK_SOL_HOLD_GROUP_CODE,\r\nSBOHD.CREATE_DATETIME\t\t\t\t\t\t\tSTART_TV_DATE,\r\n'3500-01-01'\t\t\t\t\t\t\t\t\tEND_TV_DATE,\r\nUSER \t\t\t\t\t\t\t\t\t\t\tEDW_CREATE_USER,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)  ) \tEDW_CREATE_DATETIME,\r\nUSER \t\t\t\t\t\t\t\t\t\t\tEDW_UPDATE_USER,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)  )  \tEDW_UPDATE_DATETIME,\r\n'I' as\t\t\t\t\t\t\t\tACTION_CODE,\r\n'=' \t\t\t\t\t\t\t\t\t\t\tDML_TYPE\r\nFROM \r\n$$STGDB.ST_BO_OE_HOLD_DEFINITIONS SBOHD\r\nLEFT OUTER JOIN \r\n$$STGDB.ST_UO_OE_HOLD_DEFINITIONS SUOHD\r\nON SBOHD.ATTRIBUTE6 = SUOHD.ATTRIBUTE6\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY SBOHD.ATTRIBUTE6\r\n\t\tORDER BY SBOHD.CREATE_DATETIME DESC) = 1\r\nWHERE SUOHD.ATTRIBUTE6 IS NULL\r\n\r\nUNION ALL\r\n\r\nSELECT \r\nSCOHD.ATTRIBUTE6                                BK_SOL_HOLD_GROUP_CODE,\r\nSCOHD.CREATE_DATETIME\t\t\t\t\t\t\tSTART_TV_DATE,\r\n'3500-01-01'\t\t\t\t\t\t\t\t\tEND_TV_DATE,\r\nUSER \t\t\t\t\t\t\t\t\t\t\tEDW_CREATE_USER,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)  ) \tEDW_CREATE_DATETIME,\r\nUSER \t\t\t\t\t\t\t\t\t\t\tEDW_UPDATE_USER,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)  )  \tEDW_UPDATE_DATETIME,\r\n'I'\t\t\t\t\t\t\t\t\t\t\t\tACTION_CODE,\r\n'=' \t\t\t\t\t\t\t\t\t\t\tDML_TYPE\r\nFROM \r\n$$STGDB.ST_CG1_OE_HOLD_DEFINITIONS SCOHD\r\nLEFT OUTER JOIN \r\n$$STGDB.ST_UO_OE_HOLD_DEFINITIONS SUOHD\r\nON SCOHD.ATTRIBUTE6 = SUOHD.ATTRIBUTE6\r\nLEFT OUTER JOIN \r\n$$STGDB.ST_BO_OE_HOLD_DEFINITIONS SBOHD\r\nON SCOHD.ATTRIBUTE6 = SBOHD.ATTRIBUTE6\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY SCOHD.ATTRIBUTE6\r\n\t\tORDER BY SCOHD.CREATE_DATETIME DESC) = 1\r\nWHERE SBOHD.ATTRIBUTE6 IS NULL  AND SUOHD.ATTRIBUTE6 IS NULL\r\n\r\n) HOLD_DEF\r\nWHERE NOT EXISTS\r\n( SELECT 1 FROM $$SLSORDDB.N_SALES_ORDER_HOLD_GROUP_TV NSOHGT WHERE\r\nHOLD_DEF.BK_SOL_HOLD_GROUP_CODE  = NSOHGT.BK_SOL_HOLD_GROUP_CODE \r\n)",
