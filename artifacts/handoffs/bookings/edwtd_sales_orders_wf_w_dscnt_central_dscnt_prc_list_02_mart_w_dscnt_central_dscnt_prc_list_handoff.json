      "attributes": {
        "Sql Query": "SELECT\r\nWCSDV.DISC_HEADER_ID  AS BK_DSCNT_CENTRAL_DSCNT_ID_INT ,\r\nWCSDV.VERSION_NUMBER AS BK_DSC_CNTRL_DSC_VRSN_NUM_INT,\r\nNPL.BK_PRICE_LIST_NAME AS BK_PRICE_LIST_NAME,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\n'I' AS ACTION_CODE,\r\n'=' AS DML_TYPE\r\nFROM\r\n$$STGDB.WI_CPD_STD_DISC_VW WCSDV\r\nINNER JOIN \r\n$$COMREFVWDB.N_PRICE_LIST_TV NPL\r\nON\r\nWCSDV.ERP_PRICELIST_ID=NPL.SK_PRICE_LIST_ID_INT\r\nWHERE NPL.END_TV_DATE='3500-01-01'",
