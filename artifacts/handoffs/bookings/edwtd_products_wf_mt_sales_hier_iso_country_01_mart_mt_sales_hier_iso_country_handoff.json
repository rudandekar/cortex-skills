      "attributes": {
        "Sql Query": "SELECT SH.SALES_TERRITORY_KEY, \r\n       SH.L6_SALES_TERRITORY_NAME_CODE,\r\n       SH.SALES_SUBCOVERAGE_CODE, \r\n       CASE WHEN  SH.ISO_COUNTRY_CODE IS NULL THEN 'UNK' \r\n            WHEN SH.ISO_COUNTRY_CODE = 'N' THEN 'UNK' ELSE SH.ISO_COUNTRY_CODE END AS ISO_COUNTRY_CODE,\r\n       CASE WHEN CNT.ISO_COUNTRY_NAME IS NULL THEN 'UNDEFINED COUNTRY' ELSE CNT.ISO_COUNTRY_NAME END\r\n  FROM $$COMREFVWDB.R_SALES_HIERARCHY_TV SH\r\n  INNER JOIN \r\n       $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR TME\r\n   ON TME.FISCAL_MONTH_END_DATE BETWEEN SH.START_TV_DATE AND SH.END_TV_DATE \r\nLEFT OUTER JOIN \r\n        COMREFDB_DV8.N_ISO_COUNTRY CNT\r\n   ON SH.ISO_COUNTRY_CODE           = CNT.BK_ISO_COUNTRY_CODE        \r\n WHERE SH.SALES_TERRITORY_TYPE_CODE IN ( 'CORP. REVENUE', 'UNKNOWN')\r\n   AND TME.FISCAL_YEAR_MONTH_INT         = $$SHFISYR",
