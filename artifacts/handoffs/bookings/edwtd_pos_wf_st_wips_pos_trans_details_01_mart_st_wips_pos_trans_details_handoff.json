      "attributes": {
        "Sql Query": "SELECT GG_POS_DETAILS.DETAIL_TYPE, \r\nGG_POS_DETAILS.DETAIL_VALUE, \r\nGG_POS_DETAILS.POS_TRANS_ID,\r\n GG_POS_DETAILS.DETAIL_ID, \r\n GG_POS_DETAILS.ACTIVE_FLAG,\r\n GG_POS_DETAILS.SERIAL_NUMBER_STATUS,\r\n GG_POS_DETAILS.SERIAL_NUMBER_REASON_CODE,\r\n GG_POS_DETAILS.CREATED_BY, \r\n GG_POS_DETAILS.CREATED_DATE, \r\n GG_POS_DETAILS.UPDATED_BY,\r\n GG_POS.LAST_UPDATE_DATE ,\r\n GG_POS_DETAILS.SOURCE_DML_TYPE ,\r\n GG_POS_DETAILS.SOURCE_COMMIT_TIME ,\r\n GG_POS_DETAILS.REFRESH_DATETIME ,\r\n CURRENT_TIMESTAMP(0) CREATE_DATETIME\r\nFROM \r\n( SELECT * FROM $$NRTACCUMVWDB.GG_WIPS_POS_TRANS_DETAILS\r\n  WHERE SOURCE_COMMIT_TIME >= CAST('$$LastExtractDate' AS TIMESTAMP(0))\r\n   AND SOURCE_DML_TYPE <> 'DELETE' \r\n  QUALIFY ROW_NUMBER() OVER (PARTITION BY POS_TRANS_ID,DETAIL_ID,BATCH_ID ORDER BY REFRESH_DATETIME DESC)=1) GG_POS_DETAILS \r\n INNER JOIN\r\n( SELECT POS_TRANS_ID, BATCH_ID,STATUS,LAST_UPDATE_DATE,SOURCE_COMMIT_TIME \r\nFROM $$NRTACCUMVWDB.GG_WIPS_POS_TRANS_EDW_INTF\r\n  WHERE SOURCE_COMMIT_TIME >= CAST('$$LastExtractDate' AS TIMESTAMP(0))\r\n   AND SOURCE_DML_TYPE <> 'DELETE' \r\n  QUALIFY ROW_NUMBER() OVER (PARTITION BY POS_TRANS_ID,BATCH_ID ORDER BY REFRESH_DATETIME DESC)=1) GG_POS\r\nON GG_POS.POS_TRANS_ID = GG_POS_DETAILS.POS_TRANS_ID\r\n AND GG_POS.BATCH_ID = GG_POS_DETAILS.BATCH_ID\r\n WHERE  GG_POS.STATUS = 'POSTED'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
