      "attributes": {
        "Sql Query": "SELECT \r\nTVOUTPUT.BATCH_ID  AS BATCH_ID,\r\nTVOUTPUT.BK_SO_SOURCE_NAME AS NAME,\r\nTVOUTPUT.START_TV_DATE,\r\nCOALESCE( MAX(TVOUTPUT.START_TV_DATE - INTERVAL '1' DAY) \r\nOVER (PARTITION BY TVOUTPUT.BK_SO_SOURCE_NAME ORDER BY TVOUTPUT.START_TV_DATE ASC \r\nROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING), DATE '3500-01-01') AS END_TV_DATE,\r\nTVOUTPUT.SO_SOURCE_DESCRIPTION AS DESCRIPTION,\r\nCOALESCE(TVOUTPUT.SO_SOURCE_ENABLED_FLAG,'=') AS ENABLED_FLAG,\r\nTVOUTPUT.ACTION_CODE AS ACTION_CODE ,\r\nROW_NUMBER() OVER (PARTITION BY TVOUTPUT.BK_SO_SOURCE_NAME ORDER BY TVOUTPUT.START_TV_DATE ASC) AS RANK_INDEX,\r\n(CASE WHEN RANK_INDEX = 1 AND TT.BK_SO_SOURCE_NAME IS NOT NULL THEN 'U' ELSE 'I' END) AS DML_TYPE\r\nFROM (\t\t\t\r\n\tSELECT\r\n\tBATCH_ID,\r\n\tBK_SO_SOURCE_NAME, \r\n\tSO_SOURCE_DESCRIPTION,\r\n\tSO_SOURCE_ENABLED_FLAG,\r\n\tSTART_TV_DATE,\r\n\tCREATE_DATETIME,\r\n\tACTION_CODE,\r\n\tEXCEPTION_TYPE,\r\n\tROW_NUMBER() OVER (PARTITION BY \r\n\t\tBK_SO_SOURCE_NAME,\r\n\t\tSO_SOURCE_DESCRIPTION,\r\n\t\tSO_SOURCE_ENABLED_FLAG\r\n\tORDER BY CREATE_DATETIME DESC) AS ROW_NUM  \r\n\tFROM \t\r\n\t\t(\r\n\t\tSELECT  \r\n\t\tSUOOS.BATCH_ID,\r\n\t\tSUOOS.NAME  BK_SO_SOURCE_NAME, \r\n\t\tSUOOS.DESCRIPTION SO_SOURCE_DESCRIPTION,\r\n\t\tSUOOS.ENABLED_FLAG SO_SOURCE_ENABLED_FLAG,\r\n\t\tCAST (SUOOS.CREATE_DATETIME AS DATE) START_TV_DATE,\r\n\t\tSUOOS.CREATE_DATETIME,\r\n\t\tSUOOS.ACTION_CODE,\r\n\t\t'NE' EXCEPTION_TYPE\r\n\t\tFROM  $$STGDB.ST_UO_OE_ORDER_SOURCES SUOOS\r\n\t\tQUALIFY ROW_NUMBER() OVER (PARTITION BY SUOOS.NAME\r\n\t\tORDER BY SUOOS.CREATE_DATETIME DESC) = 1 \r\n   \t\tUNION ALL\r\n\t\tSELECT  \r\n\t\tSBOOS.BATCH_ID,\r\n\t\tSBOOS.NAME  BK_SO_SOURCE_NAME, \r\n\t\tSBOOS.DESCRIPTION SO_SOURCE_DESCRIPTION,\r\n\t\tSBOOS.ENABLED_FLAG SO_SOURCE_ENABLED_FLAG,\r\n\t\tCAST (SBOOS.CREATE_DATETIME AS DATE) START_TV_DATE,\r\n\t\tSBOOS.CREATE_DATETIME,\r\n\t\tSBOOS.ACTION_CODE,\r\n\t\t'NE' EXCEPTION_TYPE\r\n\t\tFROM  $$STGDB.ST_BO_OE_ORDER_SOURCES SBOOS\r\n\t\tLEFT OUTER JOIN \r\n\t        $$STGDB.ST_UO_OE_ORDER_SOURCES SUOOS\r\n              \tON SBOOS.NAME = SUOOS.NAME \r\n\t\tLEFT OUTER JOIN \r\n\t\t$$ETLVWDB.EL_SALES_ORDER_SOURCES ESOS\r\n\t\tON (SBOOS.NAME=ESOS.NAME AND ESOS.GLOBAL_NAME ='UO')\r\n\t\tQUALIFY ROW_NUMBER() OVER (PARTITION BY SBOOS.NAME\r\n\t\tORDER BY SBOOS.CREATE_DATETIME DESC) = 1 \r\n        WHERE SUOOS.NAME IS NULL AND ESOS.NAME IS NULL\r\n        UNION ALL\r\n\t\tSELECT  \r\n\t\t1 AS BATCH_ID,\r\n\t\tSCOOS.NAME  BK_SO_SOURCE_NAME, \r\n\t\tSCOOS.DESCRIPTION SO_SOURCE_DESCRIPTION,\r\n\t\tSCOOS.ENABLED_FLAG SO_SOURCE_ENABLED_FLAG,\r\n\t\tCAST (SCOOS.SOURCE_COMMIT_TIME AS DATE) START_TV_DATE,\r\n\t\tSCOOS.SOURCE_COMMIT_TIME,\r\n\t\t'I' AS ACTION_CODE,\r\n\t\t'NE' EXCEPTION_TYPE\r\n\t\tFROM  $$STGDB.ST_CG1_OE_ORDER_SOURCES SCOOS\r\n\t\tLEFT OUTER JOIN \r\n\t    $$STGDB.ST_UO_OE_ORDER_SOURCES SUOOS\r\n        ON SCOOS.NAME = SUOOS.NAME \r\n\t\tLEFT OUTER JOIN \r\n\t    $$STGDB.ST_BO_OE_ORDER_SOURCES SBOOS\r\n        ON SCOOS.NAME = SBOOS.NAME \r\n\t\tLEFT OUTER JOIN \r\n\t\t$$ETLVWDB.EL_SALES_ORDER_SOURCES ESOS\r\n\t\tON (SCOOS.NAME=ESOS.NAME AND ESOS.GLOBAL_NAME IN ('UO','BO'))\r\n\t\tQUALIFY ROW_NUMBER() OVER (PARTITION BY SCOOS.NAME\r\n\t\tORDER BY SCOOS.SOURCE_COMMIT_TIME DESC) = 1 \r\n        WHERE SUOOS.NAME IS NULL AND SBOOS.NAME IS NULL AND ESOS.NAME IS NULL\r\n\t\tUNION ALL\r\n\t\tSELECT \r\n\t\t-999 BATCH_ID,\r\n\t\tNSARC.BK_SO_SOURCE_NAME, \r\n\t\tNSARC.SO_SOURCE_DESCRIPTION,\r\n\t\tNSARC.SO_SOURCE_ENABLED_FLAG,\r\n\t\tNSARC.START_TV_DATE,\r\n\t\tNSARC.EDW_CREATE_DATETIME CREATE_DATETIME,\r\n\t\t'X'  ACTION_CODE,\r\n\t\t'NE' EXCEPTION_TYPE\r\n\t\tFROM  $$SLSORDVWDB.N_SALES_ORDER_SRCE_TYPE_TV NSARC\r\n\t\tWHERE END_TV_DATE = CAST ('3500-01-01' AS DATE)\r\n\t\tAND BK_SO_SOURCE_NAME IN\r\n\t\t\t(\r\n\t\t\tSELECT  DISTINCT SUOOS.NAME\r\n\t\t\t\tFROM      $$STGDB.ST_UO_OE_ORDER_SOURCES SUOOS\r\n                     UNION ALL\r\n\t\tSELECT  DISTINCT SBOOS.NAME\r\n\t\t\t\tFROM      $$STGDB.ST_BO_OE_ORDER_SOURCES SBOOS\r\n              \tLEFT OUTER JOIN \r\n\t             $$STGDB.ST_UO_OE_ORDER_SOURCES SUOOS\r\n                  ON SBOOS.NAME = SUOOS.NAME \r\n        WHERE SUOOS.NAME IS NULL\r\n\t\tUNION ALL\r\n\t\tSELECT  DISTINCT SCOOS.NAME\r\n\t\t\t\tFROM      $$STGDB.ST_CG1_OE_ORDER_SOURCES SCOOS\r\n              \tLEFT OUTER JOIN \r\n\t             $$STGDB.ST_UO_OE_ORDER_SOURCES SUOOS\r\n                  ON SCOOS.NAME = SUOOS.NAME \r\n\t\t\t\tLEFT OUTER JOIN \r\n\t             $$STGDB.ST_BO_OE_ORDER_SOURCES SBOOS\r\n                  ON SCOOS.NAME = SBOOS.NAME  \r\n        WHERE SUOOS.NAME IS NULL AND SBOOS.NAME IS NULL\r\n           )\r\n\t\t) TVINPUT\r\n\t\tQUALIFY ROW_NUMBER() OVER (PARTITION BY TVINPUT.BK_SO_SOURCE_NAME, TVINPUT.START_TV_DATE \r\n\t\tORDER BY TVINPUT.CREATE_DATETIME DESC) = 1\r\n\t) TVOUTPUT\r\nLEFT JOIN\r\n$$SLSORDVWDB.N_SALES_ORDER_SRCE_TYPE_TV TT\r\n\t\tON TVOUTPUT.BK_SO_SOURCE_NAME = TT.BK_SO_SOURCE_NAME\r\n\t\tAND TT.END_TV_DATE = CAST('3500-01-01' AS DATE)\r\nWHERE\tTVOUTPUT.ROW_NUM = 1",
        "User Defined Join": "",
