      "attributes": {
        "Sql Query": "SELECT\r\n\tSATQM.BK_AS_QUOTE_NUM AS BK_AS_QUOTE_NUM,\r\n\tSATQM.BK_AS_QUOTE_MILESTONE_NUM_INT  AS BK_AS_QUOTE_MILESTONE_NUM_INT,\r\n\tSATQM.AS_QUOTE_MILESTONE_NAME AS AS_QUOTE_MILESTONE_NAME,\r\n\tSATQM.AS_QT_MILESTONE_TE_MRGN_FLG as AS_QT_MILESTONE_TE_MRGN_FLG,\r\n\tSATQM.AS_QT_MILESTONE_ACTIVE_STS_CD AS AS_QT_MILESTONE_ACTIVE_STS_CD,\r\n\tCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\n\tUSER EDW_CREATE_USER,\r\n\tCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n\tUSER EDW_UPDATE_USER,\r\n\tSATQM.REV_PLANNING_DURATION_DAYS_CNT,\r\n\tSATQM. AS_MILESTONE_START_DT,\r\n\tSATQM.MASTER_MILESTONE_FLG,\t\r\n    SATQM.SS_CD, \r\n\t'I' AS ACTION_CODE,\r\n\tCASE WHEN NAQM.BK_AS_QUOTE_NUM IS NULL THEN 'I' ELSE 'U' END AS DML_TYPE\r\n\t\r\n\r\nFROM $$STGDB.ST_AS_QUOTE_MILESTONE_HDP\tSATQM\r\nLEFT OUTER JOIN $$SERVICEVWDB.N_AS_QUOTE_MILESTONE NAQM\r\n\tON (NAQM.BK_AS_QUOTE_NUM = SATQM.BK_AS_QUOTE_NUM\r\n\tAND NAQM.BK_AS_QUOTE_MILESTONE_NUM_INT = SATQM.BK_AS_QUOTE_MILESTONE_NUM_INT\r\n    AND NAQM.BK_SS_CD = SATQM.SS_CD)",
