      "attributes": {
        "Sql Query": "SELECT \r\n   NSOL.SALES_ORDER_KEY,\r\n   NSOL.SALES_ORDER_LINE_KEY,\r\n   STL.ATTRIBUTE1, \r\n   STL.ATTRIBUTE2, \r\n   STL.ATTRIBUTE4,\r\n   STL.ATTRIBUTE5,\r\n   CURRENT_TIMESTAMP(0),\r\n   USER,\r\n   CURRENT_TIMESTAMP(0),\r\n   USER,\r\n   'I',\r\n   CASE WHEN NSOLUN.SALES_ORDER_KEY IS NOT NULL AND NSOLUN.SALES_ORDER_LINE_KEY IS NOT NULL THEN 'U' ELSE 'I'\r\n   END DML_TYPE\r\nfrom $$stgdb.st_OM_XXCCA_OE_ORD_LINES_EX STL\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE_TV NSOL\r\n  ON  NSOL.SK_SO_LINE_ID_INT = STL.LINE_ID \r\n  AND NSOL.SS_CODE = (CASE WHEN STL.GLOBAL_NAME='UO' THEN 'QTC'\r\n  \t\t    \t   WHEN STL.GLOBAL_NAME='BO' THEN 'BV' \r\n  \t\t      END)\r\nLEFT OUTER JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE_AM_UNKNOWN NSOLUN\r\nON (NSOLUN.SALES_ORDER_KEY= NSOL.SALES_ORDER_KEY\r\nAND NSOLUN.SALES_ORDER_LINE_KEY = NSOL.SALES_ORDER_LINE_KEY)",
        "User Defined Join": "",
