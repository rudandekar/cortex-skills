      "attributes": {
        "Sql Query": "SELECT\r\nSMC_FINAL.SALES_ORDER_KEY,\r\nSMC_FINAL.SALES_MOTION_CD,\r\nSMC_FINAL.DV_ALLOCATION_PCT/SMC_FINAL.SUM_SPLIT AS DV_ALLOCATION_PCT,\r\nSMC_FINAL.DV_SERVICE_CATEGORY_CD,\r\nSMC_FINAL.START_TV_DTM , \r\nSMC_FINAL.END_TV_DTM,\r\nSMC_FINAL.SALES_MOTION_TIMING_CD,\r\nSMC_FINAL.DV_SOURCE_TYPE\r\nFROM (SELECT \r\nSMC.SALES_ORDER_KEY,\r\nSMC.SALES_MOTION_CD,\r\nSUM(SMC.DV_ALLOCATION_PCT ) AS DV_ALLOCATION_PCT,\r\nSMC.SUM_SPLIT ,\r\nSMC.DV_SERVICE_CATEGORY_CD,\r\nSMC.START_TV_DTM , \r\nSMC.END_TV_DTM,\r\nSMC.SALES_MOTION_TIMING_CD,\r\nSMC.DV_SOURCE_TYPE DV_SOURCE_TYPE\r\nFROM (\r\nSELECT \r\nSALES_ORDER_KEY,\r\nSALES_MOTION_CD,\r\nDV_ALLOCATION_PCT,\r\nCASE WHEN SUM_SPLIT=0 THEN 1 ELSE SUM_SPLIT END AS SUM_SPLIT,\r\nDV_SERVICE_CATEGORY_CD,\r\nSTART_TV_DTM,\r\nEND_TV_DTM,\r\nSALES_MOTION_TIMING_CD,\r\nCAST('RTNR' AS VARCHAR(10)) AS DV_SOURCE_TYPE\r\nFROM (SELECT\r\nINCR.SALES_ORDER_KEY,\r\nSALES_MOTION_CD,\r\nDV_ALLOCATION_PCT,\r\nSUM(DV_ALLOCATION_PCT) OVER(PARTITION BY INCR.SALES_ORDER_KEY) SUM_SPLIT,\r\n'SOFTWARE' as DV_SERVICE_CATEGORY_CD,  \r\nCURRENT_TIMESTAMP(0) AS START_TV_DTM, /* CHANGED LOGIC AS PART OF MAY 2ND RELEASE */\r\nMAX(END_TV_DTM) OVER(PARTITION BY INCR.SALES_ORDER_KEY) END_TV_DTM,\r\nSALES_MOTION_TIMING_CD\r\nFROM (SELECT B.SALES_ORDER_KEY,A.SALES_MOTION_CD,A.DV_ALLOCATION_PCT,A.START_TV_DTM,A.END_TV_DTM,\r\nCOALESCE(A.SALES_MOTION_TIMING_CD,'UNKNOWN') AS SALES_MOTION_TIMING_CD\r\n,A.DV_SERVICE_CATEGORY_CD,A.SALES_ORDER_LINE_KEY,A.SK_OFFER_ATTRIBUTION_ID_INT,A.BUNDLE_FLG\r\nFROM $$SLSORDVWDB.N_SALES_ORDER_LINE B, $$SLSORDVWDB.MT_SLS_MOTION_ATTRIBUTION A\r\nWHERE A.SALES_ORDER_LINE_KEY=B.SALES_ORDER_LINE_KEY\r\nAND B.SALES_ORDER_KEY IN (SELECT B.SALES_ORDER_KEY\r\nFROM $$SLSORDVWDB.MT_SLS_MOTION_ATTRIBUTION A\r\n,$$SLSORDVWDB.N_SALES_ORDER_LINE B\r\nWHERE A.SALES_ORDER_LINE_KEY=B.SALES_ORDER_LINE_KEY\r\nAND A.END_TV_DTM='3500-01-01 00:00:00'\r\nAND A.EDW_UPDATE_DTM > '$$LASTEXTRACTDATE'\r\nGROUP BY 1\r\n)AND A.END_TV_DTM='3500-01-01 00:00:00') INCR\r\n) SMC1 ) SMC\r\nGROUP BY 1,2,4,5,6,7,8,9 ) SMC_FINAL",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
