      "attributes": {
        "Sql Query": "SELECT\r\nSMC_FINAL.SALES_ORDER_KEY,\r\nSMC_FINAL.SALES_MOTION_CD,\r\nSMC_FINAL.DV_ALLOCATION_PCT/SMC_FINAL.SUM_SPLIT AS DV_ALLOCATION_PCT,\r\nSMC_FINAL.DV_SERVICE_CATEGORY_CD,\r\nSMC_FINAL.START_TV_DTM , \r\nSMC_FINAL.END_TV_DTM,\r\nSMC_FINAL.SALES_MOTION_TIMING_CD ,\r\nSMC_FINAL.DV_SOURCE_TYPE\r\nFROM (SELECT \r\nSMC.SALES_ORDER_KEY,\r\nSMC.SALES_MOTION_CD,\r\nSUM(SMC.DV_ALLOCATION_PCT ) AS DV_ALLOCATION_PCT,\r\nSMC.SUM_SPLIT ,\r\nSMC.DV_SERVICE_CATEGORY_CD,\r\nSMC.START_TV_DTM , \r\nSMC.END_TV_DTM,\r\nSMC.SALES_MOTION_TIMING_CD,\r\nSMC.DV_SOURCE_TYPE \r\nFROM (SELECT \r\nSALES_ORDER_KEY,\r\nSALES_MOTION_CD,\r\nDV_ALLOCATION_PCT,\r\nCASE WHEN SUM_SPLIT=0 THEN 1 ELSE SUM_SPLIT END AS SUM_SPLIT,\r\n'SOFTWARE' as DV_SERVICE_CATEGORY_CD,\r\nSTART_TV_DTM,\r\nEND_TV_DTM,\r\nSALES_MOTION_TIMING_CD,\r\nCAST('RTNR' AS VARCHAR(10)) AS DV_SOURCE_TYPE\r\nFROM (SELECT\r\nNSOL.SALES_ORDER_KEY AS SALES_ORDER_KEY,\r\nMT.SALES_MOTION_CD,\r\nMT.DV_ALLOCATION_PCT,\r\nSUM(DV_ALLOCATION_PCT) OVER(PARTITION BY NSOL.SALES_ORDER_KEY) SUM_SPLIT,\r\nMT.DV_SERVICE_CATEGORY_CD,  \r\nCURRENT_TIMESTAMP(0) AS START_TV_DTM, \r\nMAX(MT.END_TV_DTM) OVER(PARTITION BY NSOL.SALES_ORDER_KEY) END_TV_DTM,\r\nCOALESCE(MT.SALES_MOTION_TIMING_CD,'UNKNOWN') AS SALES_MOTION_TIMING_CD\r\nFROM $$SLSORDVWDB.N_SALES_ORDER_LINE NSOL\r\nINNER JOIN $$SLSORDVWDB.N_XAAS_SO_SBSCR_ITM_SLS_TRX TRX\r\nON TRX.MINOR_LN_EXAAS_SUBSCR_SOL_KEY=NSOL.SALES_ORDER_LINE_KEY\r\nINNER JOIN $$SLSORDVWDB.MT_XAAS_SLS_MOTION_ATTRIB MT \r\nON MT.SO_SBSCRPTN_ITM_SLS_TRX_KEY=TRX.SO_SBSCRPTN_ITM_SLS_TRX_KEY \r\nWHERE MT.END_TV_DTM = '3500-01-01 00:00:00'\r\nAND TRX.MINOR_LN_EXAAS_SUBSCR_SOL_KEY>0\r\nAND MT.DV_SOURCE_TYPE IN ('RTNR')\r\nAND NSOL.SALES_ORDER_KEY IN (SELECT NSOL.SALES_ORDER_KEY FROM $$SLSORDVWDB.N_SALES_ORDER_LINE NSOL\r\nINNER JOIN $$SLSORDVWDB.N_XAAS_SO_SBSCR_ITM_SLS_TRX TRX\r\nON TRX.MINOR_LN_EXAAS_SUBSCR_SOL_KEY=NSOL.SALES_ORDER_LINE_KEY\r\nINNER JOIN $$SLSORDVWDB.MT_XAAS_SLS_MOTION_ATTRIB MT \r\nON MT.SO_SBSCRPTN_ITM_SLS_TRX_KEY=TRX.SO_SBSCRPTN_ITM_SLS_TRX_KEY \r\nWHERE MT.END_TV_DTM = '3500-01-01 00:00:00'\r\nAND TRX.MINOR_LN_EXAAS_SUBSCR_SOL_KEY>0\r\nAND MT.DV_SOURCE_TYPE IN ('RTNR') \r\nAND MT.EDW_UPDATE_DTM > '$$LastExtractDate'\r\nGROUP BY 1)) SMC1) SMC\r\nGROUP BY 1,2,4,5,6,7,8,9) SMC_FINAL",
        "User Defined Join": "",
