        "Sql Query": "SELECT\r\n    SALES_ORDER_KEY    \r\n     ,SALES_MOTION_CD               \r\n     ,DV_ALLOCATION_PCT \r\n\t ,DV_SERVICE_CATEGORY_CD\t\r\n     ,START_TV_DTM\r\n     ,END_TV_DTM\r\n     ,EDW_CREATE_DTM                \r\n     ,EDW_CREATE_USER               \r\n     ,EDW_UPDATE_DTM                \r\n     ,EDW_UPDATE_USER   \r\n     ,SALES_MOTION_TIMING_CD\t \r\n\t ,DV_SOURCE_TYPE \r\n\t ,DV_TRX_TYPE\r\n\t ,SS_CODE\r\n\t ,-9999 AS RENEWAL_GAP_DAYS\r\n\t ,'UNKNOWN' AS RENEWAL_REF_ID\r\n\t ,'UNKNOWN' AS RENEWAL_REF_CD\r\n\t ,'UNKNOWN' AS RENEWAL_REF_RULE\r\nFROM (\r\nSELECT \r\n     WI.SALES_ORDER_KEY       \r\n     ,WI.SALES_MOTION_CD               \r\n     ,WI.DV_ALLOCATION_PCT \r\n\t ,WI.DV_SERVICE_CATEGORY_CD\t\r\n     ,WI.START_TV_DTM\r\n     ,WI.END_TV_DTM\r\n     ,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM                \r\n     ,USER AS EDW_CREATE_USER               \r\n     ,CURRENT_TIMESTAMP(0) EDW_UPDATE_DTM                \r\n     ,USER AS EDW_UPDATE_USER   \r\n     ,WI.SALES_MOTION_TIMING_CD\t \r\n\t ,WI.DV_SOURCE_TYPE \r\n\t ,CAST('XAAS'AS VARCHAR(10)) AS DV_TRX_TYPE\r\n\t ,NSO.SS_CODE\r\n FROM $$STGDB.WI_XAAS_SO_SMC_ALLOCATION WI\r\n INNER JOIN $$SLSORDVWDB.N_SALES_ORDER NSO\r\n ON WI.SALES_ORDER_KEY=NSO.SALES_ORDER_KEY\r\n AND NOT EXISTS(SELECT 1 FROM $$STGDB.WI_ERP_SO_SMC_ALLOCATION W WHERE W.SALES_ORDER_KEY=WI.SALES_ORDER_KEY\r\n )\r\nUNION ALL\r\nSELECT \r\n      WI.SALES_ORDER_KEY     \r\n     ,WI.SALES_MOTION_CD               \r\n     ,WI.DV_ALLOCATION_PCT \r\n\t ,WI.DV_SERVICE_CATEGORY_CD\t\r\n     ,WI.START_TV_DTM\r\n     ,WI.END_TV_DTM\r\n     ,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM                \r\n     ,USER AS EDW_CREATE_USER               \r\n     ,CURRENT_TIMESTAMP(0) EDW_UPDATE_DTM                \r\n     ,USER AS EDW_UPDATE_USER   \r\n     ,WI.SALES_MOTION_TIMING_CD\t \r\n\t ,WI.DV_SOURCE_TYPE \r\n\t ,CAST('ERP' AS VARCHAR(10)) AS DV_TRX_TYPE\r\n\t ,NSO.SS_CODE\r\nFROM $$STGDB.WI_ERP_SO_SMC_ALLOCATION WI \r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER NSO\r\nON WI.SALES_ORDER_KEY=NSO.SALES_ORDER_KEY\r\n)XAAS",
