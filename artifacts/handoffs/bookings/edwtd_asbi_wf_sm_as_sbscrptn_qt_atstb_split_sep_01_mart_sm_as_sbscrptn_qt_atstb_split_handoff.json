      "attributes": {
        "Sql Query": "SELECT\r\n                RANK() OVER ( ORDER BY BK_DELIVERABLE_NAME\r\n                                     , BK_SERVICE_COMPONENT_NAME\r\n                                     , BK_SERVICE_PROGRAM_NAME\r\n                                     , BK_AS_ARCHITECTURE_NAME\r\n                                     , BK_AS_TECHNOLOGY_NAME\r\n                                     , BK_AS_SUBTECHNOLOGY_NAME\r\n                                     , BK_AS_BUSINESS_SERVICE_NAME\r\n                                     , BK_AS_QUOTE_NUM\r\n\t\t\t\t\t\t\t\t\t , BK_SS_CD\r\n\t\t\t\t\t\t\t) + MAX_VAL  ATSTB_SPLIT_KEY ,\r\n                ST.BK_DELIVERABLE_NAME,           \r\n                ST.BK_SERVICE_COMPONENT_NAME,     \r\n                ST.BK_SERVICE_PROGRAM_NAME,       \r\n                ST.BK_AS_QUOTE_NUM,               \r\n                ST.BK_AS_TECHNOLOGY_NAME,         \r\n                ST.BK_AS_BUSINESS_SERVICE_NAME,   \r\n                ST.BK_AS_ARCHITECTURE_NAME,       \r\n                ST.BK_AS_SUBTECHNOLOGY_NAME,\r\n                ST.SS_CD,\t\t\t\t\r\n                CURRENT_TIMESTAMP(0)  AS EDW_CREATE_DTM,\r\n                USER AS EDW_CREATE_USER\r\n                FROM $$STGDB.ST_AS_SBSCRPTN_QT_ATSTB_SPLIT_HDP  ST,\r\n            \r\n                (SELECT COALESCE(MAX(ATSTB_SPLIT_KEY  ),0) MAX_VAL FROM $$TRANSLATIONDB.SM_AS_SBSCRPTN_QT_ATSTB_SPLIT) SM\r\n                WHERE\r\n                NOT EXISTS\r\n                (\r\n                                SELECT 1\r\n                                                FROM $$TRANSLATIONDB.SM_AS_SBSCRPTN_QT_ATSTB_SPLIT SM\r\n                                                WHERE ST.BK_DELIVERABLE_NAME = SM.BK_DELIVERABLE_NAME         \r\n                                                AND ST.BK_SERVICE_COMPONENT_NAME = SM.BK_SERVICE_COMPONENT_NAME     \r\n                                                AND ST.BK_SERVICE_PROGRAM_NAME = SM.BK_SERVICE_PROGRAM_NAME       \r\n                                                AND ST.BK_AS_QUOTE_NUM = SM.BK_AS_QUOTE_NUM              \r\n                                                AND ST.BK_AS_TECHNOLOGY_NAME =  SM.BK_AS_TECHNOLOGY_NAME         \r\n                                                AND ST.BK_AS_BUSINESS_SERVICE_NAME =  SM.BK_AS_BUSINESS_SERVICE_NAME  \r\n                                                AND ST.BK_AS_ARCHITECTURE_NAME =  SM.BK_AS_ARCHITECTURE_NAME     \r\n                                                AND ST.BK_AS_SUBTECHNOLOGY_NAME =  SM.BK_AS_SUBTECHNOLOGY_NAME\r\n\t\t\t\t\t\t\t\t\t\t\t\tAND ST.SS_CD = SM.BK_SS_CD\r\n                )",
