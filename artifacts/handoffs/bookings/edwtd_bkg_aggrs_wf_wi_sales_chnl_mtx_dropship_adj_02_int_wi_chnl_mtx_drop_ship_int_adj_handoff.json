      "attributes": {
        "Sql Query": "SELECT \r\n   WCMDSI.SALES_TERRITORY_KEY \r\n  ,WCMDSI.SOLD_TO_CUSTOMER_KEY \r\n  ,WCMDSI.END_CUSTOMER_KEY\r\n    ,WCMDSI.BILL_TO_CUSTOMER_KEY \r\n  ,WCMDSI.SOLD_TO_PARTY_KEY  \r\n  ,WCMDSI.BILL_TO_PARTY_KEY \r\n  ,WCMDSI.END_CUST_PARTY_KEY \r\n  ,WCMDSI.PARTNER_SITE_PARTY_KEY_INT\r\n  ,WCMDSI.PARTNER   \r\n  ,WCMDSI.SOLD_TO_GRAND_PRNT_PTY_KEY\r\n  ,WCMDSI.BILL_TO_GRAND_PRNT_PTY_KEY\r\n  ,WCMDSI.EDW_CREATE_USER  \r\n  ,WCMDSI.EDW_CREATE_DATETIME \r\n  ,WCMDSI.PRTN_CNTRY_CD  \r\n  ,WCMDSI.END_CUST_CNTRY_CD  \r\n  ,WCMDSI.DROP_SHIP_PARTY_SITE_KEY \r\n  ,CASE WHEN WCMDSI.PARTNER_SITE_PARTY_KEY_INT = -999 THEN -999 \r\n          ELSE \r\n              CASE   WHEN WCMDSI.PARTNER_SITE_PARTY_KEY_INT = WCMDSI.END_CUST_PARTY_KEY   THEN WCMDSI.PARTNER_SITE_PARTY_KEY_INT \r\n       ELSE \r\n                         CASE WHEN WCMDSI.PRTN_CNTRY_CD = WCMDSI.END_CUST_CNTRY_CD  THEN  WCMDSI.PARTNER_SITE_PARTY_KEY_INT \r\n          ELSE \r\n             CASE WHEN WCMDSI.DROP_SHIP_PARTY_SITE_KEY  = -999 THEN WCMDSI.PARTNER_SITE_PARTY_KEY_INT \r\n           ELSE WCMDSI.DROP_SHIP_PARTY_SITE_KEY \r\n                                  END \r\n      END\r\n          END\r\n  END PARTNER_SITE_PARTY_KEY\r\n   ,CASE  WHEN WCMDSI.PARTNER_SITE_PARTY_KEY_INT = -999 THEN 'N' \r\n             ELSE  \r\n                      CASE WHEN  WCMDSI.PARTNER_SITE_PARTY_KEY_INT = WCMDSI.END_CUST_PARTY_KEY  THEN 'N' \r\n                             ELSE\r\n                     CASE WHEN WCMDSI.END_CUST_CNTRY_CD = 'UNK' THEN 'N'\r\n                           ELSE  \r\n              CASE WHEN WCMDSI.PRTN_CNTRY_CD  =  WCMDSI.END_CUST_CNTRY_CD   THEN  'N' \r\n            ELSE 'Y' \r\n          END\r\n                     END\r\n           END\r\n  END CHANNEL_DROP_SHIP_FLAG ,\r\n \r\n/*  ,CASE WHEN WCMDSI.END_CUSTOMER_TYPE_CODE='ACCOUNT' THEN COALESCE(NEP_END_CUST.PARTY_KEY,-999)\r\n        WHEN WCMDSI.END_CUSTOMER_TYPE_CODE='ACCOUNT_LOCATION' THEN COALESCE(NECAL_END_CUST_LOC.CUSTOMER_PARTY_KEY,-999)\r\n        ELSE -999\r\n  END   END_CUST_PARTY_KEY \r\n */\r\n WCMDSI.SHIP_TO_CUSTOMER_KEY\r\n \r\n FROM $$STGDB.WI_CHNL_MTX_DROP_SHIP_INT_ADJ WCMDSI",
        "User Defined Join": "",
