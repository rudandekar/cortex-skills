      "attributes": {
        "Sql Query": "SELECT \r\n   WCMC.SALES_TERRITORY_KEY \r\n  ,WCMC.SOLD_TO_CUSTOMER_KEY \r\n  ,WCMC.END_CUSTOMER_KEY\r\n    ,WCMC.BILL_TO_CUSTOMER_KEY\r\n  ,WCMC.SOLD_TO_PARTY_KEY  \r\n  ,WCMC.BILL_TO_PARTY_KEY  \r\n  ,WCMC.END_CUST_PARTY_KEY \r\n  ,WCMC.PARTNER_PARTY_SITE_KEY_INT\r\n  ,WCMC.PARTNER   \r\n  ,WCMC.SOLD_TO_GRAND_PRNT_PTY_KEY\r\n  ,WCMC.BILL_TO_GRAND_PRNT_PTY_KEY\r\n  ,WCMC.EDW_CREATE_USER  \r\n  ,WCMC.EDW_CREATE_DATETIME \r\n  ,WCMC.PRTN_CNTRY_CD  \r\n  ,WCMC.END_CUST_CNTRY_CD  \r\n  ,COALESCE(DSHIP.PARTNER_SITE_PARTY_KEY,-999) AS DROP_SHIP_PARTY_SITE_KEY\r\n  ,WCMC.SHIP_TO_CUSTOMER_KEY\r\n FROM $$STGDB.WI_SALES_CHNL_MTX_COUNTRY_ADJ WCMC\r\n LEFT OUTER JOIN  (SELECT PS.PARTNER_SITE_PARTY_KEY, \r\n    COALESCE(PS.BK_PARTY_ID_INT,-999) PARTY_ID,\r\n    COALESCE(DD_GRNDPARNT_PARTNER_PARTY_KEY,-999) GRNDPARNT_PARTNER_PARTY_KEY,\r\n    COALESCE (BK_ISO_COUNTRY_CODE,'UNK')  ISO_COUNTRY_CODE\r\n     FROM \r\n    $$COMREFVWDB.N_CHANNEL_PARTNER_SITE PS,\r\n    $$COMREFVWDB.N_CHNL_PTNR_COUNTRY PC\r\n     WHERE 1=1\r\n     AND   PS.PARTNER_COUNTRY_PARTY_KEY = PC.PARTNER_COUNTRY_PARTY_KEY\r\n       AND   PS.SOURCE_DELETED_FLG='N'\r\n     AND   PC.SOURCE_DELETED_FLG='N'\r\n     QUALIFY ROW_NUMBER () OVER (PARTITION BY GRNDPARNT_PARTNER_PARTY_KEY,ISO_COUNTRY_CODE \r\n        ORDER BY PARTY_ID ASC) =1)  DSHIP\r\n ON WCMC.SOLD_TO_GRAND_PRNT_PTY_KEY = DSHIP.GRNDPARNT_PARTNER_PARTY_KEY\r\n AND WCMC.END_CUST_CNTRY_CD = DSHIP.ISO_COUNTRY_CODE",
