      "attributes": {
        "Sql Query": "SELECT TMP.HOLD_RELEASE_ID,\r\nTMP.CREATION_DATE,\r\nTMP.CREATED_BY,\r\nTMP.LAST_UPDATE_DATE,\r\nTMP.LAST_UPDATED_BY,\r\nTMP.LAST_UPDATE_LOGIN,\r\nTMP.PROGRAM_APPLICATION_ID,\r\nTMP.PROGRAM_ID,\r\nTMP.PROGRAM_UPDATE_DATE,\r\nTMP.REQUEST_ID,\r\nTMP.HOLD_SOURCE_ID,\r\nTMP.RELEASE_REASON_CODE,\r\nTMP.RELEASE_COMMENT,\r\nTMP.CONTEXT,\r\nTMP.ATTRIBUTE1,\r\nTMP.ATTRIBUTE2,\r\nTMP.ATTRIBUTE3,\r\nTMP.ATTRIBUTE4,\r\nTMP.ATTRIBUTE5,\r\nTMP.ATTRIBUTE6,\r\nTMP.ATTRIBUTE7,\r\nTMP.ATTRIBUTE8,\r\nTMP.ATTRIBUTE9,\r\nTMP.ATTRIBUTE10,\r\nTMP.ATTRIBUTE11,\r\nTMP.ATTRIBUTE12,\r\nTMP.ATTRIBUTE13,\r\nTMP.ATTRIBUTE14,\r\nTMP.ATTRIBUTE15,\r\nTMP.ORDER_HOLD_ID,\r\nTMP.CREATE_DATETIME,\r\n'CG' AS GLOBAL_NAME,\r\nTMP.SOURCE_DML_TYPE,\r\nTMP.SOURCE_COMMIT_TIME,\r\nTMP.REFRESH_DATETIME FROM\r\n( SELECT HOLD_RELEASE_ID\t,\r\nCREATION_DATE\t,\r\nCREATED_BY\t,\r\nLAST_UPDATE_DATE\t,\r\nLAST_UPDATED_BY\t,\r\nLAST_UPDATE_LOGIN\t,\r\nPROGRAM_APPLICATION_ID\t,\r\nPROGRAM_ID\t,\r\nPROGRAM_UPDATE_DATE\t,\r\nREQUEST_ID\t,\r\nHOLD_SOURCE_ID\t,\r\nRELEASE_REASON_CODE\t,\r\nRELEASE_COMMENT\t,\r\nCONTEXT\t,\r\nATTRIBUTE1\t,\r\nATTRIBUTE2\t,\r\nATTRIBUTE3\t,\r\nATTRIBUTE4\t,\r\nATTRIBUTE5\t,\r\nATTRIBUTE6\t,\r\nATTRIBUTE7\t,\r\nATTRIBUTE8\t,\r\nATTRIBUTE9\t,\r\nATTRIBUTE10\t,\r\nATTRIBUTE11\t,\r\nATTRIBUTE12\t,\r\nATTRIBUTE13\t,\r\nATTRIBUTE14\t,\r\nATTRIBUTE15\t,\r\nORDER_HOLD_ID\t,\r\nCURRENT_TIMESTAMP(0) AS CREATE_DATETIME,\r\nSOURCE_DML_TYPE\t,\r\nSOURCE_COMMIT_TIME\t,\r\nREFRESH_DATETIME\tFROM $$NRTACCUMVWDB.CG1_OE_HOLD_RELEASES WHERE 1=1 AND (SOURCE_COMMIT_TIME >='$$LastExtractDate' AND SOURCE_COMMIT_TIME < '$$EndLastExtractDate')) TMP QUALIFY ROW_NUMBER() OVER (PARTITION BY TMP.HOLD_RELEASE_ID ORDER BY \r\nTMP.HOLD_RELEASE_ID,TMP.REFRESH_DATETIME DESC) = 1",
