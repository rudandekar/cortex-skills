      "attributes": {
        "Sql Query": "SELECT \r\nNMOVRLYTV.SK_TRX_SC_ID_INT,\r\nNMOVRLYTV.SS_CD,\r\nNMOVRLYTV.SLS_CR_ASSGN_MANUAL_ADJ_KEY,\r\nNMOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD AS BK_SLS_TERR_ASSIGNMENT_TYPE_CD, \r\nNMOVRLYTV.SCASA_CREATION_DT AS SCASA_CREATION_DT,\r\nNMOVRLYTV.SALES_REP_NUM AS SALES_REP_NUM, \r\nNMOVRLYTV.SALES_TERRITORY_KEY AS SALES_TERRITORY_KEY, \r\nNMOVRLYTV.MANUAL_TRX_KEY AS MANUAL_TRX_KEY, \r\nNMOVRLYTV.SALES_COMMISSION_PCT,\r\nNMOVRLYTV.START_TV_DTM,\r\nNMOVRLYTV.END_TV_DTM,\r\nNMOVRLYTV.EDW_CREATE_DTM AS EDW_CREATE_DTM,\r\nNMOVRLYTV.EDW_UPDATE_DTM AS EDW_UPDATE_DTM,\r\nNMOVRLYTV.PD_SLS_CREDIT_LAST_UPDATE_DTM,\r\nNMOVRLYTV.SALES_CREDIT_USAGE_CD\r\nFROM \r\n$$SLSORDVWDB.N_SLS_CR_ASGN_REBOK_MNL_ADJ_TV NMOVRLYTV\r\nWHERE \r\nNMOVRLYTV.SALES_CREDIT_USAGE_CD IN ('R','CR') \r\nAND NMOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD<>'DR'\r\nAND NMOVRLYTV.EDW_UPDATE_DTM>'$$LastExtractDate'",
