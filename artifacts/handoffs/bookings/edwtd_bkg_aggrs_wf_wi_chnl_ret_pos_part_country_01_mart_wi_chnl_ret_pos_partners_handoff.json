      "attributes": {
        "Sql Query": "SELECT \r\n\tRPP.SOLD_TO_CUSTOMER_KEY,\r\n\tRPP.DV_END_CUSTOMER_KEY,\r\n\tRPP.SALES_TERRITORY_KEY,\r\n\tRPP.SOLD_TO_PARTY_KEY,\r\n\tRPP.DV_END_CUSTOMER_PARTY_KEY,\r\n\tRPP.PARTNER_SITE_PARTY_KEY_INT,\r\n\tRPP.PARTNER_PARTY_KEY,\r\n\tCOALESCE(PART_CTRY.ISO_COUNTRY_CODE, 'UNK') PARTNER_COUNTRY,\r\n\tCOALESCE(END_CTRY.ISO_COUNTRY_CODE, 'UNK') DV_END_CUST_COUNTRY,\r\n\tRPP.BK_WIPS_ORIGINATOR_ID_INT,\r\n\tRPP.SHIP_TO_CUSTOMER_KEY\r\nFROM $$STGDB.WI_CHNL_RET_POS_PARTNERS RPP\r\nLEFT OUTER JOIN (\r\n\t\tSELECT \tNPLA.PARTY_KEY, NPAL.ISO_COUNTRY_CODE\r\n\t\tFROM \t$$COMREFVWDB.N_PARTY_LOCATOR_ASGN NPLA\r\n\t\tINNER JOIN $$COMREFVWDB.N_LOCATOR  NL\r\n\t\tON \tNPLA.LOCATOR_KEY = NL.LOCATOR_KEY\r\n\t\tAND \tNL.SS_CODE = 'CR'\r\n\t\tAND \tNPLA.LOCATION_TYPE_CODE = 'POSTAL ADDRESS'\r\n\t\tINNER JOIN $$COMREFVWDB.N_POSTAL_ADDRESS_LOCATOR NPAL\r\n\t\tON \tNPLA.LOCATOR_KEY = NPAL.LOCATOR_KEY) PART_CTRY\r\nON RPP.PARTNER_SITE_PARTY_KEY_INT = PART_CTRY.PARTY_KEY \r\nLEFT OUTER JOIN (\r\n\t\tSELECT NPLA.PARTY_KEY, NPAL.ISO_COUNTRY_CODE\r\n\t\tFROM   $$COMREFVWDB.N_PARTY_LOCATOR_ASGN NPLA\r\n\t\tINNER JOIN $$COMREFVWDB.N_LOCATOR  NL\r\n\t\tON \tNPLA.LOCATOR_KEY = NL.LOCATOR_KEY\r\n\t\tAND \tNL.SS_CODE = 'CR'\r\n\t\tAND \tNPLA.LOCATION_TYPE_CODE = 'POSTAL ADDRESS'\r\n\t\tINNER JOIN $$COMREFVWDB.N_POSTAL_ADDRESS_LOCATOR NPAL\r\n\t\tON \tNPLA.LOCATOR_KEY = NPAL.LOCATOR_KEY) END_CTRY\r\nON  RPP.dv_END_CUSTOMER_PARTY_KEY = END_CTRY.PARTY_KEY",
