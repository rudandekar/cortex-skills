      "attributes": {
        "Sql Query": "SELECT \r\n\tRPP.SOLD_TO_CUSTOMER_KEY\t\tAS SOLD_TO_CUSTOMER_KEY,\r\n\tRPP.DV_END_CUSTOMER_KEY\t\t\tAS DV_END_CUSTOMER_KEY,\r\n\tRPP.SALES_TERRITORY_KEY\t\t\tAS SALES_TERRITORY_KEY,\r\n\tSPK.CUSTOMER_PARTY_KEY \t\t\tAS SOLD_TO_PARTY_KEY,\r\n\tEPK.CUSTOMER_PARTY_KEY \t\t\tAS DV_END_CUSTOMER_PARTY_KEY,\r\n\tCASE  WHEN CDW.BCF_PARTNER_SITE_PARTY_KEY IS NOT NULL THEN CDW.BCF_PARTNER_SITE_PARTY_KEY \r\n\tWHEN PS.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NULL THEN\r\nCASE WHEN MT_SOLDTO.ERP_WIPS_CUSTOMER_NAME LIKE ANY  ('%CS CAPITAL%','%CISCO SYSTEMS CAPITAL%', 'CISCO SYSTEMS FINANCE %','EXPEDIA INC')\r\nAND COALESCE(SHIP_TO_PARENT.PARTNER_SITE_PARTY_KEY,-999) <> -999 THEN SHIP_TO_PARENT.PARTNER_SITE_PARTY_KEY\r\n/* WHEN CDW.BCF_PARTNER_SITE_PARTY_KEY IS NOT NULL THEN CDW.BCF_PARTNER_SITE_PARTY_KEY */\r\n      ELSE -999 END\r\n      ELSE PS.PARTNER_SITE_PARTY_KEY\r\nEND   PARTNER_SITE_PARTY_KEY_INT,\r\n\tCASE WHEN CDW.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NOT NULL THEN CDW.DD_GRNDPARNT_PARTNER_PARTY_KEY\r\n\tWHEN COALESCE(PS.DD_GRNDPARNT_PARTNER_PARTY_KEY,-999) = -999 THEN\r\nCASE WHEN MT_SOLDTO.ERP_WIPS_CUSTOMER_NAME LIKE ANY  ('%CS CAPITAL%','%CISCO SYSTEMS CAPITAL%', 'CISCO SYSTEMS FINANCE %','EXPEDIA INC')\r\nAND COALESCE(SHIP_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY,-999) <> -999 THEN SHIP_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY\r\n/* WHEN CDW.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NOT NULL THEN CDW.DD_GRNDPARNT_PARTNER_PARTY_KEY */\r\n      ELSE -999 END\r\n\t  ELSE COALESCE(PS.DD_GRNDPARNT_PARTNER_PARTY_KEY,-999) END\r\n\tAS PARTNER_PARTY_KEY,\r\n\tRPP.BK_WIPS_ORIGINATOR_ID_INT\t\tAS BK_WIPS_ORIGINATOR_ID_INT,\r\n    RPP.SHIP_TO_CUSTOMER_KEY\t\tAS SHIP_TO_CUSTOMER_KEY\r\nFROM \t$$STGDB.WI_CHNL_RET_POS_PATTERNS RPP\r\n\r\nINNER  JOIN $$COMREFVWDB.N_WIPS_CUSTOMER_SITE_TV SPK\r\nON \tRPP.SOLD_TO_CUSTOMER_KEY = SPK.WIPS_SITE_USE_KEY\r\n\tAND SPK.END_TV_DATE  = '3500-01-01'\r\n\r\nINNER  JOIN $$COMREFVWDB.N_WIPS_CUSTOMER_SITE_TV EPK\r\nON \tRPP.DV_END_CUSTOMER_KEY = EPK.WIPS_SITE_USE_KEY\r\nAND \tEPK.END_TV_DATE  = '3500-01-01'\r\n\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE PS\r\nON \tSPK.CUSTOMER_PARTY_KEY = PS.PARTNER_SITE_PARTY_KEY\r\nAND \tPS.SOURCE_DELETED_FLG='N'\r\n\r\nINNER  JOIN $$COMREFVWDB.N_WIPS_CUSTOMER_SITE_TV SHIPK\r\nON RPP.SHIP_TO_CUSTOMER_KEY = SHIPK.WIPS_SITE_USE_KEY\r\nAND SHIPK.END_TV_DATE  = '3500-01-01'\r\n\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE  SHIP_TO_PARENT\r\nON(SHIPK.CUSTOMER_PARTY_KEY=SHIP_TO_PARENT.PARTNER_SITE_PARTY_KEY)\r\nAND SHIP_TO_PARENT.SOURCE_DELETED_FLG='N'\r\n\r\nLEFT JOIN $$COMREFVWDB.MT_ERP_POS_SOLDTO MT_SOLDTO \r\nON MT_SOLDTO.SOLD_TO_CUSTOMER_KEY = RPP.SOLD_TO_CUSTOMER_KEY\r\n\r\nLEFT JOIN $$STGDB.WI_CDW_PSPK CDW\r\nON RPP.BK_WIPS_ORIGINATOR_ID_INT=CDW.BK_WIPS_ORIGINATOR_ID_INT",
        "User Defined Join": "",
