      "attributes": {
        "Sql Query": "SELECT\r\nBOOKINGS_MEASURE_KEY \r\n,OVERLAY_SALES_CREATION_DT \r\n,BKGS_MSR_TRANS_TYPE_CODE\r\n,AR_TRX_LINE_KEY   \r\n,BK_POS_TRANSACTION_ID_INT\r\n,MANUAL_TRX_KEY                \r\n,OVERLAY_SALES_TERRITORY_KEY   \r\n,OVERLAY_SALES_REP_NUMBER                \r\n,BOOKINGS_PROCESS_DATE    \r\n,CAST(COALESCE(DD_COMP_US_NET_PRICE_AMOUNT, 0) AS DECIMAL(18,6))DD_COMP_US_NET_PRICE_AMOUNT   \r\n,CAST(COALESCE(DD_COMP_US_LIST_PRICE_AMOUNT, 0) AS DECIMAL(18,6)) DD_COMP_US_LIST_PRICE_AMOUNT\r\n,CAST(COALESCE(DD_COMP_US_COST_AMOUNT , 0) AS DECIMAL(18,6)) DD_COMP_US_COST_AMOUNT \r\n,CAST(COALESCE(DD_EXTENDED_QUANTITY , 0) AS DECIMAL(18,6)) DD_EXTENDED_QUANTITY    \r\n,BK_SLS_TERR_ASSIGNMENT_TYPE_CD\r\n,OVERLAY_SALES_COMMISSION_PCT      \r\n,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM\r\n,USER AS EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM\r\n,USER AS EDW_UPDATE_USER\r\n,DV_SALES_ORDER_LINE_KEY\r\n,SO_SBSCRPTN_ITM_SLS_TRX_KEY  /*xaas*/\r\n,LATEST_DR_BKGS_FLG\r\n,'F' AS FORWARD_REVERSE_FLG\r\n,'Y' AS LATEST_RECORD_FLG\r\n,DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n,PROCESS_DATE_RK\r\n,'M' AS PD_ADJSTMNT_RPTNG_TYPE_CD\r\nFROM\r\n(SELECT \r\n NBMFOD.BOOKINGS_MEASURE_KEY \r\n,NAOVRLY.SCASA_CREATION_DT AS  OVERLAY_SALES_CREATION_DT         \r\n,NBMFOD.BKGS_MEASURE_TRANS_TYPE_CODE AS BKGS_MSR_TRANS_TYPE_CODE \r\n,NBMFOD.AR_TRX_LINE_KEY  AS AR_TRX_LINE_KEY\r\n,NBMFOD.BK_POS_TRANSACTION_ID_INT        \r\n,NBMFOD.MANUAL_TRX_KEY                \r\n,NAOVRLY.SALES_TERRITORY_KEY AS OVERLAY_SALES_TERRITORY_KEY      \r\n,NAOVRLY.SALES_REP_NUM AS OVERLAY_SALES_REP_NUMBER       \r\n,NBMFOD.BOOKINGS_PROCESS_DATE AS BOOKINGS_PROCESS_DATE  \r\n,CAST((NAOVRLY.SALES_COMMISSION_PCT*NBMFOD.DD_COMP_US_NET_PRICE_AMOUNT)/100 AS DECIMAL(18,6))  AS  DD_COMP_US_NET_PRICE_AMOUNT\r\n,CAST((NAOVRLY.SALES_COMMISSION_PCT*NBMFOD.DD_COMP_US_LIST_PRICE_AMOUNT)/100 AS DECIMAL(18,6)) AS DD_COMP_US_LIST_PRICE_AMOUNT\r\n,CAST((NAOVRLY.SALES_COMMISSION_PCT*NBMFOD.DD_COMP_US_COST_AMOUNT )/100 AS DECIMAL(18,6)) AS  DD_COMP_US_COST_AMOUNT\r\n,CAST((NAOVRLY.SALES_COMMISSION_PCT*NBMFOD.DD_EXTENDED_QUANTITY )/100 AS DECIMAL(18,6)) AS  DD_EXTENDED_QUANTITY\r\n,NAOVRLY.BK_SLS_TERR_ASSIGNMENT_TYPE_CD\r\n,NAOVRLY.SALES_COMMISSION_PCT AS OVERLAY_SALES_COMMISSION_PCT   \r\n,NBMFOD.DV_SALES_ORDER_LINE_KEY\r\n,NBMFOD.SO_SBSCRPTN_ITM_SLS_TRX_KEY  \r\n,SALES_ADJ_LINE.DV_LATEST_FLG AS  LATEST_DR_BKGS_FLG,\r\nNBMFOD.DV_FISCAL_YEAR_MTH_NUMBER_INT as DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\nNBMFOD.PROCESS_DATE_RK\r\nFROM\r\n$$STGDB.WI_DIRECT_DATA_MNL_M_INCR NBMFOD \r\nINNER JOIN $$ETLVWDB.EL_BOOKINGS_M_ADJS  SALES_ADJ_LINE\r\nON SALES_ADJ_LINE.BOOKINGS_MEASURE_KEY = NBMFOD.BOOKINGS_MEASURE_KEY\r\nINNER JOIN $$SLSORDVWDB.N_SLS_CR_ASGN_REBOK_MNL_ADJ NAOVRLY\r\nON NBMFOD.MANUAL_TRX_KEY= NAOVRLY.MANUAL_TRX_KEY  \r\nAND NAOVRLY.BK_SLS_TERR_ASSIGNMENT_TYPE_CD <>'DR' \r\nAND NAOVRLY.SALES_CREDIT_USAGE_CD IN ('R','CR')\r\nWHERE NBMFOD.MANUAL_TRX_KEY >0  \r\n) A",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
