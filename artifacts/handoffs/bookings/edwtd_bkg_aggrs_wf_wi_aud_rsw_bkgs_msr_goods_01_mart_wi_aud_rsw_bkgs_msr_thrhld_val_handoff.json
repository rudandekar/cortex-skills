      ],
      "attributes": {
        "Sql Query": "SELECT \r\n'MT_RECURRING_SW_BKGS_MEASURE' AS AUDIT_TABLE_NAME, \r\n'ALL_COLUMNS' AS AUDIT_COLUMN_NAME,\r\nCASE WHEN COUNT(*) >= 1 THEN 'Y' ELSE 'N' END as AMOUNTDIFF_FLG,\r\nUSER as EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) as EDW_CREATE_DATETIME,\r\nUSER as EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) as EDW_UPDATE_DATETIME\r\nFROM \r\n(\r\n SELECT\r\n RSW.*, \r\n THR.AUDIT_COLUMN_NAME\r\n FROM \r\n $$STGDB.WI_AUD_RSW_BKGS_MSR_THRHLD_VAL THR\r\n INNER JOIN\r\n $$STGDB.WI_AUD_RSW_BKGS_MSR_GOODS RSW\r\n ON \r\n RSW.AUDIT_TABLE_NAME = THR.AUDIT_TABLE_NAME\r\n AND \r\n THR.AUDIT_TABLE_NAME = 'MT_RECURRING_SW_BKGS_MEASURE'\r\nWHERE RSW.RS_DD_COMP_US_NET_PRICE_AMOUNT NOT BETWEEN THR.MIN_THRESHOLD_VALUE AND THR.MAX_THRESHOLD_VALUE\r\n)A",
        "User Defined Join": "",
