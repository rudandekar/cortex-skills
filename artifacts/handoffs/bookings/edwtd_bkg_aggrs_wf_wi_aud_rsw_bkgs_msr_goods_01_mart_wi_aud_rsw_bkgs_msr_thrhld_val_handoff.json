        {
          "name": "EDW_CREATE_DATETIME",
          "datatype": "date/time",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "SELECT\r\n'MT_RECURRING_SW_BKGS_MEASURE' AS AUDIT_TABLE_NAME,\r\nSRC.DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\nSRC.BKGS_MEASURE_TRANS_TYPE_CODE,\r\nSRC.RS_DD_COMP_US_NET_PRICE_AMOUNT - COALESCE(TGT.RS_DD_COMP_US_NET_PRICE_AMOUNT,0.000000) AS RS_DD_COMP_US_NET_PRICE_AMOUNT,\r\nUSER as EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) as EDW_CREATE_DATETIME\r\nFROM\r\n\r\n(\r\nSELECT\r\nBKGS.DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\nBKGS.BKGS_MEASURE_TRANS_TYPE_CODE,\r\nCAST(SUM(BKGS.DD_COMP_US_NET_PRICE_AMOUNT * CAST(NPDT.ALLOCATION_PCT AS DECIMAL (18,2)))  AS DECIMAL(18,6)) AS RS_DD_COMP_US_NET_PRICE_AMOUNT\r\nFROM $$SLSORDVWDB.MT_RSTD_BKGS_MEASURE BKGS\r\nINNER JOIN $$STGDB.WI_RS_CTRL_MTH CTRL\r\nON CTRL.FISCAL_YEAR_MONTH_INT = BKGS.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND CTRL.CURRENT_FISCAL_MONTH_FLAG = 'Y'\r\nAND CTRL.PROCESS_FLAG = 'Y'\r\nINNER JOIN $$COMREFVWDB.N_PRDT_TO_PRDT_CLSFTN_ALCTN NPDT\r\nON NPDT.PRODUCT_KEY = BKGS.PRODUCT_KEY\r\nAND NPDT.DV_FISCAL_YEAR_QUARTER_NUM_INT = BKGS.FISCAL_YEAR_QUARTER_NUMBER_INT\r\nAND NPDT.BK_PRDT_ALLCTN_METRIC_CD IN ('BOOKINGS', 'UNKNOWN')\r\nINNER JOIN $$COMREFVWDB.N_PRODUCT_TV NP\r\nON (CASE WHEN BKGS.PRODUCT_KEY BETWEEN -1006800 AND -1005000 THEN -998\r\nWHEN  BKGS.PRODUCT_KEY BETWEEN -1001800 AND -1000000 THEN -999\r\nELSE BKGS.PRODUCT_KEY END) = NP.ITEM_KEY\r\nAND NP.END_TV_DATE = '3500-01-01'\r\nWHERE BKGS.SERVICE_FLG = 'N'\r\nAND NP.RECURRING_OFFER_FLG = 'Y'\r\nAND NPDT.BK_PRDT_ALLCTN_CLSFCTN_CD = 'Software'\r\nGROUP BY 1,2\r\n) SRC\r\n\r\nLEFT OUTER JOIN\r\n(\r\nSELECT\r\nRSW.DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\nRSW.BKGS_MEASURE_TRANS_TYPE_CODE,\r\nSUM(RSW.RS_DD_COMP_US_NET_PRICE_AMOUNT) AS RS_DD_COMP_US_NET_PRICE_AMOUNT\r\nFROM $$SLSORDVWDB.MT_RECURRING_SW_BKGS_MEASURE RSW\r\nINNER JOIN $$STGDB.WI_RS_CTRL_MTH CTRL\r\nON CTRL.FISCAL_YEAR_MONTH_INT = RSW.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND CTRL.CURRENT_FISCAL_MONTH_FLAG = 'Y'\r\nAND CTRL.PROCESS_FLAG = 'Y'\r\nWHERE RSW.SERVICE_FLG = 'N'\r\n/*AND RSW.RECURRING_SOFTWARE_FLG = 'Y' */ /* This filter is not req'd as we are using NON TV view */\r\nGROUP BY 1,2\r\n)TGT\r\nON SRC.DV_FISCAL_YEAR_MTH_NUMBER_INT=TGT.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND SRC.BKGS_MEASURE_TRANS_TYPE_CODE=TGT.BKGS_MEASURE_TRANS_TYPE_CODE",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
