      ],
      "attributes": {
        "Sql Query": "SELECT\r\nINNER_NGPSPL.MAPPED_SERVICE_PRODUCT_KEY    MAPPED_SERVICE_PRODUCT_KEY \r\n,MAX(GOODS_PRODUCT_KEY )  GOODS_PRODUCT_KEY             \r\nFROM     \r\n$$SLSORDVWDB.N_GOODS_PRD_SERVICE_PRD_LINK   INNER_NGPSPL\r\nINNER JOIN $$COMREFVWDB.R_PRODUCTS_FIN                  INNER_RP\r\nON(      INNER_RP.ITEM_KEY = INNER_NGPSPL.GOODS_PRODUCT_KEY)\r\nWHERE  INNER_RP.BK_ITEM_TYPE_CODE NOT IN ('REFURBISHED','CONFIG SPARE','SPARE' , 'UNKNOWN' )\r\nAND INNER_RP.GOODS_OR_SERVICE_TYPE        <> 'SERVICE'\r\nAND INNER_NGPSPL.MAPPED_SERVICE_PRODUCT_KEY \r\nNOT IN (\r\n\t\t\tSELECT MAPPED_SERVICE_PRODUCT_KEY FROM  $$SLSORDVWDB.N_GOODS_PRD_SERVICE_PRD_LINK  \r\n\t\t\t\tWHERE GOODS_PRODUCT_KEY  IN (SELECT NOT_MAPPED_ITEM_KEY FROM $$STGDB.WI_QTR_NOT_MAPPED_PRODUCTS  )  \r\n\t\t\tGROUP BY MAPPED_SERVICE_PRODUCT_KEY \r\n\t\t\tHAVING COUNT (GOODS_PRODUCT_KEY) = 1\r\n) \r\nAND INNER_NGPSPL.GOODS_PRODUCT_KEY   IN (SELECT NOT_MAPPED_ITEM_KEY FROM $$STGDB.WI_QTR_NOT_MAPPED_PRODUCTS  ) \r\nGROUP    BY INNER_NGPSPL.MAPPED_SERVICE_PRODUCT_KEY   \r\nHAVING COUNT(DISTINCT INNER_RP.RU_BK_PRODUCT_FAMILY_ID    ) =1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
