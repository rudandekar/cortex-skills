        "Sql Query": "SELECT INNER_NGPSPL.MAPPED_SERVICE_PRODUCT_KEY MAPPED_SERVICE_PRODUCT_KEY, \r\nMAX(GOODS_PRODUCT_KEY)  GOODS_PRODUCT_KEY             \r\nFROM $$SLSORDVWDB.N_GOODS_PRD_SERVICE_PRD_LINK INNER_NGPSPL\r\nINNER JOIN $$COMREFVWDB.R_PRODUCTS_FIN INNER_RP\r\nON(INNER_RP.ITEM_KEY = INNER_NGPSPL.GOODS_PRODUCT_KEY AND  INNER_RP.GOODS_OR_SERVICE_TYPE   <> 'SERVICE' )\r\nWHERE INNER_NGPSPL.GOODS_PRODUCT_KEY  IN (SELECT NOT_MAPPED_ITEM_KEY FROM $$STGDB.WI_QTR_NOT_MAPPED_PRODUCTS  )   \r\nGROUP BY INNER_NGPSPL.MAPPED_SERVICE_PRODUCT_KEY\r\nHAVING COUNT(DISTINCT INNER_NGPSPL.GOODS_PRODUCT_KEY ) =1",
