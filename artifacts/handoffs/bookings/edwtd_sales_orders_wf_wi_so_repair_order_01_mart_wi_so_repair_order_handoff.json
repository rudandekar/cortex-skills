      "attributes": {
        "Sql Query": "SELECT NSO.SALES_ORDER_KEY,\r\n'Y' AS REPAIR_ORDER_ROLE,\r\nNRO.BK_REPAIR_ORDER_NUM_INT\r\nFROM $$SLSORDVWDB.N_SALES_ORDER_V1_TV NSO\r\nINNER JOIN ( SELECT BK_REPAIR_ORDER_NUM_INT FROM $$SERVICEVWDB.N_REPAIR_ORDER\r\n\t\t\tWHERE EDW_CREATE_DTM > ( SELECT LAST_EXTRACT_DATE \r\n\t\t\tFROM $$ETLVWDB.DW_JOB_STREAMS\r\n\t\t\tWHERE JOB_STREAM_ID='wf_WI_SO_REPAIR_ORDER' )) NRO\r\nON ( NSO.RU_SRC_REPORTED_REPAIR_ORD_NUM = CAST(NRO.BK_REPAIR_ORDER_NUM_INT AS VARCHAR(240))\r\n\tAND NSO.RU_SRC_REPORTED_REPAIR_ORD_NUM IS NOT NULL\r\n\tAND NSO.REPAIR_ORDER_ROLE ='N' )",
