      "attributes": {
        "Sql Query": "SELECT\r\nFDY.FISCAL_YEAR_MONTH_INT\r\n,DITL.PRODUCT_KEY\r\n,DITL.BK_WIPS_ORIGINATOR_ID_INT \r\n,SUM(DITL.ON_HAND_QTY )\r\n,SUM(DITL.COMMITTED_QTY)\r\n,SUM(DITL.ON_ORDER_QTY )\r\n,SUM(DITL.DISTI_REPORTED_IN_TRANSIT_QTY )\r\n,SUM(COALESCE(DITL.CISCO_TO_DISTI_IN_TRANSIT_QTY,0) )\r\n,SUM(DITL.VALUATION_PRICE_USD_AMT )\r\n,DITL.DISTRIBUTOR_WAREHOUSE_NUM\r\n,SUM(DITL.INVNTRY_VALUATION_USD_AMT)\r\n,SUM(DITL.INVNTRY_IN_TRNST_VLTN_USD_AMT )\r\n,SUM(DITL.INVNTRY_VALUATION_USD_AMT + (DITL.VALUATION_PRICE_USD_AMT * DITL.DISTI_REPORTED_IN_TRANSIT_QTY )) AS INV_ON_HAND_AMT\r\n,DITL.INVENTORY_AS_OF_DT\r\n,SUM(DITL.DISTI_RPRTD_UNIT_PRC_USD_AMT * DITL.ON_HAND_QTY) AS DV_DISTI_RPTD_NET_PRC_USD_AMT\r\nFROM $$SLSORDVWDB.N_DISTI_INVENTORY_TRX_LINE DITL\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR  FDY\r\nON ( DITL.INVENTORY_TYPE_CD ='PRIMARY'\r\nAND DITL.ACTIVE_FLG='Y'\r\nAND FDY.FISCAL_MONTH_AGE IN ( 0,1) \r\nAND (FDY.FISCAL_MONTH_END_DATE BETWEEN DITL.DV_START_ACTIVE_DT AND DITL.DV_END_ACTIVE_DT ) )\r\nGROUP BY\r\nFDY.FISCAL_YEAR_MONTH_INT,\r\nDITL.PRODUCT_KEY,\r\nDITL.BK_WIPS_ORIGINATOR_ID_INT ,\r\nDITL.DISTRIBUTOR_WAREHOUSE_NUM,\r\nDITL.INVENTORY_AS_OF_DT",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
