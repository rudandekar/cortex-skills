      "attributes": {
        "Sql Query": "SELECT\r\n  NAOVRLYTV.SK_TRX_SC_ID_INT,\r\n  NAOVRLYTV.PD_SS_CD,\r\n  NAOVRLYTV.SALES_CR_ASSGN_NONAPPLD_KEY,\r\n  NAOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD  AS  BK_SLS_TERR_ASSIGNMENT_TYPE_CD, \r\n  NAOVRLYTV.PD_SCAN_CREATION_DT AS PD_SCAN_CREATION_DT,\r\n  NAOVRLYTV.PD_SALES_REP_NUM AS  PD_SALES_REP_NUM, \r\n  NAOVRLYTV.PD_SALES_TERRITORY_KEY AS  PD_SALES_TERRITORY_KEY, \r\n  NAOVRLYTV.PD_AR_TRX_LINE_KEY AS   PD_AR_TRX_LINE_KEY , \r\n  NAOVRLYTV.PD_SALES_COMMISSION_PCT  AS PD_SALES_COMMISSION_PCT,\r\n  NAOVRLYTV.START_TV_DTM,\r\n  NAOVRLYTV.END_TV_DTM,\r\n  NAOVRLYTV.EDW_CREATE_DTM  AS EDW_CREATE_DTM,\r\n  NAOVRLYTV.EDW_UPDATE_DTM  AS EDW_UPDATE_DTM,\r\n  NAOVRLYTV.PD_SLS_CREDIT_LAST_UPDATE_DTM ,\r\n  NAOVRLYTV.PD_SALES_CREDIT_USAGE_CD,\r\n  NAOVRLYTV.BK_OFFER_ATTRIBUTION_ID_INT AS SK_OFFER_ATTRIBUTION_ID_INT,\r\n  NART.LINE_CREATION_DATE\r\n  FROM \r\n   $$SLSORDVWDB.N_SCA_NON_APLD_TRX_OVERLAY_TV NAOVRLYTV\r\n   INNER JOIN (SELECT AR_TRX_LINE_KEY, CAST(AR_TRX_LINE_CREATION_DATETIME AS DATE FORMAT 'yyyy-mm-dd' ) AS LINE_CREATION_DATE FROM $$FINLGLVWDB.N_AR_TRX_LINE ) NART \r\n  ON NART.AR_TRX_LINE_KEY =  NAOVRLYTV.PD_AR_TRX_LINE_KEY\r\n  WHERE     \r\n       NAOVRLYTV.PD_SALES_CREDIT_USAGE_CD IN ('R','CR')   \r\n   AND NAOVRLYTV.EDW_UPDATE_DTM> (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.CTL_ETL_LAST_EXTRACT_DATES \r\n WHERE JOB_STREAM_ID = 'wf_WI_OVERLAY_DATA_AR_NAPLD_INCR' AND TABLE_NAME ='N_SCA_NON_APLD_TRX_OVERLAY_TV')\r\n  --AND NAOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD NOT IN ('CX','MS','CCR','WWP')                            \r\n AND NAOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD NOT IN ('CX')\r\n AND NOT EXISTS (SELECT 1 FROM $$ETLVWDB.EL_OVERLAY_SUB_LINE_INCLUSION EL \r\n WHERE EL.BK_SLS_TERR_ASSIGNMENT_TYPE_CD=NAOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD \r\n      AND NART.LINE_CREATION_DATE BETWEEN EFFECTIVE_START_DATE AND EFFECTIVE_END_DATE)",
        "User Defined Join": "",
        "Source Filter": "",
