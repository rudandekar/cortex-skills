      "attributes": {
        "Sql Query": "-- QUERY FOR FETCHING AND MARKING NEW RECORDS\r\nSELECT\r\nTSS_COUNTRY_FACTOR_KEY, \r\nPRODUCT_KEY, \r\nBK_PRICE_LIST_NAME, \r\nBK_ISO_COUNTRY_CD, \r\nCOST_FACTOR_PCT, \r\nSRC_LST_UPDTD_WRKR_PRTY_KEY, \r\nCOUNTRY_FLG,\r\nSALES_TERRITORY_NAME,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nREBATE_FACTOR_PCT,\r\nACTION_CODE,\r\nDML_TYPE\r\nFROM(\r\nSELECT\t\r\nTSS_COUNTRY_FACTOR_KEY,\r\nPRODUCT_KEY,\r\nPRICE_LIST_NAME AS BK_PRICE_LIST_NAME ,\r\nISO_COUNTRY_CD AS BK_ISO_COUNTRY_CD,\r\nCOST_FACTOR_PCT,\r\nSRC_LST_UPDTD_WRKR_PRTY_KEY,\r\nCOUNTRY_FLG,\r\nSALES_TERRITORY_NAME,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nREBATE_FACTOR_PCT,\r\nACTION_CODE,\r\nDML_TYPE\r\n\r\nFROM\t\r\n(\r\nSELECT\t\r\nSM.TSS_COUNTRY_FACTOR_KEY,\r\nTSS.PRODUCT_KEY,\r\nTSS.BK_PRICE_LIST_NAME AS PRICE_LIST_NAME,\r\nTSS.BK_ISO_COUNTRY_CD AS ISO_COUNTRY_CD\t ,\r\nTSS.COST_FACTOR_PCT,\r\nCASE\tWHEN CWP.CISCO_WORKER_PARTY_KEY  IS NULL THEN -999 \r\nELSE\tCWP.CISCO_WORKER_PARTY_KEY \r\nEND\t AS SRC_LST_UPDTD_WRKR_PRTY_KEY,\r\nTSS.COUNTRY_FLG,\r\nTSS.SALES_TERRITORY_NAME ,\r\nTSS.BKGS_MEASURE_TRANS_TYPE_CODE,\r\nTSS.REBATE_FACTOR_PCT,\r\nNULL  ACTION_CODE,\r\n'I'  DML_TYPE\r\nFROM\t$$STGDB.ST_TSS_PRODUCT_COST_FACTOR TSS\r\nINNER JOIN $$ETLVWDB.SM_TSS_PRODUCT_COST_FACTOR  SM \r\n\tON\tSM.PRODUCT_KEY = TSS.PRODUCT_KEY\r\n\tAND\tSM.BK_ISO_COUNTRY_CD = TSS.BK_ISO_COUNTRY_CD\r\n\tAND\tSM.SALES_TERRITORY_NAME = TSS.SALES_TERRITORY_NAME\r\n\tAND\tSM.BK_PRICE_LIST_NAME = TSS.BK_PRICE_LIST_NAME\r\n\tAND\tSM.BKGS_MEASURE_TRANS_TYPE_CODE = TSS.BKGS_MEASURE_TRANS_TYPE_CODE\r\nLEFT OUTER JOIN  $$COMREFVWDB.N_CISCO_WORKER_PARTY CWP\r\n\tON\tCWP.CEC_ID=TSS.EDW_UPLOAD_USER\r\n\tAND\tCWP.RU_EMPLOYEE_STATUS_CODE='A'\r\nWHERE NOT EXISTS (SELECT 1 FROM $$WORKDB.W_TSS_PRODUCT_COST_FACTOR  WTSS\r\nWHERE WTSS.TSS_COUNTRY_FACTOR_KEY=SM.TSS_COUNTRY_FACTOR_KEY )\r\n\t)PCF1 ) PCF2",
        "User Defined Join": "",
