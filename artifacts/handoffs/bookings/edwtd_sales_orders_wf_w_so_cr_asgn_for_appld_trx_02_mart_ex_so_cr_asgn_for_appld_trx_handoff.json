      "attributes": {
        "Sql Query": "SELECT \r\nWI.SOURCE_DELETED_FLG,\r\nWI.HEADER_SEQ_ID,\r\nWI.GLOBAL_NAME,\r\nWI.SALESREP_ID,\r\nWI.TERRITORY_ID,\r\nWI.SALES_CREDIT_TYPE_ID,\r\nWI.SOURCE_HEADER_ID,\r\nWI.SPLIT_PERCENT,\r\nWI.LAST_UPDATE_DATE,\r\nWI.CREATION_DATE\r\nFROM\r\n$$STGDB.WI_SO_CR_ASGN_FOR_APPLD_TRX WI\r\nWHERE\r\nNOT EXISTS\r\n(SELECT 1 FROM \r\n$$ETLVWDB.EL_SALES_REP ESR,\r\n$$ETLVWDB.EL_SALES_TERRITORY EST,\r\n$$ETLVWDB.EL_SALES_CREDIT_TYPES ESCT,\r\n$$SLSORDVWDB.N_SALES_ORDER_TV NSO\r\nWHERE\r\nWI.SALESREP_ID=ESR.SALES_REP_ID\r\nAND WI.GLOBAL_NAME= ESR.GLOBAL_NAME\r\nAND WI.TERRITORY_ID=EST.TERRITORY_ID\r\nAND WI.GLOBAL_NAME= EST.GLOBAL_NAME\r\nAND WI.SALES_CREDIT_TYPE_ID=ESCT.SK_CREDIT_TYPE_ID\r\nAND WI.GLOBAL_NAME= ESCT.GLOBAL_NAME\r\nAND WI.SOURCE_HEADER_ID=NSO.SK_SALES_ORDER_HEADER_ID_INT       \r\nAND CASE WHEN WI.GLOBAL_NAME ='UO' THEN 'QTC' \r\nWHEN WI.GLOBAL_NAME ='BO' THEN 'BV' ELSE NULL END=NSO.SS_CODE)",
