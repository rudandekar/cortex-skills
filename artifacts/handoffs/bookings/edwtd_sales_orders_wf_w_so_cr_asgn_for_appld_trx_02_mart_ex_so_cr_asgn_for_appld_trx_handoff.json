      "attributes": {
        "Sql Query": "SELECT \r\nQ1.SO_CREDIT_ASGN_APPLIED_KEY, \r\nQ1.SOURCE_DELETED_FLG,\r\nQ1.SALES_COMMISSION_PCT, \r\nQ1.SOURCE_LAST_UPDATE_DTM, \r\nQ1.SOURCE_CREATE_DTM,\r\nQ1.SALES_ORDER_KEY,  \r\nQ1.SALES_REP_NUM, \r\nQ1.SALES_TERRITORY_KEY, \r\nQ1.SALES_CREDIT_TYPE_CD, \r\nQ1.SK_HEADER_SEQUENCE_ID_INT, \r\nQ1.SS_CD, \r\nQ1.EDW_CREATE_DTM, \r\nQ1.EDW_CREATE_USER, \r\nQ1.EDW_UPDATE_DTM, \r\nQ1.EDW_UPDATE_USER,\r\n'I' ACTION_CODE,\r\n(CASE WHEN NSATRX.SO_CREDIT_ASGN_APPLIED_KEY IS NOT NULL\r\nTHEN 'U' ELSE 'I' END) AS DML_TYPE\r\nFROM\r\n(SELECT \r\nSM.SO_CREDIT_ASGN_APPLIED_KEY SO_CREDIT_ASGN_APPLIED_KEY, \r\nWI.SOURCE_DELETED_FLG,\r\nWI.SPLIT_PERCENT SALES_COMMISSION_PCT, \r\nWI.LAST_UPDATE_DATE SOURCE_LAST_UPDATE_DTM, \r\nWI.CREATION_DATE SOURCE_CREATE_DTM, \r\nNSO.SALES_ORDER_KEY SALES_ORDER_KEY, \r\nESR.SALES_REP_NUMBER SALES_REP_NUM, \r\nEST.SALES_TERRITORY_KEY SALES_TERRITORY_KEY, \r\nESCT.NAME SALES_CREDIT_TYPE_CD, \r\nWI.HEADER_SEQ_ID SK_HEADER_SEQUENCE_ID_INT, \r\nCASE WHEN WI.GLOBAL_NAME ='UO' THEN 'QTC' \r\n              WHEN WI.GLOBAL_NAME ='BO' THEN 'BV' END AS SS_CD, \r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM, \r\n'USER' EDW_CREATE_USER, \r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM, \r\n'USER' EDW_UPDATE_USER\r\nFROM\r\n$$STGDB.WI_SO_CR_ASGN_FOR_APPLD_TRX WI\r\nINNER JOIN $$TRANSLATIONDB.SM_SO_CR_ASGN_APLD_TRX SM\r\nON \r\nSM.SK_HEADER_SEQUENCE_ID_INT=WI.HEADER_SEQ_ID\r\nAND \r\nCASE WHEN SM.SS_CD='QTC' THEN 'UO' WHEN SM.SS_CD='BV' THEN 'BO' END =WI.GLOBAL_NAME\r\nINNER JOIN $$ETLVWDB.EL_SALES_REP ESR\r\nON WI.SALESREP_ID=ESR.SALES_REP_ID\r\nAND WI.GLOBAL_NAME= ESR.GLOBAL_NAME\r\nINNER JOIN $$ETLVWDB.EL_SALES_TERRITORY EST\r\nON WI.TERRITORY_ID=EST.TERRITORY_ID\r\nAND WI.GLOBAL_NAME= EST.GLOBAL_NAME\r\nINNER JOIN $$ETLVWDB.EL_SALES_CREDIT_TYPES ESCT\r\nON WI.SALES_CREDIT_TYPE_ID=ESCT.SK_CREDIT_TYPE_ID\r\nAND WI.GLOBAL_NAME= ESCT.GLOBAL_NAME\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_TV NSO\r\nON WI.SOURCE_HEADER_ID=NSO.SK_SALES_ORDER_HEADER_ID_INT       \r\nAND CASE WHEN WI.GLOBAL_NAME ='UO' THEN 'QTC' \r\nWHEN WI.GLOBAL_NAME ='BO' THEN 'BV' ELSE NULL END  = NSO.SS_CODE\r\nUNION ALL\r\nSELECT \r\nSM.SO_CREDIT_ASGN_APPLIED_KEY SO_CREDIT_ASGN_APPLIED_KEY, \r\nEX.SOURCE_DELETED_FLG,\r\nEX.SPLIT_PERCENT SALES_COMMISSION_PCT, \r\nEX.LAST_UPDATE_DATE SOURCE_LAST_UPDATE_DTM, \r\nEX.CREATION_DATE SOURCE_CREATE_DTM, \r\nNSO.SALES_ORDER_KEY SALES_ORDER_KEY, \r\nESR.SALES_REP_NUMBER SALES_REP_NUM, \r\nEST.SALES_TERRITORY_KEY SALES_TERRITORY_KEY, \r\nESCT.NAME SALES_CREDIT_TYPE_CD, \r\nEX.HEADER_SEQ_ID SK_HEADER_SEQUENCE_ID_INT, \r\nCASE WHEN EX.GLOBAL_NAME ='UO' THEN 'QTC' \r\n              WHEN EX.GLOBAL_NAME ='BO' THEN 'BV' END  SS_CD, \r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM, \r\n'USER' EDW_CREATE_USER, \r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM, \r\n'USER' EDW_UPDATE_USER\r\nFROM\r\n$$EXCEPDB.EX_SO_CR_ASGN_FOR_APPLD_TRX EX\r\nINNER JOIN $$TRANSLATIONDB.SM_SO_CR_ASGN_APLD_TRX SM\r\nON \r\nSM.SK_HEADER_SEQUENCE_ID_INT=EX.HEADER_SEQ_ID\r\nAND CASE WHEN SM.SS_CD='QTC' THEN 'UO' WHEN SM.SS_CD='BV' THEN 'BO' END=EX.GLOBAL_NAME\r\nINNER JOIN $$ETLVWDB.EL_SALES_REP ESR\r\nON EX.SALESREP_ID=ESR.SALES_REP_ID\r\nAND EX.GLOBAL_NAME= ESR.GLOBAL_NAME\r\nINNER JOIN $$ETLVWDB.EL_SALES_TERRITORY EST\r\nON EX.TERRITORY_ID=EST.TERRITORY_ID\r\nAND EX.GLOBAL_NAME= EST.GLOBAL_NAME\r\nINNER JOIN $$ETLVWDB.EL_SALES_CREDIT_TYPES ESCT\r\nON EX.SALES_CREDIT_TYPE_ID=ESCT.SK_CREDIT_TYPE_ID\r\nAND EX.GLOBAL_NAME= ESCT.GLOBAL_NAME\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_TV NSO\r\nON EX.SOURCE_HEADER_ID=NSO.SK_SALES_ORDER_HEADER_ID_INT       \r\nAND CASE WHEN EX.GLOBAL_NAME ='UO' THEN 'QTC' \r\nWHEN EX.GLOBAL_NAME ='BO' THEN 'BV' ELSE NULL END  = NSO.SS_CODE)Q1\r\nLEFT JOIN\r\n$$SLSORDDB.N_SO_CR_ASGN_FOR_APPLD_TRX NSATRX\r\nON Q1.SO_CREDIT_ASGN_APPLIED_KEY = NSATRX.SO_CREDIT_ASGN_APPLIED_KEY",
        "User Defined Join": "",
