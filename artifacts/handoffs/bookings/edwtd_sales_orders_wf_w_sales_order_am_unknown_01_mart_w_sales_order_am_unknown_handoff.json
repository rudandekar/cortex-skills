      "attributes": {
        "Sql Query": "SELECT\r\nNSO.SALES_ORDER_KEY,\r\nSTO.ATTRIBUTE11 AS SO_AM_UNKNOWN_000_CD,\r\nSTO.ATTRIBUTE18 AS SO_AM_UNKNOWN_001_CD,\r\nSTO.ATTRIBUTE20 AS SO_AM_UNKNOWN_002_CD,\r\nSTO.ATTRIBUTE5 AS SO_AM_UNKNOWN_003_CD,\r\nCURRENT_TIMESTAMP(0),\r\n   USER,\r\n   CURRENT_TIMESTAMP(0),\r\n   USER,\r\n   'I',\r\n   CASE WHEN NSOUN.SALES_ORDER_KEY IS NOT NULL THEN 'U' ELSE 'I'\r\n   END DML_TYPE,\r\nESOU.ATTRIBUTE6 AS SO_AM_UNKNOWN_004_CD\r\nfrom $$STGDB.ST_OM_XXCCA_OE_ORD_HEADERS STO\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_TV NSO\r\nON (NSO.SK_SALES_ORDER_HEADER_ID_INT = STO.HEADER_ID\r\nAND NSO.SS_CODE =(CASE WHEN STO.GLOBAL_NAME='UO' THEN 'QTC' \r\n                       WHEN STO.GLOBAL_NAME='BO' THEN 'BV' END))\r\nINNER JOIN $$ETLVWDB.EL_SALES_ORDER_UNKNOWN ESOU\r\nON ESOU.HEADER_ID=STO.HEADER_ID AND ESOU.GLOBAL_NAME=STO.GLOBAL_NAME\t\t\t\t\t   \r\nLEFT OUTER JOIN $$SLSORDVWDB.N_SALES_ORDER_AM_UNKNOWN NSOUN\r\nON NSOUN.SALES_ORDER_KEY= NSO.SALES_ORDER_KEY",
