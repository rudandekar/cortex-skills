      "attributes": {
        "Sql Query": "SELECT \r\n ST_XXFSAM_EAC_GROUP_MEM_SAV_V.EAC_GROUP_DTL_ID, \r\n COALESCE(SAV.SALES_ACCOUNT_GROUP_PARTY_KEY,-999),\r\n ST_XXFSAM_EAC_GROUP_MEM_SAV_V.EAC_GROUP_ID, \r\n COALESCE(ST_XXFSAM_EAC_GROUP_MEM_SAV_V.EFFECTIVE_DATE,CAST('3500-01-01' AS DATE)), \r\n COALESCE(ST_XXFSAM_EAC_GROUP_MEM_SAV_V.EXPIRATION_DATE,CAST('3500-01-01' AS DATE)), \r\n COALESCE(ST_XXFSAM_EAC_GROUP_MEM_SAV_V.LAST_UPDATE_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))),\r\n COALESCE(ST_XXFSAM_EAC_GROUP_MEM_SAV_V.LAST_UPDATE_DATE,CAST('3500-01-01' AS DATE)) AS DV_SRC_LAST_UPTD_DT,\r\n COALESCE(NCWP_CRTD.CISCO_WORKER_PARTY_KEY,-999) AS CRTD_BY_CSCO_WRKR_PRTY_KEY,\r\n ST_XXFSAM_EAC_GROUP_MEM_SAV_V.ORGANIZATION_ID, \r\n COALESCE(ST_XXFSAM_EAC_GROUP_MEM_SAV_V.STATUS_NAME,'UNKNOWN'), \r\n COALESCE(ST_XXFSAM_EAC_GROUP_MEM_SAV_V.CREATION_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))),\r\n COALESCE(ST_XXFSAM_EAC_GROUP_MEM_SAV_V.CREATION_DATE,CAST('3500-01-01' AS DATE)) AS DV_SRC_CREATED_DT,\r\n COALESCE(NCWP_UPLD.CISCO_WORKER_PARTY_KEY,-999) AS SRC_LST_UPD_CSCO_WRKR_PRTY_KEY,\r\n CURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\n  USER EDW_CREATE_USER,\r\n  CURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\n'I' ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM\r\n $$STGDB.ST_XXFSAM_EAC_GROUP_MEM_SAV_V ST_XXFSAM_EAC_GROUP_MEM_SAV_V\r\n INNER JOIN $$SLSORDVWDB.N_EAC_GROUP NAG\r\n ON NAG.BK_EAC_GROUP_ID = ST_XXFSAM_EAC_GROUP_MEM_SAV_V.EAC_GROUP_ID\r\n INNER JOIN $$SLSORDVWDB.N_EAC_ORG ORG\r\n ON ORG.BK_EAC_ORG_ID = ST_XXFSAM_EAC_GROUP_MEM_SAV_V.ORGANIZATION_ID\r\n LEFT JOIN $$COMREFVWDB.MT_SLS_ACCT_GROUP_SAV_PARTY SAV\r\n ON SAV.BK_SALES_ACCOUNT_ID_INT = COALESCE(ST_XXFSAM_EAC_GROUP_MEM_SAV_V.SAV_ID,-9999) \r\n LEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP_CRTD\r\n\tON COALESCE(ST_XXFSAM_EAC_GROUP_MEM_SAV_V.CREATED_BY,'UNKNOWN') = NCWP_CRTD.CEC_ID AND NCWP_CRTD.CISCO_WORKER_PARTY_KEY<>-999\r\n LEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP_UPLD\r\n\tON COALESCE(ST_XXFSAM_EAC_GROUP_MEM_SAV_V.LAST_UPDATED_BY,'UNKNOWN') = NCWP_UPLD.CEC_ID AND NCWP_UPLD.CISCO_WORKER_PARTY_KEY<>-999",
        "User Defined Join": "",
