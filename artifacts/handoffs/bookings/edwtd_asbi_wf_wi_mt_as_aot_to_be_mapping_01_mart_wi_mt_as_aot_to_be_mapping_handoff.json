      "attributes": {
        "Sql Query": "SELECT PRDT_BKGS_MIX.*,'N' AS ALLOCATION_FLG\r\nfrom (\r\nSELECT \r\nA.L3_SALES_TERRITORY_NAME_CODE,\r\nA.BK_AS_ARCHITECTURE_NAME,\r\nA.BK_AS_BUSINESS_SERVICE_NAME,\r\nA.BK_AS_TECHNOLOGY_NAME,\r\nB.BK_SUB_BUSINESS_ENTITY_NAME  ,\r\nB.BK_BUSINESS_ENTITY_NAME ,\r\nCOALESCE(((CAST(A.TOTAL_CNT AS FLOAT)/CAST (B.TOTAL_CNT AS FLOAT))*100),1) AS ALLOCATION_PERECENTAGE\r\nFROM \r\n(SELECT \r\nA.L3_SALES_TERRITORY_NAME_CODE,\r\nA.BK_AS_ARCHITECTURE_NAME,\r\nA.BK_AS_BUSINESS_SERVICE_NAME,\r\nA.BK_AS_TECHNOLOGY_NAME,\r\nCOUNT(* ) AS TOTAL_CNT\r\nFROM  \r\n$$STGDB.WI_L3_AOT_DIFF  A\r\nGROUP BY 1,2,3,4) A\r\nINNER JOIN\r\n(SELECT \r\nA.L3_SALES_TERRITORY_NAME_CODE,\r\nA.BK_AS_ARCHITECTURE_NAME,\r\nA.BK_AS_BUSINESS_SERVICE_NAME,\r\nA.BK_AS_TECHNOLOGY_NAME,\r\nB.BK_SUB_BUSINESS_ENTITY_NAME,\r\nB.BK_BUSINESS_ENTITY_NAME,\r\nCOUNT(* ) OVER (PARTITION BY A.L3_SALES_TERRITORY_NAME_CODE,\r\nA.BK_AS_ARCHITECTURE_NAME,\r\nA.BK_AS_BUSINESS_SERVICE_NAME,\r\nA.BK_AS_TECHNOLOGY_NAME,\r\nB.BK_BUSINESS_ENTITY_NAME) AS TOTAL_CNT\r\nFROM  \r\n$$STGDB.WI_L3_AOT_DIFF  A\r\nINNER JOIN  $$STGDB.WI_L3_AOT_ALL  B\r\nON  A.L3_SALES_TERRITORY_NAME_CODE       =B.L3_SALES_TERRITORY_NAME_CODE       \r\nAND A.BK_AS_ARCHITECTURE_NAME   =B.BK_AS_ARCHITECTURE_NAME   \r\nAND A.BK_AS_BUSINESS_SERVICE_NAME   =B.BK_AS_BUSINESS_SERVICE_NAME   \r\nAND A.BK_AS_TECHNOLOGY_NAME           =B.BK_AS_TECHNOLOGY_NAME  \r\nGROUP BY 1,2,3,4 ,5,6\r\n) B\r\nON  A.L3_SALES_TERRITORY_NAME_CODE       =B.L3_SALES_TERRITORY_NAME_CODE           \r\nAND A.BK_AS_ARCHITECTURE_NAME   =B.BK_AS_ARCHITECTURE_NAME   \r\nAND A. BK_AS_BUSINESS_SERVICE_NAME   =B.BK_AS_BUSINESS_SERVICE_NAME   \r\nAND A.BK_AS_TECHNOLOGY_NAME           =B.BK_AS_TECHNOLOGY_NAME    \r\n ) PRDT_BKGS_MIX \r\nGROUP BY 1,2,3,4,5,6,7,8",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
