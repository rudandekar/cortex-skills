      "attributes": {
        "Sql Query": "SELECT  \r\nL3_SALES_TERRITORY_NAME_CODE,\r\nBK_AS_ARCHITECTURE_NAME,\r\nBK_AS_BUSINESS_SERVICE_NAME,\r\nBK_AS_TECHNOLOGY_NAME,\r\nBK_SUB_BUSINESS_ENTITY_NAME,\r\nBK_BUSINESS_ENTITY_NAME,\r\nPRODUCT_BKG_MIX_PERCENT AS DV_ALLOCATION_PERCENTAGE,\r\n'N' AS ALLOCATION_FLG\r\nFROM \r\n (\r\nSELECT \r\nA.L3_SALES_TERRITORY_NAME_CODE,\r\nA.BK_AS_ARCHITECTURE_NAME,\r\nA.BK_AS_BUSINESS_SERVICE_NAME,\r\nA.BK_AS_TECHNOLOGY_NAME,\r\nA.BK_SUB_BUSINESS_ENTITY_NAME,\r\nA.BK_BUSINESS_ENTITY_NAME,\r\nCOALESCE (((A.TOTAL_BOOKINGS/(NULLIFZERO(B.TOTAL_BOOKINGS)))*100) ,100) AS PRODUCT_BKG_MIX_PERCENT \r\nFROM \r\n(\r\nSELECT\r\nMAPPING.BK_BUSINESS_ENTITY_NAME,\r\nMAPPING.BK_SUB_BUSINESS_ENTITY_NAME,\r\nL3_SALES_TERRITORY_NAME_CODE ,\r\nBK_AS_ARCHITECTURE_NAME,\r\nBK_AS_BUSINESS_SERVICE_NAME,\r\nBK_AS_TECHNOLOGY_NAME,\r\nSUM(DD_COMP_US_NET_PRICE_AMOUNT*PRDT_FAMILY_ALLOCATION_PCT) AS TOTAL_BOOKINGS /*Modified as part of Jun 28th 2020 release*/\r\nFROM \r\n$$SLSORDVWDB.MT_RSTD_BKGS_MEASURE BKGS\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDY\r\nON BKGS.BOOKINGS_PROCESS_DATE = FDY.CALENDAR_DATE \r\nINNER JOIN $$COMREFVWDB.MT_BE_HIER_PRDT_FAMILY_ALLOC BE_HIER\r\nON FDY.DV_FISCAL_QUARTER_ID = BE_HIER.DV_FISCAL_QUARTER_ID\r\nAND  BKGS.PRODUCT_KEY = BE_HIER.ITEM_KEY\r\nAND BE_HIER.BK_BUSINESS_ENTITY_TYPE_CD ='I'\r\nINNER JOIN $$COMREFVWDB.R_SALES_HIERARCHY_FIN SLS_HIER /*Modified as part of Jun 28th 2020 release*/\r\nON BKGS.SALES_TERRITORY_KEY = SLS_HIER.SALES_TERRITORY_KEY\r\nINNER JOIN $$SERVICEVWDB.N_AOT_TO_SUB_BUSI_ENTITY_ALLOC  MAPPING\r\nON TRIM(MAPPING.BK_BUSINESS_ENTITY_NAME)=TRIM(BE_HIER.BK_BUSINESS_ENTITY_NAME)\r\nAND TRIM(MAPPING.BK_SUB_BUSINESS_ENTITY_NAME)=TRIM(BE_HIER.BK_SUB_BUSINESS_ENTITY_NAME) \r\nWHERE   \r\nMAPPING.BK_ALLOC_RULE_NAME ='PRODUCT_BKGS_MIX' AND\r\nFDY.FISCAL_YEAR_AGE IN (1,2,3) AND\r\nBKGS.CORPORATE_BOOKINGS_FLG ='Y' AND \r\nBKGS.DV_ATTRIBUTION_CD  IN ('STANDALONE','ATTRIBUTED') AND\r\nBKGS.SERVICE_FLG ='N' AND\r\nBKGS.DV_REVENUE_RECOGNITION_FLG ='Y' AND \r\nSLS_HIER.SALES_TERRITORY_TYPE_CODE = 'CORP. REVENUE'  \r\nGROUP BY 1,2,3,4,5,6\r\n) A\r\nINNER JOIN \r\n(\r\nSELECT \r\nL3_SALES_TERRITORY_NAME_CODE,\r\nBK_AS_ARCHITECTURE_NAME,\r\nBK_AS_BUSINESS_SERVICE_NAME,\r\nBK_AS_TECHNOLOGY_NAME,\r\nSUM(DD_COMP_US_NET_PRICE_AMOUNT*PRDT_FAMILY_ALLOCATION_PCT) AS TOTAL_BOOKINGS /*Modified as part of Jun 28th 2020 release*/\r\nFROM \r\n$$SLSORDVWDB.MT_RSTD_BKGS_MEASURE BKGS\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDY\r\nON BKGS.BOOKINGS_PROCESS_DATE = FDY.CALENDAR_DATE\r\nINNER JOIN $$COMREFVWDB.MT_BE_HIER_PRDT_FAMILY_ALLOC BE_HIER\r\nON FDY.DV_FISCAL_QUARTER_ID = BE_HIER.DV_FISCAL_QUARTER_ID\r\nAND  BKGS.PRODUCT_KEY = BE_HIER.ITEM_KEY\r\nAND BE_HIER.BK_BUSINESS_ENTITY_TYPE_CD ='I'\r\nINNER JOIN  $$COMREFVWDB.R_SALES_HIERARCHY_FIN SLS_HIER /*Modified as part of Jun 28th 2020 release*/\r\nON BKGS.SALES_TERRITORY_KEY = SLS_HIER.SALES_TERRITORY_KEY\r\nINNER JOIN $$SERVICEVWDB.N_AOT_TO_SUB_BUSI_ENTITY_ALLOC  MAPPING\r\nON TRIM(MAPPING.BK_BUSINESS_ENTITY_NAME)=TRIM(BE_HIER.BK_BUSINESS_ENTITY_NAME)\r\nAND TRIM(MAPPING.BK_SUB_BUSINESS_ENTITY_NAME)=TRIM(BE_HIER.BK_SUB_BUSINESS_ENTITY_NAME) \r\n\r\nWHERE \r\nMAPPING.BK_ALLOC_RULE_NAME ='PRODUCT_BKGS_MIX' and \r\nFDY.FISCAL_YEAR_AGE IN (1,2,3) AND \r\nBKGS.CORPORATE_BOOKINGS_FLG ='Y' AND \r\nBKGS.DV_ATTRIBUTION_CD IN ('STANDALONE','ATTRIBUTED') AND\r\nBKGS.SERVICE_FLG ='N' AND\r\nBKGS.DV_REVENUE_RECOGNITION_FLG ='Y' AND \r\nSLS_HIER.SALES_TERRITORY_TYPE_CODE = 'CORP. REVENUE'\r\nGROUP BY 1,2,3,4\r\n) B\r\nON A.L3_SALES_TERRITORY_NAME_CODE= B.L3_SALES_TERRITORY_NAME_CODE \r\nAND A.BK_AS_ARCHITECTURE_NAME=B.BK_AS_ARCHITECTURE_NAME\r\nAND A.BK_AS_BUSINESS_SERVICE_NAME=B.BK_AS_BUSINESS_SERVICE_NAME\r\nAND A.BK_AS_TECHNOLOGY_NAME=B.BK_AS_TECHNOLOGY_NAME\r\n) PRDT_BKGS_MIX",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
