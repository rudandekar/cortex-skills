      "attributes": {
        "Sql Query": "SELECT  \r\n NP.BK_PRODUCT_ID AS CL_SERVICE_LEVEL\r\n,NCL.SVC_CNTRCT_LN_TECH_SVCS_KEY  \r\n,NCL.IP_KEY                        \r\n,NCL.BK_SERVICE_CONTRACT_NUM      \r\n,NCL.SERVICE_STATUS_CD             \r\n,NCL.MAINTENANCE_ORDER_NUM         \r\n,NCL.MAINTENANCE_LIST_LOCAL_AMT    \r\n,ABS(NCL.MAINTENANCE_NET_LOCAL_AMT)    \r\n,NCL.SK_ID_LINT                    \r\n,NCL.SERVICE_PRODUCT_KEY           \r\n,NCL.SOURCE_CREATE_DTM             \r\n,NCL.SOURCE_APPLICATION_NAME       \r\n,NCL.CASE_DETAIL_TXT               \r\n,NCL.SUMMARY_QUOTE_CASE_NUM        \r\n,NCL.SALES_MOTION_CD        \r\n,NCL.BK_SVC_CNTRCT_LINE_START_DTM\r\n--,NCL.SVC_CNTRCT_LINE_END_DTM\r\n,CASE WHEN NCL.TERMINATED_DTM IS NOT NULL AND NCL.TERMINATED_DTM <>'1900-01-01 00:00:00' \r\nTHEN NCL.TERMINATED_DTM ELSE NCL.SVC_CNTRCT_LINE_END_DTM END AS SVC_CNTRCT_LINE_END_DTM -- added as part DAY 1 FY22\r\n,NCL.TERMINATED_DTM\r\n,NCL.EDW_UPDATE_USER\r\n,NCL.EDW_CREATE_DTM\r\n,NCL.EDW_UPDATE_DTM\r\n/*,CASE WHEN SHIP_HIER.HQ_CUSTOMER_PARTY_KEY IS NULL THEN -999 ELSE SHIP_HIER.HQ_CUSTOMER_PARTY_KEY END AS CL_HQ_KEY*/\r\n/*Added as part of May 19 Rel change in HQ Logic*/\r\n--,CASE WHEN SHIP_HIER.HQ_BRANCH_CODE='HQ' THEN SHIP_HIER.PARTY_KEY ELSE SHIP_HIER.HQ_CUSTOMER_PARTY_KEY END AS CL_HQ_KEY\r\n--,CX.CX_CUSTOMER_BU_ID AS CL_HQ_KEY \r\n,CX.CX_CUSTOMER_BU_ID AS CX_CUSTOMER_BU_ID --ADDED AS PART OF DAY1 FY22 \r\n,CASE WHEN IP.SK_INVENTORY_ITEM_ID_INT IS NULL THEN -999 ELSE IP.SK_INVENTORY_ITEM_ID_INT END AS  CL_INVENTORY_ITEM_ID ----03/04/2019\r\n,IP.BK_Product_ID AS Covered_Product_ID --03/04/2019\r\n,UPT.UPGRADE_PRODUCT_NUMBER --03/04/2019\r\n,' ' AS REASON_CODE ----ADDED AS PART OF DAY1 FY22 \r\nFROM \r\n$$SERVICEVWDB.N_SVC_CNTRCT_LN_TECH_SERVICES NCL\r\nINNER JOIN $$IBVWDB.N_INSTALLED_PRODUCT  I ON (I.IP_KEY=NCL.IP_KEY AND NCL.IP_KEY>0)\r\nINNER JOIN $$COMREFVWDB.R_PRODUCTS NP\r\nON NP.ITEM_KEY = NCL.SERVICE_PRODUCT_KEY \r\nINNER JOIN $$COMREFVWDB.R_PRODUCTS IP --03/04/2019\r\nON IP.ITEM_KEY = I.GOODS_PRODUCT_KEY --03/04/2019 \r\nLEFT JOIN $$STGDB.ST_UPT_CONTRACT_UPG_MAPPING UPT --03/04/2019\r\nON IP.BK_Product_ID = UPT.UPGRADE_PRODUCT_MAPPING   /*Join condition changed as part of Aug16 2020 Rel*/\r\nLEFT JOIN $$COMREFVWDB.MT_ERP_POS_SHIPTO  SHIP ON I.INSTALLED_CUSTOMER_PARTY_KEY =SHIP.SHIP_TO_CUSTOMER_KEY\r\nLEFT JOIN $$COMREFVWDB.MT_ERP_POS_SHIPTO_HIER  SHIP_HIER ON SHIP_HIER.SHIP_TO_CUSTOMER_KEY=SHIP.SHIP_TO_CUSTOMER_KEY\r\nLEFT JOIN $$COMREFVWDB.MT_CXCUST_BU_PARTY_MAPPING CX ON SHIP_HIER.PARTY_SSOT_PARTY_ID_INT=CX.CR_PARTY_ID\r\nWHERE\r\nNCL.MAINTENANCE_ORDER_NUM IN ( SEL DISTINCT CAST(SOL_BK_SO_NUMBER_INT AS VARCHAR(40)) FROM  $$STGDB.WI_SUMMARY_QUOTE_SWSS_1 F )\r\nAND NCL.SERVICE_STATUS_CD NOT IN ('TERMINATED')\r\nAND NP.BK_PRODUCT_ID  IN (SELECT DISTINCT GSPA.BK_PRDT_SUBGROUP_ID FROM $$SERVICEVWDB.N_GENERIC_SVC_PRDT_ATTR GSPA\r\nWHERE BK_GSP_ATTR_NAME = 'SW SERVICE CATEGORY'\r\n)\r\nAND /*Added below filter as part of Aug16 2020 Rel*/\r\nNP.BK_PRODUCT_ID NOT IN\r\n(SELECT DISTINCT BK_PRODUCT_SUBGROUP_ID FROM $$COMREFVWDB.MT_SVC_FINANCE_HIERARCHY H\r\nWHERE\r\n1=1\r\nAND BK_ALLOCATED_SERVC_GROUP_ID IN ('AS CORE')\r\nAND ALLOCATION_PERCENTAGE<1)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
  ],
