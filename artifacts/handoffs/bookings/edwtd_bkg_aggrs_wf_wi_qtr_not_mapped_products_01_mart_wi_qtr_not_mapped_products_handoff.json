      ],
      "attributes": {
        "Sql Query": "SELECT \r\nITEM_KEY \r\nFROM $$COMREFVWDB.MT_BE_HIER_PRDT_FAMILY_ALLOC  BE\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM \r\nON RFM.DV_FISCAL_QUARTER_ID = BE.DV_FISCAL_QUARTER_ID\r\nINNER JOIN $$STGDB.WI_QTR_SRVC_BKGS_PERIOD_CNTL CNTL \r\nON CNTL.FISCAL_YEAR_MTH_NUMBER_INT = RFM.FISCAL_YEAR_MONTH_INT \r\nWHERE BK_BUSINESS_ENTITY_NAME <> 'UNKNOWN'\r\nGROUP BY 1;\r\n\r\n/*SELECT RP.ITEM_KEY\r\nFROM $$COMREFVWDB.R_PRODUCTS_FIN RP\r\nINNER JOIN $$COMREFVWDB.N_TMS_CORP_PRODUCT_ALLOC  ALLOC\r\nON(RP.ITEM_KEY=ALLOC.ITEM_KEY )\r\nINNER JOIN $$COMREFVWDB.R_TECH_MKT_SEGMENT RTMS\r\nON(RTMS.TECHNOLOGY_MARKET_SEGMENT_KEY=ALLOC.TECHNOLOGY_MARKET_SEGMENT_KEY\r\nAND RTMS.HIERARCHY_TYPE='TMS_CORPORATE'\r\nAND RTMS.L1_TECHNOLOGY_MKT_SEGMENT_NAME IN('Corp-NOT Mapped','Corp-NOT Mapped EVER','Corp-Miscellaneous '))\r\nGROUP BY RP.ITEM_KEY\r\nUNION\r\nSELECT RP.ITEM_KEY\r\nFROM $$COMREFVWDB.R_PRODUCTS_FIN  RP\r\nINNER JOIN $$COMREFVWDB.N_PRD_ARCH_PLY_HIER_ND_ALOC NPARCH\r\nON(NPARCH.PRODUCT_KEY=RP.ITEM_KEY)\r\nINNER JOIN  $$COMREFVWDB.MT_ARCHITECTURE_PLAY_HIER  MT\r\nON(NPARCH.BK_ARCH_PLAY_HIER_NODE_CD=MT.BK_ARCH_PLAY_HIER_NODE_CD  AND MT.L1_ARCH_PLAY_NODE_NAME  IN ('Not Mapped Ever') )\r\n INNER JOIN $$STGDB.WI_QTR_SRVC_BKGS_PERIOD_CNTL WISBPC\r\n     ON(MT.DV_FISCAL_YR_MTH_NUM_INT=WISBPC.FISCAL_YEAR_MTH_NUMBER_INT)\r\nGROUP BY RP.ITEM_KEY*/",
