      "attributes": {
        "Sql Query": "SELECT \r\nNBM.BOOKINGS_MEASURE_KEY,\r\nNBM.SALES_ORDER_KEY,\r\nNBM.SALES_ORDER_LINE_KEY,\r\nNBM.PRODUCT_KEY,\r\nAR_TRX_LINE_KEY,\r\nAR_TRX_KEY,\r\nNBM.SALES_TERRITORY_KEY,\r\nNBM.SALES_REP_NUMBER,\r\nBOOKINGS_PROCESS_DATE,\r\nNBM.DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\nBK_POS_TRANSACTION_ID_INT,\r\nBK_SALES_ADJ_LINE_NUMBER_INT,\r\nBK_SALES_ADJ_NUMBER_INT,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nFORWARD_REVERSE_FLG,\r\nDISTRIBUTOR_OFFSET_FLG,\r\nNBM.DD_COMP_US_NET_PRICE_AMOUNT,\r\nNBM.DD_COMP_US_LIST_PRICE_AMOUNT,\r\nNBM.DD_COMP_US_COST_AMOUNT,\r\nNBM.DD_EXTENDED_QUANTITY,\r\nNBM.DD_COMP_US_STANDARD_PRICE_AMT,\r\nEDW_CREATE_DATETIME,\r\nEDW_UPDATE_DATETIME,\r\nBOOKINGS_SPLIT_PCT,\r\nNBM.DV_SALES_ORDER_LINE_KEY,\r\nSO_SBSCRPTN_ITM_SLS_TRX_KEY,\r\nSERVICE_FLG,\r\nRANK() OVER(PARTITION BY NBM.DV_SALES_ORDER_LINE_KEY ORDER BY MDNBT.PROCESS_DATE DESC ) RK,\r\nNBM.SOURCE_REP_ANNUAL_USD_AMT,\r\nNBM.DV_ANNUALIZED_US_NET_AMT, \r\nNBM.DV_MULTIYEAR_US_NET_AMT,\r\nNBM.SK_OFFER_ATTRIBUTION_ID_INT,\r\nNBM.SK_SALES_MOTION_ATTRIB_KEY\r\nFROM (SEL * FROM $$SLSORDVWDB.N_BOOKINGS_MEASURE \r\n\tWHERE CANCEL_CODE<>'Lost Order' AND BOOKINGS_MEASURE_KEY >0\r\n\tAND DV_SALES_ORDER_LINE_KEY > 0\r\n\tAND BKGS_MEASURE_TRANS_TYPE_CODE ='ERP' \r\n\tAND EDW_CREATE_DATETIME> '$$LastExtractDate'\r\n\t)NBM\r\nINNER JOIN $$STGDB.WI_MT_DRVD_NRT_BKG_TRX MDNBT\r\nON MDNBT.BOOKINGS_MEASURE_KEY = NBM.BOOKINGS_MEASURE_KEY\r\nINNER JOIN  $$COMREFVWDB.R_SALES_HIERARCHY RSH  /* added 13-08 */\r\nON NBM.SALES_TERRITORY_KEY   =   RSH.SALES_TERRITORY_KEY\r\nAND RSH.L1_SALES_TERRITORY_NAME_CODE <>  'WW Distribution'",
        "User Defined Join": "",
        "Source Filter": "",
