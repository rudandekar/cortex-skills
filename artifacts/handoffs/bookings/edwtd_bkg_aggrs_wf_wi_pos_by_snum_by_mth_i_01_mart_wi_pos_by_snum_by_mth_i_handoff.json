      "attributes": {
        "Sql Query": "SELECT\r\n SUM(NPOS.PRODUCT_NET_PRICE_AMOUNT         ) AS PRODUCT_NET_PRICE_AMOUNT\r\n,SUM(NPOS.POS_TRX_LINE_PRODUCT_QUANT      ) AS POS_TRX_LINE_PRODUCT_QUANT\r\n,SUM(NPOS.VLDTD_NET_UNIT_PRICE_USD_AMT          ) AS VLDTD_NET_UNIT_PRICE_USD_AMT\r\n,SUM(NPOS.VALUATION_PRICE_USD_AMOUNT              )       AS VALUATION_PRICE_USD_AMOUNT\r\n,NPOS.PRODUCT_KEY      \r\n,NPOS.BK_SHIP_TO_WIPS_SITE_USE_KEY  \r\n,NPOS.BK_BILL_TO_WIPS_SITE_USE_KEY  \r\n,NPOS.BK_SOLD_TO_WIPS_SITE_USE_KEY              \r\n,NPOS.BK_END_USER_WIPS_SITE_USE_KEY   \r\n ,NPOS.SOLD_TO_SALES_TERRITORY_KEY      \r\n,NPOS.BK_WIPS_ORIGINATOR_ID_INT           \r\n ,FDY.FISCAL_YEAR_MONTH_INT      \r\n ,NPOS.PARTNER_SITE_PARTY_KEY\r\n,NPOS.POS_TRX_LINE_POSTED_DATE  \r\n,NPOS.SECOND_SOURCE_FLAG\r\n,NPOS_ITEM.SCRUBBED_SERIAL_NUMBER\r\n,NPOS.POS_TRX_LINE_ACTIVE_FLAG\r\n,NPOS.POS_SOURCE_TYPE\r\n,SUM(NPOS.BASE_LIST_UNIT_PROD_PRICE_AMT)\r\n,SUM(NPOS.RPTD_UNIT_PRICE_USD_AMOUNT)\r\n,NPOS.BK_POS_TRANSACTION_ID_INT\r\n,NPOS.DISTRIBUTOR_REPORTED_DEAL_ID\r\n,NPOS.BK_DEAL_ID\r\n,NPOS.TRANSACTION_DATE\r\n,NPOS.DISTI_TO_RESELLER_SO_NUMBER\r\n,NPOS.DISTI_2_CISCO_PO_NUMBER\r\n,NPOS.RU_RSLR_TO_DISTI_PO_NUMBER\r\n,NPOS.END_CUST_TO_RESELLER_PO_NUM\r\n,NPOS.MARKET_TYPE_CODE\r\n,NPOS.DIST_RPTD_SALES_REP_NAME \r\nFROM\r\n$$SLSORDVWDB.N_POS_TRANSACTION_LINE NPOS, $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDY, $$SLSORDVWDB.N_POS_TRANSACTION_LINE_ITEM NPOS_ITEM\r\nWHERE NPOS.TRANSACTION_DATE                    = FDY.CALENDAR_DATE\r\nAND CURRENT_FISCAL_MONTH_FLAG = 'Y'\r\nAND NPOS.BK_POS_TRANSACTION_ID_INT     =NPOS_ITEM.BK_POS_TRANSACTION_ID_INT\r\nAND NPOS.POS_TRX_LINE_ACTIVE_FLAG      ='Y'\r\nGROUP BY \r\nNPOS.PRODUCT_KEY      \r\n,NPOS.BK_SHIP_TO_WIPS_SITE_USE_KEY  \r\n,NPOS.BK_BILL_TO_WIPS_SITE_USE_KEY  \r\n,NPOS.BK_SOLD_TO_WIPS_SITE_USE_KEY              \r\n,NPOS.BK_END_USER_WIPS_SITE_USE_KEY   \r\n ,NPOS.SOLD_TO_SALES_TERRITORY_KEY      \r\n,NPOS.BK_WIPS_ORIGINATOR_ID_INT           \r\n ,FDY.FISCAL_YEAR_MONTH_INT      \r\n ,NPOS.PARTNER_SITE_PARTY_KEY\r\n,NPOS.POS_TRX_LINE_POSTED_DATE      \r\n,NPOS.SECOND_SOURCE_FLAG\r\n,NPOS_ITEM.SCRUBBED_SERIAL_NUMBER\r\n,NPOS.POS_TRX_LINE_ACTIVE_FLAG\r\n,NPOS.POS_SOURCE_TYPE\r\n,NPOS.BK_POS_TRANSACTION_ID_INT\r\n,NPOS.DISTRIBUTOR_REPORTED_DEAL_ID\r\n,NPOS.BK_DEAL_ID\r\n,NPOS.TRANSACTION_DATE\r\n,NPOS.DISTI_TO_RESELLER_SO_NUMBER\r\n,NPOS.DISTI_2_CISCO_PO_NUMBER\r\n,NPOS.RU_RSLR_TO_DISTI_PO_NUMBER\r\n,NPOS.END_CUST_TO_RESELLER_PO_NUM\r\n,NPOS.MARKET_TYPE_CODE\r\n,NPOS.DIST_RPTD_SALES_REP_NAME",
