      "attributes": {
        "Sql Query": "SELECT \r\nNSOL.SALES_ORDER_LINE_KEY,\r\nNCPT.PARTNER_PARTY_KEY AS MS_PARTNER_PARTY_KEY,\r\nCAST(SSOL.CLASS_CODE AS INTEGER) AS MS_IDENTIFICATION_METHOD_INT,\r\nNEU.ERP_USER_NAME AS MODIFIED_BY_USER_ID,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM ,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE \r\nFROM $$STGDB.ST_OTM_PHX_TRX_SOL SSOL\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE NSOL   \r\nON SSOL.ORDER_LINE_ID=NSOL.SK_SO_LINE_ID_INT\r\nAND SSOL.GLOBAL_NAME = TRIM(NSOL.SS_CODE)\r\nINNER JOIN $$COMREFVWDB.N_ERP_USER NEU\r\nON NEU.ERP_USER_NAME=SSOL.USER_NAME\r\nINNER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER NCPT\r\nON SSOL.PGTMV_PARTY_BE_ID = NCPT.BK_PGTMV_PARTNER_ID_INT",
