      "attributes": {
        "Sql Query": "SELECT\r\nREASON_CODE AS NO_VLD_SLS_ACCT_PTY_RSN_NAME, \r\n'TRANSACTION' AS EP_SOURCE_CD,\r\n'UNKNOWN' AS NO_VLD_SLS_ACCT_PTY_RSN_DESCR,\r\n'1900-01-01' AS REASON_START_DT,\r\n'1900-01-01' AS REASON_END_DT,\r\nCURRENT_TIMESTAMP(0)   EDW_CREATE_DTM,               \r\nUSER  EDW_CREATE_USER,              \r\nCURRENT_TIMESTAMP(0)   EDW_UPDATE_DTM,               \r\nUSER   EDW_UPDATE_USER     \r\nFROM        \r\n(\r\nSELECT REASON_CODE FROM $$STGDB.ST_OTM_TRX_PRTS_EXT_POS \r\nUNION ALL\r\nSELECT REASON_CODE  FROM $$STGDB.ST_OTM_TRX_PRTS_EXT_MNL_TRX\r\nUNION ALL\r\nSELECT REASON_CODE  FROM $$STGDB.ST_OTM_TRX_PRTS_EXT_SOL\r\nUNION ALL\r\nSELECT REASON_CODE  FROM $$STGDB.ST_OTM_TRX_PRTS_NAPLD_REVLN\r\n) A \r\nGROUP BY 1\r\nWHERE NO_VLD_SLS_ACCT_PTY_RSN_NAME IS NOT NULL AND NOT EXISTS\r\n( SELECT NO_VLD_SLS_ACCT_PTY_RSN_NAME  FROM $$SLSORDVWDB.N_NO_VLD_SA_GRP_PTY_RSN_BIZKEY B\r\n  WHERE A.REASON_CODE=B.NO_VLD_SLS_ACCT_PTY_RSN_NAME)",
