        "Sql Query": "SELECT  WCPIM.CM_PULL_IN_MESSAGE_KEY, WCPIM.SHIPSET_VALUE_USD_AMT, WCPIM.SK_MESSAGE_ID, WCPIM.PROPOSED_SCHEDULED_SHIP_DT, WCPIM.PROPOSED_PROMISE_DT, WCPIM.PULL_IN_REASON_CD, WCPIM.CISCO_DETAIL_REASON_CD, WCPIM.PULL_IN_COMMENT, WCPIM.CM_EMPLOYEE_NAME, WCPIM.PROCESS_STATUS_CD, WCPIM.B2B_ERROR_CD, WCPIM.B2B_ERROR_MESSAGE_TXT, WCPIM.TRANSMISSION_DTM, WCPIM.DV_TRANSMISSION_DT, WCPIM.CURRENT_SCHEDULED_SHIP_DT, WCPIM.CURRENT_PROMISE_DT, WCPIM.PLANNER_REQUESTED_SHIP_DT, WCPIM.TARGET_SCHEDULED_SHIP_DT, WCPIM.TARGET_PROMISE_DT, WCPIM.SHPMNT_SECONDARY_PRIORITY_CD, WCPIM.SHIPSET_STATUS_CD, WCPIM.SALES_ORDER_LINE_NUM_INT, WCPIM.SALES_ORDER_NUM_INT, WCPIM.TOP_MODEL_SOL_KEY,  \r\nCURRENT_TIMESTAMP (0) AS EDW_CREATE_DTM,\r\nUSER AS  EDW_CREATE_USER, \r\nCURRENT_TIMESTAMP (0) AS  EDW_UPDATE_DTM, \r\nUSER AS EDW_UPDATE_USER,\r\n/*Q3FY17 column addition */\r\nWCPIM.CONSOLIDATION_FLG,\r\nWCPIM.CONSOLIDATED_SET_ID_INT,\r\nWCPIM.INTERMEDIATE_PROMISE_SHIP_DT,\r\nWCPIM.INTERMEDIATE_PROMISE_DLVRY_DT\r\n/*Q3FY17 column addition */\r\nFROM\r\n $$WORKDB.W_CM_PULL_IN_MESSAGE WCPIM\r\nWHERE NOT EXISTS\r\n(\r\nSELECT 1 FROM $$SLSORDDB.N_CM_PULL_IN_MESSAGE NCPIM\r\nWHERE NCPIM.CM_PULL_IN_MESSAGE_KEY= WCPIM.CM_PULL_IN_MESSAGE_KEY\r\n)",
