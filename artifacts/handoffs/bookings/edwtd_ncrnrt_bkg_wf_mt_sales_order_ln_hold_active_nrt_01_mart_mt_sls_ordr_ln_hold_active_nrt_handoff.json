      "attributes": {
        "Sql Query": "SELECT \r\nNSOLH.SALES_ORDER_LINE_HOLD_KEY AS SALES_ORDER_LINE_HOLD_KEY\r\n,NULL AS SALES_ORDER_HOLD_KEY\r\n,NSOLH.BK_SOL_HOLD_DATETIME AS BK_SOL_HOLD_DATETIME\r\n,NSOLH.BK_SALES_ORDER_HOLD_NAME AS BK_SALES_ORDER_HOLD_NAME\r\n,NSOLH.SALES_ORDER_LINE_KEY AS SALES_ORDER_LINE_KEY\r\n,NSOLH.DD_SALES_ORDER_KEY AS SALES_ORDER_KEY\r\n,'N' AS SO_HOLD_FLG\r\n,NSOLH.SOL_HOLD_CRTD_BY_ERP_USER_NAME AS SOL_HOLD_CRTD_BY_ERP_USER_NAME\r\n,NSOLH.SOL_HOLD_UPD_BY_ERP_USER_NAME AS SOL_HOLD_UPD_BY_ERP_USER_NAME\r\n,NSOLH.SALES_LINE_HOLD_REASON_TXT AS  SALES_LINE_HOLD_REASON_TXT\r\n,USER AS EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DATETIME\r\nFROM $$NRTNCRVWDB.N_SALES_ORDER_LINE_HOLD_NRT NSOLH\r\nWHERE NSOLH.RELEASED_ROLE='N'\r\n \r\nUNION ALL\r\n\r\nSELECT \r\nNULL AS SALES_ORDER_LINE_HOLD_KEY\r\n,NSOH.SALES_ORDER_HOLD_KEY AS SALES_ORDER_HOLD_KEY\r\n,NSOH.BK_SO_HOLD_DTM AS BK_SOL_HOLD_DATETIME\r\n,NSOH.BK_SALES_ORDER_HOLD_NAME AS BK_SALES_ORDER_HOLD_NAME\r\n,NSOL.SALES_ORDER_LINE_KEY AS SALES_ORDER_LINE_KEY\r\n,NSOH.BK_SALES_ORDER_KEY AS SALES_ORDER_KEY\r\n,'Y' AS SO_HOLD_FLG\r\n,NSOH.SO_HOLD_CRTD_BY_ERP_USER_NAME AS SOL_HOLD_CRTD_BY_ERP_USER_NAME\r\n,NSOH.SO_HOLD_UPD_BY_ERP_USER_NAME AS SOL_HOLD_UPD_BY_ERP_USER_NAME\r\n,NSOH.SO_HOLD_REASON_TXT AS SALES_LINE_HOLD_REASON_TXT\r\n,USER AS EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DATETIME\r\nFROM $$NRTNCRVWDB.N_SALES_ORDER_HOLD_NRT NSOH\r\nINNER JOIN $$NRTNCRVWDB.N_SALES_ORDER_LINE_NRT  NSOL\r\nON NSOL.SALES_ORDER_KEY=NSOH.BK_SALES_ORDER_KEY\r\nWHERE NSOH.SO_RELEASED_ROLE='N'",
