      "attributes": {
        "Sql Query": "SELECT \r\nST.EAC_GROUP_ID BK_EAC_GROUP_ID, \r\nCOALESCE(ST.EAC_GROUP_NAME,'UNKNOWN') EAC_GROUP_NAME,\r\n COALESCE(CAST(ST.EAC_START_DATE AS VARCHAR(10)),'3500-01-01' ) EAC_GROUP_START_DT,\r\n COALESCE(CAST(ST.EAC_END_DATE AS VARCHAR(10)),'3500-01-01' ) EAC_GROUP_END_DT,\r\n COALESCE(CAST(ST.EAC_LAST_UPDATE_DATE AS VARCHAR(25)),'3500-01-01 00:00:00' ) EAC_GROUP_SRC_LST_UPDT_DTM,\r\n COALESCE(CAST(ST.EAC_LAST_UPDATE_DATE AS VARCHAR(10)),'3500-01-01' ) DV_EAC_GROUP_SRC_LST_UPDT_DT,\r\n COALESCE(ST.EAC_GROUP_VERTICAL_NAME, 'UNKNOWN' ) EAC_GROUP_VERTICAL_NAME,\r\n COALESCE(ST.EAC_GROUP_SUB_VERTICAL_NAME, 'UNKNOWN') EAC_GROUP_SUB_VERTICAL_NAME,\r\n  COALESCE(ST.EAC_GROUP_MARKET_SEGMENT,  'UNKNOWN' ) EAC_GROUP_SALES_SEGMENT_NAME,\r\n COALESCE(ST.EAC_GROUP_SUBSEGMENT,  'UNKNOWN' ) EAC_GROUP_SUB_SEGMENT_NAME, \r\n CURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\nCOALESCE(EAC_GROUP_STATUS,'UNKNOWN'),\r\nCOALESCE(CAST(ST.EAC_CREATION_DATE AS VARCHAR(25)),'3500-01-01 00:00:00' ),\r\nCOALESCE(CAST(ST.EAC_CREATION_DATE AS VARCHAR(10)),'3500-01-01' )\r\n,COALESCE(NCWP_CRTD.CISCO_WORKER_PARTY_KEY,-999),\r\nCOALESCE(NCWP_UPDT.CISCO_WORKER_PARTY_KEY,-999),\r\nCOALESCE(ST.ORGANIZATION_ID, '-999') SALES_MOTION_ORGANIZATION_ID,  \r\n 'I' ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM\r\n$$STGDB.ST_XXFSAM_EAC_GROUP_V ST\r\nINNER JOIN $$SLSORDVWDB.N_EAC_ORG ORG \r\nON ORG.BK_EAC_ORG_ID = ST.ORGANIZATION_ID\r\nLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP_CRTD\r\nON COALESCE(ST.EAC_CREATED_BY,'UNKNOWN')= NCWP_CRTD.CEC_ID AND NCWP_CRTD.CISCO_WORKER_PARTY_KEY<>-999\r\nLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP_UPDT\r\nON COALESCE(ST.EAC_LAST_UPDATED_BY,'UNKNOWN')= NCWP_UPDT.CEC_ID AND NCWP_UPDT.CISCO_WORKER_PARTY_KEY<>-999",
        "User Defined Join": "",
