      "attributes": {
        "Sql Query": "SELECT\r\nFDY.FISCAL_CALENDAR_CODE AS BK_FISCAL_CALENDAR_CD,\r\nFDY.FISCAL_YEAR_NUMBER_INT AS BK_FISCAL_YEAR_NUM_INT,\r\nFDY.FISCAL_QUARTER_NUMBER_INT AS BK_FISCAL_QTR_NUM_INT,\r\nISO_CTRY.BK_ISO_COUNTRY_CODE AS BK_ISO_COUNTRY_CD,\r\nST.BE_GEO_ID AS BK_BE_GEO_ID_INT,\r\nCOALESCE(ST.PROFILE_ID, -999) BK_WIPS_ORIGINATOR_ID_INT,\r\nCOALESCE(ST.NPL_FLAG, 'N') NPL_FLG,\r\nFDY.FISCAL_YEAR_QUARTER_NUMBER_INT AS FISCAL_YEAR_QTR_NUM_INT,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM, \r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM ,\r\nUSER AS EDW_UPDATE_USER\r\nFROM\r\n$$STGDB.ST_TBL_DISTI_NPL_MAPPING ST\r\nINNER JOIN\r\n(SELECT DISTINCT DV_FISCAL_QUARTER_ID,\r\nFISCAL_CALENDAR_CODE,\r\nFISCAL_YEAR_NUMBER_INT,\r\nFISCAL_QUARTER_NUMBER_INT,\r\nFISCAL_YEAR_QUARTER_NUMBER_INT\r\n FROM\r\n$$COMREFVWDB.R_FISCAL_QUARTER_TO_YEAR\r\nWHERE CURRENT_FISCAL_QTR_FLAG='Y') FDY\r\nON ST.FISCAL_QUARTER_ID = FDY.DV_FISCAL_QUARTER_ID\r\nINNER JOIN\r\n$$COMREFVWDB.N_ISO_COUNTRY ISO_CTRY\r\nON\r\nST.COUNTRY=ISO_CTRY.ISO_COUNTRY_NAME",
        "User Defined Join": "",
