      "attributes": {
        "Sql Query": "SELECT \r\nTSS_COUNTRY_FACTOR_KEY,\r\nPRODUCT_KEY,\r\nBK_ISO_COUNTRY_CD,\r\nBK_PRICE_LIST_NAME,\r\nSALES_TERRITORY_NAME,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nEDW_CREATE_DTM,\r\nEDW_CREATE_USER\r\nFROM \r\n(\r\nSELECT \r\nRANK() OVER (ORDER BY TSS.PRODUCT_KEY,TSS.BK_ISO_COUNTRY_CD,TSS.BK_PRICE_LIST_NAME,TSS.SALES_TERRITORY_NAME,TSS.BKGS_MEASURE_TRANS_TYPE_CODE) +\r\nSMTS_MAX.MAX_SFVAL  TSS_COUNTRY_FACTOR_KEY,\r\nTSS.PRODUCT_KEY,\r\nTSS.BK_ISO_COUNTRY_CD,\r\nTSS.BK_PRICE_LIST_NAME,\r\nTSS.SALES_TERRITORY_NAME SALES_TERRITORY_NAME,\r\nTSS.BKGS_MEASURE_TRANS_TYPE_CODE,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER\r\nFROM $$STGDB.ST_TSS_PRODUCT_COST_FACTOR TSS,\r\n(SELECT CASE WHEN COALESCE(MAX(TSS_COUNTRY_FACTOR_KEY),0) < 0 THEN CAST (1000 AS INTEGER)\r\nELSE COALESCE (MAX(TSS_COUNTRY_FACTOR_KEY),0) END MAX_SFVAL\r\nFROM $$ETLVWDB.SM_TSS_PRODUCT_COST_FACTOR ) SMTS_MAX\r\nWHERE NOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.SM_TSS_PRODUCT_COST_FACTOR  SM \r\n\tWHERE \tSM.PRODUCT_KEY = TSS.PRODUCT_KEY\r\n\tAND SM.BK_ISO_COUNTRY_CD = TSS.BK_ISO_COUNTRY_CD\r\n\tAND SM.BK_PRICE_LIST_NAME = TSS.BK_PRICE_LIST_NAME\r\n\tAND SM.SALES_TERRITORY_NAME = TSS.SALES_TERRITORY_NAME\r\n\tAND SM.BKGS_MEASURE_TRANS_TYPE_CODE = TSS.BKGS_MEASURE_TRANS_TYPE_CODE\r\n\t\t)\r\n)SM_TSS",
