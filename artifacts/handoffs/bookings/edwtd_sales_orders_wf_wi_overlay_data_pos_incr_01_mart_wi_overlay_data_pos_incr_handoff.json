      "attributes": {
        "Sql Query": "SELECT\r\n  NPOVRLYTV.SK_TRX_SC_ID_INT,\r\n  NPOVRLYTV.PD_SS_CD,\r\n  NPOVRLYTV.POS_SCAAC_KEY,\r\n  NPOVRLYTV.PD_SALES_CREDIT_USAGE_CD AS PD_BK_SALES_CREDIT_TYPE_CD,\r\n  NPOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD  AS  BK_SLS_TERR_ASSIGNMENT_TYPE_CD, \r\n  NPOVRLYTV.PD_TRANSACTION_DT AS PD_TRANSACTION_DT,\r\n  NPOVRLYTV.PD_BK_SALES_REP_NUM AS  PD_BK_SALES_REP_NUM, \r\n  NPOVRLYTV.PD_SALES_TERRITORY_KEY AS  PD_SALES_TERRITORY_KEY, \r\n  NPOVRLYTV.PD_BK_POS_TRANSACTION_ID_INT AS   PD_BK_POS_TRANSACTION_ID_INT , \r\n  NPOVRLYTV.PD_SALES_COMMISSION_PCT  AS PD_SALES_COMMISSION_PCT,\r\n  NPOVRLYTV.START_TV_DTM,\r\n  NPOVRLYTV.END_TV_DTM,\r\n  NPOVRLYTV.EDW_CREATE_DTM as EDW_CREATE_DTM,\r\n  NPOVRLYTV.EDW_UPDATE_DTM as EDW_UPDATE_DTM,\r\n  NPOVRLYTV.PD_SLS_CREDIT_LAST_UPDATE_DTM ,\r\n  NPOVRLYTV.PD_SALES_CREDIT_USAGE_CD,\r\n  NPOVRLYTV.BK_OFFER_ATTRIBUTION_ID_INT AS SK_OFFER_ATTRIBUTION_ID_INT,\r\n  CAST(NPTL.POS_TRX_LINE_POSTED_DATE AS DATE FORMAT'YYYY-MM-DD')\r\n  FROM \r\n  $$SLSORDVWDB.N_POS_SCA_ADJ_CHNG_OVERLAY_TV NPOVRLYTV\r\n  INNER JOIN \r\n  (\r\n  SELECT\tBK_POS_TRANSACTION_ID_INT AS PD_BK_POS_TRANSACTION_ID_INT,POS_TRX_LINE_POSTED_DATE\r\n   FROM\t\r\n  (\r\n  SELECT\tBK_POS_TRANSACTION_ID_INT,POS_TRX_LINE_POSTED_DATE \r\n\tFROM\t$$SLSORDVWDB.N_POS_TRANSACTION_LINE\r\n\tUNION\r\n\tSELECT\tBK_POS_TRANSACTION_ID_INT,\r\n\t\t\tPOS_TRX_LINE_POSTED_DATE  \r\n\tFROM\t$$SLSORDVWDB.N_BKG_POS_TRANSACTION_LINE) A\r\nGROUP BY  1,2\r\n  ) NPTL\r\n  ON NPTL.PD_BK_POS_TRANSACTION_ID_INT=NPOVRLYTV.PD_BK_POS_TRANSACTION_ID_INT    \r\n  WHERE     \r\n  NPOVRLYTV.PD_SALES_CREDIT_USAGE_CD IN ('R','CR')  \r\n  AND NPOVRLYTV.EDW_UPDATE_DTM> (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.CTL_ETL_LAST_EXTRACT_DATES \r\n  WHERE JOB_STREAM_ID = 'wf_WI_OVERLAY_DATA_POS_INCR' AND TABLE_NAME ='N_POS_SCA_ADJ_CHNG_OVERLAY_TV')\r\n   --AND NPOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD NOT IN ('CX','MS','CCR','WWP')                            \r\n   AND NOT EXISTS \r\n    (\r\n    SELECT 1 FROM $$ETLVWDB.EL_OVERLAY_SUB_LINE_INCLUSION EL WHERE  EL.BK_SLS_TERR_ASSIGNMENT_TYPE_CD =NPOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD \r\n       AND NPTL.POS_TRX_LINE_POSTED_DATE \tBETWEEN EL.EFFECTIVE_START_DATE AND EL.EFFECTIVE_END_DATE\r\n\t)",
        "User Defined Join": "",
