      "attributes": {
        "Sql Query": "SELECT \r\n'MT_RSTD_BKGS_MEASURE', \r\n'ALL_COLUMNS',\r\n CASE WHEN COUNT(*) >= 1 THEN 'Y' ELSE 'N' END  \r\n FROM \r\n (\r\n SELECT\r\n MTH.*, \r\n THR.AUDIT_COLUMN_NAME\r\n FROM \r\n $$STGDB.WI_AUD_RSTD_BKG_THRSHLD_VALUES THR\r\n INNER JOIN\r\n $$STGDB.WI_AUD_RSTD_BKGS_MEASURE_MTH MTH\r\n ON \r\n MTH.AUDIT_TABLE_NAME = THR.AUDIT_TABLE_NAME\r\n AND \r\n THR.AUDIT_TABLE_NAME = 'MT_RSTD_BKGS_MEASURE'\r\nWHERE \r\n(MTH.TRADE_IN_AMOUNT NOT BETWEEN THR.MIN_THRESHOLD_VALUE AND THR.MAX_THRESHOLD_VALUE\r\nOR \r\nDD_COMP_US_NET_PRICE_AMOUNT NOT BETWEEN THR.MIN_THRESHOLD_VALUE AND THR.MAX_THRESHOLD_VALUE\r\nOR\r\nDD_COMP_US_LIST_PRICE_AMOUNT NOT BETWEEN THR.MIN_THRESHOLD_VALUE AND THR.MAX_THRESHOLD_VALUE\r\nOR\r\nDD_COMP_US_COST_AMOUNT NOT BETWEEN THR.MIN_THRESHOLD_VALUE AND THR.MAX_THRESHOLD_VALUE\r\nOR\r\nDD_EXTENDED_QUANTITY NOT BETWEEN THR.MIN_THRESHOLD_VALUE AND THR.MAX_THRESHOLD_VALUE\r\nOR \r\nDD_COMP_US_HOLD_NET_PRICE_AMT NOT BETWEEN THR.MIN_THRESHOLD_VALUE AND THR.MAX_THRESHOLD_VALUE\r\nOR\r\nDD_COMP_US_HOLD_LIST_PRICE_AMT NOT BETWEEN THR.MIN_THRESHOLD_VALUE AND THR.MAX_THRESHOLD_VALUE\r\nOR\r\nDD_COMP_US_HOLD_COST_AMOUNT NOT BETWEEN THR.MIN_THRESHOLD_VALUE AND THR.MAX_THRESHOLD_VALUE\r\nOR\r\nDD_EXTENDED_HOLD_QUANTITY NOT BETWEEN THR.MIN_THRESHOLD_VALUE AND THR.MAX_THRESHOLD_VALUE\r\nOR \r\nDD_COMP_US_STANDARD_PRICE_AMT NOT BETWEEN THR.MIN_THRESHOLD_VALUE AND THR.MAX_THRESHOLD_VALUE)\r\n) \r\nA",
