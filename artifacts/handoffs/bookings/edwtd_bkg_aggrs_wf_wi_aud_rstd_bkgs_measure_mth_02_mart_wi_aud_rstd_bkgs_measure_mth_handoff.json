      "attributes": {
        "Sql Query": "SELECT \r\n'MT_RSTD_BKGS_MEASURE',\r\nCOALESCE(RST.DV_FISCAL_YEAR_MTH_NUMBER_INT,ACT.DV_FISCAL_YEAR_MTH_NUMBER_INT),\r\nNULL, \r\nCOALESCE(RST.BKGS_MEASURE_TRANS_TYPE_CODE,ACT.BKGS_MEASURE_TRANS_TYPE_CODE),\r\nZEROIFNULL(RST.TRADE_IN_AMOUNT )- ZEROIFNULL(ACT.TRADE_IN_AMOUNT), \r\nZEROIFNULL(RST.DD_COMP_US_NET_PRICE_AMOUNT )-ZEROIFNULL(ACT.DD_COMP_US_NET_PRICE_AMOUNT),\r\nZEROIFNULL(RST.DD_COMP_US_LIST_PRICE_AMOUNT )-ZEROIFNULL(ACT.DD_COMP_US_LIST_PRICE_AMOUNT ),\r\nZEROIFNULL(RST.DD_COMP_US_COST_AMOUNT)-ZEROIFNULL(ACT.DD_COMP_US_COST_AMOUNT ),\r\nZEROIFNULL(RST.DD_EXTENDED_QUANTITY)-ZEROIFNULL(ACT.DD_EXTENDED_QUANTITY ),\r\nZEROIFNULL(RST.DD_COMP_US_HOLD_NET_PRICE_AMT)-ZEROIFNULL(ACT.DD_COMP_US_HOLD_NET_PRICE_AMT ),\r\nZEROIFNULL(RST.DD_COMP_US_HOLD_LIST_PRICE_AMT)-ZEROIFNULL(ACT.DD_COMP_US_HOLD_LIST_PRICE_AMT ),\r\nZEROIFNULL(RST.DD_COMP_US_HOLD_COST_AMOUNT)-ZEROIFNULL(ACT.DD_COMP_US_HOLD_COST_AMOUNT ),\r\nZEROIFNULL(RST.DD_EXTENDED_HOLD_QUANTITY )-ZEROIFNULL(ACT.DD_EXTENDED_HOLD_QUANTITY ),\r\nZEROIFNULL(RST.DD_COMP_US_STANDARD_PRICE_AMT)-ZEROIFNULL(ACT.DD_COMP_US_STANDARD_PRICE_AMT),  \r\nUSER, \r\nUSER, \r\nCURRENT_TIMESTAMP(0), \r\nCURRENT_TIMESTAMP(0)\r\nFROM\r\n(SEL DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nSUM(ZEROIFNULL(TRADE_IN_AMOUNT))  TRADE_IN_AMOUNT,\r\nSUM(ZEROIFNULL(DD_COMP_US_NET_PRICE_AMOUNT)) DD_COMP_US_NET_PRICE_AMOUNT ,\r\nSUM(ZEROIFNULL(DD_COMP_US_LIST_PRICE_AMOUNT)) DD_COMP_US_LIST_PRICE_AMOUNT,\r\nSUM(ZEROIFNULL(DD_COMP_US_COST_AMOUNT)) DD_COMP_US_COST_AMOUNT ,\r\nSUM(ZEROIFNULL(DD_EXTENDED_QUANTITY)) DD_EXTENDED_QUANTITY ,\r\nSUM(ZEROIFNULL(DD_COMP_US_HOLD_NET_PRICE_AMT))  DD_COMP_US_HOLD_NET_PRICE_AMT,\r\nSUM(ZEROIFNULL(DD_COMP_US_HOLD_LIST_PRICE_AMT))  DD_COMP_US_HOLD_LIST_PRICE_AMT,\r\nSUM(ZEROIFNULL(DD_COMP_US_HOLD_COST_AMOUNT)) DD_COMP_US_HOLD_COST_AMOUNT,\r\nSUM(ZEROIFNULL(DD_EXTENDED_HOLD_QUANTITY)     ) DD_EXTENDED_HOLD_QUANTITY,\r\nSUM(ZEROIFNULL(DD_COMP_US_STANDARD_PRICE_AMT )) DD_COMP_US_STANDARD_PRICE_AMT\r\nFROM $$SLSORDVWDB.N_BKGS_MEASURE NBM\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nON (\r\n( RFM.PREVIOUS_FSCL_MONTH_FLAG      = 'Y'  AND CURRENT_DATE BETWEEN RFM.FISCAL_MONTH_END_DATE + 1 AND  RFM.FISCAL_MONTH_END_DATE + 6) \r\nOR RFM.CURRENT_FISCAL_MONTH_FLAG    = 'Y'   \r\n)\r\nWHERE RFM.FISCAL_YEAR_MONTH_INT  = NBM.DV_FISCAL_YEAR_MTH_NUMBER_INT  \r\nGROUP BY 1,2) ACT\r\n\r\nFULL OUTER JOIN\r\n(\r\nSEL DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nSUM(ZEROIFNULL(TRADE_IN_AMOUNT))  TRADE_IN_AMOUNT,\r\nSUM(ZEROIFNULL(DD_COMP_US_NET_PRICE_AMOUNT)) DD_COMP_US_NET_PRICE_AMOUNT ,\r\nSUM(ZEROIFNULL(DD_COMP_US_LIST_PRICE_AMOUNT)) DD_COMP_US_LIST_PRICE_AMOUNT,\r\nSUM(ZEROIFNULL(DD_COMP_US_COST_AMOUNT)) DD_COMP_US_COST_AMOUNT ,\r\nSUM(ZEROIFNULL(DD_EXTENDED_QUANTITY)) DD_EXTENDED_QUANTITY ,\r\nSUM(ZEROIFNULL(DD_COMP_US_HOLD_NET_PRICE_AMT))  DD_COMP_US_HOLD_NET_PRICE_AMT,\r\nSUM(ZEROIFNULL(DD_COMP_US_HOLD_LIST_PRICE_AMT))  DD_COMP_US_HOLD_LIST_PRICE_AMT,\r\nSUM(ZEROIFNULL(DD_COMP_US_HOLD_COST_AMOUNT)) DD_COMP_US_HOLD_COST_AMOUNT,\r\nSUM(ZEROIFNULL(DD_EXTENDED_HOLD_QUANTITY)     ) DD_EXTENDED_HOLD_QUANTITY,\r\nSUM(ZEROIFNULL(DD_COMP_US_STANDARD_PRICE_AMT )) DD_COMP_US_STANDARD_PRICE_AMT\r\nFROM $$SLSORDVWDB.MT_RSTD_BKGS_MEASURE   NBM\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nON (\r\n( RFM.PREVIOUS_FSCL_MONTH_FLAG      = 'Y'  AND CURRENT_DATE BETWEEN RFM.FISCAL_MONTH_END_DATE + 1 AND  RFM.FISCAL_MONTH_END_DATE + 6) \r\nOR RFM.CURRENT_FISCAL_MONTH_FLAG    = 'Y'   \r\n)\r\nWHERE RFM.FISCAL_YEAR_MONTH_INT  = NBM.DV_FISCAL_YEAR_MTH_NUMBER_INT  \r\nGROUP BY 1,2) RST\r\nON\r\nACT.DV_FISCAL_YEAR_MTH_NUMBER_INT=RST.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND ACT.BKGS_MEASURE_TRANS_TYPE_CODE=RST.BKGS_MEASURE_TRANS_TYPE_CODE",
        "User Defined Join": "",
