      "attributes": {
        "Sql Query": "SELECT \r\nDY.FISCAL_YEAR_QUARTER_NUMBER_INT ,\r\nPRODUCT_KEY     ,\r\nSALES_TERRITORY_KEY     ,\r\nSALES_REP_NUMBER          ,\r\nCANCELLED_FLG  ,\r\nACQUISITION_FLG                ,\r\nCORPORATE_BOOKINGS_FLG            ,\r\nSERVICE_FLG        ,\r\nREVENUE_FLG      ,\r\nSUM(DD_COMP_US_NET_PRICE_AMOUNT)      ,\r\nSUM(DD_COMP_US_LIST_PRICE_AMOUNT)     ,\r\nSUM(DD_COMP_US_COST_AMOUNT)                ,\r\nSUM(DD_EXTENDED_QUANTITY)       ,\r\nSUM(DD_COMP_US_HOLD_NET_PRICE_AMT)  ,\r\nSUM(DD_COMP_US_HOLD_LIST_PRICE_AMT) ,\r\nSUM(DD_COMP_US_HOLD_COST_AMOUNT)    ,\r\nSUM(DD_EXTENDED_HOLD_QUANTITY)           ,\r\nSUM(DD_COMP_US_STANDARD_PRICE_AMT) ,\r\nCAST('CORE' AS VARCHAR(50)) ACQUISITION_SOURCE_CD     ,\r\nCAST('CORE' AS VARCHAR(50)) DV_BOOKINGS_TYPE               ,\r\nDV_REVENUE_RECOGNITION_FLG    ,\r\nDV_NET_SPREAD_FLG        ,\r\nDV_ATTRIBUTION_CD          ,\r\nDV_PRODUCT_KEY         ,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,   \r\nCURRENT_TIMESTAMP(0),\r\nUSER ,\r\nDV_FMV_FLG      \r\nFROM $$SLSORDVWDB.MT_RSTD_BKGS_MEASURE BKGS, $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR DY\r\nWHERE BKGS.BOOKINGS_PROCESS_DATE=DY.CALENDAR_DATE\r\nAND DY.FISCAL_YEAR_AGE BETWEEN 0 AND 2\r\nAND DV_REVENUE_RECOGNITION_FLG='Y'\r\nGROUP BY  DY.FISCAL_YEAR_QUARTER_NUMBER_INT          ,\r\nPRODUCT_KEY     ,\r\nSALES_TERRITORY_KEY     ,\r\nSALES_REP_NUMBER          ,\r\nCANCELLED_FLG  ,\r\nACQUISITION_FLG                ,\r\nCORPORATE_BOOKINGS_FLG            ,\r\nSERVICE_FLG        ,\r\nREVENUE_FLG,\r\nDV_REVENUE_RECOGNITION_FLG    ,\r\nDV_NET_SPREAD_FLG        ,\r\nDV_ATTRIBUTION_CD          ,\r\nDV_PRODUCT_KEY,\r\nDV_FMV_FLG              \r\n\r\nUNION ALL\r\n\r\nSELECT \r\nDY.FISCAL_YEAR_QUARTER_NUMBER_INT          ,\r\nCISCO_PRODUCT_KEY PRODUCT_KEY             ,\r\nSALES_TERRITORY_KEY     ,\r\nSALES_REP_NUMBER          ,\r\n'=' CANCELLED_FLG              ,\r\n'='  ACQUISITION_FLG           ,\r\nCORPORATE_BOOKINGS_FLG            ,\r\nSERVICE_FLG        ,\r\n'='  REVENUE_FLG ,\r\nSUM(EXTENDED_SELLING_PRICE_USD_AMT) ,\r\n0.000000 DD_COMP_US_LIST_PRICE_AMOUNT,\r\nSUM(EXTENDED_STANDARD_COST_USD_AMT)             ,\r\nSUM(ORDER_QTY)                ,\r\n0.000000  DD_COMP_US_HOLD_NET_PRICE_AMT,\r\n0.000000 DD_COMP_US_HOLD_LIST_PRICE_AMT           ,\r\n0.000000 DD_COMP_US_HOLD_COST_AMOUNT              ,\r\n0.000000 DD_EXTENDED_HOLD_QUANTITY     ,\r\n0.000000 DD_COMP_US_STANDARD_PRICE_AMT           ,\r\nACQUISITION_SOURCE_CD ACQUISITION_SOURCE_CD ,\r\n'NON-CORE'  DV_BOOKINGS_TYPE     ,\r\n'Y' DV_REVENUE_RECOGNITION_FLG               ,\r\n'N' DV_NET_SPREAD_FLG   ,\r\n'STANDALONE'  DV_ATTRIBUTION_CD              ,\r\nCISCO_PRODUCT_KEY DV_PRODUCT_KEY  ,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,   \r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\n'N' DV_FMV_FLG      \r\nFROM $$SLSORDVWDB.N_APSP_FDI_BOOKINGS_TRX FDI, $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR DY\r\nWHERE FDI.FISCAL_YEAR_MONTH_INT=DY.FISCAL_YEAR_MONTH_INT\r\nAND DY.FISCAL_YEAR_AGE BETWEEN 0 AND 2\r\nGROUP BY \r\nDY.FISCAL_YEAR_QUARTER_NUMBER_INT          ,\r\nCISCO_PRODUCT_KEY         ,\r\nSALES_TERRITORY_KEY     ,\r\nSALES_REP_NUMBER          ,\r\nCORPORATE_BOOKINGS_FLG            ,\r\nSERVICE_FLG,\r\nACQUISITION_SOURCE_CD",
