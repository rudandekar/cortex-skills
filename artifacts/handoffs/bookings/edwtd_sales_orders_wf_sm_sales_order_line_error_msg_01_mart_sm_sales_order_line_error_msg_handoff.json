      "attributes": {
        "Sql Query": "SELECT \r\nRANK() OVER \r\n\t\t\t(ORDER BY \r\n\t\t\t\tSTSVC.SK_LINE_ERROR_ID_INT, \r\n\t\t\t\tSTSVC.SK_ENTITLEMENT_ERROR_ID_INT,STSVC.SK_BATCH_ID_INT,\r\n\t\t\t\tSTSVC.SS_CODE)  +  SM_MAX.MAX_KEY_VAL  SALES_ORDER_LINE_ERROR_MSG_KEY,\r\nSTSVC.SK_ENTITLEMENT_ERROR_ID_INT,\r\nSTSVC.SK_LINE_ERROR_ID_INT,\r\nSTSVC.SK_BATCH_ID_INT,\r\nSTSVC.SS_CODE  AS SS_CD,\r\nCURRENT_TIMESTAMP(0),\r\nUSER \r\nFROM \r\n(\r\nSELECT \r\n LERS.LINE_ERROR_ID AS SK_LINE_ERROR_ID_INT,\r\n ENER.ENTL_ERROR_ID AS SK_ENTITLEMENT_ERROR_ID_INT,\r\n -999 AS SK_BATCH_ID_INT,\r\n NSSC.SOURCE_SYSTEM_CODE AS SS_CODE\r\nFROM $$STGDB.WI_OM_XXCCA_SVC_CTRT_LINE_ERRS LERS\r\nINNER JOIN $$ETLVWDB.EL_OM_XXCCA_SVC_CTRT_ENTL_ERRS ENER\r\nON LERS.ERROR_MESSAGE_CODE=ENER.ERROR_MESSAGE_CODE\r\nAND ENER.GLOBAL_NAME=LERS.GLOBAL_NAME\r\nINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\nON NSSC.GLOBAL_NAME=LERS.GLOBAL_NAME \r\nWHERE NOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.SM_SALES_ORDER_LINE_ERROR_MSG SSCE \r\n\tWHERE \tSSCE.SK_LINE_ERROR_ID_INT =LERS.LINE_ERROR_ID  AND\r\n\t\t\tSSCE.SK_ENTITLEMENT_ERROR_ID_INT=ENER.ENTL_ERROR_ID AND\r\n\t\t\tSSCE.SS_CD=NSSC.SOURCE_SYSTEM_CODE\r\n\t\t\t\r\n)\r\n) STSVC,\r\n(SELECT COALESCE(MAX(SALES_ORDER_LINE_ERROR_MSG_KEY),0) MAX_KEY_VAL  \r\n\t\tFROM $$ETLVWDB.SM_SALES_ORDER_LINE_ERROR_MSG ) SM_MAX",
        "User Defined Join": "",
