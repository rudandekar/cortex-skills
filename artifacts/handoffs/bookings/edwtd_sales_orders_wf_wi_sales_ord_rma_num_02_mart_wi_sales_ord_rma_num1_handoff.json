      "attributes": {
        "Sql Query": "SELECT \r\nBUSINESS_UNIT,                 \r\nCREATED_BY,                    \r\nCREATION_DATE,                 \r\nGES_PK_ID ,                    \r\nGES_UPDATE_DATE  ,             \r\nGLOBAL_NAME,                   \r\nLAST_UPDATED_BY  ,             \r\nLAST_UPDATE_DATE ,             \r\nLAST_UPDATE_LOGIN ,            \r\nLOB  ,                         \r\nPRODUCT_BULLETIN_NUMBER ,      \r\nPROGRAM_NAME,                  \r\nQUOTE_NUMBER ,                 \r\nRMA_NUMBER,                    \r\nTRADE_IN_ORDER_NUMBER,         \r\nTRADE_IN_TRACK_ID  ,           \r\nBATCH_ID,                      \r\nCREATE_DATETIME ,              \r\nACTION_CODE,\r\n'RI' AS EXCEPTION_TYPE                \r\nFROM \r\n$$STGDB.ST_OM_CCA_TRADE_IN_TRACK TRD_IN_TRCK\r\n WHERE NOT EXISTS(SELECT 1 FROM $$SLSORDVWDB.N_SALES_ORDER_V1_TV NSOV1\r\n WHERE (( CASE WHEN TRD_IN_TRCK.GLOBAL_NAME='UO' THEN 'QTC'\r\n                     WHEN TRD_IN_TRCK.GLOBAL_NAME='BO' THEN 'BV'\r\n                     END) = NSOV1.SS_CD\r\n       AND   TRD_IN_TRCK.TRADE_IN_ORDER_NUMBER=   NSOV1.BK_SO_NUMBER_INT\r\n       AND  NSOV1.END_TV_DTM='3500-01-01 00:00:00'))\r\n AND NOT EXISTS(SELECT 1 FROM $$SLSORDVWDB.N_SALES_ORDER_V1_TV NSOV1_REF\r\n WHERE (( CASE WHEN TRD_IN_TRCK.GLOBAL_NAME='UO' THEN 'QTC'\r\n                     WHEN TRD_IN_TRCK.GLOBAL_NAME='BO' THEN 'BV'\r\n                     END) = NSOV1_REF.SS_CD\r\n       AND   TRD_IN_TRCK.RMA_NUMBER=   NSOV1_REF.BK_SO_NUMBER_INT\r\n       AND  NSOV1_REF.END_TV_DTM='3500-01-01 00:00:00'))     \r\nAND NOT EXISTS(SELECT 1 FROM  $$SLSORDVWDB.N_TMIP_QUOTE NTQ /* Added this new condition  */\r\nWHERE NTQ.BK_TMIP_QUOTE_NUM = TRD_IN_TRCK.QUOTE_NUMBER) \r\nAND TRD_IN_TRCK.RMA_NUMBER  IS NOT NULL",
