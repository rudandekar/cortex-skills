      "attributes": {
        "Sql Query": "SELECT \r\n\t\t\t\t\t\tDRVD.SALES_ORDER_KEY, \r\n                        DRVD.RMA_SALES_ORDER_KEY,\r\n                        CASE WHEN DRVD.RMA_SALES_ORDER_KEY IS NOT NULL  THEN 'Y' ELSE 'N' END  TRADE_IN_ROLE  ,\r\n                        DRVD.TRADE_IN_ORDER_NUMBER,\r\n                        DRVD.GLOBAL_NAME,\r\n                        DRVD.RMA_NUMBER,\r\n                        DRVD.SS_CD,\r\n                        DRVD.RU_CTMP_QUOTE_NUM, /* Added this new col  */\r\n                        DRVD.RU_REPORTED_TMIP_QUOTE_NUM  /* Added this new col  */\r\nFROM (\r\nSELECT \r\n                \t\tTMP1.SALES_ORDER_KEY, \r\n                        TMP1.RMA_SALES_ORDER_KEY,\r\n                        TMP1.TRADE_IN_ORDER_NUMBER,\r\n                        TMP1.GLOBAL_NAME,\r\n                        TMP1.RMA_NUMBER,\r\n                        TMP1.SS_CD,\r\n                        TMP1.CREATE_DATETIME,\r\n                        TMP1.RU_CTMP_QUOTE_NUM,  /* Added this new col  */\r\n                        TMP1.RU_REPORTED_TMIP_QUOTE_NUM  /* Added this new col  */\r\n                        FROM (\r\nSELECT  \r\n \t\t        \tNSOV1.SALES_ORDER_KEY AS SALES_ORDER_KEY, \r\n                       NSOV1_REF.SALES_ORDER_KEY AS RMA_SALES_ORDER_KEY,\r\n                       TRD_IN_TRCK.TRADE_IN_ORDER_NUMBER AS TRADE_IN_ORDER_NUMBER,\r\n                        TRD_IN_TRCK.GLOBAL_NAME AS GLOBAL_NAME,\r\n                        TRD_IN_TRCK.RMA_NUMBER  AS RMA_NUMBER,\r\n                        NSOV1.SS_CD AS SS_CD,\r\n                        TRD_IN_TRCK.CREATE_DATETIME,\r\n                        NTQ.BK_TMIP_QUOTE_NUM AS RU_CTMP_QUOTE_NUM,  /* Added this new col  */\r\n\t\t\tTRD_IN_TRCK.QUOTE_NUMBER AS RU_REPORTED_TMIP_QUOTE_NUM   /* Added this new col  */\r\nFROM $$STGDB.ST_OM_CCA_TRADE_IN_TRACK TRD_IN_TRCK\r\n \r\n INNER JOIN $$SLSORDVWDB.N_SALES_ORDER_V1_TV NSOV1\r\n ON(( CASE WHEN TRD_IN_TRCK.GLOBAL_NAME='UO' THEN 'QTC'\r\n                     WHEN TRD_IN_TRCK.GLOBAL_NAME='BO' THEN 'BV'\r\n                     END) = NSOV1.SS_CD\r\n       AND   TRD_IN_TRCK.TRADE_IN_ORDER_NUMBER=   NSOV1.BK_SO_NUMBER_INT\r\n       AND  NSOV1.END_TV_DTM='3500-01-01 00:00:00')\r\n \r\n INNER JOIN $$SLSORDVWDB.N_SALES_ORDER_V1_TV NSOV1_REF\r\n ON(( CASE WHEN TRD_IN_TRCK.GLOBAL_NAME='UO' THEN 'QTC'\r\n                     WHEN TRD_IN_TRCK.GLOBAL_NAME='BO' THEN 'BV'\r\n                     END) = NSOV1_REF.SS_CD\r\n         AND   TRD_IN_TRCK.RMA_NUMBER=   NSOV1_REF.BK_SO_NUMBER_INT\r\n         AND NSOV1_REF.END_TV_DTM='3500-01-01 00:00:00'   )      \r\nLEFT JOIN $$SLSORDVWDB.N_TMIP_QUOTE NTQ   /* Added this new condition  */\r\nON(NTQ.BK_TMIP_QUOTE_NUM =TRD_IN_TRCK.QUOTE_NUMBER)\r\nWHERE  TRD_IN_TRCK.RMA_NUMBER IS NOT NULL   \r\n\r\nUNION ALL\r\n\r\nSELECT  \r\n\t\t\tNSOV1.SALES_ORDER_KEY AS SALES_ORDER_KEY, \r\n\t\t\tNSOV1_REF.SALES_ORDER_KEY AS RMA_SALES_ORDER_KEY,\r\n\t\t\tTRD_IN_TRCK.TRADE_IN_ORDER_NUMBER AS TRADE_IN_ORDER_NUMBER,\r\n\t\t\tTRD_IN_TRCK.GLOBAL_NAME AS GLOBAL_NAME,\r\n\t\t\tTRD_IN_TRCK.RMA_NUMBER  AS RMA_NUMBER,\r\n\t\t\tNSOV1.SS_CD AS SS_CD,\r\n\t\t\tTRD_IN_TRCK.CREATE_DATETIME,\r\n\t\t\tNTQ.BK_TMIP_QUOTE_NUM AS RU_CTMP_QUOTE_NUM,  /* Added this new col  */\r\n\t\t\tTRD_IN_TRCK.QUOTE_NUMBER AS RU_REPORTED_TMIP_QUOTE_NUM    /* Added this new col  */\r\n FROM $$EXCEPDB.EX_OM_CCA_TRADE_IN_TRACK TRD_IN_TRCK \r\n \r\n INNER JOIN $$SLSORDVWDB.N_SALES_ORDER_V1_TV NSOV1\r\n ON(( CASE WHEN TRD_IN_TRCK.GLOBAL_NAME='UO' THEN 'QTC'\r\n                     WHEN TRD_IN_TRCK.GLOBAL_NAME='BO' THEN 'BV'\r\n                     END) = NSOV1.SS_CD\r\n       AND   TRD_IN_TRCK.TRADE_IN_ORDER_NUMBER=   NSOV1.BK_SO_NUMBER_INT\r\n       AND  NSOV1.END_TV_DTM='3500-01-01 00:00:00')\r\n \r\n INNER JOIN $$SLSORDVWDB.N_SALES_ORDER_V1_TV NSOV1_REF\r\n ON(( CASE WHEN TRD_IN_TRCK.GLOBAL_NAME='UO' THEN 'QTC'\r\n                     WHEN TRD_IN_TRCK.GLOBAL_NAME='BO' THEN 'BV'\r\n                     END) = NSOV1_REF.SS_CD\r\n         AND   TRD_IN_TRCK.RMA_NUMBER=   NSOV1_REF.BK_SO_NUMBER_INT\r\n         AND NSOV1_REF.END_TV_DTM='3500-01-01 00:00:00'   )      \r\nLEFT JOIN $$SLSORDVWDB.N_TMIP_QUOTE NTQ     /* Added this new condition  */\r\nON(NTQ.BK_TMIP_QUOTE_NUM =TRD_IN_TRCK.QUOTE_NUMBER)\r\nWHERE  TRD_IN_TRCK.RMA_NUMBER IS NOT NULL \r\n )TMP1\r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY TMP1.SALES_ORDER_KEY ORDER BY  TMP1.CREATE_DATETIME DESC  ) =1 ) DRVD",
        "User Defined Join": "",
