      "attributes": {
        "Sql Query": "SELECT \r\nTVINPUT.BK_ORDER_TYPE_NAME,\r\nTVINPUT.BK_SO_PROGRAM_TYPE_NAME,\r\nTVINPUT.SHIPMENT_PRIORITY_CD,\r\nTVINPUT.SOURCE_DELETED_FLG,\r\nTVINPUT.LINK_DEFINITION_TXT,\r\nTVINPUT.LINK_DESCR LINK_DESCR, \r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,    \r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\nTVINPUT.START_TV_DT,\r\nTVINPUT.END_TV_DT,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN\r\nNSTPTLT.BK_ORDER_TYPE_NAME IS NOT NULL AND NSTPTLT.BK_SO_PROGRAM_TYPE_NAME IS NOT NULL AND TVINPUT.START_TV_DT=NSTPTLT.START_TV_DT THEN 'U' ELSE 'I' END AS DML_TYPE\r\nFROM\r\n(SELECT\r\nSCFLV.ATTRIBUTE2 AS BK_ORDER_TYPE_NAME,\r\nSCFLV.ATTRIBUTE1 AS BK_SO_PROGRAM_TYPE_NAME,\r\nCOALESCE(SCFLV.ATTRIBUTE3,'UNKNOWN' )AS SHIPMENT_PRIORITY_CD,\r\nSCFLV.ENABLED_FLAG AS SOURCE_DELETED_FLG,\r\nSCFLV.MEANING AS LINK_DEFINITION_TXT,\r\nSCFLV.DESCRIPTION AS LINK_DESCR,\r\nCAST(SCFLV.SOURCE_COMMIT_TIME AS DATE) AS START_TV_DT,\r\nCOALESCE(SCFLV.END_DATE_ACTIVE,CAST('3500-01-01' AS DATE)) AS END_TV_DT \r\nFROM              \r\n$$STGDB.ST_CG1_FND_LOOKUP_VALUES_SO SCFLV\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY ATTRIBUTE2,ATTRIBUTE1 ORDER  BY SOURCE_COMMIT_TIME DESC) = 1)TVINPUT\r\nLEFT JOIN $$SLSORDVWDB.N_SO_TYPE_PROGRAM_TYPE_LINK_TV NSTPTLT\r\nON\r\nTVINPUT.BK_ORDER_TYPE_NAME = NSTPTLT.BK_ORDER_TYPE_NAME\r\nAND\r\nTVINPUT.BK_SO_PROGRAM_TYPE_NAME = NSTPTLT.BK_SO_PROGRAM_TYPE_NAME\r\nAND\r\nNSTPTLT.END_TV_DT = CAST ('3500-01-01' AS DATE)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
