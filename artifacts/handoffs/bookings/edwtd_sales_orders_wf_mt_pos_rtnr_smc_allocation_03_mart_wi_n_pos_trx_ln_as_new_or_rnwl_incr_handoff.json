      "attributes": {
        "Sql Query": "SELECT \r\n    BK_POS_TRANSACTION_ID_INT,\r\n    SALES_MOTION_CD,\r\n    SPLIT_PCT AS DV_ALLOCATION_PCT,\r\n    'UNKNOWN' AS DV_SERVICE_CATEGORY_CD,  \r\n    START_TV_DTM,\r\n    END_TV_DTM,\r\n    SALES_MOTION_TIMING_CD,\r\n    SALES_ORDER_LINE_KEY,\r\n\tRENEWAL_REF_ID,\r\n\tRENEWAL_REF_CD,\r\n\tRENEWAL_GAP_DAYS,\r\n\tRENEWAL_REF_RULE\r\nFROM $$SLSORDVWDB.N_POS_TRX_LN_AS_NEW_OR_RNWL_TV\r\nWHERE END_TV_DTM = '3500-01-01 00:00:00' AND EDW_UPDATE_DTM > '$$LastExtractDate'",
