      "attributes": {
        "Sql Query": "SELECT\r\nSMC_FINAL.BK_POS_TRANSACTION_ID_INT,\r\nSMC_FINAL.SALES_MOTION_CD,\r\nSMC_FINAL.DV_ALLOCATION_PCT/SMC_FINAL.SUM_SPLIT AS DV_ALLOCATION_PCT,\r\nSMC_FINAL.DV_SERVICE_CATEGORY_CD,\r\nSMC_FINAL.START_TV_DTM , \r\nSMC_FINAL.END_TV_DTM,\r\nSMC_FINAL.SALES_MOTION_TIMING_CD ,\r\nSMC_FINAL.SALES_ORDER_LINE_KEY,\r\n'UNKNOWN' AS RENEWAL_REF_ID,\r\n'UNKNOWN' AS RENEWAL_REF_CD,\r\n-9999 AS RENEWAL_GAP_DAYS,\r\n'UNKNOWN' AS RENEWAL_REF_RULE\r\nFROM (SELECT \r\nSMC.BK_POS_TRANSACTION_ID_INT,\r\nSMC.SALES_MOTION_CD,\r\nSUM(SMC.DV_ALLOCATION_PCT ) AS DV_ALLOCATION_PCT,\r\nSMC.SUM_SPLIT ,\r\nsmc.DV_SERVICE_CATEGORY_CD,\r\nSMC.START_TV_DTM , \r\nSMC.END_TV_DTM,\r\nSMC.SALES_MOTION_TIMING_CD ,\r\nSMC.SALES_ORDER_LINE_KEY\r\nFROM\r\n(\r\nSELECT \r\nBK_POS_TRANSACTION_ID_INT,\r\nSALES_MOTION_CD,\r\nDV_ALLOCATION_PCT,\r\nCASE WHEN SUM_SPLIT=0 THEN 1 ELSE SUM_SPLIT END AS SUM_SPLIT,\r\n'UNKNOWN' AS DV_SERVICE_CATEGORY_CD,\r\nSTART_TV_DTM,\r\nEND_TV_DTM,\r\nSALES_MOTION_TIMING_CD,\r\nSALES_ORDER_LINE_KEY\r\nFROM \r\n(SELECT\r\nWI.BK_POS_TRANSACTION_ID_INT,\r\nWI.SALES_MOTION_CD,\r\nWI.DV_ALLOCATION_PCT,\r\nSUM(WI.DV_ALLOCATION_PCT) OVER(PARTITION BY WI.BK_POS_TRANSACTION_ID_INT) SUM_SPLIT,\r\nMAX(WI.START_TV_DTM) OVER(PARTITION BY WI.BK_POS_TRANSACTION_ID_INT) START_TV_DTM, /* Changed logic as part of May 2nd release */\r\nCAST('3500-01-01 00:00:00' AS TIMESTAMP(0)) AS END_TV_DTM,\r\nWI.SALES_MOTION_TIMING_CD,\r\nWI.SALES_ORDER_LINE_KEY\r\nFROM $$STGDB.WI_N_POS_TRX_LN_AS_NEW_OR_RNWL_INCR WI\r\n) SMC1\r\n) SMC\r\nGROUP BY 1,2,4,5,6,7,8,9\r\n) SMC_FINAL",
