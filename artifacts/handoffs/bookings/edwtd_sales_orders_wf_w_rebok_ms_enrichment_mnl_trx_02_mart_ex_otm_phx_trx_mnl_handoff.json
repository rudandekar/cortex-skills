      "attributes": {
        "Sql Query": "SELECT\r\nSTG.TRX_ID\r\n,STG.ORDER_LINE_ID\r\n,STG.TRX_ORIG_CODE\r\n,STG.PARTY_EXT_ID\r\n,STG.ENRICHMENT_CODE\r\n,STG.ENRICHMENT_PARTY_TYPE\r\n,STG.PGTMV_PARTY_BE_ID\r\n,STG.CLASS_CODE\r\n,STG.USER_NAME\r\n,STG.CREATION_DATE\r\n,STG.LAST_UPDATE_DATE\r\n,STG.BATCH_ID,\r\n'RI' AS EXCEPTION_TYPE\r\nFROM   $$STGDB.ST_OTM_PHX_TRX_MNL STG\r\nLEFT OUTER JOIN $$SLSORDVWDB.N_SALES_ADJ_REBOK_MNL_TRX NSMT  \r\nON STG.ORDER_LINE_ID=NSMT.ADJUSTMENT_LINE_ID_INT\r\nAND STG.TRX_ORIG_CODE=NSMT.TRANSACTION_ORIGINATION_CD\r\nAND TRIM(NSMT.TRANSACTION_SOURCE_TYPE_CD) = 'MANUAL'\r\nLEFT OUTER JOIN $$COMREFVWDB.N_ERP_USER NEU\r\nON NEU.ERP_USER_NAME=STG.USER_NAME\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER NCPT\r\nON STG.PGTMV_PARTY_BE_ID = NCPT.BK_PGTMV_PARTNER_ID_INT\r\nWHERE NSMT.MANUAL_TRX_KEY IS NULL\r\nOR NCPT.PARTNER_PARTY_KEY IS NULL\r\nOR NEU.ERP_USER_NAME IS NULL",
