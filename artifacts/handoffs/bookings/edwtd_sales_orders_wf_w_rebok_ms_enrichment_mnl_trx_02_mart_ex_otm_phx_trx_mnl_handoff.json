      "attributes": {
        "Sql Query": "SELECT \r\nEX.TRX_ID\r\n,EX.ORDER_LINE_ID\r\n,EX.TRX_ORIG_CODE\r\n,EX.PARTY_EXT_ID\r\n,EX.ENRICHMENT_CODE\r\n,EX.ENRICHMENT_PARTY_TYPE\r\n,EX.PGTMV_PARTY_BE_ID\r\n,EX.CLASS_CODE\r\n,EX.USER_NAME\r\n,EX.CREATION_DATE\r\n,EX.LAST_UPDATE_DATE\r\n,EX.BATCH_ID\r\nFROM $$EXCEPDB.EX_OTM_PHX_TRX_MNL EX\r\nWHERE EX.EXCEPTION_TYPE='RI' AND NOT EXISTS\r\n( SELECT 1 FROM $$STGDB.ST_OTM_PHX_TRX_MNL  ST\r\nWHERE STG.ORDER_LINE_ID=EX.ORDER_LINE_ID)",
