      "attributes": {
        "Sql Query": "SELECT\r\nRSH.SALES_TERRITORY_KEY AS SALES_TERRITORY_KEY\r\n,COALESCE(ST.SALES_THEATER_NAME, 'UNKNOWN') AS SALES_THEATER_NAME\r\n,COALESCE(ST.SALES_GEO_NAME, 'UNKNOWN') AS SALES_GEO_NAME\r\n,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM \r\n,USER AS EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM \r\n,USER AS EDW_UPDATE_USER\r\nFROM \r\n$$STGDB.ST_WIPS_DISTI_SALES_GEO_MAP ST\r\nINNER JOIN\r\n(SELECT * FROM $$COMREFVWDB.R_SALES_HIERARCHY WHERE SALES_TERRITORY_TYPE_CODE = 'CORP. REVENUE' ) RSH\r\nON\r\n\t\t\tST.SALES_LEVEL3=RSH.L3_SALES_TERRITORY_NAME_CODE\r\nQUALIFY ROW_NUMBER() OVER( PARTITION BY SALES_TERRITORY_KEY ORDER BY EDW_UPDATE_DTM ASC ) = 1",
