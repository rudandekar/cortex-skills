      "attributes": {
        "Sql Query": "SELECT \r\n SYS.CUSTOMER_PARTY_KEY,\r\n SYS.BK_SA_MEMBER_ID_INT,\r\n SAGP.SALES_ACCOUNT_GROUP_PARTY_KEY,\r\n CASE WHEN (BIZ_CUST.RU_LINK_CUSTOMER_PARTY_KEY = -999 OR BIZ_CUST.RU_LINK_CUSTOMER_PARTY_KEY IS NULL) \r\n     THEN BIZ_TMPLT_CUST.RU_LINK_CUSTOMER_PARTY_KEY ELSE BIZ_CUST.RU_LINK_CUSTOMER_PARTY_KEY \r\n END AS LINK_CUSTOMER_PARTY_KEY , \r\n COALESCE(SLSTER.SLS_ACCT_GROUP_SALES_TERR_KEY,-999) AS SLS_ACCT_GROUP_SALES_TERR_KEY ,\r\n COALESCE(SAOA.BK_OWNER_SALES_REP_NUM,'-999') AS SALES_REP_NUM , \r\n COALESCE(SH.L6_SALES_TERRITORY_NAME_CODE,'UNKNOWN') AS L6_SALES_TERRITORY_NAME_CODE, \r\n COALESCE(SH.L5_SALES_TERRITORY_NAME_CODE,'UNKNOWN') AS L5_SALES_TERRITORY_NAME_CODE,\r\n CASE \r\n WHEN COALESCE(SH.ISO_COUNTRY_CODE,'UNK') = 'UNK'\r\n  THEN SH.DD_EXTERNAL_THEATER_NAME\r\n ELSE SH.ISO_COUNTRY_CODE\r\nEND AS ISO_COUNTRY_CODE,\r\n SYS.SALES_CREDIT_SPLIT_PCT,\r\n 'NAMED_ACCOUNT' AS SALES_ACCOUNT_GROUP_TYPE_CD,\r\n COALESCE(SAOA.HIBERNATION_FLG,'N') AS HIBERNATION_FLG,\r\n CNTRL.PROCESS_TYPE,\r\n CNTRL.YEAR_FLG_INT\r\n FROM\r\n    ( SELECT \r\n     CUSTOMER_PARTY_KEY,\r\n     SALES_ACCOUNT_GROUP_PARTY_KEY,\r\n     BK_SA_MEMBER_ID_INT,\r\n     RU_PARENT_SA_MEMBER_ID_INT,\r\n     SALES_CREDIT_SPLIT_PCT\r\n    FROM $$COMREFVWDB.N_SA_GRPCSTPTY_LNKSYSVW_TV,\r\n      ( SELECT * FROM $$ETLVWDB.WI_DRR_PROCESS_CONTROL WHERE ACTIVE_FLAG = 'Y' AND PROCESS_TYPE = $$PROCESS_TYPE) CTRL  \r\n    WHERE CUSTOMER_PARTY_KEY <> -999\r\n     /*AND CTRL.ACTIVE_FLAG = 'Y' */\r\n\t AND SOURCE_DELETED_FLG = 'N'\r\n     AND CTRL.PROCESS_DATE BETWEEN LINK_START_DT AND LINK_END_DT\r\n   GROUP BY 1,2,3,4,5\r\n  ) SYS\r\n  INNER JOIN ( SELECT * FROM $$ETLVWDB.WI_DRR_PROCESS_CONTROL WHERE ACTIVE_FLAG = 'Y' AND PROCESS_TYPE = $$PROCESS_TYPE) CNTRL \r\n      ON 1=1\r\n  INNER JOIN $$COMREFVWDB.N_SLS_ACCT_GROUP_SAV_PARTY_TV SAGP\r\n      ON SYS.SALES_ACCOUNT_GROUP_PARTY_KEY = SAGP.SALES_ACCOUNT_GROUP_PARTY_KEY\r\n  AND SALES_ACCOUNT_GROUP_TYPE_CD IN ('NAMED_ACCOUNT','UNKNOWN')\r\n     AND CNTRL.PROCESS_DATE BETWEEN SAGP.SALES_ACCOUNT_GROUP_START_DT AND SAGP.SALES_ACCOUNT_GROUP_END_DT   \r\n  LEFT JOIN \r\n  ( \r\n SELECT * \r\n FROM $$COMREFVWDB.N_SA_GRPSVPTY_TERR_ASGNMNT_TV\r\n INNER JOIN \r\n ( \r\n  SELECT * \r\n  FROM \r\n  $$ETLVWDB.WI_DRR_PROCESS_CONTROL \r\n  WHERE ACTIVE_FLAG = 'Y'  AND PROCESS_TYPE = $$PROCESS_TYPE\r\n ) CL ON 1=1\r\n    WHERE SOURCE_DELETED_FLG = 'N'\r\n AND CL.PROCESS_DATE BETWEEN START_TV_DT AND END_TV_DT\r\n    QUALIFY ROW_NUMBER() OVER(PARTITION BY SALES_ACCOUNT_GROUP_PARTY_KEY ORDER BY EDW_UPDATE_DTM DESC )=1\r\n   ) SLSTER\r\n      ON SAGP.SALES_ACCOUNT_GROUP_PARTY_KEY = SLSTER.SALES_ACCOUNT_GROUP_PARTY_KEY \r\n  LEFT JOIN \r\n  ( \r\n SELECT * \r\n FROM $$COMREFVWDB.N_SALES_ACCT_OWNER_ASSIGNMENT\r\n INNER JOIN \r\n ( \r\n  SELECT * \r\n  FROM \r\n  $$ETLVWDB.WI_DRR_PROCESS_CONTROL \r\n  WHERE ACTIVE_FLAG = 'Y'  AND PROCESS_TYPE = $$PROCESS_TYPE\r\n ) CTL ON 1=1\r\n    WHERE \r\n SOURCE_DELETED_FLG = 'N' \r\n AND CTL.PROCESS_DATE BETWEEN BK_ASSIGNMENT_START_DT AND ASSIGNMENT_END_DT\r\n    QUALIFY ROW_NUMBER() OVER(PARTITION BY SALES_ACCOUNT_GROUP_PARTY_KEY ORDER BY EDW_UPDATE_DTM DESC )=1\r\n  ) SAOA\r\n  ON SAGP.SALES_ACCOUNT_GROUP_PARTY_KEY = SAOA.SALES_ACCOUNT_GROUP_PARTY_KEY\r\n LEFT OUTER JOIN $$COMREFVWDB.N_SALES_ACCOUNT_GROUP_LINK_BIZ  BIZ_CUST\r\n  ON SYS.BK_SA_MEMBER_ID_INT = BIZ_CUST.BK_SA_MEMBER_ID_INT\r\n AND CNTRL.PROCESS_DATE BETWEEN BIZ_CUST.LINK_START_DT AND BIZ_CUST.LINK_END_DT\r\n LEFT JOIN $$COMREFVWDB.N_SALES_ACCOUNT_GROUP_LINK_BIZ BIZ_TMPLT_CUST\r\n  ON SYS.RU_PARENT_SA_MEMBER_ID_INT = BIZ_TMPLT_CUST.BK_SA_MEMBER_ID_INT  \r\n AND CNTRL.PROCESS_DATE BETWEEN BIZ_TMPLT_CUST.LINK_START_DT AND BIZ_TMPLT_CUST.LINK_END_DT \r\n LEFT JOIN $$COMREFVWDB.$$R_SALES_HIERARCHY SH\r\n  ON SH.SALES_TERRITORY_KEY = SLSTER.SLS_ACCT_GROUP_SALES_TERR_KEY\r\n AND SALES_TERRITORY_TYPE_CODE = 'CORP. REVENUE'  \r\n\r\n UNION ALL\r\n \r\n SELECT\r\n SYS_GEO.CUSTOMER_PARTY_KEY,\r\n -999 AS BK_SA_MEMBER_ID_INT,        \r\n SAV_GEO.SALES_ACCOUNT_GROUP_PARTY_KEY,\r\n -999 AS LINK_CUSTOMER_PARTY_KEY,\r\n COALESCE(SLSTER.SLS_ACCT_GROUP_SALES_TERR_KEY,-999) AS SLS_ACCT_GROUP_SALES_TERR_KEY ,\r\n COALESCE(SAOA.BK_OWNER_SALES_REP_NUM,'-999') AS SALES_REP_NUM,\r\n 'UNKNOWN' AS L6_SALES_TERRITORY_NAME_CODE  ,\r\n 'UNKNOWN' AS L5_SALES_TERRITORY_NAME_CODE  ,\r\n CASE \r\n WHEN COALESCE(SH.ISO_COUNTRY_CODE,'UNK') = 'UNK'\r\n  THEN SH.DD_EXTERNAL_THEATER_NAME\r\n ELSE SH.ISO_COUNTRY_CODE\r\nEND AS ISO_COUNTRY_CODE ,\r\n SYS_GEO.SALES_CREDIT_SPLIT_PCT,\r\n 'GEO_ACCOUNT' AS SALES_ACCOUNT_GROUP_TYPE_CD,\r\n COALESCE(SAOA.HIBERNATION_FLG,'N') AS HIBERNATION_FLG,\r\n CNTRL.PROCESS_TYPE,\r\n CNTRL.YEAR_FLG_INT\r\n FROM $$COMREFVWDB.N_SAG_CP_LK_SYS_VW_GEO_FTR  SYS_GEO\r\n INNER JOIN ( SELECT * FROM $$ETLVWDB.WI_DRR_PROCESS_CONTROL WHERE ACTIVE_FLAG = 'Y' AND PROCESS_TYPE = $$PROCESS_TYPE ) CNTRL \r\n      ON 1=1 and SYS_GEO.SOURCE_DELETED_FLG='N'\r\n\t  and CNTRL.process_date between BK_LINK_START_DT and LINK_END_DT\r\n INNER JOIN $$COMREFVWDB.N_SLS_ACCT_GROUP_SAV_PARTY_TV SAV_GEO\r\n   ON SYS_GEO.SALES_ACCOUNT_GROUP_PARTY_KEY = SAV_GEO.SALES_ACCOUNT_GROUP_PARTY_KEY\r\n  AND SAV_GEO.SALES_ACCOUNT_GROUP_TYPE_CD='GEO_ACCOUNT'\r\n  AND CNTRL.PROCESS_DATE BETWEEN  SAV_GEO.SALES_ACCOUNT_GROUP_START_DT AND SAV_GEO.SALES_ACCOUNT_GROUP_END_DT /*Added date Condition here*/\r\n LEFT JOIN \r\n ( \r\n SELECT * \r\n FROM $$COMREFVWDB.N_SA_GRPSVPTY_TERR_ASGNMNT_TV\r\n INNER JOIN \r\n ( \r\n  SELECT * \r\n  FROM \r\n  $$ETLVWDB.WI_DRR_PROCESS_CONTROL \r\n  WHERE ACTIVE_FLAG = 'Y'  AND PROCESS_TYPE = $$PROCESS_TYPE\r\n ) CL ON 1=1\r\n    WHERE SOURCE_DELETED_FLG = 'N'\r\n  AND CL.PROCESS_DATE BETWEEN START_TV_DT AND END_TV_DT\r\n    QUALIFY ROW_NUMBER() OVER(PARTITION BY SALES_ACCOUNT_GROUP_PARTY_KEY ORDER BY EDW_UPDATE_DTM DESC )=1\r\n ) SLSTER\r\n ON SAV_GEO.SALES_ACCOUNT_GROUP_PARTY_KEY = SLSTER.SALES_ACCOUNT_GROUP_PARTY_KEY \r\n LEFT JOIN\r\n   ( SELECT * FROM $$COMREFVWDB.N_SALES_ACCT_OWNER_ASSIGNMENT\r\n   INNER JOIN \r\n ( \r\n  SELECT * \r\n  FROM \r\n  $$ETLVWDB.WI_DRR_PROCESS_CONTROL \r\n  WHERE ACTIVE_FLAG = 'Y'  AND PROCESS_TYPE = $$PROCESS_TYPE\r\n ) CTL ON 1=1\r\n   WHERE SOURCE_DELETED_FLG = 'N' \r\n    AND CTL.PROCESS_DATE BETWEEN BK_ASSIGNMENT_START_DT AND ASSIGNMENT_END_DT\r\n    QUALIFY ROW_NUMBER() OVER(PARTITION BY SALES_ACCOUNT_GROUP_PARTY_KEY ORDER BY EDW_UPDATE_DTM DESC )=1\r\n   ) SAOA\r\n     ON SAV_GEO.SALES_ACCOUNT_GROUP_PARTY_KEY = SAOA.SALES_ACCOUNT_GROUP_PARTY_KEY\r\n LEFT JOIN $$COMREFVWDB.$$R_SALES_HIERARCHY SH\r\n  ON SH.SALES_TERRITORY_KEY = SLSTER.SLS_ACCT_GROUP_SALES_TERR_KEY\r\n AND SH.SALES_TERRITORY_TYPE_CODE = 'CORP. REVENUE'",
        "User Defined Join": "",
