      "attributes": {
        "Sql Query": "WITH RANDOM_NUMBERS AS (\r\n  SELECT RANDOM(1000000, 1001800) AS RANDOM_KEYS)\r\nSELECT WI.SALES_ORDER_KEY,\r\nCOALESCE(NLS.LOCATOR_KEY,(select RANDOM_KEYS from RANDOM_NUMBERS) * -1) AS SHIP_TO_CONTACT_LOCATOR_KEY,\r\nCOALESCE(NLE.LOCATOR_KEY,(select RANDOM_KEYS from RANDOM_NUMBERS) * -1) AS END_CUSTOMER_CONTACT_LOCATOR_KEY,\r\nCOALESCE(NLB.LOCATOR_KEY,(select RANDOM_KEYS from RANDOM_NUMBERS) * -1) AS BILLING_CONTACT_LOCATOR_KEY,\r\nCOALESCE(NLIC.LOCATOR_KEY,(select RANDOM_KEYS from RANDOM_NUMBERS) * -1) AS INSTALL_SITE_CONTACT_LOCATOR_KEY,\r\nCOALESCE(NLIS.LOCATOR_KEY,(select RANDOM_KEYS from RANDOM_NUMBERS) * -1) AS INSTALL_SITE_CONTACT_PARTY_KEY,\r\nWI.START_TV_DTM AS START_TV_DTM,\r\nWI.END_TV_DTM AS END_TV_DTM,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DATETIME,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DATETIME,\r\nUSER AS EDW_UPDATE_USER\r\nFROM $$STGDB.WI_SALES_ORDER_EXT_CG1 WI\r\nLEFT JOIN\r\n$$COMREFVWDB.N_LOCATOR NLS \r\nON NLS.SK_LOCATOR_ID_INT = COALESCE(WI.SHIP_TO_CONTACT_EMAIL_POINT_ID,WI.SHIP_TO_CONTACT_PHONE_POINT_ID,WI.SHIP_TO_CONTACT_FAX_POINT_ID,(select RANDOM_KEYS from RANDOM_NUMBERS) * -1)\r\nAND NLS.SS_CODE = 'CG'\r\nAND NLS.LOCATOR_TYPE IN ('EMAIL','PHONE','TELEPHONE')\r\nLEFT JOIN\r\n$$COMREFVWDB.N_LOCATOR NLE \r\nON NLE.SK_LOCATOR_ID_INT = COALESCE(WI.END_CUSTOMER_CONTACT_EMAIL_POINT_ID,WI.END_CUSTOMER_CONTACT_PHONE_POINT_ID,WI.END_CUSTOMER_CONTACT_FAX_POINT_ID,(select RANDOM_KEYS from RANDOM_NUMBERS) * -1)\r\nAND NLE.SS_CODE = 'CG'\r\nAND NLE.LOCATOR_TYPE IN ('EMAIL','PHONE','TELEPHONE')\r\nLEFT JOIN\r\n$$COMREFVWDB.N_LOCATOR NLB \r\nON NLB.SK_LOCATOR_ID_INT = COALESCE(WI.BILLING_CONTACT_EMAIL_POINT_ID,WI.BILLING_CONTACT_PHONE_POINT_ID,WI.BILLING_CONTACT_FAX_POINT_ID,(select RANDOM_KEYS from RANDOM_NUMBERS) * -1)\r\nAND NLB.SS_CODE = 'CG'\r\nAND NLB.LOCATOR_TYPE IN ('EMAIL','PHONE','TELEPHONE')\r\nLEFT JOIN\r\n$$COMREFVWDB.N_LOCATOR NLIC \r\nON NLIC.SK_LOCATOR_ID_INT = COALESCE(WI.INSTALL_CONTACT_EMAIL_POINT_ID,WI.INSTALL_CONTACT_PHONE_POINT_ID,WI.INSTALL_CONTACT_FAX_POINT_ID,(select RANDOM_KEYS from RANDOM_NUMBERS) * -1)\r\nAND NLIC.SS_CODE = 'CG'\r\nAND NLIC.LOCATOR_TYPE IN ('EMAIL','PHONE','TELEPHONE')\r\nLEFT JOIN\r\n$$COMREFVWDB.N_LOCATOR NLIS\r\nON NLIS.SK_LOCATOR_ID_INT = COALESCE(WI.INSTALL_SITE_CONTACT_ID,(select RANDOM_KEYS from RANDOM_NUMBERS) * -1)\r\nAND NLIS.SS_CODE = 'CG'\r\nAND NLIS.LOCATOR_TYPE IN ('EMAIL','PHONE','TELEPHONE')\r\nWHERE NOT EXISTS (SELECT 1 FROM $$SLSORDVWDB.N_SO_CR_CONTACTS_TV NSLCR \r\n\t\t\t\t\tWHERE NSLCR.SALES_ORDER_KEY = WI.SALES_ORDER_KEY)",
        "User Defined Join": "",
