      "attributes": {
        "Sql Query": "SELECT\r\nWI.BOOKINGS_MEASURE_KEY,\r\n  WI.BOOKINGS_PROCESS_DATE,\r\n  WI.BKGS_MEASURE_TRANS_TYPE_CODE,\r\n  CASE WHEN NBM.IDE_ADJUSTMENT_CODE IN ('RB','RB1')  THEN -999 ELSE WI.PARTNER_SITE_PARTY_KEY END,\r\n  CASE WHEN NBM.IDE_ADJUSTMENT_CODE IN ('RB','RB1')  THEN 'N' ELSE WI.CHANNEL_BOOKINGS_FLG END,\r\n  WI.CHANNEL_DROP_SHIP_FLG,\r\n  WI.EDW_UPDATE_USER,\r\n  WI.EDW_UPDATE_DATETIME,\r\n  CASE WHEN NBM.IDE_ADJUSTMENT_CODE IN ('RB','RB1')  THEN -999 ELSE WI.PARTNER_SITE_PARTY_KEY END  AS_OF_FSC_MTH_PTR_STE_PRTY_KEY,\r\n  CASE WHEN NBM.IDE_ADJUSTMENT_CODE IN ('RB','RB1')  THEN 'N' ELSE WI.CHANNEL_BOOKINGS_FLG END AS_OF_FSC_MTH_CHANNEL_BKGS_FLG,\r\n  WI.CHANNEL_DROP_SHIP_FLG AS_OF_FSC_MTH_CHNL_DRP_SHP_FLG,\r\n  CASE WHEN NBM.IDE_ADJUSTMENT_CODE IN ('RB','RB1')  THEN 'N' ELSE WI.DV_DRCT_VAL_ADDED_DSTI_ORD_FLG END,\r\n     WI.DV_ROUTE_TO_MARKET_CD, /*ADDED AS A PART OF ICPM Q2FY16*/\r\n    WI.DV_ROUTE_TO_MARKET_CD  DV_AS_OF_FSC_MTH_RTM_CD /*ADDED AS A PART OF ICPM Q2FY16*/,\r\n  CASE WHEN NBM.IDE_ADJUSTMENT_CODE IN ('RB','RB1')  THEN 'REBATES' ELSE WI.BOOKING_CHANNEL_TYPE END AS BOOKING_CHANNEL_TYPE,\r\n  CASE WHEN NBM.IDE_ADJUSTMENT_CODE IN ('RB','RB1')  THEN 'REBATES' ELSE WI.BOOKING_CHANNEL_TYPE END AS AS_OF_FSC_MTH_BKGS_CHANNEL_TYPE,\r\n  COALESCE(WI.MANUAL_PTNR_OVERRIDE_REASON_CD,'UNKNOWN') AS MANUAL_PTNR_OVERRIDE_REASON_CD,\r\n  COALESCE(WI.OTM_OVERRIDE_PTNR_SITE_PARTY_KEY,-999)AS OTM_OVERRIDE_PTNR_SITE_PARTY_KEY,\r\n  COALESCE(WI.MNL_PTNR_SITE_OVERRIDE_FLG,'N') AS MNL_PTNR_SITE_OVERRIDE_FLG,\r\n  'I' ACTION_CODE,\r\n  'I' DML_TYPE\r\n  FROM \r\n   $$STGDB.WI_BKGS_CHNL_MSR_ADJ WI\r\n   LEFT JOIN $$SLSORDVWDB.N_BOOKINGS_MEASURE NBM\r\n  ON (NBM.BOOKINGS_MEASURE_KEY = WI.BOOKINGS_MEASURE_KEY\r\nAND NBM.BOOKINGS_PROCESS_DATE = WI.BOOKINGS_PROCESS_DATE\r\nAND NBM.BKGS_MEASURE_TRANS_TYPE_CODE = WI.BKGS_MEASURE_TRANS_TYPE_CODE)\r\n\r\n  UNION ALL \r\n  \r\n  SELECT\r\n   BOOKINGS_MEASURE_KEY,\r\n   BOOKINGS_PROCESS_DATE,\r\n   BKGS_MEASURE_TRANS_TYPE_CODE,\r\n   PARTNER_SITE_PARTY_KEY,\r\n   CHANNEL_BOOKINGS_FLG,\r\n   CHANNEL_DROP_SHIP_FLG,\r\n   EDW_UPDATE_USER,\r\n   EDW_UPDATE_DATETIME,\r\n   PARTNER_SITE_PARTY_KEY AS_OF_FSC_MTH_PTR_STE_PRTY_KEY,\r\n   CHANNEL_BOOKINGS_FLG AS_OF_FSC_MTH_CHANNEL_BKGS_FLG,\r\n   CHANNEL_DROP_SHIP_FLG AS_OF_FSC_MTH_CHNL_DRP_SHP_FLG,\r\n   DV_DRCT_VAL_ADDED_DSTI_ORD_FLG,\r\n      DV_ROUTE_TO_MARKET_CD, \r\n     DV_ROUTE_TO_MARKET_CD  DV_AS_OF_FSC_MTH_RTM_CD ,\r\n   BOOKING_CHANNEL_TYPE,\r\n   BOOKING_CHANNEL_TYPE AS AS_OF_FSC_MTH_BKGS_CHANNEL_TYPE ,\r\n   COALESCE(MANUAL_PTNR_OVERRIDE_REASON_CD,'UNKNOWN') AS MANUAL_PTNR_OVERRIDE_REASON_CD,\r\n   COALESCE(OTM_OVERRIDE_PTNR_SITE_PARTY_KEY,-999)AS OTM_OVERRIDE_PTNR_SITE_PARTY_KEY,\r\n   COALESCE(MNL_PTNR_SITE_OVERRIDE_FLG,'N') AS MNL_PTNR_SITE_OVERRIDE_FLG,\r\n   'I' ACTION_CODE,\r\n   'I' DML_TYPE\r\n  FROM \r\n   $$STGDB.WI_PPP_REBATE_MERGE_NBCM",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
