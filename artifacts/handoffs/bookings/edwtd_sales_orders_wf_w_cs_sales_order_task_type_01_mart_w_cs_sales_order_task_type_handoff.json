      "attributes": {
        "Sql Query": "SELECT TSK.BK_CS_SALES_ORDER_TASK_TYPE_CD,\r\nTSK.CS_SALES_ORDER_TASK_TYPE_NAME ,         \r\nTSK.ACTION_CODE ,                  \r\nTSK.DML_TYPE  \r\nFROM (\r\n SELECT\r\n   SOCT.TASK_CODE AS BK_CS_SALES_ORDER_TASK_TYPE_CD,\r\n   SOCT.TASK_NAME  AS CS_SALES_ORDER_TASK_TYPE_NAME,\r\n   SOCT. GLOBAL_NAME,\r\n   '='  ACTION_CODE,\r\n   '='  DML_TYPE\r\n  FROM $$STGDB.ST_OM_CEC_TASKS SOCT  \r\n   UNION ALL\r\n SELECT\r\nST_FND.MESSAGE_NAME BK_CS_SALES_ORDER_TASK_TYPE_CD,\r\n(CASE WHEN ST_FND.DESCRIPTION  IS NULL THEN ST_FND.MESSAGE_TEXT\r\nELSE  ST_FND.DESCRIPTION END) AS CS_SALES_ORDER_TASK_TYPE_NAME ,\r\nST_FND.GLOBAL_NAME,\r\n'='  ACTION_CODE,\r\n'='  DML_TYPE\r\n FROM $$STGDB.ST_OM_FND_NEW_MESSAGES ST_FND WHERE NOT EXISTS\r\n (SELECT 1 FROM $$STGDB.ST_OM_CEC_TASKS SOCT  WHERE SOCT.TASK_CODE=ST_FND.MESSAGE_NAME\r\n AND SOCT.GLOBAL_NAME=ST_FND.GLOBAL_NAME) \r\n UNION ALL\r\n  SELECT\r\nST_CG1_FND.MESSAGE_NAME BK_CS_SALES_ORDER_TASK_TYPE_CD,\r\n(CASE WHEN ST_CG1_FND.DESCRIPTION  IS NULL THEN ST_CG1_FND.MESSAGE_TEXT\r\nELSE  ST_CG1_FND.DESCRIPTION END) AS CS_SALES_ORDER_TASK_TYPE_NAME ,\r\nST_CG1_FND.GLOBAL_NAME,\r\n'='  ACTION_CODE,\r\n'='  DML_TYPE\r\n FROM $$STGDB.ST_CG1_FND_NEW_MESSAGES ST_CG1_FND WHERE NOT EXISTS\r\n (SELECT 1 FROM $$STGDB.ST_OM_CEC_TASKS SOCT  WHERE SOCT.TASK_CODE=ST_CG1_FND.MESSAGE_NAME\r\n AND SOCT.GLOBAL_NAME=ST_CG1_FND.GLOBAL_NAME) \r\n AND NOT EXISTS \r\n  (SELECT 1 FROM $$STGDB.ST_OM_FND_NEW_MESSAGES SOFNT  WHERE SOFNT.MESSAGE_NAME=ST_CG1_FND.MESSAGE_NAME\r\n AND SOFNT.GLOBAL_NAME=ST_CG1_FND.GLOBAL_NAME) \r\n)TSK\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY TSK.BK_CS_SALES_ORDER_TASK_TYPE_CD ORDER BY TSK.GLOBAL_NAME DESC)=1",
        "User Defined Join": "",
