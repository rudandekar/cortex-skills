      ],
      "attributes": {
        "Sql Query": "SELECT \r\nROW_NUMBER() OVER (ORDER BY X.HEADER_SEQ_ID,X.SS_CD)+MAX_KEY.VAL SO_CREDIT_ASGN_APPLIED_KEY,\r\nX.HEADER_SEQ_ID SK_HEADER_SEQUENCE_ID_INT,\r\nX.SS_CD,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\n'USER' EDW_CREATE_USER\r\nFROM\r\n(\r\nSELECT Z.HEADER_SEQ_ID,Z.SS_CD\r\nFROM\r\n(\r\nSELECT\r\nAPPLD.HEADER_SEQ_ID HEADER_SEQ_ID,\r\nCASE WHEN APPLD.GLOBAL_NAME='UO' THEN 'QTC'\r\n WHEN APPLD.GLOBAL_NAME='BO' THEN 'BV'END AS SS_CD\r\nFROM $$STGDB.ST_OM_CSM_HDR_SC_APPLD APPLD\r\nUNION\r\nSELECT\r\nDELS.HEADER_SEQ_ID HEADER_SEQ_ID,\r\nCASE WHEN DELS.GLOBAL_NAME='UO' THEN 'QTC'\r\n WHEN DELS.GLOBAL_NAME='BO' THEN 'BV'END AS SS_CD\r\nFROM\r\n$$STGDB.ST_OM_CSM_HDR_SC_APPLD_DEL DELS)Z\r\nWHERE\r\nNOT EXISTS\r\n(SELECT SK_HEADER_SEQUENCE_ID_INT,SS_CD\r\nFROM $$TRANSLATIONDB.SM_SO_CR_ASGN_APLD_TRX SM \r\nWHERE SM.SK_HEADER_SEQUENCE_ID_INT=Z.HEADER_SEQ_ID AND SM.SS_CD=Z.SS_CD))X,\r\n(SELECT COALESCE(MAX(SO_CREDIT_ASGN_APPLIED_KEY),0) VAL FROM $$TRANSLATIONDB.SM_SO_CR_ASGN_APLD_TRX SM)MAX_KEY",
        "User Defined Join": "",
