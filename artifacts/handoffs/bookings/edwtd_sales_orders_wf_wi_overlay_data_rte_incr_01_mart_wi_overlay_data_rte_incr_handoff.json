      "attributes": {
        "Sql Query": "SELECT\r\n  NAOVRLYTV.SK_LINE_SEQ_ID_INT AS SK_TRX_SC_ID_INT,\r\n  NAOVRLYTV.SS_CD AS PD_SS_CD,\r\n  NAOVRLYTV.SALES_CREDIT_ASSIGNMENT_KEY AS SALES_CREDIT_ASSIGNMENT_KEY,\r\n  NAOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD, \r\n  CAST(NAOVRLYTV.SCA_SOURCE_COMMIT_DTM AS DATE FORMAT 'YYYY-MM-DD') AS PD_SCAA_CREATION_DT,\r\n  NAOVRLYTV.SALES_REP_NUM AS  PD_SALES_REP_NUM, \r\n  NAOVRLYTV.SALES_TERRITORY_KEY AS  PD_SALES_TERRITORY_KEY, \r\n  NAOVRLYTV.EP_TRANSACTION_ID_INT AS   EP_TRANSACTION_ID_INT , \r\n  NAOVRLYTV.SCA_SALES_COMMISSION_PCT  AS PD_SALES_COMMISSION_PCT,\r\n  NAOVRLYTV.START_TV_DT AS START_TV_DTM,\r\n  NAOVRLYTV.END_TV_DT AS END_TV_DTM,\r\n  NAOVRLYTV.EDW_CREATE_DTM as EDW_CREATE_DTM,\r\n  NAOVRLYTV.EDW_UPDATE_DTM as EDW_UPDATE_DTM,  \r\n  NAOVRLYTV.EDW_UPDATE_DTM  as PD_SLS_CREDIT_LAST_UPDATE_DTM, \r\n  NAOVRLYTV.SALES_CREDIT_TYPE_CD as SALES_CREDIT_TYPE_CD  ,\r\n  CAST('-999' AS BIGINT) BK_OFFER_ATTRIBUTION_ID_INT,\r\n  'REG_OVL' AS DATA_INDICATOR,  \r\n  CAST(NXAAS.LINE_CREATION_DATE AS DATE FORMAT 'YYYY-MM-DD') AS LINE_CREATION_DATE \r\n  FROM \r\n   $$SLSORDVWDB.N_SCA_FOR_RTE_TRX_OVL_TV NAOVRLYTV   \r\n    INNER JOIN \r\n $$FINLGLVWDB.N_REVENUE_TRANSFER NRT\r\nON NAOVRLYTV.EP_TRANSACTION_ID_INT =NRT.EP_TRANSACTION_ID_INT\r\nAND NRT.TRANSACTION_SOURCE_CD ='XAAS'\r\nINNER JOIN ( SELECT SBSCRPTN_ITEM_CHANGE_ID_INT,CAST(TRX_LINE_CREATION_DTM AS DATE FORMAT 'YYYY-MM-DD') AS LINE_CREATION_DATE\r\nFROM $$SLSORDVWDB.N_XAAS_SO_SBSCR_ITM_SLS_TRX WHERE CAST(TRX_LINE_CREATION_DTM AS DATE FORMAT 'YYYY-MM-DD') >= '2021-08-01'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY SBSCRPTN_ITEM_CHANGE_ID_INT ORDER BY EDW_CREATE_DTM DESC)=1) NXAAS\r\nON NXAAS.SBSCRPTN_ITEM_CHANGE_ID_INT = NRT.SUBSCRIPTION_ITEM_CHANGE_ID_INT\r\n  WHERE   NAOVRLYTV.EDW_UPDATE_DTM> \r\n  (SELECT LAST_EXTRACT_DATE  FROM $$ETLVWdb.CTL_ETL_LAST_EXTRACT_DATES \r\n WHERE JOB_STREAM_ID = 'wf_WI_OVERLAY_DATA_RTE_INCR' AND TABLE_NAME ='N_SCA_FOR_RTE_TRX_OVL_TV')\r\nAND NAOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD NOT IN ('CX')\r\nAND  NOT EXISTS (SELECT 1 FROM $$ETLVWdb.EL_OVERLAY_SUB_LINE_INCLUSION EL \r\nWHERE NAOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD = EL.BK_SLS_TERR_ASSIGNMENT_TYPE_CD \r\n    AND NXAAS.LINE_CREATION_DATE     BETWEEN EL.EFFECTIVE_START_DATE AND EL.EFFECTIVE_END_DATE) \r\n\r\nUNION\r\n\r\nSELECT\r\n  NAOVRLYTV.SK_LINE_SEQ_ID_INT AS SK_TRX_SC_ID_INT,\r\n  NAOVRLYTV.SS_CD AS PD_SS_CD,\r\n  NAOVRLYTV.SALES_CREDIT_ASSIGNMENT_KEY AS SALES_CREDIT_ASSIGNMENT_KEY,\r\n  NAOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD, \r\n  CAST(NAOVRLYTV.SCA_SOURCE_COMMIT_DTM AS DATE FORMAT 'YYYY-MM-DD') AS PD_SCAA_CREATION_DT,\r\n  NAOVRLYTV.SALES_REP_NUM AS  PD_SALES_REP_NUM, \r\n  NAOVRLYTV.SALES_TERRITORY_KEY AS  PD_SALES_TERRITORY_KEY, \r\n  NAOVRLYTV.EP_TRANSACTION_ID_INT AS   EP_TRANSACTION_ID_INT , \r\n  NAOVRLYTV.SCA_SALES_COMMISSION_PCT  AS PD_SALES_COMMISSION_PCT,\r\n  NAOVRLYTV.START_TV_DT AS START_TV_DTM,\r\n  NAOVRLYTV.END_TV_DT AS END_TV_DTM,\r\n  NAOVRLYTV.EDW_CREATE_DTM as EDW_CREATE_DTM,\r\n  NAOVRLYTV.EDW_UPDATE_DTM as EDW_UPDATE_DTM,  \r\n  NAOVRLYTV.EDW_UPDATE_DTM  as PD_SLS_CREDIT_LAST_UPDATE_DTM, \r\n  NAOVRLYTV.SALES_CREDIT_TYPE_CD as SALES_CREDIT_TYPE_CD  ,\r\n  CAST('-999' AS BIGINT) BK_OFFER_ATTRIBUTION_ID_INT,\r\n  'REG_OVL' AS DATA_INDICATOR,  \r\n  CAST(NSOL.LINE_CREATION_DATE AS DATE FORMAT 'YYYY-MM-DD') AS LINE_CREATION_DATE \r\n  FROM \r\n   $$SLSORDVWDB.N_SCA_FOR_RTE_TRX_OVL_TV NAOVRLYTV   \r\n    INNER JOIN \r\n $$FINLGLVWDB.N_REVENUE_TRANSFER NRT\r\nON NAOVRLYTV.EP_TRANSACTION_ID_INT =NRT.EP_TRANSACTION_ID_INT\r\nAND NRT.TRANSACTION_SOURCE_CD ='ERP'\r\n  INNER JOIN $$SLSORDVWDB.N_BOOKINGS_MEASURE ELOVRLY\r\n  ON ELOVRLY.REVENUE_TRANSFER_KEY = NRT.REVENUE_TRANSFER_KEY\r\n  AND  ELOVRLY.REVENUE_TRANSFER_KEY >0  \r\n AND ELOVRLY.BKGS_MEASURE_TRANS_TYPE_CODE = 'AR' \r\nINNER JOIN ( SELECT SALES_ORDER_LINE_KEY,CAST(BK_SO_SRC_CRT_DATETIME AS DATE FORMAT 'YYYY-MM--DD') AS LINE_CREATION_DATE \r\nFROM $$SLSORDVWDB.N_SALES_ORDER_LINE WHERE CAST(BK_SO_SRC_CRT_DATETIME AS DATE FORMAT 'YYYY-MM-DD') >= '2021-08-01' GROUP BY 1,2) NSOL\r\nON NSOL.SALES_ORDER_LINE_KEY = ELOVRLY.DV_SALES_ORDER_LINE_KEY\r\n  WHERE   NAOVRLYTV.EDW_UPDATE_DTM> \r\n  (SELECT LAST_EXTRACT_DATE  FROM $$ETLVWdb.CTL_ETL_LAST_EXTRACT_DATES \r\n WHERE JOB_STREAM_ID = 'wf_WI_OVERLAY_DATA_RTE_INCR' AND TABLE_NAME ='N_SCA_FOR_RTE_TRX_OVL_TV')\r\nAND NAOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD NOT IN ('CX')\r\nAND  NOT EXISTS (SELECT 1 FROM $$ETLVWdb.EL_OVERLAY_SUB_LINE_INCLUSION EL \r\nWHERE NAOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD = EL.BK_SLS_TERR_ASSIGNMENT_TYPE_CD \r\n    AND NSOL.LINE_CREATION_DATE     BETWEEN EL.EFFECTIVE_START_DATE AND EL.EFFECTIVE_END_DATE)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "DELETE FROM $$STGDB.WI_OVERLAY_DATA_RTE_INCR;\r\nDELETE FROM $$STGDB.WI_RTE_SMC_INCR_OLY ALL;\r\n \r\nINSERT INTO $$STGDB.WI_RTE_SMC_INCR_OLY\r\nSELECT DV_TRANSACTION_ID,START_TV_DTM,DV_TRX_TYPE\r\nFROM \r\n(\r\nSELECT\r\nEP_TRANSACTION_ID_INT AS DV_TRANSACTION_ID\r\n,START_TV_DTM\r\n,DV_TRX_TYPE\r\nFROM $$SLSORDVWDB.MT_BKG_SLS_MOTION_ATTRIBUTION MBSA\r\nINNER JOIN \r\n(SELECT  REVENUE_TRANSFER_KEY,SK_SALES_MOTION_ATTRIB_KEY FROM $$SLSORDVWDB.N_BOOKINGS_MEASURE \r\nWHERE  BKGS_MEASURE_TRANS_TYPE_CODE   = 'AR'\r\nAND REVENUE_TRANSFER_KEY>0\r\nGROUP BY 1,2\r\n) NBM \r\nON (MBSA.SK_SALES_MOTION_ATTRIB_KEY=NBM.SK_SALES_MOTION_ATTRIB_KEY)\r\nINNER JOIN \r\n(\r\nSELECT EP_TRANSACTION_ID_INT,REVENUE_TRANSFER_KEY  \r\nFROM $$FINLGLVWDB.N_REVENUE_TRANSFER NRT  \r\nGROUP BY 1,2\r\n) RT\r\nON (NBM.REVENUE_TRANSFER_KEY=RT.REVENUE_TRANSFER_KEY)\r\nWHERE START_TV_DTM > (\r\nSELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.CTL_ETL_LAST_EXTRACT_DATES\r\nWHERE JOB_STREAM_ID = 'wf_WI_OVERLAY_DATA_RTE_INCR' AND TABLE_NAME ='WI_RTE_SMC_INCR_OLY')\r\nAND DV_TRX_TYPE IN ( 'AR','AR_N')\r\nand END_TV_DTM = '3500-01-01 00:00:00'\r\n) AR\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY AR.DV_TRANSACTION_ID ORDER BY AR.START_TV_DTM DESC)=1;\r\n\r\nCOLLECT STATS ON $$STGDB.WI_RTE_SMC_INCR_OLY;",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
  ],
