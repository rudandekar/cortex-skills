      "attributes": {
        "Sql Query": "SELECT  \r\n NP.BK_PRODUCT_ID AS IB_SVC_LVL\r\n,NCL.SVC_CNTRCT_LN_TECH_SVCS_KEY   \r\n,NCL.IP_KEY                        \r\n,NCL.BK_SERVICE_CONTRACT_NUM      \r\n,NCL.SERVICE_STATUS_CD             \r\n,NCL.MAINTENANCE_ORDER_NUM         \r\n,NCL.MAINTENANCE_LIST_LOCAL_AMT    \r\n,ABS(NCL.MAINTENANCE_NET_LOCAL_AMT)    \r\n,NCL.SK_ID_LINT                    \r\n,NCL.SERVICE_PRODUCT_KEY           \r\n,NCL.SOURCE_CREATE_DTM             \r\n,NCL.SOURCE_APPLICATION_NAME       \r\n,NCL.CASE_DETAIL_TXT               \r\n,NCL.SUMMARY_QUOTE_CASE_NUM        \r\n,NCL.SALES_MOTION_CD    \r\n,NCL.BK_SVC_CNTRCT_LINE_START_DTM \r\n,NCL.SVC_CNTRCT_LINE_END_DTM \r\n,NCL.TERMINATED_DTM\r\n,NCL.EDW_UPDATE_USER\r\n,NCL.EDW_CREATE_DTM\r\n,NCL.EDW_UPDATE_DTM\r\n,NCL.DV_LINE_STYLE_ID_INT  \r\n,NULL AS ARCHITECTURE_ID  \r\n,NULL AS TECHNOLOGY_ID  \r\n,NULL AS OFFER_TYPE_ID  \r\n,NULL AS PARTY_SSOT_PARTY_ID_INT  \r\n,NULL AS HQ_PARTY_SSOT_PARTY_ID_INT  \r\n,case when NCL.DV_LINE_STYLE_ID_INT=9 then 'TS' else 'AS' end as AS_TS_FLAG\r\n,ICC_ATT.PID_TYPE as ITEM_CATEGORIZATION --WI.ITEM_CATEGORIZATION\r\n,NULL AS COVERED_INV_ITEM_ID\r\n,NULL AS COVERED_PRODUCT_ID\r\nFROM \r\n$$SERVICEVWDB.N_SVC_CNTRCT_LN_TECH_SERVICES NCL\r\nLEFT OUTER JOIN $$COMREFVWDB.N_PRODUCT NP \r\nON NP.ITEM_KEY = NCL.SERVICE_PRODUCT_KEY \r\nINNER JOIN \r\n(SELECT SOL_BK_SO_NUMBER_INT\r\nFROM\r\n$$MGRSTGDB.WI_SUMMARY_QUOTE_CS_1\r\nGROUP BY 1)WI\r\nON NCL.MAINTENANCE_ORDER_NUM = CAST(WI.SOL_BK_SO_NUMBER_INT AS VARCHAR(40))\r\nLEFT OUTER JOIN  $$STGDB.ST_ITEM_CATEGORY ICC_ATT\r\nON (ICC_ATT.ITEM_NAME=NP.RU_BK_SERVICE_PROD_SUBGROUP_ID)\r\nWHERE\r\nNCL.DV_LINE_STYLE_ID_INT IN(7,9)\r\nAND SERVICE_STATUS_CD NOT IN ('TERMINATED')",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
