      "attributes": {
        "Sql Query": "select \r\nSATQ.BK_AS_QUOTE_NUM ,              \r\nSATQ.QUOTE_TYPE  ,                  \r\nSATQ.AS_QUOTE_STATUS_CD   ,         \r\nSATQ.AS_QUOTE_CREATE_DTM  ,         \r\nSATQ.DV_AS_QUOTE_CREATE_DT  ,       \r\nSATQ.SS_CD        ,                 \r\nSATQ.AS_QUOTE_CREATED_BY_PARTY_KEY ,\r\nSATQ.AS_QUOTE_UPDATED_BY_PARTY_KEY ,\r\nSATQ.DEAL_ID  ,                     \r\nSATQ.AS_QUOTE_UPDATED_DTM  ,        \r\nSATQ.DV_AS_QUOTE_UPDATED_DT,        \r\nCOALESCE(SATQ.AS_MSP_REGION_NAME , 'UNKNOWN') AS AS_MSP_REGION_NAME,\r\nCOALESCE(SATQ.AS_MSP_THEATER_NAME,'UNKNOWN') AS AS_MSP_THEATER_NAME,\r\n--COALESCE(NAMMS.AS_MSP_MARKET_SEGMENT_KEY , -999) AS AS_MSP_MARKET_SEGMENT_KEY, /* Removed as part of 16th Aug 20 Rel */      \r\nSATQ.RU_AS_SBSCRPTN_QUOTE_TYPE_CD  ,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCASE WHEN UPPER(SATQ.AS_QUOTE_STATUS_CD) = 'BOOKED' THEN 'Y' ELSE 'N' END AS BOOKED_ROLE,             \r\nCOALESCE(SATQ.RU_AS_QUOTE_BOOKED_DT,cast('3500/01/01' as date format 'yy/mm/dd'))AS RU_AS_QUOTE_BOOKED_DT  ,     \r\nSATQ.AS_QT_TE_EXCLUDE_FROM_MRGN_FLG,\r\nCOALESCE(SATQ.AS_QUOTE_NAME ,'UNKNOWN') AS AS_QUOTE_NAME,\r\nCOALESCE(SATQ.BK_SOLUTION_NAME,'UNKNOWN') AS BK_SOLUTION_NAME ,  \r\nSATQ.LIST_PRICE_NET_DSCNT_PCT  ,    \r\nSATQ.QUOTING_SALES_CHANNEL_NAME,    \r\nSATQ.QUOTING_END_CUST_SEGMENT_NAME ,\r\nSATQ.DD_MARKET_SEGMENT_NAME    , /* Added as part of 16th Aug 20 Rel */   \r\nSATQ.BK_AS_PROJECT_CD  ,    /* Added as part of 16th Aug 20 Rel */        \r\n'I' AS ACTION_CODE,\r\n'I'  DML_TYPE                     \r\nFROM $$STGDB.ST_AS_QUOTE_HDP SATQ\r\nLEFT OUTER JOIN $$SERVICEVWDB.N_AS_QUOTE NAQ\r\nON (SATQ.BK_AS_QUOTE_NUM = NAQ.BK_AS_QUOTE_NUM )\r\nAND (SATQ.SS_CD = NAQ.SS_CD)\r\n/*LEFT OUTER JOIN \r\n(SELECT AS_MSP_MARKET_SEGMENT_KEY,AS_MSP_MARKET_SEGMENT_DESCR FROM $$SERVICEVWDB.N_AS_MSP_MARKET_SEGMENT\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY AS_MSP_MARKET_SEGMENT_DESCR ORDER BY AS_MSP_MARKET_SEGMENT_STS_CD) =1) NAMMS\r\nON (NAMMS.AS_MSP_MARKET_SEGMENT_DESCR = SATQ.MARKET_SEGMENT_NAME)\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCQP1\r\nON NCQP1.CISCO_EMAIL_ADDRESS = SATQ.AS_QUOTE_SRC_CREATED_BY\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCQP2\r\nON NCQP2.CISCO_EMAIL_ADDRESS = SATQ.AS_QUOTE_SRC_UPDATED_BY*/ /* Removed as part of 16th Aug 20 Rel */",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "COLLECT STATS ON $$STGDB.ST_AS_QUOTE_HDP;\r\n\r\nDELETE FROM $$WORKDB.W_AS_QUOTE_SEP ALL;",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
