      "attributes": {
        "Sql Query": "SELECT\r\nRBQ.FISCAL_YEAR_QUARTER_NUMBER_INT,\r\nRTM.ADVANCED_TECHNOLOGY_NAME,\r\nBECB.DD_CUSTOMER_PARTY_KEY,\r\nMCPH.HQ_CUSTOMER_PARTY_KEY,\r\nRBQ.SALES_TERRITORY_KEY,\r\nRBQ.PARTNER_PARTY_SITE_KEY,        \r\nSUM(RBQ.COMP_US_NET_PRICE_AMOUNT * DOLLAR_ALLOCATION_PERCENTAGE)  AS COMP_US_NET_PRICE_AMOUNT,\r\nsum(RBQ.COMP_US_STANDARD_PRICE_AMT * DOLLAR_ALLOCATION_PERCENTAGE) AS COMP_US_STANDARD_PRICE_AMT,\r\nsum(RBQ.COMP_US_LIST_PRICE_AMOUNT * DOLLAR_ALLOCATION_PERCENTAGE) AS COMP_US_LIST_PRICE_AMOUNT,\r\nsum(RBQ.EXTENDED_QUANTITY * DV_ACTUAL_UNIT_ALOC_PERCENTAGE) AS EXTENDED_QUANTITY\r\nFROM \r\n$$SLSORDVWDB.R_BKGS_BY_QUARTER RBQ\r\nINNER JOIN \r\n$$ETLVWDB.BT_END_CUSTOMER_BRIDGE BECB \r\nON\r\nRBQ.END_CUSTOMER_KEY = BECB.END_CUSTOMER_KEY  \r\nINNER JOIN \r\n$$COMREFVWDB.MT_CUSTOMER_PARTY_HIERARCHY MCPH\r\nON\r\nMCPH.BRANCH_CUSTOMER_PARTY_KEY = BECB.DD_CUSTOMER_PARTY_KEY\r\nINNER JOIN\r\n$$COMREFVWDB.N_TMS_CORP_PRODUCT_ALLOC NTCP                     \r\nON\r\nRBQ.PRODUCT_KEY = NTCP.ITEM_KEY\r\nINNER JOIN\r\n$$COMREFVWDB.R_TECH_MKT_SEGMENT   RTM \r\nON\r\nRTM.TECHNOLOGY_MARKET_SEGMENT_KEY = NTCP.TECHNOLOGY_MARKET_SEGMENT_KEY\r\nINNER JOIN \r\n$$COMREFVWDB.R_FISCAL_QUARTER_TO_YEAR RFQY\r\nON \r\nRBQ.FISCAL_YEAR_QUARTER_NUMBER_INT = RFQY.FISCAL_YEAR_QUARTER_NUMBER_INT\r\nWHERE\r\nHIERARCHY_TYPE = 'TMS_CORPORATE'\r\nAND\r\nFISCAL_QTR_AGE<12\r\ngroup by\r\nRBQ.FISCAL_YEAR_QUARTER_NUMBER_INT,\r\nRTM.ADVANCED_TECHNOLOGY_NAME,\r\nBECB.DD_CUSTOMER_PARTY_KEY,\r\nMCPH.HQ_CUSTOMER_PARTY_KEY,\r\nRBQ.SALES_TERRITORY_KEY,\r\nRBQ.PARTNER_PARTY_SITE_KEY",
        "User Defined Join": "",
