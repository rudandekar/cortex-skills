        "Sql Query": "SELECT\t\r\nNDNBT.DRVD_NCR_BKG_TRX_KEY \t\t\t\tDRVD_NCR_BKG_TRX_KEY,\r\nNDNBT.SALES_ORDER_LINE_KEY  \t\t\tSALES_ORDER_LINE_KEY,\r\nNDNBT.SALES_ORDER_KEY  \t\t\t\t\tSALES_ORDER_KEY,\r\nNDNBT.PROCESS_DATE \t\t\t\t\t\tPROCESS_DATE,\r\nNDNBT.DD_ITEM_TYPE_CODE_FLAG \t\t\tDD_ITEM_TYPE_CODE_FLAG,\r\n\tCASE\r\n\t\t\tWHEN\tNSOT.SALES_ORDER_CATEGORY_TYPE ='RETURN'\r\n\t THEN 'Y'\r\n\t\t\tELSE\t'N'\r\n\t\tEND\t    DD_RMA_FLAG,\r\n\tCASE\r\n\t\t\tWHEN\tSUBSTR(NSOT.BK_ORDER_TYPE_NAME,1,8) ='Standard'\r\n\t\tTHEN\r\n\t\tCASE\r\n\t\t\tWHEN\t  NSOT.SHIPMENT_PRIORITY_CODE='Demo' THEN 'Y'\r\n\t\t\t\tWHEN\t NSOT.SHIPMENT_PRIORITY_CODE= 'Evaluation' THEN 'Y' \r\n\t\t\t\tWHEN\tNSOT.SHIPMENT_PRIORITY_CODE= 'Int''l Demo' THEN 'Y'\r\n\t\t\t\tWHEN\tNSOT.SHIPMENT_PRIORITY_CODE='Intl Demo' THEN 'Y'\r\n\t\t\t\tELSE\t'N'\r\n\t\tEND\r\n\t\tELSE\t'N'\r\n\t\tEND\t \t\t\t\t\t\t\tDD_INTERNATIONAL_DEMO_FLAG,\r\n\tCASE\r\n\t\t\tWHEN\tSUBSTR(NSOT.BK_ORDER_TYPE_NAME,1,11) ='Replacement'\r\n\t\tTHEN\r\n\t\tCASE\r\n\t\t\tWHEN\t  NSOT.SHIPMENT_PRIORITY_CODE='Demo' THEN 'Y'\r\n\t\t\t\t\tWHEN\t NSOT.SHIPMENT_PRIORITY_CODE= 'Evaluation' THEN 'Y' \r\n\t\t\t\t\tWHEN\tNSOT.SHIPMENT_PRIORITY_CODE= 'Int''l Demo' THEN 'Y'\r\n\t\t\t\t\tWHEN\tNSOT.SHIPMENT_PRIORITY_CODE='Intl Demo' THEN 'Y'\r\n\t\t\t\t\tELSE\t'N'\r\n\t\tEND\r\n\t\tELSE\t'N'\r\n\t\tEND\t\t\t\t\t\t\tDD_REPLACEMENT_DEMO_FLAG,\r\n\t\tCASE\r\n\t\t\tWHEN\tNSOTT.SO_TYPE_REVENUE_GEN_FLAG IS NULL \r\n\tTHEN 'N' \r\n\tELSE\tNSOTT.SO_TYPE_REVENUE_GEN_FLAG\r\n\t\tEND\t\tDD_REVENUE_FLAG,\r\nNDNBT.DD_OVERLAY_FLAG DD_OVERLAY_FLAG,\r\nNDNBT.DD_SALESREP_FLAG ,\r\n\t\tCASE\r\n\t\t\tWHEN\tNCAT.INTERNAL_CUSTOMER_FLAG='I' \r\n\t\t\tTHEN 'N'\r\n\t\t\tWHEN NCAT.INTERNAL_CUSTOMER_FLAG IS NULL\r\n\t\t\tTHEN 'N'\r\n\t\t\tELSE\t'Y'\r\n\t\tEND\tDD_IC_REVENUE_FLAG,\r\n\t\tCASE\r\n\t\t\tWHEN\tNP.BK_PRODUCT_TYPE_ID= 'CHARGES' \r\n\tTHEN 'Y'\r\n\t\t\tELSE\t'N'\r\n\t\tEND\t\t\t\t\t\t\tDD_CHARGES_FLAG, \r\n\t\tCASE\r\n\t\t\tWHEN\tSUBSTR(NP.BK_PRODUCT_ID,1,4)= 'MISC' \r\n\tTHEN 'Y'\r\n\t\t\tELSE\t'N'\r\n\t\tEND\t\t\t\t\t\tDD_MISC_FLAG,\r\n\t\tCASE\r\n\t\t\tWHEN\tNSOT.BK_SO_SOURCE_NAME ='EC ACQUISITION' \r\n\t\tTHEN 'Y'\r\n\tWHEN\tNSOT.BK_SO_SOURCE_NAME = 'ACQUISITION CONVERSION' \r\n\t\tTHEN 'Y'\r\n\tWHEN\tNSOT.BK_SO_SOURCE_NAME ='BACKLOG CONVERSION' \r\n\t\tTHEN 'Y'\r\n\t\t\tELSE\t'N'\r\n\t\tEND\t\t\t\t\t\tDD_ACQUISITION_FLAG,\r\n\t\tCASE\r\n\t\t\tWHEN\tNP.GOODS_OR_SERVICE_TYPE ='SERVICE' \r\n\tTHEN 'Y'\r\n\t\t\tELSE\t'N'\r\n\t\tEND\t\t\t\t\t\t\tDD_SERVICE_FLAG,\r\n'=' DD_REV_REC_FLAG,   /* Modified Part of True Demand replaced corp bkg flag with rev rec flag */\r\nNDNBT.DV_REVENUE_RECOGNITION_FLG  ORIG_REV_REC_FLAG, /* Modified Part of True Demand replaced corp bkg flag with rev rec flag */\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DATETIME,\r\nUSER  EDW_CREATE_USER\t\r\nFROM\r\n$$SLSORDVWDB.N_DRVD_NCR_BKG_TRX NDNBT\r\nINNER JOIN  $$STGDB.WI_PROCESS_DATES_DRVD_RECOMP NFM\r\n\tON( NDNBT.PROCESS_DATE =NFM.BK_CALENDAR_DATE)\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER NSOT\r\n\tON( NDNBT.SALES_ORDER_KEY=NSOT.SALES_ORDER_KEY)\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_TYPE  NSOTT  \r\n\tON( NSOT.BK_ORDER_TYPE_NAME=NSOTT.BK_ORDER_TYPE_NAME)\r\nLEFT OUTER JOIN ( $$COMREFVWDB.N_CUSTOMER_ACCOUNT NCAT\r\n \t\t\tINNER JOIN\t $$COMREFVWDB.N_ERP_PARTY NPT\r\n\t\t\tON( NCAT.ERP_CUSTOMER_NUMBER= NPT.ERP_PARTY_NUMBER\r\n\t\t\tAND\t\tNPT.ERP_PARTY_NAME NOT LIKE '%REGRESSION%TEST%' )\r\n\t\t\t )\r\n\tON(NDNBT.SOLD_TO_CUSTOMER_KEY= NCAT.CUSTOMER_ACCOUNT_KEY)\r\nINNER JOIN   $$COMREFVWDB.N_PRODUCT NP\r\n\tON(NDNBT.PRODUCT_KEY=NP.ITEM_KEY)",
