        "Sql Query": "SELECT \r\nWSOCO.SO_CHANGE_ORDER_KEY, \r\nWSOCO.SK_XXCCP_HDR_ID_INDCTR_INT, \r\nWSOCO.STATUS_CD, WSOCO.SUB_STATUS_CD, \r\nWSOCO.CHANGE_TYPE_CD, \r\nWSOCO.SALES_ORDER_KEY,\r\nWSOCO.CHANGE_ORDER_CREATION_DTM,\r\nWSOCO.DV_CHANGE_ORDER_CREATION_DT,\r\nWSOCO.CHANGE_ORDER_LAST_UPDATE_DTM,\r\nWSOCO.DV_CHANGE_ORDER_LAST_UPDATE_DT,\r\nWSOCO.EDW_CREATE_DTM,\r\nWSOCO.EDW_CREATE_USER,\r\nWSOCO.EDW_UPDATE_DTM,\r\nWSOCO.EDW_UPDATE_USER\r\nFROM\r\n $$WORKDB.W_SALES_ORDER_CHANGE_ORDER WSOCO\r\n WHERE  WSOCO.DML_TYPE='I'\r\nAND NOT EXISTS\r\n( SELECT 1 FROM $$SLSORDVWDB.N_SALES_ORDER_CHANGE_ORDER NSOCO\r\nWHERE NSOCO.SK_XXCCP_HDR_ID_INDCTR_INT=WSOCO.SK_XXCCP_HDR_ID_INDCTR_INT)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
