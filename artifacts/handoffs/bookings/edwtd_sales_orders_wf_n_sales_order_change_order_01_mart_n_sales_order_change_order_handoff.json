        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "UPDATE  NSOCO\r\nFROM\r\n$$SLSORDVWDB.N_SALES_ORDER_CHANGE_ORDER NSOCO,\r\n$$WORKDB.W_SALES_ORDER_CHANGE_ORDER WSOCO\r\nSET\r\nSTATUS_CD \t\t\t\t\t=\t\t\tWSOCO.STATUS_CD, \r\nSUB_STATUS_CD \t\t\t\t= \t\t\tWSOCO.SUB_STATUS_CD, \r\nCHANGE_TYPE_CD \t\t\t\t=\t\t\tWSOCO.CHANGE_TYPE_CD, \r\nCHANGE_ORDER_CREATION_DTM \t=\t\t\tWSOCO.CHANGE_ORDER_CREATION_DTM,\r\nDV_CHANGE_ORDER_CREATION_DT =\t\t\tWSOCO.DV_CHANGE_ORDER_CREATION_DT,\r\nCHANGE_ORDER_LAST_UPDATE_DTM = \t\t\tWSOCO.CHANGE_ORDER_LAST_UPDATE_DTM,\r\nDV_CHANGE_ORDER_LAST_UPDATE_DT =\t\tWSOCO.DV_CHANGE_ORDER_LAST_UPDATE_DT,\r\nEDW_UPDATE_DTM \t\t\t\t= \t\t\tCURRENT_TIMESTAMP(0),\r\nEDW_UPDATE_USER\t\t\t\t= \t\t\tUSER\r\nWHERE\r\nNSOCO.SO_CHANGE_ORDER_KEY = WSOCO.SO_CHANGE_ORDER_KEY\r\nAND WSOCO.DML_TYPE='U';",
