      "attributes": {
        "Sql Query": "SELECT\r\nNPOS.BK_POS_TRANSACTION_ID_INT POS_TRANSACTION_ID_INT\r\n,coalesce(NPOA.BK_OFFER_ATTRIBUTION_ID_INT,-9999) AS OFFER_ATTRIBUTION_ID_INT\r\n,BP.SK_INVENTORY_ITEM_ID_INT AS ATTRIBUTED_INV_ITEM_ID\r\n,BP.BK_PRODUCT_ID AS ATTRIBUTED_PRODUCT\r\n,NPOS.RU_SERVICE_CONTRACT_START_DTM AS COVERAGE_SD\r\n,NPOS.RU_SERVICE_CONTRACT_END_DTM AS COVERAGE_ED\r\n,NPOS.BK_END_USER_WIPS_SITE_USE_KEY AS END_CUSTOMER\r\n,MCPH.CX_CUSTOMER_BU_ID AS END_CUSTOMER_HQ\r\n,BP.ATTR_PRDT_CLASS_NAME\r\n,'POS'AS BKGS_MEASURE_TRANS_TYPE_CODE\r\n,CASE WHEN NPOA.BK_POS_TRANSACTION_ID_INT IS NOT NULL THEN ATTRIBUTION_CD ELSE 'STANDALONE' END AS DV_ATTRIBUTION_CD\r\n,BP1.SK_INVENTORY_ITEM_ID_INT AS ORDERED_INV_ITEM_ID\r\n,BP1.BK_PRODUCT_ID AS ORDER_PRODUCT_CD\r\n,CASE WHEN BP.GOODS_OR_SERVICE_TYPE='GOODS' THEN 'N' ELSE 'Y' END AS SERVICE_FLG\r\n,BP1.ITEM_CATALOG_GROUP_CD AS ITEM_CATEGORIZATION_CD\r\n,'N' AS TRY_AND_BUY_FLG\r\n,NPOS.POS_TRX_LINE_POSTED_DATE AS CISCO_BOOKED_DTM\r\n,coalesce(POS_SOL_LINK.SALES_ORDER_LINE_KEY,-7777) as SALES_ORDER_LINE_KEY\r\n,'N' as PROCESS_FLAG\r\n,CASE WHEN COALESCE(PNVR.SRC_RPTD_CONTRACT_NUM , NPOS.SERVICE_CONTRACT_NUMBER )='UNKNOWN' THEN NULL\r\nELSE COALESCE(PNVR.SRC_RPTD_CONTRACT_NUM , NPOS.SERVICE_CONTRACT_NUMBER ) END AS DV_CONTRACT_NUMBER\r\n,BP.ITEM_CATALOG_GROUP_CD ITEM_CATALOG_GROUP_CD\r\n,NPOS.BK_SHIP_TO_WIPS_SITE_USE_KEY\r\n,MCPH.CUSTOMER_PARTY_KEY\r\n--,BV_BKGS_MEASURE.DV_SO_SBSCRPTN_ITM_SLS_TRX_KEY\r\n,NULL AS SUBSCRIPTION_PRODUCT_KEY\r\n,NULL AS LICENSE_PRODUCT_KEY\r\nFROM (SEL BK_POS_TRANSACTION_ID_INT,RU_SERVICE_CONTRACT_START_DTM,RU_SERVICE_CONTRACT_END_DTM,BK_END_USER_WIPS_SITE_USE_KEY,\r\nPOS_TRX_LINE_POSTED_DATE,PRODUCT_KEY,BK_SHIP_TO_WIPS_SITE_USE_KEY ,SERVICE_CONTRACT_NUMBER\r\nFROM $$SLSORDVWDB.N_POS_TRANSACTION_LINE WHERE BK_POS_TRANSACTION_ID_INT IN (SELECT POS_TRANSACTION_ID_INT FROM $$STGDB.ST_SW_EL_POS_TRANS)\r\nUNION\r\nSEL BK_POS_TRANSACTION_ID_INT,RU_SERVICE_CONTRACT_START_DTM,RU_SERVICE_CONTRACT_END_DTM,BK_END_USER_WIPS_SITE_USE_KEY,POS_TRX_LINE_POSTED_DATE,\r\nPRODUCT_KEY,BK_END_USER_WIPS_SITE_USE_KEY,'UNKNOWN' AS SERVICE_CONTRACT_NUMBER\r\nFROM $$SLSORDVWDB.N_BKG_POS_TRANSACTION_LINE WHERE BK_POS_TRANSACTION_ID_INT IN (SELECT POS_TRANSACTION_ID_INT FROM $$STGDB.ST_SW_EL_POS_TRANS)) NPOS\r\n--ON NPOS.BK_POS_TRANSACTION_ID_INT=BV_BKGS_MEASURE.BK_POS_TRANSACTION_ID_INT\r\nINNER JOIN (SEL TRANS_ID,END_TV_DTM FROM $$ETLVWDB.EL_POS_TRX_LN_AS_NEW_OR_RNWL_ALL WHERE TRANS_ID IN (SELECT POS_TRANSACTION_ID_INT FROM $$STGDB.ST_SW_EL_POS_TRANS)\r\nGROUP BY 1,2) EL_ALL\r\nON NPOS.BK_POS_TRANSACTION_ID_INT=EL_ALL.TRANS_ID\r\nAND END_TV_DTM='3500-01-01 00:00:00'\r\nLEFT JOIN (\r\nSELECT TRANS_ID AS BK_POS_TRANSACTION_ID_INT,MAX(SALES_ORDER_LINE_KEY) AS SALES_ORDER_LINE_KEY,\r\nCOUNT(DISTINCT SALES_ORDER_LINE_KEY) AS CNT\r\nFROM\r\n$$ETLVWDB.EL_POS_TRX_LN_AS_NEW_OR_RNWL_ALL\r\nWHERE\r\nEND_TV_DTM >= DATE'3500-01-01'\r\nAND SALES_ORDER_LINE_KEY > 0\r\nGROUP BY TRANS_ID\r\nHAVING COUNT(DISTINCT SALES_ORDER_LINE_KEY) = 1\r\n) POS_SOL_LINK\r\nON NPOS.BK_POS_TRANSACTION_ID_INT=POS_SOL_LINK.BK_POS_TRANSACTION_ID_INT\r\nLEFT JOIN $$SLSORDVWDB.N_POS_TRX_LINE_OFFER_ATRBTN NPOA\r\nON NPOS.BK_POS_TRANSACTION_ID_INT=NPOA.BK_POS_TRANSACTION_ID_INT\r\nLEFT JOIN ( SELECT TRANS_ID AS BK_POS_TRANSACTION_ID_INT,NSOL.ru_service_contract_number AS SRC_RPTD_CONTRACT_NUM\r\nFROM $$ETLVWDB.EL_POS_TRX_LN_AS_NEW_OR_RNWL_ALL PNVR, $$SLSORDVWDB.N_SALES_ORDER_LINE NSOL\r\nWHERE PNVR.SALES_ORDER_LINE_KEY=NSOL.SALES_ORDER_LINE_KEY\r\nAND PNVR.END_TV_DTM = '3500-01-01 00:00:00'\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY TRANS_ID ORDER BY START_TV_DTM DESC ) = 1) PNVR\r\nON NPOS.BK_POS_TRANSACTION_ID_INT = PNVR.BK_POS_TRANSACTION_ID_INT\r\nLEFT JOIN $$COMREFVWDB.N_PRODUCT BP\r\nON (BP.ITEM_KEY = CASE WHEN NPOA.ATTRIBUTED_PRODUCT_KEY IS NOT NULL THEN NPOA.ATTRIBUTED_PRODUCT_KEY ELSE NPOS.PRODUCT_KEY END)\r\nLEFT JOIN $$COMREFVWDB.N_PRODUCT BP1\r\nON (BP1.ITEM_KEY = NPOS.PRODUCT_KEY)\r\nLEFT JOIN (SELECT B.END_CUSTOMER_KEY,A.CX_CUSTOMER_BU_ID,A.CUSTOMER_PARTY_KEY FROM $$COMREFVWDB.MT_CXCUST_BU_PARTY_MAPPING A,\r\n$$ETLVWDB.BT_END_CUSTOMER_BRIDGE B\r\nWHERE A.CUSTOMER_PARTY_KEY=B.DD_CUSTOMER_PARTY_KEY) MCPH\r\nON NPOS.BK_END_USER_WIPS_SITE_USE_KEY=MCPH.END_CUSTOMER_KEY\r\nWHERE BP1.MONETIZATION_TYPE_CD IN ('TERM')\r\nAND BP1.PRDT_SETUP_CLASSIFICATION_CD IN ('SOFTWARE')\r\nAND NOT EXISTS (SELECT 1 FROM $$STGDB.WI_SW_EL_POS_TRANS_INCR INCR\r\nWHERE NPOS.BK_POS_TRANSACTION_ID_INT=INCR.POS_TRANSACTION_ID_INT\r\nAND coalesce(NPOA.BK_OFFER_ATTRIBUTION_ID_INT,-9999)=INCR.OFFER_ATTRIBUTION_ID_INT)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
