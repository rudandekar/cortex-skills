      "attributes": {
        "Sql Query": "SELECT\r\nMAIN.BK_AS_QUOTE_NUM AS BK_AS_QUOTE_NUM,\r\nMAIN.BK_AS_QUOTE_MILESTONE_NUM_INT AS BK_AS_QUOTE_MILESTONE_NUM_INT ,\r\nMAIN.BK_AS_QUOTE_MILESTONE_TASK_NUM AS BK_AS_QUOTE_MILESTONE_TASK_NUM,\r\nCASE WHEN MAIN.PRODUCT_KEY = -999 THEN   coalesce(PRDT.ITEM_KEY , -999)                 \r\n            ELSE  MAIN.PRODUCT_KEY \r\nEND AS PRODUCT_KEY,\r\nMAIN.BK_AS_BUSINESS_SERVICE_NAME AS BK_AS_BUSINESS_SERVICE_NAME,\r\nMAIN.BK_AS_ARCHITECTURE_NAME AS BK_AS_ARCHITECTURE_NAME,\r\nMAIN.BK_AS_TECHNOLOGY_NAME AS BK_AS_TECHNOLOGY_NAME,\r\nMAIN.SOURCE_DELETED_FLG AS SOURCE_DELETED_FLG,\r\nMAIN.AS_QT_MS_TSK_ATB_SPLIT_PCT_INT AS AS_QT_MS_TSK_ATB_SPLIT_PCT_INT,\r\nMAIN.BK_AS_SUBTECHNOLOGY_NAME AS BK_AS_SUBTECHNOLOGY_NAME,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nMAIN.SS_CD AS BK_SS_CD,\r\nMAIN.OFFER_NAME AS RU_OFFER_NAME,\r\nMAIN.CHILD_SKU,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NQMT.BK_AS_QUOTE_NUM IS NULL THEN 'I'  ELSE 'U' END AS DML_TYPE\r\n\r\nFROM \r\n$$STGDB.ST_AS_QUOTE_MILESTONE_TASK_ATB_HDP MAIN\r\nLEFT OUTER JOIN $$COMREFVWDB.R_PRODUCTS PRDT\r\nON MAIN.BK_PRODUCT_ID = PRDT.BK_PRODUCT_ID\r\nLEFT OUTER JOIN $$SERVICEVWDB.N_AS_QUOTE_MILESTONE_TASK_ATB NQMT\r\nON MAIN.BK_AS_QUOTE_NUM = NQMT.BK_AS_QUOTE_NUM\r\nAND MAIN.BK_AS_QUOTE_MILESTONE_NUM_INT = NQMT.BK_AS_QUOTE_MILESTONE_NUM_INT\r\nAND MAIN.BK_AS_QUOTE_MILESTONE_TASK_NUM = NQMT.BK_AS_QUOTE_MILESTONE_TASK_NUM\r\nAND MAIN.PRODUCT_KEY = NQMT.PRODUCT_KEY\r\nAND MAIN.BK_AS_BUSINESS_SERVICE_NAME = NQMT.BK_AS_BUSINESS_SERVICE_NAME\r\nAND MAIN.BK_AS_ARCHITECTURE_NAME = NQMT.BK_AS_ARCHITECTURE_NAME\r\nAND MAIN.BK_AS_TECHNOLOGY_NAME = NQMT.BK_AS_TECHNOLOGY_NAME\r\nAND MAIN.BK_AS_SUBTECHNOLOGY_NAME= NQMT.BK_AS_SUBTECHNOLOGY_NAME\r\nAND MAIN.SS_CD= NQMT.BK_SS_CD",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "COLLECT STATS ON $$STGDB.ST_AS_QUOTE_MILESTONE_TASK_ATB_HDP;\r\n\r\nDELETE FROM $$WORKDB.W_AS_QT_MILESTONE_TSK_ATB_SEP ALL;",
        "Post SQL": "",
