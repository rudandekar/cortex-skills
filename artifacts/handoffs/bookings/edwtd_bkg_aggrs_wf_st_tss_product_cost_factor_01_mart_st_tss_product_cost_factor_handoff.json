      "attributes": {
        "Sql Query": "SELECT\r\nPRODUCT_KEY, \r\nBK_ISO_COUNTRY_CD, \r\nBK_PRICE_LIST_NAME, \r\nSALES_TERRITORY_NAME, \r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nCOST_FACTOR_PCT, \r\nCOUNTRY_FLG, \r\nREBATE_FACTOR_PCT,\r\nEDW_UPLOAD_USER\r\nFROM( \r\nSELECT \r\nPRODUCT_KEY,\r\nBK_ISO_COUNTRY_CD,\r\nBK_PRICE_LIST_NAME,\r\nSALES_TERRITORY_NAME_CODE AS SALES_TERRITORY_NAME ,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nCOST_FACTOR_PCT,\r\nCOUNTRY_FLG,\r\nREBATE_FACTOR_PCT,\r\nEDW_UPLOAD_USER\r\nFROM \r\n(\r\nSELECT \r\nPRD.ITEM_KEY  AS PRODUCT_KEY,\r\nCTR.BK_ISO_COUNTRY_CODE  AS BK_ISO_COUNTRY_CD,\r\nCAST(APP_TSS.PRICE_LIST_ID AS VARCHAR(100))  AS BK_PRICE_LIST_NAME,\r\nSH.SALES_TERRITORY_NAME_CODE,\r\nAPP_TSS.BKGS_MEASURE_TRANS_TYPE_CODE,\r\nAPP_TSS.COST_FACTOR  AS COST_FACTOR_PCT,\r\nCASE WHEN APP_TSS.COUNTRY_NAME='UNKNOWN' THEN 'N' ELSE 'Y' END COUNTRY_FLG,\r\nAPP_TSS.REBATE_FACTOR AS REBATE_FACTOR_PCT,\r\nAPP_TSS.EDW_UPLOAD_USER\r\nFROM $$MBRDATAVWDB.APP_MBR_TSS_COUNTRY_FACTOR APP_TSS\r\nINNER JOIN $$COMREFVWDB.R_PRODUCTS PRD ON APP_TSS.SKU=PRD.BK_PRODUCT_ID\r\nINNER JOIN $$COMREFVWDB.N_ISO_COUNTRY CTR ON  APP_TSS.COUNTRY_NAME=CTR.ISO_COUNTRY_NAME\r\nINNER JOIN $$COMREFVWDB.R_SALES_HIERARCHY SH ON APP_TSS.SALES_TERRITORY_DESCR=SH.SALES_TERRITORY_DESCR\r\n) TSS\r\n) ST_TSS",
        "User Defined Join": "",
        "Source Filter": "",
