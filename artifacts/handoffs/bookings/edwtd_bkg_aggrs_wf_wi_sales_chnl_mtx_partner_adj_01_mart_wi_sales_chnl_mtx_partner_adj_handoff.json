      "attributes": {
        "Sql Query": "SELECT\r\n WI.SALES_TERRITORY_KEY  ,         \r\nWI.SOLD_TO_CUSTOMER_KEY,\r\nWI.END_CUSTOMER_KEY,\r\nWI.BILL_TO_CUSTOMER_KEY,\r\n--BOOKINGS_PROCESS_DATE,\r\nCUST_SOLD.CUSTOMER_PARTY_KEY,\r\nCUST_BILL.CUSTOMER_PARTY_KEY,\r\nCUST_END.CUSTOMER_PARTY_KEY,\r\nCASE WHEN SOLD_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NULL \r\n    THEN -999\r\n            WHEN BILL_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NULL\r\n         THEN COALESCE(SOLD_TO_PARENT.PARTNER_SITE_PARTY_KEY ,-999)\r\n            WHEN  SOLD_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY =BILL_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY \r\n         THEN BILL_TO_PARENT.PARTNER_SITE_PARTY_KEY\r\n              WHEN  SOLD_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY  <> BILL_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY \r\n         THEN SOLD_TO_PARENT.PARTNER_SITE_PARTY_KEY\r\n       ELSE  -999\r\n        END         PARTNER_PARTY_KEY_AS_IS,\r\n\t\tCASE WHEN PARTNER_PARTY_KEY_AS_IS =-999 AND CUST_SOLD.REBOK_CUST_NAME LIKE ANY  ('%CS CAPITAL%','%CISCO SYSTEMS CAPITAL%', 'CISCO SYSTEMS FINANCE %','EXPEDIA INC')\r\n  THEN COALESCE(SHIP_TO_PARENT.PARTNER_SITE_PARTY_KEY,-999) \r\n  ELSE PARTNER_PARTY_KEY_AS_IS END AS PARTNER_PARTY_KEY,\r\n        \r\n  CASE WHEN SOLD_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NULL \r\n    THEN 'SOLD_TO'\r\n       WHEN BILL_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY IS NULL  \r\n         THEN 'SOLD_TO' \r\n       WHEN  SOLD_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY =BILL_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY \r\n         THEN 'BILL_TO'\r\n       WHEN  SOLD_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY  <> BILL_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY \r\n         THEN 'SOLD_TO'\r\n       ELSE 'SOLD_TO'\r\n  END         PARTNER,\r\n  \r\n  COALESCE(SOLD_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY,-999) SOLD_TO_GRAND_PRNT_PTY_KEY ,\r\n  BILL_TO_PARENT.DD_GRNDPARNT_PARTNER_PARTY_KEY     BILL_TO_GRAND_PRNT_PTY_KEY,\r\n  USER               EDW_CREATE_USER,\r\n  CURRENT_TIMESTAMP(0)       EDW_CREATE_DATETIME,\r\n  WI.SHIP_TO_CUSTOMER_KEY\r\nFROM\r\n$$STGDB.WI_SALES_CHNL_MTX_PATTERNS_ADJ WI\r\nLEFT JOIN $$COMREFVWDB.N_REBOK_CUSTOMER CUST_BILL\r\nON CUST_BILL.REBOK_CUST_KEY=WI.BILL_TO_CUSTOMER_KEY\r\nLEFT JOIN $$COMREFVWDB.N_REBOK_CUSTOMER CUST_SOLD\r\nON CUST_SOLD.REBOK_CUST_KEY=WI.SOLD_TO_CUSTOMER_KEY\r\nLEFT JOIN $$COMREFVWDB.N_REBOK_CUSTOMER CUST_END\r\nON CUST_END.REBOK_CUST_KEY=WI.END_CUSTOMER_KEY\r\nLEFT JOIN $$COMREFVWDB.N_REBOK_CUSTOMER CUST_SHIP\r\nON CUST_SHIP.REBOK_CUST_KEY=WI.SHIP_TO_CUSTOMER_KEY\r\n\r\n LEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE  SOLD_TO_PARENT\r\n  ON(CUST_SOLD.CUSTOMER_PARTY_KEY=SOLD_TO_PARENT.PARTNER_SITE_PARTY_KEY)\r\n  AND SOLD_TO_PARENT.SOURCE_DELETED_FLG='N'\r\n LEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE  BILL_TO_PARENT\r\n  ON(CUST_BILL.CUSTOMER_PARTY_KEY=BILL_TO_PARENT.PARTNER_SITE_PARTY_KEY)\r\n  AND BILL_TO_PARENT.SOURCE_DELETED_FLG='N'\r\n LEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE  SHIP_TO_PARENT\r\n  ON(CUST_SHIP.CUSTOMER_PARTY_KEY=SHIP_TO_PARENT.PARTNER_SITE_PARTY_KEY)\r\n  AND SHIP_TO_PARENT.SOURCE_DELETED_FLG='N'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
