      "attributes": {
        "Sql Query": "SELECT\r\n TV_OUTPUT.OFFER_ATTRIB_ACV_RTNR_XAAS_KEY\r\n,TV_OUTPUT.PRODUCT_KEY                   \r\n,TV_OUTPUT.ENTERPRISE_SKU_PRDT_KEY       \r\n,TV_OUTPUT.SO_SBSCRPTN_ITM_SLS_TRX_KEY   \r\n,TV_OUTPUT.ATTR_PRDT_AS_NEW_OR_RNWL_KEY  \r\n,TV_OUTPUT.ATTRIBUTION_SS_CD             \r\n,TV_OUTPUT.BK_OFFER_ATTRIBUTION_ID_INT   \r\n,TV_OUTPUT.DV_ATTRIBUTION_CD             \r\n,TV_OUTPUT.ATTRIBUTION_PCT               \r\n,TV_OUTPUT.RTNR_UNIQUE_ID                \r\n,TV_OUTPUT.SALES_MOTION_CD               \r\n,TV_OUTPUT.SK_RTNR_ATTRIBUTION_ID_INT    \r\n,TV_OUTPUT.SK_TRX_ID_INT                 \r\n,TV_OUTPUT.TRANSACTION_BKG_VERSION_INT   \r\n,TV_OUTPUT.TRANSACTION_TYPE_NAME         \r\n,TV_OUTPUT.DV_TOPSKU_SOSBR_ITM_SLSTRX_KEY            \r\n,TV_OUTPUT.DV_ALLOCATION_PCT             \r\n,-999 AS SK_SALES_MOTION_ATTRIB_KEY    \r\n,TV_OUTPUT.DV_TOP_SKU_PRODUCT_KEY  \r\n,TV_OUTPUT.START_TV_DTM\r\n/*,COALESCE(MAX(TV_OUTPUT.START_TV_DTM - INTERVAL '1' SECOND) OVER (PARTITION BY TV_OUTPUT.OFFER_ATTRIB_ACV_RTNR_XAAS_KEY\r\n                         ORDER BY TV_OUTPUT.START_TV_DTM ASC ROWS BETWEEN 1 \r\n                       FOLLOWING AND 1 FOLLOWING), CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))) AS END_TV_DTM*/\r\n,TV_OUTPUT.END_TV_DTM\r\n,CURRENT_TIMESTAMP(0) EDW_CREATE_DTM\r\n,USER  EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0)  EDW_UPDATE_DTM\r\n,USER EDW_UPDATE_USER  \r\n,'N' ACTION_CODE\r\n,(CASE WHEN ROW_NUMBER () OVER (PARTITION BY TV_OUTPUT.OFFER_ATTRIB_ACV_RTNR_XAAS_KEY ORDER BY TV_OUTPUT.START_TV_DTM ASC) = 1 \r\n  AND NXSA1.OFFER_ATTRIB_ACV_RTNR_XAAS_KEY IS NOT NULL THEN 'U' ELSE 'I' END) AS DML_TYPE \r\nFROM\r\n  (\r\n SELECT\r\n\t TV_INPUT.OFFER_ATTRIB_ACV_RTNR_XAAS_KEY\r\n\t,TV_INPUT.PRODUCT_KEY                   \r\n\t,TV_INPUT.ENTERPRISE_SKU_PRDT_KEY       \r\n\t,TV_INPUT.SO_SBSCRPTN_ITM_SLS_TRX_KEY   \r\n\t,TV_INPUT.ATTR_PRDT_AS_NEW_OR_RNWL_KEY  \r\n\t,TV_INPUT.ATTRIBUTION_SS_CD             \r\n\t,TV_INPUT.BK_OFFER_ATTRIBUTION_ID_INT   \r\n\t,TV_INPUT.DV_ATTRIBUTION_CD             \r\n\t,TV_INPUT.ATTRIBUTION_PCT               \r\n\t,TV_INPUT.RTNR_UNIQUE_ID                \r\n\t,TV_INPUT.SALES_MOTION_CD               \r\n\t,TV_INPUT.SK_RTNR_ATTRIBUTION_ID_INT    \r\n\t,TV_INPUT.SK_TRX_ID_INT                 \r\n\t,TV_INPUT.TRANSACTION_BKG_VERSION_INT   \r\n\t,TV_INPUT.TRANSACTION_TYPE_NAME         \r\n\t,TV_INPUT.DV_TOPSKU_SOSBR_ITM_SLSTRX_KEY         \r\n\t,TV_INPUT.DV_ALLOCATION_PCT              \r\n\t,TV_INPUT.DV_TOP_SKU_PRODUCT_KEY   \t\r\n    ,TV_INPUT.START_TV_DTM\r\n    ,TV_INPUT.END_TV_DTM\r\n  FROM(\r\n        SELECT \r\n\t\t\t  SMXSB.OFFER_ATTRIB_ACV_RTNR_XAAS_KEY \r\n\t\t\t ,WISA.PRODUCT_KEY                   \r\n\t\t\t ,WISA.ENTERPRISE_SKU_PRDT_KEY       \r\n\t\t\t ,WISA.SO_SBSCRPTN_ITM_SLS_TRX_KEY   \r\n\t\t\t ,WISA.ATTR_PRDT_AS_NEW_OR_RNWL_KEY  \r\n\t\t\t ,WISA.ATTRIBUTION_SS_CD             \r\n\t\t\t ,WISA.BK_OFFER_ATTRIBUTION_ID_INT   \r\n\t\t\t ,WISA.DV_ATTRIBUTION_CD             \r\n\t\t\t ,WISA.ATTRIBUTION_PCT               \r\n\t\t\t ,WISA.RTNR_UNIQUE_ID                \r\n\t\t\t ,WISA.SALES_MOTION_CD               \r\n\t\t\t ,WISA.SK_RTNR_ATTRIBUTION_ID_INT    \r\n\t\t\t ,WISA.SK_TRX_ID_INT                 \r\n\t\t\t ,WISA.TRANSACTION_BKG_VERSION_INT   \r\n\t\t\t ,WISA.TRANSACTION_TYPE_NAME         \r\n\t\t\t ,WISA.DV_TOPSKU_SOSBR_ITM_SLSTRX_KEY           \r\n\t\t\t ,WISA.DV_ALLOCATION_PCT              \r\n\t\t\t ,WISA.DV_TOP_SKU_PRODUCT_KEY     \t\t\t \r\n             ,WISA.START_TV_DTM\r\n\t         ,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0)) AS END_TV_DTM\r\n\t\tFROM $$STGDB.WI_XAAS_OFFER_RTNR_ATTRIB WISA\r\n\t\tINNER JOIN $$ETLVWDB.SM_XAAS_OFFER_RTNR_ATTRIB SMXSB\r\n\t\tON WISA.RTNR_UNIQUE_ID=SMXSB.RTNR_UNIQUE_ID\r\n \r\n\t  UNION ALL\r\n\t  \r\n\t  SELECT\r\n\t\t\t  NXSA.OFFER_ATTRIB_ACV_RTNR_XAAS_KEY\r\n\t\t\t ,NXSA.PRODUCT_KEY                   \r\n\t\t\t ,NXSA.ENTERPRISE_SKU_PRDT_KEY       \r\n\t\t\t ,NXSA.SO_SBSCRPTN_ITM_SLS_TRX_KEY   \r\n\t\t\t ,NXSA.ATTR_PRDT_AS_NEW_OR_RNWL_KEY  \r\n\t\t\t ,NXSA.ATTRIBUTION_SS_CD             \r\n\t\t\t ,NXSA.BK_OFFER_ATTRIBUTION_ID_INT   \r\n\t\t\t ,NXSA.DV_ATTRIBUTION_CD             \r\n\t\t\t ,NXSA.ATTRIBUTION_PCT               \r\n\t\t\t ,NXSA.RTNR_UNIQUE_ID                \r\n\t\t\t ,NXSA.SALES_MOTION_CD               \r\n\t\t\t ,NXSA.SK_RTNR_ATTRIBUTION_ID_INT    \r\n\t\t\t ,NXSA.SK_TRX_ID_INT                 \r\n\t\t\t ,NXSA.TRANSACTION_BKG_VERSION_INT   \r\n\t\t\t ,NXSA.TRANSACTION_TYPE_NAME         \r\n\t\t\t ,NXSA.DV_TOPSKU_SOSBR_ITM_SLSTRX_KEY          \r\n\t\t\t ,NXSA.DV_ALLOCATION_PCT              \r\n\t\t\t ,NXSA.DV_TOP_SKU_PRODUCT_KEY        \r\n             ,NXSA.START_TV_DTM\r\n\t\t\t ,CURRENT_TIMESTAMP(0) AS END_TV_DTM\r\n        FROM $$SLSORDVWDB.N_XAAS_OFFER_RTNR_ATTRIB_TV NXSA\r\n        WHERE NXSA.END_TV_DTM = CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))\r\n        AND EXISTS (SELECT 1 FROM $$STGDB.WI_XAAS_OFFER_RTNR_ATTRIB ST  \r\n        WHERE  ST.DV_TOPSKU_SOSBR_ITM_SLSTRX_KEY =NXSA.DV_TOPSKU_SOSBR_ITM_SLSTRX_KEY\r\n\t  )               \r\n      )TV_INPUT\r\n  QUALIFY ROW_NUMBER () OVER (PARTITION BY TV_INPUT.OFFER_ATTRIB_ACV_RTNR_XAAS_KEY,TV_INPUT.START_TV_DTM ORDER BY TV_INPUT.START_TV_DTM DESC) = 1\r\n  )TV_OUTPUT\r\nLEFT JOIN $$SLSORDVWDB.N_XAAS_OFFER_RTNR_ATTRIB_TV NXSA1\r\nON  TV_OUTPUT.OFFER_ATTRIB_ACV_RTNR_XAAS_KEY=NXSA1.OFFER_ATTRIB_ACV_RTNR_XAAS_KEY\r\nAND NXSA1.END_TV_DTM= CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))",
