      "attributes": {
        "Sql Query": "SELECT \r\nSOFLV.LOOKUP_CODE, \r\nSOFLV.MEANING, \r\nNSSC.SOURCE_SYSTEM_CODE,\r\nCURRENT_TIMESTAMP(0)  EDW_CREATE_DTM,\r\nUSER  EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0)   EDW_UPDATE_DTM,\r\nUSER  EDW_UPDATE_USER,\r\n'=' DML_TYPE\r\nFROM\r\n$$STGDB.ST_OM_FND_LOOKUP_VALUES_SOD SOFLV\r\nINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\nON SOFLV.GLOBAL_NAME = NSSC.GLOBAL_NAME\r\nWHERE NOT EXISTS\r\n(SELECT 'X' FROM $$SLSORDVWDB.N_PRICE_ADJUSTMENT_TYPE NPAT\r\n\t\tWHERE NPAT.BK_PRICE_ADJUSTMENT_TYPE_CD = SOFLV.LOOKUP_CODE) \r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY SOFLV.LOOKUP_CODE ORDER BY  SOFLV.GLOBAL_NAME DESC)  =1",
        "User Defined Join": "",
