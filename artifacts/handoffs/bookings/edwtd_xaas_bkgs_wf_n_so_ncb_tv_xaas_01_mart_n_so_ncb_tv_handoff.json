      "attributes": {
        "Sql Query": "SELECT\r\n NCB.SALES_ORDER_KEY               \r\n,FMNI.FISCAL_MONTH_START_DATE\r\n,CAST('3500-01-01' AS DATE FORMAT'YYYY-MM-DD')  AS END_TV_DT                  \r\n,'N' AS DV_NCB_INTERNTNL_DEMO_FLG     \r\n,'N' AS DV_NCB_REPLACEMENT_DEMO_FLG   \r\n,NCB.DD_REVENUE_FLAG AS DV_NCB_REVENUE_FLG            \r\n,'N' AS DV_NCB_ACQUISITION_FLG        \r\n,CASE WHEN NCAT_IC.INTERNAL_CUSTOMER_FLAG= 'I'    THEN 'N'\r\n      WHEN NCAT_IC.INTERNAL_CUSTOMER_FLAG IS NULL THEN 'N'\r\n  ELSE 'Y'\r\n  END  DV_NCB_IC_REVENUE_FLG                 \r\n,NCB.DD_NCB_BILL_TO_CUSTOMER_KEY   \r\n,NCB.DD_NCB_ORACLE_BOOK_DTM        \r\n,NCB.DD_NCB_CST_SRVC_REP_TEAM_NAME \r\n,NCB.DD_NCB_TRXL_CURRENCY_CD       \r\n,NCB.DD_NCB_CONVERSION_TYPE_CD     \r\n,NCB.DD_NCB_SO_SRC_CRT_DTM         \r\n,NCB.DD_NCB_SK_SALES_ORD_HDR_ID_INT\r\n,NCB.DD_NCB_SS_CD                  \r\n,NCB.DD_NCB_CANCELLED_FLG          \r\n,NCB.DD_NCB_SALES_ORDER_CAT_TYPE   \r\n,NCB.DD_NCB_BK_SALES_ORDER_NUM_INT \r\n,NCB.DD_NCB_BK_ORDER_TYPE_NAME     \r\n,NCB.DD_NCB_ORDER_DTM              \r\n,NCB.DD_NCB_SHIPMENT_PRIORITY_CD   \r\n,NCB.DD_NCB_SOLD_TO_CUST_ACCT_KEY  \r\n,NCB.DD_NCB_PURCHASE_ORDER_NUM     \r\n,FMNI.FISCAL_YEAR_MTH_NUMBER_INT\r\n,CURRENT_TIMESTAMP(0) EDW_UPDATE_DTM\r\n,CURRENT_TIMESTAMP(0) EDW_CREATE_DTM\r\n,USER\r\n,USER               \r\n,NCB.DD_NCB_SO_CRTD_BY_ERP_USR_NAME\r\n,NCB.DD_SO_PROGRAM_TYPE_NAME        \r\nFROM(\r\n\tSELECT\r\n\tDISTINCT\r\n\t NSO.SALES_ORDER_KEY                       AS SALES_ORDER_KEY\r\n\t,NXSO.BILL_TO_CUST_ACCT_LOC_USE_KEY        AS DD_NCB_BILL_TO_CUSTOMER_KEY \r\n\t,NSO.ORACLE_BOOK_DATETIME                  AS DD_NCB_ORACLE_BOOK_DTM\r\n\t,NSO.CUST_SVC_REP_TEAM_NAME                AS DD_NCB_CST_SRVC_REP_TEAM_NAME\r\n\t,NSO.TRANSACTIONAL_CURRENCY_CODE           AS DD_NCB_TRXL_CURRENCY_CD\r\n\t,NSO.CONVERSION_TYPE_CODE                  AS DD_NCB_CONVERSION_TYPE_CD\r\n\t,NSO.BK_SO_SRC_CRT_DATETIME                AS DD_NCB_SO_SRC_CRT_DTM\r\n\t,NSO.SK_OPL_HEADER_ID_INT                  AS DD_NCB_SK_SALES_ORD_HDR_ID_INT\r\n\t,NSO.SS_CODE                               AS DD_NCB_SS_CD\r\n\t,CASE WHEN NXSO.BK_SALES_ORDER_TYPE_CD = 'CANCEL' THEN 'Y' ELSE 'N' END                         \r\n\t\t\t\t\t\t\t\t\t\t\t   AS DD_NCB_CANCELLED_FLG\r\n\t/*,CASE WHEN NXSO.BOOKING_EXCLUSION_FLG='Y' THEN 'N' ELSE 'Y' END \r\n\t\t\t\t\t\t\t\t\t\t\t   AS DD_REVENUE_FLAG*/\r\n\t ,CASE WHEN NXSO.ACQUISITION_ORDER_ORIGIN_CD = 'CLOUD-CBM' THEN (\r\n        CASE\r\n          WHEN   NSOLT.SALES_ORDER_CATEGORY_TYPE  ='RETURN'  THEN 'N'\r\n           WHEN NSO.SALES_ORDER_PROGRAM_TYPE_NAME LIKE '%CBM RMA with credit%' THEN 'N'\r\n           WHEN NSO.SALES_ORDER_PROGRAM_TYPE_NAME = 'CBM Component Sales' THEN 'N'\r\n        ELSE 'Y' \r\n        END)\r\n     ELSE \r\n         CASE WHEN NXSO.BOOKING_EXCLUSION_FLG='Y' THEN 'N' \r\n         ELSE 'Y' END         \r\n\t END AS DD_REVENUE_FLAG\r\n\t\r\n\t,NSO.SALES_ORDER_CATEGORY_TYPE             AS DD_NCB_SALES_ORDER_CAT_TYPE\r\n\t,CASE WHEN NXSO.ACQUISITION_ORDER_ORIGIN_CD = 'CLOUD-CBM' THEN NSO.BK_SO_NUMBER_INT\r\n\tELSE CAST(-9999 AS INTEGER) END  AS DD_NCB_BK_SALES_ORDER_NUM_INT\r\n\t,NSO.BK_ORDER_TYPE_NAME                    AS DD_NCB_BK_ORDER_TYPE_NAME\r\n\t,NSO.ORDER_DATETIME                        AS DD_NCB_ORDER_DTM\r\n\t,NSO.SHIPMENT_PRIORITY_CODE                AS DD_NCB_SHIPMENT_PRIORITY_CD\r\n\t,NXSO.SOLD_TO_CUST_ACCT_KEY                AS DD_NCB_SOLD_TO_CUST_ACCT_KEY\r\n\t,NSO.PURCHASE_ORDER_NUMBER                 AS DD_NCB_PURCHASE_ORDER_NUM\r\n\t,NSO.SO_CREATED_BY_ERP_USER_NAME           AS DD_NCB_SO_CRTD_BY_ERP_USR_NAME\r\n\t,NSO.SALES_ORDER_PROGRAM_TYPE_NAME         AS DD_SO_PROGRAM_TYPE_NAME\r\n\tFROM \r\n\t(SELECT * FROM $$SLSORDVWDB.N_XAAS_SO_SBSCR_ITM_SLS_TRX_TV \r\n\tWHERE END_TV_DTM=CAST('3500-01-01 00:00:00' AS TIMESTAMP(0)) AND XAAS_TRX_METRIC_TYPE_NAME='ENB'\r\n\tAND MINOR_LN_EXAAS_SUBSCR_SOL_KEY>0 ) NXSO\r\n\tINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE_TV  NSOLT\r\n\tON  NXSO.MINOR_LN_EXAAS_SUBSCR_SOL_KEY=NSOLT.SALES_ORDER_LINE_KEY\r\n\tINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_TV NSO\r\n\tON NSO.SALES_ORDER_KEY=NSOLT.SALES_ORDER_KEY \r\n\tWHERE NSO.SS_CODE IN ('OPL')\r\n\tAND NSO.END_TV_DATETIME='3500-01-01 00.00.00'  \r\n\tAND NSOLT.END_TV_DATETIME='3500-01-01 00.00.00' \r\n\r\n)NCB\r\n\r\nCROSS JOIN \r\n (\r\n SELECT  NFM.FISCAL_MONTH_START_DATE,NFM.FISCAL_MONTH_END_DATE,BPDC.FISCAL_YEAR_MTH_NUMBER_INT,BPDC.PROCESS_DATE\r\n FROM  $$COMREFVWDB.N_FISCAL_MONTH NFM, $$ETLVWDB.BKG_PROCESS_DT_CNTRL BPDC\r\n WHERE  NFM.BK_FISCAL_YEAR_NUMBER_INT=BPDC.FISCAL_YEAR_NUMBER_INT\r\n AND  NFM.BK_FISCAL_MONTH_NUMBER_INT=BPDC.FISCAL_MONTH_NUMBER_INT) FMNI\r\n\r\nINNER JOIN $$COMREFVWDB.N_ERP_CUST_ACCT_LOC_USE SITE_USE          \r\nON SITE_USE.ERP_CUST_ACCOUNT_LOCATION_KEY = NCB.DD_NCB_BILL_TO_CUSTOMER_KEY \r\n\r\nLEFT OUTER JOIN ($$COMREFVWDB.N_CUSTOMER_ACCOUNT NCAT_IC)\r\n\r\nON SITE_USE.CUSTOMER_ACCOUNT_KEY=NCAT_IC.CUSTOMER_ACCOUNT_KEY  \r\n\r\nWHERE CAST (NCB.DD_NCB_SO_SRC_CRT_DTM AS DATE) <= FMNI.PROCESS_DATE",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
  ],
