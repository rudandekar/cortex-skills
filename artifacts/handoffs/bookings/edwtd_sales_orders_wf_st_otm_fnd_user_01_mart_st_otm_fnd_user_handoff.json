      "attributes": {
        "Sql Query": "SELECT\r\nCAST('1900-01-01 00:00:00' AS TIMESTAMP(0))  CDB_DEQUEUE_TIME,\r\nPPL.EMPLOYEE_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS ETL_PROCESS_DATE,\r\nFU.LAST_UPDATE_DATE,\r\nFU.USER_ID,\r\nFU.USER_NAME\r\nFROM\r\n(SELECT * FROM \r\n$$GGSRCVWDB.FND_USER \r\n QUALIFY ROW_NUMBER() OVER (PARTITION BY  USER_NAME,USER_ID ORDER BY REFRESH_DATETIME DESC)=1) FU\r\nLEFT JOIN\r\n(SELECT * FROM \r\n$$GGSRCVWDB.PER_ALL_PEOPLE_F \r\n QUALIFY ROW_NUMBER() OVER (PARTITION BY  EFFECTIVE_END_DATE,EFFECTIVE_START_DATE,PERSON_ID ORDER BY REFRESH_DATETIME DESC)=1) PPL\r\nON\r\nFU.EMPLOYEE_ID=PPL.PERSON_ID\r\nAND PPL.EFFECTIVE_END_DATE =CAST('4712-12-31' AS DATE)\r\nAND FU.LAST_UPDATE_DATE> CAST('$$LastExtractDate' AS TIMESTAMP(0))",
