      "attributes": {
        "Sql Query": "SELECT\r\n  NAOVRLYTV.SK_TRX_SC_ID_INT,\r\n  NAOVRLYTV.PD_SS_CD,\r\n  NAOVRLYTV.SALES_CREDIT_ASSGN_APPLD_KEY,\r\n  NAOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD  AS  BK_SLS_TERR_ASSIGNMENT_TYPE_CD, \r\n  NAOVRLYTV.PD_SCAA_CREATION_DT AS PD_SCAA_CREATION_DT,\r\n  NAOVRLYTV.PD_SALES_REP_NUM AS  PD_SALES_REP_NUM, \r\n  NAOVRLYTV.PD_SALES_TERRITORY_KEY AS  PD_SALES_TERRITORY_KEY, \r\n  NAOVRLYTV.PD_SALES_ORDER_LINE_KEY AS   PD_SALES_ORDER_LINE_KEY , \r\n  NAOVRLYTV.PD_SALES_COMMISSION_PCT  AS PD_SALES_COMMISSION_PCT,\r\n  NAOVRLYTV.START_TV_DTM,\r\n  NAOVRLYTV.END_TV_DTM,\r\n  NAOVRLYTV.EDW_CREATE_DTM as EDW_CREATE_DTM,\r\n  NAOVRLYTV.EDW_UPDATE_DTM as EDW_UPDATE_DTM,\r\n  NAOVRLYTV.PD_SLS_CREDIT_LAST_UPDATE_DTM ,\r\n  NAOVRLYTV.PD_SALES_CREDIT_USAGE_CD,\r\n  NAOVRLYTV.BK_OFFER_ATTRIBUTION_ID_INT AS SK_OFFER_ATTRIBUTION_ID_INT,\r\n  NSOL.LINE_CREATION_DATE\r\n  FROM \r\n   $$SLSORDVWDB.N_SCA_APLD_TRX_OVERLAY_TV NAOVRLYTV\r\n   INNER JOIN (SEL SALES_ORDER_LINE_KEY,CAST(BK_SO_SRC_CRT_DATETIME AS DATE FORMAT 'yyyy-mm-dd') AS LINE_CREATION_DATE  FROM $$SLSORDVWDB.N_SALES_ORDER_LINE GROUP BY 1,2 ) NSOL\r\n   ON NSOL.SALES_ORDER_LINE_KEY = NAOVRLYTV.PD_SALES_ORDER_LINE_KEY\r\n  WHERE  NAOVRLYTV.PD_SALES_CREDIT_USAGE_CD IN ('R','CR')  \r\n AND NAOVRLYTV.EDW_UPDATE_DTM> (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.CTL_ETL_LAST_EXTRACT_DATES \r\n WHERE JOB_STREAM_ID = 'wf_WI_OVERLAY_DATA_AR_APLD_INCR' AND TABLE_NAME ='N_SCA_APLD_TRX_OVERLAY_TV_AR')\r\n  --AND NAOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD NOT  ('CX','MS','CCR','WWP')                            \r\nAND NAOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD NOT IN ('CX')\r\nAND NOT EXISTS (SELECT 1 FROM $$ETLVWDB.EL_OVERLAY_SUB_LINE_INCLUSION EL \r\n WHERE EL.BK_SLS_TERR_ASSIGNMENT_TYPE_CD=NAOVRLYTV.BK_SLS_TERR_ASSIGNMENT_TYPE_CD \r\n AND NSOL.LINE_CREATION_DATE BETWEEN EFFECTIVE_START_DATE AND EFFECTIVE_END_DATE)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
