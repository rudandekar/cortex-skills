      "attributes": {
        "Sql Query": "SELECT\r\nSTG.BK_SERVICE_COMPONENT_NAME ,\r\nCOALESCE(STG.SERVICE_PRODUCT_KEY,-999) AS SERVICE_PRODUCT_KEY,\r\nSTG.BK_SERVICE_PROGRAM_NAME ,\r\nSTG.BK_AS_QUOTE_NUM ,\r\nCOALESCE(STG.SERVICE_PRODUCT_PRICE_USD_AMT,0) AS SERVICE_PRODUCT_PRICE_USD_AMT,\r\nSTG.SK_QUOTE_COMPONENT_ID,\r\nSTG.SOURCE_DELETED_FLG,\r\nCOALESCE(STG.TOTAL_COMPONENT_QTY,0) AS TOTAL_COMPONENT_QTY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\nSTG.BK_SS_CD,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NAQSPD.SK_QUOTE_COMPONENT_ID IS NULL THEN 'I' ELSE 'U' END AS DML_TYPE\r\n\r\nFROM $$STGDB.ST_AS_QT_SBSCRPTN_PRCNG_DTL_HDP STG\r\n\r\nLEFT OUTER JOIN $$SERVICEVWDB.N_AS_QUOTE_SBSCRPTN_PRCNG_DTL NAQSPD\r\nON (NAQSPD.BK_SERVICE_COMPONENT_NAME = STG.BK_SERVICE_COMPONENT_NAME\r\nAND NAQSPD.BK_SERVICE_PROGRAM_NAME = STG.BK_SERVICE_PROGRAM_NAME\r\nAND NAQSPD.BK_AS_QUOTE_NUM = STG.BK_AS_QUOTE_NUM\r\nand NAQSPD.BK_SS_CD = STG.BK_SS_CD)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "COLLECT STATS ON $$STGDB.ST_AS_QT_SBSCRPTN_PRCNG_DTL_HDP;\r\n\r\nDELETE FROM $$WORKDB.W_AS_QT_SBSCRPTN_PRCNG_DTL_SEP ;",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
