      "attributes": {
        "Sql Query": "SELECT  \r\n    SALES_ADJ_LINE.BK_SALES_ADJ_LINE_NUMBER_INT AS BOOKINGS_MEASURE_KEY, \r\n    SALES_ADJ_LINE.PROCESS_DATE AS BOOKINGS_PROCESS_DATE,\r\n    'M_ADJ' AS BKGS_MEASURE_TRANS_TYPE_CODE,\r\n    SALES_ADJ_LINE.MANUAL_TRX_KEY,\r\n    SALES_ADJ_LINE.END_CUST_REBOK_CUST_KEY AS END_CUSTOMER_KEY,\r\n    SALES_ADJ_LINE.BILL_TO_REBOK_CUST_KEY AS BILL_TO_CUSTOMER_KEY,\r\n    SALES_ADJ_LINE.SHIP_TO_REBOK_CUST_KEY AS SHIP_TO_CUSTOMER_KEY,\r\n    SALES_ADJ_LINE.SOLD_TO_REBOK_CUST_KEY AS SOLD_TO_CUSTOMER_KEY,\r\n    SALES_ADJ_LINE.BK_WIPS_ORIGINATOR_ID_INT, \r\n    SALES_ADJ_LINE.EDW_UPDATE_DATETIME \r\nFROM $$SLSORDVWDB.N_SALES_ADJUSTMENT_LINE SALES_ADJ_LINE\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ADJUSTMENT SALES_ADJ \r\n   ON SALES_ADJ_LINE.BK_SALES_ADJ_NUMBER_INT = SALES_ADJ.BK_SALES_ADJ_NUMBER_INT\r\n  AND SALES_ADJ.BK_SALES_ADJ_CODE <> 'POS-OA'  \r\n  AND SALES_ADJ_LINE.IDE_IFC_ADJ_REPORTING_TYPE_CD = 'M'\r\nINNER JOIN  $$COMREFVWDB.R_SALES_HIERARCHY RSH  /* added 13-08 */\r\nON SALES_ADJ_LINE.SALES_TERRITORY_KEY = RSH.SALES_TERRITORY_KEY\r\nAND RSH.L1_SALES_TERRITORY_NAME_CODE <> 'WW Distribution'\r\nAND SALES_ADJ_LINE.EDW_UPDATE_DATETIME > \r\n( SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.CTL_ETL_LAST_EXTRACT_DATES \r\nWHERE JOB_STREAM_ID = 'wf_WI_MT_OVRLY_END_CUST_KEY_RETRO'  AND TABLE_NAME = 'WI_MT_OVRLY_M_ADJ_RETRO' )\r\n\r\nUNION \r\n\r\nSELECT  \r\n    NSLSRMT.MANUAL_TRX_KEY AS BOOKINGS_MEASURE_KEY, \r\n    CAST(NSLSRMT.SALES_ADJUSTMENT_DTM AS DATE) AS BOOKINGS_PROCESS_DATE  ,\r\n    'O_ADJ' AS BKGS_MEASURE_TRANS_TYPE_CODE,\r\n    NSLSRMT.MANUAL_TRX_KEY,\r\n    NSLSRMT.END_CUST_REBOK_CUST_KEY AS END_CUSTOMER_KEY,\r\n    NSLSRMT.BILL_TO_REBOK_CUST_KEY AS BILL_TO_CUSTOMER_KEY,\r\n    NSLSRMT.SHIP_TO_REBOK_CUST_KEY AS SHIP_TO_CUSTOMER_KEY,\r\n    NSLSRMT.SOLD_TO_REBOK_CUST_KEY AS SOLD_TO_CUSTOMER_KEY,\r\n    NSLSRMT.BK_WIPS_ORIGINATOR_ID_INT, \r\n    NSLSRMT.EDW_UPDATE_DTM AS EDW_UPDATE_DATETIME\r\nFROM $$SLSORDVWDB.N_SALES_ADJ_REBOK_MNL_TRX NSLSRMT\r\nWHERE \r\nNSLSRMT.MANUAL_TRX_BOOKING_REVENUE_CD IN ('B','BR')  \r\n AND EXISTS \r\n( SELECT 1 \r\n                FROM $$SLSORDVWDB.N_SLS_CR_ASGN_REBOK_MNL_ADJ  OVR\r\n  WHERE  OVR.BK_SLS_TERR_ASSIGNMENT_TYPE_CD <>'DR' \r\n      AND OVR.SALES_CREDIT_USAGE_CD IN ('R','CR')  \r\n      AND  OVR.MANUAL_TRX_KEY = NSLSRMT.MANUAL_TRX_KEY \r\n)\r\nAND NOT  EXISTS \r\n( SELECT 1 \r\n                 FROM $$SLSORDVWDB.N_SLS_CR_ASGN_REBOK_MNL_ADJ DIR\r\nWHERE  DIR.BK_SLS_TERR_ASSIGNMENT_TYPE_CD ='DR' \r\n  AND DIR.MANUAL_TRX_KEY = NSLSRMT.MANUAL_TRX_KEY ) \r\nAND NSLSRMT.EDW_UPDATE_DTM > \r\n( SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.CTL_ETL_LAST_EXTRACT_DATES \r\nWHERE JOB_STREAM_ID = 'wf_WI_MT_OVRLY_END_CUST_KEY_RETRO'  AND TABLE_NAME = 'WI_MT_OVRLY_O_ADJ_RETRO' )",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
