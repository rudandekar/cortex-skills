      "attributes": {
        "Sql Query": "SELECT \t\r\nBOOKINGS_MEASURE_KEY,\r\nDV_SALES_ORDER_LINE_KEY,\r\nAR_TRX_LINE_KEY,\r\nBK_POS_TRANSACTION_ID_INT,\r\nSO_SBSCRPTN_ITM_SLS_TRX_KEY,\r\nBOOKINGS_PROCESS_DATE,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nEND_CUSTOMER_KEY,\r\nDV_FMV_FLG,\r\nCORPORATE_BOOKINGS_FLG,\r\nDV_NET_SPREAD_FLG,\r\nDV_REVENUE_RECOGNITION_FLG,\r\nBILL_TO_CUSTOMER_KEY,\r\nSHIP_TO_CUSTOMER_KEY,\r\nSOLD_TO_CUSTOMER_KEY,\r\nEDW_UPDATE_DATETIME,\r\nWIPS_ORIGINATOR_ID_INT  /*Added as part of Q3FY17 Apr release*/\r\nFROM \r\n$$SLSORDVWDB.N_BOOKINGS_MEASURE \r\nWHERE \r\nEDW_UPDATE_DATETIME > ( SEL LAST_EXTRACT_DATE FROM $$ETLVWDB.CTL_ETL_LAST_EXTRACT_DATES \r\nWHERE JOB_STREAM_ID = 'wf_WI_MT_OVRLY_END_CUST_KEY_RETRO'  AND TABLE_NAME = 'WI_MT_OVRLY_END_CUST_KEY_RETRO' )",
