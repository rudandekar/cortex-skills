      "attributes": {
        "Sql Query": "SELECT     \r\n      \tPTLP.BK_SOLD_TO_WIPS_SITE_USE_KEY\r\n       ,PTLP.BK_END_USER_WIPS_SITE_USE_KEY\r\n       ,SPK.CUSTOMER_PARTY_KEY SOLD_TO_PARTY_KEY\r\n       ,EPK.CUSTOMER_PARTY_KEY END_CUSTOMER_PARTY_KEY\r\n       ,COALESCE(PS.PARTNER_SITE_PARTY_KEY,-999) AS PARTNER_SITE_PARTY_KEY_INT\r\n       ,COALESCE(PS.DD_GRNDPARNT_PARTNER_PARTY_KEY,-999) PARTNER_PARTY_KEY\r\n\r\nFROM  $$STGDB.WI_WIPS_DSV_TRANS_PATTERNS PTLP\r\n\r\nINNER  JOIN $$COMREFVWDB.N_WIPS_CUSTOMER_SITE_TV SPK\r\nON PTLP.BK_SOLD_TO_WIPS_SITE_USE_KEY = SPK.WIPS_SITE_USE_KEY\r\nAND SPK.END_TV_DATE  = '3500-01-01'\r\n\r\nINNER  JOIN $$COMREFVWDB.N_WIPS_CUSTOMER_SITE_TV EPK\r\nON PTLP.BK_END_USER_WIPS_SITE_USE_KEY = EPK.WIPS_SITE_USE_KEY\r\nAND EPK.END_TV_DATE  = '3500-01-01'\r\n\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER_SITE PS\r\nON SPK.CUSTOMER_PARTY_KEY = PS.PARTNER_SITE_PARTY_KEY\r\nAND PS.SOURCE_DELETED_FLG='N'",
