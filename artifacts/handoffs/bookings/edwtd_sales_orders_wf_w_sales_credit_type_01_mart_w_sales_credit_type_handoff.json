      "attributes": {
        "Sql Query": "SELECT\r\n\tTVOUTPUT.BK_SALES_CREDIT_TYPE_CODE,\r\n\tTVOUTPUT.START_TV_DATE,\r\n\tCOALESCE( MAX(TVOUTPUT.START_TV_DATE - INTERVAL '1' DAY) \r\n\tOVER (PARTITION BY TVOUTPUT.BK_SALES_CREDIT_TYPE_CODE ORDER BY TVOUTPUT.START_TV_DATE ASC \r\n\tROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING), DATE '3500-01-01') AS END_TV_DATE,\r\n\tTVOUTPUT.SALES_CREDIT_TYPE_DESCRIPTION,\r\n\tCOALESCE(TVOUTPUT.SALES_CREDIT_TYPE_ENABLED_FLAG,'=') AS SALES_CREDIT_TYPE_ENABLED_FLAG,\r\n\tTVOUTPUT.SALES_CREDIT_TYPE_QUOTA_FLAG,\r\n\tTVOUTPUT.ACTION_CODE,\r\n\tROW_NUMBER() OVER (PARTITION BY TVOUTPUT.BK_SALES_CREDIT_TYPE_CODE ORDER BY TVOUTPUT.START_TV_DATE ASC) AS RANK_INDEX,\r\n\t(CASE WHEN RANK_INDEX = 1 AND NSCTT.BK_SALES_CREDIT_TYPE_CODE IS NOT NULL THEN 'U' ELSE 'I' END) AS DML_TYPE\r\nFROM\r\n(\r\nSELECT\r\n\tBATCH_ID,\r\n\tBK_SALES_CREDIT_TYPE_CODE,\r\n\tSTART_TV_DATE,\r\n\tSALES_CREDIT_TYPE_DESCRIPTION,\r\n\tSALES_CREDIT_TYPE_ENABLED_FLAG,\r\n\tSALES_CREDIT_TYPE_QUOTA_FLAG,\r\n\tCREATE_DATETIME,\r\n\tACTION_CODE,\r\n\tROW_NUMBER() OVER (PARTITION BY \r\n\t\tBK_SALES_CREDIT_TYPE_CODE,\r\n\t\tSALES_CREDIT_TYPE_DESCRIPTION,\r\n\t\tSALES_CREDIT_TYPE_ENABLED_FLAG,\r\n\t\tSALES_CREDIT_TYPE_QUOTA_FLAG\r\n\tORDER BY CREATE_DATETIME DESC) AS row_num  \r\nFROM\r\n(\r\nSELECT\r\n\tSUOSCT.BATCH_ID,\r\n\tSUOSCT.NAME AS BK_SALES_CREDIT_TYPE_CODE,\r\n\tCAST (SUOSCT.CREATE_DATETIME AS DATE) START_TV_DATE,\r\n\tSUOSCT.DESCRIPTION AS SALES_CREDIT_TYPE_DESCRIPTION ,\r\n\tSUOSCT.ENABLED_FLAG AS SALES_CREDIT_TYPE_ENABLED_FLAG,\r\n\tSUOSCT.QUOTA_FLAG AS SALES_CREDIT_TYPE_QUOTA_FLAG,\r\n\tSUOSCT.CREATE_DATETIME,\r\n\tSUOSCT.ACTION_CODE\r\nFROM\r\n\t$$STGDB.ST_UO_OE_SALES_CREDIT_TYPES SUOSCT\r\n\tQUALIFY ROW_NUMBER() OVER (PARTITION BY SUOSCT.NAME\r\n\t\tORDER BY SUOSCT.CREATE_DATETIME DESC) = 1 \r\nUNION ALL\r\nSELECT \r\n\tSBOSCT.BATCH_ID,\r\n\tSBOSCT.NAME BK_SALES_CREDIT_TYPE_CODE, \r\n\tCAST(SBOSCT.CREATE_DATETIME AS DATE ) START_TV_DATE, \r\n\tSBOSCT.DESCRIPTION SALES_CREDIT_TYPE_DESCRIPTION, \r\n\tSBOSCT.ENABLED_FLAG SALES_CREDIT_TYPE_ENABLED_FLAG, \r\n\tSBOSCT.QUOTA_FLAG SALES_CREDIT_TYPE_QUOTA_FLAG, \r\n\tSBOSCT.CREATE_DATETIME,\r\n\tSBOSCT.ACTION_CODE \r\nFROM\r\n\t$$STGDB.ST_BO_OE_SALES_CREDIT_TYPES SBOSCT \r\n\tLEFT OUTER JOIN $$STGDB.ST_UO_OE_SALES_CREDIT_TYPES SUOSCT\r\n\tON \tSBOSCT.NAME=SUOSCT.NAME\r\n\tLEFT OUTER JOIN $$ETLVWDB.EL_SALES_CREDIT_TYPES ESCT\r\n\tON (SBOSCT.NAME = ESCT.NAME AND ESCT.GLOBAL_NAME = 'UO')\r\n\tQUALIFY ROW_NUMBER() OVER (PARTITION BY SBOSCT.NAME\r\n\t\tORDER BY SBOSCT.CREATE_DATETIME DESC) = 1 \r\n\tWHERE SUOSCT.NAME IS NULL AND ESCT.NAME IS NULL\t\r\nUNION ALL\r\nSELECT\r\n\t-999 BATCH_ID,\r\n\tNSCTT.BK_SALES_CREDIT_TYPE_CODE,\r\n\tNSCTT.START_TV_DATE,\r\n\tNSCTT.SALES_CREDIT_TYPE_DESCRIPTION,\r\n\tNSCTT.SALES_CREDIT_TYPE_ENABLED_FLAG,\r\n\tNSCTT.SALES_CREDIT_TYPE_QUOTA_FLAG,\r\n\tNSCTT.EDW_CREATE_DATETIME CREATE_DATETIME,\r\n\t'X'  ACTION_CODE\r\nFROM $$SLSORDVWDB.N_SALES_CREDIT_TYPE_TV NSCTT\r\nWHERE END_TV_DATE = CAST ('3500-01-01' AS DATE)\r\nAND BK_SALES_CREDIT_TYPE_CODE IN\r\n(\r\n\tSELECT DISTINCT NAME \r\n\tFROM $$STGDB.ST_UO_OE_SALES_CREDIT_TYPES\r\n\tUNION ALL \r\n\tSELECT DISTINCT SBOSCT.NAME\r\n\tFROM $$STGDB.ST_BO_OE_SALES_CREDIT_TYPES SBOSCT \r\n\tLEFT OUTER JOIN $$STGDB.ST_UO_OE_SALES_CREDIT_TYPES SUOSCT\r\n\tON \tSBOSCT.NAME=SUOSCT.NAME\r\n\tWHERE SUOSCT.NAME IS NULL\r\n)\r\n)TVINPUT\r\n\tQUALIFY ROW_NUMBER() OVER (PARTITION BY TVINPUT.BK_SALES_CREDIT_TYPE_CODE, TVINPUT.START_TV_DATE \r\n\t\tORDER BY TVINPUT.CREATE_DATETIME desc) = 1\r\n)TVOUTPUT\r\nLEFT JOIN $$SLSORDVWDB.N_SALES_CREDIT_TYPE_TV NSCTT\r\n\tON TVOUTPUT.BK_SALES_CREDIT_TYPE_CODE = NSCTT.BK_SALES_CREDIT_TYPE_CODE\r\n\tAND NSCTT.END_TV_DATE = CAST('3500-01-01' AS date)\r\nWHERE\tTVOUTPUT.row_num = 1",
        "User Defined Join": "",
