      "attributes": {
        "Sql Query": "SELECT   \r\n   TVOUTPUT.SALES_ORDER_KEY,\r\n   TVOUTPUT.END_CUSTOMER_KEY,\r\n   TVOUTPUT.END_CUSTOMER_TYPE_CODE,\r\n   TVOUTPUT.SK_SALES_ORDER_HEADER_ID_INT  ,\r\n   TVOUTPUT.SS_CODE,\r\n   TVOUTPUT.EDW_CREATE_DATETIME  START_TV_DATE,\r\n    COALESCE (MAX (TVOUTPUT.START_TV_DATETIME - INTERVAL '1'  MINUTE) \r\n    \t\t\tOVER (PARTITION BY \tTVOUTPUT.SALES_ORDER_KEY\r\n     \t\t\t\tORDER BY TVOUTPUT.START_TV_DATETIME ASC ROWS BETWEEN 1 \r\n     \t\t\tFOLLOWING AND 1 FOLLOWING), TIMESTAMP '3500-01-01 00:00:00') END_DATE_ACTIVE ,\r\n\tROW_NUMBER () OVER (PARTITION BY \r\n\t\t\t\t\t\tTVOUTPUT.SALES_ORDER_KEY\r\n\t\tORDER BY TVOUTPUT.START_TV_DATETIME ASC) RANK_INDEX,\r\n(CASE WHEN RANK_INDEX = 1 AND NSECT_OUT.SALES_ORDER_KEY  IS NOT NULL  THEN 'U'ELSE 'I' END) DML_TYPE,\r\nCAST (CURRENT_TIMESTAMP (0) AS TIMESTAMP (0)) AS CREATE_DATETIME\r\nFROM\r\n(\r\nSELECT\r\n   \tTVINPUT.SALES_ORDER_KEY,\r\n   \tTVINPUT.END_CUSTOMER_KEY,\r\n   \tTVINPUT.END_CUSTOMER_TYPE_CODE,\r\n   \tTVINPUT.SK_SALES_ORDER_HEADER_ID_INT,\r\n   \tTVINPUT.SS_CODE,\r\n\tTVINPUT.START_TV_DATETIME,\r\n   \tTVINPUT.EDW_CREATE_DATETIME ,\r\n   \tROW_NUMBER () OVER (PARTITION BY \r\n     \t\t\t\t\tTVINPUT.SALES_ORDER_KEY,\r\n     \t\t\t\t\tTVINPUT.END_CUSTOMER_KEY,\r\n     \t\t\t\t\tTVINPUT.END_CUSTOMER_TYPE_CODE\r\n     \tORDER BY TVINPUT.EDW_CREATE_DATETIME DESC) AS ROW_NUM  \r\n  FROM \r\n  \t(\r\n  \t\t  \tSELECT \r\n   \t\t\tWSEC.SALES_ORDER_KEY \t\t\t\tSALES_ORDER_KEY ,\r\n   \t\t\tWSEC.END_CUSTOMER_KEY   \t\t\t\tEND_CUSTOMER_KEY,\r\n   \t\t\tWSEC.END_CUSTOMER_TYPE_CODE    \t\t\tEND_CUSTOMER_TYPE_CODE,\r\n   \t\t\tWSEC.SK_SALES_ORDER_HEADER_ID_INT SK_SALES_ORDER_HEADER_ID_INT,\r\n   \t\t\tWSEC.SS_CODE        \t\t\t\t\tSS_CODE,\r\n\t\t\tWSEC.EDW_CREATE_DATETIME \t\t\t\tSTART_TV_DATETIME,\r\n   \t\t\tWSEC.EDW_CREATE_DATETIME    \t\t\tEDW_CREATE_DATETIME\r\n  \t\tFROM \r\n   \t\t\t$$STGDB.WI_SO_END_CUSTOMER WSEC\r\n  \t\tUNION ALL\r\n  \t\tSELECT\r\n   \t\t\tNSECT_I.SALES_ORDER_KEY \t\t\tSALES_ORDER_KEY,\r\n     \t    NSECT_I.END_CUSTOMER_KEY   \t\t\t\tEND_CUSTOMER_KEY,\r\n      \t\tNSECT_I.DD_END_CUSTOMER_TYPE              \t\tEND_CUSTOMER_TYPE_CODE,\r\n   \t\t\tNSECT_I.SK_SALES_ORDER_HEADER_ID_INT SK_SALES_ORDER_HEADER_ID_INT,\r\n      \t\tNSECT_I.SS_CD        \t\t\t\t\tSS_CODE,\r\n\t\t\tNSECT_I.START_TV_DATETIME \t\t\t\tSTART_TV_DATETIME,\r\n      \t\tNSECT_I.EDW_CREATE_DTM                    \t\t\tEDW_CREATE_DATETIME\r\n     \tFROM $$SLSORDVWDB.N_SO_END_CUSTOMER_TV NSECT_I \r\n     \tWHERE END_TV_DATETIME='3500/01/01 00:00:00'  \r\n     \tAND  EXISTS\r\n   \t\t(SELECT 1 FROM  $$STGDB.WI_SO_END_CUSTOMER WSEC_I\r\n    \tWHERE      NSECT_I.SALES_ORDER_KEY   =WSEC_I.SALES_ORDER_KEY)\r\n \t) TVINPUT\r\n   \tQUALIFY ROW_NUMBER () OVER (PARTITION BY \r\n     \t\t\t\t\tTVINPUT.SALES_ORDER_KEY,\r\n\t                          TVINPUT.START_TV_DATETIME\r\n     \tORDER BY TVINPUT.EDW_CREATE_DATETIME DESC) = 1\r\n )TVOUTPUT  \r\nLEFT OUTER JOIN  $$SLSORDVWDB.N_SO_END_CUSTOMER_TV  NSECT_OUT  \r\n   ON (NSECT_OUT.SALES_ORDER_KEY  =TVOUTPUT.SALES_ORDER_KEY    \r\n      AND NSECT_OUT.END_TV_DATETIME ='3500-01-01 00:00:00' )\r\nWHERE  TVOUTPUT.ROW_NUM = 1",
        "User Defined Join": "",
