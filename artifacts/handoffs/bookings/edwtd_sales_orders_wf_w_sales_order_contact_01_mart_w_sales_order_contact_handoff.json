      "attributes": {
        "Sql Query": "SELECT   (RANK() OVER( ORDER BY STSLSCR_BK.HEADER_ID , STSLSCR_BK.LAST_NAME ,STSLSCR_BK.FIRST_NAME ,STSLSCR_BK.CONTACT_TYPE  DESC ) + MAX_SALES_ORDER_CONTACT_KEY )    SALES_ORDER_CONTACT_KEY, \r\nSTSLSCR_BK.SALES_ORDER_KEY AS SALES_ORDER_KEY , \r\nSTSLSCR_BK.CONTACT_TYPE AS CONTACT_TYPE_CD, \r\nSTSLSCR_BK.FIRST_NAME AS CONTACT_FIRST_NAME, \r\nSTSLSCR_BK.LAST_NAME AS CONTACT_LAST_NAME , \r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM, \r\nUSER AS EDW_CREATE_USER \r\nFROM ( \r\nSELECT SCXO.CONTACT_TYPE, \r\nSCXO.FIRST_NAME, \r\nSCXO.LAST_NAME, \r\nSCXO.HEADER_ID, \r\nNSON.SALES_ORDER_KEY\r\nFROM\r\n(\r\nSELECT\r\nCONTACT_TYPE,\r\nFIRST_NAME, \r\nLAST_NAME,\r\nHEADER_ID\r\nFROM $$STGDB.ST_CG1_XXGCO_OE_ORD_CONT\r\nUNION ALL\r\nSELECT \r\nCONTACT_TYPE,\r\nFIRST_NAME, \r\nLAST_NAME,\r\nHEADER_ID\r\nFROM $$EXCEPDB.EX_CG1_XXGCO_OE_ORD_CONT\r\n) SCXO \r\nINNER JOIN \r\n( \r\nSELECT   SK_SALES_ORDER_HEADER_ID_INT, \r\nSALES_ORDER_KEY \r\nFROM $$SLSORDVWDB.N_SALES_ORDER_TV NSON \r\nWHERE NSON.SS_CODE = 'CG' \r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY SK_SALES_ORDER_HEADER_ID_INT ORDER BY BK_SO_SRC_UPD_DATETIME DESC ) = 1) NSON \r\nON NSON.SK_SALES_ORDER_HEADER_ID_INT = SCXO.HEADER_ID\r\n)STSLSCR_BK , \r\n( \r\nSELECT COALESCE(MAX(SALES_ORDER_CONTACT_KEY),0) MAX_SALES_ORDER_CONTACT_KEY \r\nFROM   $$ETLVWDB.SM_SALES_ORDER_CONTACT ) SMSLSCR_MAX \r\nWHERE NOT EXISTS \r\n( \r\nSELECT 1 \r\nFROM   $$ETLVWDB.SM_SALES_ORDER_CONTACT SSCA \r\nWHERE  SSCA.SALES_ORDER_KEY = STSLSCR_BK.SALES_ORDER_KEY \r\nAND SSCA.CONTACT_TYPE_CD = STSLSCR_BK.CONTACT_TYPE\r\nAND STSLSCR_BK.FIRST_NAME = SSCA.CONTACT_FIRST_NAME\r\nAND STSLSCR_BK.LAST_NAME = SSCA.CONTACT_LAST_NAME)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
