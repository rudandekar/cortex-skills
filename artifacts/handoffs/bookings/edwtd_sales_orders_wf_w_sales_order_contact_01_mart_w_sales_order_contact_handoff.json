        "Sql Query": "SELECT SXOOC.HEADER_ID,\r\nSXOOC.LAST_NAME ,\r\nSXOOC.FIRST_NAME ,\r\nSXOOC.EMAIL_ADDRESS,\r\nSXOOC.CREATION_DATE,\r\nSXOOC.CREATED_BY,\r\nSXOOC.LAST_UPDATED_BY ,\r\nSXOOC.LAST_UPDATE_DATE, \r\nSXOOC.CONTACT_TYPE,\r\nSXOOC.TELEPHONE,\r\n'RI ' AS EXCEPTION_TYPE,\r\n'CG' AS GLOBAL_NAME,\r\nSXOOC.SOURCE_DML_TYPE\r\nFROM  $$STGDB.ST_CG1_XXGCO_OE_ORD_CONT SXOOC \r\nWHERE NOT EXISTS \r\n(    SELECT  1 from  $$SLSORDVWDB.N_SALES_ORDER_TV NSON \r\n   WHERE NSON.SK_SALES_ORDER_HEADER_ID_INT = SXOOC.HEADER_ID \r\n\t                     AND NSON.SS_CODE = 'CG' \r\n )\r\n AND NOT EXISTS(SELECT 1 FROM $$EXCEPDB.EX_CG1_XXGCO_OE_ORD_CONT EX\r\nWHERE EX.HEADER_ID = SXOOC.HEADER_ID\r\nAND EX.LAST_NAME = SXOOC.LAST_NAME\r\nAND EX.FIRST_NAME = SXOOC.FIRST_NAME\r\nAND EX.CONTACT_TYPE = SXOOC.CONTACT_TYPE )",
