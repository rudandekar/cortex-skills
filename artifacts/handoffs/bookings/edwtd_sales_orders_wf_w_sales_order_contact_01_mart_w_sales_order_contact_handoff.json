      ],
      "attributes": {
        "Sql Query": "SELECT SSCP.SALES_ORDER_CONTACT_KEY AS SALES_ORDER_CONTACT_KEY,\r\nNSON.SALES_ORDER_KEY AS SALES_ORDER_KEY,\r\nSCXOOC.CONTACT_TYPE AS CONTACT_TYPE_CD, \r\nSCXOOC.FIRST_NAME AS CONTACT_FIRST_NAME,\r\nSCXOOC.LAST_NAME AS CONTACT_LAST_NAME, \r\nCOALESCE(SCXOOC.EMAIL_ADDRESS ,'UNKNOWN') AS CONTACT_EMAIL_ADDR,  \r\nCASE WHEN SCXOOC.SOURCE_DML_TYPE = 'DELETE' THEN 'Y' ELSE 'N' END AS SOURCE_DELETED_FLG,\r\nCOALESCE(SCXOOC.TELEPHONE ,'UNKNOWN') AS CONTACT_TELEPHONE_NUM ,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM ,\r\nUSER AS EDW_CREATE_USER ,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM, \r\nUSER AS EDW_UPDATE_USER, \r\n'I' AS ACTION_CODE,\r\nTRIM(CASE  WHEN NSCP.SALES_ORDER_CONTACT_KEY IS NULL THEN 'I' ELSE 'U' END) AS DML_TYPE \r\nFROM (\r\nSELECT  \r\nCONTACT_TYPE,\r\nFIRST_NAME,\r\nLAST_NAME,\r\nEMAIL_ADDRESS,\r\nSOURCE_DML_TYPE,\r\nTELEPHONE,\r\nHEADER_ID    \r\nFROM $$STGDB.ST_CG1_XXGCO_OE_ORD_CONT\r\nUNION ALL\r\nSELECT  \r\nCONTACT_TYPE,\r\nFIRST_NAME,\r\nLAST_NAME,\r\nEMAIL_ADDRESS,\r\nSOURCE_DML_TYPE,\r\nTELEPHONE,\r\nHEADER_ID    \r\nFROM $$EXCEPDB.EX_CG1_XXGCO_OE_ORD_CONT\r\nWHERE EXCEPTION_TYPE='RI') SCXOOC \r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_TV NSON \r\nON NSON.SK_SALES_ORDER_HEADER_ID_INT = SCXOOC.HEADER_ID \r\nAND NSON.SS_CODE = 'CG' \t\t\t\t\t\r\nINNER JOIN $$ETLVWDB.SM_SALES_ORDER_CONTACT SSCP \r\nON SCXOOC.FIRST_NAME = SSCP.CONTACT_FIRST_NAME \r\nAND SCXOOC.LAST_NAME = SSCP.CONTACT_LAST_NAME \r\nAND SCXOOC.CONTACT_TYPE = SSCP.CONTACT_TYPE_CD \r\nAND NSON.SALES_ORDER_KEY =  SSCP.SALES_ORDER_KEY\r\nLEFT OUTER JOIN $$SLSORDVWDB.N_SALES_ORDER_CONTACT NSCP \r\nON   SSCP.SALES_ORDER_CONTACT_KEY = NSCP.SALES_ORDER_CONTACT_KEY       \r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY SK_SALES_ORDER_HEADER_ID_INT ORDER BY BK_SO_SRC_UPD_DATETIME DESC  ) = 1",
        "User Defined Join": "",
        "Source Filter": "",
