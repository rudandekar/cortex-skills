      "attributes": {
        "Sql Query": "SELECT \r\nBOOKINGS_MEASURE_KEY,\r\nBOOKINGS_PROCESS_DATE,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nCNFG.ORG_ID,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCNFG.PROFILE_ID as PROFILE_CHK_ID,\r\nNBM.SALES_TERRITORY_KEY,\r\nNBM.SALES_REP_NUMBER\r\nFROM $$SLSORDVWDB.N_BKGS_MEASURE NBM,$$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDY,$$ETLVWDB.WI_OVERLAY_CONFIG CNFG,$$ETLVWDB.WI_OVERLAY_PROCESS_CONTROL CTRL\r\nWHERE NBM.BOOKINGS_PROCESS_DATE=FDY.CALENDAR_DATE\r\nAND FDY.FISCAL_YEAR_AGE IN (0,1,2,3) AND CNFG.condition_id=1\r\nAND CTRL.PROCESS_TYPE=$$PROCESS_TYPE AND CTRL.ACTIVE_IND='Y'\r\n$$condition_1\r\nUNION ALL\r\nSELECT \r\nBOOKINGS_MEASURE_KEY,\r\nBOOKINGS_PROCESS_DATE,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nCNFG.ORG_ID,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCNFG.PROFILE_ID as PROFILE_CHK_ID,\r\nNBM.SALES_TERRITORY_KEY,\r\nNBM.SALES_REP_NUMBER\r\nFROM $$SLSORDVWDB.N_BKGS_MEASURE NBM,$$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDY,$$ETLVWDB.WI_OVERLAY_CONFIG CNFG,$$ETLVWDB.WI_OVERLAY_PROCESS_CONTROL CTRL\r\nWHERE NBM.BOOKINGS_PROCESS_DATE=FDY.CALENDAR_DATE\r\nAND FDY.FISCAL_YEAR_AGE IN (0,1,2,3) AND CNFG.condition_id=2\r\nAND CTRL.PROCESS_TYPE=$$PROCESS_TYPE AND CTRL.ACTIVE_IND='Y'\r\n$$condition_2\r\nUNION ALL\r\nSELECT \r\nBOOKINGS_MEASURE_KEY,\r\nBOOKINGS_PROCESS_DATE,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nCNFG.ORG_ID,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCNFG.PROFILE_ID as PROFILE_CHK_ID,\r\nNBM.SALES_TERRITORY_KEY,\r\nNBM.SALES_REP_NUMBER\r\nFROM $$SLSORDVWDB.N_BKGS_MEASURE NBM,$$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDY,$$ETLVWDB.WI_OVERLAY_CONFIG CNFG,$$ETLVWDB.WI_OVERLAY_PROCESS_CONTROL CTRL\r\nWHERE NBM.BOOKINGS_PROCESS_DATE=FDY.CALENDAR_DATE\r\nAND FDY.FISCAL_YEAR_AGE IN (0,1,2,3) AND CNFG.condition_id=3 \r\nAND CTRL.PROCESS_TYPE=$$PROCESS_TYPE AND CTRL.ACTIVE_IND='Y'\r\n$$condition_3\r\nUNION ALL\r\nSELECT \r\nBOOKINGS_MEASURE_KEY,\r\nBOOKINGS_PROCESS_DATE,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nCNFG.ORG_ID,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCNFG.PROFILE_ID as PROFILE_CHK_ID,\r\nNBM.SALES_TERRITORY_KEY,\r\nNBM.SALES_REP_NUMBER\r\nFROM $$SLSORDVWDB.N_BKGS_MEASURE NBM,$$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDY,$$ETLVWDB.WI_OVERLAY_CONFIG CNFG,$$ETLVWDB.WI_OVERLAY_PROCESS_CONTROL CTRL\r\nWHERE NBM.BOOKINGS_PROCESS_DATE=FDY.CALENDAR_DATE\r\nAND FDY.FISCAL_YEAR_AGE IN (0,1,2,3) AND CNFG.condition_id=4\r\nAND CTRL.PROCESS_TYPE=$$PROCESS_TYPE AND CTRL.ACTIVE_IND='Y'\r\n$$condition_4\r\nUNION ALL \r\nSELECT \r\nBOOKINGS_MEASURE_KEY,\r\nBOOKINGS_PROCESS_DATE,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nCNFG.ORG_ID,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCNFG.PROFILE_ID as PROFILE_CHK_ID,\r\nNBM.SALES_TERRITORY_KEY,\r\nNBM.SALES_REP_NUMBER\r\nFROM $$SLSORDVWDB.N_BKGS_MEASURE NBM,$$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDY,$$ETLVWDB.WI_OVERLAY_CONFIG CNFG,$$ETLVWDB.WI_OVERLAY_PROCESS_CONTROL CTRL\r\nWHERE NBM.BOOKINGS_PROCESS_DATE=FDY.CALENDAR_DATE\r\nAND FDY.FISCAL_YEAR_AGE IN (0,1,2,3) AND CNFG.condition_id=5\r\nAND CTRL.PROCESS_TYPE=$$PROCESS_TYPE AND CTRL.ACTIVE_IND='Y'\r\n$$condition_5\r\nUNION ALL\r\nSELECT \r\nBOOKINGS_MEASURE_KEY,\r\nBOOKINGS_PROCESS_DATE,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nCNFG.ORG_ID,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCNFG.PROFILE_ID as PROFILE_CHK_ID,\r\nNBM.SALES_TERRITORY_KEY,\r\nNBM.SALES_REP_NUMBER\r\nFROM $$SLSORDVWDB.N_BKGS_MEASURE NBM,$$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDY,$$ETLVWDB.WI_OVERLAY_CONFIG CNFG,$$ETLVWDB.WI_OVERLAY_PROCESS_CONTROL CTRL\r\nWHERE NBM.BOOKINGS_PROCESS_DATE=FDY.CALENDAR_DATE\r\nAND FDY.FISCAL_YEAR_AGE IN (0,1,2,3) AND CNFG.condition_id=6\r\nAND CTRL.PROCESS_TYPE=$$PROCESS_TYPE AND CTRL.ACTIVE_IND='Y'\r\n$$condition_6\r\nUNION ALL\r\nSELECT \r\nBOOKINGS_MEASURE_KEY,\r\nBOOKINGS_PROCESS_DATE,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nCNFG.ORG_ID,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCNFG.PROFILE_ID as PROFILE_CHK_ID,\r\nNBM.SALES_TERRITORY_KEY,\r\nNBM.SALES_REP_NUMBER\r\nFROM $$SLSORDVWDB.N_BKGS_MEASURE NBM,$$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDY,$$ETLVWDB.WI_OVERLAY_CONFIG CNFG,$$ETLVWDB.WI_OVERLAY_PROCESS_CONTROL CTRL\r\nWHERE NBM.BOOKINGS_PROCESS_DATE=FDY.CALENDAR_DATE\r\nAND FDY.FISCAL_YEAR_AGE IN (0,1,2,3) AND CNFG.condition_id=7 \r\nAND CTRL.PROCESS_TYPE=$$PROCESS_TYPE AND CTRL.ACTIVE_IND='Y'\r\n$$condition_7\r\nUNION ALL\r\nSELECT \r\nBOOKINGS_MEASURE_KEY,\r\nBOOKINGS_PROCESS_DATE,\r\nBKGS_MEASURE_TRANS_TYPE_CODE,\r\nCNFG.ORG_ID,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCNFG.PROFILE_ID as PROFILE_CHK_ID,\r\nNBM.SALES_TERRITORY_KEY,\r\nNBM.SALES_REP_NUMBER\r\nFROM $$SLSORDVWDB.N_BKGS_MEASURE NBM,$$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDY,$$ETLVWDB.WI_OVERLAY_CONFIG CNFG,$$ETLVWDB.WI_OVERLAY_PROCESS_CONTROL CTRL\r\nWHERE NBM.BOOKINGS_PROCESS_DATE=FDY.CALENDAR_DATE\r\nAND FDY.FISCAL_YEAR_AGE IN (0,1,2,3) AND CNFG.condition_id=8\r\nAND CTRL.PROCESS_TYPE=$$PROCESS_TYPE AND CTRL.ACTIVE_IND='Y'\r\n$$condition_8",
