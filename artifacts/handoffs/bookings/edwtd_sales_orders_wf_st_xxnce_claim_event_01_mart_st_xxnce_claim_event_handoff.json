        "Sql Query": "SELECT \r\nXCEVENT.EVENT_ID\r\n,XCEVENT.EVENT_TYPE\r\n,XCEVENT.CREATION_DATE\r\n,XCEVENT.CREATED_BY\r\n,XCEVENT.LAST_UPDATED_BY\r\n,XCEVENT.LAST_UPDATED_DATE\r\n,XCEVENT.OBJECT_VERSION_NUMBER\r\n,XCEVENT.CLAIM_ID\r\n,XCEVENT.PENDING_ACTION_ACTOR\r\n,XCEVENT.ACTOR_TYPE\r\n,XCEVENT.CLAIM_TRX_SC_ID\r\n,XCEVENT.CLAIM_STATUS\r\n,XCEVENT.TRXN_APPROVAL_STATUS   \r\nFROM $$NRTACCUMVWDB.XXNCE_CLAIM_EVENT XCEVENT\r\n WHERE XCEVENT.SOURCE_COMMIT_TIME >= '$$LastExtractDate'\r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY XCEVENT.EVENT_ID ORDER BY XCEVENT.REFRESH_DATETIME DESC) = 1",
