        "Sql Query": "SELECT \r\n  SOLD_TO_CUSTOMER_KEY,\r\n  END_CUSTOMER_KEY,\r\n   SALES_ORDER_KEY, \r\n   IDE_IFC_IDE_REPORTED_DEAL_ID,\r\n  EDW_CREATE_USER,\r\n  EDW_CREATE_DATETIME,\r\n  SHIP_TO_CUSTOMER_KEY\r\nFROM    $$STGDB.WI_CHNL_PTRN_BKG_DVAD_SLS_ADJ\r\n\r\n     QUALIFY ROW_NUMBER () OVER (PARTITION BY \r\n      SOLD_TO_CUSTOMER_KEY,\r\n      END_CUSTOMER_KEY,\r\n      SALES_ORDER_KEY,\r\n    IDE_IFC_IDE_REPORTED_DEAL_ID,\r\n  SHIP_TO_CUSTOMER_KEY\r\n\r\n   ORDER BY PROCESS_DATE DESC )  =1",
