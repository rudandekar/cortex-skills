      ],
      "attributes": {
        "Sql Query": "SELECT \r\nN_BOOKINGS_MEASURE.SOLD_TO_CUSTOMER_KEY,\r\nN_BOOKINGS_MEASURE.END_CUSTOMER_KEY,\r\nBOOKINGS_PROCESS_DATE,\r\nN_BOOKINGS_MEASURE.SALES_ORDER_KEY,\r\nNSAL.IDE_IFC_IDE_REPORTED_DEAL_ID  ,\r\nNSAL.MANUAL_TRX_KEY    ,\r\n  USER,\r\n  CURRENT_TIMESTAMP(0),\r\nN_BOOKINGS_MEASURE.SHIP_TO_CUSTOMER_KEY  \r\nFROM $$SLSORDVWDB.N_BOOKINGS_MEASURE N_BOOKINGS_MEASURE\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ADJUSTMENT_LINE NSAL\r\nON N_BOOKINGS_MEASURE.BOOKINGS_MEASURE_KEY=NSAL.BK_SALES_ADJ_LINE_NUMBER_INT\r\nINNER JOIN (\r\nSELECT \r\n  CALENDAR_DATE  \r\n FROM $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR\r\nINNER JOIN $$ETLVWDB.BKG_PROCESS_DT_CNTRL\r\n   ON  FISCAL_YEAR_MONTH_INT =FISCAL_YEAR_MTH_NUMBER_INT\r\n) NFM_CURR\r\n  /*ON NDNBT.PROCESS_DATE = NFM_CURR.CALENDAR_DATE*/\r\n  ON N_BOOKINGS_MEASURE.BOOKINGS_PROCESS_DATE  = NFM_CURR.CALENDAR_DATE\r\n   WHERE N_BOOKINGS_MEASURE.SALES_CHANNEL_CODE = 'DVAD'\r\nAND BKGS_MEASURE_TRANS_TYPE_CODE='SLS_ADJ'\r\nAND SALES_ADJUSTMENT_SOURCE_CODE  <> 'PPP' --- added as part of edw rebate integratin fy19\r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY \r\n      SOLD_TO_CUSTOMER_KEY,\r\n      END_CUSTOMER_KEY,\r\n      N_BOOKINGS_MEASURE.SALES_ORDER_KEY ,\r\n      IDE_IFC_IDE_REPORTED_DEAL_ID,\r\n\t  SHIP_TO_CUSTOMER_KEY\r\n   /*ORDER BY NDNBT.PROCESS_DATE DESC */\r\n   ORDER BY N_BOOKINGS_MEASURE.BOOKINGS_PROCESS_DATE DESC \r\n   )  =1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
