    {
      "name": "SQ_ST_NON_TS_SMT",
      "type": "Source Qualifier",
      "description": "",
      "fields": [
        {
          "name": "BATCH_NUMBER",
          "datatype": "integer",
          "porttype": "INPUT/OUTPUT",
