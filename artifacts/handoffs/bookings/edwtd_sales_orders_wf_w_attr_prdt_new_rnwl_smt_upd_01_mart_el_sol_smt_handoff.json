      "attributes": {
        "Sql Query": "SELECT 'NON-TS' OFFER_NAME,\r\n       -9999 BATCH_NUMBER,\r\n       ST.SALES_ORDER_LINE_KEY SALES_ORDER_LINE_KEY,\r\n       ST.SALES_MOTION_TIMING_CD SALES_MOTION_TIMING_CD,\r\n       CURRENT_DATE START_TV_DT,\r\n      '3500-01-01'  END_TV_DT,\r\n      CURRENT_TIMESTAMP(0) EDW_UPDATE_DTM\r\n FROM $$STGDB.ST_NON_TS_SMT ST WHERE\r\n NOT EXISTS (SELECT 1 FROM $$ETLVWDB.EL_SOL_SMT EL WHERE EL.SALES_ORDER_LINE_KEY = ST.SALES_ORDER_LINE_KEY  AND EL.END_TV_DT = '3500-01-01')",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
