      "attributes": {
        "Sql Query": "SELECT \r\n   \t\t PTL1.BK_SOLD_TO_WIPS_SITE_USE_KEY  \r\n   \t\t,PTL1.BK_END_USER_WIPS_SITE_USE_KEY \r\n   \t\t,PTL1.SOLD_TO_PARTY_KEY             \r\n   \t\t,PTL1.END_CUSTOMER_PARTY_KEY        \r\n   \t\t,PTL1.PARTNER_SITE_PARTY_KEY_INT    \r\n   \t\t,PTL1.PARTNER_PARTY_KEY             \r\n   \t\t,COALESCE(PART_CTRY.ISO_COUNTRY_CODE, 'UNK') PARTNER_COUNTRY\r\n   \t\t,COALESCE(END_CTRY.ISO_COUNTRY_CODE, 'UNK') END_CUST_COUNTRY\r\n   \r\n   \r\n   FROM     $$STGDB.WI_WIPS_DSV_TRANS_PARTNERS  PTL1\r\n   \r\n   LEFT OUTER JOIN (\r\n   \t\tSELECT\t \tNPLA.LOCATOR_KEY, \r\n   \t\t\t\tISO_COUNTRY_CODE,\r\n   \t\t\t\tPARTY_KEY\r\n   \t\tFROM \t    $$COMREFVWDB.N_PARTY_LOCATOR_ASGN NPLA\r\n   \t\tINNER JOIN  $$COMREFVWDB.N_POSTAL_ADDRESS_LOCATOR NPAL\r\n   \t\tON \t\tNPLA.LOCATION_TYPE_CODE = 'POSTAL ADDRESS'\r\n   \t\tAND\t\tNPLA.LOCATOR_KEY = NPAL.LOCATOR_KEY    \r\n   \t\tINNER JOIN  $$COMREFVWDB.N_LOCATOR NL\r\n   \t\tON \t\tNPLA.LOCATOR_KEY = NL.LOCATOR_KEY    \r\n   \t\tAND\t\tNL.SS_CODE='CR' ) PART_CTRY\r\n   ON PTL1.PARTNER_SITE_PARTY_KEY_INT = PART_CTRY.PARTY_KEY \r\n   \r\n   LEFT OUTER JOIN (\r\n   \t\tSELECT \t\tNPLA.LOCATOR_KEY,\r\n   \t\t\t\tISO_COUNTRY_CODE,\r\n   \t\t\t\tPARTY_KEY\r\n   \t\tFROM \t    $$COMREFVWDB.N_PARTY_LOCATOR_ASGN NPLA\r\n   \t\tINNER JOIN  $$COMREFVWDB.N_POSTAL_ADDRESS_LOCATOR NPAL\r\n   \t\tON \t\tNPLA.LOCATION_TYPE_CODE = 'POSTAL ADDRESS'\r\n   \t\tAND \t\tNPLA.LOCATOR_KEY = NPAL.LOCATOR_KEY\r\n   \t\tINNER JOIN  $$COMREFVWDB.N_LOCATOR NL\r\n   \t\tON \t\tNPLA.LOCATOR_KEY = NL.LOCATOR_KEY    \r\n   \t\tAND \t\tNL.SS_CODE='CR') END_CTRY\r\nON  PTL1.END_CUSTOMER_PARTY_KEY = END_CTRY.PARTY_KEY",
