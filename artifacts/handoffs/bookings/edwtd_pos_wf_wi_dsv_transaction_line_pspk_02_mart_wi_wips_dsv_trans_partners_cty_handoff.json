      "attributes": {
        "Sql Query": "SELECT \r\n\t\t PTL2.BK_SOLD_TO_WIPS_SITE_USE_KEY  \r\n\t\t,PTL2.BK_END_USER_WIPS_SITE_USE_KEY \r\n\t\t,PTL2.SOLD_TO_PARTY_KEY             \r\n\t\t,PTL2.END_CUSTOMER_PARTY_KEY        \r\n\t\t,PTL2.PARTNER_SITE_PARTY_KEY_INT    \r\n\t\t,PTL2.PARTNER_PARTY_KEY             \r\n\t\t,PTL2.PARTNER_COUNTRY\r\n\t\t,PTL2.END_CUST_COUNTRY\r\n\t\t,COALESCE(DSHIP.PARTNER_SITE_PARTY_KEY,-999) AS DROP_SHIP_PARTY_SITE_KEY\r\n\t\t,CASE WHEN PARTNER_SITE_PARTY_KEY_INT = -999 THEN -999 \r\n\t\t\t\t ELSE CASE WHEN PARTNER_SITE_PARTY_KEY_INT = END_CUSTOMER_PARTY_KEY THEN PARTNER_SITE_PARTY_KEY_INT \r\n\t\t\t\t      ELSE CASE WHEN PARTNER_COUNTRY = END_CUST_COUNTRY THEN  PARTNER_SITE_PARTY_KEY_INT \r\n\t\t\t\t           ELSE CASE WHEN DROP_SHIP_PARTY_SITE_KEY = -999 THEN PARTNER_SITE_PARTY_KEY_INT \r\n\t\t\t\t                ELSE COALESCE(DSHIP.PARTNER_SITE_PARTY_KEY,-999) \r\n\t\t\t\t                END\r\n\t\t\t\t           END\r\n\t\t\t\t      END\r\n\t\t\tEND PARTNER_SITE_PARTY_KEY\r\nFROM     $$STGDB.WI_WIPS_DSV_TRANS_PARTNERS_CTY  PTL2\r\n\r\nLEFT OUTER JOIN  (SELECT PS.PARTNER_SITE_PARTY_KEY, \r\n\t\t\t COALESCE(PS.BK_PARTY_ID_INT,-999) PARTY_ID,\r\n                         COALESCE(DD_GRNDPARNT_PARTNER_PARTY_KEY,-999) GRNDPARNT_PARTNER_PARTY_KEY,\r\n                         COALESCE (BK_ISO_COUNTRY_CODE,'UNK')  ISO_COUNTRY_CODE\r\n    \t\t  FROM \r\n    \t\t\t$$COMREFVWDB.N_CHANNEL_PARTNER_SITE PS,\r\n    \t\t\t$$COMREFVWDB.N_CHNL_PTNR_COUNTRY PC\r\n    \t\t  WHERE 1=1\r\n    \t\t  AND \tPS.PARTNER_COUNTRY_PARTY_KEY = PC.PARTNER_COUNTRY_PARTY_KEY \r\nAND PS.SOURCE_DELETED_FLG='N'\r\nAND PC.SOURCE_DELETED_FLG='N'\r\n    \t\t  QUALIFY ROW_NUMBER () OVER (PARTITION BY GRNDPARNT_PARTNER_PARTY_KEY,ISO_COUNTRY_CODE\r\n\t\t\t\t\t\tORDER BY PARTY_ID ASC) =1)  DSHIP\r\nON  PTL2.PARTNER_PARTY_KEY = DSHIP.GRNDPARNT_PARTNER_PARTY_KEY\r\nAND PTL2.END_CUST_COUNTRY = DSHIP.ISO_COUNTRY_CODE",
        "User Defined Join": "",
