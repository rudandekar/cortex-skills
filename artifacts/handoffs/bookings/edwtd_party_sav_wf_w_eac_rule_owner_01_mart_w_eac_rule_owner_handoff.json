      "attributes": {
        "Sql Query": "SELECT \r\nST_XXFSAM_EAC_RULE_OWNER_V.RULE_OWNER_DTL_ID, \r\nCOALESCE(ST_XXFSAM_EAC_RULE_OWNER_V.TERRITORY_TYPE,'UNKNOWN'), \r\nCOALESCE(RSH.SALES_TERRITORY_KEY,-999) AS SALES_TERRITORY_KEY,\r\nCOALESCE(REP.SALES_REP_NUM,'UNKNOWN') AS SALES_REP_NUM,\r\nST_XXFSAM_EAC_RULE_OWNER_V.ORGANIZATION_ID, \r\nCOALESCE(NCWP_CRTD.CISCO_WORKER_PARTY_KEY,-999) AS CRTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE(NCWP_UPDT.CISCO_WORKER_PARTY_KEY,-999) AS LST_UPTD_BY_CSCO_WRKR_PRTY_KEY,\r\nST_XXFSAM_EAC_RULE_OWNER_V.RULE_ID, \r\nCOALESCE(ST_XXFSAM_EAC_RULE_OWNER_V.RULE_OWNER_START_DATE,CAST('3500-01-01' AS DATE)), \r\nCOALESCE(ST_XXFSAM_EAC_RULE_OWNER_V.RULE_OWNER_END_DATE,CAST('3500-01-01' AS DATE)),  \r\nCOALESCE(ST_XXFSAM_EAC_RULE_OWNER_V.RULE_OWNER_CREATION_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))),  \r\nCOALESCE(ST_XXFSAM_EAC_RULE_OWNER_V.RULE_OWNER_CREATION_DATE,CAST('3500-01-01 00:00:00' AS DATE)), \r\nCOALESCE(ST_XXFSAM_EAC_RULE_OWNER_V.RULE_OWNER_LAST_UPDATED_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))), \r\nCOALESCE(ST_XXFSAM_EAC_RULE_OWNER_V.RULE_OWNER_LAST_UPDATED_DATE,CAST('3500-01-01 00:00:00' AS DATE)), \r\nCOALESCE(ST_XXFSAM_EAC_RULE_OWNER_V.OWNER_STATUS,'UNKNOWN'), \r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\n'I' ACTION_CODE,\r\n'I' AS DML_TYPE\r\n\r\nFROM\r\n$$STGDB.ST_XXFSAM_EAC_RULE_OWNER_V ST_XXFSAM_EAC_RULE_OWNER_V\r\nINNER JOIN $$SLSORDVWDB.N_EAC_RULE RULE\r\nON ST_XXFSAM_EAC_RULE_OWNER_V.RULE_ID=RULE.BK_EAC_RULE_ID\r\nINNER JOIN $$SLSORDVWDB.N_EAC_ORG ORG\r\nON ST_XXFSAM_EAC_RULE_OWNER_V.ORGANIZATION_ID=ORG.BK_EAC_ORG_ID\r\nLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP_CRTD\r\n\tON COALESCE(ST_XXFSAM_EAC_RULE_OWNER_V.RULE_OWNER_CREATED_BY,'UNKNOWN') = NCWP_CRTD.CEC_ID AND NCWP_CRTD.CISCO_WORKER_PARTY_KEY<>-999 \r\nLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP_UPDT\r\n\tON COALESCE(ST_XXFSAM_EAC_RULE_OWNER_V.RULE_OWNER_LAST_UPDATED_BY,'UNKNOWN') = NCWP_UPDT.CEC_ID AND NCWP_UPDT.CISCO_WORKER_PARTY_KEY<>-999 \r\nLEFT JOIN \r\n(SELECT SHARE_NODE_ID_INT,SALES_TERRITORY_KEY FROM $$COMREFVWDB.R_SALES_HIERARCHY \r\n  UNION \r\n SELECT SHARE_NODE_ID_INT,SALES_TERRITORY_KEY FROM $$COMREFVWDB.R_SALES_HIERARCHY_CONFIRMED\r\n ) RSH\r\n\tON COALESCE(ST_XXFSAM_EAC_RULE_OWNER_V.RULE_NODE_ID,-9999) = RSH.SHARE_NODE_ID_INT\r\nLEFT JOIN $$COMREFVWDB.MT_ERP_SALES_REP REP\r\nON COALESCE(CAST(ST_XXFSAM_EAC_RULE_OWNER_V.RULE_OWNER_ID AS VARCHAR(30)),'UNKNOWN')=REP.SALES_REP_NUM AND  REP.SALES_REP_NUM<>'UNKNOWN'",
        "User Defined Join": "",
