      "attributes": {
        "Sql Query": "SELECT\r\nPRODUCT_FAMILY AS BK_PRODUCT_FAMILY_ID,\r\nRFWY.FISCAL_WEEK_NUMBER_INT AS BK_FISCAL_WEEK_NUM_INT,\r\nRFWY.FISCAL_YEAR_NUMBER_INT AS BK_FISCAL_YEAR_NUM_INT,\r\nRFWY.fiscal_CALENDAR_CODE AS BK_FISCAL_CALENDAR_CD,\r\n'UNKNOWN' AS BK_SALES_CHANNEL_SRC_TYPE,\r\nSALES_CHANNEL AS BK_SALES_CHANNEL_CD,\r\nUPPER(DELIVERY_TYPE) AS BK_DELIVERY_TYPE_CD,\r\nSUM(BUILD_plan )    AS BUILD_PLAN_USD_AMT   ,\r\nSUM(SHIP_PLAN )     AS SHIP_PLAN_USD_AMT , \r\nRFDY.FISCAL_MONTH_START_DATE AS BK_PLAN_PUBLISH_DT,      \r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' as ACTION_CODE,\r\n'I' AS DML_TYPE           \r\nfrom (SEL PRODUCT_FAMILY,                \r\nFISCAL_WEEK_START_DATE  ,      \r\nSALES_CHANNEL                 ,\r\nDELIVERY_TYPE                 ,\r\nSHIP_PLAN                     ,\r\nCAST (0 AS DECIMAL(18,6)) AS BUILD_plan,\r\nCREATION_DATE\r\nfrom $$STGDB.ST_XXCMF_SP_CRP_SHIP_DATA\r\nunion ALL\r\nSEL PRODUCT_FAMILY,                \r\nFISCAL_WEEK_START_DATE  ,      \r\nSALES_CHANNEL                 ,\r\nDELIVERY_TYPE                 ,\r\n0       ,\r\nBUILD_plan,\r\nCREATION_DATE\r\nfrom $$stgdb.ST_XXCMF_SP_CRP_BUILD_DATA\r\n)st\r\n\r\nINNER JOIN $$COMREFVWDB.r_fiscal_week_to_year RFWY\r\nON ST.FISCAL_WEEK_START_DATE BETWEEN RFWY.FISCAL_WEEK_START_DATE AND RFWY.FISCAL_WEEK_END_DATE\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR RFDY\r\non CREATION_DATE=CALENDAR_DATE\r\nGROUP BY 1,2,3,4,5,6,7,10",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
