      ],
      "attributes": {
        "Sql Query": "SELECT\r\nRBF.BKGS_MEASURE_TRANS_TYPE_CODE AS BKGS_MEASURE_TRANS_TYPE_CD , \r\nMAX(CASE WHEN RSEC.END_CUSTOMER_KEY IS NOT NULL THEN RSEC.END_CUSTOMER_KEY     ELSE RBF.DV_END_CUSTOMER_KEY END  )AS SO_END_CUSTOMER_KEY,\r\nMAX(RBCMF.PARTNER_SITE_PARTY_KEY) AS                SO_PARTNER_SITE_PARTY_KEY                       ,\r\nRBF.DV_SOURCE_ORDER_NUM_INT AS DV_SOURCE_ORDER_NUM_INT\r\nFROM $$SLSORDVWDB.N_BKGS_MEASURE RBF\r\nINNER JOIN  $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR SFDTY\r\n            ON(RBF.BOOKINGS_PROCESS_DATE=SFDTY.CALENDAR_DATE\r\n            AND SFDTY.FISCAL_YEAR_AGE IN (0,1))\r\nINNER JOIN $$SLSORDVWDB.N_BKGS_CHNL_MEASURE RBCMF\r\n            ON ( RBCMF.BOOKINGS_MEASURE_KEY=RBF.BOOKINGS_MEASURE_KEY\r\n            AND RBCMF.BOOKINGS_PROCESS_DATE=RBF.BOOKINGS_PROCESS_DATE\r\n            AND RBCMF.BKGS_MEASURE_TRANS_TYPE_CODE=RBF.BKGS_MEASURE_TRANS_TYPE_CODE)\r\nLEFT OUTER JOIN $$SLSORDVWDB.N_SO_END_CUSTOMER RSEC\r\n            ON ( RSEC.SALES_ORDER_KEY=RBF.SALES_ORDER_KEY\r\n            AND RBF.SALES_ORDER_KEY>0)\r\nWHERE RBF.DV_SOURCE_ORDER_NUM_INT IS NOT NULL  \r\n GROUP BY 1,4",
        "User Defined Join": "",
