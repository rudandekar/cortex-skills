      "attributes": {
        "Sql Query": "SELECT\t\r\nSTQDL.BK_DELIVERABLE_NAME AS BK_DELIVERABLE_NAME,\r\nSTQDL.BK_SERVICE_COMPONENT_NAME AS BK_SERVICE_COMPONENT_NAME,\r\nSTQDL.BK_SERVICE_PROGRAM_NAME AS BK_SERVICE_PROGRAM_NAME ,\r\nSTQDL.BK_AS_QUOTE_NUM AS BK_AS_QUOTE_NUM,\r\nCOALESCE(STQDL.TOTAL_TRIPS_CNT,0) AS TOTAL_TRIPS_CNT,\r\nCOALESCE(STQDL.TOTAL_NONLABOR_USD_COST,0.00) AS  TOTAL_NONLABOR_USD_COST,\r\nCOALESCE(STQDL.TOTAL_WORK_HRS_QTY,0) AS TOTAL_WORK_HRS_QTY,\r\nSTQDL.TOTAL_NIGHTS_AWAY_CNT AS TOTAL_NIGHTS_AWAY_CNT,\r\nCOALESCE(STQDL.SERVICE_PRD_NET_PRICE_USD_AMT,0.00) AS SERVICE_PRD_NET_PRICE_USD_AMT,\r\nCOALESCE(STQDL.SERVICE_PRD_LST_PRICE_USD_AMT,0.00) AS SERVICE_PRD_LST_PRICE_USD_AMT,\r\nCOALESCE(STQDL.SERVICE_PRD_COST_USD_AMT,0.00) AS SERVICE_PRD_COST_USD_AMT,\r\nCOALESCE(STQDL.SERVICE_PRD_QTY,0.00) AS SERVICE_PRD_QTY,\r\nCOALESCE(STQDL.ORDERED_QTY,0.00) AS ORDERED_QTY,\r\nCOALESCE(STQDL.DELIVERABLE_TYPE_CD,'UNKNOWN') AS DELIVERABLE_TYPE_CD,\r\nCOALESCE(STQDL.SOURCE_DELETED_FLG,'N') AS SOURCE_DELETED_FLG,\r\nCOALESCE(STQDL.TOTAL_TRAVEL_HRS_CNT,0) AS TOTAL_TRAVEL_HRS_CNT,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\nSTQDL.SS_CD AS SS_CD,\r\nSTQDL.ONSITE_HRS_CNT,\r\nSTQDL.REMOTE_HRS_CNT,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NSUBC.BK_DELIVERABLE_NAME IS NULL\r\n\t\t  AND  NSUBC.BK_SERVICE_COMPONENT_NAME IS NULL\r\n\t\t  AND  NSUBC.BK_SERVICE_PROGRAM_NAME IS NULL\r\n\t\t  AND  NSUBC.BK_AS_QUOTE_NUM IS NULL\r\n\t THEN 'I'\r\n\t ELSE 'U'\r\nEND AS DML_TYPE\r\n\r\nFROM $$STGDB.ST_AS_QT_WTH_SBS_PRC_DLVRBL_DTL_HDP STQDL\r\n\r\nLEFT OUTER JOIN $$SERVICEVWDB.N_AS_QT_WTH_SBS_PRC_DLVRBL_DTL NSUBC\r\n ON (NSUBC.BK_DELIVERABLE_NAME = STQDL.BK_DELIVERABLE_NAME\r\n AND NSUBC.BK_SERVICE_COMPONENT_NAME=STQDL.BK_SERVICE_COMPONENT_NAME\r\n AND NSUBC.BK_SERVICE_PROGRAM_NAME=STQDL.BK_SERVICE_PROGRAM_NAME\r\n AND NSUBC.BK_AS_QUOTE_NUM=STQDL.BK_AS_QUOTE_NUM\r\n AND NSUBC.SS_CD = STQDL.SS_CD)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
