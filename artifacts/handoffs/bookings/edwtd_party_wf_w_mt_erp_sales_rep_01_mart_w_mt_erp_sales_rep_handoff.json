      "attributes": {
        "Sql Query": "SELECT\r\nREP.SALES_REP_NUMBER\t\t\t\t\tAS\tSALES_REP_NUM,              \r\nREP.ERP_SALES_REP_TYPE\t\t\t\t\tAS\tERP_SALES_REP_TYPE,\r\nREP.ERP_SALES_REP_NAME\t\t\t\t\tAS\tERP_SALES_REP_NAME,            \r\nREP.RU_SALES_TERR_TEAM_NAME\t\t\t\tAS\tSALES_TERR_TEAM_NAME,          \r\n(\tCASE \r\n\t\tWHEN CHAR(CWP.DD_PRIMARY_NAME) <= 0 \r\n\t\t\tTHEN CWP.DD_PRIMARY_NAME \r\n\t\tELSE CASE \r\n\t\t\t\tWHEN POSITION (',' IN CWP.DD_PRIMARY_NAME) <=0 \r\n\t\t\t\t\tTHEN CWP.DD_PRIMARY_NAME \r\n\t\t\t\tELSE  SUBSTR(CWP.DD_PRIMARY_NAME,(POSITION (',' IN CWP.DD_PRIMARY_NAME)+1),CHAR(CWP.DD_PRIMARY_NAME))  || ' ' || SUBSTR(CWP.DD_PRIMARY_NAME, 1, (POSITION (',' IN CWP.DD_PRIMARY_NAME)-1))\r\n\t\t\tEND \r\n\tEND\r\n)\t\t\t\t\t\t\t\t\tAS\tCWP_SORTED_PRIMARY_NAME,     \r\nCWP.CISCO_WORKER_PARTY_KEY\t\t\t\tAS\tEP_CISCO_WORKER_PARTY_KEY,     \r\nREP.SS_CODE\t\t\t\t\t\t\tAS\tSS_CD,                         \r\nREP.SALES_REP_ACTIVE_END_DT\t\t\t\tAS\tSALES_REP_ACTIVE_END_DT,       \r\nREP.SALES_REP_ACTIVE_START_DT\t\t\t\tAS\tSALES_REP_ACTIVE_START_DT,     \r\nREP.SALESREP_STATUS_CD\t\t\t\t\tAS\tSALESREP_STATUS_CD,            \r\nCWP.BK_EMPLOYEE_ID\t\t\t\t\t\tAS\tBK_EMPLOYEE_ID,                \r\nCWP.CISCO_EMAIL_ADDRESS\t\t\t\t\tAS\tCISCO_EMAIL_ADDRESS,           \r\nCWP.CISCO_EMAIL_ADDRESS\t\t\t\t\tAS\tCEC_ID,                        \r\nCWP.PUBLIC_JOB_TITLE\t\t\t\t\t\tAS\tPUBLIC_JOB_TITLE,              \r\nCWP.REFERRAL_SOURCE_DESCR\t\t\t\tAS\tREFERRAL_SOURCE_DESCR,         \r\nCWP.RU_EMPLOYEE_STATUS_CODE\t\t\t\tAS\tEMPLOYEE_STATUS_CD,            \r\nCWP.BK_DEPARTMENT_CODE\t\t\t\t\tAS\tBK_DEPARTMENT_CD,              \r\nCWP.DD_PRIMARY_NAME\t\t\t\t\tAS\tDD_PRIMARY_NAME,               \r\nCWP.BK_COMPANY_CODE\t\t\t\t\tAS\tBK_COMPANY_CD,                 \r\nCWP.RU_BK_EMPLYMNT_CAT_CNTNGNCY_CD\t\tAS\tRU_BK_EMPLYMNT_CAT_CNTNGNCY_CD,\r\nCWP.WORK_TYPE_CODE\t\t\t\t\tAS\tWORK_TYPE_CODE,                \r\nCWP.CISCO_WORKER_PARTY_TYPE\t\t\t\tAS\tCISCO_WORKER_PARTY_TYPE,       \r\n'E_COMREF_BATCH'\t\t\t\t\t\tAS\tEDW_CREATE_USER,     \r\nCURRENT_TIMESTAMP(0)\t\t\t\t\tAS\tEDW_CREATE_DTM,       \r\nCURRENT_TIMESTAMP(0)\t\t\t\t\tAS\tEDW_UPDATE_DTM,       \r\n'E_COMREF_BATCH'\t\t\t\t\t\tAS\tEDW_UPDATE_USER, \r\nREP.RU_TEAM_TYPE_CD                     AS  TEAM_TYPE_CD,\r\nREP.RU_SALES_REP_TYPE_CD \t\t\t    AS  SALES_REP_TYPE_CD,\r\nREP.RU_TEAM_DESCR\t\t\t\t\t\tAS  TEAM_DESCR,\r\nREP.SOURCE_DELETED_FLG                  AS  SOURCE_DELETED_FLG,\r\n'I'\t\t\t\t\t\t\t\t\tAS\tACTION_CODE,     \r\n'I'\t\t\t\t\t\t\t\t\tAS\tDML_TYPE\r\nFROM\r\n\t$$COMREFVWDB.N_ERP_SALES_REP_TV REP\r\n\tINNER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY_TV CWP\r\n\t\tON  REP.RU_CISCO_WORKER_PARTY_KEY  =  CWP.CISCO_WORKER_PARTY_KEY \r\n\tWHERE \r\n\t\tREP.END_TV_DATE  = '3500-01-01'\r\n\t\tAND \r\n\t\tCWP.END_TV_DATE='3500-01-01'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
