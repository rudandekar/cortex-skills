      "attributes": {
        "Sql Query": "SELECT\r\nSDAH.CLAIM_DETAIL_ID AS BK_CLAIM_DETAIL_ID_INT,\r\nSDAH.CLAIM_ID AS BK_CLAIM_ID_INT,\r\nSDAH.COMMENTS_RSN_TXT AS APPROVAL_RSN_TXT,\r\nSDAH.RESULT_ID AS SK_RESULT_ID_INT,\r\nCOALESCE(SDAH.CHECK_CODE,'UNKNOWN') AS BK_CLAIM_REJECTION_RSN_CD,\r\nCOALESCE(SDAH.CHECK_STATUS,'UNKNOWN') AS VALIDITY_CHECK_STATUS_CD,\r\nCURRENT_TIMESTAMP(0)  AS EDW_CREATE_DTM,\r\nUSER\t\t      AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0)  AS EDW_UPDATE_DTM,\r\nUSER\t\t      AS EDW_UPDATE_USER,\r\nACTION_CD  AS ACTION_CODE,\r\n'I'  AS DML_TYPE,\r\nCORRECTION_ACTION AS CORRECTIVE_ACTION_CD,\r\nVALIDATION_REASON_CODE AS VALIDATION_REASON_CD, \r\nCOALESCE(ACTIVE_FLAG,'=') AS ACTIVE_FLG\r\nFROM\r\n$$STGDB.ST_DCA_AUTOVALIDATION_HIST SDAH\r\nINNER JOIN $$SLSORDVWDB.N_DISTRIBUTOR_CLAIM_LINE NDCL\r\nON SDAH.CLAIM_ID=NDCL.BK_CLAIM_ID_INT\r\nAND SDAH.CLAIM_DETAIL_ID=NDCL.BK_CLAIM_DETAIL_ID_INT\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY CLAIM_DETAIL_ID,CLAIM_ID,CHECK_CODE ORDER BY LAST_UPDATE_DATE DESC) =1",
