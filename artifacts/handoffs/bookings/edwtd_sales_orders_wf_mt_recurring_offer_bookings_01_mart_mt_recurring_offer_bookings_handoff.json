      "attributes": {
        "Sql Query": "SELECT \r\n DV_RECURRING_OFFER_CD         \r\n ,PRODUCT_KEY                   \r\n ,DV_PRODUCT_KEY                \r\n ,SALES_ORDER_KEY               \r\n ,SK_OFFER_ATTRIBUTION_ID_INT   \r\n ,ENTERPRISE_SKU_PRDT_KEY       \r\n ,DV_RO_PRODUCT_KEY             \r\n ,BK_OFFER_TYPE_NAME            \r\n ,CSCC_FLG                      \r\n ,ELA_FLG                       \r\n ,XCAT_FLG                      \r\n ,RECURRING_OFFER_FLG           \r\n ,DV_RU_SOFTWARE_USAGE_TYPE_CD  \r\n ,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM                \r\n ,CURRENT_USER AS EDW_CREATE_USER               \r\n ,CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM                \r\n ,CURRENT_USER AS EDW_UPDATE_USER \r\n  /*Added as part of Feb 18th Rel */\r\n ,CORPORATE_RECURRING_BKGS_FLG\r\n ,TRIM(COALESCE(DV_DEAL_ID,'-9999')) AS DV_DEAL_ID\r\n ,COALESCE(DV_SOURCE_ORDER_NUM_INT,-9999) AS DV_SOURCE_ORDER_NUM_INT\r\n FROM $$STGDB.WI_RECURRING_OFFER_BOOKINGS W\r\n WHERE NOT EXISTS (\r\n SELECT 1 FROM $$SLSORDVWDB.MT_RECURRING_OFFER_BOOKINGS MT\r\n WHERE W.DV_RECURRING_OFFER_CD=MT.DV_RECURRING_OFFER_CD\r\n )",
