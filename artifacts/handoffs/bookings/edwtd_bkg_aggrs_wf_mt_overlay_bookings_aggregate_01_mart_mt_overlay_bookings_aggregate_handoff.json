      "attributes": {
        "Sql Query": "SELECT \r\nEND_CUSTOMER_KEY,\r\nBILL_TO_CUSTOMER_KEY,\r\nSHIP_TO_CUSTOMER_KEY,\r\nSOLD_TO_CUSTOMER_KEY,\r\nOVERLAY_SALES_TERRITORY_KEY,\r\nOVERLAY_SALES_REP_NUMBER,\r\nSERVICE_FLG,\r\nOVRLY_BKGS_MSR_TRANS_TYPE_CODE,\r\nBK_SLS_TERR_ASSIGNMENT_TYPE_CD,\r\nBOOK_NET_WTD_AMT,\r\nBOOK_NET_MTD_AMT,\r\nBOOK_NET_QTD_AMT,\r\nBOOK_NET_YTD_AMT,\r\nEDW_CREATE_DTM,               \r\nEDW_CREATE_USER,\r\nDV_ATTRIBUTION_CD,\r\nDV_FMV_FLG,\r\nCORPORATE_BOOKINGS_FLG,\r\nDV_REVENUE_RECOGNITION_FLG,\r\nDV_NET_SPREAD_FLG,\r\nDSV_FLG,\r\nCASE WHEN END_CUSTOMER_KEY = -999 THEN RANDOM(1000000,1001800)*-1 \r\n\t\t    ELSE END_CUSTOMER_KEY \r\n END AS RD_END_CUSTOMER_KEY,\r\nCASE WHEN BILL_TO_CUSTOMER_KEY = -999 THEN RANDOM(1000000,1001800)*-1 \r\n\t \t\tELSE BILL_TO_CUSTOMER_KEY\t\r\n END AS RD_BILL_TO_CUSTOMER_KEY ,\r\nCASE WHEN SHIP_TO_CUSTOMER_KEY = -999 THEN RANDOM(1000000,1001800)*-1 \r\n\t \t\tELSE SHIP_TO_CUSTOMER_KEY \r\n END AS RD_SHIP_TO_CUSTOMER_KEY ,\r\nCASE WHEN SOLD_TO_CUSTOMER_KEY = -999 THEN RANDOM(1000000,1001800)*-1 \r\n\t \t\tELSE SOLD_TO_CUSTOMER_KEY \r\n END AS RD_SOLD_TO_CUSTOMER_KEY  ,\r\nCASE WHEN OVERLAY_SALES_TERRITORY_KEY =\t-999 THEN RANDOM(1000000,1001800)*-1 \r\n\t \t\tELSE OVERLAY_SALES_TERRITORY_KEY \r\n END AS RD_OVERLAY_SALES_TERRITORY_KEY\r\nFROM \r\n( select \r\nEND_CUSTOMER_KEY,\r\nBILL_TO_CUSTOMER_KEY,\r\nSHIP_TO_CUSTOMER_KEY,\r\nSOLD_TO_CUSTOMER_KEY,\r\nOVERLAY_SALES_TERRITORY_KEY,\r\nOVERLAY_SALES_REP_NUMBER,\r\nSERVICE_FLG,\r\nOVRLY_BKGS_MSR_TRANS_TYPE_CODE,\r\nBK_SLS_TERR_ASSIGNMENT_TYPE_CD,\r\nsum(\r\ncase when OVERLAY_BOOKINGS_PROCESS_DATE between FISCAL_WEEK_START_DATE and FISCAL_WEEK_END_DATE\r\nthen DD_COMP_US_NET_PRICE_AMOUNT\r\nelse 0.00\r\nend) as BOOK_NET_WTD_AMT,\r\nsum(\r\ncase when OVERLAY_BOOKINGS_PROCESS_DATE between FISCAL_MONTH_START_DATE and FISCAL_MONTH_END_DATE\r\nthen DD_COMP_US_NET_PRICE_AMOUNT\r\nelse 0.00\r\nend) as BOOK_NET_MTD_AMT,\r\nsum(\r\ncase when OVERLAY_BOOKINGS_PROCESS_DATE between FISCAL_QUARTER_START_DATE and FISCAL_QUARTER_END_DATE\r\nthen DD_COMP_US_NET_PRICE_AMOUNT\r\nelse 0.00\r\nend) as BOOK_NET_QTD_AMT,\r\nsum(\r\ncase when OVERLAY_BOOKINGS_PROCESS_DATE between FISCAL_YEAR_START_DATE and FISCAL_YEAR_END_DATE\r\nthen DD_COMP_US_NET_PRICE_AMOUNT\r\nelse 0.00\r\nend) as BOOK_NET_YTD_AMT,\r\nEDW_CREATE_DTM,               \r\nEDW_CREATE_USER,\r\nDV_ATTRIBUTION_CD,\r\nDV_FMV_FLG,\r\nCORPORATE_BOOKINGS_FLG,\r\nDV_REVENUE_RECOGNITION_FLG,\r\nDV_NET_SPREAD_FLG,\r\nDSV_FLG\r\nfrom $$SLSORDVWDB.MT_OVERLAY_BKGS_MEASURE a, \r\n(select * from $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR where CALENDAR_DATE=current_date) b\r\nwhere a.OVERLAY_BOOKINGS_PROCESS_DATE between FISCAL_YEAR_START_DATE and FISCAL_YEAR_END_DATE\r\ngroup by \r\nEND_CUSTOMER_KEY,\r\nBILL_TO_CUSTOMER_KEY,\r\nSHIP_TO_CUSTOMER_KEY,\r\nSOLD_TO_CUSTOMER_KEY,\r\nOVERLAY_SALES_TERRITORY_KEY,\r\nOVERLAY_SALES_REP_NUMBER,\r\nSERVICE_FLG,\r\nOVRLY_BKGS_MSR_TRANS_TYPE_CODE,\r\nBK_SLS_TERR_ASSIGNMENT_TYPE_CD,\r\nEDW_CREATE_DTM,                \r\nEDW_CREATE_USER,\r\nDV_ATTRIBUTION_CD,\r\nDV_FMV_FLG,\r\nCORPORATE_BOOKINGS_FLG,\r\nDV_REVENUE_RECOGNITION_FLG,\r\nDV_NET_SPREAD_FLG,\r\nDSV_FLG ) MT",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
