      "attributes": {
        "Sql Query": "SELECT  \r\nINT1.ID,                           \r\nCAST(CAST(INT1.EDW_CREATE_DTM AS VARCHAR(19))AS TIMESTAMP(0)),\r\nINT1.HEADER_ID,                     \r\nINT1.ORDER_NUMBER,                  \r\nINT1.LINE_ID,                       \r\nINT1.LINE_REF_NUMBER ,              \r\nINT1.HOLD_ID ,                      \r\nINT1.HOLD_APPLY_REASON,             \r\nINT1.HOLD_APPLY_COMMENT ,           \r\nCAST(CAST(INT1.HOLD_APPLIED_DATE AS VARCHAR(19))AS TIMESTAMP(0)),\r\nINT1.HOLD_APPLIED_BY,          \r\nCAST(CAST(INT1.HOLD_RELEASE_DATE AS VARCHAR(19))AS TIMESTAMP(0)),              \r\nINT1.HOLD_RELEASED_BY,              \r\nINT1.HOLD_RELEASE_COMMENT,          \r\nINT1.HOLD_RELEASE_REASON,          \r\nINT1.RELEASED_FLAG ,                \r\nINT1.HOLD_CAUSED_BY ,               \r\nCAST(CAST(INT1.CREATION_DATE AS VARCHAR(19))AS TIMESTAMP(0)),\r\nINT1.CREATED_BY, \r\nCAST(CAST(INT1.LAST_UPDATED_DATE AS VARCHAR(19))AS TIMESTAMP(0)),\r\nINT1.LAST_UPDATED_BY,               \r\nINT1.TOTAL_ORDER_AMOUNT,            \r\nINT1.HOLD_AMOUNT ,                  \r\nINT1.HOLD_NAME ,                    \r\nINT1.HOLD_SOURCE_ID \r\nFROM (SELECT * FROM $$ETLVWDB.ST_SI_XXOPL_ORDER_HOLDS_DATA HDR\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY ID ORDER BY EDW_CREATE_DTM DESC)=1\r\n) INT1\r\nINNER JOIN (SELECT * FROM $$ETLVWDB.ST_SI_XXOPL_ORDER_HEADERS_ALL \r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY HEADER_ID ORDER BY EDW_CREATE_DTM DESC)=1\r\n)EL\r\nON EL.HEADER_ID = INT1.HEADER_ID\r\nWHERE CAST(CAST(INT1.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >=CAST('$$LastExtractDate' AS TIMESTAMP(0))\r\nAND COALESCE(EL.ORDER_ORIGIN,'UNKNOWN')<>'CLOUD-CBM' and EL.ORDER_ORIGIN NOT IN ('B2B-COMMERCE','REVCLOUD-SALESMAIN') /*REVCLOUD-SALESMAIN added for Omega Feb 23 release*/\r\n/* Below UNion ALL added for GROGU Q3FY22 release*/\r\n\r\nUNION ALL\r\n\r\nSELECT  \r\nINT1.ID,                           \r\nCAST(CAST(INT1.EDW_CREATE_DTM AS VARCHAR(19))AS TIMESTAMP(0)),\r\n/*INT1.HEADER_ID,                     */\r\n /*CQOALESCE is added for header_id and line_id for FY22 GROGU Change*/ \r\ncast(COALESCE(INT1.HEADER_ID ,INT1.ORDER_NUMBER) as BIGINT) HEADER_ID,  \r\nINT1.ORDER_NUMBER,                  \r\ncast(COALESCE(INT1.LINE_ID,INT1.LINE_REF_NUMBER) as BIGINT) LINE_ID ,\r\n /*Q3FY22 GROGU Change*/                     \r\nINT1.LINE_REF_NUMBER ,              \r\nINT1.HOLD_ID ,                      \r\nINT1.HOLD_APPLY_REASON,             \r\nINT1.HOLD_APPLY_COMMENT ,           \r\nCAST(CAST(INT1.HOLD_APPLIED_DATE AS VARCHAR(19))AS TIMESTAMP(0)),\r\nINT1.HOLD_APPLIED_BY,          \r\nCAST(CAST(INT1.HOLD_RELEASE_DATE AS VARCHAR(19))AS TIMESTAMP(0)),              \r\nINT1.HOLD_RELEASED_BY,              \r\nINT1.HOLD_RELEASE_COMMENT,          \r\nINT1.HOLD_RELEASE_REASON,          \r\nINT1.RELEASED_FLAG ,                \r\nINT1.HOLD_CAUSED_BY ,               \r\n-- modified creation_date logic as part of GROGU may 22 release            \r\nCAST(CAST(COALESCE(INT1.CREATION_DATE,INT1.HOLD_APPLIED_DATE,CURRENT_TIMESTAMP(6)) AS VARCHAR(19)) AS TIMESTAMP(0)) AS CREATION_DATE, \r\nINT1.CREATED_BY, \r\nCAST(CAST(INT1.LAST_UPDATED_DATE AS VARCHAR(19))AS TIMESTAMP(0)),\r\nINT1.LAST_UPDATED_BY,               \r\nINT1.TOTAL_ORDER_AMOUNT,            \r\nINT1.HOLD_AMOUNT ,                  \r\nINT1.HOLD_NAME ,                    \r\nINT1.HOLD_SOURCE_ID \r\nFROM (SELECT * FROM $$ETLVWDB.ST_SI_XXOPL_ORDER_HOLDS_DATA HDR\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY ID ORDER BY EDW_CREATE_DTM DESC)=1\r\n) INT1\r\nINNER JOIN (SELECT * FROM $$ETLVWDB.ST_SI_XXOPL_ORDER_HEADERS_ALL \r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY coalesce(HEADER_ID,order_number) ORDER BY EDW_CREATE_DTM DESC)=1\r\n)EL\r\nON \r\n  cast(COALESCE(EL.header_id,EL.ORDER_NUMBER) as Bigint) = cast(INT1.ORDER_NUMBER as Bigint)\r\n/*Q3FY22 GROGU Change*/\r\nWHERE CAST(CAST(INT1.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >=CAST('$$LastExtractDate' AS TIMESTAMP(0))\r\nAND EL.ORDER_ORIGIN IN ('B2B-COMMERCE','REVCLOUD-SALESMAIN') /*REVCLOUD-SALESMAIN added for Omega Feb 23 release*/",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
