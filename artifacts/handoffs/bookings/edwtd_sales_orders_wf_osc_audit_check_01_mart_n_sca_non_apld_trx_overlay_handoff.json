      "attributes": {
        "Sql Query": "SELECT \r\nPD_BK_POS_TRANSACTION_ID_INT  ,\r\nBK_OFFER_ATTRIBUTION_ID_INT,\r\nBK_SLS_TERR_ASSIGNMENT_TYPE_CD,COUNT(*) COUNT1,sum(PD_SALES_COMMISSION_PCT) sums\r\nFROM $$SLSORDVWDB.N_POS_SCA_ADJ_CHNG_OVERLAY\r\nWHERE EP_TRX_SPLIT_SC_ID <0\r\nGROUP BY 1,2,3\r\nHAVING sums>100\r\nUNION ALL\r\nSELECT \r\nPD_SALES_ORDER_LINE_KEY  ,\r\nBK_OFFER_ATTRIBUTION_ID_INT,\r\nBK_SLS_TERR_ASSIGNMENT_TYPE_CD,COUNT(*) COUNT1,sum(PD_SALES_COMMISSION_PCT) sums\r\nFROM $$SLSORDVWDB.N_SCA_APLD_TRX_OVERLAY\r\nWHERE EP_TRX_SPLIT_SC_ID <0\r\nGROUP BY 1,2,3\r\nHAVING sums>100\r\nUNION ALL\r\nSELECT \r\nPD_AR_TRX_LINE_KEY              ,\r\nBK_OFFER_ATTRIBUTION_ID_INT,\r\nBK_SLS_TERR_ASSIGNMENT_TYPE_CD,COUNT(*) COUNT1,sum(PD_SALES_COMMISSION_PCT) sums\r\nFROM $$SLSORDVWDB.N_SCA_NON_APLD_TRX_OVERLAY\r\nWHERE EP_TRX_SPLIT_SC_ID <0\r\nGROUP BY 1,2,3\r\nHAVING sums>100\r\nUNION ALL\r\nSELECT \r\nMANUAL_TRX_KEY                              ,\r\n-9999 AS BK_OFFER_ATTRIBUTION_ID_INT,\r\nBK_SLS_TERR_ASSIGNMENT_TYPE_CD,COUNT(*) COUNT1,sum(SALES_COMMISSION_PCT) sums\r\nFROM $$SLSORDVWDB.N_SLS_CR_ASGN_REBOK_MNL_ADJ\r\nGROUP BY 1,2,3 HAVING sums>100\r\nUNION ALL\r\nSELECT \r\nPD_BK_POS_TRANSACTION_ID_INT  ,\r\nBK_OFFER_ATTRIBUTION_ID_INT,\r\nBK_SLS_TERR_ASSIGNMENT_TYPE_CD,COUNT(*) COUNT1,sum(PD_SALES_COMMISSION_PCT) sums\r\nFROM $$SLSORDVWDB.N_POS_SCA_ADJ_CHNG_OVERLAY\r\nWHERE EP_TRX_SPLIT_SC_ID >0\r\nGROUP BY 1,2,3\r\nHAVING sums>100\r\nUNION ALL\r\nSELECT \r\nPD_SALES_ORDER_LINE_KEY  ,\r\nBK_OFFER_ATTRIBUTION_ID_INT,\r\nBK_SLS_TERR_ASSIGNMENT_TYPE_CD,COUNT(*) COUNT1,sum(PD_SALES_COMMISSION_PCT) sums\r\nFROM $$SLSORDVWDB.N_SCA_APLD_TRX_OVERLAY\r\nWHERE EP_TRX_SPLIT_SC_ID >0\r\nGROUP BY 1,2,3\r\nHAVING sums>100\r\nUNION ALL\r\nSELECT \r\nPD_AR_TRX_LINE_KEY              ,\r\nBK_OFFER_ATTRIBUTION_ID_INT,\r\nBK_SLS_TERR_ASSIGNMENT_TYPE_CD,COUNT(*) COUNT1,sum(PD_SALES_COMMISSION_PCT) sums\r\nFROM $$SLSORDVWDB.N_SCA_NON_APLD_TRX_OVERLAY\r\nWHERE EP_TRX_SPLIT_SC_ID >0\r\nGROUP BY 1,2,3\r\nHAVING sums>100",
