      "attributes": {
        "Sql Query": "SELECT\r\n\tSAGP.SALES_ACCOUNT_GROUP_PARTY_KEY\r\n\t,SAGP.BK_SALES_ACCOUNT_ID_INT\r\n\t,SAGP.SALES_ACCOUNT_GROUP_START_DT\r\n\t,SAGP.SALES_ACCOUNT_GROUP_END_DT\r\n    ,SAGP.SALES_ACCOUNT_GROUP_TYPE_CD\r\n\t,SAGP.SALES_ACCOUNT_SUB_TYPE_CD\r\n\t,SAGP.SALES_ACCT_CREATED_PARTY_KEY\r\n\t,SAGP.SALES_ACCOUNT_CREATION_DT\r\n\t,NSLS.SALES_ACCOUNT_GROUP_NAME\r\n\t,NSLS.PRIMARY_CUST_ADDRESS_PARTY_KEY\r\n\t,NSLS.VERTICAL_MARKET_SEGMENT_CD\r\n\t,NSLS.VERTICAL_MARKET_SUB_SEGMENT_CD\r\n\t,SLSCV.SLS_ACCT_COVERAGE_LEVEL_INT\r\n\t,COALESCE(SLSTER.SLS_ACCT_GROUP_SALES_TERR_KEY,-999) AS SLS_ACCT_GROUP_SALES_TERR_KEY\r\n\t,SGMNT.BK_SALES_ACCT_SUB_SEGMENT_NAME\r\n\t,SGMNT.BK_SALES_ACCOUNT_SEGMENT_NAME\r\n\t,COALESCE(SAOA.SALES_REP_NUM,'-999') as SALES_REP_NUM\r\n\t,SAOA.SALES_REP_NAME\r\n\t,SAOA.SLS_ACCT_GRP_PARTY_OWNER_TYPE\r\n\t,COALESCE(SAOA.HIBERNATION_FLG,'N') AS HIBERNATION_FLG\r\n\t,COALESCE(SAOA.ORPHANED_FLG,'N') AS ORPHANED_FLG\r\n\t,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM\r\n\t,USER AS EDW_CREATE_USER\r\n\t,CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM\r\n\t,USER AS EDW_UPDATE_USER\r\n\tQUALIFY\tROW_NUMBER() OVER (\r\n\tPARTITION BY SAGP.SALES_ACCOUNT_GROUP_PARTY_KEY \r\n\tORDER BY SAGP.SALES_ACCOUNT_GROUP_START_DT DESC ) = 1\r\n\t\tFROM\r\n\t$$COMREFVWDB.N_SLS_ACCT_GROUP_SAV_PARTY_TV SAGP\r\n\tcross  JOIN\r\n\t( SELECT * FROM $$ETLVWDB.WI_DRR_PROCESS_CONTROL WHERE PROCESS_TYPE = 'FDRR') CTRL\r\n\tINNER JOIN\r\n\t$$COMREFVWDB.N_SAGRP_SAV_NSLS_CVRG_PRTY_TV NSLS\r\n\t\tON SAGP.SALES_ACCOUNT_GROUP_PARTY_KEY = NSLS.SALES_ACCOUNT_GROUP_PARTY_KEY\r\n\t\tAND NSLS.SOURCE_DELETED_FLG= 'N'\r\n\t\tAND CTRL.PROCESS_DATE BETWEEN NSLS.START_TV_DT AND NSLS.END_TV_DT\r\n\tLEFT JOIN\r\n\t$$COMREFVWDB.N_SAGRP_SAV_SLS_CVRG_PRTY_TV SLSCV \r\n\t\tON SAGP.SALES_ACCOUNT_GROUP_PARTY_KEY = SLSCV.SALES_ACCOUNT_GROUP_PARTY_KEY\r\n\t\tAND SLSCV.SOURCE_DELETED_FLG= 'N'\r\n\t\tAND CTRL.PROCESS_DATE BETWEEN SLSCV.START_TV_DT AND SLSCV.END_TV_DT\r\n\tLEFT JOIN\r\n\t$$COMREFVWDB.N_SA_GRPSVPTY_TERR_ASGNMNT_TV SLSTER \r\n\t\tON SAGP.SALES_ACCOUNT_GROUP_PARTY_KEY = SLSTER.SALES_ACCOUNT_GROUP_PARTY_KEY\r\n\t\tAND SLSTER.SOURCE_DELETED_FLG= 'N'\r\n\t\tAND CTRL.PROCESS_DATE BETWEEN SLSTER.START_TV_DT AND SLSTER.END_TV_DT\r\n\tLEFT JOIN\r\n\t$$COMREFVWDB.N_SALES_ACCT_SALES_SUB_SGMNT SGMNT \r\n\t\tON NSLS.SLS_ACCT_SALES_SUB_SEGMENT_KEY = SGMNT.SLS_ACCT_SALES_SUB_SEGMENT_KEY\r\n\tLEFT JOIN\r\n\t(\r\n\t\tSELECT\r\n\t\tSAGP.SALES_ACCOUNT_GROUP_PARTY_KEY\r\n\t\t,COALESCE(SAOA.BK_OWNER_SALES_REP_NUM,-999) AS SALES_REP_NUM\r\n\t\t,CASE \r\n\t\t\t\t\tWHEN SLS_REP.ERP_SALES_REP_TYPE = 'SALESREP' THEN SLS_REP.ERP_SALES_REP_NAME  \r\n\t\t              WHEN SLS_REP.ERP_SALES_REP_TYPE = 'TEAM' THEN SLS_REP.SALES_TERR_TEAM_NAME \r\n\t\t\t\tEND SALES_REP_NAME \r\n\t\t,SLS_REP.ERP_SALES_REP_TYPE AS SLS_ACCT_GRP_PARTY_OWNER_TYPE \r\n\t\t,COALESCE(SAOA.HIBERNATION_FLG,'N') AS HIBERNATION_FLG\r\n\t\t,CASE \r\n\t\t\t\t\tWHEN SAOA.BK_OWNER_SALES_REP_NUM IS NULL THEN 'Y' \r\n\t\t\t\t\tELSE 'N' \r\n\t\t\t\tEND ORPHANED_FLG  \r\n\t\t, RANK() OVER (\r\n\t\tPARTITION BY SAGP.SALES_ACCOUNT_GROUP_PARTY_KEY \r\n\t\tORDER BY SAOA.ASSIGNMENT_END_DT DESC ) AS RNK\r\n\t\tQUALIFY\tROW_NUMBER() OVER (\r\n\t\tPARTITION BY SAGP.SALES_ACCOUNT_GROUP_PARTY_KEY \r\n\t\tORDER BY SAOA.ASSIGNMENT_END_DT DESC  ) = 1\r\n\t\tFROM\r\n\t\t$$COMREFVWDB.N_SLS_ACCT_GROUP_SAV_PARTY_TV SAGP\r\n\t\tCROSS JOIN\r\n\t( SELECT * FROM $$ETLVWDB.WI_DRR_PROCESS_CONTROL WHERE PROCESS_TYPE = 'FDRR') CTRL\r\n\t\tLEFT JOIN\r\n\t\t$$COMREFVWDB.N_SALES_ACCT_OWNER_ASSIGNMENT SAOA  \r\n\t\t\tON SAGP.SALES_ACCOUNT_GROUP_PARTY_KEY = SAOA.SALES_ACCOUNT_GROUP_PARTY_KEY\r\n\t\t\tAND SAOA.SOURCE_DELETED_FLG = 'N' \r\n\t\t\tAND SAGP.SALES_ACCOUNT_GROUP_END_DT BETWEEN SAOA.BK_ASSIGNMENT_START_DT \r\n\t\t\tAND SAOA.ASSIGNMENT_END_DT \r\n\t\tLEFT JOIN\r\n\t\t$$COMREFVWDB.MT_ERP_SALES_REP SLS_REP\r\n\t\t\tON SAOA.BK_OWNER_SALES_REP_NUM = CAST(CAST(COALESCE(NULLIF(SLS_REP.SALES_REP_NUM,\r\n\t\t\t\t'UNKNOWN'),-999) AS INTEGER) AS VARCHAR(30))\r\n\t\tWHERE\t --CTRL.PROCESS_DATE  > SAGP.SALES_ACCOUNT_GROUP_END_DT\t\t\t--commented the condition, as it is satisfying inactive sales owners\r\n\t\t\t\tCTRL.PROCESS_DATE  < SAGP.SALES_ACCOUNT_GROUP_END_DT\t--Added for taking active sales owner\r\n\t\t\tAND SAGP.SOURCE_DELETED_FLG = 'N'\r\n\t)SAOA\r\n\t\tON SAGP.SALES_ACCOUNT_GROUP_PARTY_KEY = SAOA.SALES_ACCOUNT_GROUP_PARTY_KEY\r\n\tWHERE\tCTRL.PROCESS_DATE BETWEEN SAGP.SALES_ACCOUNT_GROUP_START_DT \r\n\t\tAND SAGP.SALES_ACCOUNT_GROUP_END_DT\r\n\t\tAND SAGP.SOURCE_DELETED_FLG= 'N'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
