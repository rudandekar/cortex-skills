      "attributes": {
        "Sql Query": "SELECT \r\nOLM_PROCESS_DT_CNTRL.FISCAL_YEAR_NUMBER_INT,\r\nOLM_PROCESS_DT_CNTRL.FISCAL_YEAR_MTH_NUMBER_INT,\r\nOLM_PROCESS_DT_CNTRL.FISCAL_MONTH_NUMBER_INT,\r\nOLM_PROCESS_DT_CNTRL.PROCESS_DATE\r\nFROM\r\n $$ETLVWDB.OLM_PROCESS_DT_CNTRL",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "UPDATE\t A\r\nFROM\t(\r\n             SELECT\t\r\n\t\t         CASE\r\n\t\t\t         WHEN\tPROCESS_DATE + 1 = FISCAL_MONTH_START_DATE \r\n                                   THEN FISCAL_MONTH_START_DATE + 1\r\n\t\t\t          ELSE\tPROCESS_DATE + 1\r\n\t\t        END\tPROCESS_DATE,\r\n\t\tCASE\r\n\t\t\tWHEN\tPROCESS_DATE + 1 = FISCAL_MONTH_START_DATE \r\nTHEN BK_FISCAL_YEAR_NUMBER_INT\r\n\t\t\tELSE\tFISCAL_YEAR_NUMBER_INT\r\n\t\tEND\tFISCAL_YEAR_NUMBER_INT,\r\n\t\tCASE\r\n\t\t\tWHEN\tPROCESS_DATE + 1 = FISCAL_MONTH_START_DATE \r\nTHEN (BK_FISCAL_YEAR_NUMBER_INT*100)+BK_FISCAL_MONTH_NUMBER_INT\r\n\t\t\tELSE\tFISCAL_YEAR_MTH_NUMBER_INT\r\n\t\tEND\tFISCAL_YEAR_MTH_NUMBER_INT,\r\n\t\tCASE\r\n\t\t\tWHEN\tPROCESS_DATE + 1 = FISCAL_MONTH_START_DATE \r\nTHEN BK_FISCAL_MONTH_NUMBER_INT\r\n\t\t\tELSE\tFISCAL_MONTH_NUMBER_INT\r\n\t\tEND\tFISCAL_MONTH_NUMBER_INT\r\n\t\r\nFROM\t\r\n(\r\nSELECT\tPD.FISCAL_YEAR_NUMBER_INT,\r\nPD.FISCAL_YEAR_MTH_NUMBER_INT,\r\nPD.FISCAL_MONTH_NUMBER_INT,\r\nPD.PROCESS_DATE,\r\nNFM.FISCAL_MONTH_START_DATE,\r\nNFM.FISCAL_MONTH_END_DATE,\r\nNFM.BK_FISCAL_MONTH_NUMBER_INT,\r\nNFM.BK_FISCAL_YEAR_NUMBER_INT\r\nFROM\t$$COMREFVWDB.N_FISCAL_MONTH NFM,\r\n$$ETLVWDB.OLM_PROCESS_DT_CNTRL PD\r\nWHERE\tPROCESS_DATE + INTERVAL '1' DAY BETWEEN  FISCAL_MONTH_START_DATE\r\n\tAND\tFISCAL_MONTH_END_DATE) TEMP) B,\r\n$$ETLVWDB.OLM_PROCESS_DT_CNTRL  A\r\n\r\nSET PROCESS_DATE  =B.PROCESS_DATE,\r\nFISCAL_YEAR_NUMBER_INT=B.FISCAL_YEAR_NUMBER_INT,\r\nFISCAL_YEAR_MTH_NUMBER_INT=B.FISCAL_YEAR_MTH_NUMBER_INT,\r\nFISCAL_MONTH_NUMBER_INT=B.FISCAL_MONTH_NUMBER_INT,\r\nEDW_UPDATE_DATETIME   = CURRENT_TIMESTAMP(0) ;",
        "Post SQL": "COLLECT STATISTICS ON $$CTLDB.OLM_PROCESS_DT_CNTRL COLUMN \r\n(FISCAL_YEAR_NUMBER_INT,FISCAL_YEAR_MTH_NUMBER_INT,FISCAL_MONTH_NUMBER_INT,PROCESS_DATE);",
