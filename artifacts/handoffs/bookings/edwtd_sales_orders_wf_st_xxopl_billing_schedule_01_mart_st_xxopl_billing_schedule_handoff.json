        "Sql Query": "SELECT\r\n ST.BILL_SCHEDULE_NUMBER\r\n,ST.BILL_SCHEDULE_ID\r\n,ST.BILL_PERIOD_END_DATE \r\n,ST.BILL_PERIOD_START_DATE \r\n,ST.BILL_STATUS\r\n,ST.CURRENCY_CODE\r\n,ST.BILL_AMOUNT\r\n,ST.BILL_RELEASE_DATE \r\n,ST.BILL_QUANTITY\r\n,ST.INVOICE_AMOUNT\r\n,ST.INVOICE_DATE \r\n,ST.INVOICE_NUMBER\r\n,ST.HEADER_ID\r\n,ST.LINE_ID\r\n,ST.LINE_REF_NUMBER\r\n,ST.ORDER_ORIGIN\r\n,ST.RECORD_OFFSET\r\n,ST.EDW_CREATE_DTM \r\nFROM  $$ETLVWDB.ST_SI_XXOPL_BILLING_SCHEDULE ST\r\nWHERE  ST.EDW_CREATE_DTM  > '$$LastExtractDate' \r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY ST.LINE_ID, ST.BILL_SCHEDULE_ID, ST.BILL_SCHEDULE_NUMBER ORDER BY ST.EDW_CREATE_DTM DESC) =1",
