      "attributes": {
        "Sql Query": "SELECT \r\n SM.RESOURCE_ASSIGNMENT_KEY\r\n,RES.BK_RESOURCE_TYPE \r\n,RES.BK_AS_QUOTE_NUM\r\n,RES.BK_AS_QUOTE_MILESTONE_NUM_INT\r\n,RES.BK_AS_QUOTE_MILESTONE_TASK_NUM\r\n,RES.SK_TASK_RESOURCE_ID_INT\r\n,RES.LUMP_SUM_USD_AMT\r\n,RES.SOURCE_DELETED_FLG\r\n,RES.RU_NUM_OF_NIGHTS_CNT\r\n,RES.RU_NUM_OF_TRIPS_CNT\r\n,RES.RU_TRAVEL_HOURS_CNT\r\n,RES.RU_NON_LABOR_USD_COST\r\n,RES.RU_WORK_HOURS_CNT\r\n,RES.RU_JOB_ROLE_CD \r\n,RES.RU_DELIVERY_GROUP_NAME\r\n,RES.RU_PARTNER_NAME\r\n,RES.RU_THIRD_PARTY_NAME\r\n,CURRENT_TIMESTAMP(0) EDW_CREATE_DTM\r\n,USER EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0) EDW_UPDATE_DTM\r\n,USER EDW_UPDATE_USER\r\n,RES.RESOURCE_USD_COST\r\n,RES.TRAVEL_AND_EXPENSE_USD_COST\r\n,RES.SS_CD\r\n,RES.ONSITE_HRS_CNT\r\n,RES.REMOTE_HRS_CNT\r\n,'I' AS ACTION_CODE\r\n,CASE WHEN NASQRES.RESOURCE_ASSIGNMENT_KEY IS NULL \r\n      THEN 'I' \r\n      ELSE 'U' \r\n END AS DML_TYPE\r\nFROM $$STGDB.ST_AS_QT_RSRC_TYP_MS_TSK_ASGMT_HDP RES\r\nINNER JOIN $$ETLVWDB.SM_AS_QT_RSRC_TYP_MS_TSK_ASGMT SM\r\nON SM.SK_TASK_RESOURCE_ID_INT = RES.SK_TASK_RESOURCE_ID_INT\r\nAND SM.BK_SS_CD = RES.SS_CD\r\nLEFT JOIN $$SERVICEVWDB.N_AS_QT_RSRC_TYP_MS_TSK_ASGMT NASQRES\r\nON RES.RESOURCE_ASSIGNMENT_KEY = NASQRES.RESOURCE_ASSIGNMENT_KEY\r\nAND  RES.SS_CD = NASQRES.BK_SS_CD",
        "User Defined Join": "",
