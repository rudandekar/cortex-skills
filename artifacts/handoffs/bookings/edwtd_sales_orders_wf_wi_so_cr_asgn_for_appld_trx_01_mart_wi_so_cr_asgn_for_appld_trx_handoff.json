      "attributes": {
        "Sql Query": "SELECT\r\n'N' SOURCE_DELETED_FLG,\r\nAPPLD.HEADER_SEQ_ID HEADER_SEQ_ID,\r\nAPPLD.GLOBAL_NAME GLOBAL_NAME,\r\nAPPLD.SALESREP_ID SALESREP_ID,\r\nAPPLD.TERRITORY_ID TERRITORY_ID,\r\nAPPLD.SALES_CREDIT_TYPE_ID SALES_CREDIT_TYPE_ID,\r\nAPPLD.SOURCE_HEADER_ID SOURCE_HEADER_ID,\r\nAPPLD.SPLIT_PERCENT SPLIT_PERCENT,\r\nAPPLD.LAST_UPDATE_DATE LAST_UPDATE_DATE,\r\nAPPLD.CREATION_DATE CREATION_DATE\r\nFROM \r\n$$STGDB.ST_OM_CSM_HDR_SC_APPLD APPLD\r\nUNION ALL\r\nSELECT\r\n'Y' SOURCE_DELETED_FLG,\r\nDELS.HEADER_SEQ_ID HEADER_SEQ_ID,\r\nDELS.GLOBAL_NAME GLOBAL_NAME,\r\nDELS.SALESREP_ID SALESREP_ID,\r\nDELS.TERRITORY_ID TERRITORY_ID,\r\nDELS.SALES_CREDIT_TYPE_ID SALES_CREDIT_TYPE_ID,\r\nDELS.SOURCE_HEADER_ID SOURCE_HEADER_ID,\r\nDELS.SPLIT_PERCENT,\r\nDELS.GES_DELETE_DATE GES_DELETE_DATE,\r\nDELS.CREATION_DATE CREATION_DATE\r\nFROM \r\n$$STGDB.ST_OM_CSM_HDR_SC_APPLD_DEL DELS\r\nWHERE\r\nNOT EXISTS\r\n(SELECT APPLD.HEADER_SEQ_ID, APPLD.GLOBAL_NAME \r\nFROM $$STGDB.ST_OM_CSM_HDR_SC_APPLD APPLD\r\nWHERE\r\nAPPLD.HEADER_SEQ_ID=DELS.HEADER_SEQ_ID\r\nAND\r\nAPPLD.GLOBAL_NAME=DELS.GLOBAL_NAME)\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY HEADER_SEQ_ID,GLOBAL_NAME,GES_DELETE_DATE ORDER BY GES_DELETE_DATE DESC)=1",
        "User Defined Join": "",
