      "attributes": {
        "Sql Query": "SELECT \r\nSAVM.SALES_ORDER_LINE_KEY\r\n,SAV.SALES_ACCOUNT_GROUP_PARTY_KEY AS RESTATED_SAVM_KEY\r\n,SAV.BK_SALES_ACCOUNT_ID_INT\r\n,-999 AS AS_WAS_SAVM_KEY\r\n,SAV.SALES_ACCOUNT_GROUP_NAME\r\n,NSSNCPT.SALES_ACCOUNT_GROUP_NAME AS AS_WAS_SAV_NAME\r\n,'3500-01-01 00:00:00' AS DV_LAST_UPDATED_DT\r\n,SAVM.DV_END_CUST_PARTY_KEY\r\n,SAVM.DV_END_CUST_OWNERSHIP_SPLT_PCT\r\n,SAVM.BK_SA_MEMBER_ID_INT\r\n,NSOL.BK_SO_NUMBER_INT\r\n,RSH.SALES_TERRITORY_KEY\r\n,RSH.SALES_TERRITORY_DESCR\r\n,SAVM.DV_SAV_REASON_DESCR           \r\n,SAVM.DV_END_CUST_REASON_DESCR            \r\n,SAVM.BOOKINGS_MEASURE_KEY\r\n,SAVM.SALES_REP_NUM\r\nFROM $$SLSORDVWDB.MT_SALES_ACCOUNT_RSTD_SLS_TRX SAVM\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE NSOL\r\nON NSOL.SALES_ORDER_LINE_KEY = SAVM.SALES_ORDER_LINE_KEY\r\nINNER JOIN $$COMREFVWDB.MT_SLS_ACCT_GROUP_SAV_PARTY SAV\r\nON SAV.SALES_ACCOUNT_GROUP_PARTY_KEY= SAVM.SALES_ACCOUNT_GROUP_PARTY_KEY\r\nAND SAV.SALES_ACCOUNT_GROUP_TYPE_CD IN ('NAMED_ACCOUNT','GEO_ACCOUNT') \r\nLEFT JOIN (SELECT SALES_ACCOUNT_GROUP_PARTY_KEY,SALES_ACCOUNT_GROUP_NAME FROM $$COMREFVWDB.N_SAGRP_SAV_NSLS_CVRG_PRTY_TV WHERE END_TV_DT = '3500-01-01' GROUP BY 1,2) NSSNCPT\r\nON NSSNCPT.SALES_ACCOUNT_GROUP_PARTY_KEY = SAVM.SALES_ACCOUNT_GROUP_PARTY_KEY\r\nLEFT OUTER JOIN $$COMREFVWDB.R_SALES_HIERARCHY RSH\r\nON SAV.SLS_ACCT_GROUP_SALES_TERR_KEY = RSH.SALES_TERRITORY_KEY",
        "User Defined Join": "",
