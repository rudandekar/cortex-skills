      "attributes": {
        "Sql Query": "SELECT\r\n\t WI.BOOKINGS_MEASURE_KEY ,      \r\n\t WI.BOOKINGS_PROCESS_DATE ,      \r\n\t WI.BKGS_MEASURE_TRANS_TYPE_CODE ,\r\n\t WI.DV_END_CUST_PARTY_KEY ,\r\n\t -999 AS NEW_SA_MEMBER_ID_INT ,\r\n\t -999 AS LINK_CUSTOMER_PARTY_KEY ,\r\n\t -999 AS SALES_ACCOUNT_GROUP_PARTY_KEY ,\r\n\t WI.REASON_DESC AS REASON_DESC_END_CUST,\r\n\t '15 - WW DIST_RETAINED BKGS TERRITORY' AS REASON_DESCR ,\r\n\t 100 AS SALES_CREDIT_SPLIT_PCT,\t \r\n\t WI.SALES_TERRITORY_KEY,\r\n\t WI.SALES_REP_NUMBER,\r\n\t -999 AS EP_OTM_TERRITORY_ID_INT,\r\n\t -999 AS FIN_ADJ_KEY,\r\n\t 'Engine' AS PROCESS_TYPE,\r\n\t 'N' AS NODE_ENRICH_FLAG,\r\n\t NULL AS NODE_ENRICH_REASON\r\nFROM $$STGDB.WI_DRR_BOOKINGS_PARTY_ENRICH WI \r\n WHERE 1=2\r\n\t AND WI.RULE_PROCESS_FLAG = 'N'\r\n\t AND WI.L1_SALES_TERRITORY_NAME_CODE = 'WW Distribution'  \r\n QUALIFY ROW_NUMBER() OVER( PARTITION BY BOOKINGS_MEASURE_KEY, BKGS_MEASURE_TRANS_TYPE_CODE, BOOKINGS_PROCESS_DATE ORDER BY REASON_DESC ) = 1",
