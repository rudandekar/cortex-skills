      "attributes": {
        "Sql Query": "SELECT \r\nSSO.SALES_ORDER_KEY ,\r\nEOXOH.HEADER_ID ,\r\nEOXOH.GLOBAL_NAME, \r\nCASE WHEN SCXELN.XXCCP_HEADER_ID IS NOT NULL THEN 'N'  ELSE 'Y' END AS NO_TOUCH_FLAG, \r\nEOXOH.QUOTE_NUMBER ,\r\nUSER,\r\nEOXOH.CREATE_DATETIME, \r\nUSER, \r\nCURRENT_TIMESTAMP(0) \r\nFROM \r\n$$ETLONLYDB.EL_OM_XXCCP_OE_ORDER_HEADER EOXOH\r\nLEFT OUTER  JOIN \r\n$$STGDB.ST_CG1_XXCCP_ERROR_LOG_NT SCXELN\r\nON \r\nEOXOH.XXCCP_HEADER_ID=SCXELN.XXCCP_HEADER_ID AND\r\nEOXOH.GLOBAL_NAME = SCXELN.GLOBAL_NAME \r\nINNER JOIN \r\n$$ETLVWDB.SM_SALES_ORDER SSO\r\nON\r\nEOXOH.HEADER_ID = SSO.SK_SALES_ORDER_HEADER_ID_INT\r\nAND\r\nSSO.SS_CODE = 'CG'\r\nINNER JOIN \r\n$$SLSORDVWDB.N_SALES_ORDER_V1_TV NSOT\r\nON \r\nSSO.SALES_ORDER_KEY = NSOT.SALES_ORDER_KEY          \r\nWHERE \r\nEOXOH.OPERATION='CREATE' \r\nAND\r\nSCXELN.OPERATION_CODE = 'CREATE'\r\n--AND  NSOT.CISCO_BOOKED_RESULT_CD = 'BOOKED'\r\nAND\r\n                SCXELN.FOR_CSE_INTEGRATION = 'Y'\r\nAND \r\n                SCXELN.ERROR_STATUS = 'CSE_COMPLETED'\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY EOXOH.HEADER_ID,EOXOH.GLOBAL_NAME ORDER BY SCXELN.ERROR_DATE DESC)=1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
