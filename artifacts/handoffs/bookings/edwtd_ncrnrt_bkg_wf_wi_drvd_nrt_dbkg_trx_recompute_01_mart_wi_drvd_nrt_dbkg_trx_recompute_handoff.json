      "attributes": {
        "Sql Query": "SELECT \r\nWDNDTR_CURR_MON.DRVD_NCR_BKG_TRX_KEY,\r\nWDNDTR_CURR_MON.SALES_ORDER_LINE_KEY,\r\nWDNDTR_CURR_MON.SALES_ORDER_KEY,\r\nWDNDTR_CURR_MON.PROCESS_DATE,\r\nWDNDTR_CURR_MON.DD_ITEM_TYPE_CODE_FLAG,\r\nWDNDTR_CURR_MON.DD_RMA_FLAG,\r\nWDNDTR_CURR_MON.DD_INTERNATIONAL_DEMO_FLAG,\r\nWDNDTR_CURR_MON.DD_REPLACEMENT_DEMO_FLAG,\r\nWDNDTR_CURR_MON.DD_REVENUE_FLAG,\r\nWDNDTR_CURR_MON.DD_OVERLAY_FLAG,\r\nWDNDTR_CURR_MON.DD_SALESREP_FLAG,\r\nWDNDTR_CURR_MON.DD_IC_REVENUE_FLAG,\r\nWDNDTR_CURR_MON.DD_CHARGES_FLAG,\r\nWDNDTR_CURR_MON.DD_MISC_FLAG,\r\nWDNDTR_CURR_MON.DD_ACQUISITION_FLAG,\r\nWDNDTR_CURR_MON.DD_SERVICE_FLAG,\r\nWDNDTR_CURR_MON.DD_REV_REC_FLAG,\r\nWDNDTR_CURR_MON.ORIG_REV_REC_FLAG,\r\nCURRENT_TIMESTAMP(0) EDW_CREATEDATETIME,\r\nUSER EDW_CREATE_USER,\r\nWDNDTR_CURR_MON.DV_ATTRIBUTION_CD                     ,             \r\nWDNDTR_CURR_MON.SK_OFFER_ATTRIBUTION_ID_INT         ,\r\nWDNDTR_CURR_MON.DV_SALES_ORDER_LINE_KEY              ,\r\nWDNDTR_CURR_MON.DV_PRODUCT_KEY                       \r\nFROM $$NRTSTGDB.WI_DRVD_NRT_DEBKG_TX_RECMP_INT  WDNDTR_ORIG,\r\n(SELECT \r\n\tWDNDTR.DRVD_NCR_BKG_TRX_KEY \t\t\tDRVD_NCR_BKG_TRX_KEY,\r\n\tWDNDTR.SALES_ORDER_LINE_KEY \t\t\tSALES_ORDER_LINE_KEY,\r\n\tWDNDTR.SALES_ORDER_KEY \t\t\t\tSALES_ORDER_KEY,\r\n      WDNDTR.PROCESS_DATE                       PROCESS_DATE,\r\n\tWDNDTR.DD_ITEM_TYPE_CODE_FLAG \t\t\tDD_ITEM_TYPE_CODE_FLAG,\r\n\tWDNDTR.DD_RMA_FLAG \t\t\t\tDD_RMA_FLAG,\r\n\tWDNDTR.DD_INTERNATIONAL_DEMO_FLAG \t\tDD_INTERNATIONAL_DEMO_FLAG,\r\n\tWDNDTR.DD_REPLACEMENT_DEMO_FLAG \t\tDD_REPLACEMENT_DEMO_FLAG,\r\n\tWDNDTR.DD_REVENUE_FLAG \t\t\t\t\tDD_REVENUE_FLAG,\r\n\tWDNDTR.DD_OVERLAY_FLAG \t\t\t\t\tDD_OVERLAY_FLAG,\r\n\tWDNDTR.DD_SALESREP_FLAG \t\t\t\tDD_SALESREP_FLAG,\r\n\tWDNDTR.DD_IC_REVENUE_FLAG \t\t\t\tDD_IC_REVENUE_FLAG,\r\n\tWDNDTR.DD_CHARGES_FLAG \t\t\t\t\tDD_CHARGES_FLAG,\r\n\tWDNDTR.DD_MISC_FLAG \t\t\t\t\tDD_MISC_FLAG,\r\n\tWDNDTR.DD_ACQUISITION_FLAG \t\t\t\tDD_ACQUISITION_FLAG,\r\n\tWDNDTR.DD_SERVICE_FLAG \t\t\t\t\tDD_SERVICE_FLAG,\t\r\n\tWDNDTR.ORIG_REV_REC_FLAG \t\t\t\tORIG_REV_REC_FLAG,\r\n\tCASE WHEN \r\n\tWDNDTR.DD_ITEM_TYPE_CODE_FLAG= 'Y' OR \r\n\tWDNDTR.DD_RMA_FLAG = 'Y'  OR \r\n\tWDNDTR.DD_INTERNATIONAL_DEMO_FLAG = 'Y' OR\r\n\tWDNDTR.DD_REPLACEMENT_DEMO_FLAG = 'Y' OR \r\n\tWDNDTR.DD_REVENUE_FLAG = 'N' OR \r\n\tWDNDTR.DD_OVERLAY_FLAG='Y' OR\r\n\t WDNDTR.DD_SALESREP_FLAG ='Y' \tOR \r\n\tWDNDTR.DD_IC_REVENUE_FLAG='N' OR \r\n\tWDNDTR.DD_CHARGES_FLAG='Y' OR \r\n\tWDNDTR.DD_MISC_FLAG='Y' OR \r\n\tWDNDTR.DD_ACQUISITION_FLAG='Y' OR \r\n\tNP.DIVESTITURE_TYPE_CD <> 'UNKNOWN' OR\r\n\t( NP.GOODS_OR_SERVICE_TYPE = 'GOODS' AND NPF.BK_BUSINESS_UNIT_ID = 'CDBU' AND ELC.ENABLE_FLAG = 'Y' ) THEN 'N' \r\n\tELSE 'Y' END DD_REV_REC_FLAG,\r\n\tWDNDTR.DV_ATTRIBUTION_CD,             \r\n    WDNDTR.SK_OFFER_ATTRIBUTION_ID_INT,\r\n    WDNDTR.DV_SALES_ORDER_LINE_KEY,\r\n    WDNDTR.DV_PRODUCT_KEY                       \r\nFROM $$NRTSTGDB.WI_DRVD_NRT_DEBKG_TX_RECMP_INT WDNDTR\r\n\r\nLEFT JOIN $$COMREFVWDB.N_PRODUCT NP\r\nON NP.ITEM_KEY = WDNDTR.DV_PRODUCT_KEY \r\n\r\nLEFT JOIN $$COMREFVWDB.N_PRODUCT_FAMILY NPF      \r\nON NP.RU_BK_PRODUCT_FAMILY_ID = NPF.BK_PRODUCT_FAMILY_ID\r\n\r\nLEFT JOIN $$ETLVWDB.EL_CDBU ELC  /*NP, NPF and ELC Joins added as part of Q2FY16 - CDBU - SA (Scientific Atlanta) Changes for CORP BOOKINGS FLAG, REVENUE RECOGNITION FLAG and NET SPREAD FLAG Columns */\r\nON NPF.BK_BUSINESS_UNIT_ID = ELC.BK_BUSINESS_UNIT_ID\r\nAND NP.GOODS_OR_SERVICE_TYPE = ELC.GOODS_OR_SERVICE_TYPE ) WDNDTR_CURR_MON\r\n\r\nWHERE WDNDTR_ORIG.DRVD_NCR_BKG_TRX_KEY=WDNDTR_CURR_MON.DRVD_NCR_BKG_TRX_KEY AND \r\nWDNDTR_ORIG.ORIG_REV_REC_FLAG<>WDNDTR_CURR_MON.DD_REV_REC_FLAG",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
  ],
