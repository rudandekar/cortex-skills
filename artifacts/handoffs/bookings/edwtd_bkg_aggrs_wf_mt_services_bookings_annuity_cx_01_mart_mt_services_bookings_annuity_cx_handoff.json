      "attributes": {
        "Sql Query": "SEL\r\nANU.BOOKINGS_MEASURE_KEY\r\n,ANU.BOOKINGS_PROCESS_DT\r\n,ANU.BKGS_MEASURE_TRANS_TYPE_CD\r\n,ANU.SALES_TERRITORY_KEY\r\n,SALES_REP_NUM\r\n,ANU.GOODS_PRODUCT_KEY\r\n,ANU.DV_FISCAL_YR_MNTH_WEEK_NUM_INT\r\n,TRUE_UP_FLG\r\n,FISCAL_WEEK_NAME\r\n,FISCAL_YEAR_MONTH_INT\r\n,ANNUITY_AMT AS ANNUITY_USD_AMT\r\n,DV_MY_NET_AMT AS DV_MY_NET_USD_AMT\r\n,DV_CA_SERVICE_BOOOKINGS_AMT AS DV_CA_SERVICE_BOOOKINGS_USD_AMT\r\n,DV_ANNUAL_NET_AMT AS DV_ANNUAL_NET_USD_AMT\r\n,DV_ANNUALIZED_FLG\r\n,BOOKING_TYPE_CD\r\n,RU_SERVICE_CONTRACT_START_DTM\r\n,RU_SERVICE_CONTRACT_END_DTM\r\n,ANU.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n,ANU.DV_TSS_ALCTN_MTHD_TYPE_ID_INT\r\n,ANU.SUMMARY_QUOTE_FLG\r\n,ANU.DV_CX_PRODUCT AS DV_CX_PRODUCT_NAME\r\n,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM\r\n,CURRENT_USER AS EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM\r\n,CURRENT_USER AS EDW_UPDATE_USER\r\nFROM $$SLSORDVWDB.MT_SERVICES_BOOKINGS_ANNUITY ANU\r\nINNER JOIN $$SLSORDVWDB.MT_SERVICES_BOOKINGS_CX CX\r\nON ANU.BOOKINGS_MEASURE_KEY =CX.BOOKINGS_MEASURE_KEY\r\nAND ANU.BOOKINGS_PROCESS_DT = CX.BOOKINGS_PROCESS_DT\r\nAND ANU.BKGS_MEASURE_TRANS_TYPE_CD = CX.BKGS_MEASURE_TRANS_TYPE_CD\r\nAND ANU.SALES_TERRITORY_KEY = CX.SALES_TERRITORY_KEY\r\nAND ANU.SALES_REP_NUM = CX.SALES_REP_NUMBER\r\nAND ANU.GOODS_PRODUCT_KEY = CX.GOODS_PRODUCT_KEY\r\nWHERE CX.DV_FISCAL_YEAR_MTH_NUMBER_INT >= (SELECT FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_SRVC_BKGS_ANNUITY_MTH_CTRL)\r\nAND ANU.DV_FISCAL_YEAR_MTH_NUMBER_INT >= (SELECT FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_SRVC_BKGS_ANNUITY_MTH_CTRL)",
