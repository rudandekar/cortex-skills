      "attributes": {
        "Sql Query": "SELECT\r\nCOALESCE(SM_CG.SALES_ORDER_LINE_KEY,-999) COVERED_PRODUCT_SOL_KEY, \r\nCOALESCE(SM_OPL.SALES_ORDER_LINE_KEY,-999) SERVICE_CONTRACT_SOL_KEY,\r\nCURRENT_USER EDW_CREATE_USER,\r\nCURRENT_USER EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DATETIME,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DATETIME,\r\n'I' ACTION_CODE,\r\nCASE WHEN (NCST.SERVICE_CONTRACT_SOL_KEY IS NOT NULL AND NCST.COVERED_PRODUCT_SOL_KEY IS NOT NULL) THEN 'U'\r\nELSE 'I'\r\nEND  AS DML_TYPE\r\nFROM \r\n$$STGDB.ST_LINKED_SOL_NOS ST\r\nJOIN\r\n$$ETLVWDB.SM_SALES_ORDER_LINE SM_OPL\r\nON \r\n(\r\nST.LINE_ID=SM_OPL.SK_OPL_LINE_ID_INT\r\nand SM_OPL.SS_CODE='OPL'\r\n)\r\nJOIN\r\n$$ETLVWDB.SM_SALES_ORDER_LINE SM_CG\r\nON\r\n(\r\nST.LINKED_SO_LN_NUMS=CAST(SM_CG.SK_SO_LINE_ID_INT AS VARCHAR(500))\r\nAND SM_CG.SS_CODE='CG'\r\n)\r\nLEFT JOIN\r\n$$SLSORDVWDB.N_CNTRCT_SOL_TO_COVRD_PRDCT_SOL NCST\r\nON NCST.SERVICE_CONTRACT_SOL_KEY=SM_OPL.SALES_ORDER_LINE_KEY\r\nAND NCST.COVERED_PRODUCT_SOL_KEY=SM_CG.SALES_ORDER_LINE_KEY",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
