      "attributes": {
        "Sql Query": "SELECT\r\n BOOKINGS_MEASURE_KEY ,         \r\n BOOKINGS_PROCESS_DATE ,        \r\n BKGS_MEASURE_TRANS_TYPE_CODE  ,\r\n DV_END_CUST_PARTY_KEY         ,\r\n NEW_SA_MEMBER_ID_INT          ,\r\n LINK_CUSTOMER_PARTY_KEY       ,\r\n SALES_ACCOUNT_GROUP_PARTY_KEY ,\r\n REASON_DESC_END_CUST,\r\n REASON_DESCR,\r\n SALES_CREDIT_SPLIT_PCT  ,\r\n /*ADDED THE BELOW JOIN AS PART OF APRIL QWN*/\r\n  SLS_ACCT_GROUP_SALES_TERR_KEY,\r\n SALES_REP_NUM ,\r\nEP_OTM_TERRITORY_ID_INT,\r\nFIN_ADJ_KEY,\r\nPROCESS_TYPE,\r\n'N' AS NODE_ENRICH_FLAG,\r\nCAST(NULL AS VARCHAR(100)) AS NODE_ENRICH_REASON\r\n FROM $$STGDB.WI_DRR_NAMED_ACCOUNT\r\n WHERE (\r\n BOOKINGS_MEASURE_KEY ,         \r\n BOOKINGS_PROCESS_DATE ,        \r\n BKGS_MEASURE_TRANS_TYPE_CODE  ) IN \r\n (SELECT \r\n BOOKINGS_MEASURE_KEY ,         \r\n BOOKINGS_PROCESS_DATE ,        \r\n BKGS_MEASURE_TRANS_TYPE_CODE \r\n FROM $$STGDB.WI_DRR_NAMED_ACCOUNT\r\n WHERE NA_PROCESSED_FLG='N' \r\n /*AND (BOOKINGS_MEASURE_KEY,BOOKINGS_PROCESS_DATE,BKGS_MEASURE_TRANS_TYPE_CODE) NOT IN\r\n (SELECT BOOKINGS_MEASURE_KEY,BOOKINGS_PROCESS_DATE,BKGS_MEASURE_TRANS_TYPE_CODE FROM $$STGDB.WI_DRR_SALES_ACNT_MEASURE_FNL)*/\r\n GROUP BY 1,2,3\r\n HAVING ROUND(SUM(SALES_CREDIT_SPLIT_PCT))<100)\r\n \r\n UNION ALL\r\n \r\n SELECT\r\n WI_DRR.BOOKINGS_MEASURE_KEY ,         \r\n WI_DRR.BOOKINGS_PROCESS_DATE ,        \r\n WI_DRR.BKGS_MEASURE_TRANS_TYPE_CODE  ,\r\n WI_DRR.DV_END_CUST_PARTY_KEY         , /*Modified Here As part of SAR CR*/\r\n -999 AS NEW_SA_MEMBER_ID_INT          ,\r\n -999 AS LINK_CUSTOMER_PARTY_KEY       ,\r\n -999 AS SALES_ACCOUNT_GROUP_PARTY_KEY ,\r\n WI_DRR.REASON_DESC_END_CUST,    /*Modified Here As part of SAR CR*/\r\n ENRICH_SAV.REASON_DESCR AS REASON_DESCR,   \r\n (100-SPLIT_LOGIC.DV_SPLIT_PERCENT  ) AS   SALES_CREDIT_SPLIT_PCT ,\r\n   SLS_ACCT_GROUP_SALES_TERR_KEY,\r\n SALES_REP_NUM ,\r\nEP_OTM_TERRITORY_ID_INT,\r\nWI_DRR.FIN_ADJ_KEY,\r\nWI_DRR.PROCESS_TYPE,\r\n'Y' AS NODE_ENRICH_FLAG,\r\nCAST(NULL AS VARCHAR(100)) AS NODE_ENRICH_REASON\r\n  FROM \r\n /*Modified Here As part of SAR CR*/\r\n (SELECT\r\n BOOKINGS_MEASURE_KEY ,         \r\n BOOKINGS_PROCESS_DATE ,        \r\n BKGS_MEASURE_TRANS_TYPE_CODE,\r\n DV_END_CUST_PARTY_KEY,\r\n SLS_ACCT_GROUP_SALES_TERR_KEY,\r\n SALES_REP_NUM ,\r\n REASON_DESC_END_CUST,\r\nEP_OTM_TERRITORY_ID_INT,\r\nFIN_ADJ_KEY,\r\nPROCESS_TYPE\r\n FROM\r\n $$STGDB.WI_DRR_NAMED_ACCOUNT \r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY BOOKINGS_MEASURE_KEY,BOOKINGS_PROCESS_DATE,BKGS_MEASURE_TRANS_TYPE_CODE ORDER BY  DV_END_CUST_PARTY_KEY DESC) = 1\r\n ) WI_DRR    \r\n /*Modified Here As part of SAR CR*/\r\n INNER JOIN \r\n  (SELECT \r\n BOOKINGS_MEASURE_KEY ,         \r\n BOOKINGS_PROCESS_DATE ,        \r\n BKGS_MEASURE_TRANS_TYPE_CODE,\r\n SUM(SALES_CREDIT_SPLIT_PCT) AS DV_SPLIT_PERCENT\r\n FROM $$STGDB.WI_DRR_NAMED_ACCOUNT\r\n WHERE NA_PROCESSED_FLG='N' \r\n /*AND (BOOKINGS_MEASURE_KEY,BOOKINGS_PROCESS_DATE,BKGS_MEASURE_TRANS_TYPE_CODE) NOT IN\r\n (SELECT BOOKINGS_MEASURE_KEY,BOOKINGS_PROCESS_DATE,BKGS_MEASURE_TRANS_TYPE_CODE FROM $$STGDB.WI_DRR_SALES_ACNT_MEASURE_FNL)*/\r\n GROUP BY 1,2,3\r\n HAVING ROUND(SUM(SALES_CREDIT_SPLIT_PCT) )<100\r\n )SPLIT_LOGIC\r\n ON SPLIT_LOGIC.BOOKINGS_MEASURE_KEY=WI_DRR.BOOKINGS_MEASURE_KEY\r\n AND SPLIT_LOGIC.BOOKINGS_PROCESS_DATE=WI_DRR.BOOKINGS_PROCESS_DATE\r\n AND SPLIT_LOGIC.BKGS_MEASURE_TRANS_TYPE_CODE=WI_DRR.BKGS_MEASURE_TRANS_TYPE_CODE\r\n INNER JOIN $$SLSORDVWDB.N_DYN_RESTMT_ENRICH_REASON ENRICH_SAV\r\n ON ENRICH_SAV.BK_REASON_CD IN ('DEFAULT')\r\n \r\n UNION ALL\r\n \r\n SELECT\r\n BOOKINGS_MEASURE_KEY ,         \r\n BOOKINGS_PROCESS_DATE ,        \r\n BKGS_MEASURE_TRANS_TYPE_CODE  ,\r\n DV_END_CUST_PARTY_KEY         ,\r\n NEW_SA_MEMBER_ID_INT          ,\r\n LINK_CUSTOMER_PARTY_KEY       ,\r\n OLD_SALES_ACCNT_GRP_PARTY_KEY ,\r\n REASON_DESC_END_CUST,\r\n REASON_DESCR,\r\n SALES_CREDIT_SPLIT_PCT     ,\r\n  SLS_ACCT_GROUP_SALES_TERR_KEY,\r\n SALES_REP_NUM  ,\r\nEP_OTM_TERRITORY_ID_INT,\r\nFIN_ADJ_KEY,\r\nPROCESS_TYPE,\r\n'N' AS NODE_ENRICH_FLAG,\r\nCAST(NULL AS VARCHAR(100)) AS NODE_ENRICH_REASON\r\n FROM $$STGDB.WI_DRR_NAMED_ACC_AS_SAV\r\n WHERE (\r\n BOOKINGS_MEASURE_KEY ,         \r\n BOOKINGS_PROCESS_DATE ,        \r\n BKGS_MEASURE_TRANS_TYPE_CODE  ) IN \r\n (SELECT \r\n BOOKINGS_MEASURE_KEY ,         \r\n BOOKINGS_PROCESS_DATE ,        \r\n BKGS_MEASURE_TRANS_TYPE_CODE \r\n FROM $$STGDB.WI_DRR_NAMED_ACC_AS_SAV\r\n WHERE (BOOKINGS_MEASURE_KEY,BOOKINGS_PROCESS_DATE,BKGS_MEASURE_TRANS_TYPE_CODE) NOT IN\r\n (SELECT BOOKINGS_MEASURE_KEY,BOOKINGS_PROCESS_DATE,BKGS_MEASURE_TRANS_TYPE_CODE FROM $$STGDB.$$WI_DRR_SALES_ACNT_MEASURE_FNL)\r\n GROUP BY 1,2,3\r\n HAVING ROUND(SUM(SALES_CREDIT_SPLIT_PCT))<100)\r\n \r\n UNION ALL\r\n \r\n SELECT\r\n NA_SAV.BOOKINGS_MEASURE_KEY ,         \r\n NA_SAV.BOOKINGS_PROCESS_DATE ,        \r\n NA_SAV.BKGS_MEASURE_TRANS_TYPE_CODE  ,\r\n NA_SAV.DV_END_CUST_PARTY_KEY         ,   /*Modified Here As part of SAR CR*/\r\n -999 AS NEW_SA_MEMBER_ID_INT          ,\r\n -999 AS LINK_CUSTOMER_PARTY_KEY       ,\r\n -999 AS SALES_ACCOUNT_GROUP_PARTY_KEY ,\r\n NA_SAV.REASON_DESC_END_CUST,       /*Modified Here As part of SAR CR*/\r\n ENRICH_SAV.REASON_DESCR AS REASON_DESCR,     \r\n (100-SPLIT_LOGIC.DV_SPLIT_PERCENT  ) AS   SALES_CREDIT_SPLIT_PCT ,\r\n   SLS_ACCT_GROUP_SALES_TERR_KEY,\r\n SALES_REP_NUM ,\r\nEP_OTM_TERRITORY_ID_INT,\r\nNA_SAV.FIN_ADJ_KEY,\r\nNA_SAV.PROCESS_TYPE,\r\n'Y' AS NODE_ENRICH_FLAG,\r\nCAST(NULL AS VARCHAR(100)) AS NODE_ENRICH_REASON\r\n FROM  \r\n  /*Modified Here As part of SAR CR*/\r\n (SELECT\r\n BOOKINGS_MEASURE_KEY ,         \r\n BOOKINGS_PROCESS_DATE ,        \r\n BKGS_MEASURE_TRANS_TYPE_CODE,\r\n DV_END_CUST_PARTY_KEY,\r\nSLS_ACCT_GROUP_SALES_TERR_KEY,\r\n SALES_REP_NUM ,\r\nEP_OTM_TERRITORY_ID_INT,\r\nREASON_DESC_END_CUST,\r\nFIN_ADJ_KEY,\r\nPROCESS_TYPE\r\n FROM    \r\n $$STGDB.WI_DRR_NAMED_ACC_AS_SAV \r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY BOOKINGS_MEASURE_KEY,BOOKINGS_PROCESS_DATE,BKGS_MEASURE_TRANS_TYPE_CODE ORDER BY  DV_END_CUST_PARTY_KEY DESC) = 1\r\n )NA_SAV\r\n  /*Modified Here As part of SAR CR*/\r\n INNER JOIN \r\n (SELECT \r\n BOOKINGS_MEASURE_KEY ,         \r\n BOOKINGS_PROCESS_DATE ,        \r\n BKGS_MEASURE_TRANS_TYPE_CODE,\r\n SUM(SALES_CREDIT_SPLIT_PCT) AS DV_SPLIT_PERCENT\r\n FROM $$STGDB.WI_DRR_NAMED_ACC_AS_SAV\r\n WHERE  (BOOKINGS_MEASURE_KEY,BOOKINGS_PROCESS_DATE,BKGS_MEASURE_TRANS_TYPE_CODE) NOT IN\r\n (SELECT BOOKINGS_MEASURE_KEY,BOOKINGS_PROCESS_DATE,BKGS_MEASURE_TRANS_TYPE_CODE FROM $$STGDB.$$WI_DRR_SALES_ACNT_MEASURE_FNL)\r\n GROUP BY 1,2,3\r\n HAVING ROUND(SUM(SALES_CREDIT_SPLIT_PCT)) <100\r\n )SPLIT_LOGIC\r\n ON SPLIT_LOGIC.BOOKINGS_MEASURE_KEY=NA_SAV.BOOKINGS_MEASURE_KEY\r\n AND SPLIT_LOGIC.BOOKINGS_PROCESS_DATE=NA_SAV.BOOKINGS_PROCESS_DATE\r\n AND SPLIT_LOGIC.BKGS_MEASURE_TRANS_TYPE_CODE=NA_SAV.BKGS_MEASURE_TRANS_TYPE_CODE\r\n INNER JOIN $$SLSORDVWDB.N_DYN_RESTMT_ENRICH_REASON ENRICH_SAV\r\n ON ENRICH_SAV.BK_REASON_CD IN ('DEFAULT')",
        "User Defined Join": "",
