      "attributes": {
        "Sql Query": "SELECT \r\nCLN.SVC_CNTRCT_LN_TECH_SVCS_KEY,\r\nCLN.IP_KEY,\r\nCLN.SERVICE_PRODUCT_KEY,\r\nCLN.TERMINATED_DTM,\r\nCLN.rnwd_svc_cntrct_ln_tch_svc_key,\r\nCLN.SOURCE_CREATE_DTM,\r\nCLN.SERVICE_STATUS_CD,\r\nCLN.SK_ID_LINT,\r\n/*SHIP_HIER.HQ_CUSTOMER_PARTY_KEY AS CL_HQ_KEY,*/\r\n/*Added as part of May 19 Rel change in HQ Logic*/\r\n--CASE WHEN SHIP_HIER.HQ_BRANCH_CODE='HQ' THEN SHIP_HIER.PARTY_KEY ELSE SHIP_HIER.HQ_CUSTOMER_PARTY_KEY END AS CL_HQ_KEY,\r\n--CX.CX_CUSTOMER_BU_ID AS CL_HQ_KEY , \r\nCX.CX_CUSTOMER_BU_ID AS CX_CUSTOMER_BU_ID , --added as part of DAY1 FY22\r\nIP.SK_INVENTORY_ITEM_ID_INT as CL_INVENTORY_ITEM_ID,--03/04/2019\r\nP.BK_PRODUCT_ID AS CL_SERVICE_LEVEL,\r\n--CLN.SVC_CNTRCT_LINE_END_DTM AS SVC_CNTRCT_LINE_END_DTM, --/*Added as part of Aug 16 2020 Rel*/ \r\nCASE WHEN CLN.TERMINATED_DTM IS NOT NULL AND CLN.TERMINATED_DTM <>'1900-01-01 00:00:00' \r\nTHEN CLN.TERMINATED_DTM ELSE CLN.SVC_CNTRCT_LINE_END_DTM END AS SVC_CNTRCT_LN_END_DTM, --added as part of DAY1 FY22\r\nCLN.BK_SVC_CNTRCT_LINE_START_DTM  ,\r\nMAINTENANCE_ORDER_NUM,\r\nIP.BK_PRODUCT_ID AS COVERED_PRODUCT_ID --03/04/2019\r\nFROM $$SERVICEVWDB.N_SVC_CNTRCT_LN_TECH_SERVICES  CLN\r\nINNER JOIN $$IBVWDB.N_INSTALLED_PRODUCT I ON i.IP_KEY=CLN.IP_KEY \r\nINNER JOIN $$COMREFVWDB.MT_ERP_POS_SHIPTO  SHIP ON I.INSTALLED_CUSTOMER_PARTY_KEY=SHIP.SHIP_TO_CUSTOMER_KEY\r\nINNER JOIN $$COMREFVWDB.MT_ERP_POS_SHIPTO_HIER  SHIP_HIER ON SHIP_HIER.SHIP_TO_CUSTOMER_KEY=SHIP.SHIP_TO_CUSTOMER_KEY\r\nINNER JOIN $$COMREFVWDB.MT_CXCUST_BU_PARTY_MAPPING CX ON SHIP_HIER.PARTY_SSOT_PARTY_ID_INT=CX.CR_PARTY_ID\r\nINNER JOIN $$COMREFVWDB.R_PRODUCTS P ON CLN.SERVICE_PRODUCT_KEY  =P.ITEM_KEY \r\nINNER JOIN $$COMREFVWDB.R_PRODUCTS IP --03/04/2019\r\nON IP.ITEM_KEY = I.GOODS_PRODUCT_KEY --03/04/2019\r\nWHERE \r\n1=1\r\nAND\r\ni.IP_KEY > 0\r\nAND P.BK_PRODUCT_ID  IN (SELECT DISTINCT GSPA.BK_PRDT_SUBGROUP_ID FROM $$SERVICEVWDB.N_GENERIC_SVC_PRDT_ATTR GSPA\r\nWHERE BK_GSP_ATTR_NAME = 'SW SERVICE CATEGORY'\r\n)\r\nAND\r\nP.BK_PRODUCT_ID NOT IN\r\n(SELECT DISTINCT BK_PRODUCT_SUBGROUP_ID FROM $$COMREFVWDB.MT_SVC_FINANCE_HIERARCHY H\r\nWHERE\r\n1=1\r\nAND BK_ALLOCATED_SERVC_GROUP_ID IN ('AS CORE')\r\nAND ALLOCATION_PERCENTAGE<1)\r\nAND SHIP_HIER.HQ_CUSTOMER_PARTY_KEY>0\r\n/*Added as part of Aug 16 2020 Rel*/ \r\nAND CLN.SVC_CNTRCT_LN_TECH_SVCS_KEY NOT IN (SEL SVC_CNTRCT_LN_TECH_SVCS_KEY FROM $$STGDB.WI_SUMMARY_QUOTE_SWSS_2)  -- Exclude the current entitlement lines\r\nAND CLN.SVC_CNTRCT_LINE_END_DTM >= \r\n(SELECT\r\nMIN(CAST(BK_SVC_CNTRCT_LINE_START_DTM AS DATE))-370\r\nFROM\r\n$$STGDB.WI_SUMMARY_QUOTE_SWSS_2)\r\nAND SVC_CNTRCT_LN_END_DTM > DATE '2000-01-01'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
