      "attributes": {
        "Sql Query": "SELECT \r\nWBPCD.MAJOR_PRODUCT_ID || ' - ' || CAST(PROD_CONFIG_SEQ_NUM_INT AS VARCHAR(100)) DV_PRODUCT_CONFIGURATION_NAME, \r\nWBPCD.PRODUCT_CONFIGURATION_DESC  ,\r\nWBPCD.MAJOR_PRODUCT_ID  ,\r\nRANK() OVER ( ORDER BY WBPCD.MAJOR_PRODUCT_ID,WBPCD.PRODUCT_CONFIGURATION_DESC)+COALESCE(MAX_PROD_CONFIG_SEQ_NUM_INT.MAX_PROD_CONFIG_SEQ_NUM_INT,0)  PROD_CONFIG_SEQ_NUM_INT            \r\n,CURRENT_TIMESTAMP(0),\r\n\t\tUSER,\r\n\t\tCURRENT_TIMESTAMP(0),\r\n\t\tUSER\r\nFROM \r\n\t$$STGDB.WI_BKGS_PROD_CONFIG_DESC_DUP  WBPCD,\r\n\t(\r\n\tSELECT \r\n\t\tMAX(PROD_CONFIG_SEQ_NUM_INT) MAX_PROD_CONFIG_SEQ_NUM_INT\r\n\tFROM \r\n\t\t$$SLSORDVWDB.MT_PRODUCT_CONFIGURATION\t\r\n\t) MAX_PROD_CONFIG_SEQ_NUM_INT\r\nWHERE   NOT EXISTS \r\n(SELECT 1  \r\nFROM $$SLSORDVWDB.MT_PRODUCT_CONFIGURATION MT\r\nWHERE WBPCD.PRODUCT_CONFIGURATION_DESC =TRIM(MT.DV_PRODUCT_CONFIGURATION_DESC) \r\nAND WBPCD.MAJOR_PRODUCT_ID= MT.MAJOR_LINE_PRODUCT_ID)",
