      "attributes": {
        "Sql Query": "SELECT\r\n   CAST(EL.UNIQUE_ID AS VARCHAR(50) CASESPECIFIC) AS RTNR_UNIQUE_ID\r\n  ,CASE WHEN SOR.ACQUISITION_ROLE='Y' AND SOR.ACQUISITION_ORDER_ORIGIN_CD = 'ACQ-APPD'  THEN  \r\n\t\tCASE WHEN NSOL.ELA_FLG = 'Y' THEN COALESCE(EACEPM.EA_PRODUCT_KEY, -999) ELSE COALESCE(PID.ADJ_PRODUT_KEY,-999) END\r\n    ELSE SOR.SUBSCRIPTION_PRODUCT_KEY END AS PRODUCT_KEY \r\n  ,DV_TOP_SKU_PRODUCT_KEY1 AS ENTERPRISE_SKU_PRDT_KEY\r\n  ,SOR.SO_SBSCRPTN_ITM_SLS_TRX_KEY AS SO_SBSCRPTN_ITM_SLS_TRX_KEY\r\n  ,COALESCE(RTR.ATTR_PRDT_AS_NEW_OR_RNWL_KEY,CAST(-999 AS BIGINT)) AS ATTR_PRDT_AS_NEW_OR_RNWL_KEY\r\n  ,CAST('OPL' AS CHAR(8)) AS ATTRIBUTION_SS_CD\r\n  ,CAST(-9999 AS BIGINT) AS BK_OFFER_ATTRIBUTION_ID_INT\t\r\n  ,CASE WHEN ( NXSSA.PARENT_SO_SBSCRP_ITMSLSTRX_KEY IS NOT NULL OR NXSSA_MPOB.PARENT_SO_SBSCRP_ITMSLSTRX_KEY IS NOT NULL)THEN 'BUNDLE' \r\n                     ELSE 'STANDALONE' END AS DV_ATTRIBUTION_CD\r\n  ,COALESCE(CAST(RTR.ATTR_PCT AS DECIMAL(18,6)),CAST(100 AS DECIMAL(18,6))) AS ATTRIBUTION_PCT\r\n  ,COALESCE(RTR.SALES_MOTION_CD,CAST('UNKNOWN' AS VARCHAR(8))) AS SALES_MOTION_CD \r\n  ,COALESCE(RTR.SK_RTR_ATTRIBUTION_ID,CAST(-999 AS BIGINT)) AS SK_RTNR_ATTRIBUTION_ID_INT\r\n  ,SOR.SK_TRX_ID_INT AS SK_TRX_ID_INT\r\n  ,SOR.BOOKING_VERSION_INT AS TRANSACTION_BKG_VERSION_INT\r\n  ,SOR.XAAS_TRX_METRIC_TYPE_NAME AS TRANSACTION_TYPE_NAME   \r\n  ,SOR.SO_SBSCRPTN_ITM_SLS_TRX_KEY AS DV_TOPSKU_SOSBR_ITM_SLSTRX_KEY\r\n  ,COALESCE(CAST(RTR.ATTR_PCT/100 AS DECIMAL(18,6)),CAST(1 AS DECIMAL(18,6))) AS DV_ALLOCATION_PCT\r\n  ,CASE WHEN SOR.ACQUISITION_ROLE='Y' AND SOR.ACQUISITION_ORDER_ORIGIN_CD = 'ACQ-APPD'  THEN\r\n\t\t\t\tCASE WHEN NSOL.ELA_FLG = 'Y' THEN COALESCE(EACEPM.EA_PRODUCT_KEY, -999) ELSE COALESCE(PID.ADJ_PRODUT_KEY,-999) END\r\n          ELSE COALESCE(SOR.SUBSCRIPTION_PRODUCT_KEY,-999) END  AS  DV_TOP_SKU_PRODUCT_KEY1\r\n  ,CURRENT_TIMESTAMP(0) AS START_TV_DTM\r\n  \r\nFROM $$SLSORDVWDB.N_XAAS_SO_SBSCR_ITM_SLS_TRX_TV SOR\r\nINNER JOIN $$STGDB.WI_XAAS_ACV_RTR_INCR INC\r\nON INC.SO_SBSCRPTN_ITM_SLS_TRX_KEY = SOR.SO_SBSCRPTN_ITM_SLS_TRX_KEY\r\nLEFT JOIN (SELECT NP.ITEM_KEY APPD_PRODUT_KEY , ADJP.ITEM_KEY AS ADJ_PRODUT_KEY \r\nFROM $$COMREFVWDB.N_PRODUCT NP,  $$ETLVWDB.EL_CG1_EGO_MTL_SY_ITMS_EXT_ACQ ACQ,\r\n$$COMREFVWDB.N_PRODUCT ADJP\r\nWHERE NP.SK_INVENTORY_ITEM_ID_INT=ACQ.INVENTORY_ITEM_ID\r\nAND ADJP.BK_PRODUCT_ID =ACQ.C_EXT_ATTR5) PID \r\nON PID.APPD_PRODUT_KEY=SOR.SUBSCRIPTION_PRODUCT_KEY    \r\nLEFT JOIN $$NRTNCRVWDB.N_SALES_ORDER_LINE_NRT  NSOL  \r\nON   NSOL.SALES_ORDER_LINE_KEY =SOR.MINOR_LN_EXAAS_SUBSCR_SOL_KEY AND NSOL.SS_CD = 'OPL' \r\nLEFT JOIN $$ETLVWDB.EL_ACQ_CISCO_EA_PID_MAP EACEPM ON PID.ADJ_PRODUT_KEY = EACEPM.CISCO_PRODUCT_KEY\r\nLEFT OUTER JOIN (SELECT PARENT_SO_SBSCRP_ITMSLSTRX_KEY, MAX(SOURCE_COMMIT_DTM)  SOURCE_COMMIT_DTM \r\nFROM  $$SLSORDVWDB.N_XAAS_SO_SBSCRPTN_ATTRBTN_TV WHERE\r\nEND_TV_DTM=CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))AND PARENT_SO_SBSCRP_ITMSLSTRX_KEY>0 AND POB_TYPE_CD = 'UNKNOWN' AND TSL_TRX_TYPE_CD ='BOOKING' GROUP BY 1) NXSSA  \r\nON NXSSA.PARENT_SO_SBSCRP_ITMSLSTRX_KEY = SOR.SO_SBSCRPTN_ITM_SLS_TRX_KEY\r\nLEFT OUTER JOIN (SELECT PARENT_SO_SBSCRP_ITMSLSTRX_KEY,POB_TYPE_CD   \r\nFROM  $$SLSORDVWDB.N_XAAS_SO_SBSCRPTN_ATTRBTN_TV WHERE\r\nEND_TV_DTM=CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))AND PARENT_SO_SBSCRP_ITMSLSTRX_KEY>0 \r\nAND  ATTRIBUTION_CD = 'OFFSET' AND POB_TYPE_CD = 'MPOB'\r\nGROUP BY 1,2) NXSSA_MPOB  \r\nON NXSSA_MPOB.PARENT_SO_SBSCRP_ITMSLSTRX_KEY = SOR.SO_SBSCRPTN_ITM_SLS_TRX_KEY\r\nLEFT JOIN (SELECT * FROM $$SLSORDVWDB.N_ATTR_PRDT_NEW_RNWL_ACV_TV\r\nWHERE END_TV_DTM='3500/01/01 00:00:00'\r\nAND  ITEM_CATEGORY_NAME IN ('BILLING','FLEXIBLE CONSUMPTION MODEL') AND SK_RTR_ATTRIBUTION_ID>0) RTR\r\nON  RTR.SK_ERP_BKGS_TRX_ID = SOR.SK_TRX_ID_INT \r\nAND RTR.SK_ATTRIBUTION_ID_INT = -9999\r\nINNER JOIN $$ETLVWDB.EL_XAAS_OFFER_RTNR_ATTRIB EL \r\nON COALESCE(EL.TRX_ID,EL.PARENT_TRX_ID) = SOR.SK_TRX_ID_INT \r\nAND EL.ATTRIBUTION_ID = -9999\r\nAND EL.RTR_ATTRIBUTION_ID = COALESCE(RTR.SK_RTR_ATTRIBUTION_ID,-999)\r\nWHERE SOR.END_TV_DTM='3500/01/01 00:00:00'\r\n/*AND   INC.DV_NET_CHANGE_FLG = 'Y'*/\r\n\r\nUNION ALL\r\n\r\nSELECT\r\n   CAST(EL.UNIQUE_ID AS VARCHAR(50) CASESPECIFIC) AS RTNR_UNIQUE_ID\r\n  ,NXSSA.ORDERED_PRODUCT_KEY AS PRODUCT_KEY\r\n  ,CASE WHEN NXSSA.ATTRIBUTION_CD ='OFFSET' THEN DV_TOP_SKU_PRODUCT_KEY1 ELSE NXSSA.ENTERPRISE_SKU_PRDT_KEY END AS ENTERPRISE_SKU_PRDT_KEY\r\n  ,NXSSA.SO_SBSCRPTN_ITM_SLS_TRX_KEY    AS SO_SBSCRPTN_ITM_SLS_TRX_KEY\r\n  ,COALESCE(RTR.ATTR_PRDT_AS_NEW_OR_RNWL_KEY,CAST(-999 AS BIGINT)) AS ATTR_PRDT_AS_NEW_OR_RNWL_KEY  \r\n  ,CAST('OPL' AS CHAR(8)) AS ATTRIBUTION_SS_CD  \r\n  ,CAST(NXSSA.BK_OFFER_ATTRIBUTION_ID_INT AS BIGINT) AS BK_OFFER_ATTRIBUTION_ID_INT \r\n  ,CAST(NXSSA.ATTRIBUTION_CD AS VARCHAR(12)) AS DV_ATTRIBUTION_CD\r\n  ,(COALESCE(CAST(RTR.ATTR_PCT/CASE WHEN RTR_SUM.SUM_RTR_PCT=0 THEN 100 ELSE RTR_SUM.SUM_RTR_PCT END AS DECIMAL(18,6))\r\n       ,CAST(1 AS DECIMAL(18,6))))*100 AS ATTRIBUTION_PCT\r\n  ,COALESCE(RTR.SALES_MOTION_CD,CAST('UNKNOWN' AS VARCHAR(8))) AS SALES_MOTION_CD  \r\n  ,COALESCE(RTR.SK_RTR_ATTRIBUTION_ID,CAST(-999 AS BIGINT)) AS SK_RTNR_ATTRIBUTION_ID_INT \r\n  ,SOR.SK_TRX_ID_INT AS SK_TRX_ID_INT\r\n  ,SOR.BOOKING_VERSION_INT AS TRANSACTION_BKG_VERSION_INT  \r\n  ,NXSSA.TSL_TRX_TYPE_CD AS TRANSACTION_TYPE_NAME  \r\n  ,NXSSA.PARENT_SO_SBSCRP_ITMSLSTRX_KEY AS DV_TOPSKU_SOSBR_ITM_SLSTRX_KEY\r\n  ,COALESCE(CAST(RTR.ATTR_PCT/CASE WHEN RTR_SUM.SUM_RTR_PCT=0 THEN 100 ELSE RTR_SUM.SUM_RTR_PCT END AS DECIMAL(18,6))\r\n    ,CAST(1 AS DECIMAL(18,6))) AS DV_ALLOCATION_PCT\r\n  ,CASE WHEN SOR.ACQUISITION_ROLE='Y' AND SOR.ACQUISITION_ORDER_ORIGIN_CD = 'ACQ-APPD'  THEN\r\n\t\tCASE WHEN NSOL.ELA_FLG = 'Y' THEN COALESCE(EACEPM.EA_PRODUCT_KEY, -999) ELSE COALESCE(PID.ADJ_PRODUT_KEY ,-999) END\r\n      ELSE COALESCE(SOR.SUBSCRIPTION_PRODUCT_KEY,-999) END AS DV_TOP_SKU_PRODUCT_KEY1 \r\n  ,CURRENT_TIMESTAMP(0) AS START_TV_DTM\r\n  \r\nFROM $$SLSORDVWDB.N_XAAS_SO_SBSCR_ITM_SLS_TRX_TV SOR\r\nINNER JOIN $$STGDB.WI_XAAS_ACV_RTR_INCR INC\r\nON INC.SO_SBSCRPTN_ITM_SLS_TRX_KEY = SOR.SO_SBSCRPTN_ITM_SLS_TRX_KEY\r\nINNER JOIN  $$SLSORDVWDB.N_XAAS_SO_SBSCRPTN_ATTRBTN_TV  NXSSA \r\nON  SOR.SO_SBSCRPTN_ITM_SLS_TRX_KEY=NXSSA.PARENT_SO_SBSCRP_ITMSLSTRX_KEY\r\nAND NXSSA.PARENT_SO_SBSCRP_ITMSLSTRX_KEY>0\r\nAND NXSSA.END_TV_DTM=CAST('3500-01-01 00:00:00' AS TIMESTAMP(0)) \r\nAND NXSSA.TSL_TRX_TYPE_CD ='BOOKING'\r\nLEFT JOIN (SELECT NP.ITEM_KEY APPD_PRODUT_KEY , ADJP.ITEM_KEY AS ADJ_PRODUT_KEY \r\nFROM $$COMREFVWDB.N_PRODUCT NP,  $$ETLVWDB.EL_CG1_EGO_MTL_SY_ITMS_EXT_ACQ ACQ,\r\n$$COMREFVWDB.N_PRODUCT ADJP\r\nWHERE NP.SK_INVENTORY_ITEM_ID_INT=ACQ.INVENTORY_ITEM_ID\r\nAND ADJP.BK_PRODUCT_ID =ACQ.C_EXT_ATTR5) PID \r\nON PID.APPD_PRODUT_KEY=SOR.SUBSCRIPTION_PRODUCT_KEY   \r\nLEFT JOIN $$NRTNCRVWDB.N_SALES_ORDER_LINE_NRT  NSOL  \r\nON   NSOL.SALES_ORDER_LINE_KEY =SOR.MINOR_LN_EXAAS_SUBSCR_SOL_KEY  AND NSOL.SS_CD = 'OPL' \r\nLEFT JOIN $$ETLVWDB.EL_ACQ_CISCO_EA_PID_MAP EACEPM ON PID.ADJ_PRODUT_KEY = EACEPM.CISCO_PRODUCT_KEY\r\nLEFT JOIN (SELECT * FROM $$SLSORDVWDB.N_ATTR_PRDT_NEW_RNWL_ACV_TV\r\nWHERE END_TV_DTM='3500/01/01 00:00:00'\r\nAND  ITEM_CATEGORY_NAME IN ('BILLING','FLEXIBLE CONSUMPTION MODEL') AND SK_RTR_ATTRIBUTION_ID>0) RTR\r\nON  RTR.SK_ERP_BKGS_TRX_ID = SOR.SK_TRX_ID_INT \r\nAND RTR.SK_ATTRIBUTION_ID_INT = NXSSA.BK_OFFER_ATTRIBUTION_ID_INT\r\nLEFT JOIN (SELECT SK_ERP_BKGS_TRX_ID,SK_ATTRIBUTION_ID_INT,SUM(ATTR_PCT) SUM_RTR_PCT \r\nFROM $$SLSORDVWDB.N_ATTR_PRDT_NEW_RNWL_ACV_TV\r\nWHERE END_TV_DTM='3500/01/01 00:00:00'\r\nAND  ITEM_CATEGORY_NAME IN ('BILLING','FLEXIBLE CONSUMPTION MODEL') AND SK_RTR_ATTRIBUTION_ID>0\r\nGROUP BY 1,2 ) RTR_SUM\r\nON  RTR_SUM.SK_ERP_BKGS_TRX_ID = SOR.SK_TRX_ID_INT \r\nAND RTR_SUM.SK_ATTRIBUTION_ID_INT = NXSSA.BK_OFFER_ATTRIBUTION_ID_INT\r\nINNER JOIN $$ETLVWDB.EL_XAAS_OFFER_RTNR_ATTRIB EL \r\nON COALESCE(EL.TRX_ID,EL.PARENT_TRX_ID) = SOR.SK_TRX_ID_INT \r\nAND EL.ATTRIBUTION_ID = NXSSA.BK_OFFER_ATTRIBUTION_ID_INT\r\nAND EL.RTR_ATTRIBUTION_ID = COALESCE(RTR.SK_RTR_ATTRIBUTION_ID,-999)\r\nWHERE \r\nSOR.END_TV_DTM='3500/01/01 00:00:00'\r\n/*AND   INC.DV_NET_CHANGE_FLG = 'Y'*/\r\nAND   NXSSA.END_TV_DTM='3500/01/01 00:00:00'",
