        "Sql Query": "SELECT\r\nBK_POS_TRX_ID_INT ,            \r\nBASE_LIST_UNIT_PRDT_PRICE_AMT, \r\nVALIDATED_NET_UNT_PRC_USD_AMT ,\r\nDSTRBTR_RPTD_CST_UNT_PRC_AMT,  \r\nVALUATION_PRICE_USD_AMT,       \r\nPOS_TRX_LN_PRDT_QTY ,          \r\nEDW_CREATE_DTM ,               \r\nEDW_CREATE_USER ,              \r\nEDW_UPDATE_DTM ,               \r\nEDW_UPDATE_USER,               \r\nSTART_TV_DT ,                  \r\nEND_TV_DT   ,\r\nRU_SERVICE_CONTRACT_START_DTM ,\r\nRU_SERVICE_CONTRACT_END_DTM,\r\nRU_SRVC_CNTRCT_DRTN_MNTHS_CNT,\r\n/* Added as part of SFP June 28th Rel */\r\nIS_SERVICE_CONTRACT_POS_FLG   \r\n/*added as part of FLEXI_AUG_REL ejayacha */\r\n,GLOB_UNIT_LIST_PRICE_USD_AMT \r\n,GLOB_UNIT_LIST_PRICE_LOCAL_AMT\r\n,CHANGE_REASON_DESCR \r\n    /* added below columns as part of AI Bookings Scope */\r\n ,TRANSACTION_AI_FLG\r\n,AI_INTENT_TYPE_CD  \r\n,TRX_AI_PRODUCT_CLASS_NAME \r\n,AI_STRATEGIC_FACTOR_PCT /* AI Bookings MVP4 MAY REL */                                 \r\nFROM $$WORKDB.W_BKG_POS_TRANSACTION_LINE_TV W_BPOS\r\nWHERE DML_TYPE='I'\r\nAND NOT EXISTS (SELECT 1 FROM $$SLSORDVWDB.N_BKG_POS_TRANSACTION_LINE_TV N_BPOS \r\nWHERE N_BPOS.BK_POS_TRX_ID_INT = W_BPOS.BK_POS_TRX_ID_INT\r\nAND N_BPOS.START_TV_DT=W_BPOS.START_TV_DT)",
