      "attributes": {
        "Sql Query": "SELECT \r\nCWIAS.ACTION,\r\nCWIAS.ACTIVITY_RESULT_CODE,\r\nCWIAS.ACTIVITY_STATUS,\r\nCWIAS.ASSIGNED_USER,\r\nCWIAS.BEGIN_DATE,\r\nCWIAS.DUE_DATE,\r\nCWIAS.END_DATE,\r\nCWIAS.ERROR_MESSAGE,\r\nCWIAS.ERROR_NAME,\r\nCWIAS.ERROR_STACK,\r\nCWIAS.EXECUTION_TIME,\r\nCAST(TRIM(CWIAS.ITEM_KEY) AS INTEGER) ITEM_KEY ,\r\nCWIAS.ITEM_TYPE,\r\nCWIAS.NOTIFICATION_ID,\r\nCWIAS.PERFORMED_BY,\r\nCWIAS.PROCESS_ACTIVITY,\r\nCWIAS.SECURITY_GROUP_ID,\r\nCWIAS.SOURCE_COMMIT_TIME,\r\nCWIAS.REFRESH_DATETIME,\r\nCWIAS.PROCESSED_FLAG\r\nFROM \r\n$$NRTACCUMVWDB.CG1_WF_ITEM_ACTIVITY_STATUSES CWIAS\r\nWHERE\r\nCWIAS.SOURCE_COMMIT_TIME >= '$$LastExtractDate' \r\nAND\r\nCWIAS.SOURCE_DML_TYPE <> 'DELETE'\r\nAND \r\nITEM_TYPE ='OEOL'\r\nAND\r\nCWIAS.ACTIVITY_STATUS  in  ('COMPLETE','ACTIVE','ERROR','NOTIFIED')\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY CWIAS.ITEM_KEY,CWIAS.ITEM_TYPE,CWIAS.PROCESS_ACTIVITY ORDER BY CWIAS.REFRESH_DATETIME DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
