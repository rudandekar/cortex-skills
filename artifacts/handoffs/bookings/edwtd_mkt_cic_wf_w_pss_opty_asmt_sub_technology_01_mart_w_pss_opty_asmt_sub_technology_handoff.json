      "attributes": {
        "Sql Query": "SELECT COALESCE(SAW.AT_TECHNOLOGY__C,'UNKNOWN') AS BK_PSS_TECHNOLOGY_NAME,\r\n    COALESCE(SAW.AT_SUB_TECHNOLOGY__C,'UNKNOWN') AS BK_PSS_SUB_TECHNOLOGY_NAME,\r\n    SPOA.PSS_OPPORTUNITY_ASSESSMENT_KEY,\r\n\tSAW.AT_EXPECTED_PRODUCT__C*COALESCE(MCR.MONTHLY_BUDGET_CONV_RT,1) AS PSS_EXPCTD_GOODS_PRDCT_USD_AMT,\r\n\tSAW.AT_EXPECTED_SERVICE__C*COALESCE(MCR.MONTHLY_BUDGET_CONV_RT,1) AS PSS_EXPCTD_SVC_PRDCT_USD_AMT,       \r\n\tCURRENT_TIMESTAMP (0) AS EDW_CREATE_DTM,\r\n    USER AS EDW_CREATE_USER,\r\n    CURRENT_TIMESTAMP (0) AS EDW_UPDATE_DTM,\r\n    USER AS EDW_UPDATE_USER,\r\n    'I' AS ACTION_CODE,\r\n    'I' AS DML_TYPE\r\nFROM $$ETLVWDB.SM_PSS_OPPORTUNITY_ASSESSMENT SPOA\r\nINNER JOIN $$STGDB.ST_AT_WORKSPACE__C SAW ON SPOA.SFDC_WORKSPACE_ID = SAW.ID\r\nLEFT OUTER JOIN $$COMREFDB.R_FISCAL_MONTH_TO_YEAR M2Y ON SAW.FISCAL_YEAR_PSS__C= M2Y.FISCAL_YEAR_NUMBER_INT\r\nAND \tSAW.FISCAL_MONTH_PSS__C=M2Y.FISCAL_MONTH_NUMBER_INT\r\nLEFT OUTER JOIN $$FINLGLDB.MT_MONTHLY_CONVERSION_RATE   MCR ON \tM2Y.FISCAL_YEAR_MONTH_INT=MCR.FISCAL_YEAR_MONTH_NUM_INT\r\n\tAND\tMCR.BK_FROM_CURRENCY_CD= SAW.CURRENCYISOCODE\r\n\tAND\tMCR.BK_TO_CURRENCY_CD ='USD'",
        "User Defined Join": "",
        "Source Filter": "",
