      ],
      "attributes": {
        "Sql Query": "SELECT \r\nSOD.SALES_ORDER_KEY,\r\nSOD.NET_PRICE DD_COMP_US_NET_PRICE_AMOUNT,\r\nCASE WHEN SOD.LIST_PRICE=0 THEN 0 ELSE (SOD.LIST_PRICE-SOD.NET_PRICE)/SOD.LIST_PRICE*100 END SO_DISCOUNT_PCT,\r\n\r\nUSER EDW_CREATE_USER,\r\nUSER EDW_UPDATE_USER,\r\ncurrent_timestamp(0) EDW_CREATE_DATETIME,\r\ncurrent_timestamp(0) EDW_UPDATE_DATETIME\r\nFROM \r\n(select\r\nSALES_ORDER_KEY,\r\nSUM(DD_COMP_US_NET_PRICE_AMOUNT ) NET_PRICE,\r\nSUM(DD_COMP_US_LIST_PRICE_AMOUNT) LIST_PRICE\r\nfrom \r\n$$SLSORDVWDB.N_BOOKINGS_MEASURE\r\nwhere DV_REVENUE_RECOGNITION_FLG ='Y' /*Added part of TRUE DEMAND */\r\n/*where CORPORATE_BOOKINGS_FLG ='Y' */ /*Removed  part of TRUE DEMAND */\r\nGROUP BY SALES_ORDER_KEY) SOD",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
