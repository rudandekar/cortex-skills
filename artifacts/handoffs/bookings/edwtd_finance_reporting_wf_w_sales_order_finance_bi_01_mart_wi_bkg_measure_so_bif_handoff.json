          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "SELECT\r\nSALES_ORDER_KEY,\r\nCASE\r\n\tWHEN SO_DISCOUNT_PCT<35   THEN '35% and lesser'   \r\n\tWHEN SO_DISCOUNT_PCT>=35 AND SO_DISCOUNT_PCT<40  THEN '35% to 40%'          \r\n\tWHEN SO_DISCOUNT_PCT>=40 AND SO_DISCOUNT_PCT<45  THEN '40% to 45%' \r\n\tWHEN SO_DISCOUNT_PCT>=45 AND SO_DISCOUNT_PCT<50  THEN '45% to 50%' \r\n\tWHEN SO_DISCOUNT_PCT>=50 AND SO_DISCOUNT_PCT<55  THEN '50% to 55%' \r\n\tWHEN SO_DISCOUNT_PCT>=55 AND SO_DISCOUNT_PCT<60  THEN '55% to 60%' \r\n\tWHEN SO_DISCOUNT_PCT>=60 AND SO_DISCOUNT_PCT<65  THEN '60% to 65%' \r\n\tWHEN SO_DISCOUNT_PCT>=65 AND SO_DISCOUNT_PCT<70  THEN '65% to 70%' \r\n\tWHEN SO_DISCOUNT_PCT>=70 THEN '70% and greater'\r\nEND as DV_DISCOUNT_BAND_CD,\r\nCASE \r\n\tWHEN DD_COMP_US_NET_PRICE_AMOUNT<1000000 THEN '$1M and lesser'   \r\n\tWHEN DD_COMP_US_NET_PRICE_AMOUNT>=1000000 AND DD_COMP_US_NET_PRICE_AMOUNT<2000000  THEN '$1M to $2M' \r\n\tWHEN DD_COMP_US_NET_PRICE_AMOUNT>=2000000 AND DD_COMP_US_NET_PRICE_AMOUNT<3000000  THEN '$2M to $3M' \r\n\tWHEN DD_COMP_US_NET_PRICE_AMOUNT>=3000000 AND DD_COMP_US_NET_PRICE_AMOUNT<4000000  THEN '$3M to $4M' \r\n\tWHEN DD_COMP_US_NET_PRICE_AMOUNT>=4000000 AND DD_COMP_US_NET_PRICE_AMOUNT<5000000  THEN '$4M to $5M' \r\n\tWHEN DD_COMP_US_NET_PRICE_AMOUNT>=5000000  THEN '$5M and greater'\r\nEND as DV_ORDER_BAND_CD,\r\ncurrent_timestamp(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\ncurrent_timestamp(0) EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER\r\nFROM  \r\n$$STGDB.WI_BKG_MEASURE_SO_BIF",
