      "attributes": {
        "Sql Query": "SELECT \r\nWCSTL.CS_SALES_ORDER_TASK_KEY,       \r\nCASE WHEN SSOL.SALES_ORDER_LINE_KEY IS NULL  AND WCSTL.SS_CD='QTC' THEN -9999\r\nWHEN SSOL.SALES_ORDER_LINE_KEY IS NULL  AND WCSTL.SS_CD='BV' THEN -8888\r\nELSE SSOL.SALES_ORDER_LINE_KEY END  RU_SALES_ORDER_LINE_KEY,       \r\nWCSTL.SALES_ORDER_KEY RU_SALES_ORDER_KEY,            \r\nWCSTL.BK_CS_SALES_ORDER_TASK_TYPE_CD,\r\nWCSTL.CS_SO_TASK_STATUS_CD,          \r\nCASE WHEN SSOL.SALES_ORDER_LINE_KEY IS NOT NULL THEN \r\n'LINE' ELSE 'HEADER' END CS_SALES_ORDER_TASK_TYPE,      \r\nWCSTL.CS_SO_TASK_CREATED_DTM ,       \r\nWCSTL.SK_ORDER_TASK_ID_INT,          \r\nWCSTL.SS_CD ,   \r\n'CEC' SS_TABLE_CD,                     \r\nWCSTL.CS_SO_TASK_OBSOLETE_FLG ,      \r\nWCSTL.CS_SALES_ORDER_TASK_TXT,       \r\nCURRENT_TIMESTAMP(0),                \r\nUSER,\r\nCURRENT_TIMESTAMP(0),               \r\nUSER ,              \r\n'=' ACTION_CODE,                  \r\n'=' DML_TYPE \r\nFROM $$STGDB.WI_CS_SO_TASK_LINE  WCSTL\r\nLEFT OUTER JOIN  $$ETLVWDB.SM_SALES_ORDER_LINE SSOL \r\nON WCSTL.ERP_LINE_ID=SSOL.SK_SO_LINE_ID_INT AND WCSTL.SS_CD=SSOL.SS_CODE\r\nUNION ALL\r\nSELECT\r\nWCST_ICW.CS_SALES_ORDER_TASK_KEY       CS_SALES_ORDER_TASK_KEY       ,\r\nCASE WHEN SSOL.SALES_ORDER_LINE_KEY IS NULL  AND WCST_ICW.SS_CD='QTC' THEN -9999\r\nWHEN SSOL.SALES_ORDER_LINE_KEY IS NULL  AND WCST_ICW.SS_CD='BV' THEN -8888\r\nWHEN SSOL.SALES_ORDER_LINE_KEY IS NULL  AND WCST_ICW.SS_CD='CG' THEN -7777\r\nELSE SSOL.SALES_ORDER_LINE_KEY END  RU_SALES_ORDER_LINE_KEY,       \r\nWCST_ICW.RU_SALES_ORDER_KEY            RU_SALES_ORDER_KEY,\r\nWCST_ICW.BK_CS_SALES_ORDER_TASK_TYPE_CD,\r\nWCST_ICW.CS_SO_TASK_STATUS_CD          ,\r\nCASE WHEN SSOL.SALES_ORDER_LINE_KEY IS NOT NULL THEN \r\n'LINE' ELSE 'HEADER' END CS_SALES_ORDER_TASK_TYPE,      \r\nWCST_ICW.CS_SO_TASK_CREATED_DTM        ,\r\nWCST_ICW.SK_ORDER_TASK_ID_INT          ,\r\nWCST_ICW.SS_CD                         ,\r\nWCST_ICW.SS_TABLE_CD         ,          \r\nWCST_ICW.CS_SO_TASK_OBSOLETE_FLG       ,\r\nWCST_ICW.CS_SALES_ORDER_TASK_TXT       ,\r\nCURRENT_TIMESTAMP(0),                \r\nUSER,\r\nCURRENT_TIMESTAMP(0),               \r\nUSER ,              \r\n'=' ACTION_CODE,                  \r\n'=' DML_TYPE \r\nFROM\r\n$$STGDB.WI_CS_SO_TASK_ORDER_KEY_ICW WCST_ICW\r\nLEFT OUTER JOIN\r\n$$ETLVWDB.SM_SALES_ORDER_LINE SSOL \r\nON WCST_ICW.ORDER_LINE_ID =SSOL.SK_SO_LINE_ID_INT AND WCST_ICW.SS_CD=SSOL.SS_CODE",
