      "attributes": {
        "Sql Query": "SELECT \r\n ST.PROMO_ID, ST.PROMO_CUST_DETAIL_ID, ST.CUSTOMER_ID, ST.CUSTOMER_TYPE, ST.CUSTOMER_NAME, ST.CUSTOMER_COUNTRY_CODE, ST.CUSTOMER_ADDRESS1, ST.CUSTOMER_ADDRESS2, ST.CUSTOMER_CITY, ST.CUSTOMER_STATE, ST.CUSTOMER_ZIP_CODE, ST.CUSTOMER_PHONE, ST.CUSTOMER_ACCOUNT_NO, ST.CUSTOMER_EMAIL_ADDRESS, ST.ACTIVE_FLAG, ST.CREATED_BY, ST.CREATED_DATE, ST.UPDATED_BY, ST.LAST_UPDATE_DATE, ST.IT_COMMENTS, ST.BATCH_ID, ST.ACTION_CD, ST.CREATE_DATETIME, \r\n'RI' AS EXCEPTION_TYPE\r\nFROM $$STGDB.ST_DCA_PROMO_CUSTOMER_DETAILS  ST\r\nWHERE NOT EXISTS\r\n(SELECT 1 FROM $$COMREFVWDB.N_PARTY  NP  WHERE NP.SS_CODE IN('CR','CR_MODS')\r\nAND NP.PARTY_SSOT_PARTY_ID_INT = ST.CUSTOMER_ID\r\nAND ST.CUSTOMER_TYPE='ENDUSER')\r\nOR NOT EXISTS\r\n(SELECT 1 FROM $$SLSORDVWDB.N_DISTRIBUTOR_PROMOTION NDP\r\nWHERE NDP.SK_PROMO_ID_INT = ST.PROMO_ID)",
