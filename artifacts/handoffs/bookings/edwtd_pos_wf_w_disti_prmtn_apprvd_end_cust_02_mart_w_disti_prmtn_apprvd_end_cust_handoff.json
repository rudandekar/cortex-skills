      ],
      "attributes": {
        "Sql Query": "SELECT NP.PARTY_KEY  AS CUSTOMER_PARTY_KEY,\r\nNDP.BK_PROMOTION_NUM AS BK_PROMOTION_NUM,\r\nNDP. BK_PROMOTION_REVISION_NUM_INT  AS  BK_PROMOTION_REVISION_NUM_INT,\r\nNDP. BK_PROMOTION_TYPE_CD  AS BK_PROMOTION_TYPE_CD,\r\nCURRENT_TIMESTAMP(0)  AS   EDW_CREATE_DTM ,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS   EDW_UPDATE_USER         \r\n FROM $$STGDB.ST_DCA_PROMO_CUSTOMER_DETAILS  ST\r\nINNER JOIN\r\n(SELECT PARTY_KEY,PARTY_SSOT_PARTY_ID_INT FROM $$COMREFVWDB.N_PARTY  WHERE SS_CODE IN('CR','CR_MODS'))NP\r\nON NP.PARTY_SSOT_PARTY_ID_INT = ST.CUSTOMER_ID\r\nAND ST.CUSTOMER_TYPE='ENDUSER'\r\nINNER JOIN\r\n$$SLSORDVWDB.N_DISTRIBUTOR_PROMOTION NDP\r\nON NDP.SK_PROMO_ID_INT = ST.PROMO_ID\r\nWHERE ST.CUSTOMER_ID IS NOT NULL\r\nAND NP.PARTY_KEY IS NOT NULL\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY CUSTOMER_PARTY_KEY ,\r\nBK_PROMOTION_NUM ,BK_PROMOTION_REVISION_NUM_INT ,BK_PROMOTION_TYPE_CD ORDER BY ST.LAST_UPDATE_DATE DESC) =1\r\n\r\nUNION \r\n\r\n\r\nSELECT NP.PARTY_KEY  AS CUSTOMER_PARTY_KEY,\r\nNDP.BK_PROMOTION_NUM AS BK_PROMOTION_NUM,\r\nNDP. BK_PROMOTION_REVISION_NUM_INT  AS  BK_PROMOTION_REVISION_NUM_INT,\r\nNDP. BK_PROMOTION_TYPE_CD  AS BK_PROMOTION_TYPE_CD,\r\nCURRENT_TIMESTAMP(0)  AS   EDW_CREATE_DTM ,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS   EDW_UPDATE_USER         \r\n FROM $$EXCEPDB.EX_DISTI_PRMTN_APPRVD_END_CUST  EX\r\nINNER JOIN\r\n(SELECT PARTY_KEY,PARTY_SSOT_PARTY_ID_INT FROM $$COMREFVWDB.N_PARTY  WHERE SS_CODE IN('CR','CR_MODS'))NP\r\nON NP.PARTY_SSOT_PARTY_ID_INT = EX.CUSTOMER_ID\r\nAND EX.CUSTOMER_TYPE='ENDUSER'\r\nINNER JOIN\r\n$$SLSORDVWDB.N_DISTRIBUTOR_PROMOTION NDP\r\nON NDP.SK_PROMO_ID_INT = EX.PROMO_ID\r\nWHERE EX.CUSTOMER_ID IS NOT NULL\r\nAND NP.PARTY_KEY IS NOT NULL\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY CUSTOMER_PARTY_KEY ,\r\nBK_PROMOTION_NUM ,BK_PROMOTION_REVISION_NUM_INT ,BK_PROMOTION_TYPE_CD ORDER BY EX.LAST_UPDATE_DATE DESC) =1",
        "User Defined Join": "",
        "Source Filter": "",
