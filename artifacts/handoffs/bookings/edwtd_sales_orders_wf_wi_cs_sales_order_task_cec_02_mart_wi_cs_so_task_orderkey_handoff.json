      "attributes": {
        "Sql Query": "SELECT \r\nSCSOT.CS_SALES_ORDER_TASK_KEY,\r\nWCSTOK.SALES_ORDER_KEY ,\r\nWCSTOK.BK_CS_SALES_ORDER_TASK_TYPE_CD,\r\nWCSTOK.CS_SO_TASK_STATUS_CD,          \r\nWCSTOK.CS_SO_TASK_CREATED_DTM, \r\nWCSTOK.SK_ORDER_TASK_ID_INT,         \r\nWCSTOK.SS_CD,                         \r\nWCSTOK.CS_SO_TASK_OBSOLETE_FLG ,      \r\nWCSTOK.CS_SALES_ORDER_TASK_TXT,       \r\nWCSTOK.ORDER_NUMBER,                  \r\nWCSTOK.EC_HEADER_ID ,                 \r\nWCSTOK.ERP_HEADER_ID,                 \r\nWCSTOK.EC_LINE_ID ,\r\nSOCL.ERP_LINE_ID \r\nFROM\r\n$$STGDB.WI_CS_SO_TASK_ORDERKEY WCSTOK\r\nLEFT OUTER JOIN\r\n$$STGDB.ST_OM_CEC_LINES  SOCL\r\nON\r\nWCSTOK.EC_LINE_ID = SOCL.EC_LINE_ID AND\r\nWCSTOK.SS_CD = CASE WHEN SOCL.GLOBAL_NAME = 'UO' THEN 'QTC' WHEN SOCL.GLOBAL_NAME='BO' THEN 'BV' END\r\nINNER JOIN\r\n$$ETLVWDB.SM_CS_SALES_ORDER_TASK  SCSOT\r\nON\r\nWCSTOK.SK_ORDER_TASK_ID_INT = SCSOT.SK_ORDER_TASK_ID_INT\r\nAND\r\nWCSTOK.SS_CD = SCSOT.SS_CD\r\nAND\r\nSCSOT.SS_TABLE_CD = 'CEC'",
