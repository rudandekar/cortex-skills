      "attributes": {
        "Sql Query": "SELECT\r\n CAST(EL.SALES_ORDER_LINE_KEY AS INTEGER ) AS SALES_ORDER_LINE_KEY\r\n,EL.REVENUE_SOURCE_CODE AS SRC_REPORTED_REV_SRC_CD\r\n,-999 AS SERVICE_QUOTE_LINE_KEY\r\n,EL.ID AS SK_UNIQUE_ID_INT\r\n,EL.BOOKING_FLAG AS DSV_BOOKINGS_FLG\r\n,EL.ACTIVE_FLAG AS ACTIVE_FLG\r\n,EL.CREATED_BY AS CRTD_TAGGING_RULE_PROCESS_NM\r\n,EL.LAST_UPDATED_BY AS UPD_TAGGING_RULE_PROCESS_NM\r\n,EL.DERIVED_QUOTE_NUMBER AS SRC_REPORTED_QUOTE_NUM\r\n,EL.DERIVED_CONTRACT_NUMBER AS SRC_REPORTED_CONTRACT_NUM\r\n,EL.MATCH_TYPE AS MATCHING_METHOD_FOR_TAGGING_NM\r\n,EL.ORDER_HEADER_ID AS SRC_REPORTED_SLS_ORD_HEADER_ID\r\n,EL.QUOTE_HEADER_ID AS SRC_REPORTED_QUOTE_HEADER_ID\r\n,CAST(EL.DV_ALLOCATION_PCT AS DECIMAL(18,2)) AS DV_SPLIT_ALLOCATION_PCT\r\n,CAST(EL.SS_CODE AS VARCHAR(7)) AS SS_CODE \r\n,EL.TRANS_ID AS BK_POS_TRANSACTION_ID_INT\r\n,EL.START_TV_DTM AS START_TV_DTM\r\n,EL.END_TV_DTM AS END_TV_DTM\r\n,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM\r\n,CURRENT_USER AS EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM\r\n,CURRENT_USER AS EDW_UPDATE_USER\r\n,'I' AS ACTION_CODE\r\n,'I' AS DML_TYPE\r\nFROM $$ETLVWDB.EL_POS_TRX_LN_AS_NEW_OR_RNWL_ALL EL \r\nINNER JOIN $$STGDB.WI_POS_TRX_LN_TO_SOL_LINK WI\r\nON WI.TRANS_ID = EL.TRANS_ID\r\nWHERE EL.END_TV_DTM = '3500-01-01 00:00:00'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY SALES_ORDER_LINE_KEY,BK_POS_TRANSACTION_ID_INT ORDER BY START_TV_DTM DESC, EDW_UPDATE_DTM DESC)=1",
        "User Defined Join": "",
