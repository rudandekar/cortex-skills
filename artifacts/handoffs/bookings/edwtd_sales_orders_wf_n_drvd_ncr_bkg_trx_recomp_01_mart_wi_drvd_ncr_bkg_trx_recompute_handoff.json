      "attributes": {
        "Sql Query": "SELECT \r\n WDNBTR_CURR_MON.DRVD_NCR_BKG_TRX_KEY,\r\n WDNBTR_CURR_MON.SALES_ORDER_LINE_KEY,\r\n WDNBTR_CURR_MON.SALES_ORDER_KEY,\r\n WDNBTR_CURR_MON.PROCESS_DATE,\r\n WDNBTR_CURR_MON.DD_ITEM_TYPE_CODE_FLAG,\r\n WDNBTR_CURR_MON.DD_RMA_FLAG,\r\n WDNBTR_CURR_MON.DD_INTERNATIONAL_DEMO_FLAG,\r\n WDNBTR_CURR_MON.DD_REPLACEMENT_DEMO_FLAG,\r\n WDNBTR_CURR_MON.DD_REVENUE_FLAG,\r\n WDNBTR_CURR_MON.DD_OVERLAY_FLAG,\r\n WDNBTR_CURR_MON.DD_SALESREP_FLAG,\r\n WDNBTR_CURR_MON.DD_IC_REVENUE_FLAG,\r\n WDNBTR_CURR_MON.DD_CHARGES_FLAG,\r\n WDNBTR_CURR_MON.DD_MISC_FLAG,\r\n WDNBTR_CURR_MON.DD_ACQUISITION_FLAG,\r\n WDNBTR_CURR_MON.DD_SERVICE_FLAG,\r\n WDNBTR_CURR_MON.DD_REV_REC_FLAG,\r\n WDNBTR_CURR_MON.ORIG_REV_REC_FLAG,\r\n CURRENT_TIMESTAMP(0) EDW_CREATEDATETIME,\r\n USER EDW_CREATE_USER\r\n FROM $$STGDB.WI_DRVD_NCR_BKG_TRX_RECOMP_INT  WDNBTR_ORIG,\r\n (SELECT \r\n  WDNBTR.DRVD_NCR_BKG_TRX_KEY    DRVD_NCR_BKG_TRX_KEY,\r\n  WDNBTR.SALES_ORDER_LINE_KEY    SALES_ORDER_LINE_KEY,\r\n  WDNBTR.SALES_ORDER_KEY     SALES_ORDER_KEY,\r\n       WDNBTR.PROCESS_DATE                       PROCESS_DATE,\r\n  WDNBTR.DD_ITEM_TYPE_CODE_FLAG    DD_ITEM_TYPE_CODE_FLAG,\r\n  WDNBTR.DD_RMA_FLAG     DD_RMA_FLAG,\r\n  WDNBTR.DD_INTERNATIONAL_DEMO_FLAG   DD_INTERNATIONAL_DEMO_FLAG,\r\n  WDNBTR.DD_REPLACEMENT_DEMO_FLAG   DD_REPLACEMENT_DEMO_FLAG,\r\n  WDNBTR.DD_REVENUE_FLAG      DD_REVENUE_FLAG,\r\n  WDNBTR.DD_OVERLAY_FLAG      DD_OVERLAY_FLAG,\r\n  WDNBTR.DD_SALESREP_FLAG     DD_SALESREP_FLAG,\r\n  WDNBTR.DD_IC_REVENUE_FLAG     DD_IC_REVENUE_FLAG,\r\n  WDNBTR.DD_CHARGES_FLAG      DD_CHARGES_FLAG,\r\n  WDNBTR.DD_MISC_FLAG      DD_MISC_FLAG,\r\n  WDNBTR.DD_ACQUISITION_FLAG     DD_ACQUISITION_FLAG,\r\n  WDNBTR.DD_SERVICE_FLAG      DD_SERVICE_FLAG,\r\n  WDNBTR.ORIG_REV_REC_FLAG     ORIG_REV_REC_FLAG,\r\n  CASE WHEN \r\n  WDNBTR.DD_ITEM_TYPE_CODE_FLAG= 'Y' OR \r\n  WDNBTR.DD_RMA_FLAG = 'Y'  OR \r\n  WDNBTR.DD_INTERNATIONAL_DEMO_FLAG = 'Y' OR\r\n  WDNBTR.DD_REPLACEMENT_DEMO_FLAG = 'Y' OR \r\n  WDNBTR.DD_REVENUE_FLAG = 'N' OR \r\n  WDNBTR.DD_OVERLAY_FLAG='Y' OR\r\n   WDNBTR.DD_SALESREP_FLAG ='Y'  OR \r\n  WDNBTR.DD_IC_REVENUE_FLAG='N' OR \r\n  WDNBTR.DD_CHARGES_FLAG='Y' OR \r\n  WDNBTR.DD_MISC_FLAG='Y' OR \r\n  WDNBTR.DD_ACQUISITION_FLAG='Y' OR \r\n  NP.DIVESTITURE_TYPE_CD <> 'UNKNOWN' OR \r\n  ( NP.GOODS_OR_SERVICE_TYPE = 'GOODS' AND NPF.BK_BUSINESS_UNIT_ID ='CDBU' AND ELC.ENABLE_FLAG ='Y' )  OR\r\n  COALESCE ( NSOT.SALES_ORDER_SOURCE_TYPE_CD, 'UNKNOWN' ) = 'REFRESH EXCESS PORTAL' THEN 'N' ELSE 'Y' END  DD_REV_REC_FLAG\r\n FROM $$STGDB.WI_DRVD_NCR_BKG_TRX_RECOMP_INT WDNBTR\r\n \r\n /* EXCESS ORDER Changes from CAPITAL REFRESH GROUP STARTS */ \r\nLEFT JOIN $$NRTNCRVWDB.N_SALES_ORDER_NRT NSOT ON NSOT.SALES_ORDER_KEY=WDNBTR.SALES_ORDER_KEY\r\n/* EXCESS ORDER Changes from CAPITAL REFRESH GROUP ENDS */ \r\n \r\n INNER JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE_TV NSOL\r\n ON WDNBTR.SALES_ORDER_LINE_KEY = NSOL.SALES_ORDER_LINE_KEY\r\n \r\n INNER JOIN $$COMREFVWDB.N_PRODUCT NP\r\n ON NP.ITEM_KEY = NSOL.PRODUCT_KEY\r\n  \r\n LEFT JOIN $$COMREFVWDB.N_PRODUCT_FAMILY NPF      \r\n ON NP.RU_BK_PRODUCT_FAMILY_ID = NPF.BK_PRODUCT_FAMILY_ID\r\n\r\n LEFT JOIN $$ETLVWDB.EL_CDBU ELC  /* NP, NPF and ELC Joins added as part of Q2FY16 - CDBU - SA (Scientific Atlanta) Changes for CORP BOOKINGS FLAG, REVENUE RECOGNITION FLAG and NET SPREAD FLAG Columns */\r\n ON NPF.BK_BUSINESS_UNIT_ID = ELC.BK_BUSINESS_UNIT_ID\r\n AND NP.GOODS_OR_SERVICE_TYPE = ELC.GOODS_OR_SERVICE_TYPE) WDNBTR_CURR_MON\r\n\r\n WHERE \r\n WDNBTR_ORIG.DRVD_NCR_BKG_TRX_KEY=WDNBTR_CURR_MON.DRVD_NCR_BKG_TRX_KEY \r\n AND WDNBTR_ORIG.ORIG_REV_REC_FLAG<>WDNBTR_CURR_MON.DD_REV_REC_FLAG\r\n /* Modified Part of True Demand replaced corp bkg flag with rev rec flag */",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
