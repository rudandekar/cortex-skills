        "Sql Query": "SELECT \r\nSCOLEC.LINE_ID,\r\nSCOLEC.END_CUSTOMER_SITE_USE_ID,\r\nSCOLEC.END_CUSTOMER_ID,                      \r\nSCOLEC.SOURCE_COMMIT_TIME,\r\n'CG' GLOBAL_NAME,\r\n'RI' EXCEPTION_TYPE,\r\nSCOLEC.END_CUSTOMER_CONTACT_ID /*ADDED AS PART OF 9 APRIL 2017 RELEASE*/\r\nFROM  \r\n\t$$STGDB.ST_CG1_OE_LINES_END_CUST SCOLEC\r\n\tWHERE \r\n\t(NOT EXISTS (SELECT 1 FROM $$ETLVWDB.SM_SALES_ORDER_LINE SSOL\r\n\t\t\t\tINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC_SOL\r\n\t\t\t\tON( NSSC_SOL.SOURCE_SYSTEM_CODE=SSOL.SS_CODE)\r\n\t\t\t\tWHERE COALESCE(SCOLEC.LINE_ID,-9999)=SSOL.SK_SO_LINE_ID_INT AND NSSC_SOL.GLOBAL_NAME='CG')\r\n\tOR \r\n\tNOT EXISTS (SELECT 1 FROM $$COMREFVWDB.N_ERP_CUST_ACCT_LOC_USE NECAL_SHIP\r\n\t\t\t\tWHERE SCOLEC.END_CUSTOMER_SITE_USE_ID=NECAL_SHIP.SK_SITE_USE_ID_INT )\r\n\tOR \r\n\tNOT EXISTS (SELECT 1 FROM $$COMREFVWDB.N_CUSTOMER_ACCOUNT  NCAT_SOLD\r\n\t\t\t\tWHERE SCOLEC.END_CUSTOMER_ID=NCAT_SOLD.SK_CUSTOMER_ACCOUNT_ID_INT  ))\r\n\tAND LINE_ID IS NOT NULL\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY SCOLEC.LINE_ID ORDER BY SCOLEC.SOURCE_COMMIT_TIME DESC) = 1",
