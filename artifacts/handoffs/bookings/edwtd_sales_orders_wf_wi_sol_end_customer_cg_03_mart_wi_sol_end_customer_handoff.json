      ],
      "attributes": {
        "Sql Query": "SELECT \r\nNSOLT.SALES_ORDER_LINE_KEY  SALES_ORDER_LINE_KEY,\r\nECH.END_CUSTOMER_KEY END_CUSTOMER_KEY,\r\nECH.END_CUSTOMER_TYPE_CODE END_CUSTOMER_TYPE_CODE,\r\nECH.SS_CODE SS_CODE,\r\nECH.END_CUSTOMER_ASSGN_LEVEL END_CUSTOMER_ASSGN_LEVEL,\r\nECH.EDW_SOURCE_COMMIT_TIME EDW_SOURCE_COMMIT_TIME,\r\nNSOLT.RU_PARNT_SLS_ORDER_LINE_KEY   \r\nFROM \r\n$$SLSORDVWDB.N_SALES_ORDER_LINE NSOLT,\r\n( \r\nSELECT  \r\nSSO.SALES_ORDER_KEY SALES_ORDER_KEY, \r\nCASE WHEN SCOHEC.END_CUSTOMER_SITE_USE_ID =-999 \r\nTHEN COALESCE(NCAT_SOLD.CUSTOMER_ACCOUNT_KEY,-999)\r\nELSE  \r\nCOALESCE(NECAL_SHIP.ERP_CUST_ACCOUNT_LOCATION_KEY,-999) \r\nEND END_CUSTOMER_KEY,\r\nCASE WHEN SCOHEC.END_CUSTOMER_SITE_USE_ID =-999 \r\nTHEN 'ACCOUNT' \r\nELSE 'ACCOUNT_LOCATION' END END_CUSTOMER_TYPE_CODE,\r\nSCOHEC.SOURCE_COMMIT_TIME EDW_SOURCE_COMMIT_TIME,\r\nNSSC.SOURCE_SYSTEM_CODE SS_CODE,\r\n'HEADER' END_CUSTOMER_ASSGN_LEVEL\r\nFROM  \r\n$$STGDB.ST_CG1_OE_HEADERS_END_CUST SCOHEC\r\nINNER JOIN (\r\n$$ETLVWDB.SM_SALES_ORDER SSO \r\nINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC_SOL\r\nON( NSSC_SOL.SOURCE_SYSTEM_CODE= SSO.SS_CODE)\r\n)\r\nON ( SCOHEC.HEADER_ID=SSO.SK_SALES_ORDER_HEADER_ID_INT AND NSSC_SOL.GLOBAL_NAME='CG' )\r\nINNER JOIN $$COMREFVWDB.N_ERP_CUST_ACCT_LOC_USE NECAL_SHIP\r\n           ON ( SCOHEC.END_CUSTOMER_SITE_USE_ID=NECAL_SHIP.SK_SITE_USE_ID_INT ) \r\nINNER JOIN $$COMREFVWDB.N_CUSTOMER_ACCOUNT  NCAT_SOLD\r\nON( SCOHEC.END_CUSTOMER_ID=NCAT_SOLD.SK_CUSTOMER_ACCOUNT_ID_INT  ) \r\nINNER JOIN  $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC \r\nON(NSSC.GLOBAL_NAME='CG') \r\n           QUALIFY ROW_NUMBER() OVER(PARTITION BY SCOHEC.HEADER_ID ORDER BY SCOHEC.SOURCE_COMMIT_TIME DESC) = 1) ECH \r\nWHERE\r\nNSOLT.SALES_ORDER_KEY=ECH.SALES_ORDER_KEY\r\nAND \r\nNOT EXISTS \r\n(SELECT 1 FROM $$SLSORDVWDB.N_SOL_END_CUSTOMER NSECT\r\nWHERE\r\nNSOLT.SALES_ORDER_LINE_KEY= NSECT.SALES_ORDER_LINE_KEY AND\r\nNSECT.END_CUSTOMER_ASSGN_LEVEL='LINE'\r\n)\r\nAND NOT EXISTS\r\n(SELECT 1 FROM $$WORKDB.WI_SOL_END_CUSTOMER WSEC\r\nWHERE\r\nNSOLT.SALES_ORDER_LINE_KEY=  WSEC.SALES_ORDER_LINE_KEY AND\r\nWSEC.END_CUSTOMER_ASSGN_LEVEL='LINE'\r\n)",
        "User Defined Join": "",
