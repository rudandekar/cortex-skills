      ],
      "attributes": {
        "Sql Query": "SELECT \r\nNSOLT.SALES_ORDER_LINE_KEY  SALES_ORDER_LINE_KEY,\r\nECPL.END_CUSTOMER_KEY END_CUSTOMER_KEY,\r\nECPL.END_CUSTOMER_TYPE_CODE                          END_CUSTOMER_TYPE_CODE,\r\nECPL.SS_CODE                                                                                   SS_CODE,\r\nECPL.END_CUSTOMER_ASSGN_LEVEL                     END_CUSTOMER_ASSGN_LEVEL,\r\nECPL.EDW_CREATE_DATETIME                                   EDW_CREATE_DATETIME,\r\nNSOLT.RU_PARNT_SLS_ORDER_LINE_KEY,\r\nECPL.END_CUST_ERP_CNTCT_PRTY_KEY/*ADDED AS PART OF 9 APRIL 2017 RELEASE*/\r\nFROM \r\n$$SLSORDVWDB.N_SALES_ORDER_LINE NSOLT, \r\n(\r\nSELECT  \r\nSSOL.SALES_ORDER_LINE_KEY SALES_ORDER_LINE_KEY,                \r\nCASE WHEN SCOLEC.END_CUSTOMER_SITE_USE_ID =-999 THEN COALESCE(NCAT_SOLD.CUSTOMER_ACCOUNT_KEY,-999) ELSE COALESCE(NECAL_SHIP.ERP_CUST_ACCOUNT_LOCATION_KEY,-999) END END_CUSTOMER_KEY,\r\nCASE WHEN SCOLEC.END_CUSTOMER_SITE_USE_ID =-999 THEN 'ACCOUNT' ELSE 'ACCOUNT_LOCATION' END END_CUSTOMER_TYPE_CODE,\r\nSCOLEC.SOURCE_COMMIT_TIME  EDW_CREATE_DATETIME,\r\nNSSC.SOURCE_SYSTEM_CODE SS_CODE,\r\n'LINE' END_CUSTOMER_ASSGN_LEVEL,\r\nCOALESCE(NPPT_END.ERP_CONTACT_PARTY_KEY, -999) END_CUST_ERP_CNTCT_PRTY_KEY/*ADDED AS PART OF 9 APRIL 2017 RELEASE */\r\nFROM  \r\n$$STGDB.ST_CG1_OE_LINES_END_CUST SCOLEC\r\nINNER JOIN \r\n(\r\n$$ETLVWDB.SM_SALES_ORDER_LINE SSOL \r\nINNER JOIN \r\n$$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC_SOL\r\nON\r\n( NSSC_SOL.SOURCE_SYSTEM_CODE= SSOL.SS_CODE)\r\n)\r\nON         \r\n( SCOLEC.LINE_ID=SSOL.SK_SO_LINE_ID_INT       AND       NSSC_SOL.GLOBAL_NAME='CG' )\r\nINNER JOIN \r\n$$COMREFVWDB.N_ERP_CUST_ACCT_LOC_USE NECAL_SHIP\r\nON         \r\n( SCOLEC.END_CUSTOMER_SITE_USE_ID=NECAL_SHIP.SK_SITE_USE_ID_INT )       \r\nINNER JOIN \r\n$$COMREFVWDB.N_CUSTOMER_ACCOUNT NCAT_SOLD\r\nON\r\n( SCOLEC.END_CUSTOMER_ID=NCAT_SOLD.SK_CUSTOMER_ACCOUNT_ID_INT  ) \r\nINNER JOIN  \r\n$$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC \r\nON(NSSC.GLOBAL_NAME='CG') \r\n/*START \r\nADDED AS PART OF 9 APRIL 2017 RELEASE */\r\nLEFT OUTER JOIN \r\n( SEL ERP_CONTACT_PARTY_KEY,ERP_CONTACT_ID,CUST_SVC_CUST_CONTACT_ROLE,COMMERCE_CONTACT_ROLE\r\nFROM $$COMREFVWDB.N_ERP_CONTACT_PARTY NPPT_END  JOIN $$STGDB.ST_CG1_OE_LINES_END_CUST SCOLEC\r\nON  ( NPPT_END.ERP_CONTACT_ID = SCOLEC.END_CUSTOMER_CONTACT_ID    \r\nAND       NPPT_END.CUST_SVC_CUST_CONTACT_ROLE <> 'Y' )\r\nAND SCOLEC.END_CUSTOMER_CONTACT_ID IS NOT NULL \r\nGROUP BY 1,2,3,4\r\n) NPPT_END\r\nON          ( NPPT_END.ERP_CONTACT_ID = SCOLEC.END_CUSTOMER_CONTACT_ID  \r\nAND       NPPT_END.CUST_SVC_CUST_CONTACT_ROLE <> 'Y' )\r\n/*END \r\nADDED AS PART OF 9 APRIL 2017 RELEASE */\r\n QUALIFY ROW_NUMBER() OVER(PARTITION BY SCOLEC.LINE_ID ORDER BY SCOLEC.SOURCE_COMMIT_TIME DESC) = 1 ) ECPL\r\nWHERE ECPL.SALES_ORDER_LINE_KEY=NSOLT.RU_PARNT_SLS_ORDER_LINE_KEY",
        "User Defined Join": "",
