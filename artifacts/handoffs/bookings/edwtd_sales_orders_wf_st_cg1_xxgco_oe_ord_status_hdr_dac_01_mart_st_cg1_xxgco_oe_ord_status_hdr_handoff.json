      "attributes": {
        "Sql Query": "SELECT\r\nCG1_XXGCO_OE_ORDER_STATUSES.HEADER_ID HEADER_ID,                     \r\nCG1_XXGCO_OE_ORDER_STATUSES.LINE_ID LINE_ID,                       \r\nCG1_XXGCO_OE_ORDER_STATUSES.STATUS_RESULT_CODE STATUS_RESULT_CODE,            \r\nCG1_XXGCO_OE_ORDER_STATUSES.STATUS_RESULT_DATE STATUS_RESULT_DATE,            \r\nCG1_XXGCO_OE_ORDER_STATUSES.CREATED_PROGRAM_NAME CREATED_PROGRAM_NAME,          \r\nCG1_XXGCO_OE_ORDER_STATUSES.PROGRAM_ID PROGRAM_ID,                    \r\nCG1_XXGCO_OE_ORDER_STATUSES.REQUEST_ID REQUEST_ID,                    \r\nCG1_XXGCO_OE_ORDER_STATUSES.ORG_ID ORG_ID,                        \r\nCG1_XXGCO_OE_ORDER_STATUSES.CREATION_DATE CREATION_DATE,                 \r\nCG1_XXGCO_OE_ORDER_STATUSES.CREATED_BY CREATED_BY,                    \r\nCG1_XXGCO_OE_ORDER_STATUSES.LAST_UPDATE_DATE LAST_UPDATE_DATE,              \r\nCG1_XXGCO_OE_ORDER_STATUSES.LAST_UPDATED_BY LAST_UPDATED_BY,               \r\nCG1_XXGCO_OE_ORDER_STATUSES.LAST_UPDATE_LOGIN LAST_UPDATE_LOGIN,             \r\nCG1_XXGCO_OE_ORDER_STATUSES.SOURCE_COMMIT_TIME SOURCE_COMMIT_TIME,            \r\n'CG' GLOBAL_NAME\r\nFROM $$NRTACCUMVWDB.CG1_XXGCO_OE_ORDER_STATUSES CG1_XXGCO_OE_ORDER_STATUSES,$$COMREFVWDB.N_CISCO_OPERATING_UNIT NCOU\r\nWHERE\r\nCG1_XXGCO_OE_ORDER_STATUSES.ORG_ID = NCOU.SK_ORGANIZATION_ID_INT\r\nAND NCOU.MOVED_TO_CG1_FLG  = 'Y'      \r\nAND CG1_XXGCO_OE_ORDER_STATUSES.SOURCE_COMMIT_TIME >= '$$LastExtractDate' \r\nAND CG1_XXGCO_OE_ORDER_STATUSES.SOURCE_COMMIT_TIME < '$$EndLastExtractDate' \r\nAND CG1_XXGCO_OE_ORDER_STATUSES.LINE_ID IS NULL\r\nAND CG1_XXGCO_OE_ORDER_STATUSES.STATUS_RESULT_CODE IN ('CLOSED','CANCELLED')\r\nAND CG1_XXGCO_OE_ORDER_STATUSES.SOURCE_DML_TYPE <> 'DELETE'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY CG1_XXGCO_OE_ORDER_STATUSES.HEADER_ID,CG1_XXGCO_OE_ORDER_STATUSES.STATUS_RESULT_CODE ORDER BY CG1_XXGCO_OE_ORDER_STATUSES.REFRESH_DATETIME DESC) = 1",
