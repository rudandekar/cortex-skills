      "attributes": {
        "Sql Query": "SELECT \r\nFISCAL_YEAR_NUMBER_INT        ,\r\nFISCAL_YEAR_QUARTER_NUMBER_INT,\r\nDV_FISCAL_YEAR_MTH_NUMBER_INT ,\r\nFISCAL_YEAR_WEEK_NUM_INT      ,\r\nBOOKINGS_MEASURE_KEY          ,\r\nBKGS_MEASURE_TRANS_TYPE_CODE  ,\r\nBOOKINGS_PROCESS_DATE         ,\r\nSALES_TERRITORY_KEY           ,\r\nSALES_REP_NUMBER              ,\r\nDV_SOURCE_ORDER_NUM_INT       ,\r\nPRODUCT_KEY                   ,\r\nDV_PRODUCT_KEY                ,\r\nCORPORATE_BOOKINGS_FLG        ,\r\nDV_REVENUE_RECOGNITION_FLG    ,\r\nDV_BKG_GROSS_MGN_AMOUNT       ,\r\nDV_BKG_REBATE_AMT             ,\r\nDV_BGM_FX_COST_AMOUNT         ,\r\nDV_FX_NET_PRICE_AMT           ,\r\nDV_FX_REBATE_PRICE_AMT        ,\r\nTSS_COUNTRY_FACTOR_KEY        ,\r\n'I' AS ACTION_CODE            ,\r\n'I' AS DML_TYPE                      \r\nFROM $$STGDB.WI_RSTD_TSS_BGM BGM\r\nWHERE NOT EXISTS (SELECT  1\r\nFROM $$SLSORDVWDB.MT_RSTD_TSS_BGM MTRSTD\r\nWHERE  BGM.BOOKINGS_MEASURE_KEY =MTRSTD.BOOKINGS_MEASURE_KEY\r\nAND BGM.BKGS_MEASURE_TRANS_TYPE_CODE = MTRSTD.BKGS_MEASURE_TRANS_TYPE_CODE\r\nAND BGM.BOOKINGS_PROCESS_DATE = MTRSTD.BOOKINGS_PROCESS_DATE\r\nAND BGM.SALES_TERRITORY_KEY = MTRSTD.SALES_TERRITORY_KEY\r\nAND BGM.SALES_REP_NUMBER = MTRSTD.SALES_REP_NUMBER\r\nAND BGM.FISCAL_YEAR_QUARTER_NUMBER_INT= MTRSTD.FISCAL_YEAR_QUARTER_NUMBER_INT\r\n)",
