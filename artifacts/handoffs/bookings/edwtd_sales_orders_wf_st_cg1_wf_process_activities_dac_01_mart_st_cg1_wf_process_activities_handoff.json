      "attributes": {
        "Sql Query": "SELECT \r\nCWPA.ACTIVITY_ITEM_TYPE,\r\nCWPA.ACTIVITY_NAME,\r\nCWPA.CUSTOM_LEVEL,\r\nCWPA.DEFAULT_RESULT,\r\nCWPA.ICON_GEOMETRY,\r\nCWPA.INSTANCE_ID,\r\nCWPA.INSTANCE_LABEL,\r\nCWPA.PERFORM_ROLE,\r\nCWPA.PERFORM_ROLE_TYPE,\r\nCWPA.PROCESS_ITEM_TYPE,\r\nCWPA.PROCESS_NAME,\r\nCWPA.PROCESS_VERSION,\r\nCWPA.PROTECT_LEVEL,\r\nCWPA.SECURITY_GROUP_ID,\r\nCWPA.START_END,\r\nCWPA.USER_COMMENT,\r\nCWPA.SOURCE_COMMIT_TIME,\r\n'CG' GLOBAL_NAME \r\nFROM \r\n$$NRTACCUMVWDB.CG1_WF_PROCESS_ACTIVITIES CWPA\r\nWHERE\r\nCWPA.SOURCE_COMMIT_TIME >= '$$LastExtractDate' AND CWPA.SOURCE_COMMIT_TIME < '$$EndLastExtractDate' \r\nAND\r\nCWPA.SOURCE_DML_TYPE <> 'DELETE'\r\nAND \r\nACTIVITY_ITEM_TYPE  IN ('OEOH','OEOL')\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY CWPA.INSTANCE_ID ORDER BY CWPA.REFRESH_DATETIME DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
