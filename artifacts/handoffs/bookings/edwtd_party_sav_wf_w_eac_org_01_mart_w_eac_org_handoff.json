      "attributes": {
        "Sql Query": "SELECT \r\nST.ORGANIZATION_ID, \r\nCOALESCE(ST.ORGANIZATION_NAME,'UNKNOWN'),\r\nCOALESCE(ST.START_DATE,CAST('3500-01-01' AS DATE)),\r\nCOALESCE(ST.END_DATE,CAST('3500-01-01' AS DATE)),\r\nCOALESCE(ST.CREATION_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))),\r\nCOALESCE(ST.CREATION_DATE,CAST('3500-01-01' AS DATE)) AS DV_SRC_CREATED_DT,\r\nCOALESCE(NCWP_CRTD.CISCO_WORKER_PARTY_KEY,-999) AS CRTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE(NCWP_UPDT.CISCO_WORKER_PARTY_KEY,-999) AS LST_UPTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE(ST.LAST_UPDATED_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))),\r\nCOALESCE(ST.LAST_UPDATED_DATE,CAST('3500-01-01' AS DATE)) AS DV_SRC_LAST_UPTD_DT,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\n'I' ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM\r\n$$STGDB.ST_XXFSAM_ORG_V ST\r\nLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP_CRTD\r\nON COALESCE(ST.CREATED_BY,'UNKNOWN') = NCWP_CRTD.CEC_ID AND NCWP_CRTD.CISCO_WORKER_PARTY_KEY<>-999\r\nLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP_UPDT\r\nON COALESCE(ST.LAST_UPDATED_BY,'UNKNOWN') = NCWP_UPDT.CEC_ID AND NCWP_UPDT.CISCO_WORKER_PARTY_KEY<>-999",
        "User Defined Join": "",
