      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\nST.SALES_ORDER_KEY,\r\nST.BK_AS_QUOTE_NUM,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nST.SS_CD,\r\n'I' AS ACTION_CODE,\r\n CASE WHEN NQ.SALES_ORDER_KEY IS NULL AND NQ.BK_AS_QUOTE_NUM IS NULL\r\n      THEN 'I'\r\n      ELSE 'U'\r\n END AS DML_TYPE\r\nFROM $$STGDB.ST_SALES_ORDER_AS_QUOTE_LINK_HDP  ST\r\n LEFT OUTER JOIN\r\n$$SERVICEVWDB.N_SALES_ORDER_AS_QUOTE_LINK NQ\r\nON  ST.SALES_ORDER_KEY = NQ.SALES_ORDER_KEY\r\nAND ST.BK_AS_QUOTE_NUM = NQ.BK_AS_QUOTE_NUM\r\nAND NQ.SS_CD = ST.SS_CD",
