      "attributes": {
        "Sql Query": "SELECT  SALES_ORDER_LINE_KEY , SALES_MOTION_TIMING_CD , SALES_MOTION_CD  , CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM FROM  $$SLSORDVWDB.N_ATTR_PRDT_AS_NEW_OR_RNWL_TV \r\n WHERE  SALES_MOTION_CD = 'RENEW'\r\n AND  END_TV_DTM  = '3500-01-01 00:00:00'\r\n AND SALES_ORDER_LINE_KEY >0\r\n AND SALES_MOTION_TIMING_CD  IS NOT  NULL \r\n AND EDW_UPDATE_DTM >'$$lastextractdate'\r\n QUALIFY ROW_NUMBER()  OVER  (PARTITION BY  SALES_ORDER_LINE_KEY ORDER BY SALES_ORDER_LINE_KEY DESC, \r\n  (CASE  WHEN  SALES_MOTION_TIMING_CD = 'ONTIME' THEN 6  WHEN SALES_MOTION_TIMING_CD= 'LATE IN QUARTER'  THEN 5  WHEN  SALES_MOTION_TIMING_CD = 'EARLY'  THEN 4 WHEN SALES_MOTION_TIMING_CD = 'LATE' THEN 3 WHEN SALES_MOTION_TIMING_CD= 'RECAPTURE'  THEN  2 WHEN SALES_MOTION_TIMING_CD= 'UNKNOWN'  THEN  1 END )\r\n  DESC)= 1",
