      "attributes": {
        "Sql Query": "/*Servuce BOOKINGS PLAN  Summary Core*/\r\nSELECT \r\n  SCORECARD_ID , \r\n  METRIC_ID , \r\n  MEASURE_NAME , \r\n  HIERARCHY_TYPE , \r\n  AMOUNT_TYPE_DESC , \r\n  TIME_GRANULARITY_DESC , \r\n  FNL_QRY.FISCAL_QUARTER_NAME , \r\n  RFMY.FISCAL_QUARTER_ID , \r\n  HIERARCHY_VALUE , \r\n  ACQUISITION_SOURCE_GRP , \r\n  AMOUNT_VALUE_FMT , \r\n  AMOUNT_VALUE \r\nFROM \r\n( \r\n\t\tSELECT\r\n\t\t1 SCORECARD_ID,\r\n\t\t1001 METRIC_ID,\r\n\t\t'SERVICE BOOKINGS' AS MEASURE_NAME,\r\n\t\t'SUMMARY' AS HIERARCHY_TYPE,\r\n\t\t'PLAN' AS AMOUNT_TYPE_DESC,\r\n\t\t'QUARTERLY' TIME_GRANULARITY_DESC,\r\n\t\tT.FISCAL_QUARTER_NAME AS FISCAL_QUARTER_NAME,\r\n\t\t'SERVICE BOOKINGS' AS HIERARCHY_VALUE,\r\n\t\t'CORE' AS ACQUISITION_SOURCE_GRP,\r\n\t\tT.PLAN_AMOUNT AMOUNT_VALUE_FMT,\r\n\t\tT.PLAN_AMOUNT AS AMOUNT_VALUE\r\n\tFROM \r\n\t( \r\n\t\tSELECT \r\n\t\t\tFISCAL_QUARTER_NAME AS FISCAL_QUARTER_NAME, \r\n\t\t\tSUM(SALES_PLAN_USD_AMT) AS SALES_PLAN_USD_AMT,\r\n\t\t\tSUM(SALES_PLAN_USD_AMT) AS PLAN_AMOUNT \r\n\t\tFROM\r\n\t\t(\r\n\t\t\tSELECT \r\n\t\t\t\tRFMY.FISCAL_QUARTER_NAME AS FISCAL_QUARTER_NAME, \r\n\t\t\t\tRFMY.DV_FISCAL_QUARTER_ID , \r\n\t\t\t\tNLOVC.LOV_DESCRIPTION_TXT AS BOOKINGS_TYPE,\r\n\t\t\t\tRSH.L1_SALES_TERRITORY_DESCR  AS DIM_1, \r\n\t\t\t\tSUM(SP.SALES_PLAN_USD_AMT) AS SALES_PLAN_USD_AMT,\r\n\t\t\t\tSUM(SP.SALES_PLAN_USD_AMT) AS PLAN_AMOUNT \r\n\t\t\tFROM   \r\n\t\t\t\t$$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMY, \r\n\t\t\t\t$$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMTY , \r\n\t\t\t(\r\n\t\t\tSELECT \r\n\t\t\t\tCAST( (CASE\r\n\t\t\t\t\tWHEN RSPDT.BK_SALES_PLAN_TYPE_CD = 'PRODUCT' THEN 'PRODUCT' \r\n\t\t\t\t\tWHEN RSPDT.BK_SALES_PLAN_TYPE_CD = 'ADVISORY' THEN 'SERVICES' \r\n\t\t\t\t\tWHEN RSPDT.BK_SALES_PLAN_TYPE_CD = 'SUBSCRIPTION' THEN 'SERVICES' \r\n\t\t\t\t\tWHEN RSPDT.BK_SALES_PLAN_TYPE_CD = 'TRANSACTION' THEN 'SERVICES' \r\n\t\t\t\t\tWHEN RSPDT.BK_SALES_PLAN_TYPE_CD = 'CORE UNKNOWNS' THEN 'SERVICES' \r\n\t\t\t\t\tWHEN RSPDT.BK_SALES_PLAN_TYPE_CD = 'Ros' THEN 'REMOTE OPERATIONS SERVICES' \r\n\t\t\t\t\tWHEN RSPDT.BK_SALES_PLAN_TYPE_CD = 'Sa Services' THEN 'SCIENTIFIC ATLANTA' \r\n\t\t\t\t\tELSE'UNKNOWN' \r\n\t\t\t\t\tEND) AS VARCHAR(30) ) AS DV_FIN_CA_SERVICE_PRODUCT_CD, \r\n\t\t\t\tCAST( (CASE\r\n\t\t\t\t\tWHEN RSPDT.BK_SALES_PLAN_TYPE_CD = 'PRODUCT' THEN 'N'\r\n\t\t\t\t\tWHEN RSPDT.BK_SALES_PLAN_TYPE_CD = 'ADVISORY' THEN 'Y'\r\n\t\t\t\t\tWHEN RSPDT.BK_SALES_PLAN_TYPE_CD = 'SUBSCRIPTION'  THEN 'Y'\r\n\t\t\t\t\tWHEN RSPDT.BK_SALES_PLAN_TYPE_CD = 'TRANSACTION'    THEN 'Y'\r\n\t\t\t\t\tWHEN RSPDT.BK_SALES_PLAN_TYPE_CD = 'CORE UNKNOWNS'  THEN 'Y'\r\n\t\t\t\t\tWHEN RSPDT.BK_SALES_PLAN_TYPE_CD = 'Ros'  THEN 'Y'\r\n\t\t\t\t\tWHEN RSPDT.BK_SALES_PLAN_TYPE_CD = 'Sa Services'  THEN 'Y'\r\n\t\t\t\t\tELSE'UNKNOWN' \r\n\t\t\t\t\tEND) AS VARCHAR(30) )  AS DV_FIN_GOODS_OR_SERVICE_TYPE,\r\n\t\t\t\tRSPDT.BK_REPORTING_FSCL_MTH_NUM_INT , \r\n\t\t\t\tRSPDT.BK_REPORTING_FSCL_YR_NUM_INT , \r\n\t\t\t\tRSPDT.BK_SALES_TERRITORY_KEY , \r\n\t\t\t\tRSPDT.ACTUAL_PUBLICATION_DT, \r\n\t\t\t\tRSPDT.START_TV_DT , \r\n\t\t\t\tRSPDT.END_TV_DT , \r\n\t\t\t\tRSPDT.DD_PUBLICATION_FSCL_CLNDR_CD , \r\n\t\t\t\tRSPDT.DD_PUBLICATION_FSCL_YR_NUM_INT, \r\n\t\t\t\tRSPDT.DD_ACTIVE_FLG , \r\n\t\t\t\tRSPDT.SALES_PLAN_USD_AMT \r\n\t\t\tFROM \r\n\t\t\t\t$$SLSORDVWDB.N_SALES_PLAN_DETAIL_TV RSPDT\r\n\t\t\t) SP \r\n\t\t\tINNER JOIN $$COMREFSVDB.SV_SALES_HIERARCHY_FIN  RSH\r\n\t\t\t\tON RSH.SALES_TERRITORY_KEY = SP.BK_SALES_TERRITORY_KEY\r\n\t\t\tINNER JOIN $$COMREFVWDB.N_LIST_OF_VALUES_CHAR NLOVC\r\n\t\t\t\tON NLOVC. LOV_VALUE_CHAR  = SP. DV_FIN_GOODS_OR_SERVICE_TYPE  \r\n\t\t\tWHERE 1=1 \r\n\t\t\t\tAND NLOVC.LOV_DESCRIPTION_TXT = 'Service' \r\n\t\t\t\tAND\tNLOVC. LOV_APPLICATION_NAME  = 'ALL' \r\n\t\t\t\tAND\tNLOVC. LOV_NAME  = 'BOOKINGS_TYPE' \r\n\t\t\t\tAND ( \r\n\t\t\t\t\tRFMY.FISCAL_YEAR_NUMBER_INT = SP.BK_REPORTING_FSCL_YR_NUM_INT \r\n\t\t\t\tAND RFMY.FISCAL_MONTH_NUMBER_INT = SP.BK_REPORTING_FSCL_MTH_NUM_INT \r\n\t\t\t\tAND RFMY.FISCAL_YEAR_AGE IN (0,1,2) \r\n\t\t\t\tAND RFMTY.FISCAL_YEAR_NUMBER_INT = SP.DD_PUBLICATION_FSCL_YR_NUM_INT \r\n\t\t\t\tAND RFMTY.FISCAL_MONTH_NUMBER_INT = 12 \r\n\t\t\t\tAND SP.BK_REPORTING_FSCL_YR_NUM_INT = SP.DD_PUBLICATION_FSCL_YR_NUM_INT \r\n\t\t\t\tAND SP.DV_FIN_CA_SERVICE_PRODUCT_CD NOT IN ('PRODUCT','REMOTE OPERATIONS SERVICES','SCIENTIFIC ATLANTA','UNKNOWN' )\r\n\t\t\t\tAND RFMTY.FISCAL_MONTH_START_DATE BETWEEN SP.START_TV_DT AND SP.END_TV_DT \r\n\t\t\t\t) \r\n\t\t\tGROUP BY 1,2,3,4\r\n\t\t)X\r\n\t\tGROUP BY 1\r\n\t)T \r\n\t\r\n)FNL_QRY \r\nINNER JOIN (\r\n\tSELECT FISCAL_QUARTER_NAME,DV_FISCAL_QUARTER_ID AS FISCAL_QUARTER_ID \r\n\tFROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR WHERE FISCAL_YEAR_AGE IN (-1,0,1,2) \r\n\tGROUP BY 1,2\r\n\t)RFMY \r\nON RFMY.FISCAL_QUARTER_NAME = FNL_QRY.FISCAL_QUARTER_NAME",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "DELETE FROM $$STGDB.WI_AUTD_SCD_SRVC_BKGS_PLAN ALL;",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
  ],
