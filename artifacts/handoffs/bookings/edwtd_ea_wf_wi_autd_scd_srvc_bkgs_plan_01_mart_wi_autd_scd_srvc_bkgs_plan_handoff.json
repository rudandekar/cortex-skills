      "attributes": {
        "Sql Query": "/*SERVICE BOOKINGS TOTAL SUMMARY CORE*/\r\nSELECT \r\n\tSCORECARD_ID , \r\n\tMETRIC_ID , \r\n\tMEASURE_NAME , \r\n\tHIERARCHY_TYPE , \r\n\tAMOUNT_TYPE_DESC , \r\n\tTIME_GRANULARITY_DESC , \r\n\tFISCAL_QUARTER_NAME , \r\n\tFISCAL_QUARTER_ID , \r\n\tHIERARCHY_VALUE , \r\n\t'TOTAL'ACQUISITION_SOURCE_GRP , \r\n\tAMOUNT_VALUE_FMT , \r\n\tAMOUNT_VALUE  \r\nFROM\r\n$$STGDB.WI_AUTD_SCD_SRVC_BKGS_PLAN\r\n WHERE 1=1\t\t\t\t\t\t\t\t\t\t\r\n AND METRIC_ID = 1001\t\t\t\t\t\t\t\t\t\t\r\n AND HIERARCHY_TYPE = 'SUMMARY'\t\t\t\t\t\t\t\t\t\t\r\n AND ACQUISITION_SOURCE_GRP = 'CORE'",
