      "attributes": {
        "Sql Query": "SELECT 1  BATCH_ID,\r\nXOOC.HEADER_ID,\r\nCOALESCE(XOOC.LAST_NAME ,'UNKNOWN')   AS LAST_NAME  ,\r\nCOALESCE(XOOC.FIRST_NAME ,'UNKNOWN')   AS  FIRST_NAME  ,\r\nCOALESCE(XOOC.EMAIL_ADDRESS ,'UNKNOWN') AS EMAIL_ADDRESS ,\r\nXOOC.CREATION_DATE,\r\nXOOC.CREATED_BY,\r\nXOOC.LAST_UPDATED_BY ,\r\nXOOC.LAST_UPDATE_DATE, \r\nCOALESCE(XOOC.CONTACT_TYPE ,'UNKNOWN')            AS CONTACT_TYPE ,\r\nCOALESCE(XOOC.TELEPHONE ,'UNKNOWN')            AS TELEPHONE ,\r\nXOOC.SOURCE_DML_TYPE,\r\nXOOC.SOURCE_COMMIT_TIME,\r\nXOOC.REFRESH_DATETIME,\r\n'CG'  GLOBAL_NAME\r\nFROM     $$NRTACCUMVWDB.CG1_XXGCO_OE_ORD_CONT XOOC \r\nWHERE   XOOC.SOURCE_COMMIT_TIME >= '$$LastExtractDate' AND XOOC.SOURCE_COMMIT_TIME < '$$EndLastExtractDate'\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY XOOC.HEADER_ID,XOOC.LAST_NAME,XOOC.FIRST_NAME, XOOC.CONTACT_TYPE ORDER BY XOOC.REFRESH_DATETIME DESC  ) = 1",
        "User Defined Join": "",
        "Source Filter": "",
