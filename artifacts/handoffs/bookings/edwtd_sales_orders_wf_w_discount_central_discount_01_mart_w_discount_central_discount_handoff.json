      "attributes": {
        "Sql Query": "SELECT\r\nSCSDV.DISC_HEADER_ID AS BK_DSCNT_CENTRAL_DSCNT_ID_INT ,  \r\nSCSDV.VERSION_NUMBER AS BK_DSC_CNTRL_DSC_VRSN_NUM_INT ,\r\nSCSDV.CODE    AS DISCOUNT_CD,     \r\nSCSDV.NAME    AS DISCOUNT_NAME,           \r\nSCSDV.STD_DISC_TYPE AS DISCOUNT_PRODUCT_TYPE_CD,               \r\nSCSDV.STATUS AS DISCOUNT_STATUS_CD ,     \r\nSCSDV.SCENARIO AS PRICING_SCENARIO_TYPE_CD   ,  \r\nCASE \r\nWHEN COALESCE(SCSDV.EFFECTIVE_END_DATE,CAST('3500-01-01' AS DATE)) > CURRENT_DATE \r\nTHEN 'N' ELSE 'Y' \r\nEND AS SOURCE_DELETED_FLAG, \r\nSCSDV.DISC_TYPE AS DISCOUNT_TYPE_CD,  \r\nSCSDV.SALES_PATH          AS SALES_PATH_CD,\r\nCOALESCE(NCWP.CISCO_WORKER_PARTY_KEY ,-999) AS CRTD_BY_CISCO_WORKER_PARTY_KEY,             \r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\n'I' AS ACTION_CODE,\r\n'=' AS DML_TYPE         \r\nFROM \r\n$$STGDB.ST_CPD_STD_DISC_VW SCSDV\r\nLEFT JOIN \r\n$$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP\r\nON \r\nNCWP.CEC_ID=SCSDV.CREATED_BY",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
