      "attributes": {
        "Sql Query": "SELECT \r\n   WCMI.SALES_TERRITORY_KEY SALES_TERRITORY_KEY,\r\n   WCMI.SOLD_TO_CUSTOMER_KEY SOLD_TO_CUSTOMER_KEY,\r\n   WCMI.END_CUSTOMER_KEY  END_CUSTOMER_KEY,\r\n      WCMI.BILL_TO_CUSTOMER_KEY BILL_TO_CUSTOMER_KEY,\r\n   WCMI.PARTNER_SITE_PARTY_KEY  PARTNER_SITE_PARTY_KEY, \r\n   WCMI.CHANNEL_DROP_SHIP_FLAG  CHANNEL_DROP_SHIP_FLG,\r\n   CASE WHEN WCMI.PARTNER_SITE_PARTY_KEY = -999 THEN 'N'\r\n        WHEN WCMI.LEVEL_1_SLS_HIERARCHY='WW Distribution' THEN 'N' \r\n        WHEN WCMI.PARTNER_TYPE_CODE ='DVAR' THEN 'Y'\r\n        WHEN WCMI.PARTNER_TYPE_CODE ='SP' \r\n             THEN\r\n        CASE WHEN WCMI.RULE_CD='PARTNER_TYPE_SP_CHECK' THEN 'N'\r\n      WHEN WCMI.RULE_CD='CHK_GU_PARTY'  \r\n           THEN\r\n               CASE WHEN WCMI.SOLD_TO_GUK = WCMI.END_CUST_GUK THEN 'N'\r\n                    ELSE 'Y' \r\n               END\r\n          ELSE 'Y' \r\n        END\r\n   ELSE 'N'  \r\n   END     SALES_CHANNEL_BOOKING_FLAG,\r\n  USER EDW_CREATE_USER,\r\n  CURRENT_TIMESTAMP(0) EDW_CREATE_DATETIME,\r\n  WCMI.SHIP_TO_CUSTOMER_KEY AS SHIP_TO_CUSTOMER_KEY\r\n  FROM \r\n    $$STGDB.WI_SALES_CHNL_MATRIX_INT_ADJ WCMI",
