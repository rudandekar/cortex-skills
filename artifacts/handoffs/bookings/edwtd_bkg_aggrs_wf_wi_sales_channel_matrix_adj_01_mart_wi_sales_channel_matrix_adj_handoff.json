      "attributes": {
        "Sql Query": "SELECT \r\n  WCMP.SALES_TERRITORY_KEY,\r\n  WCMP.SOLD_TO_CUSTOMER_KEY,\r\n  WCMP.END_CUSTOMER_KEY,  \r\n    WCMP.BILL_TO_CUSTOMER_KEY,\r\n  WCMP.SOLD_TO_PARTY_KEY,\r\n  WCMP.BILL_TO_PARTY_KEY,\r\n   WCMP.PARTNER_PARTY_SITE_KEY_INT,\r\n  WCMP.PARTNER,\r\n  WCMP.SOLD_TO_GRAND_PRNT_PTY_KEY,\r\n  WCMP.BILL_TO_GRAND_PRNT_PTY_KEY,\r\n  WCMP.PARTNER_SITE_PARTY_KEY,\r\n  WCMP.CHANNEL_DROP_SHIP_FLAG,\r\n  WCMP.END_CUST_PARTY_KEY, \r\n  RSH.L1_SALES_TERRITORY_NAME_CODE LEVEL_1_SLS_HIERARCHY,\r\n  COALESCE(NCPCT.PARTNER_TYPE_CODE,'UNKNOWN') PARTNER_TYPE_CODE,\r\n  COALESCE(ECSN.RULE_CD,'UNKNOWN')  RULE_CD,\r\n  RCPH_SOLD_TO.GU_PARTY_KEY  SOLD_TO_GUK,\r\n  RCPH_END_CUST.GU_PARTY_KEY  END_CUST_GUK,\r\n  USER,\r\n  CURRENT_TIMESTAMP(0),\r\n  WCMP.SHIP_TO_CUSTOMER_KEY\r\n FROM   $$STGDB.WI_SALES_CHNL_MTX_DROPSHIP_ADJ WCMP\r\n LEFT OUTER JOIN  ($$COMREFVWDB.N_CHANNEL_PARTNER_SITE NCPST \r\n     INNER JOIN $$COMREFVWDB.N_CHNL_PTNR_COUNTRY NCPCT\r\n    ON   (NCPCT.PARTNER_COUNTRY_PARTY_KEY= NCPST.PARTNER_COUNTRY_PARTY_KEY\r\n    AND     NCPST.SOURCE_DELETED_FLG='N'\r\n    AND     NCPCT.SOURCE_DELETED_FLG='N'))\r\n ON (NCPST.PARTNER_SITE_PARTY_KEY=WCMP.PARTNER_SITE_PARTY_KEY)\r\n LEFT OUTER JOIN  $$COMREFVWDB.N_CUSTOMER_PARTY RCPH_SOLD_TO\r\n ON (RCPH_SOLD_TO.CUSTOMER_PARTY_KEY=WCMP.SOLD_TO_PARTY_KEY)\r\n LEFT OUTER JOIN  $$COMREFVWDB.N_CUSTOMER_PARTY RCPH_END_CUST\r\n ON (RCPH_END_CUST.CUSTOMER_PARTY_KEY=WCMP.END_CUST_PARTY_KEY)\r\n LEFT OUTER JOIN $$ETLVWDB.EL_CHN_SP_NODES  ECSN\r\n ON ( WCMP.SALES_TERRITORY_KEY =ECSN.SALES_TERRITORY_KEY) \r\n LEFT OUTER JOIN  $$COMREFVWDB.R_SALES_HIERARCHY  RSH\r\n  ON (WCMP.SALES_TERRITORY_KEY = RSH.SALES_TERRITORY_KEY )",
        "User Defined Join": "",
