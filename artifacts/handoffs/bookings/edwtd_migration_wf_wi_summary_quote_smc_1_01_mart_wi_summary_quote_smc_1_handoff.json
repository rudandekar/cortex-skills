      "attributes": {
        "Sql Query": "SELECT  \r\nSOL.BK_SO_NUMBER_INT SOL_BK_SO_NUMBER_INT\r\n,SOL.SALES_ORDER_LINE_KEY SOL_SALES_ORDER_LINE_KEY\r\n,SOL.SALES_ORDER_KEY SOL_SALES_ORDER_KEY\r\n,SOL_TV.AS_REPORTED_SERVICE_QUOTE_NUM\r\n,SVC_QOT.SUMMARY_QUOTE_FLG AS QUOTE_SUMMARY_QUOTE_FLG\r\n,SOL.RU_SERVICE_CONTRACT_NUMBER AS BKG_CONTRACT_NUMBER\r\n,SOL.ITEM_CATEGORY_DESCRIPTION AS BKGS_SVC_LVL\r\n,SVC_QOT.SUMMARY_QUOTE_CASE_NUM\r\n,SOL.BK_SO_SRC_CRT_DATETIME\r\n,FMTY.FISCAL_QUARTER_NAME\r\n,FMTY.fiscal_year_number_int \r\nFROM \r\n$$SLSORDVWDB.N_SALES_ORDER_LINE             SOL\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER                  SOH\r\nON SOL.SALES_ORDER_KEY                      = SOH.SALES_ORDER_KEY\r\nAND SOL.LINE_STATUS_CD NOT IN ('CANCELLED')  \r\nINNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FMTY\r\nON (SOL.BK_SO_SRC_CRT_DATETIME = FMTY.CALENDAR_DATE\r\nAND FMTY.fiscal_year_number_int IN (2016,2017)) \r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE_V1_TV  SOL_TV\r\nON (SOL_TV.SALES_ORDER_LINE_KEY               = SOL.SALES_ORDER_LINE_KEY \r\nAND SOL_TV.END_TV_DTM = '3500-01-01 00:00:00')\r\nINNER JOIN $$SERVICEVWDB.N_SERVICE_QUOTE SVC_QOT\r\nON (SVC_QOT.BK_QUOTE_NUM                      = SOL_TV.AS_REPORTED_SERVICE_QUOTE_NUM \r\nAND SVC_QOT.SUMMARY_QUOTE_FLG   = 'Y')",
        "User Defined Join": "",
        "Source Filter": "",
