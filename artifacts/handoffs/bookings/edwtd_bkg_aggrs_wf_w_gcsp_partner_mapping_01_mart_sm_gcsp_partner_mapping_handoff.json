      ],
      "attributes": {
        "Sql Query": "SELECT \r\n RANK() OVER (ORDER BY STG_GCSP.SK_SEQ_ID) +  SMKEY_MAX.MAX_MAP_KEY_VAL  GCSP_PARTNER_MAPPING_KEY,\r\n STG_GCSP.SK_SEQ_ID SK_SEQ_ID,\r\n  CAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_CREATE_DTM\r\n ,USER EDW_CREATE_USER\r\n FROM \r\n (\r\n SELECT \r\n  EDW_SEQ_NO SK_SEQ_ID\r\n FROM \r\n $$STGDB.GCSP_MAPPING \r\n\r\n )STG_GCSP,\r\n \r\n (SELECT COALESCE(MAX(GCSP_PARTNER_MAPPING_KEY),0)  MAX_MAP_KEY_VAL\r\n     FROM $$ETLVWDB.SM_GCSP_PARTNER_MAPPING \r\n  ) SMKEY_MAX\r\n WHERE NOT EXISTS\r\n (SELECT 1 FROM $$ETLVWDB.SM_GCSP_PARTNER_MAPPING SMGCSP \r\n WHERE SMGCSP.SK_SEQ_ID= STG_GCSP.SK_SEQ_ID)",
