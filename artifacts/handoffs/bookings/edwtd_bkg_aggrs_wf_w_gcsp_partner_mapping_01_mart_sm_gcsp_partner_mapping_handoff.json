      "attributes": {
        "Sql Query": "SELECT\r\n SM.GCSP_PARTNER_MAPPING_KEY\r\n,COALESCE(ST.BE_ID,-999)                         \r\n,SM.SK_SEQ_ID                    \r\n,ST.BE_GEO_ID                     \r\n,ST.BE_GEO_NAME                   \r\n,COALESCE(ST.PARTNER_COUNTRY,'UNKNOWN')               \r\n,COALESCE(ST.END_CUSTOMER_GU_ID,-999)            \r\n,COALESCE(ST.END_CUSTOMER_COUNTRY,'UNKNOWN')          \r\n,COALESCE(ST.END_CUSTOMER_GU_NAME,'UNKNOWN')          \r\n,COALESCE(ST.PARTNER_BILL_TO_ID,-999)            \r\n,COALESCE(ST.PARTNER_BILL_TO_COUNTRY,'UNKNOWN')       \r\n,COALESCE(CAST(ST.LAST_UPDATED_ON AS TIMESTAMP(0)),CAST('1900-01-01 00:00:00' AS TIMESTAMP(0)))                                   \r\n,COALESCE(ST.LAST_UPDATED_ON,CAST('1900-01-01' AS DATE))\r\n,COALESCE(CAST(ST.START_DATE AS TIMESTAMP(0)),CAST('1900-01-01 00:00:00' AS TIMESTAMP(0)))                                   \r\n,COALESCE(ST.START_DATE,CAST('1900-01-01' AS DATE))\r\n,COALESCE(CAST(ST.END_DATE AS TIMESTAMP(0)),CAST('3500-01-01 00:00:00' AS TIMESTAMP(0)))                                   \r\n,COALESCE(ST.END_DATE,CAST('3500-01-01' AS DATE))\r\n,CAST (CURRENT_TIMESTAMP(0) AS TIMESTAMP(0))\r\n,USER\r\n,CAST (CURRENT_TIMESTAMP(0) AS TIMESTAMP(0))\r\n,USER\r\n,'I' AS ACTION_CODE\r\n,'I' AS DML_TYPE\r\n\r\nFROM $$STGDB.GCSP_MAPPING ST,\r\n     $$ETLVWDB.SM_GCSP_PARTNER_MAPPING SM\r\nWHERE SM.SK_SEQ_ID= ST.EDW_SEQ_NO",
        "User Defined Join": "",
