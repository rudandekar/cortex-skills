      "attributes": {
        "Sql Query": "SELECT \r\n\r\nPH.PARTNER_SITE_PARTY_KEY AS PARTNER_SITE_PARTY_KEY,\r\n\r\nPH.PARTNER_SUBTYPE_CD             AS PARTNER_SUBTYPE_CODE,\r\n\r\nPH.PARTNER_TYPE_CD                AS PARTNER_TYPE_CODE,\r\n\r\nPH.CERTIFICATION_CD AS CERTIFICATION_CODE,\r\n\r\nCASE WHEN GP.CHANNEL_PARTNER_NAME IS NULL THEN 'UNDEFINED PARTNER' \r\n\r\nELSE SUBSTR(TRANSLATE(GP.CHANNEL_PARTNER_NAME  USING UNICODE_TO_LATIN),1,80) END AS CHANNEL_PARTNER_NAME\r\n\r\nFROM $$COMREFVWDB.MT_PARTNER_HIERARCHY PH\r\n\r\n/********** Newly added Join Starts *******/\r\n\r\nINNER JOIN  (SELECT  PARTNER_SITE_PARTY_KEY   FROM $$SLSORDVWDB.R_BOOKINGS_FYEAR \r\n\r\nWHERE FISCAL_YEAR_INT between 2006 and 2009\r\n\r\nGROUP BY 1\r\n\r\nUNION  ALL\r\n\r\nSELECT PARTNER_SITE_PARTY_KEY FROM $$SLSORDVWDB.N_SCAA_NCB_TV\r\n\r\nWHERE FISCAL_YEAR_MONTH_INT between $$FINSTYR and $$FINENDYR\r\n\r\nGROUP BY 1 ) BKG\r\n\r\nON BKG.PARTNER_SITE_PARTY_KEY  =PH.PARTNER_SITE_PARTY_KEY\r\n\r\n/**********Newly added Join Ends *******/\r\n\r\nLEFT OUTER JOIN \r\n(SELECT GP1.CHANNEL_PARTNER_NAME AS CHANNEL_PARTNER_NAME, RANK(GP1.NET_AMOUNT) AS NET_AMOUNT_RANK FROM \r\n(SELECT PHS.CHANNEL_PARTNER_NAME, SUM(FT.COMP_US_NET_PRICE_AMOUNT) AS NET_AMOUNT \r\n\r\nFROM $$SLSORDVWDB.R_BKGS_BY_MONTH FT,\r\n\r\n$$COMREFVWDB.MT_PARTNER_HIERARCHY  PHS,\r\n\r\n$$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR TMS\r\n\r\nWHERE FT.PARTNER_PARTY_SITE_KEY = PHS.PARTNER_SITE_PARTY_KEY\r\n\r\nAND FT.FISCAL_YEAR_MONTH_NUMBER_INT  BETWEEN  TMS.FISCAL_YEAR_AGO_MONTH_NUMBER AND TMS.FISCAL_YEAR_MONTH_INT \r\n\r\nAND TMS.CURRENT_FISCAL_MONTH_FLAG ='Y'\r\n\r\nAND FT.CHANNEL_BOOKING_FLAG       ='Y'\r\n\r\nGROUP BY 1)   GP1\r\n\r\nQUALIFY NET_AMOUNT_RANK <= 1000\r\n\r\n)GP\r\n\r\nON PH.CHANNEL_PARTNER_NAME = GP.CHANNEL_PARTNER_NAME;",
        "User Defined Join": "",
