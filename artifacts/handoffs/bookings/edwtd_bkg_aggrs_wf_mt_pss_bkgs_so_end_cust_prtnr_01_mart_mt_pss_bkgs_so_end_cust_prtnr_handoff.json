      "attributes": {
        "Sql Query": "SELECT \r\nRBF.BOOKINGS_MEASURE_KEY AS BOOKINGS_MEASURE_KEY,\r\nRBF.BOOKINGS_PROCESS_DATE AS BOOKINGS_PROCESS_DT,\r\nRBF.BKGS_MEASURE_TRANS_TYPE_CODE AS BKGS_MEASURE_TRANS_TYPE_CD,\r\nCOALESCE( TEMP.SO_END_CUSTOMER_KEY  ,-999 ) AS  SO_END_CUSTOMER_KEY,\r\nCOALESCE(RECPH.BRANCH_PRIMARY_NAME,'UNKNOWN') AS END_CUST_BRANCH_PRIMARY_NAME,\r\nCOALESCE(TEMP.SO_PARTNER_SITE_PARTY_KEY ,-999)AS SO_PARTNER_SITE_PARTY_KEY,\r\nCOALESCE(RPH.PRIMARY_NAME,'UNKNOWN') AS PARTNER_PRIMARY_NAME,\r\nRBF.DV_SOURCE_ORDER_NUM_INT AS DV_SOURCE_ORDER_NUM_INT\r\nFROM $$SLSORDVWDB.N_BKGS_MEASURE RBF\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR SFDTY\r\n                ON(RBF.BOOKINGS_PROCESS_DATE=SFDTY.CALENDAR_DATE\r\n                AND SFDTY.FISCAL_YEAR_AGE IN (0,1))\r\nLEFT  OUTER JOIN $$STGDB.WI_PSS_BKGS_SO_END_CUST_PRTNR TEMP\r\n                ON (TEMP.BKGS_MEASURE_TRANS_TYPE_CD=RBF.BKGS_MEASURE_TRANS_TYPE_CODE\r\n                AND TEMP.DV_SOURCE_ORDER_NUM_INT=RBF.DV_SOURCE_ORDER_NUM_INT)\r\nLEFT OUTER JOIN $$COMREFVWDB.MT_ENDCUST_CUSTOMER_PARTY_HIER  RECPH\r\n                ON (RECPH.END_CUSTOMER_KEY=TEMP.SO_END_CUSTOMER_KEY)\r\nLEFT OUTER JOIN $$COMREFVWDB.MT_PARTNER_HIERARCHY RPH\r\n                ON (RPH.PARTNER_SITE_PARTY_KEY=TEMP.SO_PARTNER_SITE_PARTY_KEY)",
        "User Defined Join": "",
