      "attributes": {
        "Sql Query": "SELECT   \r\n   TVOUTPUT.SALES_ORDER_LINE_KEY,\r\n   TVOUTPUT.END_CUSTOMER_KEY,\r\n   TVOUTPUT.END_CUSTOMER_TYPE_CODE,\r\n   TVOUTPUT.SS_CODE,\r\n   TVOUTPUT.EDW_CREATE_DATETIME  START_TV_DATE,\r\n   TVOUTPUT.END_CUSTOMER_ASSGN_LEVEL ,\r\n    COALESCE (MAX (TVOUTPUT.START_TV_DATETIME - INTERVAL '1'  MINUTE) \r\n    \t\t\tOVER (PARTITION BY \tTVOUTPUT.SALES_ORDER_LINE_KEY\r\n     \t\t\t\tORDER BY TVOUTPUT.START_TV_DATETIME ASC ROWS BETWEEN 1 \r\n     \t\t\tFOLLOWING AND 1 FOLLOWING), TIMESTAMP '3500-01-01 00:00:00') END_DATE_ACTIVE ,\r\n\t(CASE WHEN (ROW_NUMBER () OVER (PARTITION BY \r\n\t\t\t\t\t\tTVOUTPUT.SALES_ORDER_LINE_KEY\r\n\t\tORDER BY TVOUTPUT.START_TV_DATETIME ASC)) = 1 AND NSECT_OUT.SALES_ORDER_LINE_KEY  IS NOT NULL  THEN 'U'ELSE 'I' END) DML_TYPE,\r\nCAST (CURRENT_TIMESTAMP (0) AS TIMESTAMP (0)) AS CREATE_DATETIME,\r\nTVOUTPUT.RU_PARNT_SLS_ORDER_LINE_KEY,\r\nCAST(TVOUTPUT.EDW_CREATE_DATETIME AS DATE FORMAT'YYYYMMDD') AS START_SSP_DATE,\r\n CAST( COALESCE (MAX (TVOUTPUT.START_TV_DATETIME - INTERVAL '1'  MINUTE) \r\n    \t\t\tOVER (PARTITION BY \tTVOUTPUT.SALES_ORDER_LINE_KEY\r\n     \t\t\t\tORDER BY TVOUTPUT.START_TV_DATETIME ASC ROWS BETWEEN 1 \r\n     \t\t\tFOLLOWING AND 1 FOLLOWING), TIMESTAMP '3500-01-01 00:00:00') AS DATE FORMAT'YYYYMMDD') AS END_SSP_DATE,\r\n TVOUTPUT.END_CUST_ERP_CNTCT_PRTY_KEY  /* Added as part 9th Apr release */\t\t\t\t\r\nFROM\r\n(\r\nSELECT\r\n   \tTVINPUT.SALES_ORDER_LINE_KEY,\r\n   \tTVINPUT.END_CUSTOMER_KEY,\r\n   \tTVINPUT.END_CUSTOMER_TYPE_CODE,\r\n   \tTVINPUT.SS_CODE,\r\n\tTVINPUT.START_TV_DATETIME,\r\n   \tTVINPUT.EDW_CREATE_DATETIME ,\r\n   \tTVINPUT.END_CUSTOMER_ASSGN_LEVEL       END_CUSTOMER_ASSGN_LEVEL,\r\n   \tROW_NUMBER () OVER (PARTITION BY \r\n     \t\t\t\t\tTVINPUT.SALES_ORDER_LINE_KEY,\r\n     \t\t\t\t\tTVINPUT.END_CUSTOMER_KEY,\r\n     \t\t\t\t\tTVINPUT.END_CUSTOMER_TYPE_CODE\r\n     \tORDER BY TVINPUT.EDW_CREATE_DATETIME DESC) AS ROW_NUM  ,\r\nTVINPUT.RU_PARNT_SLS_ORDER_LINE_KEY RU_PARNT_SLS_ORDER_LINE_KEY,\r\nTVINPUT.END_CUST_ERP_CNTCT_PRTY_KEY  /* Added as part 9th Apr release */\t\t\t\r\n  FROM \r\n  \t(\r\n  \t\t  \tSELECT \r\n   \t\t\tWSEC.SALES_ORDER_LINE_KEY \t\t\t\tSALES_ORDER_LINE_KEY ,\r\n   \t\t\tWSEC.END_CUSTOMER_KEY   \t\t\t\tEND_CUSTOMER_KEY,\r\n   \t\t\tWSEC.END_CUSTOMER_TYPE_CODE    \t\t\tEND_CUSTOMER_TYPE_CODE,\r\n   \t\t\tWSEC.SS_CODE        \t\t\t\t\tSS_CODE,\r\n\t\t\tWSEC.EDW_CREATE_DATETIME \t\t\t\tSTART_TV_DATETIME,\r\n   \t\t\tWSEC.EDW_CREATE_DATETIME    \t\t\tEDW_CREATE_DATETIME,\r\n   \t\t\tWSEC.END_CUSTOMER_ASSGN_LEVEL       \tEND_CUSTOMER_ASSGN_LEVEL,\r\n\t        WSEC.RU_PARNT_SLS_ORDER_LINE_KEY RU_PARNT_SLS_ORDER_LINE_KEY,\r\n\t\t\tWSEC.END_CUST_ERP_CNTCT_PRTY_KEY   END_CUST_ERP_CNTCT_PRTY_KEY  /* Added as part 9th Apr release */\r\n  \t\tFROM \r\n   \t\t\t$$WORKDB.WI_SOL_END_CUSTOMER WSEC\r\n  \t\tUNION ALL\r\n  \t\tSELECT\r\n   \t\t\tNSECT_I.SALES_ORDER_LINE_KEY \t\t\tSALES_ORDER_LINE_KEY,\r\n     \t    NSECT_I.END_CUSTOMER_KEY   \t\t\t\tEND_CUSTOMER_KEY,\r\n      \t\tNSECT_I.END_CUSTOMER_TYPE_CODE    \t\tEND_CUSTOMER_TYPE_CODE,\r\n      \t\tNSECT_I.SS_CODE        \t\t\t\t\tSS_CODE,\r\n\t\t\tNSECT_I.START_TV_DATETIME \t\t\t\tSTART_TV_DATETIME,\r\n      \t\tNSECT_I.EDW_CREATE_DATETIME    \t\t\tEDW_CREATE_DATETIME,\r\n      \t\tNSECT_I.END_CUSTOMER_ASSGN_LEVEL\t\tEND_CUSTOMER_ASSGN_LEVEL,\r\n            NSECT_I.DD_PARENT_SALES_ORDER_LINE_KEY  RU_PARNT_SLS_ORDER_LINE_KEY ,\r\n\t\t\tNSECT_I.END_CUST_ERP_CNTCT_PRTY_KEY     END_CUST_ERP_CNTCT_PRTY_KEY /* Added as part 9th Apr release */\r\n     \tFROM $$SLSORDVWDB.N_SOL_END_CUSTOMER_TV NSECT_I ,$$WORKDB.WI_SOL_END_CUSTOMER WSEC_I\r\n     \tWHERE END_TV_DATETIME='3500/01/01 00:00:00'  \r\n     \tAND NSECT_I.SALES_ORDER_LINE_KEY   =WSEC_I.SALES_ORDER_LINE_KEY\r\n \t) TVINPUT\r\n   \tQUALIFY ROW_NUMBER () OVER (PARTITION BY \r\n     \t\t\t\t\tTVINPUT.SALES_ORDER_LINE_KEY,\r\n\t                          TVINPUT.START_TV_DATETIME\r\n     \tORDER BY TVINPUT.EDW_CREATE_DATETIME DESC) = 1\r\n )TVOUTPUT  \r\nLEFT OUTER JOIN  $$SLSORDVWDB.N_SOL_END_CUSTOMER_TV  NSECT_OUT  \r\n   ON (NSECT_OUT.SALES_ORDER_LINE_KEY  =TVOUTPUT.SALES_ORDER_LINE_KEY    \r\n      AND NSECT_OUT.END_TV_DATETIME ='3500-01-01 00:00:00' )\r\nWHERE  TVOUTPUT.ROW_NUM = 1",
        "User Defined Join": "",
