        "Sql Query": "SELECT \r\nWATLGD.BK_AR_TRX_LINE_GL_DISTRIB_KEY,\r\nWATLGD.ACCOUNT_CLASS_CODE, \r\nWATLGD.ACCOUNT_SET_FLAG, \r\nWATLGD.AR_TRX_KEY, \r\nWATLGD.AR_TRX_LINE_KEY, \r\nWATLGD.GENERAL_LEDGER_ACCOUNT_KEY, \r\nWATLGD.GL_DATETIME, \r\nWATLGD.TRANSACTION_LINE_PERCENTAGE, \r\nWATLGD.RU_AR_TRX_LINE_FUNC_DEBIT_AMT, \r\nWATLGD.RU_AR_TRX_LINE_TRXL_DEBIT_AMT, \r\nWATLGD.RU_AR_TRX_LINE_TRXL_CREDIT_AMT, \r\nWATLGD.RU_AR_TRX_LINE_FUNC_CREDIT_AMT, \r\nWATLGD.BK_JE_LN_COMPANY_CODE, \r\nWATLGD.BK_JE_LN_JOURNAL_ENTRY_NUM_INT, \r\nWATLGD.BK_JE_LN_JE_LINE_NUMBER_INT, \r\nWATLGD.BK_JE_LN_SET_OF_BOOKS_KEY, \r\nWATLGD.BK_FISCAL_CALENDAR_CODE, \r\nWATLGD.BK_FISCAL_YEAR_NUMBER_INT, \r\nWATLGD.BK_FISCAL_MONTH_NUMBER_INT, \r\nWATLGD.CREDIT_DEBIT_TYPE, \r\nWATLGD.COGS_PCT, \r\nWATLGD.SK_CST_TRX_LIN_GL_DIST_ID_LINT, \r\nWATLGD.SS_CODE, \r\nWATLGD.EDW_CREATE_DATETIME, \r\nWATLGD.EDW_CREATE_USER, \r\nWATLGD.EDW_UPDATE_DATETIME, \r\nWATLGD.EDW_UPDATE_USER, \r\nWATLGD.AR_POSTING_CONTROL_KEY ,\r\nWATLGD.GL_POSTED_DT\r\nFROM\t\t\t\t\t\t\t\t\t\t\t\t\r\n$$WORKDB.W_AR_TRX_LINE_GL_DIST WATLGD\r\nWHERE  WATLGD.SS_CODE='OOD'\r\nAND  NOT EXISTS\r\n(SELECT 1 FROM $$FINLGLVWDB.N_AR_TRX_LINE_GL_DIST NATLGD WHERE\r\nNATLGD.BK_AR_TRX_LINE_GL_DISTRIB_KEY=WATLGD.BK_AR_TRX_LINE_GL_DISTRIB_KEY\r\nAND WATLGD.SS_CODE='OOD')",
