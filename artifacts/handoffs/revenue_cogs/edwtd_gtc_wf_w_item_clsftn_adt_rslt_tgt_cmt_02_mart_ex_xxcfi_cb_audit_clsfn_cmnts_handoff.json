      "attributes": {
        "Sql Query": "SELECT AUDIT_COMMENT_ID,\r\nAUDIT_QUERY_ID,\r\nPID,\r\nAUDITOR_COMMENTS,\r\nCREATED_BY,\r\nCREATION_DATE,\r\nLAST_UPDATED_BY,\r\nLAST_UPDATE_DATE,\r\ncurrent_timestamp(0),\r\nACTION_CODE,\r\n'RI'\r\nFROM $$STGDB.ST_XXCFI_CB_AUDIT_CLSFN_CMNTS SXCACC\r\nWHERE NOT EXISTS (SEL 1 FROM $$FINLGLVWDB.N_ITEM_CLSFTN_RULE_AUDIT  NICRA\r\nWHERE NICRA.SK_AUDIT_QUERY_ID = SXCACC.AUDIT_QUERY_ID)\r\nOR NOT EXISTS(SEL 1 FROM   $$COMREFVWDB.N_PRODUCT NP WHERE  SXCACC.PID = NP.BK_PRODUCT_ID)\r\nOR NOT EXISTS (SEL 1 FROM $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP\r\nWHERE  NCWP.CEC_ID =COALESCE( SXCACC.CREATED_BY,'UNKNOWN'))\r\nOR NOT EXISTS (SEL 1 FROM $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP1\r\nWHERE   NCWP1.CEC_ID =COALESCE( SXCACC.LAST_UPDATED_BY,'UNKNOWN'))\r\nOR SXCACC.CREATION_DATE IS NULL\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY SXCACC.AUDIT_QUERY_ID, SXCACC.PID, SXCACC.CREATION_DATE ORDER BY SXCACC.AUDIT_COMMENT_ID DESC) =1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
