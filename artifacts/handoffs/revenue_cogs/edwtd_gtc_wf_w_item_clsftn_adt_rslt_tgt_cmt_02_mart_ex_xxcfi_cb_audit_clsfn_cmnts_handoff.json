      ],
      "attributes": {
        "Sql Query": "SELECT NICRA.BK_AUDIT_NAME AS BK_AUDIT_NAME,\r\nNP.ITEM_KEY AS PRODUCT_KEY ,\r\nSXCACC.CREATION_DATE AS BK_SRC_CREATED_DTM ,\r\nCOALESCE(SXCACC.LAST_UPDATE_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP)) AS SRC_UPDATED_DTM,\r\nSXCACC.AUDITOR_COMMENTS AS AUDITOR_CMT ,\r\nCOALESCE (NCWP.CISCO_WORKER_PARTY_KEY,-999) AS SRC_CRTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE (NCWP1.CISCO_WORKER_PARTY_KEY,-999) AS SRC_UPDT_BY_CSCO_WRKR_PRTY_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nSXCACC.ACTION_CODE,\r\n'I'\r\nFROM \r\n$$STGDB.ST_XXCFI_CB_AUDIT_CLSFN_CMNTS   SXCACC\r\nINNER JOIN $$FINLGLVWDB.N_ITEM_CLSFTN_RULE_AUDIT   NICRA \r\nON SXCACC.AUDIT_QUERY_ID = NICRA.SK_AUDIT_QUERY_ID\r\nINNER JOIN $$COMREFVWDB.N_PRODUCT NP\r\nON SXCACC.PID = NP.BK_PRODUCT_ID\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP\r\nON SXCACC.CREATED_BY =NCWP.CEC_ID\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP1\r\nON SXCACC.LAST_UPDATED_BY =NCWP.CEC_ID\r\nWHERE SXCACC.AUDIT_QUERY_ID IS NOT NULL\r\nAND SXCACC.PID IS NOT NULL\r\nAND SXCACC.CREATION_DATE IS NOT NULL\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY SXCACC.AUDIT_QUERY_ID, SXCACC.PID ,SXCACC.CREATION_DATE ORDER BY SXCACC.AUDIT_COMMENT_ID DESC) =1\r\nUNION ALL\r\nSELECT NICRA.BK_AUDIT_NAME AS BK_AUDIT_NAME,\r\nNP.ITEM_KEY AS PRODUCT_KEY  ,\r\nEXCACC.CREATION_DATE AS BK_SRC_CREATED_DTM ,\r\nCOALESCE(EXCACC.LAST_UPDATE_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP)) AS SRC_UPDATED_DTM,\r\nEXCACC.AUDITOR_COMMENTS AS AUDITOR_CMT ,\r\nCOALESCE (NCWP.CISCO_WORKER_PARTY_KEY,-999) AS SRC_CRTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE (NCWP1.CISCO_WORKER_PARTY_KEY,-999) AS SRC_UPDT_BY_CSCO_WRKR_PRTY_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nEXCACC.ACTION_CODE,\r\n'I'\r\nFROM \r\n$$EXCEPDB.EX_XXCFI_CB_AUDIT_CLSFN_CMNTS   EXCACC\r\nINNER JOIN $$FINLGLVWDB.N_ITEM_CLSFTN_RULE_AUDIT   NICRA \r\nON EXCACC.AUDIT_QUERY_ID = NICRA.SK_AUDIT_QUERY_ID \r\nINNER JOIN $$COMREFVWDB.N_PRODUCT NP\r\nON EXCACC.PID = NP.BK_PRODUCT_ID\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP\r\nON EXCACC.CREATED_BY =NCWP.CEC_ID\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP1\r\nON EXCACC.LAST_UPDATED_BY =NCWP.CEC_ID\r\nWHERE EXCACC.AUDIT_QUERY_ID IS NOT NULL\r\nAND EXCACC.PID IS NOT NULL\r\nAND EXCACC.CREATION_DATE IS NOT NULL\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY EXCACC.AUDIT_QUERY_ID, EXCACC.PID ,EXCACC.CREATION_DATE ORDER BY EXCACC.AUDIT_COMMENT_ID DESC) =1",
        "User Defined Join": "",
