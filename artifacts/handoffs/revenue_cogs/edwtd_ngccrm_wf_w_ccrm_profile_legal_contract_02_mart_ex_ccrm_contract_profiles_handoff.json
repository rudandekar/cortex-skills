      "attributes": {
        "Sql Query": "SELECT \r\n  SCCP.PROFILE_ID  BK_CCRM_PROFILE_ID_INT, \r\n  ECCC.CONTRACT_NUMBER BK_CONTRACT_NUMBER_INT,\r\n  (CASE WHEN NCP.PROFILE_SOURCE_CD='CMS'  AND SCCP.CREATED_BY = 'SYSTEM' THEN 'Y' ELSE 'N' END) AS  CCRM_CNTRCT_BASIS_FOR_PRFL_FLG,\r\n  SCCP.ACTION_CODE  ACTION_CODE,\r\n  'I'  DML_TYPE\r\nFROM  $$STGDB.ST_CCRM_CONTRACT_PROFILES SCCP\r\nINNER JOIN  $$ETLVWDB.EL_CCRM_CMS_CONTRACTS ECCC ON ECCC.CONTRACT_ID = SCCP.CONTRACT_ID\r\nLEFT OUTER JOIN  $$FINLGLVWDB.N_CCRM_PROFILE NCP ON NCP.BK_CCRM_PROFILE_ID_INT = SCCP.PROFILE_ID\r\n\r\nUNION ALL\r\n\r\nSELECT \r\n  ECCP.PROFILE_ID  BK_CCRM_PROFILE_ID_INT, \r\n  ECCC.CONTRACT_NUMBER BK_CONTRACT_NUMBER_INT,\r\n  (CASE WHEN NCP.PROFILE_SOURCE_CD='CMS'  AND ECCP.CREATED_BY = 'SYSTEM' THEN 'Y' ELSE 'N' END) AS  CCRM_CNTRCT_BASIS_FOR_PRFL_FLG,\r\n  ECCP.ACTION_CODE  ACTION_CODE,\r\n  'I'  DML_TYPE\r\nFROM  $$EXCEPDB.EX_CCRM_CONTRACT_PROFILES  ECCP\r\nINNER JOIN  $$ETLVWDB.EL_CCRM_CMS_CONTRACTS ECCC ON ECCC.CONTRACT_ID = ECCP.CONTRACT_ID\r\nLEFT OUTER JOIN  $$FINLGLVWDB.N_CCRM_PROFILE NCP ON NCP.BK_CCRM_PROFILE_ID_INT = ECCP.PROFILE_ID",
