      "attributes": {
        "Sql Query": "SELECT FISCAL_MONTH_NAME,\r\nFISCAL_MONTH_ID,\r\nFISCAL_MONTH_STATUS_IND,\r\nFISCAL_YEAR_ID,\r\nCAST(FISCAL_MONTH_START_DATE AS TIMESTAMP(0)) FISCAL_MONTH_START_DATE,\r\nCAST(FISCAL_MONTH_START_DATE_ADJ AS TIMESTAMP(0)) FISCAL_MONTH_START_DATE_ADJ,\r\nCAST(FISCAL_MONTH_END_DATE AS TIMESTAMP(0)) FISCAL_MONTH_END_DATE ,\r\nFISCAL_MONTH_END_DATE_ADJ,\r\nCAST(PREV_MONTH_START_DATE_ADJ AS TIMESTAMP(0))  PREV_MONTH_START_DATE_ADJ,\r\n'N' AS RELOAD_FLAG,\r\n'N' AS WORKGROUP_BACKFILL_FLAG\r\nFROM (SELECT FISCAL_MONTH_NAME,\r\nFISCAL_MONTH_STATUS_IND,\r\nFISCAL_MONTH_ID,\r\nFISCAL_YEAR_ID,\r\nFISCAL_MONTH_START_DATE,\r\nFISCAL_MONTH_START_DATE_ADJ,\r\nFISCAL_MONTH_END_DATE,\r\nFISCAL_MONTH_END_DATE_ADJ,\r\nMIN(FISCAL_MONTH_START_DATE -MONTH_END_OFFSET)  OVER ( ORDER BY FISCAL_MONTH_END_DATE DESC ROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING) AS PREV_MONTH_START_DATE_ADJ,\r\n'N' AS RELOAD_FLAG,\r\n'N' AS WORKGROUP_BACKFILL_FLAG\r\nFROM (SELECT TOP 3 DD.FISCAL_MONTH_NAME\r\n,CASE WHEN DD.FISCAL_MONTH_NAME = FMA.FISCAL_MONTH_NAME THEN 'WIP' ELSE 'CLOSED' END AS FISCAL_MONTH_STATUS_IND\r\n,DD.FISCAL_YEAR_MONTH_INT FISCAL_MONTH_ID\r\n,DD.FISCAL_YEAR_NUMBER_INT  FISCAL_YEAR_ID\r\n, FISCAL_MONTH_START_DATE\r\n,(FISCAL_MONTH_START_DATE - MONTH_END_OFFSET) FISCAL_MONTH_START_DATE_ADJ\r\n, DD.FISCAL_MONTH_END_DATE\r\n,CAST(OREPLACE(CAST(CAST((DD.FISCAL_MONTH_END_DATE - MONTH_END_OFFSET)  AS TIMESTAMP(0) ) AS VARCHAR(30)),'00:00:00','23:59:59') AS TIMESTAMP(0)) FISCAL_MONTH_END_DATE_ADJ\r\n,MONTH_END_OFFSET\r\nFROM $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR  DD,(SELECT (FISCAL_MONTH_END_DATE - CALENDAR_DATE) AS MONTH_END_OFFSET, FISCAL_MONTH_NAME, FISCAL_MONTH_END_DATE\r\nFROM $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR \r\nWHERE CALENDAR_DATE = CURRENT_DATE) FMA\r\nWHERE DD.CALENDAR_DATE <= FMA.FISCAL_MONTH_END_DATE\r\nGROUP BY 1,2,3,4,5,6,7,8,9\r\nORDER BY DD.FISCAL_MONTH_END_DATE DESC) X\r\nQUALIFY ROW_NUMBER() OVER (ORDER BY FISCAL_MONTH_END_DATE DESC) = 1\r\nUNION \r\nSELECT FISCAL_MONTH_NAME,\r\nFISCAL_MONTH_STATUS_IND,\r\nFISCAL_MONTH_ID,\r\nFISCAL_YEAR_ID,\r\nFISCAL_MONTH_START_DATE,\r\nFISCAL_MONTH_START_DATE_ADJ,\r\nFISCAL_MONTH_END_DATE,\r\nFISCAL_MONTH_END_DATE_ADJ,\r\nMIN(FISCAL_MONTH_START_DATE)  OVER ( ORDER BY FISCAL_MONTH_END_DATE DESC ROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING) AS PREV_MONTH_START_DATE_ADJ,\r\n'N' AS RELOAD_FLAG,\r\n'N' AS WORKGROUP_BACKFILL_FLAG\r\nFROM (SELECT TOP 3 DD.FISCAL_MONTH_NAME,\r\n'CLOSED' AS FISCAL_MONTH_STATUS_IND,\r\nDD.FISCAL_YEAR_MONTH_INT  FISCAL_MONTH_ID,\r\nDD.FISCAL_YEAR_NUMBER_INT  FISCAL_YEAR_ID,\r\nCAST(FISCAL_MONTH_START_DATE AS TIMESTAMP(0)) FISCAL_MONTH_START_DATE,\r\n(FISCAL_MONTH_START_DATE - MONTH_END_OFFSET)  FISCAL_MONTH_START_DATE_ADJ,\r\nDD.FISCAL_MONTH_END_DATE,\r\nCAST(OREPLACE(CAST(CAST((DD.FISCAL_MONTH_END_DATE - MONTH_END_OFFSET)  AS TIMESTAMP(0) ) AS VARCHAR(30)),'00:00:00','23:59:59') AS TIMESTAMP(0)) FISCAL_MONTH_END_DATE_ADJ\r\nFROM $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR  DD\r\n,(SELECT (FISCAL_MONTH_END_DATE - CALENDAR_DATE) AS MONTH_END_OFFSET, FISCAL_MONTH_NAME, FISCAL_MONTH_END_DATE\r\nFROM $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR \r\nWHERE CALENDAR_DATE = CURRENT_DATE) FMA\r\nWHERE DD.CALENDAR_DATE <= FMA.FISCAL_MONTH_END_DATE\r\nAND DD.FISCAL_MONTH_NAME <> FMA.FISCAL_MONTH_NAME\r\nGROUP BY 1,2,3,4,5,6,7,8\r\nORDER BY DD.FISCAL_MONTH_END_DATE DESC        ) X\r\nQUALIFY ROW_NUMBER() OVER (ORDER BY FISCAL_MONTH_END_DATE DESC) =1) Y",
        "User Defined Join": "",
