      "attributes": {
        "Sql Query": "SELECT\r\n GL.DV_FISCAL_YEAR_MTH_NUMBER_INT  BK_FISCAL_YEAR_MTH_NUMBER_INT,\r\n CASE \r\n   WHEN GL.BK_ADJUSTMENT_MEASURE_TYPE_CD ='SERVICE REVENUE' THEN 'REVENUE' \r\n   WHEN GL.BK_ADJUSTMENT_MEASURE_TYPE_CD ='SERVICE COGS' THEN 'COGS'\r\n   ELSE 'UNKNOWN'   END BK_REVENUE_OR_COGS_TYPE_CD ,\r\n GL.PRODUCT_KEY BK_PRODUCT_KEY,\r\n CASE WHEN GL.BK_ADJ_SUB_MEASURE_TYPE_CD LIKE 'AS%'THEN 5970786 /*'AS SUBSCRIPTION_ADJ_PROD'*/ \r\n         WHEN GL.BK_ADJ_SUB_MEASURE_TYPE_CD LIKE 'TS%'THEN 5826798 /*'SMARTNET_ADJ_PROD'*/ \r\n         WHEN GL.BK_ADJ_SUB_MEASURE_TYPE_CD LIKE 'TRAINING%'THEN 6619657/*'TRAINING_ADJ_PROD'*/ \r\n/*WHEN GL.BK_ADJ_SUB_MEASURE_TYPE_CD LIKE 'CLOUD%' THEN BK_PRODUCT_KEY*/         \r\nWHEN GL.BK_ADJ_SUB_MEASURE_TYPE_CD = 'Royalty Rev'\r\n  THEN 6206176 /*'TSS-OTHER_ADJ_PROD')*/\r\n         ELSE GL.PRODUCT_KEY   END     GOODS_PRODUCT_KEY  ,   \r\n 'UNK'BK_FINANCIAL_ACCOUNT_CD      ,\r\n 'UNKNOWN' BK_REV_MEASURE_TRNSCTN_TYPE_CD,\r\n -999 DV_TRIANGULATION_TYPE_ID_INT,\r\n 'UNKNOWN' BK_PRDT_SUBGROUP_ALLOC_SRC_CD,\r\n SALES_TERRITORY_KEY   BK_SALES_TERRITORY_KEY,\r\n BK_SALES_TERRITORY_KEY BK_TRNGLTD_SALES_TERRITORY_KEY,\r\n -9999 SALES_ORDER_LINE_KEY,\r\n 'UNKNOWN' BK_SRC_RPRTD_SRVC_CONTRACT_NUM,\r\n SUM(CASE WHEN BK_REVENUE_OR_COGS_TYPE_CD='REVENUE' \r\n THEN ZEROIFNULL(GL.ADJUSTMENT_ALLOCATION_USD_AMT) \r\n WHEN BK_REVENUE_OR_COGS_TYPE_CD='COGS' \r\n THEN ZEROIFNULL(GL.ADJUSTMENT_ALLOCATION_USD_AMT)* (-1)\r\n ELSE 0 END ) COMP_US_NET_REV_AMT,\r\n 'UNK' BK_COMPANY_CD,\r\n 'UNK' BK_ISO_COUNTRY_CD,\r\n 'SERVICE'DV_PRODUCT_TYPE,\r\n GL.BK_ADJ_SUB_MEASURE_TYPE_CD DV_PNL_LINE_ITEM_NAME,\r\nCASE WHEN GL.BK_DEAL_ID <> 'UNKNOWN' THEN 'FCM' ELSE 'UNKNOWN'  END AS DEAL_SS_CD,\r\nCOALESCE (GL.BK_DEAL_ID  ,'UNKNOWN'),\r\nCAST (TRIM(COALESCE(GL.GOODS_PRODUCT_KEY  ,-999)) || '~' || TRIM(COALESCE(GL.GOODS_PRODUCT_KEY  ,-999)) || '~' ||-9999|| '~' ||-9999 AS VARCHAR(70))  DV_RECURRING_OFFER_CD\r\n FROM\r\n $$FINLGLVWDB.N_PRDT_REV_COST_ADJSTMNT_ALCTN   GL \r\n LEFT JOIN $$FINLGLVWDB.N_FCM_DEAL_MAPPING FCM ON GL.BK_DEAL_ID=FCM.BK_DEAL_ID AND GL.DV_FISCAL_YEAR_MTH_NUMBER_INT=FCM.BK_DV_FISCAL_YEAR_MTH_NUM_INT \r\n INNER JOIN $$STGDB.WI_PNL_MTH_CNTL_OTH_COGS FY ON \r\n FY.FISCAL_YEAR_MONTH_INT=GL.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n AND GL.BK_ADJUSTMENT_COMPANY_NAME='CISCO CORE'\r\n AND FY.INC_FLAG ='Y'\r\n AND GL.BK_ADJUSTMENT_TYPE_CD = 'Manual Adjustment'\r\n AND UPPER(GL.BK_ADJUSTMENT_MEASURE_TYPE_CD)  IN  ('SERVICE REVENUE','SERVICE COGS') \r\n GROUP BY 1,2,3,4,9,10,11,12,17,18,19,DV_RECURRING_OFFER_CD",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
  ],
