      "attributes": {
        "Sql Query": "SELECT\r\nBK_FISCAL_YEAR_MTH_NUMBER_INT,\r\n'TSS_REVENUE' DV_PNL_REV_COST_TYPE,\r\n'REVENUE' BK_REVENUE_OR_COGS_TYPE_CD,   \r\nBK_SALES_TERRITORY_KEY ORIGINAL_SALES_TERRITORY_KEY,\r\nDV_PNL_LINE_ITEM_NAME,\r\nPARTNER_TYPE_CD,        \r\nCHANNEL_FLG            ,       \r\nAS_OF_FSC_MTH_PARTNER_TYPE_CD,\r\nAS_OF_FSC_MTH_CHANNEL_FLG     ,\r\nDV_ROUTE_TO_MARKET_CD         ,\r\nDV_AS_OF_FSC_MTH_RTM_CD    ,\r\nCOMP_US_NET_REV_AMT,\r\nCAST(COMP_US_NET_REV_AMT AS DECIMAL(26,10))/SUM(COMP_US_NET_REV_AMT) \r\nOVER (PARTITION BY BK_FISCAL_YEAR_MTH_NUMBER_INT,BK_SALES_TERRITORY_KEY,DV_PNL_LINE_ITEM_NAME) STK_RTM_RATIO\r\nFROM\r\n(\r\nSELECT \r\nGL.DV_FISCAL_YEAR_MTH_NUMBER_INT  BK_FISCAL_YEAR_MTH_NUMBER_INT, \r\nCASE WHEN GL.SALES_TERRITORY_KEY <0 THEN -999 ELSE     GL.SALES_TERRITORY_KEY END  BK_SALES_TERRITORY_KEY , \r\nGL_RTM.PARTNER_TYPE_CD,        \r\nGL_RTM.CHANNEL_FLG            ,       \r\nGL_RTM.AS_OF_FSC_MTH_PARTNER_TYPE_CD,\r\nGL_RTM.AS_OF_FSC_MTH_CHANNEL_FLG     ,\r\nGL_RTM.DV_ROUTE_TO_MARKET_CD         ,\r\nGL_RTM.DV_AS_OF_FSC_MTH_RTM_CD    ,\r\nEL.DV_PNL_LINE_ITEM_NAME    ,\r\nSUM(ZEROIFNULL(DV_COMP_US_NET_REV_AMT        ) *GL_RTM.RTM_SPLIT_RATIO*EL.ALLOCATION_PERCENTAGE) COMP_US_NET_REV_AMT\r\n\r\nFROM $$FINLGLVWDB.MT_RSTD_GL_REV_MEASURE  GL \r\nINNER JOIN $$FINLGLVWDB.MT_GL_CHANNEL_REV_MEASURE GL_RTM\r\nON  GL.REVENUE_MEASURE_KEY = GL_RTM.REVENUE_MEASURE_KEY\r\nAND GL.DV_FISCAL_YEAR_MTH_NUMBER_INT = GL_RTM.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND GL.REV_MEASURE_TRANS_TYPE_CD  =  GL_RTM.REV_MEASURE_TRANS_TYPE_CD\r\nINNER JOIN $$ETLVWDB.EL_EDW_PNL_LINE_ITEM EL\r\nON  GL.REVENUE_MEASURE_KEY = EL.REVENUE_MEASURE_KEY\r\nAND GL.DV_FISCAL_YEAR_MTH_NUMBER_INT = EL.BK_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND GL.REV_MEASURE_TRANS_TYPE_CD  =  EL.REV_MEASURE_TRANS_TYPE_CD\r\nINNER JOIN $$COMREFVWDB.R_SALES_HIERARCHY_FIN SH \r\nON SH.SALES_TERRITORY_KEY=GL.SALES_TERRITORY_KEY \r\nAND SH.SALES_TERRITORY_TYPE_CODE  IN ('CORP. REVENUE','UNKNOWN')\r\n\r\nINNER JOIN $$STGDB.WI_PNL_MTH_CNTL_SRVC_REV_RTR WI\r\nON GL.DV_FISCAL_YEAR_MTH_NUMBER_INT = WI.FISCAL_YEAR_MONTH_INT\r\n\r\n\r\n/*LEFT JOIN (SELECT GL.DV_SALES_ORDER_LINE_KEY  FROM FINLGLVWDB.MT_RSTD_GL_REV_MEASURE  GL \r\nWHERE  GL.DV_FISCAL_YEAR_MTH_NUMBER_INT =201606 AND GL.DV_SALES_ORDER_LINE_KEY < 0 AND  GL.RSTD_DEL_RECORD_FLG='N' AND GL .DV_ATTRIBUTION_CD IN ('STANDALONE','ATTRIBUTED') GROUP BY 1) DistinctGL \r\nON  GL.DV_SALES_ORDER_LINE_KEY=DistinctGL.DV_SALES_ORDER_LINE_KEY  \r\nINNER JOIN $$FINLGLDB.N_AR_TRX_LINE  ATL\r\nON GL.DV_AR_TRX_LINE_KEY = ATL.AR_TRX_LINE_KEY\r\nINNER JOIN FINREVPVWDB.PV_SALES_ORDER_FIN SO  ON   GL.SALES_ORDER_KEY=SO.SALES_ORDER_KEY\r\nINNER JOIN COMREFVWDB.R_SALES_HIERARCHY_FIN SH ON SH.SALES_TERRITORY_KEY=GL.SALES_TERRITORY_KEY AND SH.SALES_TERRITORY_TYPE_CODE  IN ('CORP. REVENUE','UNKNOWN')\r\nINNER JOIN COMREFVWDB.R_PRODUCTS_FIN   P   ON  GL.PRODUCT_KEY=P.ITEM_KEY   AND ((GL.REVENUE_TRANSFER_KEY < 0  AND ATL.BK_AR_TRX_LINE_TYPE='LINE' AND GL.DD_BK_FINANCIAL_ACCOUNT_CD NOT IN ('41001','43310', '43320'))\r\nOR (GL.REV_MEASURE_TRANS_TYPE_CD = 'IND_ADJ' AND  P.RU_BK_PRODUCT_FAMILY_ID <> 'SERVICE')\r\nOR (GL.REV_MEASURE_TRANS_TYPE_CD = 'AR-OOD')  OR (GL.REVENUE_TRANSFER_KEY > 0 AND GL.DD_BK_FINANCIAL_ACCOUNT_CD NOT IN ('41001','43310', '43320')))\r\nINNER JOIN SLSORDVWDB.MT_CS_DEAL_SO_LINE_LINK MCS_LN_LK \r\nON (CASE  WHEN GL.DV_SALES_ORDER_LINE_KEY > 0  THEN  GL.DV_SALES_ORDER_LINE_KEY  ELSE  DistinctGL.DV_SALES_ORDER_LINE_KEY END  = MCS_LN_LK.SALES_ORDER_LINE_KEY) AND GL.DV_ATTRIBUTION_CD = MCS_LN_LK.DV_ATTRIBUTION_CD\r\nAND (CASE WHEN P.GOODS_OR_SERVICE_TYPE ='GOODS' THEN P.RU_BK_PRODUCT_SUBGROUP_ID ELSE P.RU_BK_SERVICE_PROD_SUBGROUP_ID END = MCS_LN_LK.BK_PRODUCT_SUBGROUP_ID )  \r\nINNER JOIN COMREFVWDB.MT_CS_DEAL_SVC_FIN_HIER_ALLOC MCS_SVC_FH_ME \r\nON MCS_LN_LK.APPROVED_DEAL_ID=MCS_SVC_FH_ME.APPROVED_DEAL_ID \r\nAND MCS_LN_LK.CS_DEAL_PRDT_SUB_GROUP_ID=MCS_SVC_FH_ME.BK_PRODUCT_SUBGROUP_ID   AND MCS_SVC_FH_ME.BK_ALLOCATED_SERVC_GROUP_ID  <> 'CLOUD MANAGED SERVICES'*/\r\n               \r\nWHERE 1=1\r\n       AND  GL.DV_SERVICE_FLG='Y'\r\n       AND  GL.DV_COMP_US_NET_REV_AMT <> 0\r\n       AND  GL.RSTD_DEL_RECORD_FLG='N' \r\n\t   AND  EL.DV_PNL_LINE_ITEM_NAME LIKE ANY('TS%','CMS%')\r\n\t   AND  WI.RUN_BATCH_ID = 1\r\n\r\n\r\nGROUP BY  1 ,2,3,4,5,6,7,8,9\r\nHAVING  COMP_US_NET_REV_AMT<>0\r\n\r\n)ABC\r\nQUALIFY SUM(COMP_US_NET_REV_AMT)\r\n OVER (PARTITION BY BK_FISCAL_YEAR_MTH_NUMBER_INT,BK_SALES_TERRITORY_KEY,DV_PNL_LINE_ITEM_NAME)<>0",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
  ],
