      "attributes": {
        "Sql Query": "SELECT\r\nROW_NUMBER() OVER (ORDER BY TRIM(WI.DW_CASE_ACTIVITY_KEY), CAST(WI.INCIDENT_NUMBER AS INTEGER), BK_FSCL_CAL_CD, BK_FSCL_MTH_NUM_INT,BK_FSCL_YR_NUM_INT) \r\n+ TSLA_ACTS.TSLA_ACTS_KEY AS SR_ACTIVITY_ACTS_KEY, \r\nRFMY.FISCAL_CALENDAR_CODE AS BK_FSCL_CAL_CD,\r\nRFMY.FISCAL_MONTH_NUMBER_INT AS BK_FSCL_MTH_NUM_INT,\r\nRFMY.FISCAL_YEAR_NUMBER_INT AS BK_FSCL_YR_NUM_INT,\r\nCAST(WI.INCIDENT_NUMBER AS INTEGER) AS BK_ACTIVITY_CD_INT,\r\nTRIM(WI.DW_CASE_ACTIVITY_KEY) AS DW_CASE_ACTIVITY_KEY_ID,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER AS  EDW_CREATE_USER\r\nFROM $$STGDB.WI_ACTS_TSLA_WORKTIME_F WI\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMY\r\nON RFMY.FISCAL_YEAR_MONTH_INT = WI.FISCAL_MONTH_ID\r\n,(SELECT COALESCE( MAX(SR_ACTIVITY_ACTS_KEY),0) TSLA_ACTS_KEY \r\nFROM $$ETLVWDB.SM_SR_ACTIVITY_ACTS) TSLA_ACTS\r\nWHERE NOT EXISTS (\r\nSELECT 1 FROM $$ETLVWDB.SM_SR_ACTIVITY_ACTS SMSAA\r\n         WHERE  SMSAA.DW_CASE_ACTIVITY_KEY_ID  = TRIM(WI.DW_CASE_ACTIVITY_KEY)\r\nAND SMSAA.BK_ACTIVITY_CD_INT = CAST(WI.INCIDENT_NUMBER AS INTEGER)\r\nAND SMSAA.BK_FSCL_CAL_CD = RFMY.FISCAL_CALENDAR_CODE\r\nAND SMSAA.BK_FSCL_MTH_NUM_INT =  RFMY.FISCAL_MONTH_NUMBER_INT  \r\nAND SMSAA.BK_FSCL_YR_NUM_INT = RFMY.FISCAL_YEAR_NUMBER_INT\r\n)",
        "User Defined Join": "",
