        "Sql Query": "SELECT \r\nSMSAA.SR_ACTIVITY_ACTS_KEY    \r\n,RFMY.FISCAL_CALENDAR_CODE AS BK_FSCL_CAL_CD\r\n,RFMY.FISCAL_MONTH_NUMBER_INT AS BK_FSCL_MTH_NUM_INT\r\n,RFMY.FISCAL_YEAR_NUMBER_INT AS BK_FSCL_YR_NUM_INT\r\n,WI.ACTIVITY_CODE AS BK_ACTIVITY_CD_INT\r\n,WI.ACTIVITY_ADDNL_INFO  AS ACTIVITY_ADTNL_INFO_TXT       \r\n,WI.ACTIVITY_DATE  AS ACTIVITY_DTM                  \r\n,CAST(WI.ACTIVITY_DATE AS DATE) AS DV_ACTIVITY_DT                \r\n,COALESCE(WI.ACTIVITY_NAME,'UNKNOWN') AS ACTIVITY_NAME\r\n,WI.ACTS_ABS_DEVIATION_TSLA AS ACTS_ABSLT_DVTN_TSLA_MINS_CNT \r\n,COALESCE(WI.ACTS_ACTIVITY_NAME,'UNKNOWN') AS ACTS_ACTIVITY_NAME\r\n,WI.ACTS_CONSISTENCY_CONSTANT AS ACTS_CONSISTENCY_CONSTANT_AMT \r\n,WI.ACTS_MEAN_NON_OUTLIER_TSLA AS ACTS_MEAN_NON_OUTLIER_TSLA_AMT\r\n,WI. ACTS_MEASURES_CALC_DATE  AS ACTS_MEASURE_CALC_DT          \r\n,WI.ACTS_MEDIAN_ABS_DEV_THRESHOLD AS ACTS_MDN_ABSLT_DVTN_THRSLD_AMT\r\n,WI.ACTS_MEDIAN_ABS_DEVIATION_TSLA AS ACTS_MDN_ABSLT_DVTN_TSLA_AMT  \r\n,WI.ACTS_OUTLIER_FLAG AS ACTS_OUTLIER_FLG              \r\n,WI.ACTS_MEDIAN_TSLA AS ACTS_MEDIAN_TSLA_AMT          \r\n,WI.ACTS_TSLA AS TSLA_MINUTES_CNT              \r\n,WI.ACTS_WORKTIME AS WORKTIME_ADJSTD_FOR_ACTS_CNT            \r\n,COALESCE(TRIM(WI.DW_CRNT_KEYWORD_KEY) , 'UNKNOWN')  AS CURRENT_KEYWORD_ID            \r\n,WI.FISCAL_MONTH_STATUS_IND AS FSCL_MTH_CLOSED_STATUS_CD     \r\n,COALESCE(WI.INCIDENT_STATUS,'UNKNOWN') AS SR_STATUS_NAME                \r\n,COALESCE(WI.INCIDENT_STATUS_ID,-999) AS SR_STATUS_ID_INT              \r\n,COALESCE(NCWP.CISCO_WORKER_PARTY_KEY,-999)  AS CHANGE_CSCO_WRKR_PRTY_KEY\r\n,WI.CHG_WKGRP_DELIVERY_CHANNEL   AS CHANGE_DELIVERY_CHANNEL_NAME  \r\n,COALESCE(WI.CHG_WKGRP_TAC_CENTER_NAME,'UNKNOWN')   AS CHANGE_TAC_NAME               \r\n,WI. CHG_WKGRP_MASTER_THEATER   AS CHANGE_WG_MASTER_THEATER_NAME \r\n,WI.CHG_DW_WORKGROUP_KEY  AS SK_CHANGE_DW_WG_KEY           \r\n,WI.CHG_WKGRP_NAME   AS CHANGE_WORKGROUP_NAME         \r\n,WI.CHG_WKGRP_NATURAL_KEY  AS SK_CHANGE_WG_NATURAL_KEY      \r\n,WI.CHG_WKGRP_THEATER_NAME   AS CHANGE_WG_THEATER_NAME        \r\n,WI.DW_CASE_ACTIVITY_KEY   AS DW_CASE_ACTIVITY_KEY_ID       \r\n,WI.INCIDENT_NUMBER   AS BK_SR_NUM_INT\r\n,'I' AS ACTION_CODE\r\n,'I' AS DML_TYPE                \r\nFROM $$STGDB.WI_ACTS_TSLA_WORKTIME_F WI\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMY\r\nON RFMY.FISCAL_YEAR_MONTH_INT = WI.FISCAL_MONTH_ID\r\nINNER JOIN $$ETLVWDB.SM_SR_ACTIVITY_ACTS SMSAA\r\nON SMSAA.DW_CASE_ACTIVITY_KEY_ID = WI.DW_CASE_ACTIVITY_KEY\r\nAND SMSAA.BK_ACTIVITY_CD_INT = WI.INCIDENT_NUMBER\r\nAND SMSAA.BK_FSCL_CAL_CD = RFMY.FISCAL_CALENDAR_CODE\r\nAND SMSAA.BK_FSCL_MTH_NUM_INT =  RFMY.FISCAL_MONTH_NUMBER_INT  \r\nAND SMSAA.BK_FSCL_YR_NUM_INT = RFMY.FISCAL_YEAR_NUMBER_INT\r\nLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP\r\nON WI.CHG_CCO_ID = NCWP.CEC_ID",
        "User Defined Join": "",
