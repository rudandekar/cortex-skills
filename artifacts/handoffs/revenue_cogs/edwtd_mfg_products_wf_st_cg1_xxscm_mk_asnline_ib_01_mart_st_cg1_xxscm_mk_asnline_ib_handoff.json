      "attributes": {
        "Sql Query": "SELECT \r\nTMP.ASN_LINE_ID, \r\nTMP.SHIP_SET_NUMBER, \r\nTMP.INVENTORY_ITEM_NUMBER,\r\n TMP.SHIPPED_QUANTITY, TMP.UOM, \r\n TMP.SERIAL_NUMBER, \r\n TMP.ASN_PROCESSED_FLAG, \r\n TMP.ASN_PROCESSED_STATUS, \r\n TMP.CREATION_DATE, \r\n TMP.CREATED_BY, \r\n TMP.LAST_UPDATE_DATE, \r\n TMP.LAST_UPDATED_BY, \r\n TMP.LAST_UPDATE_LOGIN, \r\n TMP.SERIAL_NUM_STATUS, \r\n TMP.MESSAGE_3B2_ID,\r\n  TMP.CONTAINER_ID, \r\n  TMP.PO_NUMBER, \r\n TMP.PO_RELEASE_LINE_NUMBER,\r\n  TMP.SOURCE_DML_TYPE,\r\n  TMP.SOURCE_COMMIT_TIME,\r\n'CG' AS GLOBAL_NAME,\r\n   TMP.REFRESH_DATETIME \r\nFROM $$NRTACCUMVWDB.CG1_XXSCM_MK_ASNLINE_IB TMP\r\nWHERE  SOURCE_COMMIT_TIME > '$$LastExtractDate' \r\nAND SOURCE_COMMIT_TIME <=  '$$EndLastExtractDate'\r\nAND SOURCE_DML_TYPE<>'DELETE'\r\nQUALIFY RANK () OVER (PARTITION BY TMP.ASN_LINE_ID ORDER BY TMP.ASN_LINE_ID, TMP.REFRESH_DATETIME DESC ) = 1",
