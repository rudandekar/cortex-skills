      "attributes": {
        "Sql Query": "SELECT WABBPL.AS_BUILT_BOM_PRODUCT_LINK_KEY,\r\n WABBPL.SALES_ORDER_LINE_KEY,\r\n WABBPL.INVENTORY_ORGANIZATION_KEY,\r\n WABBPL.PRODUCT_KEY, \r\n WABBPL.CONSTITUENT_PART_KEY,\r\n WABBPL.CARTON_ID,\r\n WABBPL.EP_MESSAGE_BOM_PACK_ID, \r\n WABBPL.EP_BOM_REF_ID,\r\n WABBPL.EP_BOM_PARENT_REF_ID, \r\n WABBPL.PLANNING_CD, \r\n WABBPL.BOM_INFRMTN_TRANSMISSION_DTM,\r\n WABBPL.CREATE_DTM,\r\n WABBPL.CNSTNT_PART_UNIT_COST_USD_AMT, \r\n WABBPL.CONSTITUENT_PART_QTY, \r\n WABBPL.SRC_RPRTD_PURCHASE_ORDER_NUM, \r\n WABBPL.PURCHASE_ORDER_KEY, \r\n WABBPL.AS_BUILT_PRODUCT_ITEM_TYPE_CD, \r\n WABBPL.AS_BLT_CNSTNT_PART_ITEM_REV_CD, \r\n WABBPL.BOM_PROCESS_STATUS_CD,\r\n WABBPL.PROCESS_STATUS_CD,\r\nWABBPL.EDW_CREATE_DTM, WABBPL.EDW_CREATE_USER, WABBPL.EDW_UPDATE_DTM, WABBPL.EDW_UPDATE_USER ,\r\nWABBPL.DF_FEE_USD_COST,\r\nWABBPL.DV_ROLLUP_USD_COST,\r\nWABBPL.LAST_UPDATED_DTM,\r\nWABBPL.DV_LAST_UPDATED_DT,\r\n/* :pvenketa added as part of Q3FY15 by SC-LSS */\r\nWABBPL.COST_ROLLUP_DTM,\r\nWABBPL.DV_COST_ROLLUP_DT\r\n/* End of code change */\r\nFROM\r\n$$WORKDB.W_AS_BUILT_BOM_PRODUCT_LINK WABBPL\r\nWHERE WABBPL.DML_TYPE = 'I'\r\nAND NOT EXISTS (\r\nSELECT 1 FROM $$INVFLMTDB.N_AS_BUILT_BOM_PRODUCT_LINK NABBPL\r\nWHERE \r\nWABBPL.AS_BUILT_BOM_PRODUCT_LINK_KEY = NABBPL.AS_BUILT_BOM_PRODUCT_LINK_KEY\r\n)",
