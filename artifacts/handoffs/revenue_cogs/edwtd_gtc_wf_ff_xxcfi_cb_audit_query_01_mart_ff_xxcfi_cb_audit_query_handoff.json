      "attributes": {
        "Sql Query": "SELECT AUDIT_QUERY_ID, \r\nAUDIT_NAME, \r\nAUDIT_OWNER, \r\nAUDIT_TYPE, \r\nAUDIT_COUNTRY_GROUP, \r\nAUDIT_RECORD_COUNT_TYPE,\r\nAUDIT_RECORD_COUNT,\r\nAUDIT_MONTH, \r\nAUDIT_YEAR, \r\nAUDIT_STATUS, \r\nCREATED_BY,\r\nCREATION_DATE, \r\nLAST_UPDATED_BY, \r\nLAST_UPDATED_DATE, \r\nreplace(REPLACE( AUDIT_COMMENTS,CHR(13),' '),chr(10),''), \r\nAUDIT_COMMITED,\r\nAUDIT_FISCAL_YEAR \r\nFROM\r\n CUBE.XXCFI_CB_AUDIT_QUERY \r\nwhere\r\nLAST_UPDATED_DATE > TO_DATE('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS')",
