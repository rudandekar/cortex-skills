      "attributes": {
        "Sql Query": "SELECT \r\nRANK() OVER (ORDER BY ST_RAO.ADJUSTMENT_LINE_ID,NSSC.SOURCE_SYSTEM_CODE ) + SMATKEY.MAX_VAL AS  COGS_PERCENT_KEY, \r\nST_RAO.ADJUSTMENT_LINE_ID AS SK_COGS_PERCENT_ID ,\r\nNSSC.SOURCE_SYSTEM_CODE AS SS_CD,\r\nST_RAO.ADJUSTMENT_LINE_ID AS SCHEDULE_LINE_ID,\r\nCURRENT_TIMESTAMP(0) as EDW_CREATE_DTM,\r\nUSER  as EDW_CREATE_USER\r\nFROM \r\n(SELECT COALESCE(MAX(SM.COGS_PERCENT_KEY),0) MAX_VAL \r\n FROM $$ETLVWDB.SM_RAE_COGS_PERCENT SM) SMATKEY,\r\n$$STGDB.ST_NGCCRM_RAE_ADJ_LINE_DTLS ST_RAO\r\nINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\nON (ST_RAO.GLOBAL_NAME = NSSC.GLOBAL_NAME)\r\nINNER JOIN $$ETLVWDB.EL_FND_APPLICATION_AR  EFAA\r\n\tON ST_RAO.APPLICATION_ID = EFAA.APPLICATION_ID\t\r\nWHERE UPPER(ST_RAO.EVENT_TYPE) ='TBA_DEFERRAL'\t\r\nAND UPPER(EFAA.APPLICATION_NAME) = 'REVENUE ACCOUNTING ENGINE'\r\n AND ST_RAO.ACCOUNT_CLASS IN  ('COST_OF_GOODS_SOLD','DEFERRED_COGS')\r\nAND NOT EXISTS (SELECT 1 FROM $$ETLVWDB.SM_RAE_COGS_PERCENT SM_I\r\nWHERE SM_I.SK_COGS_PERCENT_ID = ST_RAO.ADJUSTMENT_LINE_ID \r\nAND SM_I.SS_CD = NSSC.SOURCE_SYSTEM_CODE\r\nAND NSSC.GLOBAL_NAME = ST_RAO.GLOBAL_NAME\r\nAND SM_I.SCHEDULE_LINE_ID = ST_RAO.ADJUSTMENT_LINE_ID\r\n                )",
        "User Defined Join": "",
