        "Sql Query": "SELECT\t1 AS BATCH_ID,\r\n        CG1_XXCFIR_WEEE_FEE_HEADERS.WEEE_FEE_HEADER_ID,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.ORG_ID, \r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.COUNTRY,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.WEEE_FEE_INV_ITEM_ID, \r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.WEEE_FEE_ITEM_NAME,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.WEEE_FEE_CURRENCY,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.SOLD_TO_ORG_ID,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.STATE_OR_PROVINCE, \r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.WEEE_FEE_DESCRIPTION,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.START_DATE_ACTIVE, \r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.END_DATE_ACTIVE,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.CREATION_DATE, \r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.CREATED_BY,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.LAST_UPDATE_DATE,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.LAST_UPDATED_BY,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.LAST_UPDATE_LOGIN,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.ACCOUNT_NO,\r\n\t    CG1_XXCFIR_WEEE_FEE_HEADERS.SUBACCOUNT,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.ATTRIBUTE1,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.ATTRIBUTE2, \r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.ATTRIBUTE3,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.ATTRIBUTE4,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.ATTRIBUTE5,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.ATTRIBUTE6, \r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.ATTRIBUTE7,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.ATTRIBUTE8,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.ATTRIBUTE9,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.ATTRIBUTE10,\r\n\t\tCG1_XXCFIR_WEEE_FEE_HEADERS.SOURCE_COMMIT_TIME,\r\n\t\t'CG'AS GLOBAL_NAME ,\r\n\t\tCURRENT_TIMESTAMP(0)  AS CREATE_DATETIME ,\r\n\t\t'I' AS ACTION_CODE\r\nFROM\t\r\n(\r\n SELECT * FROM $$NRTACCUMVWDB.CG1_XXCFIR_WEEE_FEE_HEADERS\r\n WHERE SOURCE_COMMIT_TIME >= '$$LastExtractDate' \r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY WEEE_FEE_HEADER_ID ORDER BY REFRESH_DATETIME DESC)=1\r\n )CG1_XXCFIR_WEEE_FEE_HEADERS\r\n WHERE CG1_XXCFIR_WEEE_FEE_HEADERS.SOURCE_DML_TYPE <> 'DELETE'",
