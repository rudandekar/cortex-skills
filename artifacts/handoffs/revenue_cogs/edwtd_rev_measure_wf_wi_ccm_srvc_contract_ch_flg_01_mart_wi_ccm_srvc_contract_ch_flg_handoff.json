      ],
      "attributes": {
        "Sql Query": "SELECT \r\n\tNBM.SRC_RPTD_SERVICE_CONTARCT_NUM,\r\n\tCHFLG.CHANNEL_BOOKINGS_FLG CHANNEL_BOOKINGS_FLG\r\n\tFROM  \r\n\t$$STGDB.WI_CCM_SRVC_CONTRACT NBM\r\n\tINNER JOIN \r\n\t(\r\n\tSELECT \r\n\tSOLTV.RU_SERVICE_CONTRACT_NUMBER  AS SERVICE_CONTRACT ,\r\n\tNBCM.CHANNEL_BOOKINGS_FLG\r\n\tFROM \r\n\t$$SLSORDVWDB.N_BKGS_MEASURE NB \r\n\r\n\tINNER JOIN  $$SLSORDVWDB.N_BKGS_CHNL_MEASURE NBCM\r\n\tON  NB.BKGS_MEASURE_TRANS_TYPE_CODE  = NBCM.BKGS_MEASURE_TRANS_TYPE_CODE\r\n\tAND NB.BOOKINGS_MEASURE_KEY          = NBCM.BOOKINGS_MEASURE_KEY\r\n\tAND NB.BOOKINGS_PROCESS_DATE         = NBCM.BOOKINGS_PROCESS_DATE\t \r\n\r\n\tINNER JOIN   (SELECT SOLTV_IN.SALES_ORDER_LINE_KEY,SOLTV_IN.RU_SERVICE_CONTRACT_NUMBER \r\n\tFROM $$SLSORDVWDB.N_SALES_ORDER_LINE_TV   SOLTV_IN\r\n\tINNER JOIN $$STGDB.WI_CCM_SRVC_CONTRACT NBM_IN\r\n\tON NBM_IN.SRC_RPTD_SERVICE_CONTARCT_NUM=SOLTV_IN.RU_SERVICE_CONTRACT_NUMBER\r\n\tGROUP BY 1,2) SOLTV\r\n\tON SOLTV.SALES_ORDER_LINE_KEY = NB.SALES_ORDER_LINE_KEY\r\n\r\n\tINNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FD\r\n\tON NB.BOOKINGS_PROCESS_DATE = FD.CALENDAR_DATE\r\n\r\n\tINNER JOIN (SELECT DRIVER_FISCAL_YEAR_MONTH_INT,CURRENT_FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_COGS_RTM_MTH_CNTL GROUP BY 1,2)CNTL\r\n\tON FD.FISCAL_YEAR_MONTH_INT BETWEEN CNTL.DRIVER_FISCAL_YEAR_MONTH_INT AND CNTL.CURRENT_FISCAL_YEAR_MONTH_INT\r\n\r\n\r\n\tWHERE   NB.BKGS_MEASURE_TRANS_TYPE_CODE IN ('ERP','AR')\r\n\t/*AND FD.FISCAL_YEAR_MONTH_INT  BETWEEN 201301 and 201609 */\r\n\r\n\tGROUP BY \r\n\t1,2\r\n\tQUALIFY \r\n\tCOUNT (NBCM.CHANNEL_BOOKINGS_FLG) OVER (PARTITION BY SERVICE_CONTRACT)  =1\r\n\t) CHFLG   \r\n\tON NBM.SRC_RPTD_SERVICE_CONTARCT_NUM =  CHFLG.SERVICE_CONTRACT",
