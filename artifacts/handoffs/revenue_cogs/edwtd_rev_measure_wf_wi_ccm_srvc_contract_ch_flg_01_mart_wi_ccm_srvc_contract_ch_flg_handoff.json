      "attributes": {
        "Sql Query": "SELECT SRC_RPTD_SERVICE_CONTARCT_NUM \r\nFROM $$FINLGLVWDB.MT_SR_SSC_COST_MEASURE WHERE FISCAL_YEAR_MONTH_INT  IN (SELECT TARGET_FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_COGS_RTM_MTH_CNTL GROUP BY 1)\r\nGROUP BY 1\r\nUNION\r\nSELECT SRC_RPTD_SERVICE_CONTARCT_NUM \r\nFROM $$FINLGLVWDB.MT_SR_TAC_COST_MEASURE WHERE FISCAL_YEAR_MONTH_INT IN  (SELECT TARGET_FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_COGS_RTM_MTH_CNTL GROUP BY 1) \r\nGROUP BY 1",
