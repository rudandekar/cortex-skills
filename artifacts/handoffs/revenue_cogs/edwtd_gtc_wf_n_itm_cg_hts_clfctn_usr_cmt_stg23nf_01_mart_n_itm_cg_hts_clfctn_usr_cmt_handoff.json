      "attributes": {
        "Sql Query": "SELECT\t \r\n\tBATCH_ID,\r\n\tINTERNAL_COMMENTS_ID ,          \r\n\tITEM_NAME,\r\n\tCOUNTRY_GROUP_CODE,\r\n\tCOMMENTS,\r\n\tCREATED_BY,      \r\n\tCREATED_DATE,\r\n\tCREATE_DATETIME,\r\n\tACTION_CODE,     \r\n\t'RI' AS EXCEPTION_TYPE                  \r\nFROM\t$$STGDB.ST_XXCFI_CB_CLSFN_INTRNL_CMTS  SXCCIC\r\nWHERE NOT EXISTS\r\n\t(\t\r\n\tSELECT 1\r\n    FROM  $$ETLVWDB.SM_ITM_CG_HTS_CLFCTN_USR_CMT SCCUC    \r\n\tINNER JOIN $$FINLGLVWDB.N_ITM_CG_CSTMS_CLSFCTN NICC\r\n\t\r\n    ON ( SXCCIC.ITEM_NAME = (CASE WHEN NICC.RU_BK_GTC_ITEM_NUM = 'UNKNOWN'   THEN NICC.DD_ITEM_NUM\r\n                                  WHEN        NICC.DD_ITEM_NUM = 'UNKNOWN'   THEN NICC.RU_BK_GTC_ITEM_NUM\r\n                             END\r\n                           )\r\n       AND NICC.BK_WORLD_COUNTRY_GROUP_CD  =  SXCCIC.COUNTRY_GROUP_CODE                                                   \r\n       )\r\n\t\t\r\n\tINNER JOIN  $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWPTV\r\n\tON\t(NCWPTV.CEC_ID= (CASE WHEN (SXCCIC.CREATED_BY='DM' OR SXCCIC.CREATED_BY IS NULL) THEN 'UNKNOWN' ELSE SXCCIC.CREATED_BY END))\r\n\tINNER JOIN $$FINLGLVWDB.N_CSC_WRKR_PRTY_CSTMS_CUBE_USR NCWPCCU\r\n\tON (NCWPCCU.CISCO_WORKER_PARTY_KEY = NCWPTV.CISCO_WORKER_PARTY_KEY)\r\n\tWHERE\t( SCCUC.SK_INTERNAL_COMMENTS_ID_INT = SXCCIC.INTERNAL_COMMENTS_ID)  \r\n\t)",
