      "attributes": {
        "Sql Query": "SELECT\t \r\n\tSCCUC.ITM_CG_HTS_CLSFCTN_USR_CMT_KEY  AS ITM_CG_HTS_CLSFCTN_USR_CMT_KEY,\r\n\tSXCCIC.CREATED_DATE AS BK_CMT_DTM,\r\n\tNCWPCCU.cisco_worker_party_key AS BK_CUBE_USR_CSCO_WRKR_PRTY_KEY ,\r\n\tSXCCIC.COMMENTS AS USER_CMT, \r\n\tSXCCIC.INTERNAL_COMMENTS_ID AS SK_INTERNAL_COMMENTS_ID_INT   ,\r\n\tNICC.ITEM_CG_HTS_CLSFCTN_KEY,\r\n\tCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM, \r\n\tUSER AS EDW_CREATE_USER,\r\n\tCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM, \r\n\tUSER AS EDW_UPDATE_USER                \r\nFROM\t  (    \r\n\tSELECT\t INTERNAL_COMMENTS_ID,\r\n\t\tCREATED_DATE,\r\n\t\tCREATED_BY,\r\n\t\tITEM_NAME,\r\n\t\tCOUNTRY_GROUP_CODE,\r\n\t\tCOMMENTS \r\n\tFROM\t$$STGDB.ST_XXCFI_CB_CLSFN_INTRNL_CMTS    \r\n\tUNION ALL    \r\n\tSELECT\t INTERNAL_COMMENTS_ID,\r\n\t\tCREATED_DATE,\r\n\t\tCREATED_BY,\r\n\t\tITEM_NAME,\r\n\t\tCOUNTRY_GROUP_CODE,\r\n\t\tCOMMENTS \r\n\tFROM\t$$EXCEPDB.EX_XXCFI_CB_CLSFN_INTRNL_CMTS     \r\n\tWHERE\tEXCEPTION_TYPE = 'RI'  ) SXCCIC   \r\n\tINNER JOIN $$ETLVWDB.SM_ITM_CG_HTS_CLFCTN_USR_CMT SCCUC    \r\n\tON\t( SCCUC.SK_INTERNAL_COMMENTS_ID_INT = SXCCIC.INTERNAL_COMMENTS_ID)  \r\n\t\r\n\tINNER JOIN $$FINLGLVWDB.N_ITM_CG_CSTMS_CLSFCTN NICC\r\n    ON ( SXCCIC.ITEM_NAME = (CASE WHEN NICC.RU_BK_GTC_ITEM_NUM = 'UNKNOWN'   THEN NICC.DD_ITEM_NUM\r\n                                  WHEN        NICC.DD_ITEM_NUM = 'UNKNOWN'   THEN NICC.RU_BK_GTC_ITEM_NUM\r\n                             END\r\n                           )\r\n       AND NICC.BK_WORLD_COUNTRY_GROUP_CD  =  SXCCIC.COUNTRY_GROUP_CODE                                                   \r\n       )\r\n\t\t\r\n\tINNER JOIN  $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWPTV\r\n\tON\t(NCWPTV.CEC_ID= (CASE WHEN (SXCCIC.CREATED_BY='DM' OR SXCCIC.CREATED_BY IS NULL) THEN 'UNKNOWN' ELSE SXCCIC.CREATED_BY END))\r\n\tINNER JOIN $$FINLGLVWDB.N_CSC_WRKR_PRTY_CSTMS_CUBE_USR NCWPCCU\r\n\tON (NCWPCCU.CISCO_WORKER_PARTY_KEY = NCWPTV.CISCO_WORKER_PARTY_KEY)\r\nWHERE\tNOT EXISTS ( \r\nSELECT\t1    \r\nFROM\t  $$FINLGLVWDB.N_ITM_CG_HTS_CLFCTN_USR_CMT NICHCUC   \r\nWHERE\t NICHCUC.ITM_CG_HTS_CLSFCTN_USR_CMT_KEY = SCCUC.ITM_CG_HTS_CLSFCTN_USR_CMT_KEY )",
