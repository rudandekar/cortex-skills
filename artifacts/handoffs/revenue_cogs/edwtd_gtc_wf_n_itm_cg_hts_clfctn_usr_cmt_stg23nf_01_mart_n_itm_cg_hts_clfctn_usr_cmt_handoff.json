      "attributes": {
        "Sql Query": "SELECT\t\r\nRANK() OVER(ORDER\tBY SXCCIC.INTERNAL_COMMENTS_ID)+SMKEY.MAX_VAL AS ITM_CG_HTS_CLSFCTN_USR_CMT_KEY, \r\nSXCCIC.INTERNAL_COMMENTS_ID  SK_INTERNAL_COMMENTS_ID_INT, \r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM  , \r\nUSER AS EDW_CREATE_USER  \r\nFROM\t(    \r\nSELECT\t INTERNAL_COMMENTS_ID,CREATED_DATE,CREATED_BY,ITEM_NAME,\r\n\t\tCOUNTRY_GROUP_CODE,COMMENTS \r\nFROM\t$$STGDB.ST_XXCFI_CB_CLSFN_INTRNL_CMTS    \r\nUNION\r\n ALL    \r\nSELECT\t INTERNAL_COMMENTS_ID,CREATED_DATE,CREATED_BY,ITEM_NAME,\r\n\t\tCOUNTRY_GROUP_CODE,COMMENTS \r\nFROM\t$$EXCEPDB.EX_XXCFI_CB_CLSFN_INTRNL_CMTS    \r\nWHERE\tEXCEPTION_TYPE = 'RI'  ) SXCCIC\r\nINNER JOIN $$FINLGLVWDB.N_ITM_CG_CSTMS_CLSFCTN NICC\r\n  ON ( SXCCIC.ITEM_NAME = (CASE WHEN NICC.RU_BK_GTC_ITEM_NUM = 'UNKNOWN'   THEN NICC.DD_ITEM_NUM\r\n                                WHEN        NICC.DD_ITEM_NUM = 'UNKNOWN'   THEN NICC.RU_BK_GTC_ITEM_NUM\r\n                                                    END     )\r\n       AND NICC.BK_WORLD_COUNTRY_GROUP_CD  =  SXCCIC.COUNTRY_GROUP_CODE                                                   \r\n  ),\r\n(\r\nSELECT\tCOALESCE(MAX(ITM_CG_HTS_CLSFCTN_USR_CMT_KEY),0) MAX_VAL   \r\nFROM\t$$ETLVWDB.SM_ITM_CG_HTS_CLFCTN_USR_CMT) SMKEY \r\nWHERE\tNOT EXISTS   ( \r\nSELECT\t1     \r\nFROM\t$$ETLVWDB.SM_ITM_CG_HTS_CLFCTN_USR_CMT SICHCUC    \r\nWHERE\tSXCCIC.INTERNAL_COMMENTS_ID = SICHCUC.SK_INTERNAL_COMMENTS_ID_INT   )",
