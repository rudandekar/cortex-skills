      "attributes": {
        "Sql Query": "SELECT \r\nSTG.TAN_ID, \r\nSTG.TAN_DESC, \r\nSTG.TAN_ORGANIZATION_CODE,\r\n STG.PID, \r\n STG.PID_DESC, \r\n STG.PID_ORGANIZATION_CODE, \r\n STG.BUCKET_DATE, \r\n STG.SALES_ORDER, \r\n STG.UNCONSUMED_FORECAST,\r\nSTG.RELEASED_PO, \r\nSTG.PLANNED_PO, \r\nSTG.PUBLISH_DATE, \r\nSTG.CREATION_DATE, \r\nSTG.CREATED_BY, \r\nSTG.BATCH_ID, \r\nSTG.CREATE_DATETIME, \r\nSTG.ACTION_CODE \r\nFROM\r\n$$STGDB.ST_XXCMF_SP_BTS_EXT_PIDTAN STG\r\n\r\nLEFT  JOIN $$COMREFVWDB.N_CISCO_INVENTORY_ORG  NCIO ON\r\nSTG.TAN_ORGANIZATION_CODE=NCIO.INVENTORY_ORGANIZATION_CODE \r\n\r\n LEFT  JOIN $$COMREFVWDB.N_INVENTORY_ITEM NINV ON NINV.BK_PRODUCT_ID = STG.PID\r\nAND NINV.INVENTORY_ORGN_NAME_KEY =NCIO.INVENTORY_ORGN_NAME_KEY\r\n\r\nLEFT  JOIN  $$COMREFVWDB.N_INVENTORY_ITEM NPTAN ON NPTAN.BK_PRODUCT_ID = STG.PID\r\nAND NPTAN.INVENTORY_ORGN_NAME_KEY =NCIO.INVENTORY_ORGN_NAME_KEY\r\n\r\nLEFT  JOIN $$COMREFVWDB.N_FISCAL_WEEK NFW ON\r\nSTG.BUCKET_DATE BETWEEN NFW.FISCAL_WEEK_START_DATE  AND NFW.FISCAL_WEEK_END_DATE\r\nWHERE \r\nNINV.BK_PRODUCT_ID IS NULL\r\nOR NPTAN.BK_PRODUCT_ID IS NULL\r\nOR  NCIO.INVENTORY_ORGANIZATION_CODE  IS NULL\r\nOR  NFW.FISCAL_WEEK_START_DATE IS NULL",
