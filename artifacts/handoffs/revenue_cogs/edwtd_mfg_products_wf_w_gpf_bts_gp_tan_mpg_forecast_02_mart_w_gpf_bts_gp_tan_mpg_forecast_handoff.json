      "attributes": {
        "Sql Query": "SELECT \r\nNCIO_TAN.INVENTORY_ORGN_NAME_KEY,\r\nNINV.ITEM_KEY, \r\nNPTAN.ITEM_KEY,\r\nNFW.BK_FISCAL_WEEK_NUMBER_INT, \r\nNFW.BK_FISCAL_YEAR_NUMBER_INT, \r\nNFW.BK_FISCAL_CALENDAR_CODE,\r\nCOALESCE(STG.PUBLISH_DATE,DATE '3500-01-01') AS FORECAST_PUBLICATION_DT, \r\nNCIO.INVENTORY_ORGN_NAME_KEY,\r\nCOALESCE(STG.RELEASED_PO,0)  AS  COMMITTED_TAN_SUPPLY_QTY,\r\nCOALESCE(STG.UNCONSUMED_FORECAST,0)  AS UNCONSUMED_TAN_FORECAST_QTY,\r\nCOALESCE(STG.PLANNED_PO,0) AS PLANNED_TAN_SUPPLY_QTY,\r\nCOALESCE(STG.SALES_ORDER,0) AS PRODUCT_ORDERED_QTY,\r\n'I' AS ACTION_CODE,\r\n CASE WHEN NGBGTMF.GOODS_PRODUCT_KEY IS NULL THEN  'I'  ELSE 'U' END  AS  DML_TYPE \r\nFROM\r\n(SELECT * FROM \r\n$$STGDB.ST_XXCMF_SP_BTS_EXT_PIDTAN\r\nUNION ALL\r\nSELECT * FROM \r\n$$EXCEPDB.EX_XXCMF_SP_BTS_EXT_PIDTAN)\r\n STG\r\nINNER JOIN $$COMREFVWDB.N_CISCO_INVENTORY_ORG  NCIO ON\r\nSTG.PID_ORGANIZATION_CODE=NCIO.INVENTORY_ORGANIZATION_CODE \r\nINNER JOIN $$COMREFVWDB.N_INVENTORY_ITEM NINV ON NINV.BK_PRODUCT_ID = STG.PID\r\nAND NINV.INVENTORY_ORGN_NAME_KEY=NCIO.INVENTORY_ORGN_NAME_KEY\r\nINNER JOIN $$COMREFVWDB.N_CISCO_INVENTORY_ORG  NCIO_TAN ON\r\nSTG.TAN_ORGANIZATION_CODE=NCIO_TAN.INVENTORY_ORGANIZATION_CODE \r\nINNER JOIN $$COMREFVWDB.N_INVENTORY_ITEM NPTAN ON NPTAN.BK_PRODUCT_ID = STG.TAN_ID\r\nAND NPTAN.INVENTORY_ORGN_NAME_KEY =NCIO_TAN.INVENTORY_ORGN_NAME_KEY\r\nINNER JOIN $$COMREFVWDB.N_FISCAL_WEEK NFW ON\r\nSTG.BUCKET_DATE BETWEEN NFW.FISCAL_WEEK_START_DATE  AND NFW.FISCAL_WEEK_END_DATE\r\nLEFT JOIN $$INVFLMTVWDB.N_GPF_BTS_GP_TAN_MPG_FORECAST NGBGTMF  ON \t \r\nNCIO.INVENTORY_ORGN_NAME_KEY = NGBGTMF.PRODUCT_INVENTORY_ORGN_KEY\r\nAND NCIO_TAN.INVENTORY_ORGN_NAME_KEY = NGBGTMF.TAN_INVENTORY_ORGN_NAME_KEY\r\nAND NINV.ITEM_KEY =NGBGTMF.GOODS_PRODUCT_KEY\r\nAND NPTAN.ITEM_KEY=NGBGTMF.TAN_ITEM_KEY\r\nAND NFW.BK_FISCAL_WEEK_NUMBER_INT=NGBGTMF.BK_FRCST_FISCAL_WEEK_NUM_INT\r\nAND NFW.BK_FISCAL_YEAR_NUMBER_INT=NGBGTMF.BK_FRCST_FISCAL_YEAR_NUM_INT\r\nAND NFW.BK_FISCAL_CALENDAR_CODE = NGBGTMF.BK_FRCST_FISCAL_CALENDAR_CD\r\nAND STG.PUBLISH_DATE = NGBGTMF.BK_FORECAST_PUBLICATION_DT",
        "User Defined Join": "",
