        }
      ],
      "attributes": {
        "Sql Query": "/*IF (UPPER (WCSMA.account_number) <> 'EXPENSE' AND WCSMA.sub_account_number IS NOT NULL)*/\r\nSELECT WCSMA.PL_NODE_VALUE,\r\nWCSMA.ACCOUNT_NUMBER,\r\nWCSMA.ALLOCATION_METHOD,\r\nWCSMA.SUB_ACCOUNT_NUMBER,\r\nWCSMA.FUNCTIONAL_COST,\r\nWCSMA.COST_TYPE,\r\nCOALESCE(SUM (WCSID.AMOUNT), 0) AS INPUT_AMOUNT\r\nFROM $$STGDB.WI_CCM_SSC_MAPPING_ALLOCATION WCSMA\r\nJOIN $$STGDB.WI_CCM_SSC_INPUT_DOLLAR WCSID\r\nON WCSMA.PL_NODE_VALUE =WCSID.PL_NODE_VALUE\r\nAND WCSMA.ACCOUNT_NUMBER =WCSID.ACCOUNT_NUMBER\r\nAND TRIM(CAST(WCSMA.SUB_ACCOUNT_NUMBER AS INTEGER)) = TRIM(CAST(WCSID.SUB_ACCOUNT_NUMBER AS INTEGER))\r\nAND WCSMA.FUNCTIONAL_COST =WCSID.FUNCTIONAL_COST\r\nAND WCSMA.FISCAL_MONTH_ID =WCSID.FISCAL_MONTH_ID\r\nAND WCSMA.FISCAL_MONTH_ID IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)\r\nAND UPPER(WCSMA.ALLOCATION_METHOD) = 'QOH RATIO'\r\nAND UPPER(WCSMA.ACCOUNT_NUMBER) <> 'EXPENSE'\r\nAND WCSMA.SUB_ACCOUNT_NUMBER IS NOT NULL\r\nAND WCSID.ACCOUNT_NUMBER <> 68102\r\nGROUP BY 1,2,3,4,5,6\r\n\r\nUNION\r\n/*IF (UPPER (c.account_number) <> 'EXPENSE'  AND c.sub_account_number IS NULL)*/\r\nSELECT WCSMA.PL_NODE_VALUE,\r\nWCSMA.ACCOUNT_NUMBER,\r\nWCSMA.ALLOCATION_METHOD,\r\nWCSMA.SUB_ACCOUNT_NUMBER,\r\nWCSMA.FUNCTIONAL_COST,\r\nWCSMA.COST_TYPE,\r\nCOALESCE(SUM (WCSID.AMOUNT), 0) AS INPUT_AMOUNT\r\nFROM $$STGDB.WI_CCM_SSC_MAPPING_ALLOCATION WCSMA\r\nJOIN $$STGDB.WI_CCM_SSC_INPUT_DOLLAR WCSID\r\nON  WCSMA.PL_NODE_VALUE =WCSID.PL_NODE_VALUE\r\nAND WCSMA.ACCOUNT_NUMBER =WCSID.ACCOUNT_NUMBER\r\nAND WCSMA.FUNCTIONAL_COST =WCSID.FUNCTIONAL_COST\r\nAND WCSMA.FISCAL_MONTH_ID =WCSID.FISCAL_MONTH_ID\r\nAND WCSMA.FISCAL_MONTH_ID IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)\r\nAND UPPER(WCSMA.ALLOCATION_METHOD) = 'QOH RATIO'\r\nAND UPPER(WCSMA.ACCOUNT_NUMBER) <> 'EXPENSE'\r\nAND WCSMA.SUB_ACCOUNT_NUMBER IS NULL\r\nAND WCSID.ACCOUNT_NUMBER <> 68102\r\nGROUP BY 1,2,3,4,5,6\r\n\r\nUNION\r\n/*IF (UPPER (c.account_number) = 'EXPENSE')*/\r\nSELECT WCSMA.PL_NODE_VALUE,\r\nWCSMA.ACCOUNT_NUMBER,\r\nWCSMA.ALLOCATION_METHOD,\r\nWCSMA.SUB_ACCOUNT_NUMBER,\r\nWCSMA.FUNCTIONAL_COST,\r\nWCSMA.COST_TYPE,\r\nCOALESCE(SUM (WCSID.AMOUNT), 0) AS INPUT_AMOUNT\r\nFROM $$STGDB.WI_CCM_SSC_MAPPING_ALLOCATION WCSMA\r\nJOIN $$STGDB.WI_CCM_SSC_INPUT_DOLLAR WCSID\r\nON WCSMA.PL_NODE_VALUE =WCSID.PL_NODE_VALUE\r\nAND WCSMA.FUNCTIONAL_COST =WCSID.FUNCTIONAL_COST\r\nAND WCSMA.FISCAL_MONTH_ID =WCSID.FISCAL_MONTH_ID\r\nAND WCSMA.FISCAL_MONTH_ID IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)\r\nAND UPPER(WCSMA.ALLOCATION_METHOD) = 'QOH RATIO'\r\nAND UPPER(WCSMA.ACCOUNT_NUMBER) = 'EXPENSE'\r\nAND WCSID.ACCOUNT_NUMBER <> 68102\r\nGROUP BY 1,2,3,4,5,6\r\n\r\nUNION\r\n/* IF NONE OF ABOVE STATEMENTS ARE MATCHING AND UPPER (FUNCTIONAL_COST) = 'OTHER'*/\r\nSELECT PL_NODE_VALUE,\r\nACCOUNT_NUMBER,\r\n'Other' AS ALLOCATION_METHOD,\r\nSUB_ACCOUNT_NUMBER,\r\nFUNCTIONAL_COST,\r\n'Other' AS COST_TYPE,\r\nCOALESCE(SUM(AMOUNT),0) AS INPUT_AMOUNT\r\nFROM $$STGDB.WI_CCM_SSC_INPUT_DOLLAR WCSID\r\nWHERE UPPER (FUNCTIONAL_COST) = 'OTHER' \r\nAND FISCAL_MONTH_ID IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)\r\nGROUP BY 1,2,3,4,5,6",
        "User Defined Join": "",
        "Source Filter": "",
