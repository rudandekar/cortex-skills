      "attributes": {
        "Sql Query": "SELECT \r\nWCSQD.FISCAL_MONTH_ID ,\r\nTHEATER,\r\nIAT.COST_TYPE,\r\n1,\r\nIAT.INPUT_AMOUNT * INV_PERCENTAGE\r\nFROM $$STGDB.WI_CCM_SSC_QOH_DRIVER WCSQD\r\nJOIN WI_INPUT_AMOUNT IAT\r\nON WCSQD.FISCAL_MONTH_ID IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)",
