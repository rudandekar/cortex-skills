      "attributes": {
        "Sql Query": "SELECT \r\nPO.PROFILE_ID BK_CCRM_PROFILE_ID_INT, \r\nNSO.SALES_ORDER_KEY SALES_ORDER_KEY, \r\nPO.PROCESSED PROCESSED_CD ,\r\nPO.CREATION_DATETIME EDW_CREATE_DATE,\r\nUSER EDW_CREATE_USER,\r\nPO.CREATION_DATETIME EDW_UPDATE_DATE,\r\nUSER EDW_UPDATE_USER,\r\nPO.ACTION_CODE ACTION_CODE,\r\nPO.ACTION_CODE DML_TYPE\r\nFROM $$STGDB.ST_CCRM_PROFILE_ORDER PO \r\nINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES SSC\r\nON ( PO.GLOBAL_NAME =  SSC.GLOBAL_NAME )\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER NSO \r\nON (PO.HEADER_ID = NSO.SK_SALES_ORDER_HEADER_ID_INT\r\nAND SSC.SOURCE_SYSTEM_CODE = NSO.SS_CODE)\r\nUNION ALL\r\nSELECT \r\nPO.PROFILE_ID BK_CCRM_PROFILE_ID_INT, \r\nNSO.SALES_ORDER_KEY SALES_ORDER_KEY, \r\nPO.PROCESSED PROCESSED_CD,\r\nPO.CREATION_DATETIME EDW_CREATE_DATE,\r\nUSER EDW_CREATE_USER,\r\nPO.CREATION_DATETIME EDW_UPDATE_DATE,\r\nUSER EDW_UPDATE_USER,\r\nPO.ACTION_CODE ACTION_CODE,\r\nPO.ACTION_CODE DML_TYPE\r\nFROM $$EXCEPDB.EX_CCRM_PROFILE_ORDER PO \r\nINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES SSC\r\nON ( PO.GLOBAL_NAME =  SSC.GLOBAL_NAME )\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER NSO \r\nON (PO.HEADER_ID = NSO.SK_SALES_ORDER_HEADER_ID_INT\r\nAND SSC.SOURCE_SYSTEM_CODE = NSO.SS_CODE)",
