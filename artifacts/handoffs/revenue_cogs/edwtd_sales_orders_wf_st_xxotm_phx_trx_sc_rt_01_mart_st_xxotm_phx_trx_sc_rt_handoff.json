        "Sql Query": "SELECT \r\nXPTS.TRX_SC_ID, \r\nXPTS.TRX_ID, \r\nXPTS.SC_ID, \r\nXPTS.SC_SEQUENCE, \r\nXPTS.TRX_SPLIT_ID, \r\nXPTS.TOTAL_SPLIT_PERCENT, \r\nXPTS.SC_SPLIT_PERCENT, \r\nXPTS.TRX_SPLIT_PERCENT, \r\nXPTS.LATEST_SC_FLAG, \r\nXPTS.PARENT_CHILD_FLAG, \r\nXPTS.OTM_BATCH_ID, \r\nXPTS.OBJECT_VERSION_NUMBER, \r\nXPTS.SC_DUPLICATE_FLAG,\r\nXPTS.CREATION_DATE,\r\nXPTS.CREATED_BY, \r\nXPTS.LAST_UPDATE_DATE, \r\nXPTS.LAST_UPDATED_BY, \r\nXPTS.LAST_UPDATE_LOGIN, \r\nXPTS.START_DATE, \r\nXPTS.EXPIRATION_DATE, \r\nXPTS.TRAIL_FILE_NAME,\r\nXPTS.SOURCE_DML_TYPE ,              \r\nXPTS.SOURCE_COMMIT_TIME,            \r\nXPTS.REFRESH_DATETIME \r\nFROM\r\n$$NRTACCUMVWDB.XXOTM_PHX_TRX_SC  XPTS\r\nWHERE \r\nXPTS.SOURCE_COMMIT_TIME >= '$$LastExtractDate'\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY XPTS.TRX_SC_ID ORDER BY XPTS.REFRESH_DATETIME DESC) = 1",
