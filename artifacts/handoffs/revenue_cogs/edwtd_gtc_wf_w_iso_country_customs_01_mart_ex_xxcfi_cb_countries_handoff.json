      "attributes": {
        "Sql Query": "SELECT \r\nBATCH_ID       ,               \r\nCOUNTRY_ID     ,              \r\nCOUNTRY_CODE   ,               \r\nCOUNTRY_NAME   ,               \r\nDESCRIPTION    ,               \r\nCREATED_BY     ,               \r\nCREATED_DATE   ,               \r\nMODIFIED_BY    ,               \r\nMODIFIED_DATE  ,               \r\nINTERFACE_ITEMS ,              \r\nCREATE_DATETIME ,              \r\nACTION_CODE      ,             \r\n'RI' EXCEPTION_TYPE                \r\nFROM $$STGDB.ST_XXCFI_CB_COUNTRIES CTRY\r\nWHERE NOT EXISTS\r\n(\r\nSELECT 1 FROM  $$ETLVWDB.EL_XXCFI_CB_OVER_CNTRY_LIST OVR\r\n\t\t\t\t\r\nINNER JOIN $$COMREFVWDB.N_ISO_COUNTRY NIO1\r\nON (COALESCE(CTRY.COUNTRY_CODE,'UN') = NIO1.ISO_COUNTRY_SHORT_CODE)\r\n\t\t\t\r\nINNER JOIN $$COMREFVWDB.N_ISO_COUNTRY NIO2\r\nON (COALESCE(OVR.OVERRIDE_COUNTRY_CODE,'UN') = NIO2.ISO_COUNTRY_SHORT_CODE)\r\n\t\t\t\t\r\nWHERE (OVR.SHIP_TO_COUNTRY= CTRY.COUNTRY_CODE)\t\t\t\t\r\n)",
