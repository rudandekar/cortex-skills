      "attributes": {
        "Sql Query": "SELECT\r\n\tBK_ISO_COUNTRY_CD,\r\n\tBK_WORLD_COUNTRY_GROUP_CD,\r\n\tOVERRIDE_ISO_COUNTRY_CD,\r\n\tISO_COUNTRY_DESCR,\r\n\tEDW_CREATE_DTM                ,\r\n\tEDW_CREATE_USER               ,\r\n\tEDW_UPDATE_DTM                ,\r\n\tEDW_UPDATE_USER               ,\r\n\tSTART_TV_DTM,\r\n\tEND_TV_DTM,\r\n\t'I',\r\n\tDML_TYPE\r\nFROM\r\n(\r\n\tSELECT\r\n\t\tTV_OUT.BK_ISO_COUNTRY_CD,\r\n\t\tTV_OUT.OVERRIDE_ISO_COUNTRY_CD,\r\n\t\tTV_OUT.BK_WORLD_COUNTRY_GROUP_CD,\r\n\t\tTV_OUT.ISO_COUNTRY_DESCR,\r\n\t\tTV_OUT.START_TV_DTM,\r\n\t\tCOALESCE (MAX(TV_OUT.START_TV_DTM - INTERVAL '1' SECOND) OVER (PARTITION BY TV_OUT.BK_ISO_COUNTRY_CD ORDER BY TV_OUT.START_TV_DTM ASC\r\n\t\t                           ROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING),TIMESTAMP '3500-01-01 00:00:00') AS END_TV_DTM,\r\n\t\tCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\n\t\tUSER AS EDW_CREATE_USER,\r\n\t\tCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n\t\tUSER AS EDW_UPDATE_USER,\r\n\t\tROW_NUMBER () OVER (PARTITION BY TV_OUT.BK_ISO_COUNTRY_CD ORDER BY TV_OUT.START_TV_DTM ASC ) AS RANK_INDEX,\r\n\t\t(CASE  WHEN RANK_INDEX=1 AND NICCTV.BK_ISO_COUNTRY_CD IS NOT NULL THEN 'U' ELSE 'I' END ) DML_TYPE\r\n\tFROM\r\n\t(\r\n\t\tSELECT\r\n\t\t\tBK_ISO_COUNTRY_CD,\r\n\t\t\tOVERRIDE_ISO_COUNTRY_CD,\r\n\t\t\tBK_WORLD_COUNTRY_GROUP_CD,\r\n\t\t\tISO_COUNTRY_DESCR,\r\n\t\t\tCAST(START_TV_DTM AS TIMESTAMP(0)) AS START_TV_DTM,\r\n\t\t\tEDW_CREATE_DTM,\r\n\t\t\tROW_NUMBER () OVER (PARTITION BY BK_ISO_COUNTRY_CD,OVERRIDE_ISO_COUNTRY_CD,BK_WORLD_COUNTRY_GROUP_CD,ISO_COUNTRY_DESCR\r\n\t\t\t\t\tORDER BY EDW_CREATE_DTM DESC) AS ROW_NUM\r\n\t\tFROM\r\n\t\t(\r\n\t\t\tSELECT NIO1.BK_ISO_COUNTRY_CODE \t\t\tAS BK_ISO_COUNTRY_CD,\r\n\t\t\t\tNIO2.BK_ISO_COUNTRY_CODE    \t\t\tAS OVERRIDE_ISO_COUNTRY_CD,\r\n\t\t\t\tCOALESCE(MP.COUNTRY_GROUP_CODE,'UN')    AS BK_WORLD_COUNTRY_GROUP_CD,\r\n\t\t\t\tCTRY.DESCRIPTION            \t\t\tAS ISO_COUNTRY_DESCR,\r\n\t\t\t\tCTRY.MODIFIED_DATE         \t\t\t\tAS START_TV_DTM,\r\n\t\t\t\tCREATE_DATETIME            \t\t\t\tAS EDW_CREATE_DTM\r\n\t\t\tFROM\r\n\t\t\t(\r\n\t\t\t\tSELECT COUNTRY_CODE,DESCRIPTION,MODIFIED_DATE,CREATE_DATETIME FROM $$STGDB.ST_XXCFI_CB_COUNTRIES\r\n\t\t\t\tUNION ALL\r\n\t\t\t\tSELECT COUNTRY_CODE,DESCRIPTION,MODIFIED_DATE,CREATE_DATETIME FROM $$EXCEPDB.EX_XXCFI_CB_COUNTRIES\r\n\t\t\t\tWHERE EXCEPTION_TYPE = 'RI'\r\n\t\t\t)CTRY\r\n\t\t\tINNER JOIN $$ETLVWDB.EL_XXCFI_CB_OVER_CNTRY_LIST OVR\r\n\t\t\t\tON (OVR.SHIP_TO_COUNTRY= CTRY.COUNTRY_CODE)\r\n\t\t\tINNER JOIN $$COMREFVWDB.N_ISO_COUNTRY NIO1\r\n\t\t\t\tON (COALESCE(CTRY.COUNTRY_CODE,'UN') = NIO1.ISO_COUNTRY_SHORT_CODE)\r\n\t\t\t\r\n\t\t\tLEFT OUTER JOIN $$ETLVWDB.EL_CTRYGRP_CTRY_MAPPING MP\r\n\t\t\tON (COALESCE(CTRY.COUNTRY_CODE,'UN')= MP.COUNTRY_CODE)\t\r\n\t\t\t\t\r\n\t\t\tINNER JOIN $$COMREFVWDB.N_ISO_COUNTRY NIO2\r\n\t\t\t\tON (COALESCE(OVR.OVERRIDE_COUNTRY_CODE,'UN') = NIO2.ISO_COUNTRY_SHORT_CODE)\r\n\t\t\t\t\r\n\t\t\tUNION ALL\r\n\t\t\tSELECT\r\n\t\t\t\tBK_ISO_COUNTRY_CD,\r\n\t\t\t\tOVERRIDE_ISO_COUNTRY_CD,\r\n\t\t\t\tBK_WORLD_COUNTRY_GROUP_CD,\r\n\t\t\t\tISO_COUNTRY_DESCR,\r\n\t\t\t\tSTART_TV_DTM,\r\n\t\t\t\tEDW_CREATE_DTM\r\n\t\t\tFROM  $$FINLGLVWDB.N_ISO_COUNTRY_CUSTOMS_TV TV1\r\n\t\t\tWHERE END_TV_DTM = '3500-01-01 00:00:00'\r\n\t\t\t\tAND   EXISTS\r\n\t\t\t\t(\r\n\t\t\t\t  SELECT 1\r\n\t\t\t\t  FROM\r\n\t\t\t\t    (\r\n\t\t\t\t    SELECT COUNTRY_CODE FROM $$STGDB.ST_XXCFI_CB_COUNTRIES\r\n\t\t\t\t    UNION ALL\r\n\t\t\t\t    SELECT COUNTRY_CODE FROM $$EXCEPDB.EX_XXCFI_CB_COUNTRIES\r\n\t\t\t\t    ) CTRY\r\n\t\t\t\t    JOIN $$COMREFVWDB.N_ISO_COUNTRY NIO1\r\n\t\t\t\t\tON (CTRY.COUNTRY_CODE = NIO1.ISO_COUNTRY_SHORT_CODE)\r\n\t\t\t\t  WHERE NIO1.BK_ISO_COUNTRY_CODE = TV1.BK_ISO_COUNTRY_CD\r\n\t\t\t        )\r\n\t\t) TV_IN\r\n\t\tQUALIFY ROW_NUMBER () OVER (PARTITION BY TV_IN.BK_ISO_COUNTRY_CD,TV_IN.START_TV_DTM ORDER BY TV_IN.EDW_CREATE_DTM DESC) = 1 /*  Filter  duplicate rows of the same day  and get the latest*/\r\n\t)TV_OUT\r\n\tLEFT OUTER JOIN $$FINLGLVWDB.N_ISO_COUNTRY_CUSTOMS_TV NICCTV\r\n\t\tON( TV_OUT.BK_ISO_COUNTRY_CD = NICCTV.BK_ISO_COUNTRY_CD\r\n\t        AND NICCTV.END_TV_DTM = '3500-01-01 00:00:00' )\r\nWHERE TV_OUT.ROW_NUM = 1\r\n) TV",
        "User Defined Join": "",
        "Source Filter": "",
