      "attributes": {
        "Sql Query": "SELECT \r\nSOGSOB.LEDGER_ID               ,\r\nSOGSOB.ALLOW_INTERCOMPANY_POST_FLAG  ,\r\nSOGSOB.CHART_OF_ACCOUNTS_ID          ,\r\nSOGSOB.CURRENCY_CODE                 ,\r\nSOGSOB.DESCRIPTION                   ,\r\nSOGSOB.NAME                          ,\r\nSOGSOB.SHORT_NAME              ,      \r\nSOGSOB.ATTRIBUTE1                  ,  \r\nSOGSOB.CREATE_DATETIME       ,        \r\nSOGSOB.GLOBAL_NAME                ,   \r\nSOGSOB.CREATION_DATE             ,    \r\nSOGSOB.LAST_UPDATE_DATE      \r\n   FROM     $$STGDB.ST_CDC_GL_LEDGERS  SOGSOB\r\nWHERE  NOT EXISTS\r\n(SEL 1 \r\nFROM $$ETLVWDB.EL_CDC_GL_SETS_OF_BOOKS EOGSOB \r\nWHERE EOGSOB.SET_OF_BOOKS_ID=SOGSOB.LEDGER_ID AND \r\n   EOGSOB.GLOBAL_NAME =SOGSOB.GLOBAL_NAME)\r\n   QUALIFY ROW_NUMBER () OVER (PARTITION BY LEDGER_ID,GLOBAL_NAME  ORDER BY REFRESH_DATETIME  DESC)=1",
