      "attributes": {
        "Sql Query": "SELECT DISTINCT INITIAL_TECH_ID , \r\nINITIAL_SUB_TECH_ID , \r\nINITIAL_TECH_NAME , \r\nINITIAL_DW_CRNT_KEYWORD_KEY,\r\nD.TECH_ID AS FINAL_TECH_ID, \r\nD.SUB_TECH_ID AS FINAL_SUB_TECH_ID , \r\nD.TECH_NAME AS FINAL_TECH_NAME,\r\nHASH_MD5(SUBSTRING('0000000000',1,10-LENGTH(TRIM(CAST(D.TECH_ID AS VARCHAR(5) ) ) ) )|| TRIM(D.TECH_ID) || SUBSTRING('0000000000',1,10-LENGTH(TRIM(CAST(D.SUB_TECH_ID AS VARCHAR(5) ) ) ) )|| TRIM(D.SUB_TECH_ID) ||\r\n(CASE WHEN D.TECH_ID = -888 AND D.SUB_TECH_ID = -888 AND C.PROBLEM_CODE IS NULL THEN 'LEGACY' \r\nWHEN D.TECH_ID = -999 AND D.SUB_TECH_ID = -999 AND C.PROBLEM_CODE IS NULL THEN 'NOT AVAILABLE' WHEN C.PROBLEM_CODE IS NULL THEN 'NOT AVAILABLE' ELSE C.PROBLEM_CODE END) ) FINAL_DW_CRNT_KEYWORD_KEY\r\n,C.PROBLEM_CODE \r\nFROM \r\n(SELECT DISTINCT HASH_MD5(SUBSTRING('0000000000',1,10-LENGTH(TRIM(CAST(TECH_ID AS VARCHAR(5) ) ) ) )|| TRIM(TECH_ID) || SUBSTRING('0000000000',1,10-LENGTH(TRIM(CAST(SUB_TECH_ID AS VARCHAR(5) ) ) ) )|| TRIM(SUB_TECH_ID) ||\r\n(CASE WHEN TECH_ID = -888 AND SUB_TECH_ID = -888 AND INITIAL_PROBLEM_CODE IS NULL THEN 'LEGACY'\r\nWHEN TECH_ID = -999 AND SUB_TECH_ID = -999 AND INITIAL_PROBLEM_CODE IS NULL THEN 'NOT AVAILABLE' ELSE INITIAL_PROBLEM_CODE END) ) INITIAL_DW_CRNT_KEYWORD_KEY,\r\nB.TECH_ID AS INITIAL_TECH_ID , B.SUB_TECH_ID AS INITIAL_SUB_TECH_ID , B.TECH_NAME AS INITIAL_TECH_NAME,A.*\r\nFROM (SELECT PROBLEM_CODE,INITIAL_PROBLEM_CODE,INITIAL_COT_TECH_KEY , UPDATED_COT_TECH_KEY,ACTIVITY_DATE FROM $$ETLVWDB.EL_TSS_INCIDENTS_CRNT_F_WTCALC \r\nWHERE CAST(ACTIVITY_DATE AS DATE) >=(SELECT MIN(CALENDAR_DATE) FROM $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR WHERE FISCAL_QTR_AGE >=0 AND FISCAL_QTR_AGE<=13)\r\nOR CLOSED_DATE IS NULL) A\r\n\r\nLEFT OUTER JOIN (SELECT DISTINCT TECH_ID , SUB_TECH_ID , TECH_NAME , BL_COT_TECHNOLOGY_KEY FROM $$ETLVWDB.EL_TSS_COT_TECH_D_WTCALC) B\r\nON A.INITIAL_COT_TECH_KEY=B.BL_COT_TECHNOLOGY_KEY\r\nWHERE B.TECH_ID <>-777 ) C\r\n\r\nLEFT OUTER JOIN (SELECT TECH_ID , SUB_TECH_ID , TECH_NAME , BL_COT_TECHNOLOGY_KEY FROM $$ETLVWDB.EL_TSS_COT_TECH_D_WTCALC ) D\r\nON C.UPDATED_COT_TECH_KEY=D.BL_COT_TECHNOLOGY_KEY WHERE D.TECH_ID <>-777",
        "User Defined Join": "",
