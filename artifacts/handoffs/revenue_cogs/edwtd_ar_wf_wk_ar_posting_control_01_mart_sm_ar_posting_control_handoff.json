      "attributes": {
        "Sql Query": "SELECT \r\n\tSAPC.AR_POSTING_CONTROL_KEY,\r\n\tSOAPC.GL_POSTED_DATE    ,            \r\n\tSOAPC.CREATION_DATE   ,              \r\n\tSOAPC.POSTING_CONTROL_ID,\r\n\tNSSC.SOURCE_SYSTEM_CODE,\r\n\tSOAPC.ACTION_CODE,\r\n      'I' AS DML_TYPE\r\n\tFROM $$STGDB.ST_OM_AR_POSTING_CONTROL SOAPC\r\n\tINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\n\tON (NSSC.GLOBAL_NAME =SOAPC.GLOBAL_NAME)\r\n\tINNER JOIN $$ETLVWDB.SM_AR_POSTING_CONTROL SAPC\r\n\tON(SOAPC.POSTING_CONTROL_ID = SAPC.SK_GL_POSTING_CONTROL_ID_INT       \r\n\tAND  SAPC.SS_CD=NSSC.SOURCE_SYSTEM_CODE)\r\n\tUNION ALL\r\n\tSELECT \r\n\tSAPC.AR_POSTING_CONTROL_KEY,\r\n\tEOAPC.GL_POSTED_DATE    ,            \r\n\tEOAPC.CREATION_DATE   ,              \r\n\tEOAPC.POSTING_CONTROL_ID,\r\n\tNSSC.SOURCE_SYSTEM_CODE\t,\r\n\tEOAPC.ACTION_CODE,\r\n      'I' AS DML_TYPE\r\n\tFROM $$EXCEPDB.EX_OM_AR_POSTING_CONTROL EOAPC\r\n\tINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\n\tON (NSSC.GLOBAL_NAME =EOAPC.GLOBAL_NAME)\r\n\tINNER JOIN $$ETLVWDB.SM_AR_POSTING_CONTROL SAPC\r\n\tON(EOAPC.POSTING_CONTROL_ID = SAPC.SK_GL_POSTING_CONTROL_ID_INT       \r\n\tAND  SAPC.SS_CD=NSSC.SOURCE_SYSTEM_CODE)",
