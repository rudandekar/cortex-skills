      ],
      "attributes": {
        "Sql Query": "SEL RANK() OVER ( ORDER BY STOAP.POSTING_CONTROL_ID, NSSC.SOURCE_SYSTEM_CODE ) +SMAPC.MAX_VAL AR_POSTING_CONTROL_KEY,\r\nSTOAP.POSTING_CONTROL_ID, NSSC.SOURCE_SYSTEM_CODE\r\nFROM \r\n(SEL COALESCE(MAX (AR_POSTING_CONTROL_KEY), 0) MAX_VAL\r\nFROM $$ETLVWDB.SM_AR_POSTING_CONTROL ) SMAPC,\r\n( SEL \r\nPOSTING_CONTROL_ID ,GLOBAL_NAME \r\nFROM $$STGDB.ST_OM_AR_POSTING_CONTROL\r\nUNION ALL \r\nSEL POSTING_CONTROL_ID , GLOBAL_NAME \r\nFROM $$EXCEPDB.EX_OM_AR_POSTING_CONTROL WHERE EXCEPTION_TYPE = 'RI') STOAP\r\nINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC \r\nON( NSSC.GLOBAL_NAME = STOAP. GLOBAL_NAME ) \r\nWHERE NOT EXISTS ( SEL 1 FROM \r\n$$ETLVWDB.SM_AR_POSTING_CONTROL SMAPC\r\nWHERE SMAPC.SK_GL_POSTING_CONTROL_ID_INT = STOAP.POSTING_CONTROL_ID\r\nAND SMAPC.SS_CD = NSSC.SOURCE_SYSTEM_CODE)",
        "User Defined Join": "",
        "Source Filter": "",
