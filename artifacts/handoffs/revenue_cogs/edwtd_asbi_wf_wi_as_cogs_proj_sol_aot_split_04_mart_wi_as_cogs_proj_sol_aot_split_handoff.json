      ],
      "attributes": {
        "Sql Query": "SELECT MAP2.BK_AS_PROJECT_CD, NSWAP.SALES_ORDER_LINE_KEY ,'VALID_SOLK' AS SOL_IDENTIFIER\r\nFROM $$ASBIVWDB.MT_AS_PROJECT MAP2 \r\nINNER JOIN $$SERVICEVWDB.N_SOL_WITH_AS_PROJECT nswap \r\nON MAP2.BK_AS_PROJECT_CD = NSWAP.BK_AS_PROJECT_CD \r\nWHERE MAP2.LATEST_RECORD_FLG ='Y'\r\nAND MAP2.AS_PROJECT_CLASS_CD  IN ('SUBSCRIPTION','TRANSACTION','FIXED','CAP','INTERNAL') \r\nAND (MAP2.AS_PROJECT_STATUS_NAME IN ('ACTIVE','DELIVERY CLOSE','ON HOLD') OR (MAP2.AS_PROJECT_STATUS_NAME IN ('CLOSED') \r\nAND COALESCE(MAP2.AS_PROJECT_CLOSED_DT , MAP2.AS_PROJECT_ACTUAL_FINISH_DT , AS_PROJECT_COMPLETION_DT ,MAP2.DV_AS_PROJ_STATUS_CHANGED_DT) >\r\n(SELECT MIN(NFY.FISCAL_YEAR_START_DATE ) FROM $$COMREFVWDB.N_FISCAL_YEAR nfy WHERE NFY.BK_FISCAL_YEAR_NUMBER_INT >=2021)\r\n))\r\nGROUP BY 1,2,3\r\nUNION ALL\r\nSELECT \r\nMAP3.BK_AS_PROJECT_CD , WAPSL.SALES_ORDER_LINE_KEY ,SOL_IDENTIFIER\r\nFROM $$ASBIVWDB.MT_AS_PROJECT map3 \r\nINNER JOIN $$STGDB.WI_AS_COGS_PROJ_SOL_LINK WAPSL\r\nON MAP3.BK_AS_PROJECT_CD  = WAPSL.BK_AS_PROJECT_CD \r\nWHERE MAP3.LATEST_RECORD_FLG ='Y'\r\nAND MAP3.AS_PROJECT_CLASS_CD  IN ('SUBSCRIPTION','TRANSACTION','FIXED','CAP','INTERNAL') \r\nAND (MAP3.AS_PROJECT_STATUS_NAME IN ('ACTIVE','DELIVERY CLOSE','ON HOLD') OR (MAP3.AS_PROJECT_STATUS_NAME IN ('CLOSED') \r\nAND COALESCE(MAP3.AS_PROJECT_CLOSED_DT , MAP3.AS_PROJECT_ACTUAL_FINISH_DT , AS_PROJECT_COMPLETION_DT ,MAP3.DV_AS_PROJ_STATUS_CHANGED_DT) >\r\n(SELECT MIN(NFY.FISCAL_YEAR_START_DATE ) FROM $$COMREFVWDB.N_FISCAL_YEAR nfy WHERE NFY.BK_FISCAL_YEAR_NUMBER_INT >=2021)\r\n))\r\nGROUP BY 1, 2,3",
        "User Defined Join": "",
