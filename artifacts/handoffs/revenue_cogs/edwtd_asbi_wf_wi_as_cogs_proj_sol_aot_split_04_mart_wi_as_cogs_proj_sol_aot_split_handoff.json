    {
      "name": "SQ_WI_AS_COGS_PROJ_SOL_LNK_SPLIT",
      "type": "Source Qualifier",
      "description": "",
      "fields": [
        {
          "name": "BK_AS_PROJECT_CD",
          "datatype": "string",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        },
        {
          "name": "SALES_ORDER_LINE_KEY",
          "datatype": "integer",
