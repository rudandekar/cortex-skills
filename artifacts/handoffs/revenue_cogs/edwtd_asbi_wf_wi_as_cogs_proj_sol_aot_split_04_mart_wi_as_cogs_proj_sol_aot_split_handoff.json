        },
        {
          "name": "PSOL_SPLIT_PCT",
          "datatype": "decimal",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "SELECT \r\nNMR.BK_AS_PROJECT_CD,NMR.SALES_ORDER_LINE_KEY,(NMR.PSOL_COST/NULLIFZERO(TOTAL_COST)) AS PSOL_SPLIT_PCT\r\nFROM \r\n(SELECT\r\nA.BK_AS_PROJECT_CD,\r\nA.SALES_ORDER_LINE_KEY,\r\nSUM(COALESCE(RU_PROJ_REV_BDGT_USD_AMT,RU_PROJ_COST_BDGT_USD_AMT,1)) AS PSOL_COST \r\nFROM $$STGDB.WI_AS_COGS_PROJ_SOL_LINK A \r\nLEFT JOIN $$SERVICEVWDB.N_AS_PROJECT_BUDGET NAP\r\nON A.BK_AS_PROJECT_CD =NAP.BK_AS_PROJECT_CD\r\nAND \r\nCURRENT_VERSION_FLG ='Y'\r\nAND BK_AS_PROJECT_BUDGET_TYPE_CD IN ('AS Approved Revenue Budget','AS Approved Cost Budget')\r\nAND BK_AS_PROJ_BDGT_PRCSS_STAT_CD ='Y'\r\nGROUP BY 1,2) NMR\r\nINNER JOIN \r\n(SELECT\r\nA.SALES_ORDER_LINE_KEY,\r\nSUM(COALESCE(RU_PROJ_REV_BDGT_USD_AMT,RU_PROJ_COST_BDGT_USD_AMT,1)) AS TOTAL_COST \r\nFROM $$STGDB.WI_AS_COGS_PROJ_SOL_LINK A \r\nLEFT JOIN $$SERVICEVWDB.N_AS_PROJECT_BUDGET NAP\r\nON A.BK_AS_PROJECT_CD =NAP.BK_AS_PROJECT_CD\r\nAND \r\nCURRENT_VERSION_FLG ='Y'\r\nAND BK_AS_PROJECT_BUDGET_TYPE_CD IN ('AS Approved Revenue Budget','AS Approved Cost Budget')\r\nAND BK_AS_PROJ_BDGT_PRCSS_STAT_CD ='Y'\r\nGROUP BY 1)DNMR\r\nON NMR.SALES_ORDER_LINE_KEY=DNMR.SALES_ORDER_LINE_KEY",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
