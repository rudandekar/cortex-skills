      ],
      "attributes": {
        "Sql Query": "SELECT\r\nDV_SALES_ORDER_LINE_KEY,\r\nBK_AS_ATO_ARCHITECTURE_NAME ,  \r\nBK_BUSI_SVC_OFFER_TYPE_NAME ,  \r\nBK_ALLOCATED_SERVC_GROUP_ID   ,\r\nBK_AS_ATO_TECH_NAME   ,        \r\nDV_GOODS_ADJ_PRD_KEY,\r\nDV_CX_PRODUCT,\r\nSUM(DD_COMP_US_NET_PRICE_AMT) AS BOOKINGS_AMOUNT\r\nFROM $$SERVICEVWDB.MT_AS_SVCS_BOOKINGS A\r\nINNER JOIN $$COMREFVWDB.$$MAP_TGT_VAR1 SH  \r\nON SH.SALES_TERRITORY_KEY=A.SALES_TERRITORY_KEY\r\nAND SH.SALES_TERRITORY_TYPE_CODE ='CORP. REVENUE'\r\nWHERE A.ATTRIBUTION_CD IN ('ATTRIBUTED','STANDALONE')\r\nGROUP BY 1,2,3,4,5,6,7",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
