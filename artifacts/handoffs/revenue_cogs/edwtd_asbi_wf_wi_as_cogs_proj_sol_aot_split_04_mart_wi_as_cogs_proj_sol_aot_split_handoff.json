        }
      ],
      "attributes": {
        "Sql Query": "SELECT \r\nA.BK_AS_PROJECT_CD,\r\nA.DV_SALES_ORDER_LINE_KEY,\r\nBK_ALLOCATED_SERVC_GROUP_ID,\r\nA.BK_AS_ATO_ARCHITECTURE_NAME,\r\nA.BK_BUSI_SVC_OFFER_TYPE_NAME,\r\nA.BK_AS_ATO_TECH_NAME,\r\nA.DV_GOODS_ADJ_PRD_KEY,\r\nA.DV_CX_PRODUCT\r\n,CAST(A.BOOKINGS_AMOUNT AS DECIMAL(38,16)) /(NULLIFZERO(B.PROJECT_AMOUNT)) AS SPLIT_PCT\r\nFROM\r\n(SELECT \r\nB.BK_AS_PROJECT_CD,\r\nA.DV_SALES_ORDER_LINE_KEY,\r\nBK_ALLOCATED_SERVC_GROUP_ID,\r\nA.BK_AS_ATO_ARCHITECTURE_NAME,\r\nA.BK_BUSI_SVC_OFFER_TYPE_NAME,\r\nA.BK_AS_ATO_TECH_NAME,\r\nA.DV_GOODS_ADJ_PRD_KEY,\r\nA.DV_CX_PRODUCT ,\r\nSUM(ABS(A.BOOKINGS_AMOUNT)*coalesce(C.PSOL_SPLIT_PCT,1)) AS BOOKINGS_AMOUNT \r\nFROM $$STGDB.WI_AS_COGS_BKGS_SOL_AOT A\r\nINNER JOIN $$STGDB.WI_AS_COGS_PROJ_SOL_FINAL B\r\nON A.DV_SALES_ORDER_LINE_KEY=B.SALES_ORDER_LINE_KEY\r\nleft JOIN $$STGDB.WI_AS_COGS_PROJ_SOL_LNK_SPLIT C\r\nON B.SALES_ORDER_LINE_KEY=C.SALES_ORDER_LINE_KEY\r\nGROUP BY 1,2,3,4,5,6,7,8\r\n) A\r\nINNER JOIN \r\n(SELECT \r\nB.BK_AS_PROJECT_CD,\r\nSUM(ABS(A.BOOKINGS_AMOUNT)*coalesce(C.PSOL_SPLIT_PCT,1)) AS PROJECT_AMOUNT\r\nFROM $$STGDB.WI_AS_COGS_BKGS_SOL_AOT A\r\nINNER JOIN $$STGDB.WI_AS_COGS_PROJ_SOL_FINAL B\r\nON A.DV_SALES_ORDER_LINE_KEY=B.SALES_ORDER_LINE_KEY\r\nleft JOIN $$STGDB.WI_AS_COGS_PROJ_SOL_LNK_SPLIT C\r\nON B.SALES_ORDER_LINE_KEY=C.SALES_ORDER_LINE_KEY\r\nGROUP BY 1 \r\nHAVING SUM(ABS(A.BOOKINGS_AMOUNT)) <>0\r\n) B\r\nON A.BK_AS_PROJECT_CD=B.BK_AS_PROJECT_CD",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
