      "attributes": {
        "Sql Query": "SELECT\r\nINSTANCE_ID,\r\nREPLACE(REPLACE(NVL (SERIAL_NUMBER, DUP_SERIAL_NUMBER),CHR(10),' '),CHR(13),' ')  AS SERIAL_NUMBER,\r\nREPLACE(REPLACE(INSTANCE_STATUS_DESC ,CHR(10),' '),CHR(13),' ') AS IB_STATUS,\r\nCAST(SUBSTR(CAST(WARRANTY_END_DATE AS VARCHAR(19)),1,10) AS DATE) AS WARRANTY_END_DATE,\r\nINSTANCE_CREATION_DATE AS CREATION_DATE,\r\nNRT_LAST_UPDATE_DATE AS LAST_UPDATE_DATE,\r\nATTRIBUTE1 AS ERP_SHIP_DATE,\r\nSYSDATE AS EDW_CREATE_DTM,\r\nWARRANTY_COVERAGE_TEMPLATE as WARRANTY_TYPE\r\nFROM APPS.XXCCS_DS_INSTANCE_DETAIL\r\nWHERE substr(rowid,15,1) BETWEEN 'Y' AND 'b'",
