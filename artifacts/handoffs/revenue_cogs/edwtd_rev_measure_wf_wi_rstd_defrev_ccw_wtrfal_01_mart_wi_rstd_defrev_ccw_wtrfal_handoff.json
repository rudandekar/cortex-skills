      "attributes": {
        "Sql Query": "SELECT       \r\n    SV.PROCESSED_FISCAL_YEAR_MTH_INT,\r\n    SV.FISCAL_YEAR_MONTH_INT,\r\n    P.ITEM_KEY,      \r\n    SV.RSTD_SALES_TERRITORY_KEY ORIG_SALES_TERRITORY_KEY    ,  \r\n    SV.RSTD_SALES_TERRITORY_KEY ,         \r\n    COALESCE (SV.BK_DEAL_ID,'UNKNOWN'),\r\n    SUM(ZEROIFNULL(SV.COMP_US_NET_REV_AMT   /* *COALESCE (EL.ALLOCATION_PCT,1) */ )) COMP_US_NET_REV_AMT1,\r\n    SV.SALES_ORDER_KEY ,\r\n    SV.DV_ATTRIBUTION_CD ,\r\n    COALESCE (SV.DV_PRODUCT_KEY, -998),\r\n    SV.SK_OFFER_ATTRIBUTION_ID_INT,\r\n    SV.ADJUSTMENT_TRX_TYPE_CD ,\r\n\tSV.POB_TYPE_CD ,\r\n\tSUM(SV.RESTATED_SLS_CRDT_SPLIT_PCT)\r\n    FROM\r\n    $$FINLGLVWDB.MT_RSTD_DEFERRED_REVENUE_TRX SV\r\n    INNER JOIN $$COMREFVWDB.R_PRODUCTS_FIN P\r\n    ON SV.PRODUCT_KEY=P.ITEM_KEY  \r\n    INNER JOIN $$COMREFVWDB.R_SALES_HIERARCHY_FIN SH\r\n    ON SV.RSTD_SALES_TERRITORY_KEY =SH.SALES_TERRITORY_KEY\r\n    /*LEFT OUTER JOIN $$ETLVWDB.EL_DFR_DISTI2DIRECT_PCT EL\r\n    ON SH.L3_SALES_TERRITORY_NAME_CODE  =EL.L3_SALES_TERRITORY_NAME_CODE \r\n    AND  SV.PROCESSED_FISCAL_YEAR_MTH_INT  =EL.FISCAL_YEAR_MONTH_INT\r\n    AND EL.SERVICE_FLG = 'N'*/\r\n    WHERE\r\n    SV.DV_ATTRIBUTION_CD IN ('STANDALONE','ATTRIBUTED')\r\n    AND SV.DV_UNEARN_FINANCIAL_ACCOUNT_CD  IN  ( '27029'  ) \r\n    AND P.BK_TECHNOLOGY_GROUP_ID          NOT IN  ( 'SERVICE-TG'  )\r\n    AND SV.DV_CORPORATE_REVENUE_FLG      ='Y'\r\n  AND P.GOODS_OR_SERVICE_TYPE = 'GOODS' /* Added as part of Q1FY19*/\r\n    AND SV.PROCESSED_FISCAL_YEAR_MTH_INT  IN (SELECT PROCESSED_FISCAL_YEAR_MTH_INT FROM $$STGDB.WI_DEFREV_CCW_MONTH_CNTL)\r\n    /*Added on FEB FY18 Release to Load non cspp data*/\r\n  AND SV.ADJUSTMENT_TRX_TYPE_CD  NOT IN ('CSPP_ADJ','CSPP_ANNUITY_ADJ')\r\n     GROUP BY 1,2,3,4,5,6,8,9,10,11,12,13",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
