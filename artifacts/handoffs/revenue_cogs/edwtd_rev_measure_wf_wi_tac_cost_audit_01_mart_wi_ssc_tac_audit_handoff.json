      "attributes": {
        "Sql Query": "SEL SRC.FISCAL_MONTH_ID,'TAC_COST' AS DV_SOURCE_NAME,'N_SR_TECHNI_ASSIST_CENTER_COST' AS AUDIT_TABLE, CURRENT_DATE AS AUDIT_DATE,\r\nABS(COALESCE(TGT.TGT_COST,0)-  COALESCE(SRC.SRC_COST,0)) AS DOLLAR_MISMATCH_AMT ,\r\nABS(COALESCE(TGT.TGT_COUNT,0)-  COALESCE(SRC.SRC_COUNT,0)) AS COUNT_MISMATCH\r\nFROM \r\n( SEL FISCAL_MONTH_ID,COUNT(DISTINCT SR_NUMBER) AS  SRC_COUNT , \r\nSUM(COALESCE(TAC_BB_COST,0))+ SUM(COALESCE(TAC_OT_COST,0)) + SUM(COALESCE(OH_COST,0)) +SUM(COALESCE(TBO_COST,0)) AS SRC_COST \r\nFROM $$STGDB.WI_EDW_TS_TAC_COGS  WHERE FISCAL_MONTH_ID IN (SELECT FISCAL_YEAR_MONTH_INT FROM  $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)\r\nGROUP BY 1 ) SRC \r\n\r\nFULL JOIN ( SEL  CASE WHEN  BK_SR_TAC_COST_FSCL_MTH_NUM_INT<=9 THEN  (TRIM(BK_SR_TAC_COST_FSCL_YR_NUM_INT)||'0'||TRIM(BK_SR_TAC_COST_FSCL_MTH_NUM_INT)) \r\nELSE  (TRIM(BK_SR_TAC_COST_FSCL_YR_NUM_INT)||TRIM(BK_SR_TAC_COST_FSCL_MTH_NUM_INT)) END AS FISCAL_MONTH_ID, \r\nCOUNT(DISTINCT SRC_RPTD_SERVICE_REQUEST_NUM_INT) TGT_COUNT,\r\nSUM(COALESCE(TAC_BACKBONE_COST_USD_AMT ,0))+ SUM(COALESCE(TAC_OUT_TASKING_COST_AMT,0) ) +SUM(COALESCE(TAC_OVERHEAD_COST_USD_AMT,0)) +SUM(COALESCE(TAC_THEATER_BUSI_OPERATIONS_COST_USD_AMT,0)) AS TGT_COST \r\nFROM $$FINLGLVWDB.N_SR_TECHNI_ASSIST_CENTER_COST \r\nWHERE CASE WHEN  BK_SR_TAC_COST_FSCL_MTH_NUM_INT<=9 THEN  (TRIM(BK_SR_TAC_COST_FSCL_YR_NUM_INT)||'0'||TRIM(BK_SR_TAC_COST_FSCL_MTH_NUM_INT)) \r\nELSE  (TRIM(BK_SR_TAC_COST_FSCL_YR_NUM_INT)||TRIM(BK_SR_TAC_COST_FSCL_MTH_NUM_INT)) END IN \r\n(SELECT FISCAL_YEAR_MONTH_INT FROM  $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)\r\nGROUP BY 1\r\n) TGT ON SRC.FISCAL_MONTH_ID=TGT.FISCAL_MONTH_ID",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
