      "attributes": {
        "Sql Query": "SELECT \r\nSTG.PID,\r\n  STG.PID_ORGANIZATION_CODE,\r\n  STG.ON_HAND,\r\n  STG.UNIT_COST,\r\n  STG.EOS_DATE,\r\n  STG.ORDERABILITY,\r\n  STG.PUBLISH_DATE,\r\n  STG.CREATION_DATE,\r\n  STG.CREATED_BY,\r\n  STG.BATCH_ID,\r\n  STG.CREATE_DATETIME,\r\n  STG.ACTION_CODE\r\nFROM $$STGDB.ST_XXCMF_SP_BTS_EXTR_PID STG\r\nLEFT JOIN $$COMREFVWDB.N_CISCO_INVENTORY_ORG NCIO ON NCIO.INVENTORY_ORGANIZATION_CODE = STG.PID_ORGANIZATION_CODE\r\nLEFT JOIN $$COMREFVWDB.N_INVENTORY_ITEM NINV ON NINV.BK_PRODUCT_ID = STG.PID\r\nAND NINV.INVENTORY_ORGN_NAME_KEY =NCIO.INVENTORY_ORGN_NAME_KEY\r\nWHERE NCIO.INVENTORY_ORGANIZATION_CODE IS NULL\r\nOR  NINV.BK_PRODUCT_ID IS NULL",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
