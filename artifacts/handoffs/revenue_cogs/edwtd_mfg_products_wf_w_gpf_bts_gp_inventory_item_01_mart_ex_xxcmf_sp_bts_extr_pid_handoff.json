        }
      ],
      "attributes": {
        "Sql Query": "select NCIO.INVENTORY_ORGN_NAME_KEY AS INVENTORY_ORGN_NAME_KEY,\r\nNINV.ITEM_KEY AS GOODS_PRODUCT_KEY,\r\nCOALESCE(STG.ON_HAND,0) AS ON_HAND_QTY,\r\nCOALESCE(STG.UNIT_COST,0.000) AS UNIT_USD_COST,\r\nCOALESCE(STG.EOS_DATE,DATE '3500-01-01') AS  END_OF_SALE_DT ,\r\nCOALESCE(STG.PUBLISH_DATE,DATE '3500-01-01') AS PUBLICATION_DT ,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NGBGII.INVENTORY_ORGN_NAME_KEY IS NULL THEN  'I'  ELSE 'U' END  AS  DML_TYPE \r\nfrom \r\n(SELECT * FROM $$STGDB.ST_XXCMF_SP_BTS_EXTR_PID  \r\nUNION ALL\r\nSELECT * FROM $$EXCEPDB.EX_XXCMF_SP_BTS_EXTR_PID\r\n ) STG\r\nINNER JOIN $$COMREFVWDB.N_CISCO_INVENTORY_ORG NCIO ON NCIO.INVENTORY_ORGANIZATION_CODE = STG.PID_ORGANIZATION_CODE\r\nINNER JOIN $$COMREFVWDB.N_INVENTORY_ITEM NINV ON NINV.BK_PRODUCT_ID = STG.PID\r\nAND NINV.INVENTORY_ORGN_NAME_KEY =NCIO.INVENTORY_ORGN_NAME_KEY\r\nLEFT JOIN  $$INVFLMTVWDB.N_GPF_BTS_GP_INVENTORY_ITEM NGBGII ON\r\n NCIO.INVENTORY_ORGN_NAME_KEY= NGBGII.INVENTORY_ORGN_NAME_KEY\r\nAND NINV.ITEM_KEY= NGBGII.GOODS_PRODUCT_KEY",
        "User Defined Join": "",
        "Source Filter": "",
