      "attributes": {
        "Sql Query": "SELECT\r\n MT.PROCESSED_FISCAL_YEAR_MTH_INT \r\n,MT.DV_MEASURE_NAME               \r\n,MT.BK_MEASURE_NAME               \r\n,MT.SALES_TERRITORY_KEY           \r\n,MT.PRODUCT_KEY                   \r\n,MT.FISCAL_YEAR_MONTH_INT         \r\n,MT.SRC_ENTITY_NAME               \r\n,MT.BK_DEAL_ID                    \r\n,MT.ERP_DEAL_ID                   \r\n,MT.BK_CCRM_PROFILE_ID_INT        \r\n,MT.SERVICE_FLG                   \r\n,MT.BALANCE_REV_USD_AMT           \r\n,MT.PROJECTED_REV_USD_AMT         \r\n,MT.EDW_CREATE_DTM                \r\n,MT.EDW_CREATE_USER               \r\n,MT.EDW_UPDATE_DTM                \r\n,MT.EDW_UPDATE_USER               \r\n,MT.SALES_ORDER_KEY               \r\n,MT.DV_ATTRIBUTION_CD             \r\n,MT.DV_PRODUCT_KEY                \r\n,-7777 as AR_TRX_KEY                    \r\n,CASE WHEN MSI.GOODS_OR_SERVICE_TYPE = 'GOODS' THEN MSI.RU_BK_PRODUCT_SUBGROUP_ID ELSE MSI.RU_BK_SERVICE_PROD_SUBGROUP_ID END RU_BK_PRODUCT_SUBGROUP_ID            \r\n,CAST (\r\nTRIM(COALESCE(MT.PRODUCT_KEY,-999)) || '~' ||\r\nTRIM(COALESCE(MT.DV_PRODUCT_KEY,-999)) ||  '~' ||\r\nTRIM(COALESCE(MT.SALES_ORDER_KEY,-9999)) ||  '~' ||\r\nTRIM(COALESCE(MT.SK_OFFER_ATTRIBUTION_ID_INT,-9999))AS VARCHAR(70)\r\n) AS  DV_RECURRING_OFFER_CD        \r\n,'Y' as DV_CORPORATE_REVENUE_FLG \r\n,-9999  AR_TRX_LINE_KEY\r\n,MT.NET_PRICE_FLG\r\nFROM   \r\n  $$FINLGLVWDB.MT_RSTD_FIN_DEFERRED_REVENUE MT\r\n  INNER  JOIN  $$COMREFVWDB.R_PRODUCTS MSI   ON MSI.ITEM_KEY=MT.PRODUCT_KEY\r\n  WHERE PROCESSED_FISCAL_YEAR_MTH_INT = (\r\n    SELECT PROCESSED_FISCAL_YEAR_MTH_INT FROM $$STGDB.WI_DEFREV_CCW_MONTH_CNTL)\r\n  AND  DV_MEASURE_NAME = 'SERVICE_MAN_JV'",
        "User Defined Join": "",
