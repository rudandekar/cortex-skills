      "attributes": {
        "Sql Query": "SELECT TMP.DELIVERY_ID, TMP.NAME, TMP.PLANNED_FLAG, TMP.STATUS_CODE, TMP.CREATION_DATE, TMP.ASN_DATE_SENT, TMP.ASN_STATUS_CODE, TMP.DELIVERED_DATE, TMP.CONFIRM_DATE, TMP.INITIAL_PICKUP_DATE, TMP.ULTIMATE_DROPOFF_DATE, \r\n'CG' AS GLOBAL_NAME,TMP.SOURCE_DML_TYPE, TMP.SOURCE_COMMIT_TIME, TMP.REFRESH_DATETIME \r\nFROM\r\n(SELECT DELIVERY_ID, NAME, PLANNED_FLAG, STATUS_CODE, CREATION_DATE, ASN_DATE_SENT, ASN_STATUS_CODE, DELIVERED_DATE, CONFIRM_DATE, INITIAL_PICKUP_DATE, ULTIMATE_DROPOFF_DATE\r\n,SOURCE_DML_TYPE, SOURCE_COMMIT_TIME, REFRESH_DATETIME \r\nFROM $$NRTACCUMVWDB.CG1_WSH_NEW_DELIVERIES TMP\r\nWHERE  SOURCE_COMMIT_TIME > '$$LastExtractDate' \r\nAND SOURCE_COMMIT_TIME <=  '$$EndLastExtractDate'\r\nAND SOURCE_DML_TYPE<>'DELETE')TMP\r\nQUALIFY RANK () OVER (PARTITION BY TMP.DELIVERY_ID ORDER BY TMP.DELIVERY_ID, TMP.REFRESH_DATETIME DESC ) = 1",
        "User Defined Join": "",
        "Source Filter": "",
