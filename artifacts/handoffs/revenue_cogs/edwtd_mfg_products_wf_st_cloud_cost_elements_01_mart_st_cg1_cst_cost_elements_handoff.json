      "attributes": {
        "Sql Query": "SELECT \r\nCOST_ELEMENT_ID\r\n,COALESCE(LAST_UPDATE_DATE, CURRENT_TIMESTAMP(0)) AS LAST_UPDATE_DATE\r\n,-1 AS LAST_UPDATED_BY               \r\n,COALESCE(CREATION_DATE, CURRENT_TIMESTAMP(0)) AS CREATION_DATE\r\n,-1 AS CREATED_BY                    \r\n,-1 AS LAST_UPDATE_LOGIN             \r\n,COALESCE(COST_ELEMENT,'Resource') AS COST_ELEMENT\r\n,COALESCE(DESCRIPTION,'Resource cost element') AS DESCRIPTION\r\n,REQUEST_ID                    \r\n,PROGRAM_APPLICATION_ID        \r\n,PROGRAM_ID                    \r\n,PROGRAM_UPDATE_DATE           \r\n,'ERPCLOUD' AS GLOBAL_NAME                   \r\n,GES_UPDATE_DATE\r\n,CREATE_DATETIME               \r\n,ACTION_CODE                   \r\nFROM\r\n$$ETLVWDB.ST_CLOUD_CST_COST_ELEMENTS\r\nwhere \r\nCOALESCE(COST_ELEMENT_ID,1) <> 1\r\nAND CREATE_DATETIME >'$$LastExtractDate'\r\nQUALIFY RANK () OVER (PARTITION BY COST_ELEMENT_ID ORDER BY CREATE_DATETIME DESC ) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
