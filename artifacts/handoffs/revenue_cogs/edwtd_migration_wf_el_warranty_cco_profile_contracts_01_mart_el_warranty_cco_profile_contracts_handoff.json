      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\nPARTY_ID,\r\nPARTY_NAME,\r\nPARTY_TYPE,\r\nCONTRACT_NUMBER,\r\nCONTRACT_CREATION_DATE,\r\nCONTRACT_STATUS,\r\nINACTIVE_DATE,\r\nCCO_USER,\r\nCCO_CREATION_DATE,\r\nSTATUS,\r\nLAST_UPDATE_DATE,\r\nATTRIBUTE19\r\nFROM\r\n$$STGDB.ST_WARRANTY_CCO_PROFILE_CONTRACTS A\r\nWHERE NOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.EL_WARRANTY_CCO_PROFILE_CONTRACTS B \r\nWHERE A.PARTY_ID = B.PARTY_ID\r\nAND A.CONTRACT_NUMBER=B.CONTRACT_NUMBER\r\nAND A.CONTRACT_CREATION_DATE=B.CONTRACT_CREATION_DATE\r\nAND A.CONTRACT_STATUS=B.CONTRACT_STATUS\r\nAND COALESCE(A.INACTIVE_DATE,CAST('1900-01-01 00:00:00' AS TIMESTAMP(0)))=COALESCE(B.INACTIVE_DATE,CAST('1900-01-01 00:00:00' AS TIMESTAMP(0)))\r\nAND A.LAST_UPDATE_DATE=B.LAST_UPDATE_DATE)",
