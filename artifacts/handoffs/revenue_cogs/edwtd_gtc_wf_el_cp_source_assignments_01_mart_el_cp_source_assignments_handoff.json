      "attributes": {
        "Sql Query": "SELECT\r\nSOURCE_ID,\r\nSOURCE_ASSIGNMENT_ID,\r\nSOURCE_ASSIGNMENT_NAME,\r\nSS_CODE,\r\nEDW_CREATE_USER,\r\nEDW_CREATE_DTM,\r\nEDW_UPDATE_USER,\r\nEDW_UPDATE_DTM\r\nFROM\r\n(\r\nSELECT\r\nSOURCE_ID,\r\nSOURCE_ASSIGNMENT_ID,\r\nSOURCE_ASSIGNMENT_NAME,\r\nCAST('BV' AS CHAR(8)) AS SS_CODE,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0)  AS EDW_CREATE_DTM,\r\nUSER  AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0)  AS EDW_UPDATE_DTM\r\nFROM $$STGDB.ST_CP_SOURCE_ASSIGNMENTS_BV\r\nUNION ALL\r\nSELECT\r\nSOURCE_ID,\r\nSOURCE_ASSIGNMENT_ID,\r\nSOURCE_ASSIGNMENT_NAME,\r\nCAST('CG' AS CHAR(8)) AS SS_CODE,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0)  AS EDW_CREATE_DTM,\r\nUSER  AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0)  AS EDW_UPDATE_DTM\r\nFROM $$STGDB.ST_XXCP_SOURCE_ASSIGNMENTS_CG1\r\n) IQ\r\nWHERE NOT EXISTS\r\n(\r\nSELECT 1\r\n     FROM $$ETLVWDB.EL_CP_SOURCE_ASSIGNMENTS EL\r\nWHERE IQ.SOURCE_ASSIGNMENT_ID = EL.SOURCE_ASSIGNMENT_ID\r\n       AND IQ.SS_CODE = EL.SS_CODE\r\n)",
