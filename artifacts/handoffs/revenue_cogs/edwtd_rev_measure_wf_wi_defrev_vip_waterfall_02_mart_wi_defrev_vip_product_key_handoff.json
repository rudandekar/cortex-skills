      "attributes": {
        "Sql Query": "SELECT \r\n WI.PROCESSED_FISCAL_YEAR_MTH_INT ,\r\n WI.BK_INCENTIVE_PROGRAM_NAME     ,\r\n WI.BOOKINGS_MEASURE_KEY           ,\r\n WI.BKGS_MEASURE_TRANS_TYPE_CODE                   ,\r\n WI.TRANS_FISCAL_YEAR_MONTH_INT   ,\r\n WI.BOOKING_ACCRUAL_USD_AMT - COALESCE(EL.BOOKING_ACCRUAL_USD_AMT ,0) AMT\r\n FROM $$STGDB.WI_DEFREV_VIP_ENDBAL_PRDT_SUB WI\r\n LEFT OUTER JOIN  (\r\n SELECT\r\n EL_IN.PROCESSED_FISCAL_YEAR_MTH_INT ,\r\n EL_IN.BK_INCENTIVE_PROGRAM_NAME     ,\r\n EL_IN.BOOKINGS_MEASURE_KEY           ,\r\n EL_IN.BKGS_MEASURE_TRANS_TYPE_CODE                   ,\r\n EL_IN.TRANS_FISCAL_YEAR_MONTH_INT   ,\r\n EL_IN.BOOKING_ACCRUAL_USD_AMT \r\n FROM $$ETLVWDB.EL_DEFREV_VIP_BAL EL_IN\r\n WHERE EL_IN.PROCESSED_FISCAL_YEAR_MTH_INT < (\r\n select PROCESSED_FISCAL_YEAR_MTH_INT from $$STGDB.WI_DEFREV_VIP_MONTH_CNTL group by 1\r\n )\r\n QUALIFY RANK() over (partition by \r\n EL_IN.BK_INCENTIVE_PROGRAM_NAME     ,\r\n EL_IN.BOOKINGS_MEASURE_KEY           ,\r\n EL_IN.BKGS_MEASURE_TRANS_TYPE_CODE                   ,\r\n EL_IN.TRANS_FISCAL_YEAR_MONTH_INT\r\n ORDER BY EL_IN.PROCESSED_FISCAL_YEAR_MTH_INT DESC )=1\r\n ) EL\r\n ON WI.BK_INCENTIVE_PROGRAM_NAME = EL.BK_INCENTIVE_PROGRAM_NAME\r\n AND WI.BOOKINGS_MEASURE_KEY = EL.BOOKINGS_MEASURE_KEY \r\n AND WI.BKGS_MEASURE_TRANS_TYPE_CODE = EL.BKGS_MEASURE_TRANS_TYPE_CODE\r\n  AND WI.TRANS_FISCAL_YEAR_MONTH_INT = EL.TRANS_FISCAL_YEAR_MONTH_INT\r\n  WHERE AMT<>0",
