      "attributes": {
        "Sql Query": "SELECT\r\nCAST(CUST_TRX_LINE_GL_DIST_ID AS BIGINT) AS CUST_TRX_LINE_GL_DIST_ID,\r\nCAST(CUSTOMER_TRX_ID AS BIGINT) AS CUSTOMER_TRX_ID,\r\nCAST(CUSTOMER_TRX_LINE_ID AS BIGINT) AS CUSTOMER_TRX_LINE_ID,\r\nGL_DATE,\r\nGL_POSTED_DATE,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_CREATE_DTM,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_UPDATE_DTM,\r\nCAST(SORCTLNGLDT.CODE_COMBINATION_ID AS BIGINT) AS CODE_COMBINATION_ID,\r\nEOGCC.SEGMENT4,\r\nCAST('OOD' AS VARCHAR(10)) AS IDENTIFIER\r\nFROM $$STGDB.ST_OOD_RA_CUST_TRX_LN_GLDT SORCTLNGLDT,\r\n$$ETLVWDB.EL_OOD_GL_CODE_COMBINATIONS EOGCC\r\nWHERE (SORCTLNGLDT.CODE_COMBINATION_ID=EOGCC.CODE_COMBINATION_ID)\r\nAND\r\nNOT EXISTS(SEL 1 FROM $$ETLVWDB.EL_OOD_RA_CUST_TRX_LN_GLDT EORCTLNGLDT\r\nWHERE SORCTLNGLDT.CUST_TRX_LINE_GL_DIST_ID=EORCTLNGLDT.CUST_TRX_LINE_GL_DIST_ID)\r\n\r\nUNION ALL\r\n\r\nSELECT\r\nCUST_TRX_LINE_GL_DIST_ID,\r\nCUSTOMER_TRX_ID,\r\nCUSTOMER_TRX_LINE_ID,\r\nGL_DATE,\r\nGL_POSTED_DATE,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_CREATE_DTM,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_UPDATE_DTM,\r\nSOFRCTLNGLDT.CODE_COMBINATION_ID,\r\nEOGCC.SEGMENT4,\r\n'FUSN' AS IDENTIFIER\r\nFROM $$STGDB.ST_OOD_FUSN_RA_CUST_TRX_LN_GLDT SOFRCTLNGLDT ,\r\n$$ETLVWDB.EL_OOD_GL_CODE_COMBINATIONS EOGCC\r\nWHERE (SOFRCTLNGLDT.CODE_COMBINATION_ID=EOGCC.CODE_COMBINATION_ID)\r\nAND\r\nNOT EXISTS(SEL 1 FROM $$ETLVWDB.EL_OOD_RA_CUST_TRX_LN_GLDT EORCTLNGLDT\r\nWHERE SOFRCTLNGLDT.CUST_TRX_LINE_GL_DIST_ID=EORCTLNGLDT.CUST_TRX_LINE_GL_DIST_ID)",
