        "Sql Query": "SELECT \r\n DV_RECURRING_OFFER_CD,\r\n PRODUCT_KEY,\r\n DV_PRODUCT_KEY,\r\n SALES_ORDER_KEY,\r\n SK_OFFER_ATTRIBUTION_ID_INT\r\n FROM\r\n (\r\n SELECT \r\n DV_RECURRING_OFFER_CD,\r\n  STRTOK (DV_RECURRING_OFFER_CD,'~',1) AS PRODUCT_KEY,\r\n  STRTOK (DV_RECURRING_OFFER_CD,'~',2) AS DV_PRODUCT_KEY,\r\n  STRTOK (DV_RECURRING_OFFER_CD,'~',3) AS SALES_ORDER_KEY,\r\n  STRTOK (DV_RECURRING_OFFER_CD,'~',4) AS SK_OFFER_ATTRIBUTION_ID_INT\r\n FROM $$FINLGLVWDB.MT_TSS_FIN_DEFERRED_REVENUE \r\n WHERE PROCESSED_FISCAL_YEAR_MTH_INT  IN\r\n (SEL PROCESSED_FISCAL_YEAR_MTH_INT FROM $$STGDB.WI_DEFREV_CCW_MONTH_CNTL )\r\n GROUP BY 1,2,3,4,5\r\n )A\r\n WHERE NOT EXISTS (\r\n SELECT 1 FROM $$FINLGLVWDB.MT_RECURRING_OFFER_REVENUE MT\r\n WHERE MT.DV_RECURRING_OFFER_CD=A.DV_RECURRING_OFFER_CD)",
