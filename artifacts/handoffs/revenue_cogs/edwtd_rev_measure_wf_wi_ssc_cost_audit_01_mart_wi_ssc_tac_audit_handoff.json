      "attributes": {
        "Sql Query": "SEL SRC_IP.FISCAL_YEAR_MONTH_INT,'SSC_COST' AS DV_SOURCE_NAME,'N_SR_SERVICE_SUPPORT_CENTER_COST' AS AUDIT_TABLE, CURRENT_DATE AS AUDIT_DATE,\r\nABS(COALESCE(TGT.ALLOCATED_COST_USD_AMT,0)-  COALESCE(SRC_IP.AMOUNT,0)) AS IP_DOLLAR_MISMATCH_AMT ,\r\nABS(COALESCE(TGT.TOTAL_COST,0)-  COALESCE(SRC_IP.AMOUNT,0)) AS  DOLLAR_MISMATCH_AMT ,\r\nABS(COALESCE(TGT.TOTAL_COUNT,0)-  COALESCE(SR_RMA.TOTAL_COUNT,0)) AS TOTAL_COUNT_MISMATCH,\r\nABS(COALESCE(TGT.SR_COUNT,0)-  COALESCE(SR_RMA.SR_COUNT,0)) AS SR_COUNT_MISMATCH\r\n FROM \r\n(\r\nSELECT (SELECT FISCAL_YEAR_MONTH_INT FROM  $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID) AS FISCAL_YEAR_MONTH_INT,SUM(AMOUNT) AS AMOUNT from $$STGDB.WI_CCM_SSC_INPUT_DOLLAR \r\nWHERE FISCAL_MONTH_ID  in (SELECT FISCAL_MONTH_ID FROM  $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID) GROUP BY 1\r\n) SRC_IP\r\n\r\nFULL  JOIN \r\n(\r\nSELECT (SELECT FISCAL_YEAR_MONTH_INT FROM  $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID) AS FISCAL_YEAR_MONTH_INT,COUNT(*) TOTAL_COUNT,COUNT(DISTINCT SR_NUMBER) AS SR_COUNT FROM $$STGDB.WI_SSC_RMA_VOLUME  WHERE FISCAL_MONTH_ID  in (SELECT FISCAL_MONTH_ID FROM  $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)\r\n) SR_RMA\r\nON SRC_IP.FISCAL_YEAR_MONTH_INT=SR_RMA.FISCAL_YEAR_MONTH_INT\r\nFULL JOIN \r\n(\r\nSEL  CASE WHEN  BK_SR_SSC_COST_FSCL_MTH_NUM_INT<=9 THEN  (TRIM(BK_SR_SSC_COST_FSCL_YR_NUM_INT)||'0'||TRIM(BK_SR_SSC_COST_FSCL_MTH_NUM_INT)) \r\nELSE  (TRIM(BK_SR_SSC_COST_FSCL_YR_NUM_INT)||TRIM(BK_SR_SSC_COST_FSCL_MTH_NUM_INT)) END AS FISCAL_YEAR_MONTH_INT ,\r\nCOUNT(*) TOTAL_COUNT,\r\nCOUNT(DISTINCT SRC_RPTD_SERVICE_REQUEST_NUM_INT )  SR_COUNT , \r\nSUM(ALLOCATED_COST_USD_AMT) AS ALLOCATED_COST_USD_AMT,\r\nSUM(SSC_DEPT_PRSNL_RSRC_COST_USD_AMT) +SUM(DEPT_MERAKI_CREDIT_USD_AMT)+\r\n SUM(SSC_DEPRECIATION_COST_USD_AMT)+SUM(DPRCTN_ECO_CREDIT_USD_AMT)+SUM(DPRCTN_MERAKI_CREDIT_USD_AMT)+\r\n SUM(SSC_REPAIR_COST_USD_AMT)+SUM(REPAIR_ECO_CREDIT_USD_AMT)+  \r\n SUM(SSC_DUTY_VAT_COST_USD_AMT) +SUM(DUTY_VAT_ECO_CREDIT_USD_AMT)+ SUM(DUTY_VAT_MERAKI_CREDIT_USD_AMT) +\r\n SUM(SSC_THIRD_PRTY_LOGISTICS_COST_USD_AMT) + SUM(TPL_ECO_CREDIT_USD_AMT) +SUM(TPL_MERAKI_CREDIT_USD_AMT) +\r\n SUM(SSC_THIRD_PARTY_MNTNC_COST_USD_AMT) +\r\n SUM(SSC_ORIG_EQUIP_MNFCTR_COST_USD_AMT)+SUM(OEM_MERAKI_CREDIT_USD_AMT) \r\n\t+ COALESCE(SUM(DEPR_UMPIRE_CREDIT_USD_AMT) ,0)\r\n\t+ COALESCE(SUM(REPAIR_UMPIRE_CREDIT_USD_AMT),0)\r\n\t+ COALESCE(SUM(DUTY_VAT_UMPIRE_CREDIT_USD_AMT),0)\r\n\t+ COALESCE(SUM(TPL_UMPIRE_CREDIT_USD_AMT),0)\r\n AS TOTAL_COST\r\nFROM $$FINLGLVWDB.N_SR_SERVICE_SUPPORT_CENTER_COST  \r\nWHERE   CASE WHEN  BK_SR_SSC_COST_FSCL_MTH_NUM_INT<=9 THEN  (TRIM(BK_SR_SSC_COST_FSCL_YR_NUM_INT)||'0'||TRIM(BK_SR_SSC_COST_FSCL_MTH_NUM_INT)) \r\nELSE  (TRIM(BK_SR_SSC_COST_FSCL_YR_NUM_INT)||TRIM(BK_SR_SSC_COST_FSCL_MTH_NUM_INT)) END IN \r\n(SELECT FISCAL_YEAR_MONTH_INT FROM  $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)\r\nGROUP BY 1\r\n) TGT\r\nON SRC_IP.FISCAL_YEAR_MONTH_INT=TGT.FISCAL_YEAR_MONTH_INT\r\nAND SR_RMA.FISCAL_YEAR_MONTH_INT=TGT.FISCAL_YEAR_MONTH_INT",
        "User Defined Join": "",
