      "attributes": {
        "Sql Query": "SELECT \r\nAUDIT_COMMENT_ID,            \r\nAUDIT_QUERY_ID,             \r\nRULE_ID,              \r\nCOUNTRY_GROUP_CODE,        \r\nAUDITOR_COMMENTS,            \r\nCREATED_BY,                    \r\nCREATION_DATE,                 \r\nLAST_UPDATED_BY ,              \r\nLAST_UPDATE_DATE  ,            \r\nCURRENT_TIMESTAMP(0),\r\nACTION_CODE,\r\n'RI' \r\nFROM $$STGDB.ST_XXCFI_CB_AUDIT_RULE_CMNTS ST\r\nWHERE NOT EXISTS (SEL 1 FROM $$FINLGLVWDB.N_ITEM_CLSFTN_RULE_AUDIT  NICRA\r\nWHERE NICRA.SK_AUDIT_QUERY_ID = ST.AUDIT_QUERY_ID)\r\nOR NOT EXISTS (SEL 1 FROM  $$FINLGLVWDB.N_WORLD_COUNTRY_GROUP NWCG\r\nWHERE  ST.COUNTRY_GROUP_CODE =NWCG.BK_WORLD_COUNTRY_GROUP_CD)\r\nOR NOT EXISTS (SEL 1 FROM $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP\r\nWHERE  NCWP.CEC_ID =COALESCE( ST.CREATED_BY,'UNKNOWN'))\r\nOR NOT EXISTS (SEL 1 FROM $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP1\r\nWHERE   NCWP1.CEC_ID =COALESCE( ST.LAST_UPDATED_BY,'UNKNOWN'))",
