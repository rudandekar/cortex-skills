      "attributes": {
        "Sql Query": "SELECT  NICRA.BK_AUDIT_NAME AS BK_AUDIT_NAME,\r\nNWCG.BK_WORLD_COUNTRY_GROUP_CD AS BK_WORLD_COUNTRY_GROUP_CD,\r\nST.CREATION_DATE AS BK_SRC_CREATED_DTM,\r\nST.RULE_ID AS RULE_ID_INT,\r\nCOALESCE(ST.LAST_UPDATE_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP)) AS SRC_UPDATED_DTM,\r\nST.AUDITOR_COMMENTS AS AUDIT_CMT,\r\nCOALESCE (NCWP.CISCO_WORKER_PARTY_KEY,-999) AS SRC_CRTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE (NCWP1.CISCO_WORKER_PARTY_KEY,-999) AS SRC_UPDT_BY_CSCO_WRKR_PRTY_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nST.ACTION_CODE,\r\n'I'\r\nFROM $$STGDB.ST_XXCFI_CB_AUDIT_RULE_CMNTS ST\r\nINNER JOIN $$FINLGLVWDB.N_ITEM_CLSFTN_RULE_AUDIT NICRA\r\nON  ST.AUDIT_QUERY_ID = NICRA.SK_AUDIT_QUERY_ID\r\nINNER JOIN  $$FINLGLVWDB.N_WORLD_COUNTRY_GROUP NWCG\r\nON ST.COUNTRY_GROUP_CODE =NWCG.BK_WORLD_COUNTRY_GROUP_CD\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP\r\n ON ST.CREATED_BY=NCWP.CEC_ID\r\n LEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP1\r\n ON ST.LAST_UPDATED_BY=NCWP1.CEC_ID\r\n WHERE ST.AUDIT_QUERY_ID IS NOT NULL\r\n AND ST.COUNTRY_GROUP_CODE IS NOT NULL\r\n AND ST.CREATION_DATE IS NOT NULL\r\n QUALIFY ROW_NUMBER() OVER (PARTITION BY ST.AUDIT_QUERY_ID, ST.COUNTRY_GROUP_CODE,ST.CREATION_DATE ORDER BY ST.RULE_ID DESC) =1\r\n UNION\r\n SELECT  NICRA.BK_AUDIT_NAME AS BK_AUDIT_NAME,\r\nNWCG.BK_WORLD_COUNTRY_GROUP_CD AS BK_WORLD_COUNTRY_GROUP_CD,\r\nEX.CREATION_DATE AS BK_SRC_CREATED_DTM ,\r\nEX.RULE_ID AS RULE_ID_INT,\r\nCOALESCE(EX.LAST_UPDATE_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP)) AS SRC_UPDATED_DTM,\r\nEX.AUDITOR_COMMENTS AS AUDIT_CMT,\r\nCOALESCE (NCWP.CISCO_WORKER_PARTY_KEY,-999) AS SRC_CRTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE (NCWP1.CISCO_WORKER_PARTY_KEY,-999) AS SRC_UPDT_BY_CSCO_WRKR_PRTY_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nEX.ACTION_CODE,\r\n'I'\r\nFROM $$EXCEPDB.EX_XXCFI_CB_AUDIT_RULE_CMNTS EX\r\nINNER JOIN $$FINLGLVWDB.N_ITEM_CLSFTN_RULE_AUDIT NICRA\r\nON  EX.AUDIT_QUERY_ID = NICRA.SK_AUDIT_QUERY_ID\r\nINNER JOIN  $$FINLGLVWDB.N_WORLD_COUNTRY_GROUP NWCG\r\nON EX.COUNTRY_GROUP_CODE =NWCG.BK_WORLD_COUNTRY_GROUP_CD\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP\r\n ON EX.CREATED_BY=NCWP.CEC_ID\r\n LEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP1\r\n ON EX.LAST_UPDATED_BY=NCWP1.CEC_ID\r\n WHERE EX.AUDIT_QUERY_ID IS NOT NULL\r\n AND EX.COUNTRY_GROUP_CODE IS NOT NULL\r\n AND EX.CREATION_DATE IS NOT NULL\r\n QUALIFY ROW_NUMBER() OVER (PARTITION BY EX.AUDIT_QUERY_ID, EX.COUNTRY_GROUP_CODE,EX.CREATION_DATE  ORDER BY EX.RULE_ID DESC) =1",
        "User Defined Join": "",
