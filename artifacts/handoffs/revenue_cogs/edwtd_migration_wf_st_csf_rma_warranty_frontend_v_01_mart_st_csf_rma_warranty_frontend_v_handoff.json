      "attributes": {
        "Sql Query": "SELECT\r\nooh.ORDER_NUMBER,\r\nooh.ORIG_SYS_DOCUMENT_REF AS SR_NUMBER,\r\nc.ORDERED_ITEM,\r\nooh.CREATION_DATE,\r\nCASE WHEN\r\nDECODE (ooh.attribute4, NULL, DECODE (xoh.attribute1, NULL, 'EXCEPTION', 'WARRANTY'),'CONTRACT') = 'WARRANTY'\r\nOR G.ENT_RESULT_DESCRIPTION = 'Entitled Under Warranty' THEN 'Y' ELSE 'N' END AS WARRANTY,\r\nSYSDATE AS EDW_CREATE_DTM\r\nFROM apps.OE_ORDER_HEADERS_ALL ooh --c3.OE_ORDER_HEADERS_ALL AS a\r\nINNER JOIN apps.xxcts_OE_ORDER_HEADERS_ALL xoh ON xoh.header_id = ooh.header_id\r\nINNER JOIN APPS.OE_ORDER_LINES_ALL c ON c.HEADER_ID = ooh.HEADER_ID\r\n--INNER JOIN dbo.TSS_CALENDARS_D AS F ON F.CALENDAR_DATE = CAST(ooh.CREATION_DATE AS date)\r\nINNER JOIN XXCTS_O.XXCTS_ENT_AUDIT_LOG_TBL G ON G.ENTITLEMENT_AUDIT_ID =\r\n(SELECT MIN(ENTITLEMENT_AUDIT_ID) AS Expr1\r\nFROM XXCTS_O.XXCTS_ENT_AUDIT_LOG_TBL h\r\nWHERE (SERVICE_ORDER_LINE = c.LINE_ID))\r\nWHERE (ooh.CONTEXT = 'SVO SUBMIT')\r\n--AND (F.FISCAL_YEAR_ID >= 2015)\r\nAND CAST(ooh.CREATION_DATE AS date) BETWEEN SYSDATE - 60 AND SYSDATE\r\nAND (c.LINE_CATEGORY_CODE = 'ORDER')\r\nGROUP BY ooh.ORDER_NUMBER,\r\nooh.ORIG_SYS_DOCUMENT_REF,\r\nc.ORDERED_ITEM,\r\nooh.CREATION_DATE,\r\nCASE WHEN\r\nDECODE (ooh.attribute4, NULL, DECODE (xoh.attribute1, NULL, 'EXCEPTION', 'WARRANTY'),'CONTRACT') = 'WARRANTY'\r\nOR G.ENT_RESULT_DESCRIPTION = 'Entitled Under Warranty' THEN 'Y' ELSE 'N' END",
