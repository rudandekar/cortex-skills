      "attributes": {
        "Sql Query": "SELECT\t\r\nRF.FISCAL_YEAR_NUMBER_INT as TAXAUDIT_PREVIOUS_YEAR_INT,\r\nRF.FISCAL_YEAR_NUMBER_INT+1 AS TAXAUDIT_CURRENT_YEAR_INT,\r\nRF.FISCAL_YEAR_NUMBER_INT-7 AS TAXAUDIT_DELETE_YEAR_INT,\r\nMIN(RF.FISCAL_YEAR_MONTH_INT)  AS TAXAUDIT_MONTH_START_INT,\r\nMAX(RF.FISCAL_YEAR_MONTH_INT)  AS TAXAUDIT_MONTH_END_INT\r\nFROM\t $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RF\r\nWHERE\tRF.PREVIOUS_FISCAL_YEAR_FLAG ='Y'\r\nGROUP BY 1,2,3",
