      "attributes": {
        "Sql Query": "SELECT BK_IC_ACCOUNTING_RULE_TYPE_CD,\r\n\t   SOURCE_DELETED_FLG,\r\n\t   CURRENT_TIMESTAMP(0)  AS EDW_CREATE_DTM,\r\n\t   USER                  AS EDW_CREATE_USER,\r\n       CURRENT_TIMESTAMP(0)  AS EDW_UPDATE_DTM,\r\n\t   USER                  AS EDW_UPDATE_USER\r\nFROM            \r\n(\r\n SELECT QTC.RULE_NAME  AS  BK_IC_ACCOUNTING_RULE_TYPE_CD,\r\n        'N'            AS  SOURCE_DELETED_FLG            \r\n   FROM  $$STGDB.ST_CP_ACCOUNT_RULES_QTC  QTC\r\n   WHERE QTC.RULE_NAME IS NOT NULL\r\n UNION\r\nSELECT BV.RULE_NAME     AS  BK_IC_ACCOUNTING_RULE_TYPE_CD,\r\n \t   'N'              AS  SOURCE_DELETED_FLG             \r\n   FROM  $$STGDB.ST_CP_ACCOUNT_RULES_BV     BV\r\n   WHERE BV.RULE_NAME IS NOT NULL\r\n  UNION\r\n SELECT CG1.RULE_NAME   AS  BK_IC_ACCOUNTING_RULE_TYPE_CD, \r\n        'N'             AS  SOURCE_DELETED_FLG            \r\n      FROM $$STGDB.ST_CP_ACCOUNT_RULES_CG1  CG1\r\n\t  WHERE CG1.RULE_NAME IS NOT NULL\r\n   UNION \r\n  SELECT SJ.RULE_NAME     AS BK_IC_ACCOUNTING_RULE_TYPE_CD,\r\n         'N'              AS  SOURCE_DELETED_FLG            \r\n      FROM  $$STGDB.ST_CP_ACCOUNT_RULES_SJ  SJ\r\n\t  WHERE SJ.RULE_NAME IS NOT NULL\r\n) IQ\r\nWHERE NOT EXISTS \r\n(SELECT 1 \r\n  FROM    $$FINLGLVWDB.N_IC_ACCOUNTING_RULE_TYPE NIART\r\n  WHERE NIART.BK_IC_ACCOUNTING_RULE_TYPE_CD = IQ.BK_IC_ACCOUNTING_RULE_TYPE_CD\r\n)",
