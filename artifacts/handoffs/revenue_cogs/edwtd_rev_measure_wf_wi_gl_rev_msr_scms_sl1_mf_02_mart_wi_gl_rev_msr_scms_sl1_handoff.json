      "attributes": {
        "Sql Query": "SELECT \r\n\tA.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n\t,A.L1_SALES_TERRITORY_NAME_CODE \r\n\t,A.SALES_TERRITORY_KEY\t\r\n\t,A.DV_COMP_US_NET_REV_AMT\r\n\t,SUM(A.DV_COMP_US_NET_REV_AMT)  OVER (  PARTITION BY   A.DV_FISCAL_YEAR_MTH_NUMBER_INT,A.L1_SALES_TERRITORY_NAME_CODE  )  REV_AMT_TOTAL\r\n\t,CASE WHEN REV_AMT_TOTAL = 0 THEN 0 ELSE CAST(A.DV_COMP_US_NET_REV_AMT AS DECIMAL(27,14))/CAST( REV_AMT_TOTAL AS DECIMAL(27,14)) END RATIO_BY_SL_KEY\r\n\t FROM \r\n\t(\r\n\t\t\tSELECT\r\n\t\t\t\tGL.DV_FISCAL_YEAR_MTH_NUMBER_INT  \r\n\t\t\t\t,RSH.L1_SALES_TERRITORY_NAME_CODE \r\n\t\t\t\t,GL.SALES_TERRITORY_KEY\r\n\t\t\t\t,SUM(GL.DV_COMP_US_NET_REV_AMT) DV_COMP_US_NET_REV_AMT\r\n\t\t\tFROM  \r\n\t\t\t  $$STGDB.WI_GL_REV_MEASURE_ICPM GL\r\n\t\t\tINNER JOIN $$STGDB.WI_GL_REV_MSR_SALES_HIER  RSH\r\n            ON (GL.SALES_TERRITORY_KEY = RSH.SALES_TERRITORY_KEY AND GL.DV_FISCAL_YEAR_MTH_NUMBER_INT=RSH.DV_FISCAL_MONTH_TO_YEAR_KEY)\r\n\t\t\tWHERE \r\n\t\t\tRSH.L1_SALES_TERRITORY_DESCR IN (SELECT TGT_L1_SALES_TERRITORY_DESCR  FROM $$ETLVWDB.EL_ICPM_REV_FILTER_CNTL WHERE TRIANGULATION_TYPE_ID_INT  =12)  \r\n\t\t\tAND SALES_COVERAGE_CODE IN  ( SELECT VALID_SALES_COVERAGE_CODE  FROM $$ETLVWDB.EL_ICPM_REV_FILTER_CNTL \tWHERE TRIANGULATION_TYPE_ID_INT =12\t) \r\n\t\t\tAND RSH.ISO_COUNTRY_CODE NOT IN(SELECT ISO_COUNTRY_CODE  FROM $$ETLVWDB.EL_ICPM_REV_FILTER_CNTL WHERE TRIANGULATION_TYPE_ID_INT  =12)\r\n\t\t\t\r\n\t\t\tAND GL.DV_COMP_US_NET_REV_AMT<>0\r\n\t\t\tGROUP BY \r\n\t\t\tGL.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n\t\t\t,RSH.L1_SALES_TERRITORY_NAME_CODE \r\n\t\t\t,GL.SALES_TERRITORY_KEY\r\n\t) A",
