DV_VARIANCE_ADJ_AMT   DV_VARIANCE_ADJ_AMT\n,Q2.RATIO_BY_SL_KEY*Q1.DV_WARRANTY_ADJ_AMT   DV_WARRANTY_ADJ_AMT\nFROM \n  $$STGDB.WI_GL_REV_MSR_SCMS_OTHER Q1\nINNER JOIN   $$STGDB.WI_GL_REV_MSR_SCMS_SL1 Q2\nON(  Q2.L1_SALES_TERRITORY_NAME_CODE=Q1.L1_SALES_TERRITORY_NAME_CODE\n)\nWHERE Q1.ISO_COUNTRY_CODE<>'UNK' \nAND NOT  EXISTS\n(\n\t\tSELECT L3_SALES_TERRITORY_NAME_CODE\n\t\t FROM   $$STGDB.WI_GL_REV_SCMS_VLD_CNTY_SL3  INNER_SL3_CHECK\n\t\t WHERE \n\t\tINNER_SL3_CHECK.L3_SALES_TERRITORY_NAME_CODE =Q1.L3_SALES_TERRITORY_NAME_CODE\n ) \n  AND  NOT EXISTS\n(\n\t\tSELECT L2_SALES_TERRITORY_NAME_CODE          \n\t\t FROM   $$STGDB.WI_GL_REV_SCMS_VLD_CNTY_SL2 INNER_SL2_CNTRY_CHECK\n\t\t WHERE \n\t\tINNER_SL2_CNTRY_CHECK.L2_SALES_TERRITORY_NAME_CODE =Q1.L2_SALES_TERRITORY_NAME_CODE\n )\n AND NOT EXISTS\n(\n\t\tSELECT L1_SALES_TERRITORY_NAME_CODE          \n\t\t FROM  $$STGDB.WI_GL_REV_MSR_SCMS_MIX_SL1  INNER_SL1_CNTRY_CHECK\n\t\t WHERE \n\t\t INNER_SL1_CNTRY_CHECK.L1_SALES_TERRITORY_NAME_CODE =Q1.L1_SALES_TERRITORY_NAME_CODE\n\t\t AND  INNER_SL1_CNTRY_CHECK.ISO_COUNTRY_CODE  =Q1.ISO_COUNTRY_CODE\n )\n AND  EXISTS\n(\n\t\tSELECT L1_SALES_TERRITORY_NAME_CODE          \n\t\t FROM   $$STGDB.WI_GL_REV_MSR_SCMS_MIX_SL1   INNER_SL1_CNTRY_CHECK\n\t\t WHERE \n\t\t INNER_SL1_CNTRY_CHECK.L1_SALES_TERRITORY_NAME_CODE =Q1.L1_SALES_TERRITORY_NAME_CODE\n )",
