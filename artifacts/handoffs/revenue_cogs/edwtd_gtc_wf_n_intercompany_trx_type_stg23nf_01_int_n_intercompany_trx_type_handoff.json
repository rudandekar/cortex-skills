      "attributes": {
        "Sql Query": "SELECT  BK_INTERCOMPANY_TRX_TYPE_CD,\r\n                 'N'   AS  SOURCE_DELETED_FLG,\r\n\t             CURRENT_TIMESTAMP(0)  AS EDW_CREATE_DTM,\r\n\t             USER                  AS EDW_CREATE_USER,\r\n                  CURRENT_TIMESTAMP(0)  AS EDW_UPDATE_DTM,\r\n\t             USER                  AS EDW_UPDATE_USER\r\nFROM            \r\n(\r\nSELECT DISTINCT VT_TRANSACTION_TYPE  AS BK_INTERCOMPANY_TRX_TYPE_CD\r\nFROM $$STGDB.ST_CP_OE_LINES_IFACE_QTC \r\nWHERE VT_TRANSACTION_TYPE IS NOT NULL\r\nUNION\r\nSELECT DISTINCT VT_TRANSACTION_TYPE AS BK_INTERCOMPANY_TRX_TYPE_CD\r\nFROM $$STGDB.ST_CP_CUST_TRX_DIST_IFACE_QTC\r\nWHERE VT_TRANSACTION_TYPE IS NOT NULL\r\nUNION \r\nSELECT DISTINCT VT_TRANSACTION_TYPE  AS BK_INTERCOMPANY_TRX_TYPE_CD\r\nFROM $$STGDB.ST_CP_OE_LINES_IFACE_BV\r\nWHERE VT_TRANSACTION_TYPE IS NOT NULL\r\nUNION\r\nSELECT DISTINCT VT_TRANSACTION_TYPE  AS BK_INTERCOMPANY_TRX_TYPE_CD\r\nFROM $$STGDB.ST_CP_CUST_TRX_DIST_IFACE_BV\r\nWHERE VT_TRANSACTION_TYPE IS NOT NULL\r\nUNION\r\nSELECT DISTINCT VT_TRANSACTION_TYPE  AS BK_INTERCOMPANY_TRX_TYPE_CD\r\nFROM $$STGDB.ST_CP_VT_INTERFACE_CG1\r\nWHERE VT_TRANSACTION_TYPE IS NOT NULL\r\nUNION\r\nSELECT DISTINCT VT_TRANSACTION_TYPE  AS BK_INTERCOMPANY_TRX_TYPE_CD\r\nFROM $$STGDB.ST_CP_OE_LINES_IFACE_CG1\r\nWHERE VT_TRANSACTION_TYPE IS NOT NULL\r\nUNION\r\nSELECT DISTINCT VT_TRANSACTION_TYPE  AS BK_INTERCOMPANY_TRX_TYPE_CD\r\nFROM $$STGDB.ST_CP_CUST_TRX_DIST_IFACE_CG1\r\nWHERE VT_TRANSACTION_TYPE IS NOT NULL\r\nUNION \r\nSELECT DISTINCT VT_TRANSACTION_TYPE  AS BK_INTERCOMPANY_TRX_TYPE_CD\r\nFROM $$STGDB.ST_CP_VT_INTERFACE_SJ\r\nWHERE VT_TRANSACTION_TYPE IS NOT NULL\r\n) IQ\r\nWHERE NOT EXISTS\r\n(\r\nSELECT 1 FROM $$FINLGLVWDB.N_INTERCOMPANY_TRX_TYPE\t NITT\r\nWHERE NITT.BK_INTERCOMPANY_TRX_TYPE_CD = IQ.BK_INTERCOMPANY_TRX_TYPE_CD\r\n)",
