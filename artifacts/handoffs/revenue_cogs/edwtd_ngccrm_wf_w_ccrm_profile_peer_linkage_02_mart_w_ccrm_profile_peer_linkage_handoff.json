      "attributes": {
        "Sql Query": "SELECT ST_CCRM_RELATED_PROFILES.Batch_Id, ST_CCRM_RELATED_PROFILES.CHILD_PROFILE_ID, ST_CCRM_RELATED_PROFILES.PROFILE_ID, ST_CCRM_RELATED_PROFILES.CREATED_BY, ST_CCRM_RELATED_PROFILES.CREATION_DATE, ST_CCRM_RELATED_PROFILES.LAST_UPDATED_BY, ST_CCRM_RELATED_PROFILES.LAST_UPDATE_DATE, ST_CCRM_RELATED_PROFILES.LINKAGE_TYPE, ST_CCRM_RELATED_PROFILES.LINK_TYPE, ST_CCRM_RELATED_PROFILES.PROCESSED, ST_CCRM_RELATED_PROFILES.COMMENTS, ST_CCRM_RELATED_PROFILES.CREATION_DATETIME, ST_CCRM_RELATED_PROFILES.ACTION_CODE,\r\n'RI'  EXCEPTION_TYPE\r\nFROM $$STGDB.ST_CCRM_RELATED_PROFILES ST_CCRM_RELATED_PROFILES\r\nWHERE \r\nNOT EXISTS(SELECT 1 FROM \r\n$$ETLVWDB.EL_CCRM_RELATED_PROFILE_HIST ECRPH\r\nWHERE ECRPH.PROFILE_ID = ST_CCRM_RELATED_PROFILES.PROFILE_ID\r\nAND ECRPH.CHILD_PROFILE_ID = ST_CCRM_RELATED_PROFILES.CHILD_PROFILE_ID\r\nAND ECRPH.PROCESSED='Y'\r\nAND ST_CCRM_RELATED_PROFILES.LINKAGE_TYPE = 'NORMAL' )",
