      "attributes": {
        "Sql Query": "SELECT \r\nSCRP.PROFILE_ID BK_PEER1_PROFILE_ID_INT, \r\nSCRP.CHILD_PROFILE_ID BK_PEER2_PROFILE_ID_INT, \r\nSCRP.CREATION_DATE LINKAGE_DT,\r\nECRPH.LINK_FLAG  SOURCE_DELETED_FLG,\r\nSCRP.CREATION_DATETIME EDW_CREATE_DATE,\r\nUSER EDW_CREATE_USER,\r\nSCRP.CREATION_DATETIME EDW_CREATE_DATE,\r\nUSER EDW_UPDATE_USER,\r\nSCRP.ACTION_CODE ACTION_CODE,\r\nSCRP.ACTION_CODE DML_TYPE\r\nFROM $$STGDB.ST_CCRM_RELATED_PROFILES SCRP INNER JOIN\r\n(SELECT * FROM $$ETLVWDB.EL_CCRM_RELATED_PROFILE_HIST WHERE \r\n(PROFILE_ID,CHILD_PROFILE_ID,HISTORY_ID) IN \r\n(SELECT PROFILE_ID,CHILD_PROFILE_ID,MAX(HISTORY_ID)  FROM $$ETLVWDB.EL_CCRM_RELATED_PROFILE_HIST\r\nGROUP BY PROFILE_ID,CHILD_PROFILE_ID) ) ECRPH\r\nON ECRPH.PROFILE_ID = SCRP.PROFILE_ID\r\nAND ECRPH.CHILD_PROFILE_ID = SCRP.CHILD_PROFILE_ID\r\nwhere  SCRP.LINKAGE_TYPE = 'NORMAL'\r\nAND ECRPH.PROCESSED='Y'\r\nUNION ALL\r\nSELECT \r\nEXCRP .PROFILE_ID BK_PEER1_PROFILE_ID_INT, \r\nEXCRP .CHILD_PROFILE_ID BK_PEER2_PROFILE_ID_INT, \r\nEXCRP .CREATION_DATE LINKAGE_DT,\r\nECRPH.LINK_FLAG  SOURCE_DELETED_FLG,\r\nEXCRP.CREATION_DATETIME EDW_CREATE_DATE,\r\nUSER EDW_CREATE_USER,\r\nEXCRP.CREATION_DATETIME EDW_UPDATE_DATE,\r\nUSER EDW_UPDATE_USER,\r\nEXCRP.ACTION_CODE ACTION_CODE,\r\nEXCRP.ACTION_CODE DML_TYPE\r\nFROM $$EXCEPDB.EX_CCRM_RELATED_PROFILES_PL EXCRP INNER JOIN\r\n(SELECT * FROM $$ETLVWDB.EL_CCRM_RELATED_PROFILE_HIST WHERE \r\n(PROFILE_ID,CHILD_PROFILE_ID,HISTORY_ID) IN \r\n(SELECT PROFILE_ID,CHILD_PROFILE_ID,MAX(HISTORY_ID)  FROM $$ETLVWDB.EL_CCRM_RELATED_PROFILE_HIST\r\nGROUP BY PROFILE_ID,CHILD_PROFILE_ID) ) ECRPH\r\non  ECRPH.PROFILE_ID = EXCRP .PROFILE_ID\r\nAND ECRPH.CHILD_PROFILE_ID = EXCRP .CHILD_PROFILE_ID\r\nwhere  EXCRP .LINKAGE_TYPE = 'NORMAL'\r\nAND ECRPH.PROCESSED='Y'",
