      "attributes": {
        "Sql Query": "SELECT EL.BK_FISCAL_YEAR_MTH_NUMBER_INT,EL.REV_MEASURE_TRANS_TYPE_CD ,\r\n   EL.REVENUE_MEASURE_KEY ,EL.DV_PNL_LINE_ITEM_NAME\r\n FROM $$ETLVWDB.EL_EDW_PNL_LINE_ITEM EL\r\n WHERE DV_PNL_LINE_ITEM_NAME LIKE ANY ('AS%') \r\n  AND BK_FISCAL_YEAR_MTH_NUMBER_INT >=(\r\n SELECT FISCAL_YEAR_MONTH_INT \r\n FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR \r\n WHERE FISCAL_MONTH_NUMBER_INT=1 \r\n  AND FISCAL_YEAR_AGE=3)",
