      "attributes": {
        "Sql Query": "SELECT\r\nNTAC.SERVICE_REQUEST_TAC_COST_KEY  \r\n, TACSLKEY.DRVD_SALES_TERRITORY_KEY           \r\n, TACSRVCKEY.SERVICE_PRODUCT_KEY           \r\n, TACPRDKEY.GOODS_PRODUCT_KEY             \r\n, CNTL.FISCAL_YEAR_MONTH_INT \r\n, COALESCE(ESL1.DD_EXTERNAL_THEATER_NAME, 'UNKNOWN' ) C3_CUSTOMER_THEATER_NAME        \r\n, COALESCE(ESCMS.SALES_COVERAGE_CODE  , 'OTHER' ) C3_CUST_MARKET_SEGMENT_NAME         \r\n, NTAC.SRC_RPTD_SERVICE_CONTARCT_NUM \r\n, NTAC.TAC_BACKBONE_COST_USD_AMT*SA_SLK_ALLOCATION_RATIO*TACPRDKEY.PRODUCT_KEY_RATIO  \t\tTAC_BACKBONE_COST_USD_AMT\r\n, NTAC.TAC_THTR_BIZ_OPRTN_CST_USD_AMT*SA_SLK_ALLOCATION_RATIO*TACPRDKEY.PRODUCT_KEY_RATIO    TAC_THTR_BIZ_OPRTN_CST_USD_AMT\r\n, NTAC.TAC_OUT_TASKING_COST_AMT*SA_SLK_ALLOCATION_RATIO*TACPRDKEY.PRODUCT_KEY_RATIO         TAC_OUT_TASKING_COST_AMT\r\n, NTAC.TAC_OVERHEAD_COST_USD_AMT*SA_SLK_ALLOCATION_RATIO*TACPRDKEY.PRODUCT_KEY_RATIO\t\tTAC_OVERHEAD_COST_USD_AMT\r\n, NTAC.TAC_WARRANTY_PCT   DV_TAC_WARRANTY_PCT        \r\n, NTAC.TAC_ADJUSTED_OVERHEAD_PCT  DV_TAC_ADJUSTED_OVERHEAD_PCT\r\n, COALESCE( ISO.BK_ISO_COUNTRY_CODE   ,'UNK') BK_ISO_COUNTRY_CODE          \r\n, TACSLKEY.ALLOCATION_TYPE ENRICHMENT_METHODOLODY_DESC  \r\n, NTAC.DELIVERY_CHANNEL_NAME-- Traceability Changes\r\n, NTAC.ACTUAL_CASE_ON_DAYS_HRS_CNT*SA_SLK_ALLOCATION_RATIO*TACPRDKEY.PRODUCT_KEY_RATIO       -- Traceability Changes\r\n, NTAC.SRC_RPTD_CUST_NAME-- Traceability Changes\r\n, CURRENT_TIMESTAMP(0) EDW_CREATE_DTM                \r\n, USER EDW_CREATE_USER               \r\n, CURRENT_TIMESTAMP(0)  EDW_UPDATE_DTM                \r\n, USER EDW_UPDATE_USER  \r\n,   'I' ACTION_CODE\r\n, 'I' DML_TYPE\r\nFROM $$FINLGLVWDB.N_SR_TECH_ASSISTANCE_CNTR_COST NTAC  \r\nINNER JOIN $$STGDB.WI_CCM_TS_MTH_QTR_CNTL CNTL\r\nON NTAC.FISCAL_YEAR_MONTH_INT=CNTL.FISCAL_YEAR_MONTH_INT  \r\nLEFT OUTER JOIN $$ETLONLYDB.EL_CCM_C3_CST_THTR_SL1_MAP ESL1\r\nON ESL1.C3_CUST_THEATER = NTAC.C3_CUSTOMER_THEATER_NAME\r\nLEFT OUTER JOIN $$ETLONLYDB.EL_CCM_C3_MKT_SGMT_SCMS_MAP ESCMS\r\nON ESCMS.C3_MARKET_SEGMENT=NTAC.C3_CUST_MARKET_SEGMENT_NAME\r\nINNER JOIN $$STGDB.WI_CCM_TAC_ID_SERVICE_KEY TACSRVCKEY\r\nON    TACSRVCKEY.SERVICE_REQUEST_TAC_COST_KEY=NTAC.SERVICE_REQUEST_TAC_COST_KEY\r\nINNER JOIN $$STGDB.WI_CCM_TAC_ID_PRODUCT_KEY TACPRDKEY\r\nON    TACPRDKEY.SERVICE_REQUEST_TAC_COST_KEY=NTAC.SERVICE_REQUEST_TAC_COST_KEY\r\nINNER JOIN $$STGDB.WI_CCM_TAC_ID_SALES_TERR_KEY TACSLKEY\r\nON    TACSLKEY.SERVICE_REQUEST_TAC_COST_KEY=NTAC.SERVICE_REQUEST_TAC_COST_KEY\r\nLEFT OUTER JOIN $$COMREFVWDB.N_ISO_COUNTRY ISO\r\nON ISO.ISO_COUNTRY_SHORT_CODE=NTAC.SOURCE_REPORTED_TAC_COUNTRY_CD",
        "User Defined Join": "",
