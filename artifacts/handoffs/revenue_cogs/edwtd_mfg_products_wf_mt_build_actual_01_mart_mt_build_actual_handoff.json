      "attributes": {
        "Sql Query": "SELECT\r\nRU_BK_PRODUCT_FAMILY_ID AS BK_PRODUCT_FAMILY_ID,\r\nINVENTORY_ORGANIZATION_KEY,\r\nFISCAL_YEAR_WEEK_NUM_INT AS BK_FISCAL_YEAR_WEEK_NUM_INT,\r\nSUM(DV_BUILD_ACTUAL_USD_AMT),\r\nREVENUE_FLAG AS REVENUE_FLAG,\r\ncurrent_timestamp(0),\r\nuser,\r\ncurrent_timestamp(0),\r\nuser\r\nFROM (\r\nSELECT\r\nTAB.RU_BK_PRODUCT_FAMILY_ID,\r\nTAB.FISCAL_YEAR_WEEK_NUM_INT ,\r\nINVENTORY_ORGANIZATION_KEY,\r\nCASE WHEN REVENUE_FLAG ='Y'  \r\nTHEN SUM(PHYSICAL_DELIVERY_AMOUNT) + SUM (E_DELIVERY_AMOUNT) ELSE SUM(PHYSICAL_DELIVERY_AMOUNT) END  DV_BUILD_ACTUAL_USD_AMT,\r\nTAB.REVENUE_FLAG\r\nFROM\r\n(\r\nSELECT\r\nNP.RU_BK_PRODUCT_FAMILY_ID,\r\nRFDY.FISCAL_YEAR_WEEK_NUM_INT ,\r\nMMT.INVENTORY_ORGANIZATION_KEY,\r\n/*changed as part of Q4FY14 -LSS*/\r\nCASE WHEN NSOLVT.SS_CODE IN ('QTC','BV') THEN NSOTT.SO_TYPE_REVENUE_GEN_FLAG ELSE  \r\n  (  CASE WHEN NSOLVT.SS_CODE ='CG' AND SO.ORIGINATED_QTC_VIA_CG1_FLG ='Y' THEN NSOTT.SO_TYPE_REVENUE_GEN_FLAG /* Modified as a part of Q4 SC LSS Team */\r\nELSE NSOTT_LINE.SO_TYPE_REVENUE_GEN_FLAG  END  )\r\nEND AS   REVENUE_FLAG,\r\n/*changed as part of Q4FY14 -LSS*/\r\nSUM(CAST(  (BUILD_AMT+ RTV_AMT) AS DECIMAL(26,7))) AS PHYSICAL_DELIVERY_AMOUNT,\r\nCAST(0 AS DECIMAL(26,7)) AS E_DELIVERY_AMOUNT\r\nFROM\r\n$$INVFLMTVWDB.MT_MATERIAL_TRANSACTION MMT\r\nINNER JOIN $$COMREFVWDB.N_PRODUCT NP ON ( MMT.PRODUCT_KEY = NP.ITEM_KEY )\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR RFDY  ON MMT.DV_SOURCE_CREATE_DT  = RFDY.CALENDAR_DATE                 \r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_TV SO  ON (MMT.SALES_ORDER_KEY = SO.SALES_ORDER_KEY)  \r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_TYPE NSOTT  ON (SO.BK_ORDER_TYPE_NAME = NSOTT.BK_ORDER_TYPE_NAME)  \r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE_TV NSOL ON (NSOL.SALES_ORDER_KEY=SO.SALES_ORDER_KEY)\r\nAND MMT.SALES_ORDER_LINE_KEY = NSOL.SALES_ORDER_LINE_KEY \r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE_V1_TV NSOLVT ON (NSOL.SALES_ORDER_LINE_KEY=NSOLVT.SALES_ORDER_LINE_KEY) \r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_TYPE NSOTT_LINE ON (NSOTT_LINE.BK_ORDER_TYPE_NAME=NSOLVT.SO_LINE_TYPE_NAME) \r\nWHERE RFDY.FISCAL_QTR_AGE  IN (0,1)\r\nGROUP BY 1,2,3,4,6\r\nUNION ALL\r\nSELECT\r\nPF_E_DEL.BK_PRODUCT_FAMILY_ID,\r\nRFWY.FISCAL_YEAR_WEEK_NUM_INT,\r\nCAST(315 AS INTEGER) AS INVENTORY_ORGANIZATION_KEY,\r\n'Y' REVENUE_FLAG,\r\nCAST(0 AS DECIMAL(26,7)) AS PHYSICAL_DELIVERY_AMOUNT,\r\nSUM(CAST(COALESCE(PF_E_DEL.E_DELIVERY_ACTUAL_COST_USD_AMT,0) AS DECIMAL(26,7) )) AS E_DELIVERY_AMOUNT\r\nFROM $$INVFLMTVWDB.N_PRDCT_FAMILY_WEEK_E_DELIVERY PF_E_DEL\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_WEEK_TO_YEAR  RFWY  ON\r\n( PF_E_DEL.BK_FISCAL_WEEK_NUM_INT = RFWY.FISCAL_WEEK_NUMBER_INT   \r\nAND PF_E_DEL.BK_FISCAL_YEAR_NUM_INT = RFWY.FISCAL_YEAR_NUMBER_INT)\r\nWHERE RFWY.FISCAL_QTR_AGE  IN (0,1)\r\nGROUP BY 1,2,3,4,5\r\n) TAB\r\nGROUP BY 1,2,3,5\r\n)  TAB1\r\nGROUP BY 1,2,3,5",
        "User Defined Join": "",
        "Source Filter": "",
