      ],
      "attributes": {
        "Sql Query": "SELECT \r\nSOCAA.ACCOUNTNO, \r\nSOCAA.ADJ_ACCOUNTING_ID, \r\nSOCAA.ACCOUNT_TYPE,\r\nSOCAA.ADJ_TYPE_ID, \r\nSOCAA.GLOBAL_NAME \r\nFROM\r\n $$STGDB.ST_OM_CFI_ADJ_ACCOUNTING SOCAA\r\nWHERE NOT EXISTS(\r\nSELECT 1 FROM $$ETLVWDB.EL_OM_CFI_ADJ_ACCOUNTING EOCAA\r\nWHERE SOCAA.ADJ_ACCOUNTING_ID=EOCAA.ADJ_ACCOUNTING_ID\r\nAND SOCAA.GLOBAL_NAME = EOCAA.GLOBAL_NAME)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    },
    {
      "name": "SQ_XLA_AE_LINE_CORP_ADJ_INCR",
      "type": "Source Qualifier",
      "description": "",
      "fields": [
        {
          "name": "ACCOUNTNO",
          "datatype": "string",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        },
        {
          "name": "ADJ_ACCOUNTING_ID",
          "datatype": "decimal",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        },
        {
          "name": "ACCOUNT_TYPE",
          "datatype": "string",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        },
        {
          "name": "ADJ_TYPE_ID",
          "datatype": "decimal",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        },
        {
          "name": "GLOBAL_NAME",
          "datatype": "string",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "SELECT\r\nACCOUNTNO,\r\n(MAX_ID + ROW_NUMBER () OVER ( ORDER BY ACCOUNTNO,ACCOUNT_TYPE,ADJ_TYPE_ID )) AS ADJ_ACCOUNTING_ID,  \r\nACCOUNT_TYPE,\r\nADJ_TYPE_ID,\r\nGLOBAL_NAME\r\nFROM\r\n(\r\nSELECT\r\nNGLA.BK_FINANCIAL_ACCOUNT_CODE AS ACCOUNTNO,\r\nTMP_MX.MAX_ID,\r\nXAL.ACCOUNTING_CLASS_CODE AS ACCOUNT_TYPE ,\r\nEOCATA.ADJ_TYPE_ID ,\r\nNSSC.GLOBAL_NAME \r\nFROM $$STGDB.WI_XLA_AE_LINE_CORP_ADJ_INCR XAL\r\nINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC \r\n ON XAL.GLOBAL_NAME = NSSC.GLOBAL_NAME\r\nINNER JOIN $$ETLVWDB.EL_OM_CFI_ADJ_TYPE_ALL EOCATA \r\n ON XAL.DIST_TYPE = EOCATA.ADJ_TYPE_NAME\r\nINNER JOIN $$FINLGLVWDB.N_GENERAL_LEDGER_ACCOUNT NGLA\r\nON XAL.CODE_COMBINATION_ID = NGLA.SK_CODE_COMBINATION_ID_INT\r\nAND NSSC.SOURCE_SYSTEM_CODE = NGLA.SS_CODE\r\nAND NGLA.BK_FINANCIAL_ACCOUNT_CODE LIKE '4%'\r\nINNER JOIN \r\n ( SELECT COALESCE(MAX(ADJ_ACCOUNTING_ID),0) MAX_ID FROM  $$ETLVWDB.EL_OM_CFI_ADJ_ACCOUNTING ) TMP_MX  \r\n ON 1=1\r\nWHERE \r\nXAL.ACCOUNTING_CLASS_CODE = 'REVENUE'\r\nAND NOT EXISTS (\r\nSELECT 'Y' FROM $$ETLVWDB.EL_OM_CFI_ADJ_ACCOUNTING EOCAA\r\nWHERE EOCAA.ACCOUNTNO =  NGLA.BK_FINANCIAL_ACCOUNT_CODE                 \r\n AND EOCAA.ACCOUNT_TYPE = XAL.ACCOUNTING_CLASS_CODE  \r\n AND EOCAA.ADJ_TYPE_ID =  EOCATA.ADJ_TYPE_ID\r\n/* AND EOCAA.GLOBAL_NAME = XAL.GLOBAL_NAME*/\r\n)\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY  NGLA.BK_FINANCIAL_ACCOUNT_CODE  ORDER BY XAL.ACCOUNTING_CLASS_CODE) = 1\r\n)A",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
