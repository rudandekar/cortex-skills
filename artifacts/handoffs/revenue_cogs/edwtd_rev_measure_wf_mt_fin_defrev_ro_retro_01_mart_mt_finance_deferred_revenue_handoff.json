        "Sql Query": "SELECT \r\nMT.PROCESSED_FISCAL_YEAR_MTH_INT\r\n, MT.DV_MEASURE_NAME\r\n, MT.BK_MEASURE_NAME\r\n, MT.SALES_TERRITORY_KEY\r\n, MT.PRODUCT_KEY\r\n, MT.FISCAL_YEAR_MONTH_INT\r\n, MT.SRC_ENTITY_NAME\r\n, MT.BK_DEAL_ID\r\n, MT.ERP_DEAL_ID\r\n, MT.BK_CCRM_PROFILE_ID_INT\r\n, MT.SERVICE_FLG\r\n, MT.RECOGNIZED_REV_USD_AMT\r\n, MT.BALANCE_REV_USD_AMT\r\n, MT.PROJECTED_REV_USD_AMT\r\n, MT.PROJECTED_BALANCE_REV_USD_AMT\r\n, MT.EDW_CREATE_DTM\r\n, MT.EDW_CREATE_USER\r\n, MT.EDW_UPDATE_DTM\r\n, MT.EDW_UPDATE_USER\r\n, MT.RECOGNIZE_OR_PROJECTED_TYPE_CD\r\n, MT.SALES_ORDER_KEY\r\n, MT.DV_ATTRIBUTION_CD\r\n, MT.DV_PRODUCT_KEY\r\n, MT.XCAT_FLG\r\n, MT.RECURRING_OFFER_FLG\r\n, MT.BK_OFFER_TYPE_NAME\r\n, MT.ELA_FLG\r\n, MT.DV_BEGINNING_BLNCE_REV_USD_AMT\r\n, MT.DV_BRIDGE_BALANCE_REV_USD_AMT\r\n, MT.REMAINING_BALANCE_REV_USD_AMT\r\n,MT.SK_OFFER_ATTRIBUTION_ID_INT\r\n,MT.PRODUCT_SUBSCRIPTION_FLG\r\n,MT.DEFERRAL_REV_USD_AMT \r\n,CAST (\r\n  TRIM(COALESCE(MT.PRODUCT_KEY,-999)) || '~' || \r\n  TRIM(COALESCE(MT.DV_PRODUCT_KEY,-999)) ||  '~' || \r\n  TRIM(COALESCE(MT.SALES_ORDER_KEY,-9999)) ||  '~' || \r\n  TRIM(COALESCE(MT.SK_OFFER_ATTRIBUTION_ID_INT,-9999))AS VARCHAR(70)) AS DV_RECURRING_OFFER_CD /* ADDED AS PART OF Q3FY20 ICPM  OFFER CARVE OUT CHANGE */\r\nFROM\r\n$$FINLGLVWDB.MT_FINANCE_DEFERRED_REVENUE MT\r\nWHERE 1 = 2",
