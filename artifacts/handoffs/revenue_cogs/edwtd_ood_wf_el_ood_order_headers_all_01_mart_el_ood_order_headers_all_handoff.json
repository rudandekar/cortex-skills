      "attributes": {
        "Sql Query": "SELECT CAST(SOOHA.HEADER_ID AS BIGINT), CAST(SOOHA.ORG_ID AS BIGINT), \r\nSOOHA.ORDER_NUMBER, CAST(COALESCE (SOOHA.CUSTOMER_ACCEPTANCE_FLAG,'N')AS VARCHAR(30)) , \r\nSOOHA.CREATION_DATE, \r\nSOOHA.LAST_UPDATE_DATE ,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_UPDATE_DTM ,\r\n'CG' AS SS_CODE,\r\nCAST('OOD' AS VARCHAR(10)) AS IDENTIFIER\r\nFROM\r\n$$STGDB.ST_OOD_ORDER_HEADERS_ALL SOOHA\r\nWHERE NOT EXISTS (SEL 1 FROM $$ETLVWDB.EL_OOD_ORDER_HEADERS_ALL EOOHA \r\nWHERE EOOHA.HEADER_ID = SOOHA.HEADER_ID)\r\n\r\nUNION ALL\r\n\r\nSELECT SOFOHA.HEADER_ID, SOFOHA.ORG_ID, \r\nSOFOHA.ORDER_NUMBER, COALESCE (SOFOHA.CUSTOMER_ACCEPTANCE_FLAG,'N'), \r\nSOFOHA.CREATION_DATE, \r\nSOFOHA.LAST_UPDATE_DATE ,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_UPDATE_DTM ,\r\n'CG' AS SS_CODE,\r\n'FUSN' AS IDENTIFIER\r\nFROM\r\n$$STGDB.ST_OOD_FUSN_ORDER_HEADERS_ALL SOFOHA\r\nWHERE NOT EXISTS (SEL 1 FROM $$ETLVWDB.EL_OOD_ORDER_HEADERS_ALL EOOHA \r\nWHERE EOOHA.HEADER_ID = SOFOHA.HEADER_ID)",
