        "Sql Query": "SELECT CAST(SOGSOB.SET_OF_BOOKS_ID AS BIGINT), SOGSOB.ALLOW_INTERCOMPANY_POST_FLAG, CAST(SOGSOB.CHART_OF_ACCOUNTS_ID AS BIGINT), CAST(SOGSOB.CURRENCY_CODE AS VARCHAR(15)), CAST(SOGSOB.DESCRIPTION AS VARCHAR(240)), CAST(SOGSOB.NAME AS VARCHAR(50)), CAST(SOGSOB.SHORT_NAME AS VARCHAR(50)), CAST(SOGSOB.ATTRIBUTE1 AS VARCHAR(30)), SOGSOB.CREATE_DATETIME, SOGSOB.MRC_SOB_TYPE_CODE, SOGSOB.CREATION_DATE, SOGSOB.LAST_UPDATE_DATE, CAST('OOD' AS VARCHAR(10)) AS IDENTIFIER\r\nFROM\r\n$$STGDB.ST_OOD_GL_SETS_OF_BOOKS SOGSOB WHERE NOT EXISTS\r\n(SEL 1 FROM $$ETLVWDB.EL_OOD_GL_SETS_OF_BOOKS EOGSOB WHERE EOGSOB.SET_OF_BOOKS_ID=\r\nSOGSOB.SET_OF_BOOKS_ID)\r\n\r\nUNION ALL\r\n\r\nSELECT SOFGSOB.SET_OF_BOOKS_ID, SOFGSOB.ALLOW_INTERCOMPANY_POST_FLAG, SOFGSOB.CHART_OF_ACCOUNTS_ID, SOFGSOB.CURRENCY_CODE, SOFGSOB.DESCRIPTION, SOFGSOB.NAME, ST_OOD_GL_SETS_OF_BOOKS.SHORT_NAME, SOFGSOB.ATTRIBUTE1, SOFGSOB.CREATE_DATETIME, SOFGSOB.MRC_SOB_TYPE_CODE, SOFGSOB.CREATION_DATE, SOFGSOB.LAST_UPDATE_DATE , 'FUSN' AS IDENTIFIER\r\nFROM\r\n$$STGDB.ST_OOD_FUSN_GL_SETS_OF_BOOKS SOFGSOB WHERE NOT EXISTS\r\n(SEL 1 FROM $$ETLVWDB.EL_OOD_GL_SETS_OF_BOOKS EOGSOB WHERE EOGSOB.SET_OF_BOOKS_ID=\r\nSOFGSOB.SET_OF_BOOKS_ID)",
