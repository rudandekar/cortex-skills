      "attributes": {
        "Sql Query": "SELECT 'Excel Driver files for GSLO Validation'AS VALIDATION_TYPE,\r\n'DUTY VAT CIV Validation' AS VALIDATION_SUB_TYPE,\r\n'File upload check' NAME,\r\n'prior month vs current month' Criteria,\r\n'Early warning' Phase,\r\nCURRENT_DATE AS VALIDATED_DATE,\r\nRFDY.FISCAL_YEAR_MONTH_INT,\r\nCASE WHEN RFDY.WORKDAY_IN_FISCAL_MTD_COUNT >1 THEN 'New File Uploaed' ELse 'File is not uploaded for current_month' END FILE_UPLOAD_FLG,\r\nCOUNT(1) AS CUR_MTH_COUNT,\r\n(SELECT COUNT(1) FROM $$ETLVWDB.EL_DUTY_VAT_BY_COUNTRY EL\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMY\r\nON EL.FISCAL_YEAR_MONTH_INT= RFMY.FISCAL_YEAR_MONTH_INT\r\nAND RFMY.PREVIOUS_FSCL_MONTH_FLAG='Y' ) PREV_MTH_COUNT,\r\n0.100 AS TOLERANCE_DIFF,\r\nCAST(CUR_MTH_COUNT-PREV_MTH_COUNT AS DECIMAL(12,6))/CUR_MTH_COUNT DIFF_PCT,\r\nCASE WHEN ABS(DIFF_PCT)> TOLERANCE_DIFF THEN 'FAIL' ELSE 'PASS' END FINAL_RESULT \r\nFROM $$STGDB.WI_DUTY_VAT_BY_COUNTRY DUTY_VAT\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR RFDY\r\nON DUTY_VAT.EDW_CREATE_DTM=RFDY.CALENDAR_DATE\r\nAND CURRENT_FISCAL_MONTH_FLAG='Y' GROUP BY 7,8",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
