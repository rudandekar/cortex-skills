      "attributes": {
        "Sql Query": "SELECT 'Workgroup Hierarchy validation'AS VALIDATION_TYPE,\r\n'New Workgroup from current month' AS VALIDATION_SUB_TYPE,\r\n'New Work Group' NAME,\r\n'current month vs prior month' Criteria,\r\n'Early warning' Phase,\r\nCURRENT_DATE AS VALIDATED_DATE,\r\n(SELECT  FISCAL_YEAR_MONTH_INT  FROM $$STGDB.WI_CCM_FISCAL_MONTH_CTRL_ADT) FISCAL_YEAR_MONTH_INT,\r\nWG_NAME,THEATER,DELIVERY_CHANNEL FROM (\r\nSELECT WG_NAME,THEATER,DELIVERY_CHANNEL FROM $$ETLONLYDB.EL_CCM_TAC_WORKGROUP where FISCAL_YEAR_MONTH_INT =\r\n(SELECT  FISCAL_YEAR_MONTH_INT  FROM $$STGDB.WI_CCM_FISCAL_MONTH_CTRL_ADT)\r\nMINUS \r\nSELECT WG_NAME,THEATER,DELIVERY_CHANNEL FROM $$ETLONLYDB.EL_CCM_TAC_WORKGROUP where FISCAL_YEAR_MONTH_INT =\r\n(SELECT FISCAL_MONTH_AGO_MONTH_NUMBER FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR\r\nWHERE FISCAL_YEAR_MONTH_INT = (SELECT  FISCAL_YEAR_MONTH_INT  FROM $$STGDB.WI_CCM_FISCAL_MONTH_CTRL_ADT))) A",
