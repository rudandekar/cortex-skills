      "attributes": {
        "Sql Query": "SELECT TMP.REGION_ID,TMP.LANGUAGE_R,TMP.ZONE_R,TMP.COUNTRY,TMP.GLOBAL_NAME\r\nFROM (\r\nSELECT SCWRT.REGION_ID, SCWRT.LANGUAGE_R, SCWRT.ZONE_R,SCWRT.COUNTRY, SCWRT.GLOBAL_NAME,SCWRT.REFRESH_DATETIME\r\nFROM\r\n$$STGDB.ST_CG1_WSH_REGIONS_TL SCWRT\r\n WHERE SCWRT.SOURCE_DML_TYPE<> 'DELETE' AND NOT EXISTS\r\n (SELECT   1 FROM \r\n  $$ETLONLYDB.EL_CG1_WSH_REGIONS_TL  ECWRT\r\n WHERE SCWRT.REGION_ID = ECWRT.REGION_ID\r\nAND SCWRT.LANGUAGE_R=ECWRT.LANGUAGE_R\r\nAND     SCWRT.GLOBAL_NAME = ECWRT.GLOBAL_NAME ))TMP\r\nQUALIFY RANK () OVER (PARTITION BY TMP.REGION_ID,TMP.LANGUAGE_R ORDER BY TMP. REGION_ID, TMP.LANGUAGE_R,TMP.REFRESH_DATETIME DESC ) = 1",
