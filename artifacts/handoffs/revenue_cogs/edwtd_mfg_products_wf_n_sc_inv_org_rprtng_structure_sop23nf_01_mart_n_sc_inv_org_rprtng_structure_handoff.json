      "attributes": {
        "Sql Query": "SELECT\r\nINVENTORY_ORGANIZATION_KEY,\r\nDIRECTOR_NAME,\r\nVICE_PRESIDENT_NAME,\r\nPARTNER_NAME,\r\nPARTNER_TYPE_CD,\r\nREGION_CD,\r\nSUBREGION_CD\r\nFROM\r\n(SELECT \r\nNCIO.INVENTORY_ORGN_NAME_KEY AS INVENTORY_ORGANIZATION_KEY,\r\nSRHO.DRO AS DIRECTOR_NAME,\r\nSRHO.VP AS VICE_PRESIDENT_NAME,\r\nSRHO.Partner AS PARTNER_NAME,\r\nSRHO.Partner_Type AS PARTNER_TYPE_CD,\r\nSRHO.Region AS REGION_CD,\r\nSRHO.Sub_Region AS SUBREGION_CD,\r\n(CASE WHEN NIOPS.INVENTORY_ORGANIZATION_KEY IS NOT NULL  THEN 'U' ELSE 'I' END) AS DML_TYPE \r\n\r\nFROM \r\n$$SOPDATAVWDB.SC_INV_ORG_RPRTNG_STRUCTURE  SRHO\r\nINNER JOIN \r\n$$COMREFDB.N_CISCO_INVENTORY_ORG NCIO\r\nON \r\nNCIO.INVENTORY_ORGANIZATION_CODE=SRHO.ORG\r\nLEFT JOIN  $$INVFLMTVWDB.N_SC_INV_ORG_RPRTNG_STRUCTURE NIOPS\r\nON NIOPS.INVENTORY_ORGANIZATION_KEY=NCIO.INVENTORY_ORGN_NAME_KEY\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY  SRHO.ORG ORDER BY \r\nSRHO.BATCH_ID  DESC) = 1) A\r\nwhere A.DML_TYPE='I'",
