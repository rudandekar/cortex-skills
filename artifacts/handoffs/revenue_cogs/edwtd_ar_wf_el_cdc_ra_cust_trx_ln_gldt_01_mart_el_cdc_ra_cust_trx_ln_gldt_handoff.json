      "attributes": {
        "Sql Query": "SELECT\r\nCUST_TRX_LINE_GL_DIST_ID,\r\nCUSTOMER_TRX_ID,\r\nCUSTOMER_TRX_LINE_ID,\r\nGL_DATE,\r\nGL_POSTED_DATE,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_CREATE_DTM,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_UPDATE_DTM,\r\nSRCTLNGLDT.CODE_COMBINATION_ID,\r\nECDCGCC.SEGMENT4\r\nFROM $$STGDB.ST_CG_RA_CUST_TRX_LN_GLDT SRCTLNGLDT,\r\n$$ETLVWDB.EL_CDC_GL_CODE_COMBINATIONS ECDCGCC\r\nWHERE (SRCTLNGLDT.CODE_COMBINATION_ID=ECDCGCC.CODE_COMBINATION_ID\r\nAND SRCTLNGLDT.GLOBAL_NAME=ECDCGCC.GLOBAL_NAME)\r\nAND\r\nNOT EXISTS(SEL 1 FROM $$ETLVWDB.EL_CDC_RA_CUST_TRX_LN_GLDT ECRCTLNGLDT\r\nWHERE SRCTLNGLDT.CUST_TRX_LINE_GL_DIST_ID=ECRCTLNGLDT.CUST_TRX_LINE_GL_DIST_ID)\r\nUNION ALL\r\nSELECT\r\nCUST_TRX_LINE_GL_DIST_ID,\r\nCUSTOMER_TRX_ID,\r\nCUSTOMER_TRX_LINE_ID,\r\nGL_DATE,\r\nGL_POSTED_DATE,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_CREATE_DTM,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_UPDATE_DTM,\r\nSRCTLNGLDT.CODE_COMBINATION_ID,\r\nECDCGCC.SEGMENT4\r\nFROM $$EXCEPDB.EX_CG_RA_CUST_TRX_LN_GLDT SRCTLNGLDT,\r\n$$ETLVWDB.EL_CDC_GL_CODE_COMBINATIONS ECDCGCC\r\nWHERE (SRCTLNGLDT.CODE_COMBINATION_ID=ECDCGCC.CODE_COMBINATION_ID\r\nAND SRCTLNGLDT.GLOBAL_NAME=ECDCGCC.GLOBAL_NAME)\r\nAND\r\nNOT EXISTS(SEL 1 FROM $$ETLVWDB.EL_CDC_RA_CUST_TRX_LN_GLDT ECRCTLNGLDT\r\nWHERE SRCTLNGLDT.CUST_TRX_LINE_GL_DIST_ID=ECRCTLNGLDT.CUST_TRX_LINE_GL_DIST_ID)\r\nAND\r\nNOT EXISTS(SEL 1 FROM $$STGDB.ST_CG_RA_CUST_TRX_LN_GLDT ECRCTLNGLDT\r\nWHERE SRCTLNGLDT.CUST_TRX_LINE_GL_DIST_ID=ECRCTLNGLDT.CUST_TRX_LINE_GL_DIST_ID)",
