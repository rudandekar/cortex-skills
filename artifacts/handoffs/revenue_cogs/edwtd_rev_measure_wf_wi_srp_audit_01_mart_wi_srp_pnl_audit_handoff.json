        {
          "name": "DOLLAR_MISMATCH_AMT",
          "datatype": "decimal",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "SELECT \r\n SRC.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n,SRC.DV_DATA_SOURCE_NAME,\r\n'MT_TSS_SERVICE_REVENUE' AS AUDIT_TABLE \r\n,CURRENT_DATE  \r\n,ABS(ROUND(COALESCE(SRC.SRC_REV,1)-COALESCE(TGT.TGT_REV,1),4))  AS REV_MISMATCH_AMT \r\nFROM \r\n(SELECT DV_FISCAL_YEAR_MTH_NUMBER_INT,CAST ('CISCO' AS VARCHAR(50)) AS DV_DATA_SOURCE_NAME,SUM(DV_COMP_US_NET_REV_AMT) SRC_REV \r\nFROM $$STGDB.WI_RSTD_GL_SVC_REV_MSR_FINAL\r\nWHERE DV_FISCAL_YEAR_MTH_NUMBER_INT IN (SEL FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_SRVC_REV_CNTRL_MNTH )\r\nGROUP BY 1,2\r\nUNION ALL\r\nSELECT MNL.DV_FISCAL_YEAR_MTH_NUMBER_INT,'MANUALS', SUM(ADJUSTMENT_ALLOCATION_USD_AMT) AS SRC_REV\r\nFROM  $$FINLGLVWDB.N_PRDT_REV_COST_ADJSTMNT_ALCTN MNL\r\nWHERE MNL.DV_FISCAL_YEAR_MTH_NUMBER_INT IN (SEL FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_SRVC_REV_CNTRL_MNTH )\r\nAND MNL.BK_ADJ_SUB_MEASURE_TYPE_CD = 'TS Revenue_ManAdj'\r\nGROUP BY 1,2\r\nUNION ALL\r\nSELECT DV_FISCAL_YEAR_MTH_NUMBER_INT,ACQ.ACQUISITION_SOURCE_CD,SUM(ACQ.EXTENDED_NET_REVENUE_USD_AMT *COALESCE(SFH.ALLOCATION_PERCENTAGE,1 ))AS SRC_REV\r\n FROM $$FINLGLVWDB.N_APSP_FDI_REVENUE_TRX ACQ\r\nINNER JOIN  $$COMREFVWDB.R_PRODUCTS PRD\r\nON PRD.ITEM_KEY=ACQ.CISCO_PRODUCT_KEY\r\nAND  PRD.DIVESTITURE_TYPE_CD = 'UNKNOWN' /*ADDED AS PART OF DIVESTITURE SCOPE*/\r\nINNER JOIN $$COMREFVWDB.MT_CS_DEAL_SVC_FIN_HIER_ALLOC SFH\r\nON SFH.BK_PRODUCT_SUBGROUP_ID=CASE WHEN PRD.GOODS_OR_SERVICE_TYPE ='GOODS' THEN PRD.RU_BK_PRODUCT_SUBGROUP_ID ELSE PRD.RU_BK_SERVICE_PROD_SUBGROUP_ID END \r\nAND SFH.BK_SERVICE_CATEGORY_ID='TECHNICAL SUPPORT SERVICES'\r\nWHERE ACQ.DV_FISCAL_YEAR_MTH_NUMBER_INT IN (SEL FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_SRVC_REV_CNTRL_MNTH )\r\nAND  (ACQ.EXTENDED_NET_REVENUE_USD_AMT IS NOT NULL OR ACQ.EXTENDED_NET_REVENUE_USD_AMT<>0)\r\nGROUP BY 1,2) SRC\r\nFULL JOIN \r\n(SELECT DV_FISCAL_YEAR_MTH_NUMBER_INT,DV_DATA_SOURCE_NAME,SUM(DV_COMP_US_NET_REV_AMT) TGT_REV \r\nFROM $$FINLGLVWDB.MT_TSS_SERVICE_REVENUE \r\nWHERE DV_FISCAL_YEAR_MTH_NUMBER_INT IN (SEL FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_SRVC_REV_CNTRL_MNTH )\r\nGROUP BY 1,2\r\n)TGT\r\nON SRC.DV_FISCAL_YEAR_MTH_NUMBER_INT=TGT.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND SRC.DV_DATA_SOURCE_NAME=TGT.DV_DATA_SOURCE_NAME",
        "User Defined Join": "",
