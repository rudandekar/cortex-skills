      ],
      "attributes": {
        "Sql Query": "SELECT \r\n SRC.DV_FISCAL_YEAR_MTH_NUMBER_INT \r\n,SRC.DV_DATA_SOURCE_NAME\r\n,'MT_TSS_SERVICE_REVENUE_SO_AGG' AS AUDIT_TABLE\r\n,CURRENT_DATE AS AUDIT_DATE\r\n,ABS(ROUND(COALESCE(SRC.SRC_REV,1)-COALESCE(TGT.TGT_REV,1),4)) AS REV_MISMATCH_AMT \r\nFROM \r\n(SELECT DV_FISCAL_YEAR_MTH_NUMBER_INT,DV_DATA_SOURCE_NAME,SUM(DV_COMP_US_NET_REV_AMT) SRC_REV \r\nFROM $$FINLGLVWDB.MT_TSS_SERVICE_REVENUE\r\nWHERE DV_FISCAL_YEAR_MTH_NUMBER_INT IN (SELECT FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_SRVC_REV_CNTRL_MNTH )\r\nGROUP BY 1,2 ) SRC \r\nFULL JOIN \r\n(SELECT DV_FISCAL_YEAR_MTH_NUMBER_INT,DV_DATA_SOURCE_NAME,SUM(DV_COMP_US_NET_REV_AMT) TGT_REV \r\nFROM $$FINLGLVWDB.MT_TSS_SERVICE_REVENUE_SO_AGG \r\nWHERE DV_FISCAL_YEAR_MTH_NUMBER_INT IN (SELECT FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_SRVC_REV_CNTRL_MNTH ) \r\nGROUP BY 1,2 ) TGT\r\nON SRC.DV_FISCAL_YEAR_MTH_NUMBER_INT=TGT.DV_FISCAL_YEAR_MTH_NUMBER_INT \r\nAND SRC.DV_DATA_SOURCE_NAME=TGT.DV_DATA_SOURCE_NAME",
        "User Defined Join": "",
