      ],
      "attributes": {
        "Sql Query": "SELECT \r\nNPT.ITEM_KEY PRODUCT_KEY, \r\nCASE WHEN HIER.DEFREV_COMPONENT_NAME ='DRType' THEN 'UNKNOWN' ELSE COALESCE ( HIER.DEFREV_COMPONENT_NAME,'UNKNOWN' )  END  DEFREV_COMPONENT_NAME,\r\nCASE WHEN HIER.DEFREV_GROUP_NAME='DRType' THEN 'UNKNOWN' ELSE COALESCE (HIER.DEFREV_GROUP_NAME, 'UNKNOWN')  END DEFREV_GROUP_NAME,\r\nCOALESCE ( CMPNT.DFRD_REV_OFFR_HIER_NODE_KEY ,-999)    DFRD_REV_OFFR_HIER_NODE_KEY \r\nFROM $$COMREFVWDB.N_PRODUCT_TV NPT \r\nLEFT OUTER JOIN $$FINLGLVWDB.N_DFRD_REV_OFFR_HIER_CMPNT_PRDT  CMPNT\r\nON CMPNT.PRODUCT_KEY=NPT.ITEM_KEY\r\nLEFT OUTER JOIN   (\r\nSELECT \r\nCMPNT_IN.DFRD_REV_OFFR_HIER_NODE_KEY,\r\nCMPNT_IN.NODE_NAME DEFREV_COMPONENT_NAME,  \r\nCMPNT_IN.DFRD_REV_OFFR_HIER_GROUP_NODE_KEY,\r\nGRP_IN.NODE_NAME DEFREV_GROUP_NAME\r\nFROM $$FINLGLVWDB.N_DFRD_REV_OFFR_HIER_NODE   CMPNT_IN \r\nLEFT OUTER JOIN $$FINLGLVWDB.N_DFRD_REV_OFFR_HIER_NODE  GRP_IN \r\nON CMPNT_IN.DFRD_REV_OFFR_HIER_GROUP_NODE_KEY=GRP_IN.DFRD_REV_OFFR_HIER_NODE_KEY\r\n) HIER\r\nON CMPNT.DFRD_REV_OFFR_HIER_NODE_KEY=HIER.DFRD_REV_OFFR_HIER_NODE_KEY\r\nWHERE  NPT.END_TV_DATE = '3500-01-01'",
        "User Defined Join": "",
