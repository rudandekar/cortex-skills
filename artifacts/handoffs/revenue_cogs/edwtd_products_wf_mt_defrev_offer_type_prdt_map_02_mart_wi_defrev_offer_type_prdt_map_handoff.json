      "attributes": {
        "Sql Query": "SELECT \r\nPRODUCT_KEY,                   \r\nDEFREV_COMPONENT_NAME         ,\r\nDEFREV_GROUP_NAME             ,\r\nDFRD_REV_OFFR_HIER_NODE_KEY   ,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM                \t,\r\nUSER EDW_CREATE_USER               \t,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM                \t,\r\nUSER EDW_UPDATE_USER   \r\nFROM              \r\n$$STGDB.WI_DEFREV_OFFER_TYPE_PRDT_MAP WI\r\nWHERE NOT EXISTS\r\n(SELECT 1 FROM $$COMREFVWDB.MT_DEFREV_OFFER_TYPE_PRDT_MAP MT\r\nWHERE  WI.PRODUCT_KEY = MT.PRODUCT_KEY)",
