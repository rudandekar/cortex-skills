      "attributes": {
        "Sql Query": "SELECT\r\nMT.BK_FISCAL_YEAR_MTH_NUMBER_INT ,\r\nMT.DV_PNL_REV_COST_TYPE          ,\r\nMT.BK_REVENUE_OR_COGS_TYPE_CD    ,\r\nMT.ORIGINAL_SALES_TERRITORY_KEY  ,\r\nMT.DV_PNL_LINE_ITEM_NAME         ,\r\nCOALESCE (WI.PARTNER_TYPE_CD  ,'UNKNOWN')              ,\r\nCOALESCE (WI.CHANNEL_FLG     ,'=')              ,\r\nCOALESCE (WI.AS_OF_FSC_MTH_PARTNER_TYPE_CD ,'UNKNOWN'),\r\nCOALESCE (WI.AS_OF_FSC_MTH_CHANNEL_FLG     ,'='),\r\nCOALESCE (WI.DV_ROUTE_TO_MARKET_CD         ,'OTHERS'),\r\nCOALESCE (WI.DV_AS_OF_FSC_MTH_RTM_CD        ,   'OTHERS'),  \r\nCOALESCE (WI.STK_RTM_RATIO  ,1)    ,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER          \r\nFROM  \r\n\r\n(\r\nSELECT\r\nBK_FISCAL_YEAR_MTH_NUMBER_INT ,\r\nDV_PNL_REV_COST_TYPE          ,\r\n'REVENUE' BK_REVENUE_OR_COGS_TYPE_CD    ,\r\nORIGINAL_SALES_TERRITORY_KEY  ,\r\nDV_PNL_LINE_ITEM_NAME  \r\nFROM \r\n$$STGDB.WI_PNL_REV_COST_MSR_SRVC_REV\r\nWHERE DV_PNL_REV_COST_TYPE IN ('TSS_REVENUE')\r\nGROUP BY 1,2,3,4,5\r\n)\r\nMT \r\nLEFT OUTER JOIN $$STGDB.WI_PNL_REV_COST_STK_RATIO WI\r\nON MT.BK_FISCAL_YEAR_MTH_NUMBER_INT=WI.BK_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND MT.DV_PNL_REV_COST_TYPE=WI.DV_PNL_REV_COST_TYPE\r\nAND MT.BK_REVENUE_OR_COGS_TYPE_CD=WI.BK_REVENUE_OR_COGS_TYPE_CD\r\nAND MT.ORIGINAL_SALES_TERRITORY_KEY=WI.ORIGINAL_SALES_TERRITORY_KEY\r\nAND MT.DV_PNL_LINE_ITEM_NAME=WI.DV_PNL_LINE_ITEM_NAME",
