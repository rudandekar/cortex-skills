        "Sql Query": "SELECT TMP.MESSAGE_3B2_ID, TMP.SHIPMENT_NUMBER, TMP.FREIGHT_CARRIER, TMP.SERVICE_LEVEL, TMP.VEHICLE_NUMBER, TMP.FROM_POINT, TMP.TO_POINT, TMP.SHIP_DATE, TMP.BOL_NO, TMP.SHIP_VIA, TMP.SHIPMENT_NOTE, TMP.TRACKING_NUMBER, TMP.PARTNER_DUNS_NO, TMP.PARTNER_CODE, TMP.ERROR_MESSAGE, TMP.ERROR_CODE, TMP.B2B_PROCESS_STATUS, TMP.REASON_CODE, TMP.TRANSMISSION_DATE, TMP.PROCESS_STATUS, TMP.SJ_PROCESS_STATUS, TMP.ACK_STATUS, TMP.FUNC_ACK_CREATION_DATE, TMP.FUNC_ACK_LAST_UPDATED_DATE, TMP.EMAIL_NOTIFICATION, TMP.CISCO_DUNS_NO, TMP.CREATION_DATE, TMP.CREATED_BY, TMP.LAST_UPDATE_DATE, TMP.LAST_UPDATED_BY, TMP.LAST_UPDATE_LOGIN, TMP.REQUEST_ID, TMP.SYSTEM_TIME_ZONE,\r\n TMP.SOURCE_DML_TYPE, TMP.SOURCE_COMMIT_TIME, TMP.REFRESH_DATETIME, 'CG' AS GLOBAL_NAME\r\nFROM $$NRTACCUMVWDB.CG1_XXSCM_MK_ASNHEADER_I TMP\r\nWHERE  SOURCE_COMMIT_TIME > '$$LastExtractDate' \r\nAND SOURCE_COMMIT_TIME <=  '$$EndLastExtractDate'\r\nAND SOURCE_DML_TYPE<>'DELETE'\r\nQUALIFY RANK () OVER (PARTITION BY TMP.MESSAGE_3B2_ID ORDER BY TMP.MESSAGE_3B2_ID, TMP.REFRESH_DATETIME DESC ) = 1",
