      "attributes": {
        "Sql Query": "SELECT\t\r\n\tTRIM(TRAILING '-' FROM PRODUCT_TYPE_CLASS_CODE ) AS BK_PART_CLASS_CD,\r\n\t(CASE\tWHEN DEACTIVATED_BY IS NULL THEN 'N' ELSE\t'Y' END\t) AS DEACTIVATED_ROLE, \r\n\tCOALESCE(SOURCE1,'UNKNOWN') AS SS_CD,\r\n\tCOALESCE(DEACTIVATED_DATE,DATE '3500-01-01') AS RU_DEACTIVATED_DT,\r\n\tNCWPCCU.cisco_worker_party_key AS RU_DCTVTD_CISCO_WRKR_PARTY_KEY,\r\n\tCURRENT_TIMESTAMP(0) , \r\n\tUSER, \r\n\tCURRENT_TIMESTAMP(0) , \r\n\tUSER,\r\n\tCOALESCE(NCIC.CUSTOMS_ITEM_SPECIFIC_KEY, -999) AS CUSTOMS_ITEM_SPECIFIC_KEY\r\nFROM\t (\r\n\tSELECT\t BATCH_ID,\r\n\t\tCLASSIFICATION_ATTRIBUTES_ID,\r\n\t\tPRODUCT_TYPE_CLASS_CODE,\r\n\t\tPRODUCT_FLAG, \r\n\t\tDESCRIPTION,\r\n\t\tSPECIFIC1,\r\n\t\tCOMMENTS, \r\n\t\tATTRIBUTE1,\r\n\t\tATTRIBUTE2,\r\n\t\tATTRIBUTE3,\r\n\t\tDEACTIVATED_BY,\r\n\t\tDEACTIVATED_DATE,\r\n\t\tCREATED_BY,\r\n\t\tCREATED_DATE,\r\n\t\tMODIFIED_BY,\r\n\t\tMODIFIED_DATE,\r\n\t\tSOURCE1,\r\n\t\tCREATE_DATETIME,\r\n\t\tACTION_CODE,\r\n\t\tSPECIFIC_ID\r\n\tFROM\t$$STGDB.ST_XXCFI_CB_TYPE_SPECIFIC\r\n\tWHERE\tPRODUCT_FLAG = 'C'\r\n\t  AND   SOURCE1 = 'CISCO'\r\n\tUNION ALL\r\n\tSELECT\tBATCH_ID,\r\n\t\tCLASSIFICATION_ATTRIBUTES_ID,\r\n\t\tPRODUCT_TYPE_CLASS_CODE,\r\n\t\tPRODUCT_FLAG, \r\n\t\tDESCRIPTION,\r\n\t\tSPECIFIC1,\r\n\t\tCOMMENTS, \r\n\t\tATTRIBUTE1,\r\n\t\tATTRIBUTE2,\r\n\t\tATTRIBUTE3,\r\n\t\tDEACTIVATED_BY,\r\n\t\tDEACTIVATED_DATE,\r\n\t\tCREATED_BY,\r\n\t\tCREATED_DATE,\r\n\t\tMODIFIED_BY,\r\n\t\tMODIFIED_DATE,\r\n\t\tSOURCE1,\r\n\t\tCREATE_DATETIME,\r\n\t\tACTION_CODE,\r\n\t\tSPECIFIC_ID\r\n\tFROM\t $$EXCEPDB.EX_XXCFI_CB_TYPE_SPECIFIC\r\n\tWHERE\tPRODUCT_FLAG = 'C'\r\n\t  AND   SOURCE1 = 'CISCO'\r\n\tAND\tEXCEPTION_TYPE = 'RI' ) SXCTS\r\n\tINNER JOIN $$COMREFVWDB.N_PART_CLASS NPC\r\n\tON\t( TRIM(TRAILING '-' FROM PRODUCT_TYPE_CLASS_CODE ) = NPC.BK_PART_CLASS_CD)\r\n\tINNER JOIN $$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC NCIC\r\n\tON NCIC.SK_SPECIFIC_ID_INT = SXCTS.SPECIFIC_ID\r\n\tINNER JOIN  $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWPTV\r\n\tON\t(NCWPTV.CEC_ID= COALESCE(SXCTS.DEACTIVATED_BY,'UNKNOWN'))\r\n\tINNER JOIN $$FINLGLVWDB.N_CSC_WRKR_PRTY_CSTMS_CUBE_USR NCWPCCU\r\n\tON (NCWPCCU.CISCO_WORKER_PARTY_KEY = NCWPTV.CISCO_WORKER_PARTY_KEY)\r\nWHERE\t1=1\r\n\tAND\tNOT EXISTS  (\r\n\tSELECT\t1\r\n\tFROM\t   $$FINLGLVWDB.N_ITEM_SPECIFIC_PRT_CLASS_LINK\r\n\tWHERE\tSK_SPECIFIC_ID_INT =  SXCTS.SPECIFIC_ID\r\n\tAND\tTRIM(TRAILING '-' FROM SXCTS.PRODUCT_TYPE_CLASS_CODE ) =  BK_PART_CLASS_CD   )",
