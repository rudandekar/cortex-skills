      "attributes": {
        "Sql Query": "SELECT\t\r\n\tBATCH_ID,\r\n\tCLASSIFICATION_ATTRIBUTES_ID,\r\n\tPRODUCT_TYPE_CLASS_CODE,\r\n\tPRODUCT_FLAG,\r\n\tDESCRIPTION,\r\n\tSPECIFIC1,\r\n\tCOMMENTS,\r\n\tATTRIBUTE1,\r\n\tATTRIBUTE2,\r\n\tATTRIBUTE3,\r\n\tDEACTIVATED_BY,\r\n\tDEACTIVATED_DATE,\r\n\tCREATED_BY,\r\n\tCREATED_DATE,\r\n\tMODIFIED_BY,\r\n\tMODIFIED_DATE,\r\n\tSOURCE1,\r\n\tCREATE_DATETIME,\r\n\tACTION_CODE,\r\n\t'RI' EXCEPTION_TYPE,\r\nSPECIFIC_ID\r\nFROM\t$$STGDB.ST_XXCFI_CB_TYPE_SPECIFIC SXCTS\r\nWHERE\tPRODUCT_FLAG = 'C'\r\n  AND   SOURCE1 = 'CISCO'\r\n\tAND NOT EXISTS\r\n\t(\r\n\tSELECT 1\r\n\tFROM  $$COMREFVWDB.N_PART_CLASS NPC,\r\n\t$$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC NCIC,\r\n\t(SELECT \r\n\t\tNCWPCCU.CISCO_WORKER_PARTY_KEY, \r\n\t\tNCWPTV1.CEC_ID\r\n\tFROM\t$$FINLGLVWDB.N_CSC_WRKR_PRTY_CSTMS_CUBE_USR NCWPCCU\r\n\t\tINNER JOIN  $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWPTV1\r\n\t\tON NCWPCCU.CISCO_WORKER_PARTY_KEY = NCWPTV1.CISCO_WORKER_PARTY_KEY\r\n\t)NCWPTV\r\n\tWHERE \t( TRIM(TRAILING '-' FROM PRODUCT_TYPE_CLASS_CODE ) = NPC.BK_PART_CLASS_CD)\r\n\tAND NCIC.SK_SPECIFIC_ID_INT = SXCTS.SPECIFIC_ID\r\n\tAND (NCWPTV.CEC_ID= COALESCE(SXCTS.DEACTIVATED_BY,'UNKNOWN'))\r\n\t)",
