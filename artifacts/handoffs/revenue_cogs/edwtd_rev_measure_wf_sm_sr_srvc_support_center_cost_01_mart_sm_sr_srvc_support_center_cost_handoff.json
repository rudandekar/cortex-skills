      "attributes": {
        "Sql Query": "SELECT\r\nROW_NUMBER() OVER (ORDER BY CNTL.FISCAL_YEAR_MONTH_INT ,SSC.SRC_RPTD_SERVICE_REQUEST_NUM_INT,SSC.SRC_RPTD_REPAIR_ORDER_NUM_INT,SSC.SRC_RPTD_PRDT_PART_NUM,SHP_CNTL.FISCAL_YEAR_MONTH_INT) + TAC_HDR.CCM_SSC_KEY AS SERVICE_REQUEST_SSC_COST_KEY, \r\nCNTL.FISCAL_YEAR_MONTH_INT ,\r\nSSC.SRC_RPTD_SERVICE_REQUEST_NUM_INT,\r\nSSC.SRC_RPTD_REPAIR_ORDER_NUM_INT,\r\nSSC.SRC_RPTD_PRDT_PART_NUM,\r\nSHP_CNTL.FISCAL_YEAR_MONTH_INT AS BK_SHIPPED_FSCL_MTH_NUM_INT,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER\r\nFROM (SELECT SRC_RPTD_SERVICE_REQUEST_NUM_INT,SRC_RPTD_REPAIR_ORDER_NUM_INT,SRC_RPTD_PRDT_PART_NUM,BK_SR_SSC_COST_FSCL_YR_NUM_INT,BK_SR_SSC_COST_FSCL_MTH_NUM_INT\r\nBK_SHIPPED_FISCAL_MTH_NUM_INT,BK_SHIPPED_FISCAL_YEAR_NUM_INT --Ship month & year ,part of Traceability changes\r\nFROM $$FINLGLVWDB.N_SR_SERVICE_SUPPORT_CENTER_COST GROUP BY 1,2,3,4,5,6,7) SSC\r\nINNER JOIN $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID SHP_CNTL --New Join for Ship fiscal month ,part of Traceability changes\r\nON SHP_CNTL.FISCAL_YEAR_MONTH_INT = CAST(CASE WHEN CHARACTER_LENGTH(CAST(TRIM(SSC.BK_SHIPPED_FISCAL_MTH_NUM_INT) AS VARCHAR(4))) = 1 \r\nTHEN TRIM(SSC.BK_SHIPPED_FISCAL_YEAR_NUM_INT) || '0' || TRIM(SSC.BK_SHIPPED_FISCAL_MTH_NUM_INT)\r\nELSE TRIM(SSC.BK_SHIPPED_FISCAL_YEAR_NUM_INT) || TRIM(SSC.BK_SHIPPED_FISCAL_MTH_NUM_INT) END AS INTEGER)\r\nINNER JOIN $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID CNTL\r\nON CNTL.FISCAL_YEAR_MONTH_INT = CAST(CASE WHEN CHARACTER_LENGTH(CAST(TRIM(SSC.BK_SR_SSC_COST_FSCL_MTH_NUM_INT) AS VARCHAR(4))) = 1 \r\nTHEN TRIM(SSC.BK_SR_SSC_COST_FSCL_YR_NUM_INT) || '0' || TRIM(SSC.BK_SR_SSC_COST_FSCL_MTH_NUM_INT)\r\nELSE TRIM(SSC.BK_SR_SSC_COST_FSCL_YR_NUM_INT) || TRIM(SSC.BK_SR_SSC_COST_FSCL_MTH_NUM_INT) END AS INTEGER),\r\n(SELECT COALESCE( MAX(SERVICE_REQUEST_SSC_COST_KEY),0) CCM_SSC_KEY FROM $$ETLVWDB.SM_SR_SRVC_SUPPORT_CENTER_COST) TAC_HDR\r\nWHERE NOT EXISTS (SELECT 1 FROM $$ETLVWDB.SM_SR_SRVC_SUPPORT_CENTER_COST SMTAC \r\nWHERE SMTAC.FISCAL_YEAR_MONTH_INT = CNTL.FISCAL_YEAR_MONTH_INT\r\nAND SMTAC.SRC_RPTD_SR_NUMBER_INT = SSC.SRC_RPTD_SERVICE_REQUEST_NUM_INT\r\nAND SMTAC.SRC_RPTD_REPAIR_ORDER_NUM_INT = SSC.SRC_RPTD_REPAIR_ORDER_NUM_INT\r\nAND SMTAC.SRC_RPTD_PRODUCT_PART_NUM = SSC.SRC_RPTD_PRDT_PART_NUM)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
