        "Sql Query": "SELECT VT_INTERFACE_ID,\r\nVT_TRANSACTION_TYPE, \r\nVT_TRANSACTION_REF, \r\nVT_TRANSACTION_DATE,\r\nVT_DATE_PROCESSED, \r\nINVENTORY_ITEM, \r\nUNIT_SELLING_PRICE, \r\nATTRIBUTE1, \r\nATTRIBUTE2, \r\nATTRIBUTE4, \r\nATTRIBUTE5, \r\nATTRIBUTE8, \r\nATTRIBUTE9, \r\nATTRIBUTE10, \r\nATTRIBUTE11, \r\nATTRIBUTE12, \r\nATTRIBUTE13, \r\nATTRIBUTE15, \r\nATTRIBUTE17, \r\nATTRIBUTE20, \r\nATTRIBUTE25, \r\nATTRIBUTE27, \r\nATTRIBUTE33, \r\nVT_TRANSACTION_ID, \r\nVT_SOURCE_ASSIGNMENT_ID, \r\nLINE_ID, \r\nSOURCE_DML_TYPE, \r\nSOURCE_COMMIT_TIME, \r\nREFRESH_DATETIME,\r\nATTRIBUTE37,\r\nATTRIBUTE40,\r\nORG_ID\r\nFROM\r\n$$NRTACCUMDB.CG1_CP_OE_LINES_IFACE\r\nWHERE   SOURCE_COMMIT_TIME > '$$LastExtractDate' \r\nAND   SOURCE_DML_TYPE <> 'DELETE'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY   VT_INTERFACE_ID ORDER BY   REFRESH_DATETIME DESC) = 1",
