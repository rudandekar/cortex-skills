      "attributes": {
        "Sql Query": "SELECT \r\nREASON_ID                     \r\n,COALESCE(LAST_UPDATE_DATE , CURRENT_TIMESTAMP(0))            \r\n,-1 AS LAST_UPDATED_BY               \r\n,CREATION_DATE                 \r\n,-1 AS CREATED_BY   \r\n,COALESCE(REASON_NAME,'UNKNOWN')\r\n,LAST_UPDATE_LOGIN             \r\n,REASON_TYPE                                    \r\n,REASON_TYPE_DISPLAY           \r\n,REASON_CONTEXT_CODE           \r\n,GES_UPDATE_DATE               \r\n,'ERPCLOUD' AS GLOBAL_NAME                   \r\n,CREATE_DATETIME \r\nFROM \r\n$$ETLVWDB.ST_CLOUD_MTL_TRANSACTION_REAS\r\nWHERE\r\nCREATE_DATETIME >'$$LastExtractDate'\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY REASON_ID ORDER BY GES_UPDATE_DATE DESC)=1",
        "User Defined Join": "",
        "Source Filter": "",
