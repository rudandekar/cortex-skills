      "attributes": {
        "Sql Query": "SELECT CAST(SOOSC.ORGANIZATION_ID AS BIGINT), CAST(SOOSC.ORGANIZATION_NAME AS VARCHAR(50)), CAST(SOOSC.COMPANY_CODE AS VARCHAR(50)), CAST(SOOSC.SET_OF_BOOKS_ID AS BIGINT), CAST(SOOSC.SET_OF_BOOKS_NAME AS VARCHAR(50)), SOOSC.CREATE_DATETIME, SOOSC.CREATION_DATE, SOOSC.LAST_UPDATE_DATE, \r\nCAST('OOD' AS VARCHAR(10)) AS IDENTIFIER\r\nFROM\r\n$$STGDB.ST_OOD_ORG_SOB_COMPANY  SOOSC\r\nWHERE NOT EXISTS (SEL 1 FROM $$ETLVWDB.EL_OOD_ORG_SOB_COMPANY EOOSC\r\nWHERE SOOSC.COMPANY_CODE=\r\nEOOSC.COMPANY_CODE\r\nAND SOOSC.SET_OF_BOOKS_ID\r\n= EOOSC.SET_OF_BOOKS_ID\r\nAND SOOSC.ORGANIZATION_ID\r\n = EOOSC.ORGANIZATION_ID )\r\n\r\nUNION ALL\r\n\r\n/*OOD FUSN CODE*/\r\nSELECT SOFOSC.ORGANIZATION_ID, SOFOSC.ORGANIZATION_NAME, SOFOSC.COMPANY_CODE, SOFOSC.SET_OF_BOOKS_ID, SOFOSC.SET_OF_BOOKS_NAME, SOFOSC.CREATE_DATETIME, SOFOSC.CREATION_DATE, SOFOSC.LAST_UPDATE_DATE, \r\n'FUSN' AS IDENTIFIER\r\nFROM\r\n$$STGDB.ST_OOD_FUSN_ORG_SOB_COMPANY  SOFOSC\r\nWHERE NOT EXISTS (SEL 1 FROM $$ETLVWDB.EL_OOD_ORG_SOB_COMPANY EOOSC\r\nWHERE SOFOSC.COMPANY_CODE=\r\nEOOSC.COMPANY_CODE\r\nAND SOFOSC.SET_OF_BOOKS_ID\r\n= EOOSC.SET_OF_BOOKS_ID\r\nAND SOFOSC.ORGANIZATION_ID\r\n = EOOSC.ORGANIZATION_ID )",
