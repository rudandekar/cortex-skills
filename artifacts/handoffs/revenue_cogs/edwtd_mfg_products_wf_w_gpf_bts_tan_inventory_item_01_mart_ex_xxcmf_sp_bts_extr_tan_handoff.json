      ],
      "attributes": {
        "Sql Query": "SELECT NCIO.INVENTORY_ORGN_NAME_KEY AS INVENTORY_ORGN_NAME_KEY,\r\nNPTAN.ITEM_KEY AS TAN_ITEM_KEY,\r\nCOALESCE(STG.ON_HAND, 0)  AS ON_HAND_QTY,\r\nCOALESCE(STG.UNIT_COST, 0.0000000) AS UNIT_USD_COST,\r\nCOALESCE(STG.PUBLISH_DATE, DATE '3500-01-01') AS FORECAST_PUBLICATION_DT, \r\n'I' AS ACTION_CODE,\r\n CASE WHEN NGBTI.TAN_ITEM_KEY IS NULL THEN  'I'  ELSE 'U' END  AS  DML_TYPE \r\nFROM\r\n(SELECT * FROM \r\n$$STGDB.ST_XXCMF_SP_BTS_EXTR_TAN\r\nUNION ALL\r\nSELECT * FROM \r\n$$EXCEPDB.EX_XXCMF_SP_BTS_EXTR_TAN)\r\n STG\r\nINNER JOIN $$COMREFVWDB.N_CISCO_INVENTORY_ORG  NCIO ON\r\nSTG.TAN_ORGANIZATION_CODE=NCIO.INVENTORY_ORGANIZATION_CODE \r\n\r\nINNER JOIN  N_INVENTORY_ITEM NPTAN ON NPTAN.BK_PRODUCT_ID = STG.TAN_ID\r\nAND NPTAN.INVENTORY_ORGN_NAME_KEY =NCIO.INVENTORY_ORGN_NAME_KEY\r\n\r\nLEFT JOIN $$INVFLMTVWDB.N_GPF_BTS_TAN_INVENTORY_ITEM NGBTI  ON \r\nNCIO.INVENTORY_ORGN_NAME_KEY = NGBTI.INVENTORY_ORGN_NAME_KEY\r\nAND NPTAN.ITEM_KEY=NGBTI.TAN_ITEM_KEY",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
