      "attributes": {
        "Sql Query": "SELECT \r\nSTG.TAN_ID, \r\nSTG.TAN_ORGANIZATION_CODE, \r\nSTG.ON_HAND, \r\nSTG.UNIT_COST, \r\nSTG.PUBLISH_DATE, \r\nSTG.CREATION_DATE, \r\nSTG.CREATED_BY, \r\nSTG.BATCH_ID, \r\nSTG.CREATE_DATETIME,\r\n STG.ACTION_CODE \r\nFROM\r\n $$STGDB.ST_XXCMF_SP_BTS_EXTR_TAN STG\r\n\r\nLEFT JOIN $$COMREFVWDB.N_CISCO_INVENTORY_ORG  NCIO ON\r\nSTG.TAN_ORGANIZATION_CODE=NCIO.INVENTORY_ORGANIZATION_CODE\r\n\r\nLEFT JOIN  $$COMREFVWDB.N_INVENTORY_ITEM NPTAN ON NPTAN.BK_PRODUCT_ID = STG.TAN_ID\r\nAND NPTAN.INVENTORY_ORGN_NAME_KEY =NCIO.INVENTORY_ORGN_NAME_KEY\r\n \r\nWHERE  NPTAN.BK_PRODUCT_ID IS NULL\r\nOR NCIO.INVENTORY_ORGANIZATION_CODE IS NULL",
