      "attributes": {
        "Sql Query": "SELECT \r\nNP.ITEM_KEY AS GOODS_PRODUCT_KEY, \r\nNFW.FISCAL_WEEK_NUMBER_INT AS   BK_FISCAL_WEEK_NUM_INT, \r\nNFW.FISCAL_YEAR_NUMBER_INT AS BK_FISCAL_YEAR_NUM_INT, \r\nNFW.FISCAL_CALENDAR_CODE AS BK_FISCAL_CALENDAR_CD,\r\nCOALESCE(STG.PUBLISH_DATE,DATE '3500-01-01')  AS FORECAST_PUBLICATION_DT, \r\nCOALESCE(STG.TOTAL_USR_NREV,0)  AS TOTAL_USR_NONREVENUE_USD_AMT, \r\nCOALESCE(STG.TOTAL_USR_REV,0)            AS TOTAL_USR_REVENUE_USD_AMT, \r\n'I' AS ACTION_CODE,\r\n CASE WHEN NGUWF.GOODS_PRODUCT_KEY IS NULL THEN  'I'  ELSE 'U' END  AS  DML_TYPE \r\nFROM\r\n(SELECT * FROM \r\n$$STGDB.ST_XXCMF_DP_USR_WEEKLY\r\nUNION ALL\r\nSELECT * FROM \r\n$$EXCEPDB.EX_XXCMF_DP_USR_WEEKLY)\r\n STG\r\nINNER JOIN $$COMREFVWDB.N_PRODUCT  NP ON\r\nSTG.PID_CODE =NP.BK_PRODUCT_ID\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR NFW ON\r\nSTG.SDATE =NFW.CALENDAR_DATE\r\nLEFT JOIN $$INVFLMTVWDB.N_GP_USR_WEEKLY_FORECAST NGUWF ON \r\nNP.ITEM_KEY =NGUWF.GOODS_PRODUCT_KEY\r\nAND NFW.FISCAL_WEEK_NUMBER_INT=NGUWF.BK_FISCAL_WEEK_NUM_INT\r\nAND NFW.FISCAL_YEAR_NUMBER_INT=NGUWF.BK_FISCAL_YEAR_NUM_INT\r\nAND NFW.FISCAL_CALENDAR_CODE = NGUWF.BK_FISCAL_CALENDAR_CD",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
