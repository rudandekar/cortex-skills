      "attributes": {
        "Sql Query": "SELECT \r\n STG.PID_CODE AS PID_CODE , \r\n STG.CUSTOMER_CODE As CUSTOMER_CODE,\r\n  STG.THEATER_CODE AS THEATER_CODE, \r\n  STG.SDATE AS SDATE, \r\n  STG.USR_UNITS_BASELINE_REV AS USR_UNITS_BASELINE_REV, \r\n  STG.USR_EXCEPTIONS_REV AS USR_EXCEPTIONS_REV, \r\n  STG.TOTAL_USR_REV AS TOTAL_USR_REV,\r\n   STG.USR_UNITS_BASELINE_NREV AS USR_UNITS_BASELINE_NREV, \r\n   STG.USR_EXCEPTIONS_NREV AS USR_EXCEPTIONS_NREV,\r\n    STG.TOTAL_USR_NREV AS TOTAL_USR_NREV, \r\n    STG.PUBLISH_DATE AS PUBLISH_DATE, \r\n    STG.ETL_LOAD_DATE AS ETL_LOAD_DATE, \r\n    STG.ETL_SOURCE AS ETL_SOURCE, \r\n    STG.NAIVE_USR AS NAIVE_USR, \r\n    STG.BATCH_ID AS BATCH_ID,\r\n     STG.CREATE_DATETIME AS CREATE_DATETIME, \r\n     STG.ACTION_CODE AS ACTION_CODE\r\nFROM\r\n$$STGDB.ST_XXCMF_DP_USR_WEEKLY STG\r\nLEFT JOIN $$COMREFVWDB.N_PRODUCT  NP ON\r\nSTG.PID_CODE =NP.BK_PRODUCT_ID\r\nLEFT  JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR NFW ON\r\nSTG.SDATE =NFW.CALENDAR_DATE\r\nWHERE \r\nNP.BK_PRODUCT_ID IS NULL\r\n OR NFW.FISCAL_WEEK_START_DATE  IS NULL",
