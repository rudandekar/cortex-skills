      "attributes": {
        "Sql Query": "SELECT \r\nXXOPL_LINES.HEADER_ID,\r\nXXOPL_LINES.LINE_ID, \r\nXXOPL_LINES.ORDERED_ITEM,\r\nXXOPL_LINES.ITEM_CATEGORY,\r\nXXOPL_LINES.SUBSCRIPTION_REF_ID,\r\nXXOPL_LINES.SUBSCRIPTION_ID,\r\nXXOPL_LINES.CONTRACT_START_DATE,\r\nXXOPL_LINES.CONTRACT_END_DATE,\r\nXXOPL_LINES.LINE_REF_NUMBER,\r\nXXOPL_LINES.ACCOUNTING_RULE,\r\nXXOPL_LINES.ACCOUNTING_DURATION,\r\nXXOPL_LINES.SOURCE_COMMIT_TIME\r\n  FROM \r\n   (SEL * FROM $$NRTACCUMVWDB.CG1_XXOPL_ORDER_LINES_ALL  \r\n   QUALIFY ROW_NUMBER() OVER (PARTITION BY SUBSCRIPTION_REF_ID,SUBSCRIPTION_ID,ORDERED_ITEM ORDER BY REFRESH_DATETIME DESC)=1) XXOPL_LINES\r\n   INNER JOIN $$ETLVWDB.EL_XXOPL_ORDER_HEADERS_ALL EL\r\n   on XXOPL_LINES.HEADER_ID=EL.HEADER_ID\r\n   WHERE XXOPL_LINES.SOURCE_DML_TYPE IN ('SQL COMPUPDATE','INSERT')\r\n   AND XXOPL_LINES.SOURCE_COMMIT_TIME >CAST('$$LastExtractDate' AS TIMESTAMP(0))\r\n   AND (EL.INTENDED_USE is NULL OR  upper(EL.intended_use) <> 'NPI TEST')\r\n   AND  COALESCE(XXOPL_LINES.BOOKING_SOURCE,'OPL')<>'CG1'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
