      "attributes": {
        "Sql Query": "SELECT \r\nSR.FISCAL_YEAR_MONTH_INT\r\n,SR.SERVICE_REQUEST_TAC_COST_KEY\r\n,'EC_DIRECT_MAP_CONTRACT_1:1' AS END_CUST_ENRICHMENT_MTHOD_NAME\r\n, NULL AS BK_REPAIR_ORDER_NUM_INT\r\n,SR.SRC_RPTD_SR_NUMBER_INT \r\n,SR.SRC_RPTD_SERVICE_CONTARCT_NUM \r\n,SR.SRC_RPTD_CUST_NAME AS C3_CUSTOMER\r\n,COALESCE(WI_ENDCUST.DV_END_CUSTOMER_NAME,'UNKW') AS  DV_END_CUSTOMER_NAME\r\n,SUM(SR.TAC_BACKBONE_COST_USD_AMT     \r\n+SR.TAC_THTR_BIZ_OPRTN_CST_USD_AMT\r\n+SR.TAC_OUT_TASKING_COST_AMT\r\n+SR.TAC_OVERHEAD_COST_USD_AMT) SR_EXP\t\t\r\nFROM $$FINLGLVWDB.N_SR_TECH_ASSISTANCE_CNTR_COST SR \r\n INNER JOIN $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID CNTL\r\n ON CNTL.FISCAL_YEAR_MONTH_INT = SR.FISCAL_YEAR_MONTH_INT\r\n INNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM \r\n ON RFM.FISCAL_YEAR_MONTH_INT=CNTL.FISCAL_YEAR_MONTH_INT\t\r\n LEFT JOIN $$STGDB.WI_ENDCUST_REV_MAP WI_ENDCUST\r\nON WI_ENDCUST.SERVICE_CONTRACT=SR.SRC_RPTD_SERVICE_CONTARCT_NUM \r\nAND WI_ENDCUST.FISCAL_QUARTER_NAME=RFM.FISCAL_QUARTER_NAME\r\nAND WI_ENDCUST.FISCAL_YEAR_MONTH_INT = RFM.FISCAL_YEAR_MONTH_INT \r\nAND WI_ENDCUST.SLK_DIST_COUNT = 1\r\nGROUP BY 1,2,3,4,5,6,7,8",
        "User Defined Join": "",
        "Source Filter": "",
