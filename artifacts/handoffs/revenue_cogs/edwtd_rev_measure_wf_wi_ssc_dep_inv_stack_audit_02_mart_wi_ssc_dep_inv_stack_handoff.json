      ],
      "attributes": {
        "Sql Query": "SELECT mc.segment1 as PF ,$$FISCAL_MONTH_ID as FISCAL_MONTH_ID,\r\nsum(nvl(xfnbs.shipment_unit_std_cost,0) * xfnbd.matched_qty) as DEP_INV_COST\r\n,SUM(xfnbd.matched_qty) AS QUANTITY\r\nFROM APPS.rcv_transactions rt \r\n,APPS.mtl_material_transactions  mmt \r\n,APPS.po_lines_all pol \r\n,XXCTS_O.xxcts_fin_new_buy_shipments  xfnbs \r\n,APPS.mtl_system_items_b msi \r\n,APPS.mtl_item_categories mic \r\n,APPS.mtl_categories mc\r\n,XXCTS_O.xxcts_fin_new_buy_deliveries xfnbd \r\n,APPS.mtl_category_sets  mcs \r\nWHERE rt.transaction_date BETWEEN /*$$START_DATE and $$END_DATE */\r\nTO_DATE('$$START_DATE','MM/DD/YYYY HH24:MI:SS') AND TO_DATE('$$END_DATE','MM/DD/YYYY HH24:MI:SS')\r\nAND rt.transaction_type = 'DELIVER' \r\nAND rt.destination_type_code = 'INVENTORY' \r\nAND rt.transaction_id = mmt.rcv_transaction_id \r\nAND mmt.transaction_quantity> 0 \r\nAND mmt.source_code = 'RCV' \r\nAND rt.po_line_id = pol.po_line_id \r\nAND rt.transaction_id = xfnbd.transaction_id \r\nAND xfnbs.new_buy_shipment_id = xfnbd.new_buy_shipment_id \r\nAND pol.item_id = msi.inventory_item_id \r\nAND msi.organization_id = mmt.organization_id \r\nAND mc.category_id = mic.category_id \r\nAND mic.category_set_id = mcs.category_set_id (+) \r\nAND mcs.category_set_name = 'PROD GROUP'\r\nAND mic.inventory_item_id = msi.inventory_item_id \r\nAND mic.organization_id = msi.organization_id\r\nGROUP BY mc.segment1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
