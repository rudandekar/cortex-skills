      ],
      "attributes": {
        "Sql Query": "SELECT SRC.FISCAL_YEAR_QUARTER_NUMBER_INT,\r\nSRC.FISCAL_YEAR_MONTH_INT,\r\nABS(ROUND(SRC.REV_RPO_AMT+TGT.UNB_AMT)) AS REV_RPO_MISMATCH ,\r\n'RPO_QTR' AS AUDIT_TRXN_TYPE,\r\n'MT_RSTD_UNBILLED_DEFER_REV_RPO_QTR' AS AUDIT_TABLE,\r\n   Current_Date AS AUDIT_DATE\r\n   FROM \r\n( SELECT         \r\nRPO.FISCAL_YEAR_QUARTER_NUMBER_INT ,       \r\nRPO.FISCAL_YEAR_MONTH_INT ,\r\nSUM( DV_GROSS_UNB_CURR_QTR_AMT + DV_DEFERRED_REV_BAL_CURR_QTR_AMT + DV_NONREC_REV_BAL_CURR_QTR_AMT ) AS REV_RPO_AMT\r\nFROM $$FINLGLVWDB.MT_RSTD_UNBILLED_DEFER_REV_RPO_QTR RPO\r\nINNER JOIN  $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nON RFM.FISCAL_YEAR_MONTH_INT = RPO.FISCAL_YEAR_MONTH_INT\r\nAND RFM.FISCAL_YEAR_QUARTER_NUMBER_INT=RPO.FISCAL_YEAR_QUARTER_NUMBER_INT\r\nWHERE PREVIOUS_FSCL_MONTH_FLAG = 'Y'\r\nGROUP BY 1,2 ) SRC\r\nLEFT JOIN\r\n(\r\nSELECT INNER_QUERY.FISCAL_YEAR_QUARTER_NUMBER_INT,\r\nINNER_QUERY.FISCAL_YEAR_MONTH_INT,\r\nSUM(INNER_QUERY.UNB_AMT) AS UNB_AMT  FROM \r\n(SELECT\r\nRFM.FISCAL_YEAR_QUARTER_NUMBER_INT AS FISCAL_YEAR_QUARTER_NUMBER_INT,\r\nPROCESSED_FISCAL_MTH AS FISCAL_YEAR_MONTH_INT,\r\nCAST(SUM(UNBILLED_REVENUE_AMT) AS DECIMAL (26,7))*-1 AS UNB_AMT\r\nFROM $$FINLGLVWDB.MT_RSTD_UNBILLED_REVENUE UNB\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nON RFM.FISCAL_YEAR_MONTH_INT = UNB.PROCESSED_FISCAL_MTH\r\nWHERE PREVIOUS_FSCL_MONTH_FLAG = 'Y'\r\nGROUP BY 1,2\r\nUNION ALL\r\nSELECT \r\nRFM.FISCAL_YEAR_QUARTER_NUMBER_INT AS FISCAL_YEAR_QUARTER_NUMBER_INT,\r\n  DEF.FISCAL_YEAR_MONTH_INT AS  FISCAL_YEAR_MONTH_INT,\r\n  CAST(SUM(BALANCE_REV_USD_AMT ) AS DECIMAL(26,7))*-1 AS UNB_AMT\r\n  FROM \r\n  $$FINLGLVWDB.MT_RSTD_FIN_DEFERRED_REV_QTR DEF\r\n  INNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nON RFM.FISCAL_YEAR_MONTH_INT = DEF.FISCAL_YEAR_MONTH_INT\r\nWHERE PREVIOUS_FSCL_MONTH_FLAG = 'Y'\r\nGROUP BY 1,2)INNER_QUERY\r\nGROUP BY 1,2) TGT\r\nON SRC.FISCAL_YEAR_QUARTER_NUMBER_INT=TGT.FISCAL_YEAR_QUARTER_NUMBER_INT\r\nAND SRC.FISCAL_YEAR_MONTH_INT=TGT.FISCAL_YEAR_MONTH_INT",
        "User Defined Join": "",
