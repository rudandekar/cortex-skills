      "attributes": {
        "Sql Query": "SELECT\r\nNICRA.BK_AUDIT_NAME AS BK_AUDIT_NAME,\r\nST.RULE_ID AS BK_RULE_ID_INT,\r\nCOALESCE(ST.COMMIT_STATUS,'=') AS COMMIT_STATUS_FLG,\r\nST.RULE_COMMENT AS RULE_CMT,\r\nST.RULE_RANK AS RULE_RANK_INT,\r\nST.PID_COUNT AS PRODUCT_CNT,\r\nCOALESCE(ST.CREATION_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))) AS SRC_CREATED_DTM,\r\nCOALESCE(ST.LAST_UPDATE_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))) AS SRC_UPDATED_DTM,\r\nCOALESCE(NCWP1.CISCO_WORKER_PARTY_KEY, -999) AS SRC_CRTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE(NCWP2.CISCO_WORKER_PARTY_KEY, -999) AS SRC_UPDT_BY_CSCO_WRKR_PRTY_KEY,\r\nST.POOL_TARGET_FLAG AS POOL_TARGET_CD,\r\nCOALESCE(NCIS.CUSTOMS_ITEM_SPECIFIC_KEY,-999) AS CUSTOMS_ITEM_SPECIFIC_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nST.ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM \r\n$$STGDB.ST_XXCFI_CB_AUDT_POOL_RULE_RES ST\r\nINNER JOIN $$FINLGLVWDB.N_ITEM_CLSFTN_RULE_AUDIT NICRA\r\nON ST.AUDIT_QUERY_ID=NICRA.SK_AUDIT_QUERY_ID\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP1\r\nON COALESCE(ST.CREATED_BY,'UNKNOWN')=NCWP1.CEC_ID\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP2\r\nON COALESCE(ST.LAST_UPDATED_BY,'UNKNOWN')=NCWP2.CEC_ID\r\nLEFT OUTER JOIN $$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC NCIS \r\nON ST.SPECIFIC_ID = NCIS.SK_SPECIFIC_ID_INT\r\nWHERE ST.AUDIT_QUERY_ID IS NOT NULL\r\nAND ST.RULE_ID IS NOT NULL\r\nQUALIFY  ROW_NUMBER() OVER(PARTITION BY ST.AUDIT_QUERY_ID,ST.RULE_ID ORDER  BY ST.LAST_UPDATE_DATE DESC)=1\r\nUNION\r\nSELECT\r\nNICRA.BK_AUDIT_NAME AS BK_AUDIT_NAME,\r\nEX.RULE_ID AS BK_RULE_ID_INT,\r\nEX.COMMIT_STATUS AS COMMIT_STATUS_FLG,\r\nEX.RULE_COMMENT AS RULE_CMT,\r\nEX.RULE_RANK AS RULE_RANK_INT,\r\nEX.PID_COUNT AS PRODUCT_CNT,\r\nCOALESCE(EX.CREATION_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))) AS SRC_CREATED_DTM,\r\nCOALESCE(EX.LAST_UPDATE_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))) AS SRC_UPDATED_DTM,\r\nCOALESCE(NCWP1.CISCO_WORKER_PARTY_KEY, -999) AS SRC_CRTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE(NCWP2.CISCO_WORKER_PARTY_KEY, -999) AS SRC_UPDT_BY_CSCO_WRKR_PRTY_KEY,\r\nEX.POOL_TARGET_FLAG AS POOL_TARGET_CD,\r\nCOALESCE(NCIS.CUSTOMS_ITEM_SPECIFIC_KEY ,-999) AS CUSTOMS_ITEM_SPECIFIC_KEY ,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nEX.ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM \r\n$$EXCEPDB.EX_XXCFI_CB_AUDT_POOL_RULE_RES EX\r\nINNER JOIN $$FINLGLVWDB.N_ITEM_CLSFTN_RULE_AUDIT NICRA\r\nON EX.AUDIT_QUERY_ID=NICRA.SK_AUDIT_QUERY_ID\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP1\r\nON COALESCE(EX.CREATED_BY,'UNKNOWN')=NCWP1.CEC_ID\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP2\r\nON COALESCE(EX.LAST_UPDATED_BY,'UNKNOWN')=NCWP2.CEC_ID\r\nLEFT OUTER JOIN $$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC NCIS \r\nON EX.SPECIFIC_ID=NCIS.SK_SPECIFIC_ID_INT\r\nWHERE EX.AUDIT_QUERY_ID IS NOT NULL\r\nAND EX.RULE_ID IS NOT NULL\r\nQUALIFY  ROW_NUMBER() OVER(PARTITION BY EX.AUDIT_QUERY_ID,EX.RULE_ID ORDER  BY EX.LAST_UPDATE_DATE DESC)=1",
