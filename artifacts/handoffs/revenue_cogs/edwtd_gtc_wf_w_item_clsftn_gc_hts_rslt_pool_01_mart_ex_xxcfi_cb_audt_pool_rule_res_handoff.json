      "attributes": {
        "Sql Query": "SELECT\r\nAUDIT_RESULT_ID ,\r\nAUDIT_QUERY_ID ,\r\nRULE_ID ,\r\nSPECIFIC_NAME ,\r\nPID_COUNT ,\r\nRULE_COMMENT,\r\nCOMMIT_STATUS,\r\nRULE_RANK ,\r\nPOOL_TARGET_FLAG,\r\nAUDIT_MONTH,\r\nCREATED_BY,\r\nCREATION_DATE ,\r\nLAST_UPDATED_BY,\r\nLAST_UPDATE_DATE ,\r\nSPECIFIC_ID ,\r\nCREATE_DATETIME ,\r\nACTION_CODE,\r\n'RI' AS EXCEPTION_TYPE\r\nFROM \r\n$$STGDB.ST_XXCFI_CB_AUDT_POOL_RULE_RES ST\r\nWHERE NOT EXISTS (SELECT 1 FROM $$FINLGLVWDB.N_ITEM_CLSFTN_RULE_AUDIT NICRA\r\nINNER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP1\r\nON COALESCE(ST.CREATED_BY,'UNKNOWN')=NCWP1.CEC_ID\r\nINNER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP2\r\nON COALESCE(ST.LAST_UPDATED_BY,'UNKNOWN')=NCWP2.CEC_ID\r\nINNER JOIN $$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC NCIS \r\nON COALESCE(ST.SPECIFIC_ID,-999)=NCIS.SK_SPECIFIC_ID_INT\r\nWHERE  ST.AUDIT_QUERY_ID=NICRA.SK_AUDIT_QUERY_ID)",
