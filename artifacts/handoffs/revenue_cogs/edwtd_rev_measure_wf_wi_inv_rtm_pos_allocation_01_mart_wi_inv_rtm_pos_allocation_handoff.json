      "attributes": {
        "Sql Query": "SELECT \r\n  ACTL.REVENUE_MEASURE_KEY,\r\n  ACTL.DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\n  ACTL.REV_MEASURE_TRANS_TYPE_CD,\r\n  SUM(ZEROIFNULL(ACTL.DV_COMP_US_NET_REV_AMT))\r\n  FROM \r\n  $$FINLGLVWDB.N_INV_REV_MEASURE ACTL\r\n  INNER JOIN $$STGDB.WI_GL_CHANNEL_REV_MONTH_CNTL CNTL\r\n  ON ACTL.DV_FISCAL_YEAR_MTH_NUMBER_INT =CNTL.FISCAL_YEAR_MONTH_INT\r\n \r\n  /*AND ACTL.REV_MEASURE_TRANS_TYPE_CD = CNTL.REV_MEASURE_TRANS_TYPE_CD */\r\n  INNER JOIN $$FINLGLVWDB.MT_DIRECT_INDIRECT_ADJ_TYPE ADJ\r\n  ON ACTL.DD_BK_DIRECT_CORP_ADJ_TYPE_CD =ADJ.BK_DIRECT_CORP_ADJ_TYPE_CD      \r\n  AND ACTL.BK_ADJUSTMENT_TYPE_CD         =ADJ.BK_ADJUSTMENT_TYPE_CD          \r\n  AND ACTL.BK_REVENUE_OR_COGS_TYPE_CD    =ADJ.BK_REVENUE_OR_COGS_TYPE_CD      \r\n  WHERE \r\n  ACTL.DV_CORPORATE_REVENUE_FLG  =  'Y' \r\n  AND ACTL.DV_SERVICE_FLG   =  'N'  \r\n  AND ADJ.L3_HIERARCHY_NODE_TYPE_ID = 'POS ALLOCATION' \r\n  AND ACTL.DV_2T_DISTI_REVENUE_FLG =  'N'  \r\n  GROUP BY 1,2,3",
