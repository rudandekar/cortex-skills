      "attributes": {
        "Sql Query": "SELECT\r\nNFM.BK_FISCAL_CALENDAR_CODE,         \r\nNFM.BK_FISCAL_YEAR_NUMBER_INT        ,\r\nNFM.BK_FISCAL_MONTH_NUMBER_INT       ,\r\nAE.SALES_TERRITORY_KEY      ,     \r\nNP.ITEM_KEY PRODUCT_KEY   ,                \r\nAE.MEASURE_NAME BK_ADJUSTMENT_MEASURE_TYPE_CD ,\r\nAE.SUB_MEASURE_NAME BK_ADJ_SUB_MEASURE_TYPE_CD    ,\r\nAE.DATA_TYPE BK_ADJUSTMENT_TYPE_CD   ,      \r\nAE.COMPANY_NAME    ,\r\nAE.COUNTRY_NAME          BK_RPRTD_ADJSTMNT_CNTRY_NAME     ,\r\nAE.SALES_SUBCOVERAGE_CODE ADJSTMNT_SALES_SUBCOVERAGE_CD ,\r\nSUM(AE.AMOUNT) ADJUSTMENT_ALLOCATION_USD_AMT ,\r\n(NFM.BK_FISCAL_YEAR_NUMBER_INT*100+NFM.BK_FISCAL_MONTH_NUMBER_INT ) DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM                ,\r\nUSER EDW_CREATE_USER               ,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM                ,\r\nUSER EDW_UPDATE_USER               ,\r\n'I' ACTION_CODE                   ,\r\n'I' DML_TYPE    ,\r\nAE.DEAL_ID BK_DEAL_ID\r\nFROM $$STGDB.ST_PRODUCT_MANUAL_ADJ AE\r\nINNER JOIN $$COMREFVWDB.N_FISCAL_MONTH NFM   \r\nON (NFM.BK_FISCAL_YEAR_NUMBER_INT*100+NFM.BK_FISCAL_MONTH_NUMBER_INT )=AE.FISCAL_MONTH_ID\r\nINNER JOIN $$COMREFVWDB.N_PRODUCT NP\r\nON NP.BK_PRODUCT_ID=AE.PRODUCT_ID\r\nINNER JOIN $$COMREFVWDB.N_SALES_TERRITORY NST\r\nON NST.SALES_TERRITORY_KEY=(CASE WHEN AE.SALES_TERRITORY_KEY <0 THEN -999 ELSE AE.SALES_TERRITORY_KEY END)\r\nGROUP BY\r\nNFM.BK_FISCAL_CALENDAR_CODE,         \r\nNFM.BK_FISCAL_YEAR_NUMBER_INT        ,\r\nNFM.BK_FISCAL_MONTH_NUMBER_INT       ,\r\nAE.SALES_TERRITORY_KEY      ,     \r\nNP.ITEM_KEY    ,                \r\nAE.MEASURE_NAME  ,\r\nAE.SUB_MEASURE_NAME     ,\r\nAE.DATA_TYPE    ,      \r\nAE.COMPANY_NAME    ,\r\nAE.COUNTRY_NAME                 ,\r\nAE.SALES_SUBCOVERAGE_CODE  ,\r\nAE.DEAL_ID,\r\n(NFM.BK_FISCAL_YEAR_NUMBER_INT*100+NFM.BK_FISCAL_MONTH_NUMBER_INT )",
        "User Defined Join": "",
        "Source Filter": "",
