      "attributes": {
        "Sql Query": "SELECT\r\nST.ADJUSTMENT_LINE_ID\r\n,ST.GLOBAL_NAME\r\n,ST.ADJUSTMENT_ACCOUNTING_ID\r\n,ST.ADJUSTMENT_ID\r\n,ST.BATCH_SOURCE\r\n,ST.CODE_COMBINATION_ID\r\n,ST.COGS_DEFERRAL_FLAG\r\n,ST.COGS_REV_GL_DATE\r\n,ST.COGS_REV_POSTED_DATE\r\n,ST.CURRENCY_CODE\r\n,ST.CUSTOMER_TRX_LINE_ID\r\n,ST.DIST_BAL_TYPE\r\n,ST.DISTRIBUTION_TYPE\r\n,ST.AMOUNT as DV_AMOUNT\r\n,COALESCE(CASE WHEN ST.DIST_BAL_TYPE = 'C' THEN -1 * ABS(ST.PERCENT_ADJ) WHEN ST.DIST_BAL_TYPE = 'D' THEN ABS(ST.PERCENT_ADJ) END,0) as DV_PERCENT\r\n,ST.EVENT_ID\r\n,ST.GL_DATE\r\n,ST.GL_POSTED_DATE\r\n,ST.GL_POSTED_FLAG\r\n,ST.LEDGER_ID\r\n,ST.LINE_ID\r\n,CASE WHEN SOURCE_DATA_KEY5 IN ('NRS SSPTP Transition Release', 'NRS_MPOB_TRANS') THEN 'Y' ELSE 'N' END as NRS_TRANSITION_FLG\r\n,ST.OA_SKU_TYPE\r\n,ST.ORG_ID\r\n,ST.ROL_TRANSACTION_ID\r\n,ST.SOURCE_BATCH_NAME\r\n,ST.SOURCE_DATA_KEY5\r\n,COALESCE(ST.MERAKI_FLAG,'N') AS MERAKI_FLAG\r\n,CURRENT_TIMESTAMP(0) as EDW_CREATE_DTM\r\n,CURRENT_TIMESTAMP(0) as EDW_UPDATE_DTM\r\nFROM $$STGDB.ST_NGCCRM_RAE_ADJ_LINE_DTLS ST\r\nINNER JOIN $$ETLVWDB.EL_AR_LEDGER GL\r\n  ON ST.LEDGER_ID = GL.LEDGER_ID\r\nINNER JOIN $$ETLVWDB.EL_FND_APPLICATION_AR  EFAA\r\n  ON ST.APPLICATION_ID = EFAA.APPLICATION_ID \r\n  AND UPPER(EFAA.APPLICATION_NAME) = 'REVENUE ACCOUNTING ENGINE'\r\nWHERE  EVENT_TYPE ='TBA_DEFERRAL' \r\n  AND ACCOUNT_CLASS IN  ('COST_OF_GOODS_SOLD','DEFERRED_COGS')\r\n AND ST.GL_POSTED_DATE IS NOT NULL\r\n AND COALESCE(ST.GL_POSTED_FLAG, 'N') = 'Y' \r\nAND NOT EXISTS (SELECT 1 FROM $$ETLVWDB.EL_RAO_XXCFI_RAE_COGS_PERCNT ERXRCP\r\nWHERE \r\nST.ADJUSTMENT_LINE_ID = ERXRCP.ADJUSTMENT_LINE_ID\r\nAND\r\nST.GLOBAL_NAME = ERXRCP.GLOBAL_NAME\r\n)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
