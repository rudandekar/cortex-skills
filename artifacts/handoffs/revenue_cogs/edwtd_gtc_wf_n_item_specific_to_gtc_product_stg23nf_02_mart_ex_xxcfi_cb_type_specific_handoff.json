      "attributes": {
        "Sql Query": "SELECT\r\nBK_PRODUCT_TYPE_ID            ,\r\nSS_CD                         ,\r\nDEACTIVATED_ROLE              ,\r\nRU_DEACTIVATED_DT             ,\r\nRU_DCTVTD_CISCO_WRKR_PARTY_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER \t\t\t\t AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER \t\t\t\t AS EDW_UPDATE_USER,\r\nCUSTOMS_ITEM_SPECIFIC_KEY\r\nFROM $$FINLGLVWDB.N_ITEM_SPECIFIC_PRDT_TYPE_LINK NISPTL\r\nWHERE NOT EXISTS\r\n(\r\nSELECT 1\r\n  FROM $$FINLGLVWDB.N_ITEM_SPECIFIC_TO_GTC_PRODUCT NISTGP\r\n WHERE NISTGP.CUSTOMS_ITEM_SPECIFIC_KEY = NISPTL.CUSTOMS_ITEM_SPECIFIC_KEY\r\n   AND NISTGP.BK_GTC_PRODUCT_TYPE_CD = NISPTL.BK_PRODUCT_TYPE_ID\r\n   AND NISTGP.BK_SS_CD = 'CISCO'\r\n)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
