        }
      ],
      "attributes": {
        "Sql Query": "SELECT\r\nCOALESCE(PRODUCT_TYPE_CLASS_CODE,'UNKNOWN') AS BK_GTC_PRODUCT_TYPE_CD,\r\nCOALESCE(SOURCE1,'UNKNOWN') AS SS_CD, \r\n(CASE WHEN DEACTIVATED_BY IS NULL THEN 'N' ELSE 'Y' END) AS DEACTIVATED_ROLE,\r\nCOALESCE(DEACTIVATED_DATE,DATE '3500-01-01') AS RU_DEACTIVATED_DT,\r\nNCWPCCU.CISCO_WORKER_PARTY_KEY  AS RU_DACTVTD_CISCO_WRKR_PRTY_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER                 AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER                 AS EDW_UPDATE_USER,\r\nCOALESCE(CUSTOMS_ITEM_SPECIFIC_KEY, -999) AS CUSTOMS_ITEM_SPECIFIC_KEY\r\nFROM \r\n(\r\nSELECT  BATCH_ID,CLASSIFICATION_ATTRIBUTES_ID,PRODUCT_TYPE_CLASS_CODE,PRODUCT_FLAG, DESCRIPTION,SPECIFIC1,COMMENTS, ATTRIBUTE1,\r\nATTRIBUTE2,ATTRIBUTE3,DEACTIVATED_BY,DEACTIVATED_DATE,CREATED_BY,CREATED_DATE,MODIFIED_BY,MODIFIED_DATE,SOURCE1,\r\nCREATE_DATETIME,ACTION_CODE , SPECIFIC_ID                   \r\nFROM   $$STGDB.ST_XXCFI_CB_TYPE_SPECIFIC SXCTS1\r\nWHERE SXCTS1.PRODUCT_FLAG = 'P'\r\n    AND SXCTS1.SOURCE1 <> 'CISCO'\r\n\r\nUNION ALL\r\n\r\nSELECT BATCH_ID,CLASSIFICATION_ATTRIBUTES_ID,PRODUCT_TYPE_CLASS_CODE,PRODUCT_FLAG, DESCRIPTION,SPECIFIC1,COMMENTS, ATTRIBUTE1,ATTRIBUTE2,\r\nATTRIBUTE3,DEACTIVATED_BY,DEACTIVATED_DATE,CREATED_BY,CREATED_DATE,MODIFIED_BY,MODIFIED_DATE,SOURCE1,\r\nCREATE_DATETIME,ACTION_CODE,SPECIFIC_ID                  \r\nFROM  $$EXCEPDB.EX_XXCFI_CB_TYPE_SPECIFIC EXCTS\r\nWHERE EXCTS.PRODUCT_FLAG = 'P'\r\n    AND EXCTS.SOURCE1 <> 'CISCO'\r\n    AND EXCTS.EXCEPTION_TYPE = 'RI'\r\n) SXCTS   \r\n\r\nINNER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWPTV\r\n       ON ( COALESCE(SXCTS.DEACTIVATED_BY,'UNKNOWN')  = NCWPTV.CEC_ID)\r\nINNER JOIN $$FINLGLVWDB.N_CSC_WRKR_PRTY_CSTMS_CUBE_USR NCWPCCU\r\n       ON (NCWPCCU.CISCO_WORKER_PARTY_KEY = NCWPTV.CISCO_WORKER_PARTY_KEY)\r\n\t   INNER JOIN $$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC NCIC\r\n\t   ON NCIC.SK_SPECIFIC_ID_INT = SXCTS.SPECIFIC_ID\r\nWHERE CUSTOMS_ITEM_SPECIFIC_KEY IN (SELECT CUSTOMS_ITEM_SPECIFIC_KEY FROM $$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC)\r\nAND NOT EXISTS\r\n(\r\nSELECT 1 \r\nFROM    $$FINLGLVWDB.N_ITEM_SPECIFIC_TO_GTC_PRODUCT \r\nWHERE CUSTOMS_ITEM_SPECIFIC_KEY =  NCIC.CUSTOMS_ITEM_SPECIFIC_KEY\r\nAND  COALESCE(SXCTS.PRODUCT_TYPE_CLASS_CODE,'UNKNOWN') =   BK_GTC_PRODUCT_TYPE_CD  )",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
