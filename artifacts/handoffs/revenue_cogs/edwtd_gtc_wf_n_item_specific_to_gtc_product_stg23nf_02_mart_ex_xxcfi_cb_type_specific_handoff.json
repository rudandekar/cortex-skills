        "Sql Query": "SELECT  BATCH_ID,CLASSIFICATION_ATTRIBUTES_ID,PRODUCT_TYPE_CLASS_CODE,PRODUCT_FLAG,DESCRIPTION,SPECIFIC1,COMMENTS,ATTRIBUTE1,ATTRIBUTE2,ATTRIBUTE3,\r\nDEACTIVATED_BY,DEACTIVATED_DATE,CREATED_BY,CREATED_DATE,MODIFIED_BY,MODIFIED_DATE,SOURCE1,CREATE_DATETIME,ACTION_CODE,'RI' EXCEPTION_TYPE ,SPECIFIC_ID            \r\nFROM $$STGDB.ST_XXCFI_CB_TYPE_SPECIFIC SXCTS \r\nWHERE PRODUCT_FLAG = 'P' \r\nAND\r\n(\r\nNOT EXISTS\r\n   ( SELECT 1  \r\n     FROM $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWPTV \r\n      \r\n     INNER JOIN $$FINLGLVWDB.N_CSC_WRKR_PRTY_CSTMS_CUBE_USR NCWPCCU \r\n            ON (NCWPCCU.CISCO_WORKER_PARTY_KEY = NCWPTV.CISCO_WORKER_PARTY_KEY)\r\n\r\n     INNER JOIN $$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC NCIS  \r\n            ON (NCIS.SK_SPECIFIC_ID_INT = SXCTS.SPECIFIC_ID )\r\n\t\t\t\r\n WHERE ( COALESCE(SXCTS.DEACTIVATED_BY,'UNKNOWN')  = CEC_ID)\r\n   )\r\nAND SXCTS.SOURCE1 <> 'CISCO'\r\n)",
