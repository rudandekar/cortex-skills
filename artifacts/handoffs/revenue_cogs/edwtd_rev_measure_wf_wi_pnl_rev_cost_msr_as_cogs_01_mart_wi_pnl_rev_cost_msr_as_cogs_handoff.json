      "attributes": {
        "Sql Query": "SELECT  \r\nGL.DV_FISCAL_YEAR_MTH_NUMBER_INT  BK_FISCAL_YEAR_MTH_NUMBER_INT,\r\nCAST ( GL.BK_REVENUE_OR_COGS_TYPE_CD AS CHAR(7))  BK_REVENUE_OR_COGS_TYPE_CD ,   \r\n/*5970786 AS SUBSCRIPTION_ADJ_PROD  BK_PRODUCT_KEY,\r\n5970786 AS SUBSCRIPTION_ADJ_PROD GOODS_PRODUCT_KEY,*/---CMS CHNAGES\r\nCASE WHEN RPT.BK_PNL_MEASURE_NAME ='Cloud and Managed Services' THEN 11969520 ELSE 5970786 END BK_PRODUCT_KEY,\r\nCASE WHEN RPT.BK_PNL_MEASURE_NAME ='Cloud and Managed Services' THEN 11969520  ELSE 5970786 END GOODS_PRODUCT_KEY, \r\nCAST(GL.BK_FINANCIAL_ACCOUNT_CD AS CHAR(5)) BK_FINANCIAL_ACCOUNT_CD  ,\r\n'UNKNOWN'BK_REV_MEASURE_TRNSCTN_TYPE_CD,\r\n-999 DV_TRIANGULATION_TYPE_ID_INT,\r\n'UNKNOWN'BK_PRDT_SUBGROUP_ALLOC_SRC_CD,\r\nGL.BK_SALES_TERRITORY_KEY  BK_SALES_TERRITORY_KEY    ,       \r\nBK_SALES_TERRITORY_KEY BK_TRNGLTD_SALES_TERRITORY_KEY,\r\n-9999 SALES_ORDER_LINE_KEY,\r\n'UNKNOWN' BK_SRC_RPRTD_SRVC_CONTRACT_NUM\t,\r\nSUM(ADVANCED_SERVICES_COGS_USD_AMT) *(-1) AS COMP_US_NET_REV_AMT1,\t\r\n'UNK'BK_COMPANY_CD,\r\n'UNK' BK_ISO_COUNTRY_CD,\r\n'SERVICE' DV_PRODUCT_TYPE,\r\nCAST(CASE WHEN RPT.BK_PNL_MEASURE_NAME ='CENTRALIZED COGS' THEN 'AS Centralized Indirect' ELSE UPPER(RPT.BK_PNL_MEASURE_NAME) END AS VARCHAR(100)) DV_PNL_LINE_ITEM_NAME ,\r\nCAST (TRIM(COALESCE(GOODS_PRODUCT_KEY  ,-999)) || '~' || TRIM(COALESCE(GOODS_PRODUCT_KEY  ,-999)) || '~' ||-9999|| '~' ||-9999 AS VARCHAR(70))  DV_RECURRING_OFFER_CD\r\nFROM\r\n$$FINLGLVWDB.N_ADV_SRVCS_COGS_ALLOCATION   GL\r\nINNER JOIN $$FINLGLVWDB.N_APSP_PNL_ASCOGS_DPT_ACCT_MPG RPT   ON \r\nGL.BK_COMPANY_CD||GL.BK_DEPARTMENT_CD = RPT.BK_COMPANY_CODE||RPT.BK_DEPARTMENT_CD\r\nINNER JOIN $$STGDB.WI_PNL_MTH_CNTL_AS_COGS FY ON \r\nGL.DV_FISCAL_YEAR_MTH_NUMBER_INT=FY.FISCAL_YEAR_MONTH_INT\r\nWHERE GL.ALLOCATION_METHOD_NAME = RPT.ALLOCATION_METHOD_NAME\r\nAND GL.BK_FINANCIAL_ACCOUNT_CD =  RPT.BK_FINANCIAL_ACCOUNT_CD\r\nAND GL.DV_FISCAL_YEAR_MTH_NUMBER_INT = RPT.BK_FISCAL_YEAR_MONTH_NUM_INT\r\nAND RPT.FINANCIAL_ACCT_REPORTING_FLG = 'Y'\r\nAND FY.INC_FLAG ='Y'\r\nAND GL.BK_ADJUSTMENT_TYPE_CD ='AS COGS AE SYSTEM ALLOCATION'\r\nAND GL.BK_REVENUE_OR_COGS_TYPE_CD = 'COGS'\r\nGROUP BY 1,2,3,4,5,9,10,17,DV_RECURRING_OFFER_CD\r\n\r\nUNION ALL\r\n \r\nSELECT  \r\nGL.DV_FISCAL_YEAR_MTH_NUMBER_INT  BK_FISCAL_YEAR_MTH_NUMBER_INT,\r\nGL.BK_REVENUE_OR_COGS_TYPE_CD  BK_REVENUE_OR_COGS_TYPE_CD ,   \r\n/*5970786 AS SUBSCRIPTION_ADJ_PROD  BK_PRODUCT_KEY,\r\n5970786 AS SUBSCRIPTION_ADJ_PROD GOODS_PRODUCT_KEY,*/ -- CMS CHANGES\r\n CASE WHEN RPT.BK_PNL_MEASURE_NAME ='Cloud and Managed Services' THEN 11969520 ELSE 5970786 END BK_PRODUCT_KEY,\r\n CASE WHEN RPT.BK_PNL_MEASURE_NAME ='Cloud and Managed Services' THEN 11969520 ELSE 5970786 END GOODS_PRODUCT_KEY,\r\nGL.BK_FINANCIAL_ACCOUNT_CD  BK_FINANCIAL_ACCOUNT_CD  ,\r\n'UNKNOWN'BK_REV_MEASURE_TRNSCTN_TYPE_CD,\r\n-999 DV_TRIANGULATION_TYPE_ID_INT,\r\n'UNKNOWN'BK_PRDT_SUBGROUP_ALLOC_SRC_CD,\r\nGL.BK_SALES_TERRITORY_KEY  BK_SALES_TERRITORY_KEY    ,       \r\nBK_SALES_TERRITORY_KEY BK_TRNGLTD_SALES_TERRITORY_KEY,\r\n-9999 SALES_ORDER_LINE_KEY,\r\n'UNKNOWN' BK_SRC_RPRTD_SRVC_CONTRACT_NUM\t,\r\nSUM(ADVANCED_SERVICES_COGS_USD_AMT)*(-1) AS COMP_US_NET_REV_AMT1,\t\r\n'UNK'BK_COMPANY_CD,\r\n'UNK' BK_ISO_COUNTRY_CD,\r\n'SERVICE' DV_PRODUCT_TYPE,\r\nCASE WHEN RPT.BK_PNL_MEASURE_NAME ='CENTRALIZED COGS' THEN 'AS Centralized Indirect' ELSE UPPER(RPT.BK_PNL_MEASURE_NAME) END AS DV_PNL_LINE_ITEM_NAME ,\r\nCAST (TRIM(COALESCE(GOODS_PRODUCT_KEY  ,-999)) || '~' || TRIM(COALESCE(GOODS_PRODUCT_KEY  ,-999)) || '~' ||-9999|| '~' ||-9999 AS VARCHAR(70))  DV_RECURRING_OFFER_CD\r\nFROM\r\n$$FINLGLVWDB.N_ADV_SRVCS_COGS_ALLOCATION   GL\r\nINNER JOIN $$FINLGLVWDB.N_APSP_PNL_ASCOGS_DPT_ACCT_MPG RPT   ON \r\nGL.BK_COMPANY_CD||GL.BK_DEPARTMENT_CD = RPT.BK_COMPANY_CODE||RPT.BK_DEPARTMENT_CD\r\nINNER JOIN $$STGDB.WI_PNL_MTH_CNTL_AS_COGS FY ON \r\nGL.DV_FISCAL_YEAR_MTH_NUMBER_INT=FY.FISCAL_YEAR_MONTH_INT\r\nWHERE GL.ALLOCATION_METHOD_NAME = RPT.ALLOCATION_METHOD_NAME\r\nAND GL.BK_FINANCIAL_ACCOUNT_CD <>  RPT.BK_FINANCIAL_ACCOUNT_CD\r\nAND GL.DV_FISCAL_YEAR_MTH_NUMBER_INT = RPT.BK_FISCAL_YEAR_MONTH_NUM_INT\r\nAND RPT.FINANCIAL_ACCT_REPORTING_FLG = 'N'\r\nAND FY.INC_FLAG ='Y'\r\nAND GL.BK_ADJUSTMENT_TYPE_CD ='AS COGS AE SYSTEM ALLOCATION'\r\nAND GL.BK_REVENUE_OR_COGS_TYPE_CD = 'COGS'\r\nGROUP BY 1,2,3,4,5,9,10,17,DV_RECURRING_OFFER_CD\r\n  \r\nUNION ALL \r\n\r\nSELECT  \r\nGL.DV_FISCAL_YEAR_MTH_NUMBER_INT  BK_FISCAL_YEAR_MTH_NUMBER_INT,\r\nGL.BK_REVENUE_OR_COGS_TYPE_CD  BK_REVENUE_OR_COGS_TYPE_CD ,   \r\n/*5970786 /*AS SUBSCRIPTION_ADJ_PROD BK_PRODUCT_KEY,\r\n5970786 /*AS SUBSCRIPTION_ADJ_PROD GOODS_PRODUCT_KEY,*/-- CMS change\r\n  CASE WHEN RPT.BK_PNL_MEASURE_NAME ='Cloud and Managed Services' THEN 11969520 ELSE 5970786 END BK_PRODUCT_KEY,\r\n CASE WHEN RPT.BK_PNL_MEASURE_NAME ='Cloud and Managed Services' THEN 11969520  ELSE 5970786 END GOODS_PRODUCT_KEY,\r\nGL.BK_FINANCIAL_ACCOUNT_CD  BK_FINANCIAL_ACCOUNT_CD  ,\r\n'UNKNOWN'BK_REV_MEASURE_TRNSCTN_TYPE_CD,\r\n-999 DV_TRIANGULATION_TYPE_ID_INT,\r\n'UNKNOWN'BK_PRDT_SUBGROUP_ALLOC_SRC_CD,\r\nGL.BK_SALES_TERRITORY_KEY  BK_SALES_TERRITORY_KEY    ,       \r\nBK_SALES_TERRITORY_KEY BK_TRNGLTD_SALES_TERRITORY_KEY,\r\n-9999 SALES_ORDER_LINE_KEY,\r\n'UNKNOWN' BK_SRC_RPRTD_SRVC_CONTRACT_NUM\t,\r\nSUM(ADVANCED_SERVICES_COGS_USD_AMT) *(-1) AS COMP_US_NET_REV_AMT1,\t\r\n'UNK'BK_COMPANY_CD,\r\n'UNK' BK_ISO_COUNTRY_CD,\r\n'SERVICE' DV_PRODUCT_TYPE,\r\nCASE WHEN RPT.BK_PNL_MEASURE_NAME ='CENTRALIZED COGS' THEN 'AS Centralized Indirect' ELSE UPPER(RPT.BK_PNL_MEASURE_NAME) END AS DV_PNL_LINE_ITEM_NAME ,\r\nCAST (TRIM(COALESCE(GOODS_PRODUCT_KEY  ,-999)) || '~' || TRIM(COALESCE(GOODS_PRODUCT_KEY  ,-999)) || '~' ||-9999|| '~' ||-9999 AS VARCHAR(70))  DV_RECURRING_OFFER_CD\r\nFROM\r\n$$FINLGLVWDB.N_ADV_SRVCS_COGS_ALLOCATION   GL\r\nINNER JOIN $$FINLGLVWDB.N_APSP_PNL_ASCOGS_DPT_ACCT_MPG RPT   ON \r\nGL.BK_COMPANY_CD||GL.BK_DEPARTMENT_CD = RPT.BK_COMPANY_CODE||RPT.BK_DEPARTMENT_CD\r\nINNER JOIN $$STGDB.WI_PNL_MTH_CNTL_AS_COGS FY ON \r\nGL.DV_FISCAL_YEAR_MTH_NUMBER_INT=FY.FISCAL_YEAR_MONTH_INT\r\nWHERE GL.ALLOCATION_METHOD_NAME = RPT.ALLOCATION_METHOD_NAME\r\nAND GL.DV_FISCAL_YEAR_MTH_NUMBER_INT = RPT.BK_FISCAL_YEAR_MONTH_NUM_INT\r\nAND RPT.FINANCIAL_ACCT_REPORTING_FLG = '='\r\nAND FY.INC_FLAG ='Y'\r\nAND GL.BK_ADJUSTMENT_TYPE_CD ='AS COGS AE SYSTEM ALLOCATION'\r\nAND GL.BK_REVENUE_OR_COGS_TYPE_CD = 'COGS'\r\nGROUP BY 1,2,3,4,5,9,10,17,DV_RECURRING_OFFER_CD\r\n   \r\nUNION ALL \r\n  \r\nSELECT  \r\nGL.DV_FISCAL_YEAR_MTH_NUMBER_INT  BK_FISCAL_YEAR_MTH_NUMBER_INT,\r\nGL.BK_REVENUE_OR_COGS_TYPE_CD  BK_REVENUE_OR_COGS_TYPE_CD ,   \r\n/*5970786 /*AS SUBSCRIPTION_ADJ_PROD  BK_PRODUCT_KEY,\r\n5970786 /*AS SUBSCRIPTION_ADJ_PROD GOODS_PRODUCT_KEY,*/\r\nCASE WHEN GL.BK_ADJUSTMENT_TYPE_CD ='Cloud and Managed Services' THEN 11969520  ELSE 5970786 END BK_PRODUCT_KEY,\r\nCASE WHEN   GL.BK_ADJUSTMENT_TYPE_CD ='Cloud and Managed Services' THEN 11969520 ELSE 5970786 END GOODS_PRODUCT_KEY,\r\nGL.BK_FINANCIAL_ACCOUNT_CD  BK_FINANCIAL_ACCOUNT_CD  ,\r\n'UNKNOWN'BK_REV_MEASURE_TRNSCTN_TYPE_CD,\r\n-999 DV_TRIANGULATION_TYPE_ID_INT,\r\n'UNKNOWN'BK_PRDT_SUBGROUP_ALLOC_SRC_CD,\r\nGL.BK_SALES_TERRITORY_KEY  BK_SALES_TERRITORY_KEY    ,       \r\nBK_SALES_TERRITORY_KEY BK_TRNGLTD_SALES_TERRITORY_KEY,\r\n-9999 SALES_ORDER_LINE_KEY,\r\n'UNKNOWN' BK_SRC_RPRTD_SRVC_CONTRACT_NUM\t,\r\nSUM(ADVANCED_SERVICES_COGS_USD_AMT) *(-1) AS COMP_US_NET_REV_AMT1,\t\r\n'UNK'BK_COMPANY_CD,\r\n'UNK' BK_ISO_COUNTRY_CD,\r\n'SERVICE' DV_PRODUCT_TYPE,\r\nCASE WHEN GL.BK_ADJUSTMENT_TYPE_CD ='CENTRALIZED COGS' THEN 'AS Centralized Indirect' ELSE UPPER(GL.BK_ADJUSTMENT_TYPE_CD) END AS DV_PNL_LINE_ITEM_NAME ,\r\nCAST (TRIM(COALESCE(GOODS_PRODUCT_KEY  ,-999)) || '~' || TRIM(COALESCE(GOODS_PRODUCT_KEY  ,-999)) || '~' ||-9999|| '~' ||-9999 AS VARCHAR(70))  DV_RECURRING_OFFER_CD\r\nFROM\r\n$$FINLGLVWDB.N_ADV_SRVCS_COGS_ALLOCATION   GL\r\nINNER JOIN $$STGDB.WI_PNL_MTH_CNTL_AS_COGS FY ON \r\nGL.DV_FISCAL_YEAR_MTH_NUMBER_INT=FY.FISCAL_YEAR_MONTH_INT\r\nW