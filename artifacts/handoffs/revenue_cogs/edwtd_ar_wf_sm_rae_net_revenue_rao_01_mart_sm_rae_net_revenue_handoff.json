      "attributes": {
        "Sql Query": "SELECT \r\n RANK() OVER (ORDER BY ST_RAO.ADJUSTMENT_LINE_ID,NSSC.SOURCE_SYSTEM_CODE ) + SMATKEY.MAX_VAL AS  NET_REVENUE_KEY, \r\n ST_RAO.ADJUSTMENT_LINE_ID AS SK_NET_REVENUE_ID ,   \r\n NSSC.SOURCE_SYSTEM_CODE AS SS_CD,\r\n ST_RAO.ADJUSTMENT_LINE_ID as SCHEDULE_LINE_ID,\r\n CURRENT_TIMESTAMP(0) as EDW_CREATE_DTM,\r\n USER  as EDW_CREATE_USER\r\n FROM \r\n (SELECT COALESCE(MAX(SM.NET_REVENUE_KEY),0) MAX_VAL \r\n  FROM $$ETLVWDB.SM_RAE_NET_REVENUE SM) SMATKEY,\r\n $$STGDB.ST_NGCCRM_RAE_ADJ_LINE_DTLS ST_RAO\r\n INNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\n ON (ST_RAO.GLOBAL_NAME = NSSC.GLOBAL_NAME)\r\n INNER JOIN $$ETLVWDB.EL_FND_APPLICATION_AR  EFAA\r\n\tON ST_RAO.APPLICATION_ID = EFAA.APPLICATION_ID\t\r\n WHERE UPPER(ST_RAO.EVENT_TYPE) ='TBA_DEFERRAL'\t\r\n AND UPPER(EFAA.APPLICATION_NAME) = 'REVENUE ACCOUNTING ENGINE'\r\n AND ST_RAO.ACCOUNT_CLASS IN  ('UNEARNED_REVENUE','REVENUE') \r\n AND ( ST_RAO.OA_SKU_TYPE = 'SUB' OR ST_RAO.OA_SKU_TYPE IS NULL ) \r\n AND NOT EXISTS (SELECT 1 FROM $$ETLVWDB.SM_RAE_NET_REVENUE SM_RAE\r\n WHERE SM_RAE.SK_NET_REVENUE_ID = ST_RAO.ADJUSTMENT_LINE_ID \r\n AND SM_RAE.SS_CD = NSSC.SOURCE_SYSTEM_CODE\r\n AND SM_RAE.SCHEDULE_LINE_ID = ST_RAO.ADJUSTMENT_LINE_ID\r\n                )",
        "User Defined Join": "",
