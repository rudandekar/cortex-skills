      ],
      "attributes": {
        "Sql Query": "SELECT WAPNSNA.BK_AS_PROJECT_CD, nsolaq.SALES_ORDER_LINE_KEY,CAST('QUOTE-SOLK' AS VARCHAR(25)) AS SOL_IDENTIFIER\r\n,MAP2.AS_PROJECT_CLASS_CD\r\nFROM $$STGDB.WI_AS_COGS_PROJ_NO_SOL_AMT wapnsna \r\nINNER JOIN $$SERVICEVWDB.N_AS_QUOTE naq \r\nON WAPNSNA.BK_AS_PROJECT_CD = NAQ.BK_AS_PROJECT_CD\r\nAND NAQ.AS_QUOTE_STATUS_CD  ='BOOKED'\r\nINNER JOIN $$SERVICEVWDB.N_SALES_ORDER_LINE_AS_QUOTE nsolaq \r\nON NAQ.BK_AS_QUOTE_NUM = NSOLAQ.BK_AS_QUOTE_NUM \r\nINNER JOIN $$ASBIVWDB.MT_AS_PROJECT map2 \r\nON WAPNSNA.BK_AS_PROJECT_CD = MAP2.BK_AS_PROJECT_CD\r\nAND MAP2.AS_PROJECT_CLASS_CD=wapnsna.AS_PROJECT_CLASS_CD\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE NSOL\r\nON NSOLAQ.SALES_ORDER_LINE_KEY = NSOL.SALES_ORDER_LINE_KEY\r\nINNER JOIN\r\n(SELECT \r\nMSFH.ITEM_KEY, SUBSTR(MSFH.BK_ALLOCATED_SERVC_GROUP_ID, 4, LENGTH(MSFH.BK_ALLOCATED_SERVC_GROUP_ID)-3) AS BK_ALLOCATED_SERVC_GROUP_ID\r\nFROM $$COMREFVWDB.MT_SVC_FINANCE_HIERARCHY msfh \r\nWHERE BK_SERVICE_CATEGORY_ID='ADVANCED SERVICES') MSFH\r\nON MSFH.ITEM_KEY = NSOL.PRODUCT_KEY \r\nAND MAP2.AS_PROJECT_CLASS_CD = MSFH.BK_ALLOCATED_SERVC_GROUP_ID \r\nWHERE MAP2.LATEST_RECORD_FLG ='Y'\r\nGROUP BY 1,2,3,4",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
