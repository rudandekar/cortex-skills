      ],
      "attributes": {
        "Sql Query": "SELECT \r\nB.BK_AS_PROJECT_CD,A.SALES_ORDER_LINE_KEY,'CUSTOMER' AS SOL_IDENTIFIER,B.AS_PROJECT_CLASS_CD\r\nFROM $$STGDB.WI_AS_COGS_PROJ_SOLK A\r\nINNER JOIN \r\n(SELECT \r\nWAP.BK_AS_PROJECT_CD,GU_PRIMARY_NAME AS CUSTOMER_NAME,WAP.AS_PROJECT_CLASS_CD\r\nFROM \r\n$$STGDB.WI_AS_COGS_PROJ_NO_SOL_AMT WAP\r\nINNER JOIN $$ASBIVWDB.MT_AS_PROJECT MA\r\nON MA.BK_AS_PROJECT_CD=WAP.BK_AS_PROJECT_CD\r\nAND MA.AS_PROJECT_CLASS_CD=WAP.AS_PROJECT_CLASS_CD\r\nAND LATEST_RECORD_FLG='Y'\r\nINNER JOIN $$COMREFVWDB.MT_ERP_POS_SOLDTO_HIER PRJ_CUST\r\nON MA.PROJECT_CUST_ACCT_KEY  = PRJ_CUST.SOLD_TO_CUSTOMER_KEY\r\nWHERE GU_PRIMARY_NAME NOT IN ('UNKNOWN')\r\nGROUP BY 1,2,3 ) B\r\nON A.CUSTOMER_NAME=B.CUSTOMER_NAME\r\nAND A.AS_PROJECT_CLASS_CD=B.AS_PROJECT_CLASS_CD \r\nWHERE B.BK_AS_PROJECT_CD NOT IN (SELECT BK_AS_PROJECT_CD FROM  $$STGDB.WI_AS_COGS_PROJ_SOL_LINK GROUP BY 1)\r\nAND A.CUSTOMER_NAME NOT IN ('UNKNOWN')\r\nGROUP BY 1,2,3,4",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
