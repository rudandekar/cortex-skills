          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "SELECT \r\nB.BK_AS_PROJECT_CD,A.SALES_ORDER_LINE_KEY,'DEAL' AS SOL_IDENTIFIER,B.AS_PROJECT_CLASS_CD\r\nFROM $$STGDB.WI_AS_COGS_PROJ_SOLK A\r\nINNER JOIN \r\n(SELECT \r\nWAP.BK_AS_PROJECT_CD,MA.AS_LOCAL_DEAL_ID_INT,WAP.AS_PROJECT_CLASS_CD\r\nFROM \r\n$$STGDB.WI_AS_COGS_PROJ_NO_SOL_AMT WAP\r\nINNER JOIN $$ASBIVWDB.MT_AS_PROJECT MA\r\nON MA.BK_AS_PROJECT_CD=WAP.BK_AS_PROJECT_CD\r\nAND MA.AS_PROJECT_CLASS_CD=WAP.AS_PROJECT_CLASS_CD\r\nAND LATEST_RECORD_FLG='Y'\r\nINNER JOIN $$SLSORDVWDB.N_DEAL ND\r\nON CAST(MA.AS_LOCAL_DEAL_ID_INT AS VARCHAR(50))=ND.BK_DEAL_ID\r\nAND ND.bk_deal_status_cd NOT IN('Expired', 'Lost', 'Cancelled')\r\nAND ND.BK_DEAL_ID <> 'UNKNOWN'\r\nWHERE AS_LOCAL_DEAL_ID_INT <> -999\r\nGROUP BY 1,2,3 ) B\r\nON A.AS_LOCAL_DEAL_ID_INT=B.AS_LOCAL_DEAL_ID_INT\r\nAND A.AS_PROJECT_CLASS_CD=B.AS_PROJECT_CLASS_CD\r\nWHERE B.BK_AS_PROJECT_CD NOT IN (SELECT BK_AS_PROJECT_CD FROM  $$STGDB.WI_AS_COGS_PROJ_SOL_LINK GROUP BY 1)\r\nAND A.AS_LOCAL_DEAL_ID_INT <> -999\r\nGROUP BY 1,2,3,4",
        "User Defined Join": "",
