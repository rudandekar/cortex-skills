      "attributes": {
        "Sql Query": "SELECT FISCAL_QUARTER_NAME,\r\nSERVICE_CONTRACT  AS SERVICE_CONTRACT_NOTE_TXT\r\n,DRVD_SALES_TERRITORY_KEY\r\n,DV_COMP_US_NET_REV_AMT\r\n,SUM(DV_COMP_US_NET_REV_AMT) OVER(PARTITION BY FISCAL_QUARTER_NAME,SERVICE_CONTRACT) TOTAL_COMP_US_NET_REV_AMT\r\n,COUNT  (  DRVD_SALES_TERRITORY_KEY) OVER(PARTITION BY FISCAL_QUARTER_NAME,SERVICE_CONTRACT) SLK_DIST_COUNT\r\n,CAST(DV_COMP_US_NET_REV_AMT AS DECIMAL(27,14))/CAST(TOTAL_COMP_US_NET_REV_AMT AS DECIMAL(27,14)) SA_SLK_ALLOCATION_RATIO \r\n FROM\r\n(\r\nSELECT \r\n  REV_MTH.FISCAL_QUARTER_NAME,\r\nCOALESCE(SOLTV.RU_SERVICE_CONTRACT_NUMBER, ITEM_LINE.SERVICE_CONTRACT_NOTE_TXT) AS SERVICE_CONTRACT\r\n,CASE WHEN GL.SALES_TERRITORY_KEY <=-1000000 THEN -999 ELSE GL.SALES_TERRITORY_KEY END DRVD_SALES_TERRITORY_KEY\r\n,SUM(GL.DV_COMP_US_NET_REV_AMT) DV_COMP_US_NET_REV_AMT\r\n--FROM $$FINLGLVWDB.N_GL_REV_MEASURE GL\r\nFROM  $$FINLGLVWDB.MT_RSTD_GL_REV_MEASURE GL  \r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\r\n LEFT OUTER JOIN  $$SLSORDVWDB.N_SALES_ORDER_LINE_TV  SOLTV \r\n ON SOLTV.SALES_ORDER_LINE_KEY = (CASE WHEN GL.SALES_ORDER_LINE_KEY >0 THEN GL.SALES_ORDER_LINE_KEY ELSE GL.DV_SALES_ORDER_LINE_KEY END )\r\n\r\nLEFT OUTER JOIN  $$FINLGLVWDB.N_AR_TRX_ITEM_LINE  ITEM_LINE \r\n ON GL.AR_TRX_LINE_KEY=ITEM_LINE.AR_TRX_LINE_KEY \r\n\r\n INNER JOIN \r\n   (SELECT CTRL_FISCAL.FISCAL_QUARTER_NAME,RFISCAL.FISCAL_QTR_AGO_MONTH_NUMBER, RFISCAL.FISCAL_MONTH_AGO_MONTH_NUMBER,CTRL_FISCAL.FISCAL_YEAR_MONTH_INT   \r\n   FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFISCAL  \r\n   INNER JOIN $$STGDB.WI_CCM_TS_MTH_QTR_CNTL CTRL_FISCAL\r\n    ON  CTRL_FISCAL.FISCAL_YEAR_MONTH_INT=RFISCAL.FISCAL_YEAR_MONTH_INT AND CTRL_FISCAL.MONTH_RANK=1) REV_MTH\r\nON 1=1 \r\n --INNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR  RFM\r\n--ON RFM.FISCAL_MONTH_AGE BETWEEN 1 AND 3   commentes as prt of nov21 rel\r\n-- WHERE GL.DV_FISCAL_YEAR_MTH_NUMBER_INT  = RFM.FISCAL_YEAR_MONTH_INT\r\nWHERE GL.DV_FISCAL_YEAR_MTH_NUMBER_INT IN (202110,202109,202108) -- HARD CODE FOR TEST ONLY. NEED TO CHANGE TO PROD CODE ABOVE FOR NOV21 REL\r\n AND SOLTV.RU_SERVICE_CONTRACT_NUMBER IS NOT NULL--added as prt of nov21 rel\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\r\nAND SERVICE_CONTRACT IN (SELECT SERVICE_CONTRACT_NOTE_TXT  FROM $$STGDB.WI_CCM_REV_MAPNG_DATA_SRVC_CNT)--added as prt of nov21 rel\r\n AND COALESCE(SOLTV.RU_SERVICE_CONTRACT_NUMBER, ITEM_LINE.SERVICE_CONTRACT_NOTE_TXT) IS NOT NULL\r\nAND GL.DV_CORPORATE_REVENUE_FLG = 'Y'\r\n --AND GL.DV_SERVICE_FLG='Y'\r\n AND DV_REVENUE_FLG ='Y'--added as prt of nov21 rel\r\n \r\nGROUP BY \r\n REV_MTH.FISCAL_QUARTER_NAME,\r\nSERVICE_CONTRACT,\r\nDRVD_SALES_TERRITORY_KEY\r\nHAVING SUM(GL.DV_COMP_US_NET_REV_AMT) > 0\r\n\r\n) GL_REV_DRIVER",
