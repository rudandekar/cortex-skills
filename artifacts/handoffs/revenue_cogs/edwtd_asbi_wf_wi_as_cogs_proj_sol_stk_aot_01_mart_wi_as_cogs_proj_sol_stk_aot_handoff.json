      "attributes": {
        "Sql Query": "SELECT \r\nDCOGS.BK_FISCAL_YEAR_MTH_NUMBER_INT,\r\nDCOGS.PROJECT_CD,\r\nDCOGS.PNL_LINE_ITEM,\r\nDCOGS.BK_SALES_TERRITORY_KEY,\r\nDCOGS.L6_SALES_TERRITORY_DESCR, \r\nDCOGS.L3_SALES_TERRITORY_DESCR, \r\nDCOGS.L2_SALES_TERRITORY_DESCR, \r\nCOALESCE(PSOL.DV_CX_PRODUCT,CASE WHEN MA.AS_PROJECT_CLASS_CD = 'Subscription'  \r\nTHEN CASE WHEN AS_PROJECT_CATEGORY_NAME='BCS 3.x' THEN 'Lifecycle Svcs Other' ELSE 'Legacy BCS' END \r\nELSE 'Professional Services Other' END) AS DV_CX_PRODUCT,\r\nCOALESCE(PSOL.BK_AS_ATO_ARCHITECTURE_NAME,'AS OTHER') AS BK_AS_ATO_ARCHITECTURE_NAME ,\r\nCOALESCE(PSOL.BK_BUSI_SVC_OFFER_TYPE_NAME,'AS OTHER') AS BK_BUSI_SVC_OFFER_TYPE_NAME,\r\nCOALESCE(PSOL.BK_AS_ATO_TECH_NAME,'AS OTHER') AS BK_AS_ATO_TECH_NAME,\r\nCOALESCE(CASE WHEN MA.AS_PROJECT_CLASS_CD IN ('CAP','INTERNAL') THEN 'TRANSACTION' ELSE MA.AS_PROJECT_CLASS_CD END,'UNKNOWN') AS AS_PROJECT_CLASS_CD,\r\nL3_SALES_TERRITORY_NAME_CODE, \r\nSALES_COVERAGE_CODE, \r\nISO_COUNTRY_CODE , \r\nEXTERNAL_THEATER,  \r\nCAST(DCOGS.ALLOCATED_COST*COALESCE(PSOL.SPLIT_PCT,1) AS DECIMAL(26,7)) AS ALLOCATED_COST\r\nFROM \r\n$$STGDB.WI_AS_COGS_PROJ_SOL_STK DCOGS\r\nLEFT OUTER JOIN \r\n(SELECT BK_AS_PROJECT_CD,\r\nBK_AS_ATO_ARCHITECTURE_NAME ,BK_BUSI_SVC_OFFER_TYPE_NAME ,BK_AS_ATO_TECH_NAME,DV_CX_PRODUCT,\r\nsum(SPLIT_PCT) as SPLIT_PCT\r\nFROM $$STGDB.WI_AS_COGS_PROJ_SOL_AOT_SPLIT\r\nGROUP BY 1,2,3,4,5) PSOL \r\nON DCOGS.PROJECT_CD=PSOL.BK_AS_PROJECT_CD\r\nLEFT JOIN  $$ASBIVWDB.MT_AS_PROJECT MA\r\nON DCOGS.PROJECT_CD=MA.BK_AS_PROJECT_CD\r\nAND lATEST_RECORD_FLG='Y'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
