      "attributes": {
        "Sql Query": "SELECT  \r\nADJUSTMENT_RATE_ID,\r\nRATE_SET_ID,\r\nOWNER,\r\nPARTNER,\r\nAR_QUALIFIER1,\r\nAR_QUALIFIER2,\r\nEFFECTIVE_FROM_DATE,\r\nEFFECTIVE_TO_DATE,\r\nRATE,\r\nRATE_DISPLAYED,\r\nATTRIBUTE1,\r\nATTRIBUTE2,\r\nATTRIBUTE3,\r\nATTRIBUTE4,\r\nATTRIBUTE5,\r\nCREATED_BY,\r\nCREATION_DATE,\r\nLAST_UPDATED_BY,\r\nLAST_UPDATE_DATE,\r\nLAST_UPDATE_LOGIN,\r\nMD_ID,\r\nSECONDARY_RATE,\r\nSECONDARY_RATE_DISPLAYED,\r\nSOURCE_ID,\r\nSOURCE_DML_TYPE,\r\nSOURCE_COMMIT_TIME,\r\nREFRESH_DATETIME\r\nFROM\r\n$$NRTACCUMVWDB.BV_CP_ADJUSTMENT_RATES BV_CP_ADJUSTMENT_RATES\r\nWHERE   SOURCE_COMMIT_TIME > '$$LastExtractDate' \r\nAND   SOURCE_DML_TYPE <> 'DELETE'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY BV_CP_ADJUSTMENT_RATES.ADJUSTMENT_RATE_ID ORDER BY   REFRESH_DATETIME DESC) = 1",
