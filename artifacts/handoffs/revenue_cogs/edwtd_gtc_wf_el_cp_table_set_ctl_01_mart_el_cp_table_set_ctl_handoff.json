      "attributes": {
        "Sql Query": "/*    */\r\n\r\nSELECT \r\nSET_ID, \r\nSET_BASE_TABLE, \r\nSET_NAME, \r\nCAST('CG' AS CHAR(8)) AS SS_CODE,\r\nUSER AS EDW_CREATE_USER, \r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM, \r\nUSER AS EDW_UPDATE_USER, \r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM \r\nFROM \r\n(\r\nSELECT \r\nSET_ID, \r\nSET_BASE_TABLE, \r\nSET_NAME, \r\nCAST('CG' AS CHAR(8)) AS SS_CODE\r\nFROM $$STGDB.ST_XXCP_TABLE_SET_CTL_CG1\r\nWHERE SET_BASE_TABLE = 'CP_ADJUSTMENT_RATES'\r\nUNION ALL\r\nSELECT \r\nSET_ID, \r\nSET_BASE_TABLE, \r\nSET_NAME, \r\nCAST('BV' AS CHAR(8)) AS SS_CODE\r\nFROM $$STGDB.ST_CP_TABLE_SET_CTL_BV\r\nWHERE SET_BASE_TABLE = 'CP_ADJUSTMENT_RATES'\r\n) IQ\r\nWHERE NOT EXISTS\r\n(\r\n SELECT 1\r\n   FROM $$ETLVWDB.EL_CP_TABLE_SET_CTL EL\r\n   WHERE IQ.SET_ID = EL.SET_ID\r\n     AND IQ.SS_CODE = EL.SS_CODE\r\n     AND IQ.SET_BASE_TABLE = EL.SET_BASE_TABLE\r\n)",
