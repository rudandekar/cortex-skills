      "attributes": {
        "Sql Query": "SELECT SNLD.DETAIL_CODE  BK_CCRM_ELEMENT_TYPE_CD, SNLD.DETAIL_DESC  ELEMENT_TYPE_DESCR,\r\nSNLD.ACTION_CODE  ACTION_CODE,\r\n'I'  DML_TYPE  \r\nFROM  $$STGDB.ST_NGCCRM_LOOKUP_DETAILS SNLD\r\nINNER JOIN $$ETLVWDB.EL_NGCCRM_LOOKUP ENL\r\nON SNLD.LOOKUP_ID = ENL.LOOKUP_ID\r\nWHERE ENL.LOOKUP_TYPE='ELEMENT_TYPE'\r\nUNION ALL\r\nSELECT ENLD.DETAIL_CODE  BK_CCRM_ELEMENT_TYPE_CD, ENLD.DETAIL_DESC  ELEMENT_TYPE_DESCR,\r\nENLD.ACTION_CODE  ACTION_CODE,\r\n'I'  DML_TYPE  \r\nFROM  $$EXCEPDB.EX_NGCCRM_LOOKUP_DETAILS ENLD\r\nINNER JOIN $$ETLVWDB.EL_NGCCRM_LOOKUP ENL\r\nON ENLD.LOOKUP_ID = ENL.LOOKUP_ID\r\nWHERE ENL.LOOKUP_TYPE='ELEMENT_TYPE'",
