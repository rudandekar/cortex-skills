      "attributes": {
        "Sql Query": "SELECT COALESCE(NAME,'UNKNOWN') AS GTC_PRODUCT_TYPE_CD,\r\nCOALESCE(SOURCE1,'UNKNOWN') AS SS_CD,\r\nDESCRIPTION AS PRODUCT_TYPE_DESCR,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER\r\n FROM $$STGDB.ST_XXCFI_CB_PT_CC XCTS\r\nWHERE  XCTS.SOURCE1 <> 'CISCO' AND XCTS.PRODUCT_FLAG = 'P'\r\nAND NOT EXISTS (SELECT 1 FROM  $$FINLGLVWDB.N_GTC_PRODUCT_TYPE NGPT WHERE NGPT.GTC_PRODUCT_TYPE_CD = COALESCE(XCTS.NAME,'UNKNOWN'))\r\nQUALIFY ROW_NUMBER() OVER( PARTITION BY XCTS.NAME, XCTS.SOURCE1 ORDER BY XCTS.MODIFIED_DATE DESC) = 1",
