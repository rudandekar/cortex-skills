      "attributes": {
        "Sql Query": "SELECT\r\nBK_PRODUCT_TYPE_ID,\r\n'CISCO' AS SS_CD,\r\nPRODUCT_TYPE_DESCR,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER \t\t\t\t AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER \t\t\t\t AS EDW_UPDATE_USER\r\nFROM $$COMREFVWDB.N_PRODUCT_TYPE NPT\r\nWHERE NOT EXISTS\r\n(\r\nSELECT 1\r\n  FROM $$FINLGLVWDB.N_GTC_PRODUCT_TYPE NGPT\r\n  WHERE NGPT.GTC_PRODUCT_TYPE_CD = NPT.BK_PRODUCT_TYPE_ID\r\n    AND NGPT.SS_CD = 'CISCO'\r\n)",
