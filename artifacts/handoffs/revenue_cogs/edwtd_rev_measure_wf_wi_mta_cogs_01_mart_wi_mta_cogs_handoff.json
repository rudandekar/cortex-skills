      "attributes": {
        "Sql Query": "SELECT\r\nNSOL.SALES_ORDER_KEY\r\n, NSOL.SALES_ORDER_LINE_KEY\r\n, NSOL.RU_PARNT_SLS_ORDER_LINE_KEY\r\n, NSOL.BK_SO_NUMBER_INT \r\n, NSOL.SK_SO_LINE_ID_INT\r\n, NMT.RU_PRODUCT_ITEM_KEY  AS SK_INVENTORY_ITEM_ID_INT\r\n, NMT.SS_CD AS SS_CODE\r\n, NSOL.ITEM_TYPE_CODE\r\n, FISCMTH.FISCAL_YEAR_MONTH_INT  AS DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n, NMT.TRANSACTION_DTM\r\n, SUM(CAST(COALESCE(NMTD.RU_CR_USD_AMT, 0)  AS DECIMAL(18, 6))) AS MTA_BASE_TRANSACTION_VALUE\r\n, SUM(CAST(COALESCE(NMTD.RU_CR_USD_AMT, 0)  AS DECIMAL(18, 6))) AS DV_COMP_US_MTA_COST_AMT\r\nFROM   $$INVFLMTVWDB.N_MATERIAL_TRANSACTION NMT\r\nJOIN  $$INVFLMTVWDB.N_MATERIAL_TRANSACTION_DETAIL NMTD ON  NMTD.BK_MATERIAL_TRANSACTION_KEY = NMT.MATERIAL_TRANSACTION_KEY\r\nJOIN $$ETLVWDB.EV_N_GENERAL_LEDGER_ACCOUNT  GL ON NMTD.BK_GENERAL_LEDGER_ACCOUNT_KEY  = GL.GENERAL_LEDGER_ACCOUNT_KEY \r\n\t\t\t AND GL.GLOBAL_NAME = 'US' \r\n\t\t\tAND TRIM(GL.BK_FINANCIAL_ACCOUNT_CODE) = '50100' \r\nJOIN $$SLSORDVWDB.N_SALES_ORDER_LINE NSOL ON NMT.RU_SALES_ORDER_LINE_KEY = NSOL.SALES_ORDER_LINE_KEY \r\n\t\tAND NMT.RU_SALES_ORDER_KEY = NSOL.SALES_ORDER_KEY               \r\nJOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR FISCMTH ON  CAST( (CURRENT_DATE  - 1) AS DATE)  BETWEEN FISCAL_MONTH_START_DATE       AND  FISCAL_MONTH_END_DATE\r\n\t\tAND CAST(TRANSACTION_DTM  AS DATE)  BETWEEN  CAST( FISCAL_MONTH_START_DATE AS DATE)  AND  CAST( FISCAL_MONTH_END_DATE AS DATE)   \r\nWHERE NMT.BK_SOURCE_TYPE_NAME = 'SALES ORDER'\t\t  \r\nAND NMT.SS_CD = 'MFG' \r\n AND  NOT EXISTS (\r\n SELECT  NMTCG.RU_SALES_ORDER_LINE_KEY FROM  $$INVFLMTVWDB.N_MATERIAL_TRANSACTION NMTCG\r\nJOIN  $$INVFLMTVWDB.N_MATERIAL_TRANSACTION_DETAIL NMTDCG\r\n ON  NMTDCG.BK_MATERIAL_TRANSACTION_KEY = NMTCG.MATERIAL_TRANSACTION_KEY\r\nJOIN $$ETLVWDB.EV_N_GENERAL_LEDGER_ACCOUNT  GLCG\r\nON NMTDCG.BK_GENERAL_LEDGER_ACCOUNT_KEY  = GLCG.GENERAL_LEDGER_ACCOUNT_KEY \r\nAND GLCG.GLOBAL_NAME = 'CG' \r\nAND TRIM(GLCG.BK_FINANCIAL_ACCOUNT_CODE) = '50100' \r\nWHERE   NMTCG.SS_CD = 'CG' AND  NMT.RU_SALES_ORDER_LINE_KEY = NMTCG.RU_SALES_ORDER_LINE_KEY\r\n)\r\nGROUP BY \tNSOL.SALES_ORDER_KEY\r\n, NSOL.SALES_ORDER_LINE_KEY\r\n, NSOL.RU_PARNT_SLS_ORDER_LINE_KEY\r\n, NSOL.BK_SO_NUMBER_INT\r\n, NSOL.SK_SO_LINE_ID_INT\r\n, NMT.RU_PRODUCT_ITEM_KEY\r\n, NMT.SS_CD \r\n, NSOL.ITEM_TYPE_CODE\r\n, FISCMTH.FISCAL_YEAR_MONTH_INT  \r\n, NMT.TRANSACTION_DTM",
        "User Defined Join": "",
