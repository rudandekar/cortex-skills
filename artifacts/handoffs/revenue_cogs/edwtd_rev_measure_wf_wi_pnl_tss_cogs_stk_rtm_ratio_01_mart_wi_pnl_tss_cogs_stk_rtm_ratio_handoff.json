      "attributes": {
        "Sql Query": "SELECT \r\nFISCAL_YEAR_MONTH_INT BK_FISCAL_YEAR_MTH_NUMBER_INT,\r\n'TSS_COGS' DV_PNL_REV_COST_TYPE,\r\n'COGS' BK_REVENUE_OR_COGS_TYPE_CD,\r\nSALES_TERRITORY_KEY ORIGINAL_SALES_TERRITORY_KEY ,\r\nCHANNEL_FLG     ,            \r\nAS_OF_FSC_MTH_CHANNEL_FLG   ,  \r\nDV_ROUTE_TO_MARKET_CD         ,\r\nDV_AS_OF_FSC_MTH_RTM_CD   ,\r\n(TAC_COGS_AMOUNT+TAC_OH_COGS_AMOUNT+TAC_TBO_COGS_AMOUNT+SSC_COGS_AMOUNT+TSS_WARRANTY_AMOUNT)  *(-1)   TSS_COGS_AMT,\r\nCAST(TSS_COGS_AMT AS DECIMAL(26,16))/SUM(TSS_COGS_AMT) OVER (PARTITION BY FISCAL_YEAR_MONTH_INT,SALES_TERRITORY_KEY)  STK_RTM_RATIO\r\nFROM \r\n(\r\n\r\nSELECT\r\nFISCAL_YEAR_MONTH_INT,\r\nSALES_TERRITORY_KEY,\r\nCHANNEL_FLG     ,              \r\nAS_OF_FSC_MTH_CHANNEL_FLG   ,  \r\nDV_ROUTE_TO_MARKET_CD         ,\r\nDV_AS_OF_FSC_MTH_RTM_CD   \r\n ,SUM(TAC_COGS_AMOUNT) TAC_COGS_AMOUNT\r\n, SUM(TAC_OH_COGS_AMOUNT) TAC_OH_COGS_AMOUNT\r\n, SUM(TAC_TBO_COGS_AMOUNT) TAC_TBO_COGS_AMOUNT\r\n, SUM(SSC_COGS_AMOUNT) SSC_COGS_AMOUNT\r\n, SUM(TAC_WARRANTY_AMOUNT+SSC_WARRANTY_AMOUNT) * (-1) TSS_WARRANTY_AMOUNT\r\nFROM\r\n(\r\nSELECT\r\nFISCAL_YEAR_MONTH_INT,\r\nSALES_TERRITORY_KEY ,\r\nCHANNEL_FLG     ,              \r\nAS_OF_FSC_MTH_CHANNEL_FLG   ,  \r\nDV_ROUTE_TO_MARKET_CD         ,\r\nDV_AS_OF_FSC_MTH_RTM_CD      \r\n,CASE WHEN P.FLAG='TAC' THEN SUM(P.COGS_AMOUNT) ELSE 0 END TAC_COGS_AMOUNT\r\n, CASE WHEN P.FLAG='TAC' THEN SUM(P.TAC_OH_COGS_AMOUNT) ELSE 0 END TAC_OH_COGS_AMOUNT\r\n, CASE WHEN P.FLAG='TAC' THEN SUM(P.TAC_TBO_COGS_AMOUNT) ELSE 0 END TAC_TBO_COGS_AMOUNT\r\n, CASE WHEN P.FLAG='TAC' THEN SUM(P.WARRANTY_AMOUNT) ELSE 0 END TAC_WARRANTY_AMOUNT\r\n, CASE WHEN P.FLAG='SSC' THEN SUM(P.COGS_AMOUNT) ELSE 0 END SSC_COGS_AMOUNT\r\n, CASE WHEN P.FLAG='SSC' THEN SUM(P.WARRANTY_AMOUNT) ELSE 0 END SSC_WARRANTY_AMOUNT\r\nFROM\r\n(\r\nSELECT\r\nGL.FISCAL_YEAR_MONTH_INT,\r\nGL.SALES_TERRITORY_KEY ,\r\nCHANNEL_FLG     ,              \r\nAS_OF_FSC_MTH_CHANNEL_FLG   ,  \r\nDV_ROUTE_TO_MARKET_CD         ,\r\nDV_AS_OF_FSC_MTH_RTM_CD      , \r\n 'TAC' FLAG\r\n,SUM((GL.TAC_BACKBONE_COST_USD_AMT+GL.TAC_OUT_TASKING_COST_AMT)/*  *TMS.DOLLAR_ALLOCATION_PERCENTAGE*EXTBE.PRDT_FAMILY_ALLOCATION_PCT*BE.PRDT_FAMILY_ALLOCATION_PCT*/) (DECIMAL(18,6)) COGS_AMOUNT\r\n,SUM(GL.TAC_THTR_BIZ_OPRTN_CST_USD_AMT/*  *TMS.DOLLAR_ALLOCATION_PERCENTAGE*EXTBE.PRDT_FAMILY_ALLOCATION_PCT*BE.PRDT_FAMILY_ALLOCATION_PCT*/) (DECIMAL(18,6)) TAC_TBO_COGS_AMOUNT\r\n,SUM(GL.TAC_OVERHEAD_COST_USD_AMT/*  *TMS.DOLLAR_ALLOCATION_PERCENTAGE*EXTBE.PRDT_FAMILY_ALLOCATION_PCT*BE.PRDT_FAMILY_ALLOCATION_PCT*/) * GL.DV_TAC_ADJUSTED_OVERHEAD_PCT/100 (DECIMAL(18,6)) TAC_OH_COGS_AMOUNT\r\n,(SUM((GL.TAC_BACKBONE_COST_USD_AMT+GL.TAC_OUT_TASKING_COST_AMT+GL.TAC_THTR_BIZ_OPRTN_CST_USD_AMT)/*  *TMS.DOLLAR_ALLOCATION_PERCENTAGE*EXTBE.PRDT_FAMILY_ALLOCATION_PCT*BE.PRDT_FAMILY_ALLOCATION_PCT*/ (DECIMAL(18,6)))+SUM((GL.TAC_OVERHEAD_COST_USD_AMT)/*  *TMS.DOLLAR_ALLOCATION_PERCENTAGE*EXTBE.PRDT_FAMILY_ALLOCATION_PCT*BE.PRDT_FAMILY_ALLOCATION_PCT*/ (DECIMAL(18,6))) * GL.DV_TAC_ADJUSTED_OVERHEAD_PCT/100)*(100-GL.DV_TAC_WARRANTY_PCT)/100 (DECIMAL(18,6)) WARRANTY_AMOUNT\r\nFROM\r\n$$FINLGLVWDB.MT_SR_TAC_COST_MEASURE GL,\r\n$$STGDB.WI_PNL_MTH_CNTL_TSS_COGS_RTM FY\r\nWHERE\r\nGL.FISCAL_YEAR_MONTH_INT=FY.FISCAL_YEAR_MONTH_INT\r\nAND FY.RUN_BATCH_ID = 1\r\nGROUP BY\r\n1,2,3,4,5,6,GL.DV_TAC_ADJUSTED_OVERHEAD_PCT,GL.DV_TAC_WARRANTY_PCT\r\n  \r\nUNION\r\n    \r\nSELECT\r\nGL.FISCAL_YEAR_MONTH_INT,\r\nGL.SALES_TERRITORY_KEY ,\r\nCHANNEL_FLG     ,              \r\nAS_OF_FSC_MTH_CHANNEL_FLG   ,  \r\nDV_ROUTE_TO_MARKET_CD         ,\r\nDV_AS_OF_FSC_MTH_RTM_CD      , \r\n'SSC' FLAG \r\n,SUM((GL.SSC_DPT_PRSNL_RSRC_CST_USD_AMT+GL.SSC_DEPRECIATION_COST_USD_AMT+GL.SSC_REPAIR_COST_USD_AMT+GL.SSC_DUTY_VAT_COST_USD_AMT+GL.SSC_THRD_PRTY_LGST_CST_USD_AMT+GL.SSC_THRD_PRTY_MTNC_CST_USD_AMT+GL.SSC_ORIG_EQP_MFGR_CST_USD_AMT)/*  *TMS.DOLLAR_ALLOCATION_PERCENTAGE*EXTBE.PRDT_FAMILY_ALLOCATION_PCT*BE.PRDT_FAMILY_ALLOCATION_PCT*/)  (DECIMAL(18,6)) COGS_AMOUNT\r\n,0 TAC_TBO_COGS_AMOUNT\r\n,0 TAC_OH_COGS_AMOUNT\r\n,SUM((GL.SSC_DPT_PRSNL_RSRC_CST_USD_AMT+GL.SSC_DEPRECIATION_COST_USD_AMT+GL.SSC_REPAIR_COST_USD_AMT+GL.SSC_DUTY_VAT_COST_USD_AMT+GL.SSC_THRD_PRTY_LGST_CST_USD_AMT+GL.SSC_THRD_PRTY_MTNC_CST_USD_AMT+GL.SSC_ORIG_EQP_MFGR_CST_USD_AMT)/*  *TMS.DOLLAR_ALLOCATION_PERCENTAGE*EXTBE.PRDT_FAMILY_ALLOCATION_PCT*BE.PRDT_FAMILY_ALLOCATION_PCT*/)*(100-GL.DV_SSC_WARRANTY_PCT)/100  (DECIMAL(18,6)) WARRANTY_AMOUNT\r\nFROM\r\n$$FINLGLVWDB.MT_SR_SSC_COST_MEASURE GL,\r\n$$STGDB.WI_PNL_MTH_CNTL_TSS_COGS_RTM FY\r\nWHERE\r\nGL.FISCAL_YEAR_MONTH_INT=FY.FISCAL_YEAR_MONTH_INT\r\nAND FY.RUN_BATCH_ID = 1\r\nGROUP BY  1,2,3,4,5,6,GL.DV_SSC_WARRANTY_PCT\r\n) P\r\nGROUP BY 1,2,3,4,5,6, P.FLAG\r\n) G\r\nGROUP BY 1,2,3,4,5,6\r\n) ABC \r\nQUALIFY SUM(TSS_COGS_AMT) OVER (PARTITION BY FISCAL_YEAR_MONTH_INT,SALES_TERRITORY_KEY) <>0",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
