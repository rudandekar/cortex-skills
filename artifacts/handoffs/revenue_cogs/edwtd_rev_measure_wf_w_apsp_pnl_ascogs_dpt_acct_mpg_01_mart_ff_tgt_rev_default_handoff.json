      "attributes": {
        "Sql Query": "SELECT \r\nDEPT.BK_DEPARTMENT_CODE BK_DEPARTMENT_CD, \r\nDEPT.BK_COMPANY_CODE BK_COMPANY_CODE,\r\nSTG.PNL_MEASURE_NAME BK_PNL_MEASURE_NAME,\r\nRFM.FISCAL_YEAR_MONTH_INT BK_FISCAL_YEAR_MONTH_NUM_INT,\r\nACCNT.BK_FINANCIAL_ACCOUNT_CODE BK_FINANCIAL_ACCOUNT_CD ,\r\nSTG.ACCOUNT_INCLUDE_FLAG FINANCIAL_ACCT_REPORTING_FLG,\r\nSTG.ALLOCATION_METHOD_NAME,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,\r\nUSER  EDW_UPDATE_USER,\r\n'I' ACTION_CODE,\r\n'I' DML_TYPE \r\nFROM $$STGDB.WI_AE_ASCOGS_DEPT_PNL_MAP STG\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR  RFM \r\nON RFM.FISCAL_YEAR_MONTH_INT=STG.FISCAL_MONTH_ID  \r\nINNER JOIN $$FINLGLVWDB.N_FINANCIAL_ACCOUNT ACCNT  ON ACCNT.BK_FINANCIAL_ACCOUNT_CODE = STG.GL_ACCOUNT_CODE\r\nINNER JOIN  $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT DEPT  ON DEPT.BK_COMPANY_CODE  = SUBSTR(STG.DEPT_NUMBER, 1, 3 )  AND DEPT.BK_DEPARTMENT_CODE = SUBSTR(STG.DEPT_NUMBER,4 )\r\nGROUP BY \r\nDEPT.BK_DEPARTMENT_CODE , \r\nDEPT.BK_COMPANY_CODE ,\r\nSTG.PNL_MEASURE_NAME ,\r\nRFM.FISCAL_YEAR_MONTH_INT ,\r\nACCNT.BK_FINANCIAL_ACCOUNT_CODE  ,\r\nSTG.ACCOUNT_INCLUDE_FLAG ,\r\nSTG.ALLOCATION_METHOD_NAME",
