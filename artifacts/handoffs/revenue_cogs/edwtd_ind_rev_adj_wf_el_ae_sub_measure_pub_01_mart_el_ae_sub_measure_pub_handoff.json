        "Sql Query": "SELECT  SASMP.SOURCE_SYSTEM_ADJ_TYPE_ID, \r\n SASMP.UPDATE_USER,\r\n SASMP.CREATE_USER, \r\n SASMP.START_FISCAL_PERIOD_ID, \r\n SASMP.SUB_MEASURE_KEY, \r\n SASMP.SUB_MEASURE_NAME,\r\n SASMP.SOURCE_SYSTEM_ID, \r\n SASMP.MEASURE_ID,\r\n SASMP.UPDATE_DATETIME, \r\n CAST(COALESCE(SASMP.CREATE_DATETIME,current_timestamp(0)) AS TIMESTAMP(0)) CREATE_DATETIME,\r\n SASMP.CREATE_TIMESTAMP,\r\n COALESCE(SASMP.TRANSITION_FLAG,'N') AS TRANSITION_FLAG,\r\n COALESCE(SASMP.RETAINED_EARNINGS_FLAG,'N') AS RETAINED_EARNINGS_FLAG,\r\n COALESCE(SASMP.CORPORATE_REVENUE_FLAG,'Y') AS CORPORATE_REVENUE_FLAG,\r\n COALESCE(SASMP.DUAL_GAAP_FLAG,'N') AS DUAL_GAAP_FLAG\r\n FROM\r\n  $$STGDB.ST_AE_SUB_MEASURE_PUB SASMP\r\n  WHERE NOT EXISTS (\r\n  SELECT 1 FROM  $$ETLVWDB.EL_AE_SUB_MEASURE_PUB EASMP\r\n  WHERE EASMP.SUB_MEASURE_KEY = SASMP.SUB_MEASURE_KEY)",
