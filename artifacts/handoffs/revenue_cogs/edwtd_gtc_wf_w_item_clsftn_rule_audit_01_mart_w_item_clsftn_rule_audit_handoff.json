      "attributes": {
        "Sql Query": "SELECT\t\r\n\tAUDIT_COMMENTS ,\r\n\tAUDIT_COMMITED ,\r\n\tAUDIT_COUNTRY_GROUP ,\r\n\tAUDIT_FISCAL_YEAR ,\r\n\tAUDIT_MONTH ,\r\n\tAUDIT_NAME ,\r\n\tAUDIT_OWNER ,\r\n\tAUDIT_QUERY_ID ,\r\n\tAUDIT_RECORD_COUNT ,\r\n\tAUDIT_RECORD_COUNT_TYPE ,\r\n\tAUDIT_STATUS ,\r\n\tAUDIT_TYPE ,\r\n\tAUDIT_YEAR ,\r\n\tCREATED_BY ,\r\n\tCREATION_DATE ,\r\n\tLAST_UPDATED_BY ,\r\n\tLAST_UPDATED_DATE ,\r\n\tCREATE_DATETIME ,\r\n\tACTION_CODE ,\r\n\t'RI'\r\nFROM\t$$STGDB.ST_XXCFI_CB_AUDIT_QUERY SXCI\r\nWHERE NOT EXISTS (SELECT 1 FROM $$FINLGLVWDB.N_ITEM_CLSFTN_RULE_AUDIT NCRA\r\nINNER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP1\r\nON COALESCE(SXCI.AUDIT_OWNER,'UNKNOWN')=NCWP1.CEC_ID\r\nINNER JOIN $$COMREFVWDB.N_CALENDAR_MONTH NCM \r\nON SUBSTR(SXCI.AUDIT_MONTH,1,3)=SUBSTR(NCM.CALENDAR_MONTH_NAME,1,3)\r\nAND SXCI.AUDIT_YEAR = NCM.BK_CALENDAR_YEAR_INT\r\nINNER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP2\r\nON COALESCE(SXCI.CREATED_BY,'UNKNOWN')=NCWP2.CEC_ID\r\nINNER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP3\r\nON COALESCE(SXCI.LAST_UPDATED_BY,'UNKNOWN')=NCWP3.CEC_ID\r\nWHERE SXCI.AUDIT_QUERY_ID=NCRA.SK_AUDIT_QUERY_ID)",
        "User Defined Join": "",
