        "Sql Query": "SELECT \r\nST.AUDIT_NAME AS BK_AUDIT_NAME,\r\nCOALESCE(ST.AUDIT_TYPE,'UNKNOWN') AS AUDIT_TYPE_CD,\r\nCOALESCE(ST.AUDIT_STATUS,'UNKNOWN') AS AUDIT_STATUS_CD,\r\nCOALESCE(CAST(ST.CREATION_DATE AS TIMESTAMP),CAST('3500-01-01 00:00:00' AS TIMESTAMP(0)))  AS SRC_CREATION_DTM,\r\nCOALESCE(CAST(ST.LAST_UPDATED_DATE AS TIMESTAMP),CAST('3500-01-01 00:00:00' AS TIMESTAMP(0)))  AS SRC_UPDATED_DTM,\r\nCOALESCE(NCWP1.CISCO_WORKER_PARTY_KEY, -999) AS AUDIT_OWNER_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE(NCM.BK_CALENDAR_YEAR_INT,1900) AS BK_CALENDAR_YEAR_INT,\r\nCOALESCE(NCM.BK_CALENDAR_MONTH_NUMBER_INT,99) AS BK_CALENDAR_MTH_NUM_INT,\r\nCOALESCE(NCWP2.CISCO_WORKER_PARTY_KEY, -999)AS SRC_CRTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE(NCWP3.CISCO_WORKER_PARTY_KEY, -999) AS SRC_UPDT_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE(ST.AUDIT_RECORD_COUNT_TYPE,'UNKNOWN') AS AUDIT_RECORD_COUNT_TYPE,\r\nST.AUDIT_QUERY_ID AS SK_AUDIT_QUERY_ID,             \r\n(CASE WHEN ST.AUDIT_RECORD_COUNT_TYPE='COUNT' THEN ST.AUDIT_RECORD_COUNT ELSE 0 END) AS RU_AUDIT_RECORD_CNT,\r\n(CASE WHEN ST.AUDIT_RECORD_COUNT_TYPE='PERCENTAGE' THEN ST.AUDIT_RECORD_COUNT ELSE 0 END) AS RU_AUDIT_RECORD_PCT,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nST.ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM \r\n$$STGDB.ST_XXCFI_CB_AUDIT_QUERY ST\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP1\r\nON ST.AUDIT_OWNER=NCWP1.CEC_ID\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CALENDAR_MONTH NCM \r\nON SUBSTR(ST.AUDIT_MONTH,1,3)=SUBSTR(NCM.CALENDAR_MONTH_NAME,1,3)\r\nAND ST.AUDIT_YEAR = NCM.BK_CALENDAR_YEAR_INT\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP2\r\nON ST.CREATED_BY=NCWP2.CEC_ID\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP3\r\nON ST.LAST_UPDATED_BY=NCWP3.CEC_ID\r\nWHERE ST.AUDIT_NAME IS NOT NULL\r\nQUALIFY  ROW_NUMBER() OVER(PARTITION BY AUDIT_NAME ORDER  BY ST.LAST_UPDATED_DATE DESC)=1\r\n\r\nUNION\r\n\r\nSELECT \r\nEX.AUDIT_NAME AS BK_AUDIT_NAME,\r\nCOALESCE(EX.AUDIT_TYPE,'UNKNOWN') AS AUDIT_TYPE_CD,\r\nCOALESCE(EX.AUDIT_STATUS,'UNKNOWN') AS AUDIT_STATUS_CD,\r\nCOALESCE(CAST(EX.CREATION_DATE AS TIMESTAMP),CAST('3500-01-01 00:00:00' AS TIMESTAMP(0)))  AS SRC_CREATION_DTM,\r\nCOALESCE(CAST(EX.LAST_UPDATED_DATE AS TIMESTAMP),CAST('3500-01-01 00:00:00' AS TIMESTAMP(0)))  AS SRC_UPDATED_DTM,\r\nCOALESCE(NCWP1.CISCO_WORKER_PARTY_KEY, -999) AS AUDIT_OWNER_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE(NCM.BK_CALENDAR_YEAR_INT,1900) AS BK_CALENDAR_YEAR_INT,\r\nCOALESCE(NCM.BK_CALENDAR_MONTH_NUMBER_INT,99) AS BK_CALENDAR_MTH_NUM_INT,\r\nCOALESCE(NCWP2.CISCO_WORKER_PARTY_KEY, -999)AS SRC_CRTD_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE(NCWP3.CISCO_WORKER_PARTY_KEY, -999) AS SRC_UPDT_BY_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE(EX.AUDIT_RECORD_COUNT_TYPE,'UNKNOWN') AS AUDIT_RECORD_COUNT_TYPE,\r\nEX.AUDIT_QUERY_ID AS SK_AUDIT_QUERY_ID,             \r\n(CASE WHEN EX.AUDIT_RECORD_COUNT_TYPE='COUNT' THEN EX.AUDIT_RECORD_COUNT ELSE 0 END) AS RU_AUDIT_RECORD_CNT,\r\n(CASE WHEN EX.AUDIT_RECORD_COUNT_TYPE='PERCENTAGE' THEN EX.AUDIT_RECORD_COUNT ELSE 0 END) AS RU_AUDIT_RECORD_PCT,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nEX.ACTION_CODE,\r\n'I' AS DML_TYPE \r\nFROM \r\n$$EXCEPDB.EX_XXCFI_CB_AUDIT_QUERY EX\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP1\r\nON EX.AUDIT_OWNER=NCWP1.CEC_ID\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CALENDAR_MONTH NCM \r\nON SUBSTR(EX.AUDIT_MONTH,1,3)=SUBSTR(NCM.CALENDAR_MONTH_NAME,1,3)\r\nAND EX.AUDIT_YEAR = NCM.BK_CALENDAR_YEAR_INT\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP2\r\nON EX.CREATED_BY=NCWP2.CEC_ID\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP3\r\nON EX.LAST_UPDATED_BY=NCWP3.CEC_ID\r\nWHERE EX.AUDIT_NAME IS NOT NULL\r\nQUALIFY  ROW_NUMBER() OVER(PARTITION BY AUDIT_NAME ORDER  BY EX.LAST_UPDATED_DATE DESC)=1",
        "User Defined Join": "",
