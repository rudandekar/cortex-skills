      "attributes": {
        "Sql Query": "SELECT \r\n 1 AS BATCH_ID,\r\n CDC_XLA_TRANSACTION_ENTITIES.ENTITY_ID,\r\n CDC_XLA_TRANSACTION_ENTITIES.APPLICATION_ID,\r\n CDC_XLA_TRANSACTION_ENTITIES.LEGAL_ENTITY_ID,\r\n CDC_XLA_TRANSACTION_ENTITIES.ENTITY_CODE,\r\n CDC_XLA_TRANSACTION_ENTITIES.CREATION_DATE,\r\n CDC_XLA_TRANSACTION_ENTITIES.CREATED_BY,\r\n CDC_XLA_TRANSACTION_ENTITIES.LAST_UPDATE_DATE,\r\n CDC_XLA_TRANSACTION_ENTITIES.LAST_UPDATED_BY,\r\n CDC_XLA_TRANSACTION_ENTITIES.LAST_UPDATE_LOGIN,\r\n CDC_XLA_TRANSACTION_ENTITIES.SOURCE_ID_INT_1,\r\n CDC_XLA_TRANSACTION_ENTITIES.SOURCE_ID_CHAR_1,\r\n CDC_XLA_TRANSACTION_ENTITIES.SECURITY_ID_INT_1,\r\n CDC_XLA_TRANSACTION_ENTITIES.SECURITY_ID_INT_2,\r\n CDC_XLA_TRANSACTION_ENTITIES.SECURITY_ID_INT_3,\r\n CDC_XLA_TRANSACTION_ENTITIES.SECURITY_ID_CHAR_1,\r\n CDC_XLA_TRANSACTION_ENTITIES.SECURITY_ID_CHAR_2,\r\n CDC_XLA_TRANSACTION_ENTITIES.SECURITY_ID_CHAR_3,\r\n CDC_XLA_TRANSACTION_ENTITIES.SOURCE_ID_INT_2,\r\n CDC_XLA_TRANSACTION_ENTITIES.SOURCE_ID_CHAR_2,\r\n CDC_XLA_TRANSACTION_ENTITIES.SOURCE_ID_INT_3,\r\n CDC_XLA_TRANSACTION_ENTITIES.SOURCE_ID_CHAR_3,\r\n CDC_XLA_TRANSACTION_ENTITIES.SOURCE_ID_INT_4,\r\n CDC_XLA_TRANSACTION_ENTITIES.SOURCE_ID_CHAR_4,\r\n CDC_XLA_TRANSACTION_ENTITIES.TRANSACTION_NUMBER,\r\n CDC_XLA_TRANSACTION_ENTITIES.LEDGER_ID,\r\n CDC_XLA_TRANSACTION_ENTITIES.VALUATION_METHOD,\r\n CDC_XLA_TRANSACTION_ENTITIES.SOURCE_APPLICATION_ID,\r\n CDC_XLA_TRANSACTION_ENTITIES.UPG_BATCH_ID,\r\n CDC_XLA_TRANSACTION_ENTITIES.UPG_SOURCE_APPLICATION_ID,\r\n CDC_XLA_TRANSACTION_ENTITIES.UPG_VALID_FLAG,\r\n CDC_XLA_TRANSACTION_ENTITIES.SOURCE_COMMIT_TIME ,\r\n  'CDC' AS GLOBAL_NAME,  \r\n CURRENT_TIMESTAMP(0) AS CREATE_DATETIME, \r\n 'I' AS ACTION_CODE \r\nFROM\r\n(\r\n SELECT * FROM $$NRTACCUMVWDB.CDC_XLA_TRANSACTION_ENTITIES\r\n WHERE SOURCE_COMMIT_TIME >= '$$LastExtractDate' \r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY ENTITY_ID ,APPLICATION_ID  ORDER BY REFRESH_DATETIME  DESC)=1\r\n )CDC_XLA_TRANSACTION_ENTITIES\r\n WHERE CDC_XLA_TRANSACTION_ENTITIES.SOURCE_DML_TYPE <> 'DELETE'",
