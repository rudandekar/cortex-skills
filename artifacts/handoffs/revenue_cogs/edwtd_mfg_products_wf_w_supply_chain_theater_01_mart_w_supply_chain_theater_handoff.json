      "attributes": {
        "Sql Query": "SELECT  DISTINCT ECWRT.ZONE_R AS BK_SUPPLY_CHAIN_THEATER_NAME,\r\n'N' AS SOURCE_DELETED_FLAG,\r\n'I' ACTION_CODE,\r\n(CASE WHEN NSCTC.BK_SUPPLY_CHAIN_THEATER_NAME  IS NOT NULL THEN 'U' ELSE 'I' END) AS DML_TYPE\r\nFROM \r\n(\r\nSELECT TMP.ZONE_R,TMP.REGION_ID \r\nFROM (SELECT ZONE_R,REGION_ID,REFRESH_DATETIME,LANGUAGE_R FROM $$STGDB.ST_CG1_WSH_REGIONS_TL B WHERE B.SOURCE_DML_TYPE <> 'DELETE') TMP\r\nQUALIFY RANK () OVER (PARTITION BY TMP.REGION_ID,TMP.LANGUAGE_R ORDER BY TMP. REGION_ID, TMP.LANGUAGE_R,TMP.REFRESH_DATETIME DESC ) = 1\r\nUNION ALL\r\nSELECT BU.ZONE_R ,BU.REGION_ID FROM $$EXCEPDB.EX_CG1_WSH_REGIONS_TL BU\r\n) SU\r\nINNER JOIN $$ETLVWDB.EL_CG1_WSH_REGIONS ECWR  ON\r\nSU.REGION_ID = ECWR.REGION_ID\r\nINNER JOIN $$ETLVWDB.EL_CG1_WSH_ZONE_REGIONS ECWZR  ON\r\nECWR.REGION_ID = ECWZR.REGION_ID\r\nINNER JOIN $$ETLVWDB.EL_CG1_WSH_REGIONS_TL ECWRT ON\r\nECWRT.REGION_ID = ECWZR.PARENT_REGION_ID\r\nAND ECWRT.LANGUAGE_R = 'US'\r\nLEFT JOIN $$INVFLMTVWDB.N_SUPPLY_CHAIN_THEATER NSCTC ON\r\nNSCTC.BK_SUPPLY_CHAIN_THEATER_NAME=SU.ZONE_R",
        "User Defined Join": "",
