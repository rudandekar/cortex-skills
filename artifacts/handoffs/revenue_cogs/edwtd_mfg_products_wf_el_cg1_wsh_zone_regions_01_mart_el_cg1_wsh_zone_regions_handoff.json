      "attributes": {
        "Sql Query": "SELECT TMP.REGION_ID,TMP.PARENT_REGION_ID,TMP.GLOBAL_NAME\r\nFROM (\r\nSELECT SCWZR.REGION_ID, SCWZR.PARENT_REGION_ID, SCWZR.GLOBAL_NAME,SCWZR.REFRESH_DATETIME\r\nFROM\r\n$$STGDB.ST_CG1_WSH_ZONE_REGIONS SCWZR\r\nWHERE SCWZR.SOURCE_DML_TYPE<> 'DELETE' AND NOT EXISTS\r\n(SELECT   1 FROM \r\n$$ETLONLYDB.EL_CG1_WSH_ZONE_REGIONS ECWZR\r\nWHERE SCWZR.REGION_ID=ECWZR.REGION_ID\r\nAND SCWZR.GLOBAL_NAME=ECWZR.GLOBAL_NAME))TMP\r\nQUALIFY RANK () OVER (PARTITION BY TMP.REGION_ID ORDER BY TMP. REGION_ID,TMP.REFRESH_DATETIME DESC ) = 1",
