      "attributes": {
        "Sql Query": "SELECT \r\n WI_KEYS.SERVICE_REQUEST_SSC_COST_KEY,\r\n WI_KEYS.SALES_TERRITORY_KEY,\r\n WI_KEYS.SERVICE_PRODUCT_KEY,\r\n WI_KEYS.GOODS_PRODUCT_KEY,\r\n WI_KEYS.SRC_RPTD_SERVICE_CONTARCT_NUM,\r\nCOALESCE ( WI_CH.CHANNEL_BOOKINGS_FLG,'=')  CHANNEL_FLG\r\n FROM $$STGDB.WI_CCM_SSC_KEYS WI_KEYS\r\n LEFT OUTER JOIN $$STGDB.WI_CCM_SRVC_CONTRACT_CH_FLG WI_CH\r\n ON WI_KEYS.SRC_RPTD_SERVICE_CONTARCT_NUM=WI_CH.SRC_RPTD_SERVICE_CONTARCT_NUM",
