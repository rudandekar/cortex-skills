      "attributes": {
        "Sql Query": "SELECT \r\n      WI_KEYS.SERVICE_REQUEST_SSC_COST_KEY,\r\n      WI_KEYS.SALES_TERRITORY_KEY,\r\n      WI_KEYS.SERVICE_PRODUCT_KEY,\r\n      WI_KEYS.GOODS_PRODUCT_KEY,\r\n      WI_KEYS.SRC_RPTD_SERVICE_CONTARCT_NUM,\r\n     WI_KEYS.CHANNEL_FLG CHANNEL_FLG,\r\n    CASE \r\n\tWHEN RL.L1_SALES_TERRITORY_NAME_CODE\r\n = 'WW Distribution' THEN '2-Tier (VAR)'\r\nELSE  \r\n\t\tCASE \r\n\t\tWHEN  WI_KEYS.CHANNEL_FLG = 'N'  THEN  'Direct'\r\n\t\tWHEN  WI_KEYS.CHANNEL_FLG = 'Y'  THEN  '1-Tier'\r\n\t\tELSE 'OTHERS' \r\n\t\tEND\r\nEND DV_ROUTE_TO_MARKET_CD\r\nFROM $$STGDB.WI_CCM_SSC_KEYS_CH_FLG WI_KEYS\r\nINNER JOIN $$COMREFVWDB.R_SALES_HIERARCHY RL\r\nON WI_KEYS.SALES_TERRITORY_KEY              =  RL.SALES_TERRITORY_KEY",
