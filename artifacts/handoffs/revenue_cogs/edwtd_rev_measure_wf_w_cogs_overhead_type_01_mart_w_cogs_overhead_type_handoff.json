      "attributes": {
        "Sql Query": "SELECT \r\nRFMTY.FISCAL_CALENDAR_CODE\r\n,RFMTY.FISCAL_YEAR_NUMBER_INT AS BK_SR_TAC_COST_FSCL_YR_NUM_INT\r\n,RFMTY.FISCAL_MONTH_NUMBER_INT AS BK_SR_TAC_COST_FSCL_MTH_NUM_INT\r\n,A.OH_CATEGORY\r\n,SUM(B.AMOUNT)/(SELECT SUM (B.AMOUNT) AS DRIVER_TOTAL_AMOUNT\r\nFROM $$ETLVWDB.EL_CCM_TAC_MAPPING_ALLOCATION A\r\nINNER JOIN $$STGDB.WI_CCM_TAC_INPUT_DOLLAR B\r\nON UPPER (A.DELIVERY_THEATER) = 'TSB' AND A.PL_NODE_VALUE = B.PL_NODE_VALUE\r\nAND A.FISCAL_MONTH_ID = B.FISCAL_MONTH_ID AND B.FISCAL_MONTH_ID IN \r\n(SELECT FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)) AS OH_PERCENTAGE\r\n,CURRENT_TIMESTAMP(0)\r\n,USER \r\n,CURRENT_TIMESTAMP(0)\r\n,USER \r\n,'I'\r\n,'I'\r\nFROM $$ETLVWDB.EL_CCM_TAC_MAPPING_ALLOCATION A\r\nINNER JOIN $$STGDB.WI_CCM_TAC_INPUT_DOLLAR B\r\nON A.PL_NODE_VALUE = B.PL_NODE_VALUE\r\nAND A.FISCAL_MONTH_ID = B.FISCAL_MONTH_ID\r\nINNER JOIN $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID CNTRL\r\nON B.FISCAL_MONTH_ID = CNTRL.FISCAL_YEAR_MONTH_INT\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMTY\r\nON RFMTY.FISCAL_YEAR_MONTH_INT = CNTRL.FISCAL_YEAR_MONTH_INT \r\nWHERE UPPER (A.DELIVERY_THEATER) = 'TSB'\r\nGROUP BY 1,2,3,4",
        "User Defined Join": "",
        "Source Filter": "",
