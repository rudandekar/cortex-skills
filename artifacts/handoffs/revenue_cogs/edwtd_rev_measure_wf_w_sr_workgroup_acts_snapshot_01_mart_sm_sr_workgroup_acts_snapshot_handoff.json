      "attributes": {
        "Sql Query": "SELECT SMWAS.SR_WORKGROUP_ACTS_SNAPSHOT_KEY,\r\nST.WORKGROUP_NAME AS BK_SR_WORKGROUP_CD,            \r\nRFMY.FISCAL_CALENDAR_CODE AS BK_FSCL_CAL_CD,\r\nRFMY.FISCAL_MONTH_NUMBER_INT AS BK_FSCL_MTH_NUM_INT,\r\nRFMY.FISCAL_YEAR_NUMBER_INT AS BK_FSCL_YR_NUM_INT,\r\nHIERARCHY_VERSION AS HIERARCHY_VERSION_NUM_INT,\r\nCASE WHEN ISACTIVE=1 THEN 'Y' ELSE 'N' END AS ACTIVE_FLG,\r\nCOALESCE(NCWP.CISCO_WORKER_PARTY_KEY,-999)  AS CSCO_WRKR_PRTY_KEY,\r\nST.MASTER_THEATER AS MASTER_THEATER_NAME,\r\nST.NATURAL_KEY AS SK_NATURAL_KEY_INT,\r\nST.ROLLUP_THEATER AS ROLL_UP_THEATER_NAME,\r\nST.SERVICE_LINE AS SUPPORTED_SERVICE_LINE_NAME,\r\nST.SERVICE_TYPE AS SUPPORTED_SERVICE_TYPE_NAME,\r\nST.TECHNOLOGY AS SUPPORTED_TECH_NAME,\r\nST.THEATER AS THEATER_NAME,\r\nACTRL.FISCAL_MONTH_STATUS_IND AS FSCL_MTH_CLOSED_STATUS_CD,\r\nDW_WORKGROUP_KEY AS SK_DW_WG_KEY_INT,\r\nST.REPORTS_TO_OBJECT_NUMBER AS SK_RPRTS_TO_OBJECT_NUM_INT,\r\nST.HIERARCHY_ROOT AS HIERARCHY_ROOT_NAME,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM $$STGDB.ST_WORKGROUP_HIER_V18_D ST\r\nINNER JOIN $$STGDB.WI_ACTS_CTRL ACTRL\r\nON ACTRL.FISCAL_MONTH_STATUS_IND = 'WIP'\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMY\r\nON RFMY.FISCAL_YEAR_MONTH_INT = ACTRL.FISCAL_MONTH_ID\r\nINNER JOIN $$ETLVWDB.SM_SR_WORKGROUP_ACTS_SNAPSHOT SMWAS\r\n  ON SMWAS.SK_DW_WG_KEY_INT = ST.DW_WORKGROUP_KEY\r\nAND SMWAS.BK_SR_WORKGROUP_CD = ST.WORKGROUP_NAME\r\nAND SMWAS.BK_FSCL_CAL_CD = RFMY.FISCAL_CALENDAR_CODE\r\nAND SMWAS.BK_FSCL_MTH_NUM_INT =  RFMY.FISCAL_MONTH_NUMBER_INT  \r\nAND SMWAS.BK_FSCL_YR_NUM_INT = RFMY.FISCAL_YEAR_NUMBER_INT\r\nLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP\r\nON SUBSTR(ST.MANAGER_EMAIL,1,POSITION('@'  IN  ST.MANAGER_EMAIL) - 1) = NCWP.CEC_ID",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
