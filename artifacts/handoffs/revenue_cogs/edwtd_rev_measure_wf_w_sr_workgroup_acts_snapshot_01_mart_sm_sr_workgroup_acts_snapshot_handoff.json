        }
      ],
      "attributes": {
        "Sql Query": "SELECT\r\nROW_NUMBER() OVER (ORDER BY SK_DW_WG_KEY_INT, BK_SR_WORKGROUP_CD, BK_FSCL_CAL_CD, BK_FSCL_MTH_NUM_INT,BK_FSCL_YR_NUM_INT) \r\n+ WKGRP_SNPSHT.WKGRP_SNPSHT_KEY AS SR_WORKGROUP_ACTS_SNAPSHOT_KEY, \r\nST.DW_WORKGROUP_KEY AS SK_DW_WG_KEY_INT,\r\nST.WORKGROUP_NAME AS BK_SR_WORKGROUP_CD,\r\nRFMY.FISCAL_CALENDAR_CODE AS BK_FSCL_CAL_CD,\r\nRFMY.FISCAL_MONTH_NUMBER_INT AS BK_FSCL_MTH_NUM_INT,\r\nRFMY.FISCAL_YEAR_NUMBER_INT AS BK_FSCL_YR_NUM_INT,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER AS  EDW_CREATE_USER\r\nFROM $$STGDB.ST_WORKGROUP_HIER_V18_D  ST\r\nINNER JOIN $$STGDB.WI_ACTS_CTRL ACTRL\r\nON ACTRL.FISCAL_MONTH_STATUS_IND = 'WIP'\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMY\r\nON RFMY.FISCAL_YEAR_MONTH_INT = ACTRL.FISCAL_MONTH_ID\r\n,(SELECT COALESCE( MAX(SR_WORKGROUP_ACTS_SNAPSHOT_KEY),0) WKGRP_SNPSHT_KEY \r\nFROM $$ETLVWDB.SM_SR_WORKGROUP_ACTS_SNAPSHOT) WKGRP_SNPSHT\r\nWHERE NOT EXISTS (\r\nSELECT 1 FROM $$ETLVWDB.SM_SR_WORKGROUP_ACTS_SNAPSHOT SMWAS\r\nWHERE SMWAS.SK_DW_WG_KEY_INT = ST.DW_WORKGROUP_KEY\r\nAND SMWAS.BK_SR_WORKGROUP_CD = ST.WORKGROUP_NAME\r\nAND SMWAS.BK_FSCL_CAL_CD = RFMY.FISCAL_CALENDAR_CODE\r\nAND SMWAS.BK_FSCL_MTH_NUM_INT =  RFMY.FISCAL_MONTH_NUMBER_INT  \r\nAND SMWAS.BK_FSCL_YR_NUM_INT = RFMY.FISCAL_YEAR_NUMBER_INT\r\n)",
