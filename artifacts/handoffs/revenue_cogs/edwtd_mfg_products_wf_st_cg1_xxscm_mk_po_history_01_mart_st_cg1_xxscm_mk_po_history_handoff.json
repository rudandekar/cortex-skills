      "attributes": {
        "Sql Query": "SELECT \r\nTMP.MESSAGE_3B2_ID, \r\nTMP.PO_NUMBER, \r\nTMP.ASN_PROCESS_DATE,\r\n TMP.MESSAGE_BOM_PACK_ID, \r\n TMP.BOM_REF_ID, \r\n TMP.BOM_PARENT_REF_ID,\r\n  TMP.ITEM_NUMBER,\r\n  TMP.ITEM_REVISION, \r\n  TMP.ITEM_TYPE,\r\n   TMP.UOM, \r\n   TMP.BOM_ITEM_QUANTITY, \r\n   TMP.ORG_CODE, \r\n   TMP.FLB_COST, \r\n   TMP.DF_FEE_COST, \r\n   TMP.CURRENCY_CODE, \r\n   TMP.PLANNING_CODE, \r\n   TMP.REQUEST_ID, \r\n   TMP.CREATION_DATE, \r\n   TMP.CREATED_BY, \r\n   TMP.LAST_UPDATE_DATE, \r\n   TMP.LAST_UPDATED_BY, \r\n   TMP.COST_UPDATED_FLAG, \r\n  'CG' AS GLOBAL_NAME, \r\n   TMP.SOURCE_DML_TYPE,\r\n    TMP.SOURCE_COMMIT_TIME, \r\n    TMP.REFRESH_DATETIME ,\r\n/* sdande:5/19/2014 Q4-JUNE release brazil tax elements starts*/\r\n\t TMP.CONFIS_TAX_AMOUNT,\r\n\t TMP.ICMS_TAX_AMOUNT ,\r\n\t TMP.RND_TAX_AMOUNT,\r\n\t  TMP.PIS_TAX_AMOUNT \r\n/* Q4-JUNE release brazil tax elements ends*/\r\nFROM\r\n(SELECT MESSAGE_3B2_ID, \r\nPO_NUMBER, \r\nASN_PROCESS_DATE,\r\n MESSAGE_BOM_PACK_ID, \r\n BOM_REF_ID, \r\n BOM_PARENT_REF_ID,\r\n  ITEM_NUMBER,\r\n  ITEM_REVISION, \r\n  ITEM_TYPE,\r\n   UOM, \r\n   BOM_ITEM_QUANTITY, \r\n   ORG_CODE, \r\n   FLB_COST, \r\n   DF_FEE_COST, \r\n   CURRENCY_CODE, \r\n   PLANNING_CODE, \r\n   REQUEST_ID, \r\n   CREATION_DATE, \r\n   CREATED_BY, \r\n   LAST_UPDATE_DATE, \r\n   LAST_UPDATED_BY, \r\n   COST_UPDATED_FLAG, \r\n     SOURCE_DML_TYPE,\r\n    SOURCE_COMMIT_TIME, \r\n    REFRESH_DATETIME ,\r\n/* sdande:5/19/2014 Q4-JUNE release brazil tax elements starts*/\r\n CONFIS_TAX_AMOUNT,\r\n\t  ICMS_TAX_AMOUNT ,\r\n\t  RND_TAX_AMOUNT,\r\n\t  PIS_TAX_AMOUNT \r\n/* sdande:5/19/2014 Q4-JUNE release brazil tax elements ends*/\r\n  FROM $$NRTACCUMVWDB.CG1_XXSCM_MK_PO_HISTORY TMP\r\n WHERE  \r\nSOURCE_COMMIT_TIME > '$$LastExtractDate' \r\nAND SOURCE_COMMIT_TIME <=  '$$EndLastExtractDate'\r\n/* pvenketa : 09/25/2014 added as part of Q2FY15 SC-LSS */\r\nAND COST_UPDATED_FLAG ='Y')TMP\r\nWHERE\r\nTMP.SOURCE_DML_TYPE<>'DELETE'\r\n/* pvenketa : 09/25/2014 added as part of Q2FY15 SC-LSS */\r\nQUALIFY RANK () OVER (PARTITION BY TMP.PO_NUMBER ,TMP.MESSAGE_BOM_PACK_ID ,TMP.BOM_REF_ID ,\r\nTMP.BOM_PARENT_REF_ID ,TMP.ITEM_NUMBER ORDER BY  TMP.REFRESH_DATETIME DESC ) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
