      "attributes": {
        "Sql Query": "SELECT * FROM (SELECT SCMTR.REASON_ID, \r\nSCMTR.REASON_NAME, \r\nSCMTR.GLOBAL_NAME \r\nFROM\r\n$$STGDB.ST_CG1_MTL_TRANSACTION_REAS SCMTR\r\n/* Removed as part of SJPROD RETIREMENT\r\nUNION ALL\r\nSELECT SMMTR.REASON_ID, \r\nSMMTR.REASON_NAME, \r\nSMMTR.GLOBAL_NAME \r\nFROM\r\n$$STGDB.ST_MF_MTL_TXN_REASONS SMMTR \r\nWHERE SMMTR.GLOBAL_NAME = 'US'  */\r\n) SMTR\r\nWHERE NOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.EL_MTL_TRANSACTION_REAS  EMTR WHERE\r\nEMTR.REASON_ID=SMTR.REASON_ID AND\r\nEMTR.GLOBAL_NAME=SMTR.GLOBAL_NAME)",
