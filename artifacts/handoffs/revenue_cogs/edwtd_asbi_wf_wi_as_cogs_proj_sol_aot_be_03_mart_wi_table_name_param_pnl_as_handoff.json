      "attributes": {
        "Sql Query": "SELECT \r\nDCOGS.BK_FISCAL_YEAR_MTH_NUMBER_INT,\r\nCOALESCE(DCOGS.PROJECT_CD,'999999') AS PROJECT_CD,\r\nDCOGS.PNL_LINE_ITEM,\r\nDCOGS.BK_SALES_TERRITORY_KEY,\r\n'AS OTHER' AS BK_AS_ATO_ARCHITECTURE_NAME ,\r\n'AS OTHER' AS BK_BUSI_SVC_OFFER_TYPE_NAME ,\r\n'AS OTHER' AS BK_AS_ATO_TECH_NAME\r\n,COALESCE(L2BE.GOODS_PRODUCT_KEY,(SELECT BK_ADJ_PRODUCT_KEY FROM $$SERVICEVWDB.MT_AS_ADJ_PID_MAPPING ADJ_PID INNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMY\r\nON ADJ_PID.FISCAL_YEAR_QUARTER_NUMBER_INT=RFMY.FISCAL_YEAR_QUARTER_NUMBER_INT\r\nINNER JOIN $$STGDB.WI_AS_COGS_PROJ_SOL_STK_AOT A\r\nON A.BK_FISCAL_YEAR_MTH_NUMBER_INT=RFMY.FISCAL_YEAR_MONTH_INT\r\nWHERE ADJ_PID.BK_BUSINESS_ENTITY_NAME='OTHER'\r\nAND  ADJ_PID.BK_SUB_BUSINESS_ENTITY_NAME   ='OTHER_OTHER'\r\nGROUP BY 1)) AS GOODS_PRODUCT_KEY\r\n,'INDIRECT' AS BE_ASSOCIATION_CD\r\n,COALESCE(L2BE.DV_CX_PRODUCT,'Professional Services Other') AS DV_CX_PRODUCT \r\n,COALESCE(L2BE.BK_ALLOCATED_SERVC_GROUP_ID ,DCOGS.AS_PROJECT_CLASS_CD) AS BK_ALLOCATED_SERVC_GROUP_ID\r\n,COALESCE(CAST(DCOGS.ALLOCATED_COST*COALESCE(L2BE.PID_SPLIT,1) AS DECIMAL(26,7)),0) AS ALLOCATED_COST\r\nFROM \r\n$$STGDB.WI_AS_COGS_PROJ_SOL_STK_AOT DCOGS\r\nINNER JOIN $$COMREFVWDB.$$MAP_TGT_VAR1 RSH\r\nON DCOGS.BK_SALES_TERRITORY_KEY=RSH.SALES_TERRITORY_KEY\r\nAND DCOGS.PNL_LINE_ITEM IN ('Direct-Mapped Allocated','PCOGS-Mapped Allocated')\r\nLEFT OUTER JOIN $$STGDB.WI_AS_COGS_STK_BE_SPLIT L2BE \r\nON DCOGS.BK_FISCAL_YEAR_MTH_NUMBER_INT=L2BE.BK_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND RSH.L3_SALES_TERRITORY_NAME_CODE=L2BE.L3_SALES_TERRITORY_NAME_CODE\r\n--AND DCOGS.PNL_LINE_ITEM=L2BE.PNL_LINE_ITEM\r\nAND RSH.SALES_COVERAGE_CODE=L2BE.SALES_COVERAGE_CODE\r\n--AND DCOGS.AS_PROJECT_CLASS_CD=L2BE.BK_ALLOCATED_SERVC_GROUP_ID \r\nAND RSH.DD_EXTERNAL_THEATER_NAME=L2BE.DD_EXTERNAL_THEATER_NAME",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "DELETE FROM $$STGDB.WI_AS_COGS_STK_BE_SPLIT ;\r\n\r\nINSERT INTO $$STGDB.WI_AS_COGS_STK_BE_SPLIT\r\nSELECT \r\nA.BK_FISCAL_YEAR_MTH_NUMBER_INT,A.L3_SALES_TERRITORY_NAME_CODE,--A.PNL_LINE_ITEM,\r\nA.SALES_COVERAGE_CODE,A.BK_ALLOCATED_SERVC_GROUP_ID  \r\n,A.DD_EXTERNAL_THEATER_NAME,   \r\nA.DV_CX_PRODUCT,A.GOODS_PRODUCT_KEY,\r\nCAST(A.PID_COST AS DECIMAL(26,7)) /(NULLIFZERO(B.TOTAL_COST)) AS PID_SPLIT\r\nFROM \r\n(\r\nSELECT \r\nBK_FISCAL_YEAR_MTH_NUMBER_INT,L3_SALES_TERRITORY_NAME_CODE,\r\n--CASE WHEN A.PNL_LINE_ITEM IN ('Direct-PROJ Mapped','DIRECT-ALLOCATED') THEN 'Direct-Mapped Allocated' ELSE 'PCOGS-Mapped Allocated' END AS PNL_LINE_ITEM,\r\nRSH.SALES_COVERAGE_CODE,A.BK_ALLOCATED_SERVC_GROUP_ID  \r\n,RSH.DD_EXTERNAL_THEATER_NAME,   \r\nDV_CX_PRODUCT,GOODS_PRODUCT_KEY\r\n,SUM(ALLOCATED_COST) AS PID_COST\r\nFROM  $$STGDB.WI_AS_COGS_PROJ_SOL_AOT_BE A\r\nINNER JOIN $$COMREFVWDB.$$MAP_TGT_VAR1 RSH\r\nON A.BK_SALES_TERRITORY_KEY= RSH.SALES_TERRITORY_KEY\r\nWHERE A.PNL_LINE_ITEM IN ('Direct-PROJ Mapped','PCOGS-PROJ Mapped','DIRECT-ALLOCATED','PCOGS-ALLOCATED','GCXC ADC DIRECT','GCXC CLOUD DIRECT','GCXC ADC ALLOCATED','GCXC CLOUD ALLOCATED','NET IMPORT/EXPORT')\r\nGROUP BY 1,2,3,4,5,6,7--,8\r\n) A\r\nINNER JOIN (\r\nSELECT BK_FISCAL_YEAR_MTH_NUMBER_INT,L3_SALES_TERRITORY_NAME_CODE,\r\n--CASE WHEN A.PNL_LINE_ITEM IN ('Direct-PROJ Mapped','DIRECT-ALLOCATED') THEN 'Direct-Mapped Allocated' ELSE 'PCOGS-Mapped Allocated' END AS PNL_LINE_ITEM,\r\nRSH.SALES_COVERAGE_CODE --,A.BK_ALLOCATED_SERVC_GROUP_ID  \r\n,RSH.DD_EXTERNAL_THEATER_NAME,\r\nSUM(ALLOCATED_COST) AS TOTAL_COST\r\nFROM $$STGDB.WI_AS_COGS_PROJ_SOL_AOT_BE A\r\nINNER JOIN $$COMREFVWDB.$$MAP_TGT_VAR1 RSH\r\nON A.BK_SALES_TERRITORY_KEY= RSH.SALES_TERRITORY_KEY\r\nWHERE A.PNL_LINE_ITEM IN ('Direct-PROJ Mapped','PCOGS-PROJ Mapped','DIRECT-ALLOCATED','PCOGS-ALLOCATED','GCXC ADC DIRECT','GCXC CLOUD DIRECT','GCXC ADC ALLOCATED','GCXC CLOUD ALLOCATED','NET IMPORT/EXPORT')\r\nGROUP BY 1,2,3,4--,5--,6 \r\n) B\r\nON A.BK_FISCAL_YEAR_MTH_NUMBER_INT=B.BK_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND A.L3_SALES_TERRITORY_NAME_CODE=B.L3_SALES_TERRITORY_NAME_CODE\r\n--AND A.PNL_LINE_ITEM=B.PNL_LINE_ITEM\r\nAND A.SALES_COVERAGE_CODE=B.SALES_COVERAGE_CODE\r\n--AND A.BK_ALLOCATED_SERVC_GROUP_ID =B.BK_ALLOCATED_SERVC_GROUP_ID \r\nAND A.DD_EXTERNAL_THEATER_NAME=B.DD_EXTERNAL_THEATER_NAME;\r\n\r\nCALL COLLECT_STATS_WRAP('$$STGDB','WI_AS_COGS_STK_BE_SPLIT','M');",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
