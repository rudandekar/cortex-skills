      "attributes": {
        "Sql Query": "SELECT\r\n*\r\nFROM\r\n(\r\nSELECT \r\nSCRL.REQUEST_NUMBER BK_AWAITING_AUTHORIZATION_NUM,\r\nCAST(SCRL.CREATION_DATE AS DATE)  DV_RMA_REQUEST_SUBMIT_DT,\r\nCOALESCE(NRR.ORIGINAL_SALES_ORDER_KEY,-999) ORIGINAL_SALES_ORDER_KEY,\r\nCAST(SCRL.RETURN_QUANTITY AS INTEGER) RMA_REQUEST_LINE_RETURN_QTY,\r\nSCRL.LINE_NUMBER LINE_NUMBER,\r\nSCRL.LINE_ID LINE_ID,\r\nSCRL.CREATION_DATE CREATION_DATE\r\nFROM (SELECT * FROM $$STGDB.ST_CMRS_RMA_LINES SCRL WHERE COALESCE(SCRL.RETURN_QUANTITY,0)<>0 ) SCRL\r\nLEFT OUTER  JOIN $$SERVICEVWDB.N_RMA_REQUEST NRR\r\nON (SCRL.REQUEST_NUMBER=NRR.BK_AWAITING_AUTHORIZATION_NUM)\r\nUNION ALL\r\nSELECT \r\nECRL.REQUEST_NUMBER BK_AWAITING_AUTHORIZATION_NUM,\r\nCAST(ECRL.CREATION_DATE AS DATE)  DV_RMA_REQUEST_SUBMIT_DT,\r\nCOALESCE(NRR.ORIGINAL_SALES_ORDER_KEY,-999) ORIGINAL_SALES_ORDER_KEY,\r\nCAST(ECRL.RETURN_QUANTITY AS INTEGER) RMA_REQUEST_LINE_RETURN_QTY,\r\nECRL.LINE_NUMBER LINE_NUMBER,\r\nECRL.LINE_ID LINE_ID,\r\nECRL.CREATION_DATE CREATION_DATE\r\nFROM (SELECT * FROM $$EXCEPDB.EX_CMRS_RMA_LINES ECRL WHERE COALESCE(ECRL.RETURN_QUANTITY,0)<>0 ) ECRL\r\nLEFT OUTER  JOIN $$SERVICEVWDB.N_RMA_REQUEST NRR\r\nON (ECRL.REQUEST_NUMBER=NRR.BK_AWAITING_AUTHORIZATION_NUM AND COALESCE(ECRL.RETURN_QUANTITY,0)<>0 )\r\n)RMALINE\r\nQUALIFY ROW_NUMBER () OVER ( PARTITION BY RMALINE.BK_AWAITING_AUTHORIZATION_NUM,RMALINE.LINE_NUMBER,RMALINE.RMA_REQUEST_LINE_RETURN_QTY  ORDER BY RMALINE.CREATION_DATE,RMALINE.LINE_ID  DESC)= 1",
        "User Defined Join": "",
        "Source Filter": "",
