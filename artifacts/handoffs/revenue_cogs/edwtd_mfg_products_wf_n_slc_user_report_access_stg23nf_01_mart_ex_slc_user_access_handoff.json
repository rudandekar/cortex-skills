      "attributes": {
        "Sql Query": "SELECT \r\nSLC_USER_CSCO_WORKER_PARTY_KEY,\r\nBK_STRTGC_LOGISTICS_CNTR_NAME,\r\nSOURCE_DELETED_FLG\r\nFROM \r\n(\r\nSELECT\r\nNCWP.CISCO_WORKER_PARTY_KEY AS SLC_USER_CSCO_WORKER_PARTY_KEY,\r\nNSLC.BK_STRTGC_LOGISTICS_CNTR_NAME AS BK_STRTGC_LOGISTICS_CNTR_NAME,\r\nCASE WHEN SSUA.ACTIVE_FLAG='N' THEN 'Y' ELSE 'N' END AS SOURCE_DELETED_FLG ,\r\n(CASE WHEN NSUR.SLC_USER_CSCO_WORKER_PARTY_KEY  IS NOT NULL AND NSUR.BK_STRTGC_LOGISTICS_CNTR_NAME IS NOT NULL  THEN 'U' ELSE 'I' END) AS DML_TYPE  \r\nFROM \r\n(\r\nSELECT \r\nCEC_USER_ID,\r\nSTRATEGIC_LOGISTIC_CENTER_NM,\r\nACTIVE_FLAG,\r\nROW_ID,\r\nLINE_ID,\r\nBATCH_ID\r\nfrom $$SOPDATAVWDB.SC_N_SLC_USER_REPORT_ACCESS \r\nUNION \r\nSELECT \r\nCEC_USER_ID,\r\nSTRATEGIC_LOGISTIC_CENTER_NM,\r\nACTIVE_FLAG,\r\nROW_ID,\r\nLINE_ID,\r\nBATCH_ID\r\nfrom $$EXCEPDB.EX_SLC_USER_ACCESS \r\n)SSUA\r\nINNER  JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP\r\nON NCWP.CEC_ID= SSUA.CEC_USER_ID\r\nINNER JOIN $$SLSORDVWDB.N_STRATEGIC_LOGISTICS_CENTER NSLC\r\nON NSLC.BK_STRTGC_LOGISTICS_CNTR_NAME=SSUA.STRATEGIC_LOGISTIC_CENTER_NM\r\nLEFT JOIN $$INVFLMTVWDB.N_SLC_USER_REPORT_ACCESS NSUR\r\nON NSUR.SLC_USER_CSCO_WORKER_PARTY_KEY=NCWP.CISCO_WORKER_PARTY_KEY\r\nAND NSUR.BK_STRTGC_LOGISTICS_CNTR_NAME=SSUA.STRATEGIC_LOGISTIC_CENTER_NM\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY  SSUA.CEC_USER_ID,SSUA.STRATEGIC_LOGISTIC_CENTER_NM ORDER BY SSUA.BATCH_ID  DESC) = 1\r\n) A where DML_TYPE='I'",
