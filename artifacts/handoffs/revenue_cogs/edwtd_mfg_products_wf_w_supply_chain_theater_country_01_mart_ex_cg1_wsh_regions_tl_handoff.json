      ],
      "attributes": {
        "Sql Query": "SELECT   DISTINCT \r\nECWR.COUNTRY_CODE AS BK_ISO_COUNTRY_CODE,\r\nNSCT.BK_SUPPLY_CHAIN_THEATER_NAME AS BK_SUPPLY_CHAIN_THEATER_NAME,\r\n'N' AS SOURCE_DELETED_FLAG,\r\n'I' ACTION_CODE,\r\n(CASE WHEN NSCTC.BK_SUPPLY_CHAIN_THEATER_NAME IS NOT NULL AND  NSCTC.BK_ISO_COUNTRY_CODE IS NOT NULL THEN 'U' ELSE 'I' END) AS DML_TYPE\r\nFROM\r\n(\r\nSELECT TMP.ZONE_R,TMP.REGION_ID \r\nFROM (SELECT ZONE_R,REGION_ID,REFRESH_DATETIME,LANGUAGE_R FROM $$STGDB.ST_CG1_WSH_REGIONS_TL B \r\nWHERE B.SOURCE_DML_TYPE <> 'DELETE' AND B.LANGUAGE_R='US') TMP\r\nQUALIFY RANK () OVER (PARTITION BY TMP.REGION_ID,TMP.LANGUAGE_R ORDER BY TMP. REGION_ID, TMP.LANGUAGE_R,TMP.REFRESH_DATETIME DESC ) = 1\r\nUNION ALL\r\nSELECT BU.ZONE_R ,BU.REGION_ID  FROM $$EXCEPDB.EX_CG1_WSH_REGIONS_TL BU WHERE  BU.LANGUAGE_R='US'\r\n) SU\r\nINNER JOIN\r\n(\r\nSELECT EWT.REGION_ID , EWT.ZONE_R,V.COUNTRY_CODE \r\nFROM (SELECT\r\n      Z.PARENT_REGION_ID AS ZONE_ID,\r\n      RT.REGION_ID AS REGION_ID,\r\n      RT.COUNTRY AS COUNTRY,\r\n      R.COUNTRY_CODE AS COUNTRY_CODE\r\n             FROM $$ETLVWDB.EL_CG1_WSH_REGIONS R, $$ETLVWDB.EL_CG1_WSH_REGIONS_TL RT,$$ETLVWDB.EL_CG1_WSH_ZONE_REGIONS Z\r\n       WHERE     R.REGION_ID = RT.REGION_ID\r\n             AND Z.REGION_ID = R.REGION_ID) V,\r\n$$ETLVWDB.EL_CG1_WSH_REGIONS_TL EWT\r\nWHERE EWT.REGION_ID = V.ZONE_ID\r\nAND EWT.LANGUAGE_R = 'US'\r\nGROUP BY 1,2,3\r\n) ECWR\r\nON ECWR.REGION_ID  = SU.REGION_ID\r\nINNER  JOIN $$INVFLMTVWDB.N_SUPPLY_CHAIN_THEATER NSCT ON\r\nSU.ZONE_R = NSCT.BK_SUPPLY_CHAIN_THEATER_NAME\r\nINNER JOIN $$COMREFVWDB.N_ISO_COUNTRY NIC  ON\r\nECWR.COUNTRY_CODE= NIC.ISO_COUNTRY_SHORT_CODE\r\nLEFT JOIN $$INVFLMTVWDB.N_SUPPLY_CHAIN_THEATER_COUNTRY NSCTC ON\r\nNSCTC.BK_SUPPLY_CHAIN_THEATER_NAME=SU.ZONE_R\r\nAND NSCTC.BK_ISO_COUNTRY_CODE=NIC.ISO_COUNTRY_SHORT_CODE",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
