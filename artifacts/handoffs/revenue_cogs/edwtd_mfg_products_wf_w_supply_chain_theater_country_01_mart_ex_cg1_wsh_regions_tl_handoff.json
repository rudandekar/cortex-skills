      "attributes": {
        "Sql Query": "SELECT TMP.LANGUAGE_R,\r\n    TMP.SOURCE_LANG ,\r\n    TMP.REGION_ID,\r\n    TMP.CONTINENT,\r\n    TMP.COUNTRY, \r\n    TMP.COUNTRY_REGION,\r\n    TMP.STATE, \r\n    TMP.CITY, \r\n    TMP.ZONE_R, \r\n    TMP.POSTAL_CODE_FROM, \r\n    TMP.POSTAL_CODE_TO, \r\n    TMP.ALTERNATE_NAME, \r\n    TMP.COUNTY ,\r\n    TMP.CREATED_BY,\r\n    TMP.CREATION_DATE, \r\n    TMP.LAST_UPDATED_BY,\r\n    TMP.LAST_UPDATE_DATE, \r\n    TMP.LAST_UPDATE_LOGIN, \r\n     TMP.GLOBAL_NAME, \r\nTMP.SOURCE_DML_TYPE,\r\nTMP.SOURCE_COMMIT_TIME,\r\nTMP.REFRESH_DATETIME,   \r\n'RI' EXCEPTION_TYPE\r\nFROM (\r\nSELECT\r\nSCWRT.LANGUAGE_R,\r\n    SCWRT.SOURCE_LANG ,\r\n    SCWRT.REGION_ID,\r\n    SCWRT.CONTINENT,\r\n    SCWRT.COUNTRY, \r\n    SCWRT.COUNTRY_REGION,\r\n    SCWRT.STATE, \r\n    SCWRT.CITY, \r\n    SCWRT.ZONE_R, \r\n    SCWRT.POSTAL_CODE_FROM, \r\n    SCWRT.POSTAL_CODE_TO, \r\n    SCWRT.ALTERNATE_NAME, \r\n    SCWRT.COUNTY ,\r\n    SCWRT.CREATED_BY,\r\n    SCWRT.CREATION_DATE, \r\n    SCWRT.LAST_UPDATED_BY,\r\n    SCWRT.LAST_UPDATE_DATE, \r\n    SCWRT.LAST_UPDATE_LOGIN, \r\n     SCWRT.GLOBAL_NAME, \r\nSCWRT.SOURCE_DML_TYPE,\r\nSCWRT.SOURCE_COMMIT_TIME,\r\nSCWRT.REFRESH_DATETIME\r\n  FROM \r\n$$STGDB.ST_CG1_WSH_REGIONS_TL SCWRT,\r\n$$ETLVWDB.EL_CG1_WSH_REGIONS ECWR \r\nWHERE SCWRT.SOURCE_DML_TYPE <> 'DELETE'\r\nAND SCWRT.REGION_ID = ECWR.REGION_ID \r\nAND (\r\nNOT EXISTS (SELECT 1 FROM   $$INVFLMTVWDB.N_SUPPLY_CHAIN_THEATER NSCT\r\nWHERE SCWRT.ZONE_R = NSCT.BK_SUPPLY_CHAIN_THEATER_NAME ) \r\nOR \r\nNOT EXISTS ( SELECT 1 FROM $$COMREFVWDB.N_ISO_COUNTRY NIC \r\nWHERE ECWR.COUNTRY_CODE=NIC.ISO_COUNTRY_SHORT_CODE)\r\n)\r\n) TMP\r\nQUALIFY RANK () OVER (PARTITION BY TMP.REGION_ID,TMP.LANGUAGE_R ORDER BY TMP. REGION_ID, TMP.LANGUAGE_R,TMP.REFRESH_DATETIME DESC ) = 1",
        "User Defined Join": "",
