        "Sql Query": "SELECT FISCAL_QUARTER_NAME,SERVICE_REQUEST_TAC_COST_KEY, MAX(SERVICE_PRODUCT_KEY) SERVICE_PRODUCT_KEY FROM \r\n( SELECT FISCAL_QUARTER_NAME,SERVICE_REQUEST_TAC_COST_KEY, SFH.ITEM_KEY SERVICE_PRODUCT_KEY\r\nFROM $$FINLGLVWDB.N_SR_TECH_ASSISTANCE_CNTR_COST SCTTC\r\nINNER JOIN $$STGDB.WI_CCM_TS_MTH_QTR_CNTL CNTL\r\nON SCTTC.FISCAL_YEAR_MONTH_INT=CNTL.FISCAL_YEAR_MONTH_INT\r\nINNER JOIN ( SELECT SFH.BK_PRODUCT_SUBGROUP_ID, MAX(RPA.ITEM_KEY) ITEM_KEY FROM $$COMREFVWDB.MT_SVC_FINANCE_HIERARCHY SFH\r\nINNER JOIN  ( SELECT RU_BK_SERVICE_PROD_SUBGROUP_ID, MAX(ITEM_KEY) ITEM_KEY, DIVESTITURE_TYPE_CD\r\nFROM $$COMREFVWDB.R_PRODUCTS_ME RPF\r\nINNER JOIN $$COMREFVWDB.R_TRX_PRODUCT RTP\r\nON RTP.PRODUCT_KEY = RPF.ITEM_KEY \r\nAND RPF.DIVESTITURE_TYPE_CD = 'UNKNOWN'   /* ADDED AS PART OF M&A JUN10 Q4FY18*/  GROUP BY 1,3 ) RPA \r\nON RPA.RU_BK_SERVICE_PROD_SUBGROUP_ID = SFH.BK_PRODUCT_SUBGROUP_ID  \r\nWHERE SFH.BK_SERVICE_CATEGORY_ID = 'TECHNICAL SUPPORT SERVICES' \r\nGROUP BY 1 )  SFH\r\nON SFH.BK_PRODUCT_SUBGROUP_ID        = SCTTC.SR_PRODUCT_SUBGROUP_ID\r\nUNION ALL\r\nSELECT FISCAL_QUARTER_NAME,SERVICE_REQUEST_TAC_COST_KEY, SFH.ITEM_KEY SERVICE_PRODUCT_KEY\r\nFROM $$FINLGLVWDB.N_SR_TECH_ASSISTANCE_CNTR_COST SCTTC\r\nINNER JOIN $$STGDB.WI_CCM_TS_MTH_QTR_CNTL CNTL\r\nON SCTTC.FISCAL_YEAR_MONTH_INT=CNTL.FISCAL_YEAR_MONTH_INT\r\nINNER JOIN  ( SELECT ITEM_KEY, DIVESTITURE_TYPE_CD FROM $$COMREFVWDB.R_PRODUCTS_ME RPF\r\nINNER JOIN $$COMREFVWDB.R_TRX_PRODUCT RTP\r\nON RTP.PRODUCT_KEY = RPF.ITEM_KEY\r\nAND RPF.DIVESTITURE_TYPE_CD = 'UNKNOWN'   /* ADDED AS PART OF M&A JUN10 Q4FY18*/ \r\nWHERE BK_PRODUCT_ID = 'TSS-OTHER_ADJ_PROD' )  SFH\r\nON 1 = 1\r\nWHERE NOT EXISTS ( SELECT 1 FROM  ( SELECT SFH.BK_PRODUCT_SUBGROUP_ID, MAX(RPA.ITEM_KEY) ITEM_KEY FROM $$COMREFVWDB.MT_SVC_FINANCE_HIERARCHY SFH\r\nINNER JOIN  ( SELECT RU_BK_SERVICE_PROD_SUBGROUP_ID     , MAX(ITEM_KEY) ITEM_KEY,DIVESTITURE_TYPE_CD\r\n FROM $$COMREFVWDB.R_PRODUCTS_ME RPF\r\nINNER JOIN $$COMREFVWDB.R_TRX_PRODUCT RTP\r\nON RTP.PRODUCT_KEY = RPF.ITEM_KEY\r\nAND  RPF.DIVESTITURE_TYPE_CD = 'UNKNOWN'   /* ADDED AS PART OF M&A JUN10 Q4FY18*/  GROUP BY 1,3 ) RPA \r\nON RPA.RU_BK_SERVICE_PROD_SUBGROUP_ID          = SFH.BK_PRODUCT_SUBGROUP_ID  \r\nWHERE SFH.BK_SERVICE_CATEGORY_ID = 'TECHNICAL SUPPORT SERVICES' \r\nGROUP BY 1 )  SFH WHERE SFH.BK_PRODUCT_SUBGROUP_ID = SCTTC.SR_PRODUCT_SUBGROUP_ID) ) SRC\r\nGROUP BY 1,2",
