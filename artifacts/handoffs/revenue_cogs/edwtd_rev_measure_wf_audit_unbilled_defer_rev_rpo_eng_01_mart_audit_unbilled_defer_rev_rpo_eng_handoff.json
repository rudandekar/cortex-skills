        }
      ],
      "attributes": {
        "Sql Query": "SELECT SRC.PROCESSED_FISCAL_MTH,\r\nABS(ROUND(SRC.REV_RPO_AMT+TGT.UNB_AMT)) AS REV_RPO_MISMATCH ,\r\n'REV_RPO' AS AUDIT_TRXN_TYPE,\r\n'MT_RSTD_UNBILLED_DEFERRED_REV_RPO' AS AUDIT_TABLE,\r\n   Current_Date AS AUDIT_DATE\r\n   FROM \r\n(SELECT         \r\nPROCESSED_FISCAL_MTH                     ,       \r\nSUM( UNBILLED_REVENUE_AMT + DV_NONREC_REV_AMT + BALANCE_REV_USD_AMT ) AS REV_RPO_AMT\r\nFROM $$FINLGLVWDB.MT_RSTD_UNBILLED_DEFERRED_REV_RPO RPO\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nON RFM.FISCAL_YEAR_MONTH_INT = RPO.PROCESSED_FISCAL_MTH\r\nWHERE PREVIOUS_FSCL_MONTH_FLAG = 'Y'\r\nGROUP BY 1) SRC\r\nLEFT JOIN\r\n(\r\nSELECT INNER_QUERY.PROCESSED_FISCAL_MTH,SUM(INNER_QUERY.UNB_AMT) AS UNB_AMT  FROM \r\n(SELECT PROCESSED_FISCAL_MTH,\r\nCAST(SUM(UNBILLED_REVENUE_AMT) AS DECIMAL (26,7))*-1 AS UNB_AMT\r\nFROM $$FINLGLVWDB.MT_RSTD_UNBILLED_REVENUE UNB\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nON RFM.FISCAL_YEAR_MONTH_INT = UNB.PROCESSED_FISCAL_MTH\r\nWHERE PREVIOUS_FSCL_MONTH_FLAG = 'Y'\r\nGROUP BY 1\r\nUNION ALL\r\nSELECT \r\n  PROCESSED_FISCAL_YEAR_MTH_INT AS  PROCESSED_FISCAL_MTH,\r\n  CAST(SUM(BALANCE_REV_USD_AMT ) AS DECIMAL(26,7))*-1 AS UNB_AMT\r\n  FROM \r\n  $$FINLGLVWDB.MT_RSTD_FIN_DEFERRED_REVENUE DEF\r\n  INNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nON RFM.FISCAL_YEAR_MONTH_INT = DEF.PROCESSED_FISCAL_YEAR_MTH_INT\r\nWHERE PREVIOUS_FSCL_MONTH_FLAG = 'Y'\r\nGROUP BY 1)INNER_QUERY\r\nGROUP BY 1) TGT\r\nON SRC.PROCESSED_FISCAL_MTH=TGT.PROCESSED_FISCAL_MTH",
        "User Defined Join": "",
        "Source Filter": "",
