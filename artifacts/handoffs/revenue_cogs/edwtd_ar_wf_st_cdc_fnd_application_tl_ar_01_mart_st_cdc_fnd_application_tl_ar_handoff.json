      "attributes": {
        "Sql Query": "SELECT\t1 AS BATCH_ID,\r\n APPLICATION_ID,\r\n LANG,\r\n APPLICATION_NAME,\r\n CREATED_BY,\r\n CREATION_DATE,\r\n LAST_UPDATED_BY,\r\n LAST_UPDATE_DATE,\r\n LAST_UPDATE_LOGIN,\r\n DESCRIPTION,\r\n SOURCE_LANG ,\r\n SOURCE_COMMIT_TIME\r\n, 'CDC'AS GLOBAL_NAME  \r\n,CURRENT_TIMESTAMP(0)  AS CREATE_DATETIME               \r\n,'I' as ACTION_CODE \r\nFROM\t\r\n(\r\nSELECT * FROM $$NRTACCUMVWDB.CDC_FND_APPLICATION_TL\r\nWHERE\t\r\nLANG = 'US'\r\nAND SOURCE_COMMIT_TIME >= '$$LastExtractDate' \r\nQUALIFY\tROW_NUMBER () OVER (PARTITION BY APPLICATION_ID ,LANG \r\nORDER\tBY REFRESH_DATETIME DESC)=1\r\n)CDC_FND_APPLICATION_TL\r\nWHERE CDC_FND_APPLICATION_TL.SOURCE_DML_TYPE <> 'DELETE'",
