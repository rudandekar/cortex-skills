        "Sql Query": "SELECT EM_ITEM_MASTER.ITEM_MASTER_ID, EM_ITEM_MASTER.PARTNER_ID, EM_ITEM_MASTER.PRODUCT_ID, EM_ITEM_MASTER.REORDER_POINT_QUANTITY, EM_ITEM_MASTER.ROP_SAFETY_STOCK_QUANTITY, EM_ITEM_MASTER.SINGLE_USE_KANBAN_QUANTITY, EM_ITEM_MASTER.CYCLE_TIME_TO_REPLENISH, EM_ITEM_MASTER.MINIMUM_ORDER_QUANTITY, EM_ITEM_MASTER.MINIMUM_PACKAGE_QUANTITY, EM_ITEM_MASTER.LAST_UPDATE, EM_ITEM_MASTER.CREATION_DATE \r\nFROM\r\n EM_ITEM_MASTER\r\nWHERE \r\n EM_ITEM_MASTER.PRODUCT_ID IN ( SELECT DISTINCT SEGMENT1 FROM CG1_MTL_SYSTEM_ITEMS_B )\r\nAND EM_ITEM_MASTER.LAST_UPDATE > '$$LastExtractDate'\r\nAND EM_ITEM_MASTER.PARTNER_ID <> '153804570'",
