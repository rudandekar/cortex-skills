        }
      ],
      "attributes": {
        "Sql Query": "SELECT\t\r\n\tTRIM(TRAILING '-' FROM PRODUCT_TYPE_CLASS_CODE ) AS BK_GTC_PART_CLASS_CD,\r\n\tCOALESCE(SOURCE1,'UNKNOWN') AS SS_CD,\r\n\t(CASE\tWHEN DEACTIVATED_BY IS NULL THEN 'N' ELSE\t'Y' END\t) AS DEACTIVATED_ROLE, \t\r\n\tCOALESCE(DEACTIVATED_DATE,DATE '3500-01-01') AS RU_DEACTIVATED_DT,\r\n\tNCWPCCU.cisco_worker_party_key AS RU_DCTVTD_CISCO_WRKR_PARTY_KEY,\r\n\tCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\n\t \tUSER AS EDW_CREATE_USER, \r\n\t\r\n\tCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n\t\t \tUSER AS EDW_UPDATE_USER,\r\n\t\t\tCOALESCE(NCIC.CUSTOMS_ITEM_SPECIFIC_KEY, -999) AS CUSTOMS_ITEM_SPECIFIC_KEY\r\n\tFROM\t (\t\r\n\tSELECT\t BATCH_ID,\t\tCLASSIFICATION_ATTRIBUTES_ID,\t\r\n\tPRODUCT_TYPE_CLASS_CODE,\t\tPRODUCT_FLAG, \t\tDESCRIPTION,\t\r\n\tSPECIFIC1,\t\tCOMMENTS, \t\tATTRIBUTE1,\t\tATTRIBUTE2,\t\tATTRIBUTE3,\t\r\n\tDEACTIVATED_BY,\t\tDEACTIVATED_DATE,\t\tCREATED_BY,\t\tCREATED_DATE,\t\t\r\n\tMODIFIED_BY,\t\tMODIFIED_DATE,\t\tSOURCE1,\r\n\t\t\tCREATE_DATETIME,\t\t\r\n\tACTION_CODE\t,SPECIFIC_ID\r\n\tFROM\t$$STGDB.ST_XXCFI_CB_TYPE_SPECIFIC\r\n\t\tWHERE\tPRODUCT_FLAG = 'C'\r\n\t\tAND SOURCE1 <> 'CISCO'\r\n\t\tAND TRIM(TRAILING '-' FROM PRODUCT_TYPE_CLASS_CODE ) IN \r\n\t\t(\r\nSELECT NGPC.GTC_PART_CLASS_CD      FROM   $$FINLGLVWDB.N_GTC_PART_CLASS NGPC\r\n)\r\n\t\t\r\n\tUNION ALL\t\r\n\tSELECT\tBATCH_ID,\t\tCLASSIFICATION_ATTRIBUTES_ID,\t\t\r\n\tPRODUCT_TYPE_CLASS_CODE,\t\tPRODUCT_FLAG, \t\tDESCRIPTION,\r\n\tSPECIFIC1,\t\tCOMMENTS, \t\tATTRIBUTE1,\t\tATTRIBUTE2,\t\tATTRIBUTE3,\t\t\r\n\tDEACTIVATED_BY,\t\tDEACTIVATED_DATE,\t\tCREATED_BY,\t\tCREATED_DATE,\t\t\r\n\tMODIFIED_BY,\t\tMODIFIED_DATE,\t\tSOURCE1,\t\tCREATE_DATETIME,\t\t\r\n\tACTION_CODE,SPECIFIC_ID\tFROM\t $$EXCEPDB.EX_XXCFI_CB_TYPE_SPECIFIC\r\n\tWHERE\tPRODUCT_FLAG = 'C'\tAND\tEXCEPTION_TYPE = 'RI' \r\n\tAND SOURCE1 <> 'CISCO'\r\nAND TRIM(TRAILING '-' FROM PRODUCT_TYPE_CLASS_CODE ) IN \r\n\t\t\r\n(\r\nSELECT NGPC.GTC_PART_CLASS_CD      FROM   $$FINLGLVWDB.N_GTC_PART_CLASS NGPC\r\n)\r\n\t) SXCTS\r\n\t\r\n\tINNER JOIN $$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC NCIC\r\n\tON NCIC.SK_SPECIFIC_ID_INT = SXCTS.SPECIFIC_ID\t\r\n\tINNER JOIN  $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWPTV\t\r\n\tON\t(NCWPTV.CEC_ID= COALESCE(SXCTS.DEACTIVATED_BY,'UNKNOWN'))\r\n\tINNER JOIN $$FINLGLVWDB.N_CSC_WRKR_PRTY_CSTMS_CUBE_USR NCWPCCU\r\n\tON (NCWPCCU.CISCO_WORKER_PARTY_KEY = NCWPTV.CISCO_WORKER_PARTY_KEY)\r\n\tWHERE\t1=1\tAND\r\n\tNOT EXISTS  \r\n\t(\tSELECT\t1\tFROM\t\r\n\t$$FINLGLVWDB.N_ITEM_SPCFC_GTC_PRT_CLASS_LNK\tNISGPC\r\n\tINNER JOIN $$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC NCIC1\r\n\tON NISGPC.CUSTOMS_ITEM_SPECIFIC_KEY     = NCIC1.CUSTOMS_ITEM_SPECIFIC_KEY     \r\n\tAND\tNCIC1.SK_SPECIFIC_ID_INT =  SXCTS.SPECIFIC_ID\t\r\n\tAND\tTRIM(TRAILING '-' FROM SXCTS.PRODUCT_TYPE_CLASS_CODE ) =  BK_GTC_PART_CLASS_CD  \r\n\t)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
