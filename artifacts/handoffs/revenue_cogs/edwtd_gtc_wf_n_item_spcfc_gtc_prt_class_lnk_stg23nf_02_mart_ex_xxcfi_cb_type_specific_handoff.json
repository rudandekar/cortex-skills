        "Sql Query": "SELECT\t\tBATCH_ID,\tCLASSIFICATION_ATTRIBUTES_ID,\tPRODUCT_TYPE_CLASS_CODE,\tPRODUCT_FLAG,\tDESCRIPTION,\tSPECIFIC1,\tCOMMENTS,\r\nATTRIBUTE1,\tATTRIBUTE2,\tATTRIBUTE3,\tDEACTIVATED_BY,\tDEACTIVATED_DATE,\tCREATED_BY,\tCREATED_DATE,\t\r\nMODIFIED_BY,\tMODIFIED_DATE,\tSOURCE1,\tCREATE_DATETIME,\tACTION_CODE,\t'RI' EXCEPTION_TYPE ,\r\nSPECIFIC_ID\r\nFROM\t\r\n$$STGDB.ST_XXCFI_CB_TYPE_SPECIFIC SXCTS WHERE\tPRODUCT_FLAG = 'C'\r\nAND \tSOURCE1<>'CISCO'\r\nAND NOT EXISTS\r\n\t(\tSELECT 1\tFROM   $$FINLGLVWDB.N_GTC_PART_CLASS  NGPC,\t$$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC NCIC,\t\r\n\t(SELECT \t\tNCWPCCU.CISCO_WORKER_PARTY_KEY, \t\tNCWPTV1.CEC_ID\tFROM $$FINLGLVWDB.N_CSC_WRKR_PRTY_CSTMS_CUBE_USR NCWPCCU\t\t\r\n\tINNER JOIN  $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWPTV1\t\tON NCWPCCU.CISCO_WORKER_PARTY_KEY = NCWPTV1.CISCO_WORKER_PARTY_KEY\r\n\t\t)\r\n\tNCWPTV\t\r\n\tWHERE \t( TRIM(TRAILING '-' FROM SXCTS.PRODUCT_TYPE_CLASS_CODE ) = NGPC.GTC_PART_CLASS_CD)\r\n\t\tAND NCIC.SK_SPECIFIC_ID_INT = SXCTS.SPECIFIC_ID\tAND (NCWPTV.CEC_ID= COALESCE(SXCTS.DEACTIVATED_BY,'UNKNOWN'))\t)",
