      "attributes": {
        "Sql Query": "SELECT\r\nBK_PART_CLASS_CD              ,\r\nSS_CD                         ,\r\nDEACTIVATED_ROLE              ,\r\nRU_DEACTIVATED_DT             ,\r\nRU_DCTVTD_CISCO_WRKR_PARTY_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER \t\t\t\t AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER \t\t\t\t AS EDW_UPDATE_USER,\r\nCUSTOMS_ITEM_SPECIFIC_KEY \r\nFROM $$FINLGLVWDB.N_ITEM_SPECIFIC_PRT_CLASS_LINK NISPCL\r\nWHERE NOT EXISTS\r\n(\r\nSELECT 1\r\n  FROM $$FINLGLVWDB.N_ITEM_SPCFC_GTC_PRT_CLASS_LNK NISGPCL\r\n WHERE NISGPCL.CUSTOMS_ITEM_SPECIFIC_KEY      = NISPCL.CUSTOMS_ITEM_SPECIFIC_KEY     \r\n   AND NISGPCL.BK_GTC_PART_CLASS_CD = NISPCL.BK_PART_CLASS_CD\r\n   AND NISGPCL.BK_SS_CD = 'CISCO'\r\n)",
        "User Defined Join": "",
        "Source Filter": "",
