        "Pre SQL": "DELETE  FROM $$STGDB.WI_RMA_ENDCUST_IB_MAP  WHERE FISCAL_QUARTER_NAME IN ( SELECT FISCAL_QUARTER_NAME FROM $$STGDB.WI_CCM_TS_MTH_QTR_CNTL);\r\n\r\nCREATE MULTISET VOLATILE TABLE EC_RMA_IB_BASED AS \r\n(\r\nSELECT * FROM \r\n(SELECT RMA.BK_REPAIR_ORDER_NUM_INT ,CNTL.FISCAL_QUARTER_NAME,RMA.FISCAL_YEAR_MONTH_INT,\r\nCOALESCE(RMA_DTL.BK_CUST_RPRTD_PRD_SERIAL_NUM,000000) AS BK_CUST_RPRTD_PRD_SERIAL_NUM,\r\nROW_NUMBER() OVER (PARTITION BY RMA_LINE.BK_REPAIR_ORDER_NUM_INT ORDER BY RMA_DTL.EDW_CREATE_DTM DESC) SL_NUM\r\nFROM $$FINLGLVWDB.N_SR_SRVC_SUPPORT_CENTER_COST RMA\r\nINNER JOIN $$STGDB.WI_CCM_TS_MTH_QTR_CNTL CNTL\r\nON CNTL.FISCAL_YEAR_MONTH_INT = RMA.FISCAL_YEAR_MONTH_INT\r\nLEFT JOIN (\r\n\tSELECT BK_REPAIR_ORDER_NUM_INT,REPAIR_ORDER_LINE_KEY\r\n\tFROM $$SERVICEVWDB.N_REPAIR_ORDER_LINE \r\n\tWHERE BK_REPAIR_ORDER_NUM_INT IN (SELECT BK_REPAIR_ORDER_NUM_INT FROM $$FINLGLVWDB.N_SR_SRVC_SUPPORT_CENTER_COST WHERE FISCAL_YEAR_MONTH_INT IN( SELECT\tFISCAL_YEAR_MONTH_INT  FROM\t$$STGDB.WI_CCM_TS_MTH_QTR_CNTL)\r\n\t GROUP BY 1) \r\n\tQUALIFY ROW_NUMBER() OVER (PARTITION BY BK_REPAIR_ORDER_NUM_INT ORDER BY REPAIR_ORDER_LINE_KEY  DESC)=1\r\n)RMA_LINE \r\nON RMA_LINE.BK_REPAIR_ORDER_NUM_INT=RMA.BK_REPAIR_ORDER_NUM_INT\t\t\r\nLEFT JOIN $$SERVICEVWDB.N_REPAIR_ORDER_LINE_RTRN_DTL RMA_DTL ON RMA_DTL.REPAIR_ORDER_LINE_KEY=RMA_LINE.REPAIR_ORDER_LINE_KEY    \r\nWHERE\tRMA.FISCAL_YEAR_MONTH_INT IN( SELECT\tFISCAL_YEAR_MONTH_INT  FROM\t$$STGDB.WI_CCM_TS_MTH_QTR_CNTL)                       \r\nGROUP BY 1,2,3,4,RMA_LINE.BK_REPAIR_ORDER_NUM_INT,RMA_DTL.EDW_CREATE_DTM\r\n) A \r\n)  WITH DATA ON COMMIT PRESERVE ROWS; \r\n\r\nCOLLECT STATS ON EC_RMA_IB_BASED COLUMN ( FISCAL_YEAR_MONTH_INT);\r\nCOLLECT STATS ON EC_RMA_IB_BASED COLUMN ( BK_REPAIR_ORDER_NUM_INT);\r\nCOLLECT STATS ON EC_RMA_IB_BASED COLUMN ( BK_CUST_RPRTD_PRD_SERIAL_NUM);\r\n\r\n\r\n\r\nINSERT INTO $$STGDB.WI_RMA_ENDCUST_IB_MAP\r\nSELECT\t\t\t\t\t\t\t\t\t\r\nCTRL.FISCAL_QUARTER_NAME\r\n,RMA.FISCAL_YEAR_MONTH_INT\r\n,BK_REPAIR_ORDER_NUM_INT \r\n,ENDCUST.GU_PRIMARY_NAME AS DV_END_CUSTOMER_NAME\r\n,ROW_NUMBER() OVER (PARTITION BY BK_REPAIR_ORDER_NUM_INT ORDER BY IB.INSTALLED_CUSTOMER_PARTY_KEY DESC) SL_NUM\r\n,CAST(COUNT(BK_REPAIR_ORDER_NUM_INT) OVER (PARTITION BY BK_REPAIR_ORDER_NUM_INT,RMA.FISCAL_YEAR_MONTH_INT) AS BIGINT )NO_OF_END_CUST\r\nFROM EC_RMA_IB_BASED RMA\t\t\t\t\t\t\t\t\t\r\nLEFT JOIN (SEL DU_BK_SERIAL_NUM,INSTALLED_CUSTOMER_PARTY_KEY,IP_SALES_TERRITORY_KEY,BILL_TO_ERP_CUST_ACCT_LOC_KEY,SHIP_TO_ERP_CUST_ACCT_LOC_KEY FROM \r\n$$IBVWDB.N_INSTALLED_PRODUCT WHERE DU_BK_SERIAL_NUM IN(SEL BK_CUST_RPRTD_PRD_SERIAL_NUM FROM EC_RMA_IB_BASED GROUP BY 1)\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY DU_BK_SERIAL_NUM ORDER BY IP_KEY  DESC)=1) IB \r\nON IB.DU_BK_SERIAL_NUM=RMA.BK_CUST_RPRTD_PRD_SERIAL_NUM  \t\t\t\t\t\t\t\t\t\r\nINNER JOIN $$COMREFVWDB.MT_ENDCUST_CUSTOMER_PARTY_HIER ENDCUST \r\nON ENDCUST.END_CUSTOMER_KEY=IB.INSTALLED_CUSTOMER_PARTY_KEY\r\nINNER JOIN $$STGDB.WI_CCM_TS_MTH_QTR_CNTL CTRL\r\nON  RMA.FISCAL_YEAR_MONTH_INT=CTRL.FISCAL_YEAR_MONTH_INT\r\nGROUP BY 1,2,3,4, BK_REPAIR_ORDER_NUM_INT,INSTALLED_CUSTOMER_PARTY_KEY;",
