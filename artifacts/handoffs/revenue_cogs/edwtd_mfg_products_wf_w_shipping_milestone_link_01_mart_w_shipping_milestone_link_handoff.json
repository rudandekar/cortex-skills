      "attributes": {
        "Sql Query": "SELECT\r\nWSMT.SMT_KEY,\r\nWSMT.INTER_EVENT_DRTN_SECONDS_CNT,\r\nWSMT.SSMT_KEY,\r\nCURRENT_TIMESTAMP(0)  AS EDW_CREATE_DTM,\r\nUSER  AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' AS ACTION_CODE,\r\n(CASE WHEN NSML.SMT_KEY IS  NULL THEN 'I' ELSE 'U' END) AS DML_TYPE\r\nFROM\r\n(\r\nSELECT \r\nSSMTA.SHIPPING_MILESTONE_TYPE_KEY AS SMT_KEY,\r\nSSMT.INTER_EVENT_DRTN_SECONDS_CNT,\r\nSSMTB.SHIPPING_MILESTONE_TYPE_KEY AS SSMT_KEY\r\nFROM \r\n$$STGDB.ST_SHIPPING_MILESTONE_TYPE SSMT\r\nINNER JOIN  $$ETLVWDB.SM_SHIPPING_MILESTONE_TYPE  SSMTA ON\r\nSSMTA.SK_GID_ID = SSMT.SK_GID_ID \r\nINNER JOIN \r\n$$ETLVWDB.SM_SHIPPING_MILESTONE_TYPE SSMTB ON\r\nSSMTB.SK_GID_ID = SSMT.SK_GID_SUCC_ID) WSMT\r\nLEFT JOIN \r\n$$INVFLMTVWDB.N_SHIPPING_MILESTONE_LINK NSML ON \r\nNSML.SMT_KEY = WSMT.SMT_KEY",
        "User Defined Join": "",
