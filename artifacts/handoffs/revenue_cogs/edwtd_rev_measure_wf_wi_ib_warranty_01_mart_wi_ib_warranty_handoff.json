      ],
      "attributes": {
        "Sql Query": "SELECT \r\nBE.BUSINESS_ENTITY_DESCR ,\r\nSUM(InW_InC) AS InWInC,SUM(InW_MC) AS InWMC,SUM(InW_OoC) AS InWOoC,\r\nSUM(MW_InC) AS MWInC,SUM(MW_MC) AS MWMC,SUM(MW_OoC) AS MWOoC,\r\nSUM(OoW_InC) AS OoWInC,SUM(OoW_MC) AS OoWMC,\r\nCAST((CAST (InWInC+InWMC+InWOoC+MWOoC+MWMC AS DECIMAL(38,6))\r\n/ CAST((InWInC+InWMC+InWOoC+MWOoC+MWMC+MWInC+OoWInC+OoWMC)AS DECIMAL(38,6))) AS DECIMAL(38,6)) AS IB_RATIO\r\nFROM \r\n$$STGDB.ST_IB_WARRANTY IB\r\nLEFT JOIN $$STGDB.WI_PF_BE BE\r\nON IB.GPI_PRODUCT_CODE = BE.PF\r\nGROUP BY 1",
        "User Defined Join": "",
