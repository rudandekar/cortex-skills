      ],
      "attributes": {
        "Sql Query": "SELECT\r\n NATL.AR_TRX_LINE_KEY,\r\n NAT.AR_TRX_KEY,\r\n NABS.BK_BATCH_SOURCE_NAME,\r\n EORCTL.INTERFACE_LINE_ATTRIBUTE10,\r\n CASE WHEN EORCTL.INTERFACE_LINE_ATTRIBUTE10 IN ('SPECIAL_DEBIT','SPECIAL_CREDIT','SPECIAL_INVOICE') THEN 'Y' ELSE 'N' END as NON_REF_TRX_FLAG,\r\n 'N' as IS_EXISTS_IN_XAAS_SC_FLAG,\r\n CURRENT_TIMESTAMP(0) AS EDW_CREATE_DATETIME,\r\n CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DATETIME\r\nFROM\r\n( SELECT RU_AR_TRANSACTION_LINE_KEY FROM $$STGDB.WI_REV_SCA_NRT_SNAP_TV WHERE RU_AR_TRANSACTION_LINE_KEY > 0 GROUP BY 1 ) ERP \r\n INNER JOIN $$FINLGLVWDB.N_AR_TRX_LINE NATL\r\n   ON ERP.RU_AR_TRANSACTION_LINE_KEY = NATL.AR_TRX_LINE_KEY\r\n INNER JOIN $$FINLGLVWDB.N_AR_TRX NAT\r\n   ON NATL.AR_TRX_KEY=NAT.AR_TRX_KEY\r\n INNER JOIN $$FINLGLVWDB.N_AR_BATCH_SOURCE NABS\r\n   ON NAT.AR_BATCH_SOURCE_KEY = NABS.AR_BATCH_SOURCE_KEY\r\n INNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC \r\n   ON NATL.SS_CODE = NSSC.SOURCE_SYSTEM_CODE\r\n INNER JOIN $$ETLVWDB.EL_OM_RA_CUST_TRX_LINES EORCTL\r\n   ON  EORCTL.CUSTOMER_TRX_LINE_ID = NATL.SK_CUSTOMER_TRX_LINE_ID_LINT\r\n   AND EORCTL.GLOBAL_NAME = NSSC.GLOBAL_NAME\r\n WHERE 1=1 \r\n  AND ( NABS.BK_BATCH_SOURCE_NAME LIKE ANY ('%XAAS%','CSP-MARKETPLACE','SAAS-RIMG-ONL','BSFT-ORDERS','CBM-OPL-CLOUD')  /* 'SAAS-RIMG-ONL','BSFT-ORDERS' -- Added as part BSFT Q1FY21 Release*/\r\n\r\n    OR (NABS.BK_BATCH_SOURCE_NAME IN ('ORDER MANAGEMENT','ICMS-ADJ') AND NATL.TRX_LINE_SRC_NAME LIKE ANY ('%XAAS%')) /*Added As part of TNC Feb 2020 Release*/ \r\n\tOR (NABS.BK_BATCH_SOURCE_NAME IN ('ICMS-ADJ') AND NATL.ORIGIN_SOURCE_CD IN ('BSFT-OPL','CBM-OPL-ICMS'))/*Added as part BSFT Q1FY21 Release*/\r\n\t)\r\n  AND EORCTL.INTERFACE_LINE_ATTRIBUTE10 IN ('SPECIAL_DEBIT','SPECIAL_CREDIT','SPECIAL_INVOICE')\r\n  AND NOT EXISTS ( SELECT 1 FROM $$ETLVWDB.EL_XAAS_TRX_FROM_ERP_SC EL WHERE EL.AR_TRX_LINE_KEY = ERP.RU_AR_TRANSACTION_LINE_KEY )",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
