      "attributes": {
        "Sql Query": "SELECT \r\nWICNQRT.CNTRB_MRGN_COST_ACTL_LN_KEY   \t,\r\nWICNQRT.BK_FISCAL_YEAR_NUMBER_INT     \t,\r\nWICNQRT.BK_FISCAL_MONTH_NUMBER_INT    \t,\r\nWICNQRT.BK_PRODUCT_KEY                \t,\r\nWICNQRT.CNTRB_MRGN_ACTL_LN_USD_AMT    \t,\r\nWICNQRT.EDW_CREATE_USER               \t,\r\nWICNQRT.EDW_CREATE_DTM                \t,\r\nWICNQRT.EDW_UPDATE_USER               \t,\r\nWICNQRT.EDW_UPDATE_DTM                \t       \t\r\nFROM $$STGDB.WI_CNTRB_CURR_LAST_QRTR WICNQRT\r\nWHERE (BK_FISCAL_YEAR_NUMBER_INT*100+ BK_FISCAL_MONTH_NUMBER_INT) NOT IN(\r\nSELECT (BK_FISCAL_YEAR_NUMBER_INT*100+ BK_FISCAL_MONTH_NUMBER_INT)  \t\r\nFROM $$STGDB.WI_CNTRB_CURR_LAST_QRTR WICNQRT1\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMY\r\nON( (BK_FISCAL_YEAR_NUMBER_INT*100+ BK_FISCAL_MONTH_NUMBER_INT) = RFMY.FISCAL_YEAR_MONTH_INT\r\nAND  CURRENT_FISCAL_QTR_FLAG='Y')\r\n)\r\nAND WICNQRT.BK_PRODUCT_KEY NOT IN ( SELECT HANDSHAKE_BUNDLE_PRODUCT_KEY  FROM $$INVFLMTVWDB.N_HNDSHK_BUNDLE_PRODUCT\r\nWHERE BK_ALLOCATION_TYPE_CD='ACTUAL')",
