      "attributes": {
        "Sql Query": "SELECT                      \r\nSXCRD.COUNTRY_GROUP_CODE AS BK_WORLD_COUNTRY_GROUP_CD,          \r\nNHCR.HTS_CLASSIFICATION_RULE_KEY AS HTS_CLASSIFICATION_RULE_KEY,    \r\nSXCRD.HTS_CODE AS BK_HRMNZD_TARIFF_SCHEDULE_CD  ,                                    \r\nSXCRD.RULE_STATUS AS BK_HTS_CLSFCTN_RULE_STATUS_CD ,                \r\nHTSC.BK_HTS_EFFECTIVE_START_DT AS BK_HTS_EFFECTIVE_START_DT ,\r\nHTSC.BK_ISO_COUNTRY_CD AS BK_ISO_COUNTRY_CD  ,           \r\nHTSC.BK_ACTIVE_FLG  AS BK_ACTIVE_FLG ,\r\nCASE WHEN ACTIVE_FLAG='N' THEN 'Y' ELSE 'N' END AS SOURCE_DELETED_FLG,   \r\nCURRENT_TIMESTAMP(0)  AS EDW_CREATE_DTM ,  \r\nUSER EDW_CREATE_USER ,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,   \r\nUSER EDW_UPDATE_USER,  \r\nSXCRD.START_DATE AS START_TV_DTM,\r\nCOALESCE(CAST(SXCRD.END_DATE AS TIMESTAMP(0)), TIMESTAMP  '3500-01-01 00:00:00'  ) END_TV_DTM,\r\n'I' ACTION_CODE ,                  \r\nCASE WHEN NTV.HTS_CLASSIFICATION_RULE_KEY IS NULL OR NTV.BK_WORLD_COUNTRY_GROUP_CD IS NULL THEN 'I'\r\nELSE 'U' END AS  DML_TYPE\r\nFROM \r\n(\r\nSELECT RULE_ID,\r\n\t   COUNTRY_GROUP_CODE,\r\n\t   HTS_CODE,\r\n\t   RULE_STATUS,\r\n\t   START_DATE,\r\n\t   END_DATE,\r\n\t   ACTIVE_FLAG,\r\n\t   CREATE_DATETIME\r\nFROM  $$STGDB.ST_XXCFI_CB_RULE_DETAILS \r\nUNION ALL\r\nSELECT RULE_ID,\r\n\t   COUNTRY_GROUP_CODE,\r\n\t   HTS_CODE,\r\n\t   RULE_STATUS,\r\n\t   START_DATE,\r\n\t   END_DATE,\r\n\t   ACTIVE_FLAG,\r\n\t   CREATE_DATETIME\r\nFROM  $$EXCEPDB.EX_XXCFI_CB_RULE_DETAILS \r\n) SXCRD\r\n\r\nINNER JOIN $$FINLGLVWDB.N_HTS_CLASSIFICATION_RULE NHCR \r\nON (NHCR.SK_RULE_ID_INT = SXCRD.RULE_ID)\r\n\r\nINNER JOIN $$FINLGLDB.N_WORLD_COUNTRY_GROUP NWCG\r\nON NWCG.BK_WORLD_COUNTRY_GROUP_CD = SXCRD.COUNTRY_GROUP_CODE\r\n\r\nINNER JOIN $$FINLGLDB.N_HTS_CLSFCTN_RULE_STATUS NHCRS\r\nON NHCRS.BK_HTS_CLSFCTN_RULE_STATUS_CD =SXCRD.RULE_STATUS\r\n\r\nINNER JOIN  \r\n(\r\n SELECT HTS.BK_HRMNZD_TARIFF_SCHEDULE_CD,HTS.BK_ISO_COUNTRY_CD,HTS.BK_ACTIVE_FLG,HTS.BK_HTS_EFFECTIVE_START_DT, HTS.HTS_EFFECTIVE_END_DT,ECCM.COUNTRY_GROUP_CODE AS COUNTRY_GROUP_CODE\r\n FROM $$FINLGLVWDB.N_HRMNZD_TRF_SCHDL_CNTRY_LNK HTS\r\n INNER JOIN $$COMREFVWDB.N_ISO_COUNTRY NIC\r\n ON (HTS.BK_ISO_COUNTRY_CD = NIC.BK_ISO_COUNTRY_CODE)\r\n INNER JOIN $$ETLVWDB.EL_CTRYGRP_CTRY_MAPPING ECCM\r\n ON (NIC.ISO_COUNTRY_SHORT_CODE=ECCM.COUNTRY_CODE)\r\n QUALIFY ROW_NUMBER() OVER (PARTITION BY HTS.BK_HRMNZD_TARIFF_SCHEDULE_CD,ECCM.COUNTRY_GROUP_CODE ORDER BY HTS.BK_HTS_EFFECTIVE_START_DT DESC)=1\r\n)  HTSC\r\n\r\nON (HTSC.COUNTRY_GROUP_CODE= COALESCE(SXCRD.COUNTRY_GROUP_CODE,'UN')\r\nAND HTSC.BK_HRMNZD_TARIFF_SCHEDULE_CD=SXCRD.HTS_CODE \r\n)     \r\n  \r\nLEFT JOIN  $$FINLGLVWDB.N_HTS_CLFTN_RL_CNTY_GRP_LNK_TV NTV\r\nON NHCR.HTS_CLASSIFICATION_RULE_KEY = NTV.HTS_CLASSIFICATION_RULE_KEY\r\nAND SXCRD.COUNTRY_GROUP_CODE = NTV.BK_WORLD_COUNTRY_GROUP_CD\r\nAND CAST(SXCRD.START_DATE AS TIMESTAMP(0)) = NTV.START_TV_DTM\r\nAND NTV.END_TV_DTM = '3500-01-01 00:00:00'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY SXCRD.RULE_ID,SXCRD.COUNTRY_GROUP_CODE,SXCRD.START_DATE ORDER BY COALESCE(SXCRD.END_DATE,TIMESTAMP'3500-01-01 00:00:00') DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
