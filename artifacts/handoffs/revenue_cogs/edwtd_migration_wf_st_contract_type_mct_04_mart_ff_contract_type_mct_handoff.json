      "attributes": {
        "Sql Query": "select cvg.coverage_template_name Service_type,bp.pillar_desc Pillar, bp.business_process_name business_process\r\nfrom xxccs_o.xxccs_ds_master_cvg_template cvg\r\n,xxccs_o.xxccs_ds_master_cvg_template bp\r\n,(SELECT lookup_code,meaning ent_key FROM   fnd_lookup_values\r\nWHERE  lookup_type ='XXCSS_SA_BUS_PRC_CUST_SEG_TIER'\r\nAND    enabled_flag ='Y' AND    NVL(start_date_active,SYSDATE)<=SYSDATE AND    NVL(end_date_active,SYSDATE+1)>SYSDATE) high\r\n,(SELECT lookup_code,meaning ent_key FROM   fnd_lookup_values\r\nWHERE  lookup_type ='XXCSS_SA_BUS_PRC_CUST_SEG_TIER'\r\nAND    enabled_flag ='Y' AND    NVL(start_date_active,SYSDATE)<=SYSDATE AND    NVL(end_date_active,SYSDATE+1)>SYSDATE) Med\r\n,(SELECT lookup_code,meaning ent_key FROM   fnd_lookup_values WHERE  lookup_type ='XXCSS_SA_BUS_PRC_CUST_SEG_TIER'\r\nAND    enabled_flag ='Y' AND    NVL(start_date_active,SYSDATE)<=SYSDATE AND    NVL(end_date_active,SYSDATE+1)>SYSDATE) low\r\nwhere 1=1 and bp.business_process_cle_id = cvg.coverage_template_line_id and high.lookup_code(+)= bp.attribute5 and med.lookup_code(+)= bp.attribute4 and low.lookup_code(+)= bp.attribute3\r\norder by cvg.coverage_template_name",
