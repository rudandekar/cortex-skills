      "attributes": {
        "Sql Query": "SEL \r\nCAST (ORGANIZATION_ID AS BIGINT)     ,          \r\nORGANIZATION_NAME        ,     \r\nORGANIZATION_CODE         ,    \r\nDATE_FROM                  ,   \r\nCOALESCE(DATE_TO, DATE '3500-01-01'),\r\n'OOD' AS OPERATING_UNIT_TYPE_CD ,       \r\nACTION_CODE,\r\n'UNKNOWN' as BK_BUS_ENTITY_ORG_NAME_CODE,\r\n'UNKNOWN' as OPERATING_UNIT_SHORT_NAME        \r\nFROM $$STGDB.ST_OOD_HR_ALL_ORG_UNITS\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY ORGANIZATION_ID ORDER BY LAST_UPDATE_DATE DESC)=1\r\n\r\nUNION ALL\r\n\r\nSELECT\r\nORGANIZATION_ID\t\t,\r\nORGANIZATION_NAME\t,\r\nORGANIZATION_CODE\t,\r\nDATE_FROM\t\t\t,\r\nCOALESCE(DATE_TO, DATE '3500-01-01'),\r\n'OOD' AS OPERATING_UNIT_TYPE_CD,\r\nACTION_CODE,\r\n'UNKNOWN' as BK_BUS_ENTITY_ORG_NAME_CODE,\r\n'UNKNOWN' as OPERATING_UNIT_SHORT_NAME  \r\nFROM $$STGDB.ST_OOD_FUSN_HR_ALL_ORG_UNITS\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY ORGANIZATION_ID ORDER BY LAST_UPDATE_DATE DESC)=1",
