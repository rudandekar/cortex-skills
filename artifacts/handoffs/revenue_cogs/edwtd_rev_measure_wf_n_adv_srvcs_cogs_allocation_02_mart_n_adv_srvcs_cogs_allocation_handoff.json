      "attributes": {
        "Sql Query": "SELECT \r\n DV_GOODS_PRDT_KEY BK_PRODUCT_KEY,\r\nDV_GOODS_PRDT_KEY PRODUCT_KEY,\r\n-9999 SALES_ORDER_KEY,\r\n-9999 SK_OFFER_ATTRIBUTION_ID_INT,\r\nCAST (TRIM(COALESCE(DV_GOODS_PRDT_KEY,-999)) || '~' || TRIM(COALESCE(DV_GOODS_PRDT_KEY,-999)) || '~' ||-9999|| '~' ||-9999 AS VARCHAR(70))  DV_RECURRING_OFFER_CD\r\nFROM \r\n$$WORKDB.W_ADV_SRVCS_COGS_ALLOCATION NCSCA \r\nINNER JOIN\r\n$$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMT\r\nON NCSCA.BK_FISCAL_YEAR_NUM_INT = RFMT.FISCAL_YEAR_NUMBER_INT\r\nAND NCSCA.BK_FISCAL_MONTH_NUM_INT  = RFMT.FISCAL_MONTH_NUMBER_INT\r\nWHERE RFMT.FISCAL_YEAR_AGE  IN (0,1,2,3)\r\nAND NCSCA.BK_REVENUE_OR_COGS_TYPE_CD = 'COGS'\r\nAND DV_RECURRING_OFFER_CD NOT IN (\r\nSELECT DV_RECURRING_OFFER_CD FROM $$FINLGLVWDB.MT_RECURRING_OFFER_REVENUE)\r\nGROUP BY 1,2,DV_RECURRING_OFFER_CD",
