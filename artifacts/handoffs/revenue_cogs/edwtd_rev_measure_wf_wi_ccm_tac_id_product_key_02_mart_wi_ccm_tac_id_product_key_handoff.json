        "Sql Query": "SELECT \r\nAMOUNT_BY_SBE.SUB_BUSINESS_ENTITY_NAME,\r\nCOALESCE(BE_ITEM_MAP.PRODUCT_KEY  ,6190028),\r\nSBE_AMOUNT / SUM( SBE_AMOUNT ) OVER ( PARTITION BY AMOUNT_BY_SBE.FISCAL_QUARTER_ID ) BE_RATIO\r\nFROM\r\n( \r\nSELECT\r\nBE_ALLOC.DV_FISCAL_QUARTER_ID FISCAL_QUARTER_ID,     \r\n CNTL.FISCAL_YEAR_MONTH_INT         ,\r\nBE_ALLOC.BK_SUB_BUSINESS_ENTITY_NAME SUB_BUSINESS_ENTITY_NAME,\r\nSUM((TAC_OVERHEAD_COST_USD_AMT+TAC_BACKBONE_COST_USD_AMT+TAC_OUT_TASKING_COST_AMT+TAC_THTR_BIZ_OPRTN_CST_USD_AMT) * PRDT_FAMILY_ALLOCATION_PCT)  SBE_AMOUNT\r\nFROM $$STGDB.WI_CCM_TAC_ID_PRODUCT_KEY WITAC\r\n\r\nINNER JOIN $$FINLGLVWDB.N_SR_TECH_ASSISTANCE_CNTR_COST SCTSC\r\nON SCTSC.SERVICE_REQUEST_TAC_COST_KEY=WITAC.SERVICE_REQUEST_TAC_COST_KEY\r\n\r\nINNER JOIN $$STGDB.WI_CCM_TS_MTH_QTR_CNTL CNTL\r\nON  CNTL.FISCAL_QUARTER_NAME=WITAC.FISCAL_QUARTER_NAME\r\n\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_QUARTER_TO_YEAR RFM\r\nON RFM.FISCAL_QUARTER_NAME=CNTL.FISCAL_QUARTER_NAME\r\n\r\nINNER JOIN  $$COMREFDB.MT_BE_HIER_PRDT_FAMILY_ALLOC BE_ALLOC\r\nON WITAC.GOODS_PRODUCT_KEY=BE_ALLOC.ITEM_KEY\r\nAND BE_ALLOC.DV_FISCAL_QUARTER_ID=RFM.DV_FISCAL_QUARTER_ID\r\nAND BE_ALLOC.BK_BUSINESS_ENTITY_TYPE_CD    ='I'\r\n\r\nGROUP BY \r\nBE_ALLOC.DV_FISCAL_QUARTER_ID ,\r\n CNTL.FISCAL_YEAR_MONTH_INT         ,\r\nBE_ALLOC.BK_SUB_BUSINESS_ENTITY_NAME\r\n\r\nHAVING SBE_AMOUNT <>0.00000000\r\n) \r\nAMOUNT_BY_SBE\r\nLEFT JOIN $$FINLGLVWDB.N_SVC_GM_BY_BE  BE_ITEM_MAP ON  BE_ITEM_MAP.BK_SUB_BUSINESS_ENTITY_NAME    = AMOUNT_BY_SBE.SUB_BUSINESS_ENTITY_NAME\r\nAND (BE_ITEM_MAP.BK_FISCAL_YEAR_NUM_INT * 100 + BE_ITEM_MAP.BK_FISCAL_MONTH_NUM_INT)=AMOUNT_BY_SBE.FISCAL_YEAR_MONTH_INT        \r\nAND BE_ITEM_MAP.BK_DATA_SET_CD='CISCO'",
