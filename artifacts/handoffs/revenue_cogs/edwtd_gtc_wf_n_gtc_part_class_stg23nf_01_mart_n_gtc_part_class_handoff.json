      "attributes": {
        "Sql Query": "SELECT COALESCE(TRIM(TRAILING '-' FROM NAME ) ,'UNKNOWN') AS GTC_PART_CLASS_CD,\r\nCOALESCE(SOURCE1,'UNKNOWN') AS SS_CD,\r\nDESCRIPTION AS PART_CLASS_DESCR,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER\r\n FROM  $$STGDB.ST_XXCFI_CB_PT_CC XCTS\r\nWHERE  XCTS.SOURCE1 <> 'CISCO' AND XCTS.PRODUCT_FLAG = 'C'\r\nAND NOT EXISTS (SELECT 1 FROM  $$FINLGLVWDB.N_GTC_PART_CLASS NGPC WHERE NGPC.GTC_PART_CLASS_CD = TRIM(TRAILING '-' FROM XCTS.NAME))\r\nQUALIFY ROW_NUMBER() OVER( PARTITION BY TRIM(TRAILING '-' FROM NAME), XCTS.SOURCE1 ORDER BY XCTS.MODIFIED_DATE DESC) = 1",
