      "attributes": {
        "Sql Query": "SELECT\r\nBK_PART_CLASS_CD              ,\r\n'CISCO' AS SS_CD,\r\nPART_CLASS_DESCR              ,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER \t\t\t\t AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER \t\t\t\t AS EDW_UPDATE_USER\r\nFROM $$COMREFVWDB.N_PART_CLASS NPC\r\nWHERE NOT EXISTS\r\n(\r\nSELECT 1\r\n  FROM $$FINLGLVWDB.N_GTC_PART_CLASS NGPC\r\n WHERE NGPC.GTC_PART_CLASS_CD = NPC.BK_PART_CLASS_CD\r\n   AND NGPC.SS_CD = 'CISCO'\r\n)",
