      "attributes": {
        "Sql Query": "SELECT\r\nNFM.BK_FISCAL_CALENDAR_CODE,         \r\nNFM.BK_FISCAL_YEAR_NUMBER_INT        ,\r\nNFM.BK_FISCAL_MONTH_NUMBER_INT       ,\r\nNST.SALES_TERRITORY_KEY      ,     \r\nNP.ITEM_KEY PRODUCT_KEY   ,                \r\nAE.MEASURE_NAME BK_ADJUSTMENT_MEASURE_TYPE_CD ,\r\nAE.SUB_MEASURE_NAME BK_ADJ_SUB_MEASURE_TYPE_CD    ,\r\nAE.ADJ_TYPE_CODE BK_ADJUSTMENT_TYPE_CD   ,      \r\nAE.COMPANY_NAME    ,\r\nAE.BK_RPRTD_ADJSTMNT_CNTRY_NAME          BK_RPRTD_ADJSTMNT_CNTRY_NAME     ,\r\nAE.BK_ADJSTMNT_SLS_SUBCOVERGE_CD ADJSTMNT_SALES_SUBCOVERAGE_CD ,\r\nNPTV.ITEM_KEY GOODS_PRODUCT_KEY,\r\nSUM(AE.AMOUNT) ADJUSTMENT_ALLOCATION_USD_AMT ,\r\n(NFM.BK_FISCAL_YEAR_NUMBER_INT*100+NFM.BK_FISCAL_MONTH_NUMBER_INT ) DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM                ,\r\nUSER EDW_CREATE_USER               ,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM                ,\r\nUSER EDW_UPDATE_USER               ,\r\n'I' ACTION_CODE                   ,\r\n'I' DML_TYPE  ,\r\nCOALESCE(AE.DEAL_ID, 'UNKNOWN') AS  BK_DEAL_ID\r\nFROM $$STGDB.ST_AE_FIN_EDW_MANUAL_ADJ AE\r\nINNER JOIN $$COMREFVWDB.N_FISCAL_MONTH NFM   \r\nON (NFM.BK_FISCAL_YEAR_NUMBER_INT*100+NFM.BK_FISCAL_MONTH_NUMBER_INT )=AE.FISCAL_MONTH_ID\r\nINNER JOIN $$COMREFVWDB.N_PRODUCT NP\r\nON NP.BK_PRODUCT_ID=AE.PRODUCT_ID\r\nINNER JOIN $$COMREFVWDB.N_SALES_TERRITORY NST\r\n/*ON NST.SALES_TERRITORY_KEY=(CASE WHEN AE.SALES_TERRITORY_KEY <0 THEN -999 ELSE AE.SALES_TERRITORY_KEY END)*/\r\nON NST.BK_SALES_TERRITORY_NAME_CODE = COALESCE(AE.SALES_TERRITORY_NAME_CODE,'WW_SALES')\r\nAND NST.BK_SALES_HIERARCHY_TYPE_CODE = 'CORP. REVENUE'\r\n\r\nINNER JOIN $$COMREFVWDB.N_PRODUCT_TV NPTV\r\nON NPTV.BK_PRODUCT_ID=AE.GOODS_PRODUCT_ID AND NPTV.END_TV_DATE='3500-01-01'\r\n\r\nGROUP BY\r\nNFM.BK_FISCAL_CALENDAR_CODE,         \r\nNFM.BK_FISCAL_YEAR_NUMBER_INT        ,\r\nNFM.BK_FISCAL_MONTH_NUMBER_INT       ,\r\nNST.SALES_TERRITORY_KEY      ,     \r\nNP.ITEM_KEY    ,                \r\nAE.MEASURE_NAME  ,\r\nAE.SUB_MEASURE_NAME     ,\r\nAE.ADJ_TYPE_CODE    ,      \r\nAE.COMPANY_NAME    ,\r\nAE.BK_RPRTD_ADJSTMNT_CNTRY_NAME                 ,\r\nAE.BK_ADJSTMNT_SLS_SUBCOVERGE_CD  ,\r\n(NFM.BK_FISCAL_YEAR_NUMBER_INT*100+NFM.BK_FISCAL_MONTH_NUMBER_INT ),\r\nNPTV.ITEM_KEY,\r\nAE.DEAL_ID",
        "User Defined Join": "",
        "Source Filter": "",
