      "attributes": {
        "Sql Query": "SELECT \r\nNONREC.PROCESSED_FISCAL_MONTH_ID,\r\nNONREC.MEASURE_NAME,\r\nNONREC.MEASURE_LEVEL_2,\r\nNONREC.SERVICE_FLAG,\r\nSALES_TERRITORY_CODE,\r\nNP.ITEM_KEY,\r\nNONREC.REVENUE_TYPE,\r\nNONREC.AMOUNT,\r\nNONREC.CREATE_USER,\r\nNONREC.CREATE_DATETIME,\r\nNONREC.UPDATE_USER,\r\nNONREC.UPDATE_DATETIME,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM ,               \r\nUSER AS EDW_UPDATE_USER,               \r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM ,\r\nNONREC.FISCAL_MONTH_ID,\r\nNONREC.SOURCE_ENTITY              \r\nFROM \r\n$$STGDB.ST_DFR_NONREC_REV_DATA NONREC\r\nINNER JOIN $$COMREFVWDB.N_PRODUCT NP ON NP.BK_PRODUCT_ID=NONREC.PRODUCT_ID",
