      "attributes": {
        "Sql Query": "SELECT\r\n  MT.DV_FISCAL_YEAR_MTH_NUMBER_INT PROCESSED_FISCAL_YEAR_MTH_INT,\r\n     MT.DV_FISCAL_YEAR_MTH_NUMBER_INT FISCAL_YEAR_MONTH_INT,\r\n     MT.PRODUCT_KEY PRODUCT_KEY , \r\n     MT.SALES_TERRITORY_KEY ORIG_SALES_TERRITORY_KEY    ,  \r\n     MT.SALES_TERRITORY_KEY,     \r\n     MT.DV_ERP_DEAL_ID,\r\n     SUM(ZEROIFNULL(MT.DV_COMP_US_NET_REV_AMT))DV_COMP_US_NET_REV_AMT1,\r\n     MT.SALES_ORDER_KEY,\r\n     MT.DV_ATTRIBUTION_CD DV_ATTRIBUTION_CD,\r\n     MT.DV_PRODUCT_KEY DV_PRODUCT_KEY,\r\n     COALESCE(MT.SK_OFFER_ATTRIBUTION_ID_INT   ,-9999) ,\r\n\t MT.POB_TYPE_CD ,\r\n\t SUM(MT.SPLIT_PCT) AS RESTATED_SLS_CRDT_SPLIT_PCT\r\n       FROM\r\n       $$FINLGLVWDB.MT_RSTD_GL_REV_MEASURE MT\r\n       INNER JOIN   $$FINLGLVWDB.MT_DIRECT_INDIRECT_ADJ_TYPE BDIAT\r\n       ON     ( MT.DD_BK_DIRECT_CORP_ADJ_TYPE_CD=BDIAT.BK_DIRECT_CORP_ADJ_TYPE_CD \r\n       AND MT.BK_ADJUSTMENT_TYPE_CD=BDIAT.BK_ADJUSTMENT_TYPE_CD \r\n       AND MT.BK_REVENUE_OR_COGS_TYPE_CD=BDIAT.BK_REVENUE_OR_COGS_TYPE_CD  )\r\n       INNER JOIN $$COMREFVWDB.R_PRODUCTS_FIN RPFIN \r\n       ON ( MT.PRODUCT_KEY=RPFIN.ITEM_KEY  )\r\n       INNER JOIN $$COMREFVWDB.R_TRX_PRODUCT_FIN  RTP  /* we have replace this with one randomized  base view which need to be created */\r\n       ON (RPFIN.ITEM_KEY=RTP.PRODUCT_KEY) \r\n       \r\n    INNER JOIN $$SLSORDVWDB.N_SALES_ORDER_TV SO\r\n    ON  SO.SALES_ORDER_KEY=MT.SALES_ORDER_KEY\r\n    \r\n         \r\n    INNER JOIN $$STGDB.WI_RSTD_DEFREV_CCW_PRODUCT_KEY CCW_PK\r\n    ON CCW_PK.PRODUCT_KEY=MT.PRODUCT_KEY\r\n    AND CCW_PK.DV_ATTRIBUTION_CD=MT.DV_ATTRIBUTION_CD\r\n    AND CCW_PK.DV_PRODUCT_KEY=MT.DV_PRODUCT_KEY\r\n    AND CCW_PK.DV_AR_TRX_LINE_KEY=MT.DV_AR_TRX_LINE_KEY \r\n      /*AND CCW_PK.AR_TRX_KEY=MT.AR_TRX_KEY */\r\n    \r\n       \r\n    LEFT OUTER JOIN  $$COMREFVWDB.MT_OFFER_TYPE_PRDT_MAP OFFER\r\n    ON  OFFER.PRODUCT_KEY = MT.PRODUCT_KEY    \r\n    AND OFFER.DV_PRODUCT_KEY  = MT.DV_PRODUCT_KEY \r\n    AND OFFER.BK_OFFER_ATTRBTN_TYPE_CD  = MT.DV_ATTRIBUTION_CD     \r\n       \r\n       WHERE\r\n       MT.BK_COMPANY_CODE IS NULL \r\n       AND MT.BK_ISO_COUNTRY_CODE='UNK' \r\n       AND   MT.DV_CORPORATE_REVENUE_FLG  =  'Y'\r\n       AND   MT.DV_SERVICE_FLG  =  'N'\r\n       AND   RPFIN.BK_TECHNOLOGY_GROUP_ID          NOT IN  ( 'TOTAL_CISCO','TBA','MISC','SERVICE'  )\r\n\t   AND RPFIN.GOODS_OR_SERVICE_TYPE = 'GOODS' /* Added as part of Q1FY19*/\r\n       AND   MT.DV_2T_DISTI_REVENUE_FLG  =  'N'\r\n       --AND   BDIAT.L3_HIERARCHY_NODE_TYPE_ID  IN  ( 'VIP Subscription Systematic'  )\r\n   AND   BDIAT.L2_HIERARCHY_NODE_TYPE_ID  IN  ('VIP')\r\n       AND   RPFIN.BK_TECHNOLOGY_GROUP_ID          <>  'CDBU'\r\n       AND MT.RSTD_DEL_RECORD_FLG = 'N'\r\n       AND MT.DV_FISCAL_YEAR_MTH_NUMBER_INT IN (SELECT PROCESSED_FISCAL_YEAR_MTH_INT FROM $$STGDB.WI_DEFREV_CCW_MONTH_CNTL)\r\n       GROUP BY 1,2,3,4,5,6,8,9,10,11,12\r\n       HAVING DV_COMP_US_NET_REV_AMT1 <>0\r\n\r\nUNION ALL\r\n\r\nSELECT\r\n  MT.DV_FISCAL_YEAR_MTH_NUMBER_INT PROCESSED_FISCAL_YEAR_MTH_INT,\r\n  MT.DV_FISCAL_YEAR_MTH_NUMBER_INT FISCAL_YEAR_MONTH_INT,\r\n  MT.PRODUCT_KEY PRODUCT_KEY , \r\n  MT.SALES_TERRITORY_KEY ORIG_SALES_TERRITORY_KEY    ,  \r\n  MT.SALES_TERRITORY_KEY,     \r\n  MT.DV_ERP_DEAL_ID,\r\n  SUM(ZEROIFNULL(MT.DV_COMP_US_NET_REV_AMT))DV_COMP_US_NET_REV_AMT1,\r\n  MT.SALES_ORDER_KEY,\r\n  MT.DV_ATTRIBUTION_CD DV_ATTRIBUTION_CD,\r\n  MT.DV_PRODUCT_KEY DV_PRODUCT_KEY,\r\n  COALESCE(MT.SK_OFFER_ATTRIBUTION_ID_INT   ,-9999) ,\r\n  MT.POB_TYPE_CD ,\r\n  SUM(MT.SPLIT_PCT) AS RESTATED_SLS_CRDT_SPLIT_PCT\r\n    FROM\r\n    $$FINLGLVWDB.MT_RSTD_GL_REV_MEASURE MT\r\n    INNER JOIN   $$FINLGLVWDB.MT_DIRECT_INDIRECT_ADJ_TYPE BDIAT\r\n    ON     ( MT.DD_BK_DIRECT_CORP_ADJ_TYPE_CD=BDIAT.BK_DIRECT_CORP_ADJ_TYPE_CD \r\n    AND MT.BK_ADJUSTMENT_TYPE_CD=BDIAT.BK_ADJUSTMENT_TYPE_CD \r\n    AND MT.BK_REVENUE_OR_COGS_TYPE_CD=BDIAT.BK_REVENUE_OR_COGS_TYPE_CD  )\r\n    INNER JOIN $$COMREFVWDB.R_PRODUCTS_FIN RPFIN \r\n    ON ( MT.PRODUCT_KEY=RPFIN.ITEM_KEY  )\r\n    INNER JOIN $$COMREFVWDB.R_TRX_PRODUCT_FIN  RTP  /* we have replace this with one randomized  base view which need to be created */\r\n    ON (RPFIN.ITEM_KEY=RTP.PRODUCT_KEY) \r\n       \r\n    INNER JOIN $$STGDB.WI_GL_REC_REV_DEFREV_CCW_AR_VIP CCW_PK\r\n    ON CCW_PK.PRODUCT_KEY=MT.PRODUCT_KEY\r\n    AND CCW_PK.DV_ATTRIBUTION_CD=MT.DV_ATTRIBUTION_CD\r\n    AND CCW_PK.DV_PRODUCT_KEY=MT.DV_PRODUCT_KEY\r\n    AND CCW_PK.DV_AR_TRX_LINE_KEY=MT.SALES_ORDER_LINE_KEY \r\n    \r\n\tINNER JOIN $$FINLGLVWDB.N_ROL_TRX_LINE_GL_DISTRI   NROL\r\n    ON NROL.ROL_TRX_LINE_GL_DISTRI_KEY = MT.ADJSMT_RBT_TRX_LIN_GL_DIST_KEY\r\n    \r\n\tINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_TV SO\r\n    ON  SO.SALES_ORDER_KEY=MT.SALES_ORDER_KEY\r\n    \r\n\tLEFT OUTER JOIN  $$COMREFVWDB.MT_OFFER_TYPE_PRDT_MAP OFFER\r\n    ON  OFFER.PRODUCT_KEY = MT.PRODUCT_KEY    \r\n    AND OFFER.DV_PRODUCT_KEY  = MT.DV_PRODUCT_KEY \r\n    AND OFFER.BK_OFFER_ATTRBTN_TYPE_CD  = MT.DV_ATTRIBUTION_CD     \r\n       \r\n    WHERE\r\n    MT.BK_COMPANY_CODE IS NULL \r\n    AND MT.BK_ISO_COUNTRY_CODE='UNK' \r\n    AND   MT.DV_CORPORATE_REVENUE_FLG  =  'Y'\r\n    AND   MT.DV_SERVICE_FLG  =  'N'\r\n    AND   RPFIN.BK_TECHNOLOGY_GROUP_ID NOT IN  ( 'TOTAL_CISCO','TBA','MISC','SERVICE'  )\r\n\tAND RPFIN.GOODS_OR_SERVICE_TYPE = 'GOODS' /* Added as part of Q1FY19*/\r\n    AND   MT.DV_2T_DISTI_REVENUE_FLG  =  'N'\r\n    AND   BDIAT.L2_HIERARCHY_NODE_TYPE_ID  IN  ('VIP')\r\n    AND   RPFIN.BK_TECHNOLOGY_GROUP_ID  <>  'CDBU'\r\n    AND MT.RSTD_DEL_RECORD_FLG = 'N'\r\n\tAND NROL.TRX_SRC_CD = 'VIP_XAAS_ADJ' AND NROL.REBATE_APPLIED_METHOD_CD = 'KICKERS'\r\n    AND MT.DV_FISCAL_YEAR_MTH_NUMBER_INT IN (SELECT PROCESSED_FISCAL_YEAR_MTH_INT FROM $$STGDB.WI_DEFREV_CCW_MONTH_CNTL)\r\n    GROUP BY 1,2,3,4,5,6,8,9,10,11,12\r\n    HAVING DV_COMP_US_NET_REV_AMT1 <>0",
