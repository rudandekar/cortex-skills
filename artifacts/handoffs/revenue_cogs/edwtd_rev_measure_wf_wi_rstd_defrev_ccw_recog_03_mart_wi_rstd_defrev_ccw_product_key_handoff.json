      "attributes": {
        "Sql Query": "SELECT \r\n P.ITEM_KEY,\r\n SV.DV_ATTRIBUTION_CD,\r\n SV.DV_PRODUCT_KEY,\r\n SV.DV_AR_TRX_LINE_KEY\r\n FROM\r\n $$FINLGLVWDB.MT_RSTD_DEFERRED_REVENUE_TRX SV\r\n INNER JOIN $$COMREFVWDB.R_PRODUCTS_FIN P\r\n ON SV.PRODUCT_KEY=P.ITEM_KEY  \r\n INNER JOIN $$STGDB.WI_DEFREV_CCW_MONTH_CNTL CNTL \r\n ON CNTL.PROCESSED_FISCAL_YEAR_MTH_INT=SV.PROCESSED_FISCAL_YEAR_MTH_INT\r\n WHERE\r\n SV.DV_ATTRIBUTION_CD IN ('STANDALONE','ATTRIBUTED')\r\n AND SV.DV_UNEARN_FINANCIAL_ACCOUNT_CD  IN  ( '27029'  ) \r\n AND P.BK_TECHNOLOGY_GROUP_ID          NOT IN  ( 'SERVICE-TG'  )\r\n AND P.GOODS_OR_SERVICE_TYPE = 'GOODS'\r\n AND SV.DV_CORPORATE_REVENUE_FLG      ='Y'\r\n GROUP BY 1,2,3,4\r\n \r\n UNION \r\n  \r\n SELECT \r\n P.ITEM_KEY,\r\n SV.DV_ATTRIBUTION_CD,\r\n SV.DV_PRODUCT_KEY,\r\n SV.DV_AR_TRX_LINE_KEY\r\n FROM\r\n $$FINLGLVWDB.MT_RSTD_DEFERRED_REVENUE_TRX SV\r\n INNER JOIN $$COMREFVWDB.R_PRODUCTS_FIN P\r\n ON SV.PRODUCT_KEY=P.ITEM_KEY  \r\n INNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RF \r\n ON RF.FISCAL_MONTH_AGO_MONTH_NUMBER=SV.PROCESSED_FISCAL_YEAR_MTH_INT\r\n INNER JOIN $$STGDB.WI_DEFREV_CCW_MONTH_CNTL CNTL \r\n ON CNTL.PROCESSED_FISCAL_YEAR_MTH_INT=RF.FISCAL_YEAR_MONTH_INT\r\n WHERE\r\n SV.DV_ATTRIBUTION_CD IN ('STANDALONE','ATTRIBUTED')\r\n AND SV.DV_UNEARN_FINANCIAL_ACCOUNT_CD  IN  ( '27029'  ) \r\n AND P.BK_TECHNOLOGY_GROUP_ID          NOT IN  ( 'SERVICE-TG'  )\r\n AND P.GOODS_OR_SERVICE_TYPE = 'GOODS'\r\n AND SV.DV_CORPORATE_REVENUE_FLG      ='Y'\r\n GROUP BY 1,2,3,4",
