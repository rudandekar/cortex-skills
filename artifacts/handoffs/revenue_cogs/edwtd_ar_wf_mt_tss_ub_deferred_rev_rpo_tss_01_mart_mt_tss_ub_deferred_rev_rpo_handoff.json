      "attributes": {
        "Sql Query": "SELECT \r\n PROCESSED_FISCAL_MTH     \r\n,FISCAL_MTH               \r\n,ATTRIBUTED_PRODUCT_KEY                   \r\n,SALES_TERRITORY_KEY           \r\n,SERVICE_FLG                   \r\n,TRANSACTION_TYPE              \r\n,SRC_ENTITY                    \r\n,RPO_FLG                       \r\n,CAST(SUM(UNBILLED_REVENUE_AMT) AS DECIMAL (26,7)) AS UNBILLED_REVENUE_AMT            \r\n,CAST(SUM(DV_PROJECTED_UNBILL_REV_AMT) AS DECIMAL (26,7)) AS DV_PROJECTED_UNBILL_REV_AMT     \r\n,CAST(SUM(DV_SHORT_TERM_UNBILLED_REV_AMT) AS DECIMAL (26,7)) AS DV_SHORT_TERM_UNBILLED_REV_AMT  \r\n,CAST(SUM(DV_LONG_TERM_UNBILLED_REV_AMT) AS DECIMAL (26,7)) AS DV_LONG_TERM_UNBILLED_REV_AMT   \r\n,CAST(SUM(BK_PARENT_OFFER_TYPE_NAME) AS DECIMAL (26,7)) AS BK_PARENT_OFFER_TYPE_NAME       \r\n,CAST(SUM(BK_OFFER_TYPE_NAME) AS DECIMAL (26,7)) AS BK_OFFER_TYPE_NAME              \r\n,CAST(SUM(DV_NONREC_REV_AMT) AS DECIMAL (26,7)) AS DV_NONREC_REV_AMT               \r\n,CAST(SUM(DV_SHORT_TERM_NONREC_REV_AMT) AS DECIMAL (26,7)) AS DV_SHORT_TERM_NONREC_REV_AMT    \r\n,CAST(SUM(DV_LONG_TERM_NONREC_REV_AMT) AS DECIMAL (26,7)) AS DV_LONG_TERM_NONREC_REV_AMT     \r\n,CAST(SUM(BALANCE_REV_USD_AMT) AS DECIMAL (26,7)) AS BALANCE_REV_USD_AMT             \r\n,CAST(SUM(PROJECTED_BALANCE_REV_USD_AMT) AS DECIMAL (26,7)) AS PROJECTED_BALANCE_REV_USD_AMT   \r\n,CAST(SUM(DV_SHORT_TERM_BAL_REV_USD_AMT) AS DECIMAL (26,7)) AS DV_SHORT_TERM_BAL_REV_USD_AMT   \r\n,CAST(SUM(DV_LONG_TERM_BAL_REV_REV_USD_AMT) AS DECIMAL (26,7)) AS DV_LONG_TERM_BAL_REV_REV_USD_AMT\r\n,GOODS_PRODUCT_KEY\r\n,DV_TSS_ALCTN_MTHD_TYPE\r\n,DV_PID_ALLOC_PCT\r\n,CURRENT_TIMESTAMP(0)\r\n,USER\r\n,CURRENT_TIMESTAMP(0)\r\n,USER\r\n,PRODUCT_KEY\r\n,DV_CX_PRODUCT\r\nFROM\r\n$$STGDB.WI_UNBIL_RSTD_RPO_MTH_TSS\r\nGROUP BY 1,2,3,4,5,6,7,8,22,23,24,25,26,27,28,29,30",
