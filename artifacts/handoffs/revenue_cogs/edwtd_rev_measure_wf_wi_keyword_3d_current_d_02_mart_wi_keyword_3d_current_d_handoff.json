      ],
      "attributes": {
        "Sql Query": "SELECT CSONE.DW_CRNT_KEYWORD_KEY, \r\nCAST(CSONE.TECH_ID  AS INTEGER) TECH_ID,\r\nCSONE.TECH_NAME, \r\nCAST(CSONE.SUB_TECH_ID AS INTEGER) SUB_TECH_ID, \r\nCSONE.SUB_TECH_NAME, \r\nCOALESCE(CSONE.PROBLEM_CODE,'_') AS PROBLEM_CODE, \r\nCONCAT('HTTP://SDCA/CMP',COALESCE( CAST(CSONE.TECH_ID AS VARCHAR(30)),'_'),COALESCE( CAST(CSONE.SUB_TECH_ID AS VARCHAR(30)),'_') ,COALESCE(PROBLEM_SEQ_ID,'ABC123')) AS RPM_SKILLID, \r\nCONCAT('CSONE-TSTPC-T',CAST(CSONE.TECH_ID AS VARCHAR(30)),'S',CAST(CSONE.SUB_TECH_ID AS VARCHAR(30)),'P',COALESCE(PROBLEM_SEQ_ID,CSONE.PROBLEM_CODE)) AS FF_SKILLID, \r\n'Y' AS DW_ACTIVE_FLAG\r\nFROM (SELECT A.PROBLEMCODE_ID, B.SUB_TECH_ID,B.SUB_TECH_NAME, A.HIDDEN_FLAG, B.TECHNOLOGY_LOOKUP, COALESCE(C.PROBLEM_CODE,'_') PROBLEM_CODE, C.PROBLEM_SEQ_ID,\r\nD.TECH_ID, D.TECH_NAME,\r\nHASH_MD5(CONCAT(LPAD(D.TECH_ID,10,'0'),LPAD(B.SUB_TECH_ID,10,'0'),COALESCE(C.PROBLEM_CODE,'_'))) AS DW_CRNT_KEYWORD_KEY\r\nFROM \r\n(SELECT SUB_TECHNOLOGY_LOOKUP__C AS SUBTECHNOLOGY_ID, PROBLEM_CODE_LOOKUP__C AS PROBLEMCODE_ID, CASE WHEN EXTERNAL__C = 'TRUE' THEN 'Y' ELSE 'N' END AS HIDDEN_FLAG \r\nFROM $$ETLVWDB.EL_CSONE_HB_PC_STECH_JUNCTION   \r\nWHERE STATUS__C = 'TRUE')  A\r\nINNER JOIN (SELECT SUB_TECHNOLOGY_ID__C AS SUB_TECH_ID, SUB_TECHNOLOGY_DESCRIPTION__C AS SUB_TECH_NAME, TECHNOLOGY__C AS TECHNOLOGY_LOOKUP, HB_KEY AS SFDC_SUBTECH_ID\r\nFROM $$ETLVWDB.EL_CSONE_HB_SUB_TECHNOLOGY\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY SUB_TECHNOLOGY_ID__C ORDER BY LASTMODIFIEDDATE DESC) = 1) B\r\nON A.SUBTECHNOLOGY_ID = B.SFDC_SUBTECH_ID\r\nINNER JOIN (SELECT PROBLEM_CODE, PROBLEM_CODE_SEQUENCE_ID AS PROBLEM_SEQ_ID, ID AS SFDC_PC_ID \r\nFROM $$ETLVWDB.EL_CSONE_HB_PROBLEM_CODE) C\r\nON A.PROBLEMCODE_ID = C.SFDC_PC_ID\r\nINNER JOIN (SELECT TECHNOLOGY_ID__C AS TECH_ID, TECHNOLOGY_DESCRIPTION__C AS TECH_NAME, HB_KEY AS SFDC_TECH_ID \r\n FROM $$ETLVWDB.EL_CSONE_HB_TECHNOLOGY        \r\nWHERE STATUS__C = 'TRUE') D\r\nON B.TECHNOLOGY_LOOKUP = D.SFDC_TECH_ID) CSONE\r\n\r\nUNION ALL\r\n\r\nSELECT B.DW_CRNT_KEYWORD_KEY, \r\nCAST(B.TECH_ID AS INTEGER) TECH_ID,\r\nCOALESCE(TECH.TECH_NAME, B.TECH_NAME) AS TECH_NAME, \r\nCAST(B.SUB_TECH_ID AS INTEGER) SUB_TECH_ID,\r\nCOALESCE(LSN.SUB_TECH_NAME,B.SUB_TECH_NAME) AS SUB_TECH_NAME, \r\nB.PROBLEM_CODE, \r\nB.RPM_SKILLID, \r\nB.FF_SKILLID, \r\n'N' AS DW_ACTIVE_FLAG\r\nFROM (SELECT HASH_MD5(CONCAT(LPAD(CAST(TECH_ID AS VARCHAR(30)),10,'0'),LPAD(CAST(SUB_TECH_ID AS VARCHAR(30)),10,'0'),COALESCE(PROBLEM_CODE,'_'))) AS DW_CRNT_KEYWORD_KEY,\r\nTECH_ID,TECH_NAME,SUB_TECH_ID,SUB_TECH_NAME,RPM_SKILLID, FF_SKILLID, COALESCE(PROBLEM_CODE,'_') AS PROBLEM_CODE\r\nFROM (SELECT DISTINCT TECH_ID , TECH_NAME, SUB_TECH_ID , SUB_TECH_NAME, PROBLEM_CODE, RPM_SKILLID, FF_SKILLID FROM $$STGDB.WI_KEYWORD_3D_CURRENT_D) X) B \r\nLEFT JOIN (SELECT A.PROBLEMCODE_ID, B.SUB_TECH_ID,B.SUB_TECH_NAME, A.HIDDEN_FLAG, B.TECHNOLOGY_LOOKUP, COALESCE(C.PROBLEM_CODE,'_') PROBLEM_CODE, C.PROBLEM_SEQ_ID,\r\nD.TECH_ID, D.TECH_NAME,\r\nHASH_MD5(CONCAT(LPAD(D.TECH_ID,10,'0'),LPAD(B.SUB_TECH_ID,10,'0'),COALESCE(C.PROBLEM_CODE,'_'))) AS DW_CRNT_KEYWORD_KEY\r\nFROM \r\n(SELECT SUB_TECHNOLOGY_LOOKUP__C AS SUBTECHNOLOGY_ID, PROBLEM_CODE_LOOKUP__C AS PROBLEMCODE_ID, CASE WHEN EXTERNAL__C = 'TRUE' THEN 'Y' ELSE 'N' END AS HIDDEN_FLAG \r\nFROM $$ETLVWDB.EL_CSONE_HB_PC_STECH_JUNCTION   \r\nWHERE STATUS__C = 'TRUE')  A\r\nINNER JOIN (SELECT SUB_TECHNOLOGY_ID__C AS SUB_TECH_ID, SUB_TECHNOLOGY_DESCRIPTION__C AS SUB_TECH_NAME, TECHNOLOGY__C AS TECHNOLOGY_LOOKUP, HB_KEY AS SFDC_SUBTECH_ID\r\nFROM $$ETLVWDB.EL_CSONE_HB_SUB_TECHNOLOGY\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY SUB_TECHNOLOGY_ID__C ORDER BY LASTMODIFIEDDATE DESC) = 1) B\r\nON A.SUBTECHNOLOGY_ID = B.SFDC_SUBTECH_ID\r\nINNER JOIN (SELECT PROBLEM_CODE, PROBLEM_CODE_SEQUENCE_ID AS PROBLEM_SEQ_ID, ID AS SFDC_PC_ID \r\nFROM $$ETLVWDB.EL_CSONE_HB_PROBLEM_CODE) C\r\nON A.PROBLEMCODE_ID = C.SFDC_PC_ID\r\nINNER JOIN (SELECT TECHNOLOGY_ID__C AS TECH_ID, TECHNOLOGY_DESCRIPTION__C AS TECH_NAME, HB_KEY AS SFDC_TECH_ID \r\n FROM $$ETLVWDB.EL_CSONE_HB_TECHNOLOGY        \r\nWHERE STATUS__C = 'TRUE') D\r\nON B.TECHNOLOGY_LOOKUP = D.SFDC_TECH_ID) CSONE\r\nON B.TECH_ID = CSONE.TECH_ID\r\nAND B.SUB_TECH_ID = CSONE.SUB_TECH_ID\r\nAND B.PROBLEM_CODE = COALESCE(CSONE.PROBLEM_CODE,'_')\r\nLEFT JOIN (SELECT DISTINCT SUB_TECHNOLOGY_ID__C SUB_TECH_ID, SUB_TECHNOLOGY_DESCRIPTION__C SUB_TECH_NAME FROM  $$ETLVWDB.EL_CSONE_HB_SUB_TECHNOLOGY) LSN\r\nON B.SUB_TECH_ID = LSN.SUB_TECH_ID\r\nLEFT JOIN (SELECT TECHNOLOGY_ID__C AS TECH_ID, TECHNOLOGY_DESCRIPTION__C AS TECH_NAME, HB_KEY AS SFDC_TECH_ID \r\n FROM $$ETLVWDB.EL_CSONE_HB_TECHNOLOGY        \r\nWHERE STATUS__C = 'TRUE') TECH\r\nON B.TECH_ID = TECH.TECH_ID\r\nWHERE CSONE.TECH_ID IS NULL AND CSONE.SUB_TECH_ID IS NULL AND CSONE.PROBLEM_CODE IS NULL\r\n\r\nUNION ALL\r\n\r\nSELECT B.DW_CRNT_KEYWORD_KEY, \r\nCAST(B.TECH_ID AS INT), \r\nTECH.TECH_NAME, \r\nCAST(B.SUB_TECH_ID AS INT) SUB_TECH_ID, \r\nLSN.SUB_TECH_NAME, \r\nCOALESCE(B.PROBLEM_CODE,'_') AS PROBLEM_CODE, \r\nCONCAT('HTTP://SDCA/CMP',COALESCE ( CAST(B.TECH_ID AS VARCHAR(30)),'_'),COALESCE( CAST(B.SUB_TECH_ID AS VARCHAR(30)),'_') , 'ABC123') AS RPM_SKILLID, \r\nCONCAT('CSONE-TSTPC-T',CAST(B.TECH_ID AS VARCHAR(30)),'S',CAST(B.SUB_TECH_ID AS VARCHAR(30)),'P',B.PROBLEM_CODE) AS FF_SKILLID, \r\n'N' AS DW_ACTIVE_FLAG\r\nFROM (SELECT \r\nHASH_MD5(CONCAT(LPAD(CAST(TECH_ID AS VARCHAR(30)),10,'0'),LPAD(CAST(SUB_TECH_ID AS VARCHAR(30)),10,'0'),COALESCE(PROBLEM_CODE,'_'))) AS DW_CRNT_KEYWORD_KEY,\r\nTECH_ID,SUB_TECH_ID\r\n,COALESCE(PROBLEM_CODE,'_') AS PROBLEM_CODE\r\nFROM (SELECT DISTINCT F.FINAL_TECH_ID  AS TECH_ID, F.FINAL_SUB_TECH_ID AS SUB_TECH_ID, F.PROBLEM_CODE \r\nFROM $$STGDB.WI_SR_VOLUME F\r\nLEFT JOIN $$STGDB.WI_KEYWORD_3D_CURRENT_D K3D\r\nON F.FINAL_TECH_ID = K3D.TECH_ID AND F.FINAL_SUB_TECH_ID = K3D.SUB_TECH_ID AND NVL(F.PROBLEM_CODE,'_') = K3D.PROBLEM_CODE\r\nWHERE F.PROBLEM_CODE IS NULL AND K3D.DW_CRNT_KEYWORD_KEY IS NULL) A) B \r\n JOIN (SELECT TECHNOLOGY_ID__C AS TECH_ID, TECHNOLOGY_DESCRIPTION__C AS TECH_NAME, HB_KEY AS SFDC_TECH_ID \r\n FROM $$ETLVWDB.EL_CSONE_HB_TECHNOLOGY        \r\nWHERE STATUS__C = 'TRUE'\r\n) TECH\r\nON B.TECH_ID = TECH.TECH_ID\r\nJOIN (SELECT DISTINCT SUB_TECHNOLOGY_ID__C SUB_TECH_ID, SUB_TECHNOLOGY_DESCRIPTION__C SUB_TECH_NAME FROM $$ETLVWDB.EL_CSONE_HB_SUB_TECHNOLOGY) LSN\r\nON B.SUB_TECH_ID = LSN.SUB_TECH_ID",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "DELETE FROM $$STGDB.ST_KEYWORD_3D_CURRENT_D ALL;",
