        }
      ],
      "attributes": {
        "Sql Query": "SELECT\r\nXAL.GLOBAL_NAME ,\r\ncast(XAL.TRANSACTION_DIST_ID AS DECIMAL(15,0)) as REV_ADJ_TRX_ID, \r\nEOCATA.ADJ_TYPE_ID ,\r\nWI_AMT.ADJUSTMENT_COGS * COALESCE(NCCDR.PL_CONVERSION_RATE,1) as ADJUSTMENT_REVENUE_USD,\r\nWI_AMT.ADJUSTMENT_REVENUE * COALESCE(NCCDR.PL_CONVERSION_RATE,1) as ADJUSTMENT_COGS_USD,\r\nNFM.BK_FISCAL_YEAR_NUMBER_INT as PERIOD_YEAR ,\r\nNFM.BK_FISCAL_MONTH_NUMBER_INT as PERIOD_NUM\r\nFROM\r\n$$STGDB.WI_XLA_AE_LINE_CORP_ADJ_INCR XAL\r\nINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\n ON NSSC.GLOBAL_NAME = XAL.GLOBAL_NAME\r\nINNER JOIN $$STGDB.WI_CORP_ADJ_AMOUNT WI_AMT\r\nON XAL.TRANSACTION_DIST_ID = WI_AMT.TRANSACTION_DIST_ID\r\nAND XAL.APPLICATION_ID = WI_AMT.APPLICATION_ID\r\nAND XAL.GLOBAL_NAME = WI_AMT.GLOBAL_NAME\r\nINNER JOIN $$ETLVWDB.EL_OM_CFI_ADJ_TYPE_ALL EOCATA \r\n ON  XAL.DIST_TYPE = EOCATA.ADJ_TYPE_NAME\r\nINNER JOIN $$ETLVWDB.EL_XLA_AE_HEADERS_AR XAH\r\n ON  XAL.AE_HEADER_ID = XAH.AE_HEADER_ID\r\n AND XAL.APPLICATION_ID = XAH.APPLICATION_ID \r\nINNER JOIN  $$COMREFVWDB.N_FISCAL_MONTH NFM\r\n ON  CAST(XAH.ACCOUNTING_DATE AS DATE) >= NFM.FISCAL_MONTH_START_DATE\r\n AND CAST(XAH.ACCOUNTING_DATE AS DATE)<= NFM.FISCAL_MONTH_END_DATE\r\nINNER JOIN $$FINLGLVWDB.N_SET_OF_BOOKS NSOB\r\n ON NSOB.SK_SET_OF_BOOKS_ID_INT = XAH.LEDGER_ID\r\n AND NSOB.SS_CODE = NSSC.SOURCE_SYSTEM_CODE     \r\nLEFT OUTER JOIN $$FINLGLVWDB.N_CURRENCY_CONV_DAILY_RATE NCCDR\r\n ON  NSOB.FUNCTIONAL_CURRENCY_CODE = NCCDR.BK_FROM_CURRENCY_CODE\r\n AND NCCDR.BK_TO_CURRENCY_CODE = 'USD'\r\n AND CAST(XAL.GL_DATE AS DATE) = NCCDR.BK_CONVERSION_DATE   \r\n AND NCCDR.SK_CONVERSION_TYPE_CODE = 'Corporate'\r\nWHERE NOT EXISTS\r\n ( SELECT 1 FROM $$ETLVWDB.EL_OM_CFI_REV_ADJ_TRX_ALL \r\n WHERE cast(XAL.TRANSACTION_DIST_ID AS DECIMAL(15,0)) = EL_OM_CFI_REV_ADJ_TRX_ALL.REV_ADJ_TRX_ID\r\n AND XAL.GLOBAL_NAME = EL_OM_CFI_REV_ADJ_TRX_ALL.GLOBAL_NAME)\r\n/*AND EXISTS (SELECT 1 FROM $$ETLVWDB.EL_AR_LEDGER EAL WHERE XAH.LEDGER_ID = EAL.LEDGER_ID) */\r\nAND XAH.GL_TRANSFER_DATE IS NOT NULL\r\nAND COALESCE(XAH.GL_TRANSFER_STATUS_CODE, 'N') = 'Y'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
