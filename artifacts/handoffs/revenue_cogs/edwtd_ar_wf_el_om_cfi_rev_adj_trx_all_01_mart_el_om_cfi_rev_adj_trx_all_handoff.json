      "attributes": {
        "Sql Query": "SELECT\tST_OM_CFI_REV_ADJ_TRX_ALL.GLOBAL_NAME, ST_OM_CFI_REV_ADJ_TRX_ALL.REV_ADJ_TRX_ID,\r\n\t\tST_OM_CFI_REV_ADJ_TRX_ALL.ADJ_TYPE_ID, ST_OM_CFI_REV_ADJ_TRX_ALL.ADJUSTMENT_REVENUE_USD,\r\n\t\tST_OM_CFI_REV_ADJ_TRX_ALL.ADJUSTMENT_COGS_USD,\r\nST_OM_CFI_REV_ADJ_TRX_ALL.PERIOD_YEAR,\r\nST_OM_CFI_REV_ADJ_TRX_ALL.PERIOD_NUM\r\nFROM\t\r\n $$STGDB.ST_OM_CFI_REV_ADJ_TRX_ALL\r\nWHERE\tNOT EXISTS( \r\nSELECT\t1 \r\nFROM\t$$ETLVWDB.EL_OM_CFI_REV_ADJ_TRX_ALL \r\nWHERE\tST_OM_CFI_REV_ADJ_TRX_ALL.REV_ADJ_TRX_ID=EL_OM_CFI_REV_ADJ_TRX_ALL.REV_ADJ_TRX_ID\r\n\tAND\t\r\nST_OM_CFI_REV_ADJ_TRX_ALL.GLOBAL_NAME=EL_OM_CFI_REV_ADJ_TRX_ALL.GLOBAL_NAME)",
        "User Defined Join": "",
        "Source Filter": "",
