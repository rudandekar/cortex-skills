      "attributes": {
        "Sql Query": "SELECT SRC.FISCAL_YEAR_MONTH_INT ,ABS(ROUND(N_INV_MEASURE_AMT+MT_INV_MEASURE_AMT)) AS REV_MISMATCH_AMT ,\r\n   'REVENUE' AS AUDIT_TRXN_TYPE,\r\n   'MT_INV_REV_MEASURE' AS AUDIT_TABLE,\r\n   Current_Date AS AUDIT_DATE\r\nFROM\r\n(SEL FISCAL_YEAR_MONTH_INT,\r\nSum(INV.DV_COMP_US_NET_PRICE_AMT) AS N_INV_MEASURE_AMT\r\nFROM\r\n$$FINLGLVWDB.N_INV_REV_MEASURE INV,\r\n$$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nWHERE DV_FISCAL_YEAR_MTH_NUMBER_INT >= 201911\r\nAND FISCAL_YEAR_MONTH_INT         =DV_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND (CURRENT_FISCAL_MONTH_FLAG     IN 'Y' OR PREVIOUS_FSCL_MONTH_FLAG    IN 'Y')\r\nAND GL_DT >= Cast ('2019-05-26' AS DATE)\r\nAND REV_MEASURE_TRANS_TYPE_CD NOT IN ('POS') GROUP BY 1) SRC\r\nLEFT JOIN \r\n(SEL FISCAL_YEAR_MONTH_INT,\r\nSum(INV.DV_COMP_US_NET_PRICE_AMT)*-1  AS MT_INV_MEASURE_AMT\r\nFROM\r\n$$FINLGLVWDB.MT_INV_REV_MEASURE INV,\r\n$$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nWHERE DV_FISCAL_YEAR_MTH_NUMBER_INT >= 201911\r\nAND FISCAL_YEAR_MONTH_INT         =DV_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND (CURRENT_FISCAL_MONTH_FLAG     IN 'Y' OR PREVIOUS_FSCL_MONTH_FLAG    IN 'Y')\r\nAND REV_MEASURE_TRANS_TYPE_CD NOT IN ('POS')\r\nGROUP BY 1)  TGT\r\nON 1=1\r\nAND SRC.FISCAL_YEAR_MONTH_INT=TGT.FISCAL_YEAR_MONTH_INT",
        "User Defined Join": "",
