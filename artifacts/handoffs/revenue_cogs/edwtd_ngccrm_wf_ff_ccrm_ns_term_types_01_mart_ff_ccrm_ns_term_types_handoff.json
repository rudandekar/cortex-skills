        "Sql Query": "SELECT\r\nCCRM_NS_TERM_ID,               \r\nREPLACE(REPLACE(TERM_NAME,CHR(10),' '),CHR(13),' ')  TERM_NAME,                     \r\nACTIVE,                        \r\nCREATED_BY,                    \r\nCREATION_DATE,                 \r\nREPLACE(REPLACE(TERM_CODE,CHR(10),' '),CHR(13),' ')    TERM_CODE,                     \r\nLAST_UPDATE_DATE,              \r\nLAST_UPDATED_BY,               \r\nPROFILE_CATG,                  \r\nREPLACE(REPLACE(NONSTDDESC,CHR(10),' '),CHR(13),' ')   NONSTDDESC,                    \r\nREPLACE(REPLACE(NONSTDCOMMENT,CHR(10),' '),CHR(13),' ')  NONSTDCOMMENT,                 \r\nSTARTDATE,                     \r\nENDDATE                                                         \r\nFROM CCRM_NS_TERM_TYPES_MV CCRM_NS_TERM_TYPES\r\nWHERE LAST_UPDATE_DATE > TO_DATE('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS')",
