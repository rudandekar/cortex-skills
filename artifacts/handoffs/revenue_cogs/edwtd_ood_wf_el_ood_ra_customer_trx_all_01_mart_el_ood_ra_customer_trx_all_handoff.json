      "attributes": {
        "Sql Query": "SELECT CAST(SORCT.ORG_ID AS BIGINT), CAST(SORCT.CUSTOMER_TRX_ID AS BIGINT), CAST(SORCT.TRX_NUMBER AS VARCHAR(20)), CAST(SORCT.CUST_TRX_TYPE_ID AS BIGINT), SORCT.TRX_DATE, CAST(SORCT.BATCH_SOURCE_ID AS BIGINT), CAST(SORCT.REASON_CODE AS VARCHAR(30)), CAST(SORCT.SOLD_TO_CUSTOMER_NUMBER AS VARCHAR(30)), CAST(SORCT.BILL_TO_CUSTOMER_NUMBER AS VARCHAR(30)), CAST(SORCT.SHIP_TO_CUSTOMER_NUMBER AS VARCHAR(30)), CAST(SORCT.PREVIOUS_CUSTOMER_TRX_ID AS BIGINT), CAST(SORCT.INVOICE_CURRENCY_CODE AS VARCHAR(15)), CAST(SORCT.ATTRIBUTE10 AS VARCHAR(150)), CAST(SORCT.REQUEST_ID AS BIGINT), SORCT.COMPLETE_FLAG, CAST(SORCT.INVOICING_RULE_ID AS BIGINT), CAST(SORCT.INTERFACE_HEADER_ATTRIBUTE1 AS VARCHAR(30)), CAST(SORCT.INTERFACE_HEADER_CONTEXT AS VARCHAR(30)), SORCT.CREATION_DATE, CAST(SORCT.INTERFACE_HEADER_ATTRIBUTE10 AS VARCHAR(30)), CAST(SORCT.INTERFACE_HEADER_ATTRIBUTE11 AS VARCHAR(30)), CAST(SORCT.INTERFACE_HEADER_ATTRIBUTE9 AS VARCHAR(30)), CAST(SORCT.TERM_ID AS BIGINT), CAST(SORCT.PURCHASE_ORDER AS VARCHAR(50)), SORCT.LAST_UPDATE_DATE, SORCT.CREATE_DATETIME ,\r\nCAST(SORCT.BILLTO_LOCATION_NUMBER AS VARCHAR(50)),\r\nCAST(SORCT.SHIPTO_LOCATION_NUMBER AS VARCHAR(50)),\r\nCAST(SORCT.EXCHANGE_RATE AS DECIMAL(26,18)),\r\nSORCT.CONVERSION_DATE,\r\nCAST('OOD' AS VARCHAR(10)) AS IDENTIFIER\r\nFROM\r\n $$STGDB.ST_OOD_RA_CUSTOMER_TRX_ALL SORCT\r\nWHERE NOT EXISTS\r\n(SEL 1 FROM $$ETLVWDB.EL_OOD_RA_CUSTOMER_TRX_ALL EORCT\r\nWHERE EORCT.CUSTOMER_TRX_ID=SORCT.CUSTOMER_TRX_ID)\r\n\r\nUNION ALL\r\n\r\nSELECT \r\nSOFRCT.ORG_ID, SOFRCT.CUSTOMER_TRX_ID, SOFRCT.TRX_NUMBER, SOFRCT.CUST_TRX_TYPE_ID, SOFRCT.TRX_DATE, SOFRCT.BATCH_SOURCE_ID, SOFRCT.REASON_CODE, SOFRCT.SOLD_TO_CUSTOMER_NUMBER, SOFRCT.BILL_TO_CUSTOMER_NUMBER, SOFRCT.SHIP_TO_CUSTOMER_NUMBER, SOFRCT.PREVIOUS_CUSTOMER_TRX_ID, SOFRCT.INVOICE_CURRENCY_CODE, SOFRCT.ATTRIBUTE10, SOFRCT.REQUEST_ID, SOFRCT.COMPLETE_FLAG, SOFRCT.INVOICING_RULE_ID, SOFRCT.INTERFACE_HEADER_ATTRIBUTE1, SOFRCT.INTERFACE_HEADER_CONTEXT, SOFRCT.CREATION_DATE, SOFRCT.INTERFACE_HEADER_ATTRIBUTE10, SOFRCT.INTERFACE_HEADER_ATTRIBUTE11, SOFRCT.INTERFACE_HEADER_ATTRIBUTE9, SOFRCT.TERM_ID, SOFRCT.PURCHASE_ORDER, SOFRCT.LAST_UPDATE_DATE, SOFRCT.CREATE_DATETIME ,\r\nSOFRCT.BILL_TO_LOCATION_NUMBER,\r\nSOFRCT.SHIP_TO_LOCATION_NUMBER,\r\nSOFRCT.EXCHANGE_RATE,\r\nEXCHANGE_DATE,\r\n'FUSN' AS IDENTIFIER\r\nFROM $$STGDB.ST_OOD_FUSN_RA_CUSTOMER_TRX_ALL SOFRCT\r\nWHERE NOT EXISTS\r\n(SEL 1 FROM $$ETLVWDB.EL_OOD_RA_CUSTOMER_TRX_ALL EORCT\r\nWHERE EORCT.CUSTOMER_TRX_ID=SOFRCT.CUSTOMER_TRX_ID)",
