        }
      ],
      "attributes": {
        "Sql Query": "SELECT RANK() OVER (ORDER BY SXCBR.RULE_ID) + SMKEY.MAX_VAL AS HTS_CLASSIFICATION_RULE_KEY,\r\n     SXCBR.RULE_ID SK_RULE_ID_INT,\r\n     CURRENT_TIMESTAMP(0) ,\r\n     USER\r\nFROM \r\n     (  \r\n      SELECT  DISTINCT RULE_ID\r\n      FROM\r\n\t   (\r\n        SELECT RULE_ID,SPECIFIC_ID FROM  $$STGDB.ST_XXCFI_CB_RULES\r\n        UNION\r\n        SELECT RULE_ID,SPECIFIC_ID FROM  $$EXCEPDB.EX_XXCFI_CB_RULES\r\n\t\tWHERE EXCEPTION_TYPE = 'RI'\r\n        ) T\r\n        WHERE SPECIFIC_ID IN (SELECT SK_SPECIFIC_ID_INT FROM $$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC)\r\n\t) SXCBR,\t\r\n(SELECT COALESCE(MAX(HTS_CLASSIFICATION_RULE_KEY),0) MAX_VAL\r\n  FROM $$ETLVWDB.SM_HTS_CLASSIFICATION_RULE) SMKEY\r\nWHERE NOT EXISTS \r\n    ( SELECT 1 \r\n      FROM $$ETLVWDB.SM_HTS_CLASSIFICATION_RULE SHCR\r\n      WHERE SXCBR.RULE_ID = SHCR.SK_RULE_ID_INT\r\n     )",
