        }
      ],
      "attributes": {
        "Sql Query": "SELECT \r\nSHCR.HTS_CLASSIFICATION_RULE_KEY,\r\nCOALESCE(SXCR.OVERRIDE_KEY_IN,'N') OVERRIDE_KEY_IN,\r\nSHCR.SK_RULE_ID_INT,\r\n(CASE WHEN (SXCR.ACTIVE_FLAG = 'Y' OR SXCR.ACTIVE_FLAG IS NULL) THEN 'N' ELSE 'Y' END) SOURCE_DELETED_FLAG,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCAST(SXCR.START_DATE AS TIMESTAMP(0))   AS START_TV_DTM,\r\nCOALESCE(CAST(SXCR.END_DATE AS TIMESTAMP(0)), TIMESTAMP  '3500-01-01 00:00:00'  ) END_TV_DTM,\r\nCOALESCE(NCIS.CUSTOMS_ITEM_SPECIFIC_KEY, -999) AS CUSTOMS_ITEM_SPECIFIC_KEY,\r\n'I' ACTION_CODE ,                  \r\nCASE WHEN NTV.HTS_CLASSIFICATION_RULE_KEY IS NULL THEN 'I' ELSE 'U' END AS  DML_TYPE\r\nFROM \r\n(\r\n SELECT RULE_ID,SPECIFIC_ID,OVERRIDE_KEY_IN,ACTIVE_FLAG,SPECIFIC_NAME,MODIFIED_DATE,CREATE_DATETIME,START_DATE,END_DATE FROM $$STGDB.ST_XXCFI_CB_RULES\r\n UNION ALL\r\n SELECT RULE_ID,SPECIFIC_ID,OVERRIDE_KEY_IN,ACTIVE_FLAG,SPECIFIC_NAME,MODIFIED_DATE,CREATE_DATETIME,START_DATE,END_DATE FROM $$EXCEPDB.EX_XXCFI_CB_RULES\r\n  WHERE EXCEPTION_TYPE = 'RI'\r\n) SXCR\r\n     \r\nINNER JOIN $$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC NCIS\r\nON SXCR.SPECIFIC_ID = NCIS.SK_SPECIFIC_ID_INT\r\n\t   \r\nINNER JOIN $$ETLVWDB.SM_HTS_CLASSIFICATION_RULE SHCR \r\nON (SXCR.RULE_ID = SHCR.SK_RULE_ID_INT)\r\n     \r\nLEFT OUTER JOIN $$FINLGLVWDB.N_HTS_CLASSIFICATION_RULE_TV NTV\r\nON ( SHCR.HTS_CLASSIFICATION_RULE_KEY = NTV.HTS_CLASSIFICATION_RULE_KEY\r\nAND CAST(SXCR.START_DATE AS TIMESTAMP(0)) = NTV.START_TV_DTM\r\nAND NTV.END_TV_DTM = '3500-01-01 00:00:00' \r\n)\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY SXCR.RULE_ID, SXCR.START_DATE ORDER BY COALESCE(SXCR.END_DATE,TIMESTAMP'3500-01-01 00:00:00') DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
