      "attributes": {
        "Sql Query": "SELECT\r\nBATCH_ID                    ,\r\nRULE_ID                      ,\r\nSPECIFIC_ID                ,\r\nSPECIFIC_NAME         ,\r\nOVERRIDE_KEY_IN    ,\r\nACTIVE_FLAG             ,         \r\nSTART_DATE             ,       \r\nEND_DATE                 ,      \r\nOVERRIDE_FLAG      ,           \r\nCREATED_BY           ,          \r\nCREATED_DATE     ,             \r\nMODIFIED_BY       ,            \r\nMODIFIED_DATE      ,          \r\nCREATE_DATETIME     ,          \r\nACTION_CODE     ,\r\n'RI'       ,\r\nAUDIT_FLAG\t       \r\nFROM $$STGDB.ST_XXCFI_CB_RULES SXCR\r\nWHERE  NOT EXISTS \r\n (SELECT 1 \r\n    FROM $$ETLVWDB.SM_HTS_CLASSIFICATION_RULE SHCR \r\n\t\r\n    INNER JOIN $$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC\t NCIS\t\r\n\tON SXCR.SPECIFIC_ID = NCIS.SK_SPECIFIC_ID_INT\r\n\t\r\n\tWHERE SXCR.RULE_ID = SHCR.SK_RULE_ID_INT\r\n)",
