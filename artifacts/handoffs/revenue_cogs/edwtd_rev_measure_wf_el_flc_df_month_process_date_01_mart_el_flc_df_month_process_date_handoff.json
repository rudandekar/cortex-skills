      "attributes": {
        "Sql Query": "SELECT \r\n   NFM.FISCAL_YEAR_NUMBER_INT*100 + NFM.FISCAL_MONTH_NUMBER_INT AS  PROCESSED_FISCAL_YEAR_MTH_INT,\r\n  NFM.FISCAL_MONTH_START_DATE AS START_DATE,\r\n  NFM.FISCAL_MONTH_END_DATE AS FISCAL_MONTH_END_DATE,\r\n  CURRENT_TIMESTAMP(0) DV_AR_TRX_DTM \r\n  FROM\r\n  $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR NFM\r\n WHERE 1=1\r\n AND NFM.FISCAL_MONTH_START_DATE  <= Current_Date \r\n  AND NFM.CURRENT_FISCAL_MONTH_FLAG = 'Y' AND   WORKDAY_IN_FISCAL_MTD_COUNT >0\r\n  GROUP BY 1,2,3,4",
