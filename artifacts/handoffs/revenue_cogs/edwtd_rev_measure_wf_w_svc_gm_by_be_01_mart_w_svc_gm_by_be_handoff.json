      "attributes": {
        "Sql Query": "SELECT\r\nNSBE.BK_SUB_BUSINESS_ENTITY_NAME,\r\nFISCAL_MONTH_ID/100  BK_FISCAL_YEAR_NUM_INT,\r\n'Fiscal'  BK_FISCAL_CALENDAR_CD,\r\nNSBE.BK_BUSINESS_ENTITY_TYPE_CD,\r\nFISCAL_MONTH_ID - FISCAL_MONTH_ID/100 *100 BK_FISCAL_MONTH_NUM_INT,\r\nNP.ITEM_KEY ,\r\nDATA_SOURCE BK_DATA_SET_CD,\r\nCOALESCE(SOURCE_NAME,'CISCO')  BK_MEASURE_NAME,\r\nSPLIT_PERCENTAGE SPLIT_PCT,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\n'I',\r\n'I'\r\nFROM\r\n$$STGDB.ST_FIN_SVC_GOODS_MAP_TMPLT STG \r\nINNER JOIN $$COMREFVWDB.N_PRODUCT_TV NP\r\nON NP.BK_PRODUCT_ID=STG.PRODUCT_ID\r\nINNER JOIN $$COMREFVWDB.N_SUB_BUSINESS_ENTITY_TV NSBE\r\nON NSBE.BK_SUB_BUSINESS_ENTITY_NAME=STG.SUB_BUSINESS_ENTITY_NAME\r\nWHERE NSBE.BK_BUSINESS_ENTITY_TYPE_CD='I'\r\nAND NSBE.END_TV_DT                                        =16000101\r\nAND NP.END_TV_DATE                   =16000101",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
