      "attributes": {
        "Sql Query": "SELECT \r\n  CNTL.PROCESSED_FISCAL_YEAR_MTH_INT,\r\n  BK_INCENTIVE_PROGRAM_NAME,\r\n  BOOKINGS_MEASURE_KEY,\r\n  BKGS_MEASURE_TRANS_TYPE_CODE,  \r\n  RDAYS.FISCAL_YEAR_MONTH_INT  TRANS_FISCAL_YEAR_MONTH_INT,\r\n  SUM(BOOKING_ACCRUAL_USD_AMT) BOOKING_ACCRUAL_USD_AMT1\r\n  FROM \r\n  (\r\n  SELECT\r\n  B1.BK_INCENTIVE_PROGRAM_NAME,\r\n  A.BOOKINGS_MEASURE_KEY,\r\n  A.BKGS_MEASURE_TRANS_TYPE_CODE,\r\n  CAST(NPOS.TRANSACTION_DATE                          AS DATE) TRANSACTION_DATE,  \r\n  SUM(ZEROIFNULL(A.BOOKING_ACCRUAL_AMOUNT)) BOOKING_ACCRUAL_USD_AMT\r\n  FROM \r\n  $$GGSRCVWDB.GG_PPI_REBATE_FACT_E A \r\n  INNER JOIN $$ETLVWDB.EL_PRE_PROGRAM_HIER_DIM  B\r\n  ON A.PROGRAM_HIERARCHY_KEY =  B.PROGRAM_HIERARCHY_KEY\r\n  INNER JOIN $$SLSORDVWDB.N_INCENTIVE_PROGRAM B1\r\n  ON B.PROGRAM_NAME =  B1.BK_INCENTIVE_PROGRAM_NAME\r\n  INNER JOIN $$COMREFVWDB.R_SALES_HIERARCHY_FIN SH\r\n  ON  SH.SALES_TERRITORY_KEY=A.SALES_TERRITORY_KEY  \r\n\r\n  INNER JOIN $$SLSORDVWDB.N_BKGS_MEASURE BKGS\r\n  ON  A.BOOKINGS_MEASURE_KEY=BKGS.BOOKINGS_MEASURE_KEY\r\n  AND A.BKGS_MEASURE_TRANS_TYPE_CODE=BKGS.BKGS_MEASURE_TRANS_TYPE_CODE\r\n  INNER JOIN $$SLSORDVWDB.N_POS_TRANSACTION_LINE NPOS\r\n  ON  BKGS.BK_POS_TRANSACTION_ID_INT=NPOS.BK_BOOKING_POS_TRX_ID_INT\r\n  WHERE\r\n  B1.VIP_PROGRAM_FLG ='Y'\r\n  AND A.OVERALL_ELIGIBLE_FLAG = 'Y'\r\n  AND B1.ACTIVE_FLG ='Y'  \r\n  AND SH.SALES_TERRITORY_TYPE_CODE='CORP. REVENUE'\r\n  AND DSV_FLG                       ='Y' \r\n\r\n  AND  TRANSACTION_DATE >=\r\n  (SELECT FISCAL_MONTH_START_DATE \r\n  FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR  \r\n  WHERE FISCAL_MONTH_AGE =(SELECT DEFREV_VIP_WTRFAL_PERIOD  FROM $$ETLVWDB.EL_DEFREV_VIP_WTRFAL_PERIOD)\r\n\r\n/*Added on FEB FY18 Release to Restrict the VIP*/\r\n   AND B1.BK_INCENTIVE_PROGRAM_NAME IN (SELECT BK_INCENTIVE_PROGRAM_NAME FROM $$ETLVWDB.EL_INCENTIVE_PROGRAM)\r\n  )\r\n  GROUP BY 1,2,3,4\r\n  ) ABC,\r\n  $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR RDAYS,\r\n  $$STGDB.WI_DEFREV_VIP_MONTH_CNTL CNTL\r\n  WHERE ABC.TRANSACTION_DATE=RDAYS.CALENDAR_DATE\r\n  AND RDAYS.FISCAL_YEAR_MONTH_INT<=CNTL.PROCESSED_FISCAL_YEAR_MTH_INT\r\nAND 1=2\r\n  GROUP BY 1,2,3,4,5\r\n  HAVING BOOKING_ACCRUAL_USD_AMT1<>0",
