        "Sql Query": "SELECT\r\nMAX_ID + ROW_NUMBER () OVER (ORDER BY ADJ_TYPE_NAME ) as ADJ_TYPE_ID  ,   /*ROWNUM*/\r\nADJ_TYPE_NAME    ,             \r\nADJ_SOURCE_ID   , \r\nADJ_TYPE_DESC    ,             \r\nSTART_DATE_ACTIVE  ,           \r\nEND_DATE_ACTIVE   ,            \r\nENABLED_FLAG    ,              \r\nADJ_TYPE_TYPE    ,\r\nGLOBAL_NAME     ,               \r\nREPORT_LEVEL_1_ID  ,\r\nREPORT_LEVEL_2_ID\r\nFROM\r\n(\r\nSELECT \r\nTMP_MX.MAX_ID,\r\nST.DESCRIPTION AS ADJ_TYPE_NAME    ,             \r\n5002 AS ADJ_SOURCE_ID   ,              /* RCHETTRI : SOURCE FOR CG1 IS ALWAYS 'OE' */\r\nST.DESCRIPTION AS ADJ_TYPE_DESC    ,             \r\nST.START_DATE_ACTIVE  ,           \r\nST.END_DATE_ACTIVE   ,            \r\nST.ENABLED_FLAG    ,              \r\n'R' AS ADJ_TYPE_TYPE    ,    /* RCHETTRI : SOURCE FOR CG1 IS ALWAYS 'R' */         \r\nST.GLOBAL_NAME     ,               \r\nNULL AS REPORT_LEVEL_1_ID  ,    /* RCHETTRI : TAKE SAME AS QTC */ \r\nNULL AS REPORT_LEVEL_2_ID    /* RCHETTRI : TAKE SAME AS QTC */ \r\nFROM\r\n$$STGDB.ST_CG_FND_LOOKUP_VALUES_AR ST,\r\n( SELECT MAX(ADJ_TYPE_ID) MAX_ID FROM  $$ETLVWDB.EL_OM_CFI_ADJ_TYPE_ALL ) TMP_MX\r\nWHERE ST.LANG = 'US'\r\nAND  ST.LOOKUP_TYPE='RMA RESERVE'\r\nAND NOT EXISTS (\r\nSELECT 1 FROM $$ETLVWDB.EL_OM_CFI_ADJ_TYPE_ALL EOCATA\r\nWHERE ST.DESCRIPTION = EOCATA.ADJ_TYPE_NAME )\r\nQUALIFY ROW_NUMBER() OVER( PARTITION BY LOOKUP_TYPE, LANG, SECURITY_GROUP_ID, LOOKUP_CODE, VIEW_APPLICATION_ID, GLOBAL_NAME \r\n        ORDER BY CASE WHEN ATTRIBUTE1 IS NULL THEN '2' ELSE '1' END, LAST_UPDATE_DATE DESC)  =1\r\n)A",
