        "Sql Query": "SELECT\r\n\tNTAC.SERVICE_REQUEST_SSC_COST_KEY  \r\n,\tTACSLKEY.DRVD_SALES_TERRITORY_KEY           \r\n,\tTACSRVCKEY.SERVICE_PRODUCT_KEY           \r\n,\tTACPRDKEY.GOODS_PRODUCT_KEY             \r\n,\tCNTL.FISCAL_YEAR_MONTH_INT \r\n, COALESCE(ESL1.DD_EXTERNAL_THEATER_NAME, 'UNKNOWN' ) C3_CUSTOMER_THEATER_NAME        \r\n, COALESCE(ESCMS.SALES_COVERAGE_CODE  , 'OTHER' ) C3_CUST_MARKET_SEGMENT_NAME   \r\n,\tNTAC.SRC_RPTD_SERVICE_CONTARCT_NUM \r\n,\tNTAC.SSC_DPT_PRSNL_RSRC_CST_USD_AMT*SA_SLK_ALLOCATION_RATIO*TACPRDKEY.PRODUCT_KEY_RATIO  \tSSC_DPT_PRSNL_RSRC_CST_USD_AMT\r\n,\tNTAC.SSC_DEPRECIATION_COST_USD_AMT*SA_SLK_ALLOCATION_RATIO*TACPRDKEY.PRODUCT_KEY_RATIO  \t\tSSC_DEPRECIATION_COST_USD_AMT\r\n,\tNTAC.SSC_REPAIR_COST_USD_AMT*SA_SLK_ALLOCATION_RATIO*TACPRDKEY.PRODUCT_KEY_RATIO        \t\tSSC_REPAIR_COST_USD_AMT\r\n,\tNTAC.SSC_DUTY_VAT_COST_USD_AMT*SA_SLK_ALLOCATION_RATIO*TACPRDKEY.PRODUCT_KEY_RATIO      \t\tSSC_DUTY_VAT_COST_USD_AMT\r\n,\tNTAC.SSC_THRD_PRTY_LGST_CST_USD_AMT*SA_SLK_ALLOCATION_RATIO*TACPRDKEY.PRODUCT_KEY_RATIO  \tSSC_THRD_PRTY_LGST_CST_USD_AMT\r\n,\tNTAC.SSC_THRD_PRTY_MTNC_CST_USD_AMT*SA_SLK_ALLOCATION_RATIO*TACPRDKEY.PRODUCT_KEY_RATIO  \tSSC_THRD_PRTY_MTNC_CST_USD_AMT\r\n,\tNTAC.SSC_ORIG_EQP_MFGR_CST_USD_AMT*SA_SLK_ALLOCATION_RATIO*TACPRDKEY.PRODUCT_KEY_RATIO   \tSSC_ORIG_EQP_MFGR_CST_USD_AMT\r\n,\tNTAC.SSC_WARRANTY_PCT                     \r\n,\tTACSLKEY.ALLOCATION_TYPE ENRICHMENT_METHODOLODY_DESC   \r\n,\tNTAC.SHIPPED_QTY*SA_SLK_ALLOCATION_RATIO*TACPRDKEY.PRODUCT_KEY_RATIO   -- Traceability Changes\r\n,\tNTAC.CONTRACTED_SERVICE_GROUP_NAME -- Traceability Changes\r\n,\tNTAC.SRC_RPTD_SITE_CNTRY_NAME      -- Traceability Changes\r\n,\tNTAC.SRC_RPTD_CUST_NAME            -- Traceability Changes\r\n,\tCURRENT_TIMESTAMP(0) EDW_CREATE_DTM                \r\n,\tUSER EDW_CREATE_USER               \r\n,\tCURRENT_TIMESTAMP(0)  EDW_UPDATE_DTM                \r\n,\tUSER EDW_UPDATE_USER  \r\n,   'I' ACTION_CODE\r\n,\t'I' DML_TYPE\r\nFROM  $$FINLGLVWDB.N_SR_SRVC_SUPPORT_CENTER_COST NTAC  \r\nINNER JOIN $$STGDB.WI_CCM_TS_MTH_QTR_CNTL CNTL\r\nON NTAC.FISCAL_YEAR_MONTH_INT=CNTL.FISCAL_YEAR_MONTH_INT \r\nLEFT OUTER JOIN $$ETLONLYDB.EL_CCM_C3_CST_THTR_SL1_MAP ESL1\r\nON ESL1.C3_CUST_THEATER = NTAC.C3_CUSTOMER_THEATER_NAME\r\nLEFT OUTER JOIN $$ETLONLYDB.EL_CCM_C3_MKT_SGMT_SCMS_MAP ESCMS\r\nON ESCMS.C3_MARKET_SEGMENT=NTAC.C3_CUST_MARKET_SEGMENT_NAME\r\nINNER JOIN $$STGDB.WI_CCM_SSC_ID_SERVICE_KEY TACSRVCKEY\r\nON    TACSRVCKEY.SERVICE_REQUEST_SSC_COST_KEY=NTAC.SERVICE_REQUEST_SSC_COST_KEY \r\nINNER JOIN $$STGDB.WI_CCM_SSC_ID_PRODUCT_KEY TACPRDKEY\r\nON    TACPRDKEY.SERVICE_REQUEST_SSC_COST_KEY=NTAC.SERVICE_REQUEST_SSC_COST_KEY \r\nINNER JOIN $$STGDB.WI_CCM_SSC_ID_SALES_TERR_KEY TACSLKEY\r\nON    TACSLKEY.SERVICE_REQUEST_SSC_COST_KEY=NTAC.SERVICE_REQUEST_SSC_COST_KEY",
