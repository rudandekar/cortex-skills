      "attributes": {
        "Sql Query": "SELECT\r\nST.TRANSACTION_ID ,\r\nST.APPLICATION_NAME ,\r\nST.APPLICATION_ID ,\r\nST.LEDGER_ID      ,\r\nST.ORG_ID         ,\r\nST.TRX_CLASS,\r\nST.ORDER_LINE_ID,\r\nST.TRX_LINE_ID,\r\nST.AMOUNT,\r\nST.QUANTITY_INVOICED  AS ORDER_QUANTITY,\r\nST.CURRENCY_CODE,\r\nST.PROCESS_STATUS,\r\nST.ELEMENT_TYPE   ,\r\nST.RULE_START_DATE,\r\nST.RULE_END_DATE  ,\r\nST.ACCOUNTING_RULE_DURATION ,\r\nST.ATTRIBUTE1,\r\nST.ATTRIBUTE2,\r\nST.ATTRIBUTE6,\r\nST.SKU,\r\nST.ACCOUNTING_RULE_NAME,\r\nST.TRANSACTION_SOURCE,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DATETIME,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DATETIME   ,\r\nUSER AS EDW_UPDATE_USER    ,\r\nST.ATTRIBUTE12,\r\nST.ATTRIBUTE13,\r\nST.ATTRIBUTE4,\r\nST.ATTRIBUTE16,\r\nST.ATTRIBUTE21,\r\nST.ATTRIBUTE24,\r\nST.ATTRIBUTE8           \r\nFROM $$STGDB.ST_CG_XXCFIR_REV_EXT_SUB_VIP  ST\r\nWHERE  NOT EXISTS (\r\nSELECT 1 FROM $$ETLVWDB.EL_XXCFIR_REV_EXT_SUB_VIP  EL\r\nWHERE\r\nEL.TRANSACTION_ID= ST.TRANSACTION_ID\r\nAND EL.APPLICATION_ID = ST.APPLICATION_ID\r\nAND EL.ATTRIBUTE4=ST.ATTRIBUTE4\r\n)",
