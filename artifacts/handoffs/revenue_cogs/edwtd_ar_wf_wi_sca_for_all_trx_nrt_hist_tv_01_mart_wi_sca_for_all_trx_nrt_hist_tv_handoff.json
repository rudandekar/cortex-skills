      "attributes": {
        "Sql Query": "SELECT\r\nSALES_CREDIT_ASSIGNMENT_KEY   , \r\nEP_SOURCE_LINE_ID_INT, \r\nRU_AR_TRANSACTION_LINE_KEY  ,           \r\nCURRENT_TIMESTAMP(0)                 AS   START_TV_DATETIME  ,           \r\nCURRENT_DATE                         AS   START_SSP_DATE   ,             \r\nBK_SALES_CREDIT_TYPE_CODE ,  \r\nSALES_REP_NUMBER  ,         \r\nCURRENT_TIMESTAMP(0)                 AS   END_TV_DATETIME    ,           \r\nCURRENT_DATE                         AS   END_SSP_DATE   ,               \r\nSCA_SALES_COMMISSION_PCT   , \r\nSALES_TERRITORY_KEY   ,      \r\nSK_LINE_SEQ_ID_INT      ,    \r\nSS_CD , \r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),       \r\n'I'  AS ACTION_CODE,\r\n'I' AS DML_TYPE,\r\nSK_SC_AGENT_ID_INT        \r\nFROM $$NRTNCRVWDB.N_SCA_FOR_ALL_TRX_NRT_HIST_TV\r\nWHERE SCA_TRANSACTION_TYPE =    'NON APPLIED'\r\nAND EDW_UPDATE_DTM  >= '$$LastExtractDate'\r\nAND SS_CD IN ('CG','1C')\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY SALES_CREDIT_ASSIGNMENT_KEY   ORDER BY END_TV_DTM  DESC)=1",
