      "attributes": {
        "Sql Query": "SELECT REP_LEV_2.LOOKUP_VALUE ,\r\nREP_LEV_1.LOOKUP_VALUE ,\r\nREP_LEV_2.DESCRIPTION\r\nFROM $$STGDB.ST_OM_CFI_ADJ_LOOKUPS REP_LEV_2\r\nINNER JOIN $$ETLVWDB.EL_OM_CFI_ADJ_TYPE_ALL CFI_ADJ_TY\r\nON( CFI_ADJ_TY.REPORT_LEVEL_2_ID = REP_LEV_2.LOOKUP_ID )\r\nINNER JOIN $$ETLVWDB.EL_OM_CFI_ADJ_LOOKUPS REP_LEV_1 \r\nON( CFI_ADJ_TY.REPORT_LEVEL_1_ID = REP_LEV_1.LOOKUP_ID\r\nAND REP_LEV_1.LOOKUP_TYPE = 'LEVEL1' )\r\nINNER JOIN $$FINLGLVWDB.N_DIRECT_CORP_ADJ_TYPE_LVL1 LEVEL1\r\nON (LEVEL1.BK_DIRECT_CORP_ADJ_LVL1_TYP_CD = REP_LEV_1.LOOKUP_VALUE)\r\nWHERE \r\n REP_LEV_2.LOOKUP_TYPE = 'LEVEL2'\r\nAND REP_LEV_1.LOOKUP_VALUE <>'INDIRECT'\r\nGROUP BY REP_LEV_1.LOOKUP_VALUE,\r\nREP_LEV_2.LOOKUP_VALUE,\r\nREP_LEV_2.DESCRIPTION",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
