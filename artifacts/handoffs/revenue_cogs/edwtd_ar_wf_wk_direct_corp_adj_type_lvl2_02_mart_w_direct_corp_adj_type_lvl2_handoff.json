      "attributes": {
        "Sql Query": "SELECT REP_LEV_2.BATCH_ID, \r\n\r\nREP_LEV_2.ATTRIBUTE1, \r\n\r\nREP_LEV_2.ATTRIBUTE2,\r\n\r\nREP_LEV_2.ATTRIBUTE3, \r\n\r\nREP_LEV_2.ATTRIBUTE4,\r\n\r\nREP_LEV_2.ATTRIBUTE5, \r\n\r\nREP_LEV_2.CREATED_BY,\r\n\r\nREP_LEV_2.CREATION_DATE, \r\n\r\nREP_LEV_2.DESCRIPTION,\r\n\r\nREP_LEV_2.ENABLED_FLAG, \r\n\r\nREP_LEV_2.END_DATE,\r\n\r\nREP_LEV_2.GES_UPDATE_DATE, \r\n\r\nREP_LEV_2.GLOBAL_NAME,\r\n\r\nREP_LEV_2.LAST_UPDATED_BY, \r\n\r\nREP_LEV_2.LAST_UPDATE_DATE,\r\n\r\nREP_LEV_2.LOOKUP_ID, \r\n\r\nREP_LEV_2.LOOKUP_TYPE,\r\n\r\nREP_LEV_2.LOOKUP_VALUE, \r\n\r\nREP_LEV_2.START_DATE, \r\n\r\nREP_LEV_2.CREATE_DATETIME, \r\n\r\nREP_LEV_2.ACTION_CODE,\r\n\r\n'RI' AS EXCEPTION_TYPE\r\n\r\nFROM\r\n\r\n$$STGDB.ST_OM_CFI_ADJ_LOOKUPS  REP_LEV_2\r\n\r\nLEFT OUTER JOIN $$ETLVWDB.EL_OM_CFI_ADJ_TYPE_ALL EOCATA\r\n\r\n                ON( EOCATA.REPORT_LEVEL_2_ID = REP_LEV_2.LOOKUP_ID )\r\n\r\nLEFT OUTER JOIN $$ETLVWDB.EL_OM_CFI_ADJ_LOOKUPS REP_LEV_1 \r\n\r\n                ON(         REP_LEV_1.LOOKUP_TYPE = 'LEVEL1' \r\n\r\n                                AND EOCATA.REPORT_LEVEL_1_ID = REP_LEV_1.LOOKUP_ID )\r\n\r\nWHERE \r\n\r\nREP_LEV_2.LOOKUP_TYPE = 'LEVEL2' \r\n\r\nAND REP_LEV_1.LOOKUP_VALUE <>'INDIRECT'\r\n\r\nAND \r\n\r\n( NOT EXISTS (SELECT 1 FROM $$ETLVWDB.EL_OM_CFI_ADJ_TYPE_ALL EOCATA  \r\n\r\n                                                WHERE   EOCATA.REPORT_LEVEL_2_ID = REP_LEV_2.LOOKUP_ID)\r\n\r\n OR NOT EXISTS ( SEL 1 FROM  $$ETLVWDB.EL_OM_CFI_ADJ_LOOKUPS REP_LEV_1 ,$$ETLVWDB.EL_OM_CFI_ADJ_TYPE_ALL EOCATA\r\n  ,$$FINLGLVWDB.N_DIRECT_CORP_ADJ_TYPE_LVL1 NDCATL \r\n\r\n                                                WHERE  REP_LEV_1.LOOKUP_TYPE = 'LEVEL1'\r\n\r\n                                                AND REP_LEV_1.LOOKUP_VALUE <>'INDIRECT'\r\n\r\n                                                AND EOCATA.REPORT_LEVEL_1_ID = REP_LEV_1.LOOKUP_ID\r\n\r\n                                                AND NDCATL.BK_DIRECT_CORP_ADJ_LVL1_TYP_CD =REP_LEV_1.LOOKUP_VALUE)\r\n\r\n)",
        "User Defined Join": "",
