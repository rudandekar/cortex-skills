      "attributes": {
        "Sql Query": "/*Insert DIRECT MAP data into SSC table when account number is EXPENSE*/\r\nSELECT\t\r\nWCSMA.FISCAL_MONTH_ID,\r\nWCSMA.THEATER,\r\nWCSMA.COST_TYPE,\r\n1,\r\nCOALESCE (SUM (WCSID.AMOUNT), 0)\r\nFROM $$STGDB.WI_CCM_SSC_MAPPING_ALLOCATION WCSMA\r\nJOIN $$STGDB.WI_CCM_SSC_INPUT_DOLLAR WCSID\r\nON WCSMA.PL_NODE_VALUE = WCSID.PL_NODE_VALUE\r\nAND WCSMA.FUNCTIONAL_COST = WCSID.FUNCTIONAL_COST\r\nAND WCSMA.FISCAL_MONTH_ID = WCSID.FISCAL_MONTH_ID\r\nAND WCSMA.FISCAL_MONTH_ID IN (\r\nSELECT\tFISCAL_MONTH_ID \r\nFROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)\r\nAND UPPER (WCSMA.ALLOCATION_METHOD) = 'DIRECT MAP'\r\nAND UPPER (WCSMA.ACCOUNT_NUMBER) = 'EXPENSE'\r\nGROUP\tBY 1,2,3,4\r\n\r\nUNION\r\n/* Insert DIRECT MAP data into SSC table when COALESCE (UPPER (WCSMA.account_number), 'EXPENSE') <> 'EXPENSE' and sub_account_number IS NULL */\r\n\r\nSELECT\t\r\nWCSMA.FISCAL_MONTH_ID,\r\nWCSMA.THEATER,\r\nWCSMA.COST_TYPE,\r\n1,\r\nCOALESCE(SUM (WCSID.AMOUNT), 0)\r\nFROM $$STGDB.WI_CCM_SSC_MAPPING_ALLOCATION WCSMA\r\nJOIN $$STGDB.WI_CCM_SSC_INPUT_DOLLAR WCSID\r\nON WCSMA.PL_NODE_VALUE = WCSID.PL_NODE_VALUE\r\nAND WCSMA.FUNCTIONAL_COST = WCSID.FUNCTIONAL_COST\r\nAND WCSMA.ACCOUNT_NUMBER = WCSID.ACCOUNT_NUMBER\r\nAND WCSMA.FISCAL_MONTH_ID = WCSID.FISCAL_MONTH_ID\r\nAND WCSMA.FISCAL_MONTH_ID IN (\r\nSELECT FISCAL_MONTH_ID \r\nFROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)\r\nAND UPPER (WCSMA.ALLOCATION_METHOD) = 'DIRECT MAP'\r\nAND COALESCE(UPPER (WCSMA.ACCOUNT_NUMBER),'EXPENSE') <> 'EXPENSE'\r\nAND WCSMA.SUB_ACCOUNT_NUMBER IS NULL\r\nGROUP\tBY 1,2,3,4\r\n\r\nUNION\r\n\r\n/*Insert DIRECT MAP data into SSC table when NVL (UPPER (WCSMA.account_number), 'EXPENSE') <> 'EXPENSE' and sub_account_number IS NOT NULL*/\r\nSELECT\tWCSMA.FISCAL_MONTH_ID,\r\nWCSMA.THEATER,\r\nWCSMA.COST_TYPE,\r\n1,\r\nCOALESCE (SUM (WCSID.AMOUNT), 0)\r\nFROM $$STGDB.WI_CCM_SSC_MAPPING_ALLOCATION WCSMA\r\nJOIN $$STGDB.WI_CCM_SSC_INPUT_DOLLAR WCSID\r\nON WCSMA.PL_NODE_VALUE = WCSID.PL_NODE_VALUE\r\nAND\tWCSMA.FUNCTIONAL_COST = WCSID.FUNCTIONAL_COST\r\nAND\tWCSMA.SUB_ACCOUNT_NUMBER IS NOT NULL\r\nAND\tWCSMA.ACCOUNT_NUMBER = WCSID.ACCOUNT_NUMBER\r\nAND\tWCSMA.SUB_ACCOUNT_NUMBER = WCSID.SUB_ACCOUNT_NUMBER\r\nAND\tWCSMA.FISCAL_MONTH_ID = WCSID.FISCAL_MONTH_ID\r\nAND\tWCSMA.FISCAL_MONTH_ID IN (\r\nSELECT FISCAL_MONTH_ID \r\nFROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)\r\nAND\tUPPER (WCSMA.ALLOCATION_METHOD) = 'DIRECT MAP'\r\nAND\tCOALESCE (UPPER (WCSMA.ACCOUNT_NUMBER), 'EXPENSE') <> 'EXPENSE'\r\nGROUP\tBY 1,2,3,4",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "DELETE\tFROM $$STGDB.WI_SSC_ALLOC_ER \r\nWHERE\tFISCAL_MONTH_ID  IN (\r\nSELECT\tFISCAL_MONTH_ID \r\nFROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID);\r\n\r\nUPDATE\t$$STGDB.WI_CCM_SSC_QOH_DRIVER WCSSQD\r\nSET INV_PERCENTAGE =(\r\nSELECT\tWCSQD.INV_COST_AMT \r\nFROM\t$$STGDB.WI_CCM_SSC_QOH_DRIVER WCSQD   \r\nWHERE\tWCSSQD.THEATER = WCSQD.THEATER \r\nAND\tWCSSQD.FISCAL_MONTH_ID = WCSQD.FISCAL_MONTH_ID)/\r\n(SELECT\tSUM(INV_COST_AMT) AS DRIVER_TOTAL_AMOUNT \r\nFROM $$STGDB.WI_CCM_SSC_QOH_DRIVER \r\nWHERE FISCAL_MONTH_ID   IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID))\r\nWHERE WCSSQD.FISCAL_MONTH_ID IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID);",
