      "attributes": {
        "Sql Query": "SELECT \r\nBK_DEAL_ID\r\n,FMY.FISCAL_YEAR_MONTH_INT\r\n,SRC_REPORTED_FCM_CUSTOMER_NAME\r\n,MAJOR_OFFER_TYPE_CD\r\n,DEAL_START_DTM\r\n,DV_DEAL_START_DT\r\n,DEAL_END_DTM\r\n,DV_DEAL_END_DT\r\n,CURRENT_TIMESTAMP(0)\r\n,USER\r\n,CURRENT_TIMESTAMP(0)\r\n,USER\r\n,XAAS_FLG\r\nFROM $$FINLGLVWDB.N_FCM_DEAL_MAPPING NFDM\r\n, $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR FMY\r\nWHERE NFDM.BK_DV_FISCAL_YEAR_MTH_NUM_INT = FMY.FISCAL_MONTH_AGO_MONTH_NUMBER\r\nAND DEAL_END_DTM = CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))\r\nAND FMY.CURRENT_FISCAL_MONTH_FLAG ='Y'\r\nAND FMY.FISCAL_MONTH_START_DATE = CURRENT_DATE \r\nAND NOT EXISTS (SELECT 1 FROM $$FINLGLVWDB.N_FCM_DEAL_MAPPING FDM\r\nWHERE NFDM.BK_DEAL_ID= FDM.BK_DEAL_ID\r\nAND FMY.FISCAL_YEAR_MONTH_INT = FDM.BK_DV_FISCAL_YEAR_MTH_NUM_INT)",
