      "attributes": {
        "Sql Query": "SELECT \r\nFISCAL.BK_FISCAL_MONTH_NUMBER_INT BK_FISCAL_MONTH_NUM_INT,\r\nDEPT.BK_DEPARTMENT_CODE BK_DEPT_CD,\r\nDEPT.BK_COMPANY_CODE BK_COMPANY_CD, \r\nST.SALES_TERRITORY_KEY   SALES_TERRITORY_KEY,\r\nPR.ITEM_KEY PRODUCT_KEY,\r\nSTG.PNL_LINE_ITEM_NAME BK_PNL_LINE_ITEM_NAME,\r\nFISCAL.BK_FISCAL_CALENDAR_CODE BK_FISCAL_CALENDAR_CD,\r\nFISCAL.BK_FISCAL_YEAR_NUMBER_INT BK_FISCAL_YEAR_NUM_INT,\r\n'COGS' REV_OR_COGS_TYPE_CD,\r\nSTG.AMOUNT CIS_COGS_ALLOCATION_USD_AMT,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\n'I' ACTION_CODE,\r\n'I' DML_TYPE\r\nFROM $$STGDB.ST_AE_CISCOGS_ALLOCATION_PUB STG\r\nINNER JOIN $$COMREFVWDB.N_FISCAL_MONTH  FISCAL  ON ( FISCAL.BK_FISCAL_YEAR_NUMBER_INT * 100 + FISCAL.BK_FISCAL_MONTH_NUMBER_INT ) = STG.FISCAL_MONTH_ID\r\nINNER JOIN $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT DEPT  ON DEPT.BK_COMPANY_CODE  = SUBSTR(STG.DEPT_NUMBER, 1, 3 )  AND DEPT.BK_DEPARTMENT_CODE = SUBSTR(STG.DEPT_NUMBER,4 )  \r\nINNER JOIN $$COMREFVWDB.N_SALES_TERRITORY ST  ON ST.BK_SALES_TERRITORY_NAME_CODE  =  STG.SALES_TERRITORY_CODE\r\nINNER JOIN $$COMREFVWDB.N_PRODUCT PR ON STG.PRODUCT_ID = PR.BK_PRODUCT_ID\r\nGROUP BY 1,2,3,4,5,6,7,8,10",
        "User Defined Join": "",
        "Source Filter": "",
