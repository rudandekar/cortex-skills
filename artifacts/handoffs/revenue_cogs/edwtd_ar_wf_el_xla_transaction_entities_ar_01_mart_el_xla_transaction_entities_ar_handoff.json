      "attributes": {
        "Sql Query": "SELECT \r\nGLOBAL_NAME                    \r\n,ENTITY_ID                      \r\n,APPLICATION_ID                 \r\n,ENTITY_CODE                    \r\n,CREATION_DATE  \r\n,SOURCE_APPLICATION_ID                \r\n,SOURCE_ID_INT_1                \r\n,TRANSACTION_NUMBER             \r\n,LEDGER_ID \r\n,LAST_UPDATE_DATE\r\nFROM $$STGDB.ST_CG_XLA_TRX_ENTITIES_AR  ST \r\nWHERE (ST.APPLICATION_ID = 222 OR \r\n\tST.APPLICATION_ID IN (SELECT APPLICATION_ID FROM $$ETLVWDB.EL_FND_APPLICATION_AR \r\n\t                       WHERE UPPER(APPLICATION_NAME) IN ('REVENUE ACCOUNTING ENGINE','CISCO TWO TIER','CISCO OPEN RMA')  AND LANG = 'US'))\r\nAND NOT EXISTS(SEL 1 FROM $$ETLVWDB.EL_XLA_TRANSACTION_ENTITIES_AR EL \r\nWHERE ST.ENTITY_ID = EL.ENTITY_ID \r\nAND ST.APPLICATION_ID = EL.APPLICATION_ID \r\nAND ST.GLOBAL_NAME= EL.GLOBAL_NAME )",
