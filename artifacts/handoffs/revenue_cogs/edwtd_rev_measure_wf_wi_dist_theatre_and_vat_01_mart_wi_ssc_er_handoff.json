      "attributes": {
        "Sql Query": "SELECT FISCAL_MONTH_ID,THEATER,COST_TYPE,SUB_COST_TYPE,COST\r\nFROM $$STGDB.WI_SSC_ALLOC_ER\r\nWHERE FISCAL_MONTH_ID IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "UPDATE WSAE \r\nFROM $$STGDB.WI_SSC_ALLOC_ER WSAE,\r\nWI_COST_VAT CVT\r\nSET COST = WSAE.COST+CVT.COST\r\nWHERE WSAE.FISCAL_MONTH_ID IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)\r\nAND UPPER (WSAE.COST_TYPE) LIKE '%TPL%'\r\nAND UPPER(WSAE.THEATER)=UPPER(CVT.THEATER); \r\n\r\n-- Fix to have cost_type as Supplementary Data and sub_cost_type as VAT / Duty\r\n\r\nupdate $$STGDB.WI_SSC_ALLOC_ER \r\nset COST_TYPE='Supplementary Data' ,  SUB_COST_TYPE='VAT / Duty'\r\nwhere fiscal_month_id IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID) \r\nand upper(cost_type) like'%VAT%';\r\n\r\nUPDATE $$STGDB.WI_SSC_ALLOC_ER\r\nSET THEATER = \r\nCASE WHEN THEATER= 'EM - EAST' THEN 'EME' \r\nWHEN THEATER= 'EM - LATAM' THEN 'LATAM' \r\nWHEN THEATER= 'US-CAN' THEN 'NAM' \r\nWHEN THEATER= 'EUROPEAN MKTST' THEN 'EMEA' \r\nELSE THEATER END \r\nWHERE FISCAL_MONTH_ID IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID);\r\n\r\nUPDATE $$STGDB.WI_SSC_ALLOC_ER\r\nSET COST_TYPE = 'Departmental - Global SSC Ops'\r\nWHERE FISCAL_MONTH_ID IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID) \r\nAND COST_TYPE='Departmental - Global SC Ops';\r\n\r\nUPDATE SSE\r\nFROM $$STGDB.WI_SSC_ALLOC_ER SSE, $$STGDB.WI_THEATER_MAP STM /* ST_THEATER_MAP changed to WI_THEATER_MAP*/\r\nSET THEATER = COALESCE(STM.THEATER_NAME,SSE.THEATER)\r\nWHERE STM.EXT_THEATER_NAME = UPPER(TRIM(SSE.THEATER)) \r\nAND SSE.FISCAL_MONTH_ID IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID);\r\n\r\nDELETE $$STGDB.WI_SSC_ER\r\nWHERE FISCAL_MONTH_ID IN (\r\nSELECT FISCAL_MONTH_ID \r\nFROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID);",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
