        "Sql Query": "SELECT DT.THEATER,WSAE.COST AS COST_VAT\r\nFROM $$STGDB.WI_SSC_ALLOC_ER WSAE\r\nJOIN $$STGDB.WI_DIST_THEATRE DT\r\nON WSAE.FISCAL_MONTH_ID IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID)\r\nAND UPPER (WSAE.COST_TYPE) LIKE '%VAT%'\r\nAND UPPER(WSAE.THEATER)=UPPER(DT.THEATER)",
