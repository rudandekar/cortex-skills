      "attributes": {
        "Sql Query": "SELECT TMP.REGION_ID,TMP.PARENT_REGION_ID,TMP.GLOBAL_NAME , TMP.COUNTRY_CODE\r\nFROM (\r\nSELECT \r\nSCWR.REGION_ID,SCWR.PARENT_REGION_ID,SCWR.GLOBAL_NAME , SCWR.COUNTRY_CODE,SCWR.REFRESH_DATETIME\r\nFROM\r\n  $$STGDB.ST_CG1_WSH_REGIONS SCWR\r\nWHERE SCWR.SOURCE_DML_TYPE<> 'DELETE' AND NOT EXISTS\r\n(SELECT   1 FROM \r\n  $$ETLONLYDB.EL_CG1_WSH_REGIONS  ECWR\r\nWHERE SCWR.REGION_ID = ECWR.REGION_ID\r\nAND     SCWR.GLOBAL_NAME = ECWR.GLOBAL_NAME ) )TMP\r\nQUALIFY RANK () OVER (PARTITION BY TMP.REGION_ID ORDER BY TMP. REGION_ID, TMP.REFRESH_DATETIME DESC ) = 1",
        "User Defined Join": "",
        "Source Filter": "",
