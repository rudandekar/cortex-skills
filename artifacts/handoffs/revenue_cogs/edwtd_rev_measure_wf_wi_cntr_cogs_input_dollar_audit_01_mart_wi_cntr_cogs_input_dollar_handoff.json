      "attributes": {
        "Sql Query": "SELECT \r\nWEA.DV_FISCAL_YEAR_MONTH_NUM_INT AS FISCAL_YEAR_MONTH_NUM_INT\r\n,CENTRAL.COST_TYPE\r\n,CENTRAL.DIRECT_FLAG\r\n,CENTRAL.AS_TSS_FLAG\r\n,CENTRAL.PL_NODE_VALUE\r\n,CENTRAL.PL_NODE_NAME\r\n,CENTRAL.PL_NODE_LEVEL\r\n,WEA.BK_COMPANY_CODE||WEA.DD_BK_DEPT_CD DEPT_NUMBER\r\n,SUM(ZEROIFNULL(WEA.RU_DV_USD_DEBIT_AMT)-ZEROIFNULL(WEA.RU_DV_USD_CREDIT_AMT)) AMOUNT\r\n,CENTRAL.INTERNAL_L2_THEATER/*Added New attribute as part of FEB 13,2022 Release*/\r\nFROM \r\n$$STGDB.WI_EXPENSE_ACTUALS WEA,\r\n$$STGDB.WI_FINANCE_ACCOUNTS ACC,\r\n$$FINLGLVWDB.N_FINANCIAL_DEPARTMENT DEP,\r\n$$FINLGLVWDB.R_PL_HIERARCHY PL,\r\n$$ETLVWDB.EL_CNTR_COGS_PL_MAPPING  CENTRAL , --- CENTRAL PL NODE DRIVER INPUT TABLE \r\n$$STGDB.WI_TSS_COST_CNTRL_MONTH_ID MTH_CTRL -- CURRENT MONTH CONTROL TABLE\r\n\r\n   WHERE \r\nWEA.BK_COMPANY_CODE=DEP.BK_COMPANY_CODE \r\nAND     WEA.DD_BK_DEPT_CD=DEP.BK_DEPARTMENT_CODE \r\nAND     DEP.BK_COMPANY_CODE=PL.FINANCIAL_COMPANY_CODE \r\nAND DEP.BK_DEPARTMENT_CODE=PL.FINANCIAL_DEPARTMENT_CODE \r\nAND     PL.NODE_LEVEL05_NAME IN ('CX LEGACY.SUPPORT SERVICES','CX LEGACY.PROACTIVE SERVICES')\r\nAND     WEA.DD_FINANCIAL_ACCOUNT_CD= ACC.BK_FINANCIAL_ACCOUNT_CODE \r\nAND     WEA.DD_BK_SUBACCOUNT_CD=ACC.BK_SUBACCOUNT_CODE \r\nAND     (WEA.DD_FINANCIAL_COMPANY_MAPPED_CD IN ('MO','MC') \r\n                                                                                                OR        \r\n                        (WEA.DD_FINANCIAL_COMPANY_MAPPED_CD =  'UO'     \r\n                                    AND     WEA.BK_JOURNAL_ENTRY_CATEGORY_NAME =  'REVALUATION'     \r\n                                    AND     WEA.BK_JOURNAL_ENTRY_SOURCE_NAME = 'REVALUATION' \r\n                                    AND     WEA.PUSH_TO_GLBL_CONSOL_BOOKS_FLG ='Y')\r\n                        )      \r\nAND     ACC.LEVEL03_ACCT_GROUP_ID='EXPENSE' \r\nAND     ACC.LEVEL04_ACCT_GROUP_ID <> 'NON EXPENSE SSOT OTHER' \r\nAND     DEP.FINANCIAL_DEPT_NAME <> 'NON-SI-DEPT' \r\nAND     WEA.DV_FISCAL_YEAR_MONTH_NUM_INT = CENTRAL.FISCAL_YEAR_MONTH_INT\r\nAND CENTRAL.FISCAL_YEAR_MONTH_INT =  MTH_CTRL.FISCAL_YEAR_MONTH_INT --- Current Fiscal Months for which Cogs ME is processed\r\nAND(PL.NODE_LEVEL06_VALUE = CENTRAL.PL_NODE_VALUE  \r\n                                                OR        \r\n                        PL.NODE_LEVEL07_VALUE = CENTRAL.PL_NODE_VALUE \r\n                                                OR        \r\n                        PL.NODE_LEVEL08_VALUE = CENTRAL.PL_NODE_VALUE  \r\n                                                OR        \r\n                        PL.NODE_LEVEL09_VALUE = CENTRAL.PL_NODE_VALUE \r\n                                                OR        \r\n                        PL.NODE_LEVEL10_VALUE = CENTRAL.PL_NODE_VALUE  \r\n                                                OR        \r\n                        PL.NODE_LEVEL11_VALUE = CENTRAL.PL_NODE_VALUE  \r\n                                                OR        \r\n                        PL.NODE_LEVEL12_VALUE = CENTRAL.PL_NODE_VALUE  \r\n                                                OR        \r\n                        PL.NODE_LEVEL13_VALUE = CENTRAL.PL_NODE_VALUE  \r\n                                                OR        \r\n                        PL.NODE_LEVEL14_VALUE = CENTRAL.PL_NODE_VALUE \r\n                                                OR        \r\n                        PL.NODE_LEVEL15_VALUE = CENTRAL.PL_NODE_VALUE\r\n                        )\r\nGROUP BY 1,2,3,4,5,6,7,8,10",
        "User Defined Join": "",
        "Source Filter": "",
