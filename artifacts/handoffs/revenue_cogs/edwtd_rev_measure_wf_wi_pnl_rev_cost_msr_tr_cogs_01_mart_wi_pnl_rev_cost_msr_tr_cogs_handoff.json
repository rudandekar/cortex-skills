      "attributes": {
        "Sql Query": "SELECT                \r\nDV_FISCAL_YEAR_MONTH_NUM_INT BK_FISCAL_YEAR_MTH_NUMBER_INT,\r\n'COGS'     BK_REVENUE_OR_COGS_TYPE_CD,\r\n6619657  /*TRAINING_ADJ_PROD*/ BK_PRODUCT_KEY,\r\n6619657  /*TRAINING_ADJ_PROD*/ GOODS_PRODUCT_KEY,\r\nDD_FINANCIAL_ACCOUNT_CD BK_FINANCIAL_ACCOUNT_CD,\r\n'UNKNOWN'BK_REV_MEASURE_TRNSCTN_TYPE_CD,\r\n-999 DV_TRIANGULATION_TYPE_ID_INT,\r\n'UNKNOWN'BK_PRDT_SUBGROUP_ALLOC_SRC_CD,\r\nTCA.SALES_TERRITORY_KEY  BK_SALES_TERRITORY_KEY,\r\nBK_SALES_TERRITORY_KEY BK_TRNGLTD_SALES_TERRITORY_KEY,\r\n-9999 SALES_ORDER_LINE_KEY,\r\n'UNKNOWN' BK_SRC_RPRTD_SRVC_CONTRACT_NUM,\r\nCAST(SUM(((ZEROIFNULL(JEL.RU_DV_USD_DEBIT_AMT)-ZEROIFNULL(JEL.RU_DV_USD_CREDIT_AMT))* (-1))*SPLIT_PCT/100)  AS DECIMAL(26,7)) COMP_US_NET_REV_AMT,\r\n'UNK'BK_COMPANY_CD,\r\n'UNK'BK_ISO_COUNTRY_CD,\r\n'SERVICE'DV_PRODUCT_TYPE,\r\n'Training - COGS' DV_PNL_LINE_ITEM_NAME\r\nFROM  $$FINLGLVWDB.N_JOURNAL_ENTRY_LINE  JEL                                \r\nINNER JOIN $$STGDB.WI_PNL_MTH_CNTL_SRVC_COGS_TR FM                               \r\nON   JEL.DV_FISCAL_YEAR_MONTH_NUM_INT   = FM.FISCAL_YEAR_MONTH_INT                     \r\n\r\nINNER JOIN  $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RF\r\nON FM.FISCAL_YEAR_MONTH_INT= RF.FISCAL_YEAR_MONTH_INT\r\n\r\nINNER JOIN $$FINLGLVWDB.N_TRNG_COGS_ALCTN_PERCENTAGE TCA \r\nON TCA.BK_FISCAL_YEAR_NUMBER_INT  = RF. FISCAL_YEAR_NUMBER_INT\r\n\r\nINNER JOIN  $$FINLGLVWDB.N_JOURNAL_ENTRY JE  \r\nON   (JEL.BK_JOURNAL_ENTRY_NUMBER_INT   =JE.BK_JOURNAL_ENTRY_NUMBER_INT                      \r\nAND JEL.SET_OF_BOOKS_KEY=JE.SET_OF_BOOKS_KEY)                             \r\nINNER JOIN  $$FINLGLVWDB.N_SET_OF_BOOKS_TV SOB                           \r\nON (JEL.SET_OF_BOOKS_KEY = SOB.SET_OF_BOOKS_KEY                           \r\nAND SOB.END_TV_DT='3500-01-01')   \r\nINNER JOIN  $$FINLGLVWDB.R_PL_HIERARCHY PL                     \r\nON (JEL.BK_COMPANY_CODE               =PL.FINANCIAL_COMPANY_CODE                    \r\nAND JEL.DD_BK_DEPT_CD=PL.FINANCIAL_DEPARTMENT_CODE                                \r\nAND PL.NODE_LEVEL05_NAME='CX Legacy.Training')                   \r\nINNER JOIN  $$FINLGLVWDB.R_FINANCIAL_ACCOUNT_HIERARCHY AC                   \r\nON (JEL.DD_FINANCIAL_ACCOUNT_CD = AC.BK_FINANCIAL_ACCOUNT_CODE                           \r\nAND AC.LEVEL03_ACCT_GROUP_ID='Expense'                 \r\nAND AC.LEVEL04_ACCT_GROUP_ID <> 'Non Expense SSOT Other')                \r\nWHERE                                 \r\n(  JEL.DD_FINANCIAL_COMPANY_MAPPED_CD  IN ( 'MO' , 'MC' )                     \r\nOR(  JEL.DD_FINANCIAL_COMPANY_MAPPED_CD =  'UO'                               \r\nAND JE.BK_JOURNAL_ENTRY_CATEGORY_NAME =  'Revaluation'                                \r\nAND JE.BK_JOURNAL_ENTRY_SOURCE_NAME = 'Revaluation'                      \r\nAND SOB.PUSH_TO_GLBL_CONSOL_BOOKS_FLG ='Y'                    \r\n)                               \r\n)GROUP BY 1,5,9,10",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
