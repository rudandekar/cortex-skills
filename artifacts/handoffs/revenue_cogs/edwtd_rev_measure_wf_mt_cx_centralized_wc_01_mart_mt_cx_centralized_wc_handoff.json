      "attributes": {
        "Sql Query": "SELECT \r\nFISCAL_YEAR_MONTH_INT\r\n,HYBRID_PRODUCT_FAMILY\r\n,SUM(CENTRAL_TS_PLATFORM_WC_USD_AMT) AS CENTRAL_TS_PLATFORM_WC_USD_AMT\r\n,SUM(ALLOCATED_TAC_WC_USD_AMT) AS ALLOCATED_TAC_WC_USD_AMT\r\n,WC_AS_OF_FISCAL_YEAR_MONTH_INT\r\n,EDW_CREATE_DTM\r\n,EDW_CREATE_USER\r\n,EDW_UPDATE_DTM\r\n,EDW_UPDATE_USER\r\nFROM (\r\nSELECT\r\n(SELECT FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID) AS FISCAL_YEAR_MONTH_INT\r\n,TAC_BY_PF.HYBRID_PRODUCT_FAMILY\r\n,SUM((CAST((A.CENTRALIZED_COST_USD_AMT * B.SSC_PCT * CAST(C.TAC_PCT AS DECIMAL(26,6))) AS DECIMAL(30,0)))) AS CENTRAL_TS_PLATFORM_WC_USD_AMT\r\n,NULL AS ALLOCATED_TAC_WC_USD_AMT\r\n, TAC_BY_PF.WC_TRNX_FISCAL_YEAR_MONTH_INT AS WC_AS_OF_FISCAL_YEAR_MONTH_INT\r\n,CURRENT_TIMESTAMP(0)  AS EDW_CREATE_DTM\r\n,CURRENT_USER  AS EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0)  AS EDW_UPDATE_DTM\r\n,CURRENT_USER AS EDW_UPDATE_USER\r\nFROM $$STGDB.WI_WC_CNTRL_TAC_BY_PF TAC_BY_PF\r\nINNER JOIN $$FINLGLVWDB.MT_CX_CENTRALIZED_COGS A \r\nON (A.FISCAL_YEAR_MONTH_INT = TAC_BY_PF.WC_TRNX_FISCAL_YEAR_MONTH_INT\r\nAND A.DV_CX_LINE_OF_BIZ_CODE = 'TSS' \r\nAND A.DV_COST_TYPE = 'Platforms' )\r\nINNER JOIN $$STGDB.WI_WC_CNTRL_SSC_WARR_TOTAL_PCT B \r\nON (A.FISCAL_YEAR_MONTH_INT = B.WC_TRNX_FISCAL_YEAR_MONTH_INT \r\nAND TAC_BY_PF.HYBRID_PRODUCT_FAMILY = B.HW_FAMILY)\r\nINNER JOIN $$STGDB.WI_WC_CNTRL_ALLCTD_TAC_PCT C  \r\nON (C.WC_TRNX_FISCAL_YEAR_MONTH_INT = A.FISCAL_YEAR_MONTH_INT\r\nAND C.HYBRID_PRODUCT_FAMILY = TAC_BY_PF.HYBRID_PRODUCT_FAMILY)\r\nWHERE A.FISCAL_YEAR_MONTH_INT IN\r\n(SELECT DISTINCT FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID_WC)\r\nGROUP BY 1,2,3,6,7,8,9\r\nUNION\r\nSELECT\r\nFISCAL_YEAR_MONTH\r\n,HYBRID_PRODUCT_FAMILY \r\n,NULL AS CENTRAL_TS_PLATFORM_WC_USD_AMT\r\n,SUM(TAC_ALLOCATED_COST) AS ALLOCATED_TAC_WC_USD_AMT    \r\n,WC_TRNX_FISCAL_YEAR_MONTH_INT\r\n,CURRENT_TIMESTAMP(0)  AS EDW_CREATE_DTM\r\n,CURRENT_USER  AS EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0)  AS EDW_UPDATE_DTM\r\n,CURRENT_USER AS EDW_UPDATE_USER\r\nFROM $$STGDB.WI_WC_CNTRL_ALLCTD_TAC_PF_MTCH\r\nWHERE WC_TRNX_FISCAL_YEAR_MONTH_INT IN\r\n(SELECT DISTINCT FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID_WC)\r\nGROUP BY 1,2,3,4,6,7,8,9\r\n) A\r\nGROUP BY 1,2,3,6,7,8,9",
        "User Defined Join": "",
