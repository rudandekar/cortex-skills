  "transformation_chain": [
    {
      "name": "SQ_ST_CG1_BOM_CALENDAR_DATES",
      "type": "Source Qualifier",
      "description": "",
      "fields": [
        {
          "name": "INV_ORG_NAME_KEY",
          "datatype": "integer",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        },
        {
          "name": "BK_CALENDAR_DT",
          "datatype": "date/time",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        },
        {
          "name": "CALENDAR_DATE_STATUS_CD",
          "datatype": "string",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        },
        {
          "name": "ACTION_CODE",
          "datatype": "string",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        },
        {
          "name": "DML_TYPE",
          "datatype": "string",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "SELECT\r\nNCIO.INVENTORY_ORGN_NAME_KEY AS INV_ORG_NAME_KEY,\r\nSCBCD.CALENDAR_DATE AS BK_CALENDAR_DT,\r\n(CASE WHEN SCBCD.SEQ_NUM IS NOT NULL THEN 'WORK DAY'\r\nWHEN SCBCD.SEQ_NUM IS NULL AND RFDTY.CALENDAR_DAY_NAME IN ('SATURDAY','SUNDAY') THEN 'NON-WORK DAY'\r\nWHEN SCBCD.SEQ_NUM IS NULL AND RFDTY.CALENDAR_DAY_NAME IN ('MONDAY','TUESDAY','WEDNESDAY','THURSDAY','FRIDAY') THEN 'HOLIDAY'\r\nELSE 'UNKNOWN' END) AS CALENDAR_DATE_STATUS_CODE,\r\nSCBCD.ACTION_CD AS ACTION_CODE,\r\n(CASE WHEN (NMIOWC.INV_ORG_NAME_KEY IS NULL OR NMIOWC.BK_CALENDAR_DT IS NULL) THEN 'I' ELSE 'U' END) AS DML_TYPE\r\nFROM \r\n(\r\nSELECT \r\nCALENDAR_CODE,\r\nCALENDAR_DATE,\r\nACTION_CD,\r\nSEQ_NUM\r\nFROM $$STGDB.ST_CG1_BOM_CALENDAR_DATES\r\nUNION\r\nSELECT \r\nCALENDAR_CODE,\r\nCALENDAR_DATE,\r\nACTION_CD,\r\nSEQ_NUM\r\nFROM $$EXCEPDB.EX_CG1_BOM_CALENDAR_DATES\r\n)SCBCD\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR RFDTY\r\nON RFDTY.CALENDAR_DATE = SCBCD.CALENDAR_DATE\r\nINNER JOIN $$STGDB.ST_CG1_MTL_PARAMETER SCMP\r\nON SCMP.CALENDAR_CODE = SCBCD.CALENDAR_CODE\r\nINNER JOIN $$COMREFVWDB.N_CISCO_INVENTORY_ORG NCIO\r\nON NCIO.INVENTORY_ORGANIZATION_CODE = SCMP.ORGANIZATION_CODE\r\nLEFT JOIN $$INVFLMTVWDB.N_MFG_INV_ORG_WRKNG_CLNDR NMIOWC\r\nON NMIOWC.INV_ORG_NAME_KEY = NCIO.INVENTORY_ORGN_NAME_KEY\r\nAND NMIOWC.BK_CALENDAR_DT = SCBCD.CALENDAR_DATE",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    },
