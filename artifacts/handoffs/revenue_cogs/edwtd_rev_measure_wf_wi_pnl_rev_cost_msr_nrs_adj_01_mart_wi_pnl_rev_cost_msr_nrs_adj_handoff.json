      "attributes": {
        "Sql Query": "SELECT\r\n\tEANMA.DV_FISCAL_YEAR_MTH_NUMBER_INT  BK_FISCAL_YEAR_MTH_NUMBER_INT,\r\n\r\n\tCASE \r\n\t\tWHEN ELSMP.MEASURE_ID = 1 THEN 'REVENUE' \r\n\t\tWHEN ELSMP.MEASURE_ID IN (2,3,4,5,6,22) THEN 'COGS'  \r\n\tEND BK_REVENUE_OR_COGS_TYPE_CD ,\r\n\t\r\n\tEANMA.PRODUCT_KEY BK_PRODUCT_KEY, \r\n\r\n\tSALES_TERRITORY_KEY   BK_SALES_TERRITORY_KEY,\r\n\r\n\tCASE WHEN BK_REVENUE_OR_COGS_TYPE_CD = 'COGS' THEN ( \tSUM(ZEROIFNULL(EANMA.ADJUSTMENT_ALLOCATION_USD_AMT)  ) * -1) \r\n\t\t\tELSE SUM(ZEROIFNULL(EANMA.ADJUSTMENT_ALLOCATION_USD_AMT))  END AS COMP_US_NET_REV_AMT, \r\n\r\n\tEANMA.BK_ADJ_SUB_MEASURE_TYPE_CD DV_PNL_LINE_ITEM_NAME,\r\n\tEANMA.OFFER_TYPE_LEVEL_2 AS  BK_OFFER_TYPE_NAME \r\n\r\nFROM   $$ETLVWDB.EL_AE_NRS_MANUAL_ADJ   EANMA \r\nINNER JOIN $$STGDB.WI_PNL_MTH_CNTL_NRS_ADJ WIPMCNA ON WIPMCNA.FISCAL_MONTH_ID = EANMA.DV_FISCAL_YEAR_MTH_NUMBER_INT \r\nINNER JOIN $$ETLVWDB.EL_AE_SUB_MEASURE_PUB ELSMP ON ELSMP.SUB_MEASURE_NAME = EANMA.BK_ADJ_SUB_MEASURE_TYPE_CD \r\nGROUP BY 1, 2, 3, 4, 6  ,7",
