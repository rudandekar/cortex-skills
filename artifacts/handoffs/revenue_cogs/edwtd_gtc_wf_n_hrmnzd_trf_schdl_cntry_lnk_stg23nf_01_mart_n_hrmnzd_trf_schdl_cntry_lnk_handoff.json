      "attributes": {
        "Sql Query": "SELECT \r\nSHC.HTS_CODE As BK_HRMNZD_TARIFF_SCHEDULE_CD,\r\nCOALESCE(NIC.BK_ISO_COUNTRY_CODE,'UNK') As BK_ISO_COUNTRY_CD,\r\nSHC.START_DATE As BK_HTS_EFFECTIVE_START_DT,\r\n(CASE WHEN SHC.STATUS='A' THEN 'Y' ELSE 'N' END) As BK_ACTIVE_FLG,\r\nCOALESCE(SHC.END_DATE,DATE '3500-01-01') As HTS_EFFECTIVE_END_DT,\r\nSHC.CUSTOM_HTS_FLAG As CUSTOM_HTS_FLG,\r\nSHC.OVERRIDE_FLAG As HTS_CONTENT_OVERRIDE_FLG,\r\nSHO.RATE_OVERRIDE As OVERRIDE_DUTY_RT,\r\nSHC.MFN_DUTY_RATE As DUTY_RT,\r\nSHC.CREATED_DATE As HTS_CONTENT_UPLOAD_DT,\r\nSHC.HTS_DESC As HTS_DESCR,\r\nCURRENT_TIMESTAMP(0)  As EDW_CREATE_DTM,\r\nUSER As EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0)  As EDW_UPDATE_DTM,\r\nUSER As EDW_UPDATE_USER,\r\nCAST(SHC.MODIFIED_DATE AS TIMESTAMP(0)) SOURCE_MODIFIED_DTM,\r\nSHC.MODIFIED_DATE     DV_SOURCE_MODIFIED_DT,\r\n'UNKNOWN' AS DV_HTS_CNTRY_ASGNMNT_STATUS_CD , \r\nCOALESCE(SHC.DASHBOARD_FLAG,'N') AS DASHBOARD_FLG        \r\nFROM \r\n$$STGDB.ST_XXCFI_CB_HTS_CONTENTS  SHC\r\nLEFT OUTER JOIN  $$COMREFVWDB.N_ISO_COUNTRY NIC\r\nON (SHC.COUNTRY_CODE = NIC.ISO_COUNTRY_SHORT_CODE)\r\nLEFT OUTER JOIN $$STGDB.ST_XXCFI_CB_HTS_OVERRIDE_RATE SHO \r\n  ON (SHC.HTS_ID =SHO.HTS_ID)\r\n  QUALIFY ROW_NUMBER() OVER(PARTITION BY SHC.HTS_CODE,NIC.BK_ISO_COUNTRY_CODE,SHC.START_DATE,SHC.STATUS ORDER BY SHC.HTS_ID desc) = 1\r\nWHERE (BK_HRMNZD_TARIFF_SCHEDULE_CD ,BK_ISO_COUNTRY_CD,BK_HTS_EFFECTIVE_START_DT,BK_ACTIVE_FLG)              \r\nNOT IN (SELECT  BK_HRMNZD_TARIFF_SCHEDULE_CD,BK_ISO_COUNTRY_CD ,BK_HTS_EFFECTIVE_START_DT,BK_ACTIVE_FLG FROM $$FINLGLVWDB.N_HRMNZD_TRF_SCHDL_CNTRY_LNK)",
        "User Defined Join": "",
