      "attributes": {
        "Sql Query": "SELECT \r\n  NAT.BK_AR_TRX_NUMBER AS BK_AR_TRX_NUMBER,\r\n NAT.AR_TRX_DATETIME AS AR_TRX_DATETIME,\r\n NAT.AR_TRX_KEY AS AR_TRX_KEY,\r\n NAT.RU_BK_ADJD_AR_TRX_KEY AS RU_BK_ADJD_AR_TRX_KEY,\r\n NATL.AR_TRX_LINE_KEY AS AR_TRX_LINE_KEY,\r\n SRCP.COGS_PERCENT_KEY AS COGS_PERCENT_KEY,\r\n CURRENT_TIMESTAMP(0) AS EDW_CREATE_DATE,\r\n 'AUD_REV_DRVD_RAE_REVENUE' AS AUDIT_JOB_NAME,\r\n COUNT(*) AS AUD_COUNT\r\n FROM   $$ETLVWDB.EL_RAO_XXCFI_RAE_COGS_PERCNT   ERXRCP \r\n  INNER JOIN $$ETLVWDB.EL_AR_MONTH_PROCESS_DATE EAMPD ON  ERXRCP.GL_DATE  BETWEEN EAMPD.START_DATE AND EAMPD.END_DATE\r\n  INNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES  NSSC ON  ERXRCP.GLOBAL_NAME = NSSC.GLOBAL_NAME  AND NSSC.GLOBAL_NAME = 'CG'\r\n \r\n  INNER JOIN $$FINLGLVWDB.N_AR_TRX_LINE NATL  ON  NATL.SK_CUSTOMER_TRX_LINE_ID_LINT  = ERXRCP.CUSTOMER_TRX_LINE_ID \r\n  \t\t\t\tAND NATL.SS_CODE = NSSC.SOURCE_SYSTEM_CODE\r\n \r\n INNER JOIN $$FINLGLVWDB.N_AR_TRX NAT ON   NATL.AR_TRX_KEY = NAT.AR_TRX_KEY \r\n INNER JOIN $$ETLVWDB.EL_AR_LEDGER  EAL ON   ERXRCP.LEDGER_ID = EAL.LEDGER_ID\r\n INNER JOIN $$ETLVWDB.SM_RAE_COGS_PERCENT SRCP   ON ERXRCP.ADJUSTMENT_LINE_ID = SRCP.SK_COGS_PERCENT_ID  AND NSSC.SOURCE_SYSTEM_CODE = SRCP.SS_CD\r\n \r\n WHERE\t1=1\r\nAND ERXRCP.GL_POSTED_DATE IS NOT NULL \r\nAND COALESCE(ERXRCP.GL_POSTED_FLAG, 'N') = 'Y'\r\n\r\nAND ERXRCP.CUSTOMER_TRX_LINE_ID IS NOT NULL \r\nAND ERXRCP.COGS_REV_GL_DATE IS NOT NULL \r\nAND ERXRCP.COGS_REV_POSTED_DATE IS NOT NULL\r\nAND ERXRCP.COGS_DEFERRAL_FLAG IN ('Y', 'N')\r\n\r\nAND NOT EXISTS(SELECT 'X'  FROM  $$FINLGLVWDB.N_DRVD_NCR_REV_TRX_FOR_REV DRVDR\r\n\t\t\t\t\t\t\t\t\t\t WHERE DRVDR.DV_TRANSACTION_KEY = SRCP.COGS_PERCENT_KEY\r\n\t\t\t\t\t\t\t\t\t\t AND DRVDR.DV_TRANSACTION_SOURCE_CD='RAE_COGS'\r\n\t\t\t\t\t\t\t\t\t\t AND DRVDR.NCR_TRANSACTION_REASON_CD = 'O'\r\n\t\t\t\t\t\t\t\t\t\t AND DRVDR.DV_FISCAL_YEAR_MONTH_NUM_INT  = EAMPD.FISCAL_ID) \r\nGROUP BY 1,2,3,4,5,6",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
