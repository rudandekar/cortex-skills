      "attributes": {
        "Sql Query": "SELECT \r\n SH.SALES_TERRITORY_KEY,\r\n REV.SALES_REP_NUMBER  AS SALES_REP_NUM,\r\n SH.L1_SALES_TERRITORY_DESCR,\r\n SH.L2_SALES_TERRITORY_DESCR,\r\n SH.L3_SALES_TERRITORY_DESCR,\r\n SH.L4_SALES_TERRITORY_DESCR,\r\n SH.L5_SALES_TERRITORY_DESCR,\r\n SH.L6_SALES_TERRITORY_DESCR, \r\nSO.BK_SO_NUMBER_INT  SOURCE_ORDER_NUM_INT,\r\n REV.BK_POS_TRANSACTION_ID_INT POS_TRANSACTION_ID_INT,\r\n REV.DV_ERP_DEAL_ID  AS DEAL_ID,\r\n REV.PRODUCT_KEY,\r\n PRD.PRODUCT_FAMILY_ID    ,\r\n PRD.PRODUCT_ID,\r\n REV.REV_MEASURE_TRANS_TYPE_CD,\r\n REV.DV_SERVICE_FLG,\r\nREV.DV_CORPORATE_REVENUE_FLG,\r\nREV.DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\n'UNKNOWN' DISCOUNT_CATEGORY,\r\n 'N' AS PF_EXCL_FLG,\r\n 'N' AS PID_EXCL_FLG,\r\n 'N' AS DEAL_EXCL_FLG,\r\n 'N' AS SO_EXCL_FLG,\r\n REV.REVENUE_MEASURE_KEY\r\n FROM \r\n $$FINLGLVWDB.MT_RSTD_GL_REV_MEASURE REV , \r\n $$COMREFVWDB.R_SALES_HIERARCHY SH,\r\n (\r\n SELECT \r\n ITEM_KEY,\r\n RU_BK_PRODUCT_FAMILY_ID   AS PRODUCT_FAMILY_ID    ,\r\n BK_PRODUCT_ID   AS PRODUCT_ID\r\n FROM \r\n $$COMREFVWDB.R_PRODUCTS_FIN RPFIN\r\n INNER JOIN\r\n $$COMREFDB.R_TRX_PRODUCT RTP\r\n ON RPFIN.ITEM_KEY=RTP.PRODUCT_KEY\r\n ) PRD,\r\n$$slsordvwDB.N_SALES_ORDER SO\r\n WHERE  SH.SALES_TERRITORY_KEY= REV.SALES_TERRITORY_KEY\r\n   AND PRD.ITEM_KEY=REV.PRODUCT_KEY\r\n   AND REV.DV_SERVICE_FLG='N' \r\n AND REV.DV_CORPORATE_REVENUE_FLG ='Y'\r\n AND SO.SALES_ORDER_KEY = REV.SALES_ORDER_KEY              \r\n AND SH.SALES_TERRITORY_TYPE_CODE='CORP. REVENUE'",
        "User Defined Join": "",
        "Source Filter": "",
