      "attributes": {
        "Sql Query": "select \r\nINCIDENT_NUMBER,\r\nSHIPPED_PID,\r\nORDER_NUMBER,\r\nORDER_CREATION_DATE,\r\nB.FISCAL_MONTH_NAME AS ORDER_CREATION_MONTH,\r\nB.FISCAL_QUARTER_NAME AS ORDER_CREATION_QUARTER,\r\nCLAIMED_SN,\r\nENTITLEMENT_RESULT,\r\nPRIMARY_REASON,\r\nACTUAL_SHIPMENT_DATE,\r\nSHIPPED_SN,\r\nACTUAL_RECEIVED_DATE,\r\nC.FISCAL_MONTH_NAME AS RMA_RETURN_FISCAL_MONTH,\r\nC.FISCAL_QUARTER_NAME RMA_RETURN_FISCAL_QUARTER,\r\nRECEIVED_SN,\r\nRECEIVED_PID, \r\nRECEIVED_SN_ON_CONTRACT, \r\nRECEIVED_SN_ON_WARRANTY\r\n,B.DV_FISCAL_QUARTER_ID\r\nfrom $$STGDB.ST_RMA_DETAILS_B_SHIP_RCVD A\r\nJOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR B \r\nON B.CAlenDAR_DATE = CAST(A.ORDER_CREATION_DATE AS DATE)\r\nLEFT JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR C \r\nON C.CAlenDAR_DATE = CAST(A.ACTUAL_RECEIVED_DATE AS DATE)",
