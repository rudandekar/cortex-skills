      "attributes": {
        "Sql Query": "SELECT\r\nSTSD.ADDRESS1\tAS\tADDRESS,\r\nSTSD.CREATION_DATE\tAS\tCREATED_DT,\r\nSTSD.PST_CREATION_DATE \tAS\tCREATED_DT_GMT,\r\nSTSD.PARTY_NAME\tAS\tNAME,\r\nNULL\tAS\tPHONE,\r\nSTSD.THEATER\tAS\tPHY_SVC_GRP_A,\r\nSTSD.PARTY_NUMBER\tAS\tREST_OF_NAME,\r\nSTSD.ADDRESS2\tAS\tSECOND_ADDRESS,\r\nSTSD.STATE\tAS\tSTATE_PROV,\r\nCURRENT_TIMESTAMP(0)\tAS\tUPDATE_DATE,\r\nSTSD.TIME_ZONE\tAS\tX_COORDINATE,\r\nNULL\tAS\tCALENDAR_ID,\r\nSTSD.CITY\tAS\tCITY,\r\nSTSD.COUNTRY\tAS\tCOUNTRY,\r\nSTSD.ADDRESS4\tAS\tFOURTH_ADDRESS,\r\nNULL\tAS\tGLOBAL_NAME,\r\nCURRENT_TIMESTAMP(0) AS GMT_OFFSET,\r\nCURRENT_TIMESTAMP(0) AS LAST_UPDATED_DT,\r\nCURRENT_TIMESTAMP(0) AS LAST_UPDATED_DTTM,\r\nNULL AS LAST_UPDATED_ID,\r\nCURRENT_TIMESTAMP(0) AS LAST_UPDATED_TM,\r\nNULL\tAS\tMTX_PLACE_ID,\r\nCAST(STSD.PARTY_SITE_ID AS CHAR(30))\tAS\tORACLE_ADDR_ID,\r\nCOALESCE(STSD.PARTY_SITE_ID,-999)\tAS\tPLACE_ID,\r\n'C3'\tAS\tSOURCE_SYSTEM,\r\nNULL\tAS\tSTATUS,\r\nSTSD.ADDRESS3\tAS\tTHIRD_ADDRESS,\r\nCASE WHEN STSD.SHIP_TO_FLAG='Y' THEN 'CUST' ELSE 'BILL' END\tAS\tWHOS_PLACE,\r\nSTSD.POSTAL_CODE\tAS\tZIPPOST,\r\nCURRENT_TIMESTAMP(0)\tAS\tCREATE_DATE,\r\nCURRENT_TIMESTAMP(0) AS CREATED_TM,\r\nUSER AS CREATE_USER,\r\nUSER AS UPDATE_USER,\r\nSTSD.PARTY_ID,\r\nSTSD.BL_SITE_KEY,\r\nSTSD.CUST_ACCOUNT_ID,\r\nSTSD.CUST_ACCT_SITE_ID\r\nFROM\r\n$$STGDB.ST_TSS_SITES_D_COGS STSD\r\nLEFT OUTER JOIN\r\n$$ETLVWDB.EL_TSS_SITES_D CSP\r\nON \r\nSTSD.PARTY_SITE_ID = CSP.PLACE_ID\r\nWHERE CSP.PLACE_ID IS NULL\r\nQUALIFY\tROW_NUMBER () OVER (PARTITION BY PARTY_SITE_ID ORDER\tBY CREATE_DATE DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "UPDATE CSP\r\nFROM $$ETLVWDB.EL_TSS_SITES_D CSP,\r\n     (SELECT * FROM $$STGDB.ST_TSS_SITES_D_COGS \r\n\t\tQUALIFY\tROW_NUMBER () OVER (PARTITION BY PARTY_SITE_ID\r\n\t\tORDER\tBY CREATION_DATE  DESC) = 1) WCSP\r\n SET\r\nNAME                          \t=WCSP.PARTY_NAME              ,\r\nCREATED_DT                    \t=WCSP.CREATION_DATE                 ,\r\nLAST_UPDATED_DT               \t=NULL          ,   \r\nLAST_UPDATED_TM               \t=NULL             ,  \r\nUPDATE_DATE                   \t=CURRENT_TIMESTAMP(0)                   ,\r\nCREATE_DATE                   \t=CURRENT_TIMESTAMP(0)                   ,\r\nLAST_UPDATED_DTTM             \t=NULL      ,       \r\nWHOS_PLACE                    \t=CASE WHEN WCSP.SHIP_TO_FLAG='Y' THEN 'CUST' ELSE 'BILL' END                    ,\r\nADDRESS                       \t=WCSP.ADDRESS1                       ,\r\nCITY                          \t=WCSP.CITY                          ,\r\nSTATE_PROV                    \t=WCSP.STATE           ,         \r\nCOUNTRY                       \t=WCSP.COUNTRY                  ,     \r\nPHONE                         \t=NULL                        , \r\nSTATUS                        \t=NULL                       , \r\nCREATED_TM                    \t=NULL              ,      \r\nLAST_UPDATED_ID               \t=NULL     ,          \r\nREST_OF_NAME                  \t=WCSP.PARTY_NUMBER           ,       \r\nSECOND_ADDRESS                \t=WCSP.ADDRESS2      ,          \r\nTHIRD_ADDRESS                 \t=WCSP.ADDRESS3           ,      \r\nFOURTH_ADDRESS                \t=WCSP.ADDRESS4        ,        \r\nZIPPOST                       \t=WCSP.POSTAL_CODE                       ,\r\nPHY_SVC_GRP_A                 \t=WCSP.THEATER         ,        \r\nGLOBAL_NAME                   \t=NULL              ,     \r\nCALENDAR_ID                   \t=NULL                ,   \r\nX_COORDINATE                  \t=WCSP.TIME_ZONE              ,    \r\nGMT_OFFSET                    \t=NULL                   , \r\nCREATED_DT_GMT                \t=WCSP.PST_CREATION_DATE          ,      \r\nORACLE_ADDR_ID                \t=CAST(WCSP.PARTY_SITE_ID AS CHAR(30))             ,   \r\nSOURCE_SYSTEM                 \t='C3'               ,  \r\nMTX_PLACE_ID                  \t=NULL    ,\r\nPARTY_ID                        =WCSP.PARTY_ID    ,\r\nBL_SITE_KEY                     =WCSP.BL_SITE_KEY  ,\r\nCUST_ACCOUNT_ID \t\t\t\t=WCSP.CUST_ACCOUNT_ID \r\nCUST_ACCT_SITE_ID\t\t\t\t=WCSP.CUST_ACCT_SITE_ID\r\nWHERE \r\n CSP.PLACE_ID  = WCSP.PARTY_SITE_ID\r\nAND CSP.PLACE_ID IS NOT NULL",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
