      ],
      "attributes": {
        "Sql Query": "SEL SRC.FISCAL_YEAR_MTH_INT, ABS( (BL_AMT-REV_AMT)) AS REV_MISMATCH_AMT,\r\n'ERP' AS AUDIT_TRXN_TYPE,\r\n'MT_UNBILLED_REVENUE' AS AUDIT_TABLE,\r\nCURRENT_DATE AS AUDIT_DATE\r\nFROM (\r\nSELECT DV_FISCAL_YEAR_MTH_NUMBER_INT AS FISCAL_YEAR_MTH_INT ,SUM(DV_FB_COMP_NET_PRICE_USD_AMT) BL_AMT FROM   $$SLSORDVWDB.N_SCAA_FINANCE_BACKLOG_TV NSOB  \r\n WHERE  DV_FISCAL_YEAR_MTH_NUMBER_INT  =(SEL DISTINCT DV_FISCAL_YEAR_MTH_NUMBER_INT FROM $$SLSORDVWDB.N_SCAA_FINANCE_BACKLOG WHERE DD_FB_SS_CD NOT IN ('AE')) \r\n AND  DV_FB_CORP_FINANCE_BACKLOG_FLG='Y' AND DD_FB_SS_CD NOT IN ('AE')\r\n GROUP BY 1\r\n  )SRC\r\nLEFT JOIN (\r\nSEL PROCESSED_FISCAL_MTH AS FISCAL_MTH,SUM(UNBILLED_REVENUE_AMT) REV_AMT  FROM $$FINLGLVWDB.MT_UNBILLED_REVENUE WHERE PROCESSED_FISCAL_MTH IN ( SEL DISTINCT DV_FISCAL_YEAR_MTH_NUMBER_INT FROM $$SLSORDVWDB.N_SCAA_FINANCE_BACKLOG WHERE DD_FB_SS_CD NOT IN ('AE') )\r\nAND TRANSACTION_TYPE='ERP' GROUP BY 1\r\n  )TGT\r\nON TGT.FISCAL_MTH=SRC.FISCAL_YEAR_MTH_INT\r\nUNION ALL\r\nSEL\r\n SRC.FISCAL_YEAR_MTH_INT, ABS(BACKLOG_TSV +UNBILLED_TSV) AS REV_MISMATCH_AMT,\r\n'ERP' AS AUDIT_TRXN_TYPE,\r\n'MT_UNBILLED_REVENUE' AS AUDIT_TABLE,\r\nCURRENT_DATE AS AUDIT_DATE\r\nFROM\r\n(SELECT DV_FISCAL_YEAR_MTH_NUMBER_INT AS FISCAL_YEAR_MTH_INT, \r\nSUM(UNIT_SALE_PRICE*ORDER_QUANTITY*(DD_FB_SALES_COMMISSION_PCT/100)    ) AS BACKLOG_TSV\r\nFROM   $$SLSORDVWDB.N_SCAA_FINANCE_BACKLOG_TV NSOB  \r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE NSOL\r\nON NSOL.SALES_ORDER_LINE_KEY=NSOB.DD_FB_SALES_ORDER_LINE_KEY\r\n WHERE  DV_FISCAL_YEAR_MTH_NUMBER_INT  =(SEL DISTINCT DV_FISCAL_YEAR_MTH_NUMBER_INT FROM $$SLSORDVWDB.N_SCAA_FINANCE_BACKLOG WHERE DD_FB_SS_CD NOT IN ('AE')) \r\n AND  DV_FB_CORP_FINANCE_BACKLOG_FLG='Y' AND DD_FB_SS_CD NOT IN ('AE')\r\n GROUP BY 1)SRC\r\nLEFT JOIN\r\n(SEL PROCESSED_FISCAL_MTH AS FISCAL_YEAR_MTH_INT,SUM(DV_TOTAL_SALES_VALUE_AMT/PL_CONVERSION_RATE)*-1 AS UNBILLED_TSV  FROM $$FINLGLVWDB.MT_UNBILLED_REVENUE WHERE PROCESSED_FISCAL_MTH IN \r\n( SEL DISTINCT DV_FISCAL_YEAR_MTH_NUMBER_INT FROM $$SLSORDVWDB.N_SCAA_FINANCE_BACKLOG WHERE DD_FB_SS_CD NOT IN ('AE') )\r\nAND TRANSACTION_TYPE='ERP' GROUP BY 1)TGT\r\nON TGT.FISCAL_YEAR_MTH_INT=SRC.FISCAL_YEAR_MTH_INT",
        "User Defined Join": "",
