      "attributes": {
        "Sql Query": "SELECT\r\nTRANSACTION_DIST_ID\r\n,AE_HEADER_ID                  \r\n,AE_LINE_NUM                   \r\n,XAL.APPLICATION_ID                \r\n,XAL.GLOBAL_NAME\r\n,COALESCE(XAL.ACCOUNTED_CR,0) - COALESCE(XAL.ACCOUNTED_DR,0) AS ADJUSTMENT_REVENUE\r\n,CAST (0 AS DECIMAL(26,7)) AS ADJUSTMENT_COGS\r\nFROM \r\n$$STGDB.WI_XLA_AE_LINE_CORP_ADJ_INCR XAL\r\nINNER JOIN $$ETLVWDB.EL_FND_APPLICATION_AR APPL\r\nON XAL.APPLICATION_ID = APPL.APPLICATION_ID\r\nAND APPL.LANG = 'US'\r\nAND APPL.APPLICATION_NAME = 'Cisco Open RMA'\r\n/*UNION ALL\r\nSELECT\r\nAE_HEADER_ID                  \r\n,AE_LINE_NUM                   \r\n,XAL.APPLICATION_ID                \r\n,XAL.GLOBAL_NAME\r\n,CAST( (COALESCE(XAL.ACCOUNTED_CR,0) + COALESCE(XAL.ACCOUNTED_DR,0)) * \r\n (CASE WHEN XAL.ATTRIBUTE7 = 'REVENUE DEFERRAL OFFSET' THEN -1 WHEN XAL.ATTRIBUTE7 = 'REVENUE AMORTIZATION OFFSET' THEN 1 ELSE 1 END) AS DECIMAL(26,7)) AS ADJUSTMENT_REVENUE\r\n,CAST( (COALESCE(ADJ_COGS.ADJUSTMENT_COGS,0)) *\r\n(CASE WHEN XAL.ATTRIBUTE7 = 'REVENUE DEFERRAL OFFSET' THEN -1 WHEN XAL.ATTRIBUTE7 = 'REVENUE AMORTIZATION OFFSET' THEN 1 ELSE 1 END) AS DECIMAL(26,7)) AS ADJUSTMENT_COGS\r\nFROM \r\n$$STGDB.WI_XLA_AE_LINE_CORP_ADJ_INCR XAL\r\nINNER JOIN $$ETLVWDB.EL_FND_APPLICATION_AR APPL\r\nON XAL.APPLICATION_ID = APPL.APPLICATION_ID\r\nAND APPL.LANG = 'US'\r\nAND APPL.APPLICATION_NAME = 'Cisco Two Tier'\r\nINNER JOIN $$ETLVWDB.EL_AR_MONTH_PROCESS_DATE FTH\r\nON CAST(XAL.ACCOUNTING_DATE AS DATE) BETWEEN FTH.START_DATE AND FTH.END_DATE \r\nINNER JOIN\r\n(\r\nSELECT\r\nSUM(COALESCE(XAL.ACCOUNTED_CR,0) + COALESCE(XAL.ACCOUNTED_DR,0)) AS ADJUSTMENT_COGS\r\n,FTH.FISCAL_ID AS FISCAL_ID\r\n,CASE WHEN XAL.ATTRIBUTE7 = 'COGS DEFERRAL OFFSET' THEN 'REVENUE DEFERRAL OFFSET' ELSE 'REVENUE AMORTIZATION OFFSET' END AS DIST_TYPE\r\n,XAL.ATTRIBUTE9\r\nFROM \r\n$$ETLVWDB. EL_XLA_AE_LINES_AR XAL\r\nINNER JOIN $$ETLVWDB.EL_XLA_AE_HEADERS_AR EXAHA\r\nON EXAHA.AE_HEADER_ID = XAL.AE_HEADER_ID\r\nAND EXAHA.APPLICATION_ID = XAL.APPLICATION_ID\r\nAND EXAHA.GLOBAL_NAME = XAL.GLOBAL_NAME\r\nINNER JOIN $$ETLVWDB.EL_FND_APPLICATION_AR APPL\r\nON XAL.APPLICATION_ID = APPL.APPLICATION_ID\r\nAND APPL.LANG = 'US'\r\nAND APPL.APPLICATION_NAME = 'Cisco Two Tier'\r\nINNER JOIN $$ETLVWDB.EL_AR_MONTH_PROCESS_DATE FTH\r\nON CAST(XAL.ACCOUNTING_DATE AS DATE) BETWEEN START_DATE AND END_DATE\r\nWHERE XAL.ATTRIBUTE7 IN ('COGS DEFERRAL OFFSET', 'COGS AMORTIZATION OFFSET')\r\nAND EXAHA.GL_TRANSFER_DATE IS NOT NULL\r\nAND COALESCE(EXAHA.GL_TRANSFER_STATUS_CODE, 'N') = 'Y'\r\nGROUP BY 2,3,4\r\n) ADJ_COGS\r\nON XAL.ATTRIBUTE7 = ADJ_COGS.DIST_TYPE\r\nAND XAL.ATTRIBUTE9 = ADJ_COGS.ATTRIBUTE9\r\nAND ADJ_COGS.FISCAL_ID = FTH.FISCAL_ID\r\nWHERE XAL.ATTRIBUTE7 IN ('REVENUE DEFERRAL OFFSET', 'REVENUE AMORTIZATION OFFSET')\r\n*/",
