      "attributes": {
        "Sql Query": "SELECT\r\nBK_COO_PRJCT_NAME,\r\nBK_COO_COUNTRY_CD,\r\nBK_SN_PREFIX_NUM_CD,\r\nSN_MAP_CREATE_DTM,\r\nDV_SN_MAP_CREATE_DT,\r\nSN_MAP_LAST_UPDATE_DTM,\r\nDV_SN_MAP_LAST_UPDATE_DT,\r\nSN_MAP_CREATED_AUTO_TEST_FLG,\r\nSN_MAP_UPDATED_AUTO_TEST_FLG,\r\nSOURCE_DELETED_FLG,\r\nSN_MAP_LT_UPD_CSCO_WKR_PTY_KEY,\r\nSN_MAP_CREATE_CSCO_WKR_PTY_KEY,\r\nEDW_CREATE_DTM,\r\nEDW_CREATE_USER,\r\nEDW_UPDATE_DTM,\r\nEDW_UPDATE_USER,\r\nSTART_TV_DT,\r\nEND_TV_DT,\r\nACTION_CODE,\r\nDML_TYPE\r\nFROM\r\n(\r\n\tSELECT\r\n\tTOT.BK_COO_PRJCT_NAME,\r\n\tTOT.BK_COO_COUNTRY_CD,\r\n\tTOT.BK_SN_PREFIX_NUM_CD,\r\n\tTOT.SN_MAP_CREATE_DTM,\r\n\tTOT.DV_SN_MAP_CREATE_DT,\r\n\tTOT.SN_MAP_LAST_UPDATE_DTM,\r\n\tTOT.DV_SN_MAP_LAST_UPDATE_DT,\r\n\tTOT.SN_MAP_CREATED_AUTO_TEST_FLG,\r\n\tTOT.SN_MAP_UPDATED_AUTO_TEST_FLG,\r\n\tTOT.SOURCE_DELETED_FLG,\r\n\tTOT.SN_MAP_LT_UPD_CSCO_WKR_PTY_KEY,\r\n\tTOT.SN_MAP_CREATE_CSCO_WKR_PTY_KEY,\r\n\tCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM ,\r\n\tUSER AS EDW_CREATE_USER ,\r\n\tCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n\tUSER AS EDW_UPDATE_USER,\r\n\tTOT.START_TV_DT AS START_TV_DT,\r\n\tCOALESCE(MAX(TOT.START_TV_DT - INTERVAL '1' DAY) OVER (PARTITION BY TOT.BK_COO_PRJCT_NAME,TOT.BK_COO_COUNTRY_CD,TOT.BK_SN_PREFIX_NUM_CD ORDER BY TOT.START_TV_DT\r\n\t\t\tROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING), DATE '3500-01-01') AS END_TV_DT,\r\n\tROW_NUMBER() OVER(PARTITION BY TOT.BK_COO_PRJCT_NAME,TOT.BK_COO_COUNTRY_CD,TOT.BK_SN_PREFIX_NUM_CD ORDER BY TOT.START_TV_DT ASC) AS RANK_INDEX,\r\n\tTOT.ACTION_CODE ,\r\n\t(CASE WHEN RANK_INDEX = 1 \r\n\t\t  AND (NCPSPMT.BK_COO_PRJCT_NAME IS NOT NULL AND NCPSPMT.BK_COO_COUNTRY_CD IS NOT NULL AND NCPSPMT.BK_SN_PREFIX_NUM_CD IS NOT NULL) \r\n\t\tTHEN 'U' \r\n\t\tELSE 'I' END) AS DML_TYPE\r\n\tFROM\r\n\t(\r\n\t\tSELECT\r\n\t\tTIN.BK_COO_PRJCT_NAME,\r\n\t\tTIN.BK_COO_COUNTRY_CD,\r\n\t\tTIN.BK_SN_PREFIX_NUM_CD,\r\n\t\tTIN.SN_MAP_CREATE_DTM,\r\n\t\tTIN.DV_SN_MAP_CREATE_DT,\r\n\t\tTIN.SN_MAP_LAST_UPDATE_DTM,\r\n\t\tTIN.DV_SN_MAP_LAST_UPDATE_DT,\r\n\t\tTIN.SN_MAP_CREATED_AUTO_TEST_FLG,\r\n\t\tTIN.SN_MAP_UPDATED_AUTO_TEST_FLG,\r\n\t\tTIN.SOURCE_DELETED_FLG,\r\n\t\tTIN.SN_MAP_LT_UPD_CSCO_WKR_PTY_KEY,\r\n\t\tTIN.SN_MAP_CREATE_CSCO_WKR_PTY_KEY,\r\n\t\tTIN.START_TV_DT AS START_TV_DT ,\r\n\t\tTIN.ACTION_CODE AS ACTION_CODE,\r\n\t\tTIN.CREATE_DATETIME AS CREATE_DATETIME,\r\n\t\tROW_NUMBER() OVER (PARTITION BY TIN.BK_COO_PRJCT_NAME,TIN.BK_COO_COUNTRY_CD,TIN.BK_SN_PREFIX_NUM_CD,\r\n\t\t\t\t\t\t\t\t\t\tTIN.SN_MAP_CREATED_AUTO_TEST_FLG,TIN.SN_MAP_UPDATED_AUTO_TEST_FLG,TIN.SOURCE_DELETED_FLG,\r\n\t\t\t\t\t\t\t\t\t\tTIN.SN_MAP_LT_UPD_CSCO_WKR_PTY_KEY ,TIN.SN_MAP_CREATE_CSCO_WKR_PTY_KEY\r\n\t\t\t\t\t\t\tORDER BY CREATE_DATETIME DESC) AS ROW_NUM\r\n\t\tFROM\r\n\t\t\t(\r\n\t\t\t\tSELECT\r\n\t\t\t\tNCP.BK_COO_PRJCT_NAME AS BK_COO_PRJCT_NAME,\r\n\t\t\t\tNIC.BK_ISO_COUNTRY_CODE AS BK_COO_COUNTRY_CD,\r\n\t\t\t\tCOALESCE(SCS.SNPREFIX,'UNK') AS BK_SN_PREFIX_NUM_CD,\r\n\t\t\t\tSCS.CREATED_DATE AS SN_MAP_CREATE_DTM,\r\n\t\t\t\tCAST (SCS.CREATED_DATE AS DATE FORMAT 'YYYY-MM-DD') AS DV_SN_MAP_CREATE_DT,\r\n\t\t\t\tSCS.LAST_UPDATED_DATE AS SN_MAP_LAST_UPDATE_DTM,\r\n\t\t\t\tCAST (SCS.LAST_UPDATED_DATE AS DATE FORMAT 'YYYY-MM-DD') AS DV_SN_MAP_LAST_UPDATE_DT,\r\n\t\t\t\t(CASE WHEN  SCS.CREATED_BY = 'AUTOTEST' THEN 'Y' ELSE 'N' END) AS SN_MAP_CREATED_AUTO_TEST_FLG,\r\n\t\t\t\t(CASE WHEN  SCS.LAST_UPDATED_BY = 'AUTOTEST' THEN 'Y' ELSE 'N' END) AS SN_MAP_UPDATED_AUTO_TEST_FLG,\r\n\t\t\t\t'N' AS SOURCE_DELETED_FLG,\r\n\t\t\t\tCOALESCE(NCWPU.CISCO_WORKER_PARTY_KEY,-999) AS SN_MAP_LT_UPD_CSCO_WKR_PTY_KEY,\r\n\t\t\t\tCOALESCE(NCWPC.CISCO_WORKER_PARTY_KEY,-999) AS SN_MAP_CREATE_CSCO_WKR_PTY_KEY,\r\n\t\t\t\tCAST(SCS.LAST_UPDATED_DATE AS DATE ) START_TV_DT ,\r\n\t\t\t\t'I' AS ACTION_CODE,\r\n\t\t\t\tSCS.CREATE_DATETIME AS CREATE_DATETIME\r\n\t\t\t\tFROM $$STGDB.ST_CO_SNPREFIX SCS\r\n\r\n\t\t\t\tINNER JOIN $$FINLGLVWDB.N_COO_PROJECT NCP\r\n\t\t\t\tON COALESCE(SCS.PROJECT_ID,-999) = NCP.SK_PROJECT_ID_INT\r\n\t\t\t\tINNER JOIN $$COMREFVWDB.N_ISO_COUNTRY NIC\r\n\t\t\t\tON COALESCE(UPPER(TRIM(SCS.COO)),'UN') = NIC.ISO_COUNTRY_SHORT_CODE\r\n\t\t\t\tLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWPC\r\n\t\t\t\tON (COALESCE(SCS.CREATED_BY,'UNKNOWN') = NCWPC.CEC_ID)\r\n\t\t\t\tLEFT JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWPU\r\n\t\t\t\tON (COALESCE(SCS.LAST_UPDATED_BY,'UNKNOWN') = NCWPU.CEC_ID )\r\n\r\n\t\t\t\tUNION ALL\r\n\t\t\t\tSELECT\r\n\t\t\t\tBK_COO_PRJCT_NAME,\r\n\t\t\t\tBK_COO_COUNTRY_CD,\r\n\t\t\t\tBK_SN_PREFIX_NUM_CD,\r\n\t\t\t\tSN_MAP_CREATE_DTM,\r\n\t\t\t\tDV_SN_MAP_CREATE_DT,\r\n\t\t\t\tSN_MAP_LAST_UPDATE_DTM,\r\n\t\t\t\tDV_SN_MAP_LAST_UPDATE_DT,\r\n\t\t\t\tSN_MAP_CREATED_AUTO_TEST_FLG,\r\n\t\t\t\tSN_MAP_UPDATED_AUTO_TEST_FLG,\r\n\t\t\t\tSOURCE_DELETED_FLG,\r\n\t\t\t\tSN_MAP_LT_UPD_CSCO_WKR_PTY_KEY,\r\n\t\t\t\tSN_MAP_CREATE_CSCO_WKR_PTY_KEY,\r\n\t\t\t\tSTART_TV_DT,\r\n\t\t\t\t'X' AS ACTION_CODE,\r\n\t\t\t\tEDW_UPDATE_DTM AS CREATE_DATETIME\r\n\t\t\t\tFROM $$FINLGLVWDB.N_COO_PRJCT_SN_PRFX_MAP_TV NCPSPMT\r\n\t\t\t\tWHERE EXISTS\r\n\t\t\t\t\t\t\t(SELECT 1 FROM $$STGDB.ST_CO_SNPREFIX SCS\r\n\t\t\t\t\t\t\t\t\t\tINNER JOIN $$FINLGLVWDB.N_COO_PROJECT NCP\r\n\t\t\t\t\t\t\t\t\t\tON COALESCE(SCS.PROJECT_ID,-999) = NCP.SK_PROJECT_ID_INT\r\n\t\t\t\t\t\t\t\t\t\tINNER JOIN $$COMREFVWDB.N_ISO_COUNTRY NIC\r\n\t\t\t\t\t\t\t\t\t\tON COALESCE(UPPER(TRIM(SCS.COO)),'UN') = NIC.ISO_COUNTRY_SHORT_CODE\r\n\t\t\t\t\t\t\t\tWHERE  \r\n\t\t\t\t\t\t\t\t(NCP.BK_COO_PRJCT_NAME = NCPSPMT.BK_COO_PRJCT_NAME\r\n\t\t\t\t\t\t\t\tAND NIC.BK_ISO_COUNTRY_CODE = NCPSPMT.BK_COO_COUNTRY_CD\r\n\t\t\t\t\t\t\t\tAND\tCOALESCE(SCS.SNPREFIX,'UNK') = NCPSPMT.BK_SN_PREFIX_NUM_CD)\r\n\t\t\t\t\t\t\t\t)\r\n\t\t\t\tAND NCPSPMT.END_TV_DT=16000101\r\n\t\t\t)TIN\r\n\t\tQUALIFY ROW_NUMBER() OVER (PARTITION BY TIN.BK_COO_PRJCT_NAME,TIN.BK_COO_COUNTRY_CD,TIN.BK_SN_PREFIX_NUM_CD,TIN.START_TV_DT ORDER BY TIN.CREATE_DATETIME DESC) =1\r\n\t)TOT\r\nLEFT OUTER JOIN $$FINLGLVWDB.N_COO_PRJCT_SN_PRFX_MAP_TV NCPSPMT\r\nON NCPSPMT.BK_COO_PRJCT_NAME = TOT.BK_COO_PRJCT_NAME\r\nAND NCPSPMT.BK_COO_COUNTRY_CD  = TOT.BK_COO_COUNTRY_CD\r\nAND NCPSPMT.BK_SN_PREFIX_NUM_CD = TOT.BK_SN_PREFIX_NUM_CD\r\nAND NCPSPMT.END_TV_DT = 16000101\r\nWHERE ROW_NUM = 1\r\n) A",
        "User Defined Join": "",
