      "attributes": {
        "Sql Query": "SELECT\r\nBATCH_ID,\r\nSNPREFIX_ID,\r\nPROJECT_ID,\r\nSNPREFIX,\r\nCOO,\r\nCREATED_BY,\r\nCREATED_DATE,\r\nLAST_UPDATED_BY,\r\nLAST_UPDATED_DATE,\r\n'INCR' EXCEPTION_CD,\r\nCREATE_DATETIME,\r\nACTION_CODE,\r\n'RI' EXCEPTION_TYPE\r\nFROM $$STGDB.ST_CO_SNPREFIX SCS\r\nWHERE  NOT EXISTS\r\n\t\t\t\t( \r\n\t\t\t\tSELECT 1 FROM $$FINLGLVWDB.N_COO_PROJECT NCP\r\n\t\t\t\t\r\n\t\t\t\t\t\tINNER JOIN $$COMREFVWDB.N_ISO_COUNTRY NIC\r\n\t\t\t\t\t\tON COALESCE(UPPER(TRIM(SCS.COO)),'UN') = NIC.ISO_COUNTRY_SHORT_CODE\r\n\t\t\t\t\t\t\r\n\t\t\t\t\t\tINNER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWPC\r\n\t\t\t\t\t\tON (COALESCE(SCS.CREATED_BY,'UNKNOWN') = NCWPC.CEC_ID)\r\n\t\t\t\t\t\t\r\n\t\t\t\t\t\tINNER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWPU\r\n\t\t\t\t\t\tON (COALESCE(SCS.LAST_UPDATED_BY,'UNKNOWN') = NCWPU.CEC_ID )\r\n\t\t\t\tWHERE COALESCE(SCS.PROJECT_ID,-999) = NCP.SK_PROJECT_ID_INT\r\n\t\t\t\t)",
