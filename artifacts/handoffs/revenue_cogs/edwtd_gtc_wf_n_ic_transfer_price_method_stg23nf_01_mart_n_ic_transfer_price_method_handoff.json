      "attributes": {
        "Sql Query": "SELECT BK_TRANSFER_PRICE_METHOD_CD,\r\n\t   'N'   AS  SOURCE_DELETED_FLG,\r\n\t   CURRENT_TIMESTAMP(0)  AS EDW_CREATE_DTM,\r\n\t   USER                  AS EDW_CREATE_USER,\r\n       CURRENT_TIMESTAMP(0)  AS EDW_UPDATE_DTM,\r\n\t   USER                  AS EDW_UPDATE_USER\r\nFROM             \r\n( \r\nSELECT DISTINCT MC_QUALIFIER1 AS BK_TRANSFER_PRICE_METHOD_CD\r\nFROM  $$STGDB.ST_CP_TRNSACTIN_ATR_QTC\r\nWHERE MC_QUALIFIER1 IS NOT NULL\r\nUNION \r\nSELECT DISTINCT MC_QUALIFIER1 AS BK_TRANSFER_PRICE_METHOD_CD\r\nFROM  $$STGDB.ST_CP_TRNSACTION_ATTR_BV\r\nWHERE MC_QUALIFIER1 IS NOT NULL\r\nUNION\r\nSELECT DISTINCT MC_QUALIFIER1 AS BK_TRANSFER_PRICE_METHOD_CD\r\nFROM  $$STGDB.ST_CP_TRNSACTION_ATTR_CG1\r\nWHERE MC_QUALIFIER1 IS NOT NULL\r\nUNION\r\nSELECT DISTINCT MC_QUALIFIER1 AS BK_TRANSFER_PRICE_METHOD_CD\r\nFROM  $$STGDB.ST_CP_TRANSACTION_ATTR_SJ\r\nWHERE MC_QUALIFIER1 IS NOT NULL\r\n) IQ\r\nWHERE NOT EXISTS\r\n(\r\n SELECT 1\r\n    FROM     $$FINLGLVWDB.N_IC_TRANSFER_PRICE_METHOD NITPM\r\n    WHERE NITPM.BK_TRANSFER_PRICE_METHOD_CD = IQ.BK_TRANSFER_PRICE_METHOD_CD\r\n)",
