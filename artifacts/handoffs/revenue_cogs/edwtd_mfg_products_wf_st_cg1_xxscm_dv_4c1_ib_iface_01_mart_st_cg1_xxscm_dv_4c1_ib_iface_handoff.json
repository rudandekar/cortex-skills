      "attributes": {
        "Sql Query": "SELECT TMP.MESSAGE_ID\t,\r\nTMP.CYCLE_COUNT_ID\t,\r\nTMP.RESPONSE_DATE\t,\r\nTMP.HANDLING_UNIT_ID\t,\r\nTMP.HANDLING_UNIT_ID_STATUS\t,\r\nTMP.CREATED_BY\t,\r\nTMP.CREATION_DATE\t,\r\nTMP.LAST_UPDATED_BY\t,\r\nTMP.LAST_UPDATE_DATE\t,\r\nTMP.ATTRIBUTE1\t,\r\nTMP.ATTRIBUTE2\t,\r\nTMP.ATTRIBUTE3\t,\r\nTMP.ATTRIBUTE4\t,\r\nTMP.ATTRIBUTE5\t,\r\nTMP.ATTRIBUTE6\t,\r\nTMP.ATTRIBUTE7\t,\r\nTMP.ATTRIBUTE8\t,\r\nTMP.ATTRIBUTE9\t,\r\nTMP.ATTRIBUTE10\t,\r\nTMP.ATTRIBUTE11\t,\r\nTMP.ATTRIBUTE12\t,\r\nTMP.ATTRIBUTE13\t,\r\nTMP.ATTRIBUTE14\t,\r\nTMP.ATTRIBUTE15\t,\r\nTMP.SLC_SITE_NAME\t,\r\nTMP.PART_DUNS_NUMBER\t,\r\nTMP.CISCO_DUNS_NUMBER\t,\r\nTMP.B2B_PROCESS_STATUS\t,\r\nTMP.SEQ_ID\t,\r\n'CG' AS GLOBAL_NAME,\r\nTMP.SOURCE_DML_TYPE,\r\nTMP.SOURCE_COMMIT_TIME ,\r\nTMP.REFRESH_DATETIME\r\nFROM\r\n (SELECT MESSAGE_ID\t,\r\nCYCLE_COUNT_ID\t,\r\nRESPONSE_DATE\t,\r\nHANDLING_UNIT_ID\t,\r\nHANDLING_UNIT_ID_STATUS\t,\r\nCREATED_BY\t,\r\nCREATION_DATE\t,\r\nLAST_UPDATED_BY\t,\r\nLAST_UPDATE_DATE\t,\r\nATTRIBUTE1\t,\r\nATTRIBUTE2\t,\r\nATTRIBUTE3\t,\r\nATTRIBUTE4\t,\r\nATTRIBUTE5\t,\r\nATTRIBUTE6\t,\r\nATTRIBUTE7\t,\r\nATTRIBUTE8\t,\r\nATTRIBUTE9\t,\r\nATTRIBUTE10\t,\r\nATTRIBUTE11\t,\r\nATTRIBUTE12\t,\r\nATTRIBUTE13\t,\r\nATTRIBUTE14\t,\r\nATTRIBUTE15\t,\r\nSLC_SITE_NAME\t,\r\nPART_DUNS_NUMBER\t,\r\nCISCO_DUNS_NUMBER\t,\r\nB2B_PROCESS_STATUS\t,\r\nSEQ_ID\t,\r\nSOURCE_DML_TYPE, TRAIL_FILE_NAME,SOURCE_COMMIT_TIME, REFRESH_DATETIME \r\nFROM $$NRTACCUMVWDB.CG1_XXSCM_DV_4C1_IB_IFACE\r\nWHERE  SOURCE_COMMIT_TIME > '$$LastExtractDate' \r\nAND SOURCE_COMMIT_TIME <=  '$$EndLastExtractDate' AND SOURCE_DML_TYPE<>'DELETE') TMP\r\nQUALIFY RANK () OVER (PARTITION BY TMP.SLC_SITE_NAME,TMP.HANDLING_UNIT_ID,TMP.RESPONSE_DATE  ORDER BY TMP.SLC_SITE_NAME,TMP.HANDLING_UNIT_ID,TMP.RESPONSE_DATE, TMP.REFRESH_DATETIME DESC ) = 1",
        "User Defined Join": "",
