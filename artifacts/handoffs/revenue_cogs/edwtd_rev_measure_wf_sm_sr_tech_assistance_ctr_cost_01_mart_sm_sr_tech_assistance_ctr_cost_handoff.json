      "attributes": {
        "Sql Query": "SELECT\r\nROW_NUMBER() OVER (ORDER BY CNTL.FISCAL_YEAR_MONTH_INT ,TAC.SRC_RPTD_SERVICE_REQUEST_NUM_INT,OREPLACE(TAC.BK_SR_TAC_WORK_THEATER_CD,'GLOBAL_TAC_','GTC_'),TAC.DELIVERY_CHANNEL_NAME) + TAC_HDR.CCM_TAC_KEY AS SERVICE_REQUEST_TAC_COST_KEY, \r\nCNTL.FISCAL_YEAR_MONTH_INT ,\r\nTAC.SRC_RPTD_SERVICE_REQUEST_NUM_INT,\r\nOREPLACE(TAC.BK_SR_TAC_WORK_THEATER_CD,'GLOBAL_TAC_','GTC_'),\r\nTAC.DELIVERY_CHANNEL_NAME,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER\r\nFROM (SELECT SRC_RPTD_SERVICE_REQUEST_NUM_INT, BK_SR_TAC_WORK_THEATER_CD,BK_SR_TAC_COST_FSCL_YR_NUM_INT,BK_SR_TAC_COST_FSCL_MTH_NUM_INT,DELIVERY_CHANNEL_NAME\r\nFROM $$FINLGLVWDB.N_SR_TECHNI_ASSIST_CENTER_COST GROUP BY 1,2,3,4,5) TAC\r\nINNER JOIN $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID CNTL\r\nON CNTL.FISCAL_YEAR_MONTH_INT = CAST(CASE WHEN CHARACTER_LENGTH(CAST(TRIM(BK_SR_TAC_COST_FSCL_MTH_NUM_INT) AS VARCHAR(4))) = 1 \r\nTHEN TRIM(BK_SR_TAC_COST_FSCL_YR_NUM_INT) || '0' || TRIM(BK_SR_TAC_COST_FSCL_MTH_NUM_INT)\r\nELSE TRIM(BK_SR_TAC_COST_FSCL_YR_NUM_INT) || TRIM(BK_SR_TAC_COST_FSCL_MTH_NUM_INT) END AS INTEGER),\r\n(SELECT COALESCE( MAX(SERVICE_REQUEST_TAC_COST_KEY),0) CCM_TAC_KEY FROM $$ETLVWDB.SM_SR_TECH_ASSISTANCE_CTR_COST) TAC_HDR\r\nWHERE NOT EXISTS (SELECT 1 FROM $$ETLVWDB.SM_SR_TECH_ASSISTANCE_CTR_COST SMTAC \r\nWHERE SMTAC.FISCAL_YEAR_MONTH_INT = CNTL.FISCAL_YEAR_MONTH_INT\r\nAND SMTAC.SRC_RPTD_SR_NUMBER_INT = TAC.SRC_RPTD_SERVICE_REQUEST_NUM_INT\r\nAND SMTAC.BK_SR_TAC_WORK_THEATER_CD = OREPLACE(TAC.BK_SR_TAC_WORK_THEATER_CD,'GLOBAL_TAC_','GTC_'))\r\nAND TAC.SRC_RPTD_SERVICE_REQUEST_NUM_INT <>-999",
        "User Defined Join": "",
        "Source Filter": "",
