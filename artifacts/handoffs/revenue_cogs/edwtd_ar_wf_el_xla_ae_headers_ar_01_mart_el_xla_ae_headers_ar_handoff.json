      "attributes": {
        "Sql Query": "SELECT\r\nAE_HEADER_ID                  \r\n,APPLICATION_ID                \r\n,ACCOUNTING_DATE               \r\n,ACCOUNTING_ENTRY_STATUS_CODE  \r\n,ACCOUNTING_ENTRY_TYPE_CODE    \r\n,BALANCE_TYPE_CODE             \r\n,COMPLETED_DATE                \r\n,ENTITY_ID                     \r\n,EVENT_ID                      \r\n,EVENT_TYPE_CODE               \r\n,GL_TRANSFER_STATUS_CODE       \r\n,GL_TRANSFER_DATE              \r\n,JE_CATEGORY_NAME              \r\n,LEDGER_ID                     \r\n,PARENT_AE_HEADER_ID           \r\n,PARENT_AE_LINE_NUM            \r\n,GLOBAL_NAME                   \r\nFROM $$STGDB.ST_CG_XLA_AE_HEADERS_AR ST\r\nWHERE (ST.APPLICATION_ID = 222 OR \r\n\tST.APPLICATION_ID IN (SELECT APPLICATION_ID FROM $$ETLVWDB.EL_FND_APPLICATION_AR \r\n\t                      WHERE UPPER(APPLICATION_NAME) IN ('REVENUE ACCOUNTING ENGINE','CISCO TWO TIER','CISCO OPEN RMA','CISCO NAT ADJUSTMENTS') AND LANG = 'US'))\r\nAND NOT EXISTS (\r\nSELECT 1 FROM $$ETLVWDB.EL_XLA_AE_HEADERS_AR EL\r\nWHERE \r\nEL.AE_HEADER_ID                  \t=\tST.AE_HEADER_ID              \r\nAND EL.GLOBAL_NAME                   \t=\tST.GLOBAL_NAME        \r\nAND EL.APPLICATION_ID = ST.APPLICATION_ID      \r\n)",
