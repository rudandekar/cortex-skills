      "attributes": {
        "Sql Query": "SELECT \r\n\tSOAA.ADJUSTMENT_NUMBER\t\tBK_AR_ADJ_NUMBER,\r\n\tEOUGC.BK_COMPANY_CODE\t\tBK_COMPANY_CODE,\r\n\tEOUGC.SET_OF_BOOKS_KEY\t\tBK_SET_OF_BOOKS_KEY,\r\n\tSOAA.ADJUSTMENT_ID\t\tSK_ADJUSTMENT_ID_INT,\r\n\tNSSC.SOURCE_SYSTEM_CODE\t\tSS_CODE\r\n\tFROM \r\n\t$$STGDB.ST_OM_AR_ADJUSTMENTS SOAA\r\n\tINNER JOIN $$ETLVWDB.EV_OP_UNIT_GAAP_COMPANY EOUGC\r\n\t\tON (EOUGC.SK_ORGANIZATION_ID_INT = SOAA.ORG_ID)\r\n\tINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC \r\n\t\tON (NSSC.GLOBAL_NAME = SOAA.GLOBAL_NAME)\r\n\tINNER JOIN $$ETLVWDB.SM_AR_TRX SMAT \r\n\t\tON (SOAA.CUSTOMER_TRX_ID = SMAT.SK_CUSTOMER_TRX_ID_LINT\r\n\t\tAND SMAT.SS_CODE = NSSC.SOURCE_SYSTEM_CODE) \r\n\tINNER JOIN $$FINLGLVWDB.N_AR_ADJUSTMENT_TYPE NAAT\r\n\t\tON (SOAA.RECEIVABLES_TRX_ID = NAAT.SK_ADJUSTMENT_TYPE_ID_INT\r\n\t\tAND NAAT.SS_CODE = NSSC.SOURCE_SYSTEM_CODE\r\n\t\tAND NAAT.BK_COMPANY_CODE = EOUGC.BK_COMPANY_CODE\r\n\t\tAND NAAT.BK_SET_OF_BOOKS_KEY = EOUGC.SET_OF_BOOKS_KEY) \r\n\tWHERE \r\n\tNOT EXISTS ( SELECT 1 FROM $$ETLVWDB.EL_AR_ADJUSTMENT_TRX EAATRX\r\n\t\tWHERE EAATRX.SK_ADJUSTMENT_ID_INT = SOAA.ADJUSTMENT_ID\r\n\t\tAND EAATRX.SS_CODE = NSSC.SOURCE_SYSTEM_CODE)\r\nUNION ALL\r\n\tSELECT \r\n\tEOAA.ADJUSTMENT_NUMBER\t\tBK_AR_ADJ_NUMBER,\r\n\tEOUGC.BK_COMPANY_CODE\t\tBK_COMPANY_CODE,\r\n\tEOUGC.SET_OF_BOOKS_KEY\t\tBK_SET_OF_BOOKS_KEY,\r\n\tEOAA.ADJUSTMENT_ID\t\tSK_ADJUSTMENT_ID_INT,\r\n\tNSSC.SOURCE_SYSTEM_CODE\t\tSS_CODE\r\n\tFROM \r\n\t$$EXCEPDB.EX_OM_AR_ADJUSTMENTS EOAA\r\n\tINNER JOIN $$ETLVWDB.EV_OP_UNIT_GAAP_COMPANY EOUGC\r\n\t\tON (EOUGC.SK_ORGANIZATION_ID_INT = EOAA.ORG_ID)\r\n\tINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC \r\n\t\tON (NSSC.GLOBAL_NAME = EOAA.GLOBAL_NAME)\r\n\tINNER JOIN $$ETLVWDB.SM_AR_TRX SMAT \r\n\t\tON (EOAA.CUSTOMER_TRX_ID = SMAT.SK_CUSTOMER_TRX_ID_LINT\r\n\t\tAND SMAT.SS_CODE = NSSC.SOURCE_SYSTEM_CODE) \r\n\tINNER JOIN $$FINLGLVWDB.N_AR_ADJUSTMENT_TYPE NAAT\r\n\t\tON (EOAA.RECEIVABLES_TRX_ID = NAAT.SK_ADJUSTMENT_TYPE_ID_INT\r\n\t\tAND NAAT.SS_CODE = NSSC.SOURCE_SYSTEM_CODE\r\n\t\tAND NAAT.BK_COMPANY_CODE = EOUGC.BK_COMPANY_CODE\r\n\t\tAND NAAT.BK_SET_OF_BOOKS_KEY = EOUGC.SET_OF_BOOKS_KEY) \r\n\tWHERE \r\n    NOT EXISTS \r\n    \t( SELECT 1 FROM $$ETLVWDB.EL_AR_ADJUSTMENT_TRX EAATRX\r\n\t\tWHERE EAATRX.SK_ADJUSTMENT_ID_INT = EOAA.ADJUSTMENT_ID\r\n\t\t AND  EAATRX.SS_CODE = NSSC.SOURCE_SYSTEM_CODE\r\n\t\t)",
