      "attributes": {
        "Sql Query": "SELECT\r\n ST.BK_DEAL_ID AS BK_DEAL_ID\r\n ,FMY.FISCAL_YEAR_MONTH_INT AS BK_DV_FISCAL_YEAR_MTH_NUM_INT \r\n ,COALESCE(ST.SRC_REPORTED_FCM_CUSTOMER_NAME,'UNKNOWN') AS SRC_REPORTED_FCM_CUSTOMER_NAME\r\n ,COALESCE(ST.MAJOR_OFFER_TYPE_CD,'UNKNOWN') AS MAJOR_OFFER_TYPE_CD\r\n ,COALESCE(ST.DEAL_START_DTM,CURRENT_TIMESTAMP(0)) AS DEAL_START_DTM\r\n ,COALESCE(ST.DV_DEAL_START_DT,CURRENT_TIMESTAMP(0)) AS DV_DEAL_START_DT\r\n ,COALESCE(ST.DEAL_END_DTM,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))) AS DEAL_END_DTM\r\n ,COALESCE(ST.DV_DEAL_END_DT,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0)))  AS DV_DEAL_END_DT\r\n ,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM\r\n ,USER AS EDW_CREATE_USER\r\n ,CURRENT_TIMESTAMP(0)  AS EDW_UPDATE_DTM\r\n ,USER EDW_UPDATE_USER\r\n ,COALESCE(ST.XAAS_FLAG,'N') AS XAAS_FLG\r\n  , 'I' AS ACTION_CODE\r\n ,'I' AS DML_TYPE\r\nFROM \r\n  $$STGDB.ST_FCM_DEAL_MAPPING  ST\r\n,$$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR FMY\r\n WHERE ST.BK_DEAL_ID IS NOT NULL\r\n AND ST.STATUS_DTM BETWEEN FMY.FISCAL_MONTH_START_DATE AND FMY.FISCAL_MONTH_END_DATE",
        "User Defined Join": "",
        "Source Filter": "",
