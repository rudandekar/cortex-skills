      "attributes": {
        "Sql Query": "SELECT \r\nNODE_ID                       ,\r\nCOALESCE (PARENT_NODE_ID   ,-999)               ,\r\nNODE_NAME                     ,\r\nRELATIONSHIP_START_DATE       ,\r\nRELATIONSHIP_END_DATE         ,\r\nSOURCE_UPDATE_DATE\r\nFROM\r\n(\r\nSELECT\r\nNODE_ID                       ,\r\nPARENT_NODE_ID                 ,\r\nNODE_NAME                     ,\r\nRELATIONSHIP_START_DATE       ,\r\nRELATIONSHIP_END_DATE         ,\r\nSOURCE_UPDATE_DATE                          \r\nFROM $$STGDB.ST_XXHMP_DEF_REV_HIER_VW\r\n QUALIFY ROW_NUMBER () OVER(PARTITION BY NODE_ID\r\nORDER BY SOURCE_UPDATE_DATE DESC, CHANGE_ID DESC ) =1\r\n) ABC\r\nWHERE  PARENT_NODE_ID  IS NOT NULL",
