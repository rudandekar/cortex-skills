      "attributes": {
        "Sql Query": "SELECT \r\nROW_NUMBER() OVER (ORDER BY NODE_ID) + SM.DFRD_REV_OFFR_HIER_NODE_KEY ,\r\nNODE_ID SK_NODE_ID_INT,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM                ,\r\nUSER EDW_CREATE_USER  \r\nFROM \r\n(\r\nSELECT \r\nNODE_ID\r\nFROM $$STGDB.WI_XXHMP_DEF_REV_HIER_VW\r\n)ST\r\nINNER JOIN \r\n( SELECT COALESCE( MAX(DFRD_REV_OFFR_HIER_NODE_KEY),0 ) DFRD_REV_OFFR_HIER_NODE_KEY FROM $$ETLVWDB.SM_DFRD_REV_OFFR_HIER_NODE ) SM\r\nON 1=1\r\nWHERE NOT EXISTS \r\n(SELECT 1 FROM $$ETLVWDB.SM_DFRD_REV_OFFR_HIER_NODE SM_INR WHERE         \r\nST.NODE_ID = SM_INR.SK_NODE_ID_INT)",
