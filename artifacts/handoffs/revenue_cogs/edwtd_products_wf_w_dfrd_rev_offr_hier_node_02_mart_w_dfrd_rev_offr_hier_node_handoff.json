      "attributes": {
        "Sql Query": "SELECT\r\n   DFRD_REV_OFFR_HIER_NODE_KEY ,           \r\n   DFRD_REV_OFFR_HIER_GROUP_NODE_KEY,     \r\n   SK_NODE_ID_INT       ,    \r\n   NODE_NAME,\r\n   CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\n   USER AS EDW_CREATE_USER,\r\n   CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n   USER AS EDW_UPDATE_USER,               \r\n   START_TV_DT  ,                 \r\n   END_TV_DT     ,\r\n   ACTION_CODE,\r\n   DML_TYPE                \r\n   FROM\r\n   (\r\n   SELECT \r\n   TVOUTPUT.DFRD_REV_OFFR_HIER_NODE_KEY,\r\n   TVOUTPUT.DFRD_REV_OFFR_HIER_GROUP_NODE_KEY,\r\n   TVOUTPUT.SK_NODE_ID_INT,\r\n   TVOUTPUT.NODE_NAME,\r\n   CAST(TVOUTPUT.START_TV_DT AS DATE)  AS START_TV_DT,\r\n   \r\n   (CASE WHEN TVOUTPUT.RELATIONSHIP_END_DATE <= CURRENT_DATE THEN RELATIONSHIP_END_DATE\r\n   ELSE COALESCE (MAX (CAST(TVOUTPUT.START_TV_DT  AS DATE) - INTERVAL '1' DAY) \r\n   OVER (PARTITION BY TVOUTPUT.DFRD_REV_OFFR_HIER_NODE_KEY\r\n   ORDER BY TVOUTPUT.START_TV_DT ASC ROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING), DATE '3500-01-01') END ) AS END_TV_DT,\r\n  \r\n   TVOUTPUT.ACTION_CODE AS ACTION_CODE, \r\n   \r\n   ROW_NUMBER () OVER (PARTITION BY TVOUTPUT.DFRD_REV_OFFR_HIER_NODE_KEY  ORDER BY TVOUTPUT.START_TV_DT ASC) AS RANK_INDEX,\r\n   ( CASE WHEN RANK_INDEX = 1 AND TV_3NF.DFRD_REV_OFFR_HIER_NODE_KEY  IS NOT NULL  THEN 'U'ELSE 'I' END ) AS DML_TYPE, \r\n   TVOUTPUT.LAST_UPDATE_DATE AS TRANSACTION_DATE\r\n   \r\n   FROM\r\n   (\r\n   SELECT\r\n   DFRD_REV_OFFR_HIER_NODE_KEY,\r\n   DFRD_REV_OFFR_HIER_GROUP_NODE_KEY,\r\n   SK_NODE_ID_INT,\r\n   NODE_NAME,\r\n   START_TV_DT,\r\n   CREATE_DATETIME,\r\n   ACTION_CODE, \r\n   LAST_UPDATE_DATE,\r\n   RELATIONSHIP_END_DATE,\r\n   ROW_NUMBER () OVER (PARTITION BY DFRD_REV_OFFR_HIER_NODE_KEY,DFRD_REV_OFFR_HIER_GROUP_NODE_KEY,NODE_NAME ORDER BY LAST_UPDATE_DATE DESC) AS ROW_NUM  \r\n   FROM \r\n   (\r\n   SELECT\r\n   SM_NODE.DFRD_REV_OFFR_HIER_NODE_KEY DFRD_REV_OFFR_HIER_NODE_KEY,\r\n   SM_PARENT.DFRD_REV_OFFR_HIER_NODE_KEY DFRD_REV_OFFR_HIER_GROUP_NODE_KEY,\r\n   ST.NODE_ID SK_NODE_ID_INT,\r\n   ST.NODE_NAME,\r\n   CAST(ST.RELATIONSHIP_START_DATE AS DATE) AS START_TV_DT,\r\n   CURRENT_TIMESTAMP(0) AS CREATE_DATETIME,\r\n   'X' ACTION_CODE,\r\n   ST.SOURCE_UPDATE_DATE AS LAST_UPDATE_DATE ,\r\n   ST.RELATIONSHIP_END_DATE  \r\n   FROM $$STGDB.WI_XXHMP_DEF_REV_HIER_VW ST \r\nINNER JOIN  $$ETLVWDB.SM_DFRD_REV_OFFR_HIER_NODE SM_NODE\r\n ON ST.NODE_ID = SM_NODE.SK_NODE_ID_INT\r\n INNER JOIN  $$ETLVWDB.SM_DFRD_REV_OFFR_HIER_NODE SM_PARENT\r\n ON ST.PARENT_NODE_ID = SM_PARENT.SK_NODE_ID_INT\r\n \r\n    UNION ALL\r\n    \r\n   SELECT  \r\n   TV_3NF.DFRD_REV_OFFR_HIER_NODE_KEY,\r\n   TV_3NF.DFRD_REV_OFFR_HIER_GROUP_NODE_KEY,\r\n   TV_3NF.SK_NODE_ID_INT,\r\n   TV_3NF.NODE_NAME,\r\n   TV_3NF.START_TV_DT,\r\n   CAST(TV_3NF.START_TV_DT AS TIMESTAMP(0))  CREATE_DATETIME, \r\n   'X' ACTION_CODE, \r\n    CAST(TV_3NF.START_TV_DT AS TIMESTAMP(0))  LAST_UPDATE_DATE,\r\n    TV_3NF.END_TV_DT AS RELATIONSHIP_END_DATE \r\n   FROM\r\n   $$FINLGLVWDB.N_DFRD_REV_OFFR_HIER_NODE_TV TV_3NF\r\n   WHERE\r\n   (TV_3NF.SK_NODE_ID_INT) IN ( SELECT NODE_ID FROM $$STGDB.WI_XXHMP_DEF_REV_HIER_VW  )\r\n   AND TV_3NF.END_TV_DT = CAST ('3500-01-01' AS DATE)\r\n   ) TVINPUT\r\n   \r\n   QUALIFY ROW_NUMBER () OVER (PARTITION BY TVINPUT.DFRD_REV_OFFR_HIER_NODE_KEY,  CAST(TVINPUT.LAST_UPDATE_DATE AS DATE)\r\n   ORDER BY TVINPUT.LAST_UPDATE_DATE DESC) = 1\r\n   \r\n   ) TVOUTPUT\r\n   LEFT JOIN $$FINLGLVWDB.N_DFRD_REV_OFFR_HIER_NODE_TV TV_3NF\r\n   ON TVOUTPUT.DFRD_REV_OFFR_HIER_NODE_KEY = TV_3NF.DFRD_REV_OFFR_HIER_NODE_KEY\r\n   AND TV_3NF.END_TV_DT =CAST ('3500-01-01' AS DATE)\r\n   WHERE TVOUTPUT.ROW_NUM = 1\r\n   )A",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
