      "attributes": {
        "Sql Query": "SELECT\r\n'Non Recurring Deferred Revenue' AS TRANSACTION_TYPE,\r\nCAST ((NONREC.AMOUNT * CAST (COALESCE(ALLOCATION_PCT,1) AS DECIMAL(18,6))) AS DECIMAL (26,7)) AS UNBILLED_REVENUE_AMT,\r\nNONREC.PROCESSED_FISCAL_MONTH_ID AS PROCESSED_FISCAL_MTH,\r\n--NONREC.PROCESSED_FISCAL_MONTH_ID AS FISCAL_MTH,\r\nNONREC.FISCAL_MONTH_ID AS FISCAL_MTH,\r\n'CISCO' AS SRC_ENTITY,\r\nEST.SALES_TERRITORY_KEY AS SALES_TERRITORY_KEY,\r\n0 AS SALES_ORDER_LINE_KEY,\r\nNONREC.SERVICE_FLAG AS SERVICE_FLG,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM , \r\nUSER AS EDW_CREATE_USER,                          \r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM ,\r\nUSER AS EDW_UPDATE_USER,\r\nNP.ITEM_KEY AS ATTRIBUTED_PRODUCT_KEY, \r\nNONREC.MEASURE_LEVEL_2 AS OFFER_TYPE_CD,\r\nNONREC.MEASURE_NAME AS ATO_NAME,\r\nCast( (Trim(ATTRIBUTED_PRODUCT_KEY)|| '~' || Trim(ATTRIBUTED_PRODUCT_KEY) || '~' ||Trim(-9999) ||  '~' || Trim(-9999)) AS VARCHAR(70)) AS DV_RECURRING_OFFER_CD,\r\nBK_PRDT_ALLCTN_CLSFCTN_CD AS DV_PRDT_ALLCTN_CLSFCTN_CD,\r\nCOALESCE(RPFIN.DV_PRODUCT_SUBGROUP_ID,'UNKNOWN') AS DV_CX_PRODUCT, \r\n  -999 as DV_ATO_PRODUCT_KEY\r\nFROM \r\n$$STGDB.ST_DFR_NONREC_REV_DATA NONREC\r\nINNER JOIN $$COMREFVWDB.N_PRODUCT NP \r\nON NP.BK_PRODUCT_ID=NONREC.PRODUCT_ID\r\nINNER JOIN $$ETLVWDB.EL_SALES_TERRITORY EST \r\n                ON         ( EST.TERRITORY_CODE =NONREC.SALES_TERRITORY_CODE \r\n                AND       EST.GLOBAL_NAME='UO' ) \r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\n\tON RFM.FISCAL_YEAR_MONTH_INT = NONREC.PROCESSED_FISCAL_MONTH_ID\r\n   INNER  JOIN ( SELECT \r\n         DV_FISCAL_YEAR_QUARTER_NUM_INT, PRODUCT_KEY, BK_PRDT_ALLCTN_METRIC_CD, BK_PRDT_ALLCTN_CLSFCTN_CD, SUM(ALLOCATION_PCT) AS ALLOCATION_PCT \r\n         FROM $$COMREFVWDB.N_PRDT_TO_PRDT_CLSFTN_ALCTN  WHERE  BK_PRDT_ALLCTN_METRIC_CD IN ('BOOKINGS','UNKNOWN')\r\n         GROUP BY 1,2,3,4 HAVING SUM(ALLOCATION_PCT) <> 0\r\n       --  QUALIFY RANK()  OVER (PARTITION BY DV_FISCAL_YEAR_QUARTER_NUM_INT,PRODUCT_KEY, BK_PRDT_ALLCTN_METRIC_CD  \r\n         --    ORDER BY  BK_PRDT_ALLCTN_CLSFCTN_CD DESC  ) = 1\r\n       ) ALCTN\r\n    ON NP.ITEM_KEY = ALCTN.PRODUCT_KEY    \r\n\tAND RFM.FISCAL_YEAR_QUARTER_NUMBER_INT = ALCTN.DV_FISCAL_YEAR_QUARTER_NUM_INT\r\nLEFT JOIN $$COMREFVWDB.R_PRODUCTS_FIN RPFIN \r\n  ON RPFIN.ITEM_KEY=NP.ITEM_KEY\r\n AND RPFIN.DIVESTITURE_TYPE_CD = 'UNKNOWN'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
