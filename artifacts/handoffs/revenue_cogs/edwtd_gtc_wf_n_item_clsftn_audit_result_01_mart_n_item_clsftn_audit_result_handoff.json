        "Sql Query": "SELECT WICAR.BK_AUDIT_NAME, \r\nWICAR.BK_WORLD_CG_CD,\r\n WICAR.PRODUCT_KEY, \r\n WICAR.CG_DUTY_RATE,\r\n WICAR.PRODUCT_SOURCE_CD, \r\n WICAR.REQUESTOR_TRAINED_FLG, \r\n WICAR.COMMIT_STATUS_FLG, \r\n WICAR.AUDIT_STATUS_CD, \r\n WICAR.POOL_TARGET_TYPE, \r\n WICAR.SRC_CREATED_DTM, \r\n WICAR.SRC_UPDATED_DTM, \r\n WICAR.SRC_CRTD_BY_CSCO_WRKR_PRTY_KEY, \r\n WICAR.SRC_UPDT_BY_CSCO_WRKR_PRTY_KEY,  \r\n WICAR.REQUESTOR_CSCO_WRKR_PRTY_KEY,\r\n WICAR.US_ITM_CG_HTS_CLSFCTN_KEY, \r\n WICAR.ITEM_CG_HTS_CLSFCTN_KEY, \r\n WICAR.RU_CCAP_IS_CORRECT_FLG, \r\n WICAR.RU_US_HTS_IMPACTED_FLG, \r\n WICAR.RU_CG_HTS_IMPACTED_FLG, \r\n WICAR.RU_MIS_CLSFCTN_REASON_CMT, \r\n WICAR.ERP_ITEM_SPECIFIC_KEY,\r\nWICAR.CUSTOMS_ITEM_SPECIFIC_KEY,\r\nWICAR.RU_NEW_ITEM_SPECIFIC_KEY,\r\n WICAR.EDW_CREATE_DTM, \r\n WICAR.EDW_CREATE_USER, \r\n WICAR.EDW_UPDATE_DTM, \r\n WICAR.EDW_UPDATE_USER \r\nFROM\r\n $$WORKDB.W_ITEM_CLSFTN_AUDIT_RESULT WICAR\r\n WHERE NOT EXISTS ( SEL 1 FROM $$FINLGLVWDB.N_ITEM_CLSFTN_AUDIT_RESULT NICAR\r\n WHERE NICAR.BK_AUDIT_NAME = WICAR.BK_AUDIT_NAME\r\n AND NICAR.BK_WORLD_CG_CD = WICAR.BK_WORLD_CG_CD\r\n AND NICAR.PRODUCT_KEY = WICAR.PRODUCT_KEY )",
