      "attributes": {
        "Sql Query": "SELECT \r\n\tEL.LINE_ID,\r\n\tNSOL.SALES_ORDER_LINE_KEY AS SOLK_LINE_ID,\r\n\tEL.TOP_MODEL_LINE_ID,\r\n\tNSOL1.SALES_ORDER_LINE_KEY AS SOLK_TOP_MODEL_LINE_ID,\r\n\tNSOL.SS_CODE AS NSOL_SS_CODE,\r\n\t'CG' AS SS_CODE\r\nFROM $$ETLVWDB.EL_CG1_XXGCO_OE_ORD_LINES_EXT EL \r\n\r\nLEFT OUTER JOIN $$ETLVWDB.EL_CG1_XXGCO_OE_ORD_LINES_EXT EL1 \r\n\tON EL.TOP_MODEL_LINE_ID = EL1.LINE_ID\r\n\tAND EL.GLOBAL_NAME =  EL1.GLOBAL_NAME\r\n\r\nLEFT OUTER JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE_TV NSOL \r\n\tON   NSOL.SK_SO_LINE_ID_INT = COALESCE(EL.CMS_SOURCE_LINE_ID,EL.LINE_ID)\r\n\tAND (NSOL.SS_CODE = (CASE WHEN  EL.CMS_SOURCE_CODE LIKE '%SJOE.CISCO.COM' THEN 'QTC' \r\n\t\t\t\tWHEN  EL.CMS_SOURCE_CODE LIKE '%BV.CISCO.COM' THEN 'BV' ELSE 'CG' END))\r\n\r\nLEFT OUTER  JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE_TV NSOL1 \r\n\tON   NSOL1.SK_SO_LINE_ID_INT = COALESCE(EL1.CMS_SOURCE_LINE_ID,EL1.LINE_ID)\r\n\tAND (NSOL1.SS_CODE = (CASE WHEN  EL1.CMS_SOURCE_CODE LIKE '%SJOE.CISCO.COM' THEN 'QTC' \r\n\t\t\t\tWHEN  EL1.CMS_SOURCE_CODE LIKE '%BV.CISCO.COM' THEN 'BV' ELSE 'CG' END))\r\n\r\nWHERE EXISTS\r\n(\r\nSELECT 1\r\nFROM\r\n(\r\nSELECT VT_TRANSACTION_ID,VT_INTERFACE_ID , ATTRIBUTE4    \r\nFROM   $$STGDB.ST_CP_VT_INTERFACE_CG1\r\nWHERE VT_TRANSACTION_TYPE IN ('SHIPMENTS-TITLE TRANSFER','SHIPMENTS','SHIPMENTS-COGS BOOKING')\r\nUNION ALL\r\nSELECT VT_TRANSACTION_ID,VT_INTERFACE_ID , ATTRIBUTE4    \r\nFROM   $$EXCEPDB.EX_CP_VT_INTERFACE_CG1\r\nWHERE VT_TRANSACTION_TYPE IN ('SHIPMENTS-TITLE TRANSFER','SHIPMENTS','SHIPMENTS-COGS BOOKING')\r\n) ST\r\nWHERE ( ST.VT_TRANSACTION_ID = EL.LINE_ID)\r\n)",
