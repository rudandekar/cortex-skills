      ],
      "attributes": {
        "Sql Query": "SELECT\r\nSASNPL.ASN_PO_LINE_KEY,\r\nCOALESCE(NPOL.PURCHASE_ORDER_LINE_KEY,-99995)  AS BK_PURCHASE_ORDER_LINE_KEY,\r\nSCXMA.CREATION_DATE AS BK_ASN_RECEIVED_DTM,\r\nCAST( SCXMA.CREATION_DATE AS  DATE) AS DV_ASN_RECEIVED_DT,\r\nCOALESCE(SCXMA.SHIPPED_QUANTITY,0)  AS SHIPPED_QTY,\r\nCOALESCE(SCXMA.ASN_PROCESSED_STATUS, 'UNKNOWN') AS ASN_PROCESSED_STATUS_CD,\r\nCOALESCE(SCXMA.ASN_PROCESSED_FLAG, 'N') AS ASN_PROCESSED_FLG,\r\nSCXMA.ASN_LINE_ID AS SK_ASN_LINE_ID_INT,\r\nCOALESCE(NP.ITEM_KEY, -997)  AS PRODUCT_KEY,\r\nCOALESCE(NRS.RECEIPT_SHIPMENT_KEY, -99995) AS RECEIPT_SHIPMENT_KEY,\r\nCOALESCE(SCXMA.PO_NUMBER,'UNKNOWN') AS SRC_RPRTD_PURCHASE_ORDER_NUM,\r\nSCXMA.CONTAINER_ID AS EP_CONTAINER_ID,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' AS ACTION_CODE,\r\n(CASE WHEN NASNPL.ASN_PO_LINE_KEY IS NOT NULL THEN 'U' ELSE 'I' END) AS DML_TYPE\r\n\r\nFROM\r\n\r\n(SELECT \r\nASN_LINE_ID,\r\nPO_RELEASE_LINE_NUMBER,\r\nPO_NUMBER,\r\nCREATION_DATE,\r\nSHIPPED_QUANTITY,\r\nASN_PROCESSED_STATUS,\r\nASN_PROCESSED_FLAG,\r\nINVENTORY_ITEM_NUMBER,\r\nMESSAGE_3B2_ID,\r\nCONTAINER_ID\r\nFROM $$STGDB.ST_CG1_XXSCM_MK_ASNLINE_IB \r\nUNION ALL\r\nSELECT \r\nASN_LINE_ID,\r\nPO_RELEASE_LINE_NUMBER,\r\nPO_NUMBER,\r\nCREATION_DATE,\r\nSHIPPED_QUANTITY,\r\nASN_PROCESSED_STATUS,\r\nASN_PROCESSED_FLAG,\r\nINVENTORY_ITEM_NUMBER,\r\nMESSAGE_3B2_ID,\r\nCONTAINER_ID\r\nFROM $$EXCEPDB.EX_ADVNCD_SHPMNT_NOTICE_PO_LIN WHERE EXCEPTION_TYPE='RI' \r\n) SCXMA \r\nINNER JOIN\r\n$$ETLVWDB.SM_ADVNCD_SHPMNT_NOTICE_PO_LN SASNPL\r\nON SASNPL.SK_ASN_LINE_ID_INT = SCXMA.ASN_LINE_ID\r\nLEFT OUTER JOIN (SELECT BK_PURCHASE_ORDER_LINE_NUM_INT, BK_PURCHASE_ORDER_NUM, MIN(PURCHASE_ORDER_LINE_KEY) AS PURCHASE_ORDER_LINE_KEY\r\nFROM $$FINLGLVWDB.N_PURCHASE_ORDER_LINE\r\nWHERE SS_CD='CG'\r\nGROUP BY 1,2\r\n) NPOL\r\nON SCXMA.PO_RELEASE_LINE_NUMBER= NPOL.BK_PURCHASE_ORDER_LINE_NUM_INT\r\nAND SCXMA.PO_NUMBER = NPOL.BK_PURCHASE_ORDER_NUM\r\nINNER JOIN \r\n(SELECT SM.ITEM_KEY,SM.BK_PRODUCT_ID FROM $$ETLVWDB.SM_PRODUCT SM, $$COMREFVWDB.N_PRODUCT NM\r\nWHERE SM.ITEM_KEY=NM.ITEM_KEY) NP\r\nON  SCXMA.INVENTORY_ITEM_NUMBER = NP.BK_PRODUCT_ID\r\nINNER JOIN $$ETLVWDB.EL_XXSCM_MK_ASNHEADER EXMA\r\nON SCXMA.MESSAGE_3B2_ID = EXMA.MESSAGE_3B2_ID\r\nINNER JOIN $$FINLGLVWDB.N_RECEIPT_SHIPMENT NRS\r\nON EXMA.SHIPMENT_NUMBER = NRS.SHIPMENT_NUM\r\nAND NRS.SS_CD='CG'\r\nLEFT JOIN \r\n$$INVFLMTVWDB.N_ADVNCD_SHPMNT_NOTICE_PO_LINE NASNPL \r\nON  NASNPL.SK_ASN_LINE_ID_INT=SCXMA.ASN_LINE_ID",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
