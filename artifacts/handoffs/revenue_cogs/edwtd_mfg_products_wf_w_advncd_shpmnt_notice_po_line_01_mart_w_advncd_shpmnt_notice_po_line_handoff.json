          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "SELECT\tRANK () OVER (ORDER BY SCXMAI.ASN_LINE_ID) + MAX_VAL ASN_PO_LINE_KEY,\r\nSCXMAI.ASN_LINE_ID AS SK_ASN_LINE_ID_INT\r\nFROM  \r\n (SELECT COALESCE (MAX (ASN_PO_LINE_KEY), 0) MAX_VAL  FROM $$ETLVWDB.SM_ADVNCD_SHPMNT_NOTICE_PO_LN) SASNPL,\r\n(SELECT ASN_LINE_ID,PO_RELEASE_LINE_NUMBER,PO_NUMBER,INVENTORY_ITEM_NUMBER,MESSAGE_3B2_ID FROM  $$STGDB.ST_CG1_XXSCM_MK_ASNLINE_IB\r\nUNION ALL\r\n SELECT ASN_LINE_ID,PO_RELEASE_LINE_NUMBER,PO_NUMBER,INVENTORY_ITEM_NUMBER,MESSAGE_3B2_ID FROM  $$EXCEPDB.EX_ADVNCD_SHPMNT_NOTICE_PO_LIN) SCXMAI\r\nINNER JOIN \r\n(SELECT SM.ITEM_KEY,SM.BK_PRODUCT_ID FROM $$ETLVWDB.SM_PRODUCT SM,$$COMREFVWDB.N_PRODUCT NM\r\nWHERE SM.ITEM_KEY=NM.ITEM_KEY) NP\r\nON  SCXMAI.INVENTORY_ITEM_NUMBER = NP.BK_PRODUCT_ID\r\nINNER JOIN $$ETLVWDB.EL_XXSCM_MK_ASNHEADER EXMA\r\n\tON SCXMAI.MESSAGE_3B2_ID = EXMA.MESSAGE_3B2_ID\r\nINNER JOIN $$FINLGLVWDB.N_RECEIPT_SHIPMENT NRS\r\n\tON EXMA.SHIPMENT_NUMBER = NRS.SHIPMENT_NUM\r\n\tAND NRS.SS_CD='CG'\r\nWHERE NOT EXISTS ( \tSELECT 1 FROM $$ETLVWDB.SM_ADVNCD_SHPMNT_NOTICE_PO_LN SAS\r\n\t\t\t\t\tWHERE SAS.SK_ASN_LINE_ID_INT = SCXMAI.ASN_LINE_ID)",
