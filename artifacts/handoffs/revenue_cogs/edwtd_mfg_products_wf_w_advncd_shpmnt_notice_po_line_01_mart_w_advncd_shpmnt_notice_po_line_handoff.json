      "attributes": {
        "Sql Query": "SELECT \r\nSCXMA.ASN_LINE_ID                   \r\n,SCXMA.SHIP_SET_NUMBER               \r\n,SCXMA.INVENTORY_ITEM_NUMBER         \r\n,SCXMA.SHIPPED_QUANTITY              \r\n,SCXMA.UOM                           \r\n,SCXMA.SERIAL_NUMBER                 \r\n,SCXMA.ASN_PROCESSED_FLAG            \r\n,SCXMA.ASN_PROCESSED_STATUS          \r\n,SCXMA.CREATION_DATE                 \r\n,SCXMA.CREATED_BY                    \r\n,SCXMA.LAST_UPDATE_DATE              \r\n,SCXMA.LAST_UPDATED_BY               \r\n,SCXMA.LAST_UPDATE_LOGIN             \r\n,SCXMA.SERIAL_NUM_STATUS             \r\n,SCXMA.MESSAGE_3B2_ID                \r\n,SCXMA.CONTAINER_ID                  \r\n,SCXMA.PO_NUMBER                     \r\n,SCXMA.PO_RELEASE_LINE_NUMBER        \r\n,SCXMA.GLOBAL_NAME                   \r\n,SCXMA.SOURCE_DML_TYPE                      \r\n,SCXMA.SOURCE_COMMIT_TIME               \r\n,SCXMA.REFRESH_DATETIME  ,\r\n'RI' AS EXCEPTION_TYPE                \r\nFROM\r\n $$STGDB.ST_CG1_XXSCM_MK_ASNLINE_IB SCXMA\r\n WHERE \r\nNOT EXISTS ( SELECT 1 FROM  $$ETLVWDB.SM_ADVNCD_SHPMNT_NOTICE_PO_LN SASNPL\r\n\t\t\t\t\t\t\tWHERE SASNPL.SK_ASN_LINE_ID_INT = SCXMA.ASN_LINE_ID)\r\nOR  NOT EXISTS ( SELECT 1 FROM (SELECT SM.ITEM_KEY,SM.BK_PRODUCT_ID FROM $$ETLVWDB.SM_PRODUCT SM,$$COMREFVWDB.N_PRODUCT NM\r\nWHERE SM.ITEM_KEY=NM.ITEM_KEY) NP\r\nWHERE  SCXMA.INVENTORY_ITEM_NUMBER = NP.BK_PRODUCT_ID)\r\n\r\nOR  NOT EXISTS ( SELECT 1 FROM (SELECT MESSAGE_3B2_ID FROM $$ETLVWDB.EL_XXSCM_MK_ASNHEADER EXMA, $$FINLGLVWDB.N_RECEIPT_SHIPMENT NRS\r\nWHERE EXMA.SHIPMENT_NUMBER = NRS.SHIPMENT_NUM\r\nAND NRS.SS_CD='CG') ENRS\r\nWHERE SCXMA.MESSAGE_3B2_ID = ENRS.MESSAGE_3B2_ID)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
