      "attributes": {
        "Sql Query": "SELECT\r\nSCXSSA.SAF_SALESREP_ID,\r\nSCXSSA.SAF_INVOICE_ID,\r\nSCXSSA.SALESREP_ID,\r\nSCXSSA.TERRITORY_ID,\r\nSCXSSA.SPLIT_PERCENT,\r\nSCXSSA.CREATED_BY,\r\nSCXSSA.CREATION_DATE,\r\nSCXSSA.LAST_UPDATED_BY,\r\nSCXSSA.LAST_UPDATE_DATE,\r\nSCXSSA.LAST_UPDATE_LOGIN,\r\nSCXSSA.TRANSACTION_TYPE,\r\nSCXSSA.ATTRIBUTE1,\r\nSCXSSA.ATTRIBUTE2,\r\nSCXSSA.ATTRIBUTE3,\r\nSCXSSA.ATTRIBUTE4,\r\nSCXSSA.ATTRIBUTE5,\r\nSCXSSA.ATTRIBUTE6,\r\nSCXSSA.ATTRIBUTE7,\r\nSCXSSA.ATTRIBUTE8,\r\nSCXSSA.ATTRIBUTE9,\r\nSCXSSA.ATTRIBUTE10,\r\nSCXSSA.ATTRIBUTE11,\r\nSCXSSA.ATTRIBUTE12,\r\nSCXSSA.ATTRIBUTE13,\r\nSCXSSA.ATTRIBUTE14,\r\nSCXSSA.ATTRIBUTE15,\r\nSCXSSA.SOURCE_COMMIT_TIME,\r\nSCXSSA.GLOBAL_NAME,\r\nSCXSSA.CREATE_DATETIME,\r\nSCXSSA.ACTION_CODE \r\nFROM\r\n $$STGDB.ST_CG_XXICM_SAF_SALESREPS_ALL SCXSSA\r\n  QUALIFY ROW_NUMBER() OVER(PARTITION BY SOURCE_COMMIT_TIME ,GLOBAL_NAME ,SAF_SALESREP_ID   \r\n  ORDER BY SOURCE_COMMIT_TIME DESC)=1\r\n  WHERE NOT EXISTS\r\n  (\r\n SELECT 1 FROM $$ETLVWDB.EL_CG_XXICM_SAF_SALESREPS_ALL EOXSH\r\nWHERE\r\n(\r\nEOXSH.SAF_SALESREP_ID=SCXSSA.SAF_SALESREP_ID\r\nAND\r\nEOXSH.GLOBAL_NAME=SCXSSA.GLOBAL_NAME)\r\n)",
