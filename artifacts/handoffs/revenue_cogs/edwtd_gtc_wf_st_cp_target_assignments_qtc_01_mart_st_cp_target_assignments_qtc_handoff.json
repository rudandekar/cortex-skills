        "Sql Query": "SELECT QTC_CP_TARGET_ASSIGNMENTS.TARGET_ASSIGNMENT_ID, QTC_CP_TARGET_ASSIGNMENTS.REG_ID, QTC_CP_TARGET_ASSIGNMENTS.TARGET_TYPE_ID, QTC_CP_TARGET_ASSIGNMENTS.ACC_SEGMENT_VALUE, QTC_CP_TARGET_ASSIGNMENTS.TARGET_SET_OF_BOOKS_ID, QTC_CP_TARGET_ASSIGNMENTS.SET_OF_BOOKS_NAME, QTC_CP_TARGET_ASSIGNMENTS.TARGET_ORG_ID, QTC_CP_TARGET_ASSIGNMENTS.ORG_NAME, QTC_CP_TARGET_ASSIGNMENTS.TARGET_INSTANCE_ID, QTC_CP_TARGET_ASSIGNMENTS.TARGET_COA_ID, QTC_CP_TARGET_ASSIGNMENTS.BALANCING_SEGMENT, QTC_CP_TARGET_ASSIGNMENTS.TARGET_ACCT_CURRENCY, QTC_CP_TARGET_ASSIGNMENTS.ACTIVE, QTC_CP_TARGET_ASSIGNMENTS.ZERO_FLAG, QTC_CP_TARGET_ASSIGNMENTS.MASTER, QTC_CP_TARGET_ASSIGNMENTS.TARGET_SET_OF_BOOKS, QTC_CP_TARGET_ASSIGNMENTS.TARGET_ORG, QTC_CP_TARGET_ASSIGNMENTS.CREATED_BY, QTC_CP_TARGET_ASSIGNMENTS.CREATION_DATE, QTC_CP_TARGET_ASSIGNMENTS.LAST_UPDATED_BY, QTC_CP_TARGET_ASSIGNMENTS.LAST_UPDATE_DATE, QTC_CP_TARGET_ASSIGNMENTS.LAST_UPDATE_LOGIN, QTC_CP_TARGET_ASSIGNMENTS.MD_ID, QTC_CP_TARGET_ASSIGNMENTS.SOURCE_ID, QTC_CP_TARGET_ASSIGNMENTS.SOURCE_DML_TYPE, QTC_CP_TARGET_ASSIGNMENTS.SOURCE_COMMIT_TIME, QTC_CP_TARGET_ASSIGNMENTS.REFRESH_DATETIME \r\nFROM\r\n$$NRTACCUMVWDB.QTC_CP_TARGET_ASSIGNMENTS\r\nWHERE   SOURCE_COMMIT_TIME > '$$LastExtractDate' \r\nAND   SOURCE_DML_TYPE <> 'DELETE'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY QTC_CP_TARGET_ASSIGNMENTS.TARGET_ASSIGNMENT_ID ORDER BY   REFRESH_DATETIME DESC) = 1",
