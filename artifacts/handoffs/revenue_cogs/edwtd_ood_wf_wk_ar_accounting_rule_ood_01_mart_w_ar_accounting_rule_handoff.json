      "attributes": {
        "Sql Query": "SELECT\r\n\tCAST(TVOUTPUT.BK_ACCOUNTING_RULE_NAME AS VARCHAR(50)) AS BK_ACCOUNTING_RULE_NAME,\r\n\tCAST(TVOUTPUT.AR_ACCOUNTING_RULE_DESCRIPTION AS VARCHAR(240)) AS AR_ACCOUNTING_RULE_DESCRIPTION,\r\n\tCAST(TVOUTPUT.SK_RULE_ID_INT AS BIGINT) AS SK_RULE_ID_INT,\r\n\tTVOUTPUT.SS_CODE AS SS_CODE,\r\n\tTVOUTPUT.START_TV_DATE AS START_DATE_ACTIVE,\r\n\tCOALESCE (MAX (TVOUTPUT.START_TV_DATE - INTERVAL '1' DAY)\r\n\t\tOVER(PARTITION BY TVOUTPUT.BK_ACCOUNTING_RULE_NAME\r\n\t\tORDER BY TVOUTPUT.START_TV_DATE ASC ROWS BETWEEN 1 \r\n\t\tFOLLOWING AND 1 FOLLOWING), DATE '3500-01-01') AS END_DATE_ACTIVE,\r\n\t\tTVOUTPUT.ACTION_CODE AS ACTION_CODE, \r\n\t\tROW_NUMBER () OVER(PARTITION BY TVOUTPUT.BK_ACCOUNTING_RULE_NAME \r\n\t\tORDER BY TVOUTPUT.START_TV_DATE ASC) AS RANK_INDEX,\r\n\t(CASE WHEN RANK_INDEX = 1 AND NAARTV.BK_ACCOUNTING_RULE_NAME\r\n\tIS NOT NULL \r\n\tTHEN 'U'ELSE 'I' END) AS DML_TYPE, \r\n\tCAST (CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) AS CREATE_DATETIME\r\nFROM (\tSELECT \r\n\t\t\t\tBK_ACCOUNTING_RULE_NAME,\r\n                \tAR_ACCOUNTING_RULE_DESCRIPTION,\r\n\t\tSK_RULE_ID_INT,\r\n\t\tSS_CODE,\r\n\t\tSTART_TV_DATE,\r\n\t\t CREATE_DATETIME, \r\n\t\t ACTION_CODE,\r\nROW_NUMBER () OVER (PARTITION BY BK_ACCOUNTING_RULE_NAME\tORDER BY CREATE_DATETIME DESC) \r\n\t\tAS ROW_NUM\r\n\tFROM ( SELECT \r\n\t\t\t\t\t\tSORR.NAME BK_ACCOUNTING_RULE_NAME,\r\n\t\t\tSORR.DESCRIPTION AR_ACCOUNTING_RULE_DESCRIPTION,\r\n\t\t\tSORR.RULE_ID SK_RULE_ID_INT,\r\n\t\t\t'OOD' SS_CODE,\r\n\t\t\tCAST(SORR.CREATE_DATETIME AS DATE) START_TV_DATE,\r\n\t\t\tSORR.CREATE_DATETIME,\r\n\t\t\tSORR.ACTION_CODE\r\n\t\t\t\t\tFROM $$STGDB.ST_OOD_RA_RULES SORR\r\n\t\tUNION ALL\r\n\t\tSELECT\r\n\t\t\tNAARTV.BK_ACCOUNTING_RULE_NAME,\r\n\t\t\tNAARTV.AR_ACCOUNTING_RULE_DESCRIPTION,\r\n\t\t\tNAARTV.SK_RULE_ID_INT,\r\n\t\t\tNAARTV.SS_CODE,\r\n\t\t\tNAARTV.START_TV_DATE,\r\n\t\t\tNAARTV.EDW_UPDATE_DATETIME CREATE_DATETIME,\r\n\t\t\t'X' ACTION_CODE\r\n\t\t\tFROM $$FINLGLVWDB.N_AR_ACCOUNTING_RULE_TV NAARTV\r\n\t\tWHERE END_TV_DATE = CAST ('3500-01-01' AS DATE)\r\n\t\tAND BK_ACCOUNTING_RULE_NAME IN (SELECT NAME FROM $$STGDB.ST_OOD_RA_RULES )) TVINPUT\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY TVINPUT.BK_ACCOUNTING_RULE_NAME,TVINPUT.START_TV_DATE ORDER BY TVINPUT.CREATE_DATETIME DESC)=1\r\n\t)TVOUTPUT\r\n\tLEFT JOIN \r\n\t$$FINLGLVWDB.N_AR_ACCOUNTING_RULE_TV NAARTV\r\n\tON TVOUTPUT.BK_ACCOUNTING_RULE_NAME = NAARTV.BK_ACCOUNTING_RULE_NAME\r\n\tAND NAARTV.END_TV_DATE=CAST('3500-01-01' AS DATE)\r\n\tWHERE TVOUTPUT.ROW_NUM=1\r\n\t\r\n\r\nUNION ALL\r\n\r\nSELECT\r\n\tTVOUTPUT.BK_ACCOUNTING_RULE_NAME AS BK_ACCOUNTING_RULE_NAME,\r\n\tTVOUTPUT.AR_ACCOUNTING_RULE_DESCRIPTION AS AR_ACCOUNTING_RULE_DESCRIPTION,\r\n\tTVOUTPUT.SK_RULE_ID_INT AS SK_RULE_ID_INT,\r\n\tTVOUTPUT.SS_CODE AS SS_CODE,\r\n\tTVOUTPUT.START_TV_DATE AS START_DATE_ACTIVE,\r\n\tCOALESCE (MAX (TVOUTPUT.START_TV_DATE - INTERVAL '1' DAY)\r\n\t\tOVER(PARTITION BY TVOUTPUT.BK_ACCOUNTING_RULE_NAME\r\n\t\tORDER BY TVOUTPUT.START_TV_DATE ASC ROWS BETWEEN 1 \r\n\t\tFOLLOWING AND 1 FOLLOWING), DATE '3500-01-01') AS END_DATE_ACTIVE,\r\n\t\tTVOUTPUT.ACTION_CODE AS ACTION_CODE, \r\n\t\tROW_NUMBER () OVER(PARTITION BY TVOUTPUT.BK_ACCOUNTING_RULE_NAME \r\n\t\tORDER BY TVOUTPUT.START_TV_DATE ASC) AS RANK_INDEX,\r\n\t(CASE WHEN RANK_INDEX = 1 AND NAARTV.BK_ACCOUNTING_RULE_NAME\r\n\tIS NOT NULL \r\n\tTHEN 'U'ELSE 'I' END) AS DML_TYPE, \r\n\tCAST (CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) AS CREATE_DATETIME\r\nFROM (\tSELECT \r\n\t\t\t\tBK_ACCOUNTING_RULE_NAME,\r\n                \tAR_ACCOUNTING_RULE_DESCRIPTION,\r\n\t\tSK_RULE_ID_INT,\r\n\t\tSS_CODE,\r\n\t\tSTART_TV_DATE,\r\n\t\t CREATE_DATETIME, \r\n\t\t ACTION_CODE,\r\nROW_NUMBER () OVER (PARTITION BY BK_ACCOUNTING_RULE_NAME\tORDER BY CREATE_DATETIME DESC) \r\n\t\tAS ROW_NUM\r\n\tFROM ( SELECT \r\n\t\t\t\t\t\tSOFRR.NAME BK_ACCOUNTING_RULE_NAME,\r\n\t\t\tSOFRR.DESCRIPTION AR_ACCOUNTING_RULE_DESCRIPTION,\r\n\t\t\tSOFRR.RULE_ID SK_RULE_ID_INT,\r\n\t\t\t'OOD' SS_CODE,\r\n\t\t\tCAST(SOFRR.CREATE_DATETIME AS DATE) START_TV_DATE,\r\n\t\t\tSOFRR.CREATE_DATETIME,\r\n\t\t\tSOFRR.ACTION_CODE\r\n\t\t\t\t\tFROM $$STGDB.ST_OOD_FUSN_RA_RULES SOFRR\r\n\t\t\t\t\tWHERE NOT EXISTS (SEL 1 FROM $$STGDB.ST_OOD_RA_RULES SORR\r\n\t\t\t\t\tWHERE SORR.RULE_ID = SOFRR.RULE_ID)\r\n\t\tUNION ALL\r\n\t\tSELECT\r\n\t\t\tNAARTV.BK_ACCOUNTING_RULE_NAME,\r\n\t\t\tNAARTV.AR_ACCOUNTING_RULE_DESCRIPTION,\r\n\t\t\tNAARTV.SK_RULE_ID_INT,\r\n\t\t\tNAARTV.SS_CODE,\r\n\t\t\tNAARTV.START_TV_DATE,\r\n\t\t\tNAARTV.EDW_UPDATE_DATETIME CREATE_DATETIME,\r\n\t\t\t'X' ACTION_CODE\r\n\t\t\tFROM $$FINLGLVWDB.N_AR_ACCOUNTING_RULE_TV NAARTV\r\n\t\tWHERE END_TV_DATE = CAST ('3500-01-01' AS DATE)\r\n\t\tAND BK_ACCOUNTING_RULE_NAME IN (SELECT NAME FROM $$STGDB.ST_OOD_FUSN_RA_RULES )) TVINPUT\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY TVINPUT.BK_ACCOUNTING_RULE_NAME,TVINPUT.START_TV_DATE ORDER BY TVINPUT.CREATE_DATETIME DESC)=1\r\n\t)TVOUTPUT\r\n\tLEFT JOIN \r\n\t$$FINLGLVWDB.N_AR_ACCOUNTING_RULE_TV NAARTV\r\n\tON TVOUTPUT.BK_ACCOUNTING_RULE_NAME = NAARTV.BK_ACCOUNTING_RULE_NAME\r\n\tAND NAARTV.END_TV_DATE=CAST('3500-01-01' AS DATE)\r\n\tWHERE TVOUTPUT.ROW_NUM=1",
