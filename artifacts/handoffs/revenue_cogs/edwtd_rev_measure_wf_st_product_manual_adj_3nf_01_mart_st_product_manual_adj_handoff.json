      "attributes": {
        "Sql Query": "SELECT \r\nNALCTN.DV_FISCAL_YEAR_MTH_NUMBER_INT FISCAL_MONTH_ID,\r\nNALCTN.BK_ADJUSTMENT_COMPANY_NAME COMPANY_NAME,\r\nNALCTN.SALES_TERRITORY_KEY,\r\nNALCTN.BK_RPRTD_ADJSTMNT_CNTRY_NAME COUNTRY_NAME,\r\nNALCTN.BK_ADJSTMNT_SLS_SUBCOVERGE_CD SALES_SUBCOVERAGE_CODE,\r\nRPF.BK_PRODUCT_ID PRODUCT_ID,\r\nNALCTN.BK_ADJUSTMENT_MEASURE_TYPE_CD MEASURE_NAME,\r\nNALCTN.BK_ADJ_SUB_MEASURE_TYPE_CD SUB_MEASURE_NAME,\r\nNALCTN.BK_ADJUSTMENT_TYPE_CD DATA_TYPE,\r\nNALCTN.ADJUSTMENT_ALLOCATION_USD_AMT AMOUNT,\r\nCURRENT_DATE,\r\n'3NF',\r\nNALCTN.BK_DEAL_ID\r\nFROM \r\n$$FINLGLVWDB.N_PRDT_REV_COST_ADJSTMNT_ALCTN NALCTN\r\nINNER JOIN $$COMREFVWDB.R_PRODUCTS_FIN RPF\r\nON RPF.ITEM_KEY=NALCTN.PRODUCT_KEY\r\nWHERE NALCTN.DV_FISCAL_YEAR_MTH_NUMBER_INT IN (SELECT FISCAL_MONTH_ID FROM $$STGDB.ST_PRODUCT_MANUAL_ADJ)\r\nAND ( NALCTN.BK_ADJUSTMENT_TYPE_CD <> 'Restatement/Acct Movement'\r\nAND NALCTN.BK_ADJUSTMENT_MEASURE_TYPE_CD <> 'SERVICE' )",
        "User Defined Join": "",
