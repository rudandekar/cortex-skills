      "attributes": {
        "Sql Query": "SELECT \r\n SRC.DV_FISCAL_YEAR_MTH_NUMBER_INT \r\n,SRC.DV_DATA_SOURCE_NAME\r\n,'MT_PNL_REV_COST_MSR' AS AUDIT_TABLE\r\n,CURRENT_DATE AS AUDIT_DATE\r\n,ABS(ROUND(COALESCE(SRC.SRC_REV,1)-COALESCE(TGT.TGT_REV,1),4)) AS REV_MISMATCH_AMT  \r\nFROM \r\n(SELECT DV_FISCAL_YEAR_MTH_NUMBER_INT,DV_DATA_SOURCE_NAME,SUM(DV_COMP_US_NET_REV_AMT) SRC_REV  \r\n FROM $$FINLGLVWDB.MT_TSS_SERVICE_REVENUE \r\n WHERE DV_FISCAL_YEAR_MTH_NUMBER_INT IN (SELECT FISCAL_YEAR_MONTH_INT FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR  WHERE FISCAL_YEAR_AGE IN (0,1,2,3) ) \r\n    AND DV_ATTRIBUTION_CD IN ('STANDALONE','ATTRIBUTED')\r\nGROUP BY 1,2\r\n) SRC \r\nLEFT JOIN \r\n(SELECT DV_FISCAL_YEAR_MTH_NUMBER_INT,DV_DATA_SOURCE_NAME,SUM(COMP_US_NET_REV_AMT)AS TGT_REV \r\nFROM $$FINLGLVWDB.MT_PNL_REV_COST_MSR \r\nGROUP BY 1,2\r\n) TGT \r\nON SRC.DV_FISCAL_YEAR_MTH_NUMBER_INT=TGT.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\nAND SRC.DV_DATA_SOURCE_NAME=TGT.DV_DATA_SOURCE_NAME",
