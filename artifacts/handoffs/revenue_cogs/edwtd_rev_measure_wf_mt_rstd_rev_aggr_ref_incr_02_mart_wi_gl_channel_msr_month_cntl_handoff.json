      "attributes": {
        "Sql Query": "SELECT \r\nFISCAL_YEAR_QUARTER_NUMBER_INT,\r\nFISCAL_YEAR_MONTH_INT,\r\nRUN_BATCH_ID\r\nFROM (\r\nSELECT\r\nFISCAL_YEAR_QUARTER_NUMBER_INT,\r\nFISCAL_YEAR_MONTH_INT,\r\n(RANK() OVER (  ORDER BY FISCAL_YEAR_QUARTER_NUMBER_INT DESC )-1)/3+1 RUN_BATCH_ID \r\nFROM\r\n$$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR FISCAL\r\nWHERE FISCAL_YEAR_NUMBER_INT>(SELECT FISCAL_YEAR_NUMBER_INT-5 FROM $$STGDB.REV_RSTD_PROCESS_DT_CNTRL)\r\nAND FISCAL_YEAR_NUMBER_INT<=(SELECT FISCAL_YEAR_NUMBER_INT FROM $$STGDB.REV_RSTD_PROCESS_DT_CNTRL)\r\n) SUB_QRY",
