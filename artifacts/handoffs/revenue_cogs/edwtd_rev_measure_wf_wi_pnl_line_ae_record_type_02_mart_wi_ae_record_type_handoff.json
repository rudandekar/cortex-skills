      "attributes": {
        "Sql Query": "SELECT\tEL.BK_FISCAL_YEAR_MTH_NUMBER_INT,EL.REV_MEASURE_TRANS_TYPE_CD ,\r\n\t\tEL.REVENUE_MEASURE_KEY ,EL.DV_PNL_LINE_ITEM_NAME,\r\n(CAST(SUM(ALLOCATION_PERCENTAGE ) OVER (PARTITION BY  EL.REV_MEASURE_TRANS_TYPE_CD ,\r\n\t\tEL.REVENUE_MEASURE_KEY ,EL.DV_PNL_LINE_ITEM_NAME ) \r\nAS DECIMAL(30,16))) /\r\nCOALESCE(NULLIFZERO(CAST(SUM(ALLOCATION_PERCENTAGE) OVER (PARTITION BY EL.REV_MEASURE_TRANS_TYPE_CD,\r\n\t\tEL.REVENUE_MEASURE_KEY) AS DECIMAL(30,16))),1) AS REV_SPLIT_PCT\r\nFROM\t$$ETLVWDB.EL_EDW_PNL_LINE_ITEM EL\r\nWHERE\tDV_PNL_LINE_ITEM_NAME LIKE ANY ('TS%','CMS%')\r\n\tAND\tBK_FISCAL_YEAR_MTH_NUMBER_INT >=(\r\nSELECT\tFISCAL_YEAR_MONTH_INT \r\nFROM\t$$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR \r\nWHERE\tFISCAL_MONTH_NUMBER_INT=1 \r\n\tAND\tFISCAL_YEAR_AGE=3)",
