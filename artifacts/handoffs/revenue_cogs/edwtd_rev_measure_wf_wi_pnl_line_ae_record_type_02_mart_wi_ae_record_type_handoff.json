      "attributes": {
        "Sql Query": "SELECT\tBK_FISCAL_YEAR_MTH_NUMBER_INT,BK_SALES_TERRITORY_KEY,\r\nCASE\tWHEN TRIANGULATION_TYPE_ID_INT IN (1,2,3) THEN 'DISTI' \r\nELSE\t'SCMS' \r\nEND\tAS RECORD_TYPE\r\nFROM\t$$FINLGLVWDB.N_TRNGLTED_GL_SVC_REV_ALLOCATN \r\nWHERE\tTRIANGULATION_TYPE_ID_INT >0  \r\n\tAND\tBK_FISCAL_YEAR_MTH_NUMBER_INT>=(\r\nSELECT\tFISCAL_YEAR_MONTH_INT \r\nFROM\t$$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR \r\nWHERE\tFISCAL_MONTH_NUMBER_INT=1 \r\n\tAND\tFISCAL_YEAR_AGE=3) \r\nGROUP\tBY 1,2,3",
