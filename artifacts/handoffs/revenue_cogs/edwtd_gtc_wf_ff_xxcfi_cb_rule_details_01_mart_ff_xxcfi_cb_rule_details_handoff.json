      "attributes": {
        "Sql Query": "SELECT RULE_DETAILS.rule_details_id\r\n      ,RULE_DETAILS.rule_id\r\n      ,RULE_DETAILS.country_group_id\r\n      ,RULE_DETAILS.country_group_code\r\n      ,RULE_DETAILS.hts_code\r\n      ,RULE_DETAILS.start_date\r\n      ,RULE_DETAILS.end_date\r\n      ,RULE_DETAILS.active_flag\r\n      ,RULE_DETAILS.rule_status\r\n      ,RULE_DETAILS.processed_flag\r\n      ,RULE_DETAILS.rule_reversed\r\n      ,RULE_DETAILS.created_by\r\n      ,RULE_DETAILS.created_date\r\n      ,RULE_DETAILS.modified_by\r\n      ,RULE_DETAILS.modified_date\r\nFROM CUBE.XXCFI_CB_RULE_DETAILS  RULE_DETAILS\r\nWHERE trim(upper(RULE_DETAILS.rule_status)) <> 'FUTURE'\r\nAND RULE_DETAILS.MODIFIED_DATE > TO_DATE('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS')\r\nunion all\r\nSELECT XXCFI_CB_RULE_DETAILS_HISTORY.RULE_DETAILS_ID, XXCFI_CB_RULE_DETAILS_HISTORY.RULE_ID, XXCFI_CB_RULE_DETAILS_HISTORY.COUNTRY_GROUP_ID, XXCFI_CB_RULE_DETAILS_HISTORY.COUNTRY_GROUP_CODE, XXCFI_CB_RULE_DETAILS_HISTORY.HTS_CODE, XXCFI_CB_RULE_DETAILS_HISTORY.START_DATE, XXCFI_CB_RULE_DETAILS_HISTORY.END_DATE, 'N' AS ACTIVE_FLAG, XXCFI_CB_RULE_DETAILS_HISTORY.RULE_STATUS, XXCFI_CB_RULE_DETAILS_HISTORY.PROCESSED_FLAG, XXCFI_CB_RULE_DETAILS_HISTORY.RULE_REVERSED, XXCFI_CB_RULE_DETAILS_HISTORY.CREATED_BY, XXCFI_CB_RULE_DETAILS_HISTORY.CREATED_DATE, XXCFI_CB_RULE_DETAILS_HISTORY.MODIFIED_BY, XXCFI_CB_RULE_DETAILS_HISTORY.MODIFIED_DATE \r\nFROM  CUBE.XXCFI_CB_RULE_DETAILS_HISTORY      XXCFI_CB_RULE_DETAILS_HISTORY\r\nWHERE   XXCFI_CB_RULE_DETAILS_HISTORY.MODIFIED_DATE > TO_DATE('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS')",
