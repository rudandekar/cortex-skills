      "attributes": {
        "Sql Query": "SELECT \r\nNGLRM.REVENUE_MEASURE_KEY \t ,\r\nNGLRM.REV_MEASURE_TRANS_TYPE_CD ,\r\nNGLRM.DV_FISCAL_YEAR_MTH_NUMBER_INT  ,\r\nNGLRM.JOURNAL_ENTRY_LINE_DESCR  JOURNAL_ENTRY_LINE_DESCR,\r\nCOALESCE(SUBSTR ( JOURNAL_ENTRY_LINE_DESCR, 0, POSITION ( '-' IN JOURNAL_ENTRY_LINE_DESCR)  ) , 'UNKNOWN') DV_EVENT_ID ,\r\nSUBSTR ( JOURNAL_ENTRY_LINE_DESCR, POSITION ( '-' IN JOURNAL_ENTRY_LINE_DESCR) + 1 , CHARACTER_LENGTH ( JOURNAL_ENTRY_LINE_DESCR) )  PROJECT_MILESTONE_USER ,\r\nSUBSTR ( PROJECT_MILESTONE_USER, 0, POSITION ( '-' IN PROJECT_MILESTONE_USER )  ) PROJECT_CD ,\r\nSUBSTR ( PROJECT_MILESTONE_USER, POSITION ( '-' IN PROJECT_MILESTONE_USER ) + 1 , CHARACTER_LENGTH ( PROJECT_MILESTONE_USER ) )  AS MILESTONE_USER,\r\nSUBSTR ( MILESTONE_USER, 0, POSITION ( '-' IN MILESTONE_USER )  ) MILESTONE_ID ,\r\nSUBSTR ( MILESTONE_USER, POSITION ( '-' IN MILESTONE_USER ) + 1 , CHARACTER_LENGTH ( MILESTONE_USER ) )  USER_ID,\r\nBK_JOURNAL_ENTRY_NUMBER_INT   ,\r\nBK_JOURNAL_ENTRY_LINE_NUM_INT ,\r\nRAE_ADJUSTMENT_GL_DSTRBTN_KEY \r\nFROM $$STGDB.WI_AST_REVENUE_EVENT_LINK NGLRM\r\n/* WHERE  NGLRM.TRANSACTION_TYPE_CATEGORY_CD = 'OP_ADJ' AND NGLRM.TRANSACTION_TYPE_CATEGORY_CD IS NOT NULL */",
