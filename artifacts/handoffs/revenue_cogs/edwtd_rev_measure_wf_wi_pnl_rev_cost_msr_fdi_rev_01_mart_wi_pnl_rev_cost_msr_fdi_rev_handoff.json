      "attributes": {
        "Sql Query": "SELECT\r\n  U.DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\n  U.REVENUE_OR_COGS_TYPE_CD,\r\n  U.PRODUCT_KEY,\r\n  U.GOODS_PRODUCT_KEY,\r\n  U.FINANCIAL_ACCOUNT_CD,\r\n  U.REV_MEASURE_TRNSCTN_TYPE_CD,\r\n  U.TRIANGULATION_TYPE_ID_INT,\r\n  U.PRDT_SUBGROUP_ALLOC_SRC_CD,\r\n  U.SALES_TERRITORY_KEY,\r\n  U.TRNGLTD_SALES_TERRITORY_KEY,\r\n  U.SALES_ORDER_LINE_KEY,\r\n  U.SRC_RPRTD_SRVC_CONTRACT_NUM,\r\n  U.REV_PROFITABILITY_AMT,\r\n  U.COMPANY_CD,\r\n  U.ISO_COUNTRY_CD,\r\n  U.PRODUCT_TYPE,\r\n  U.PNL_LINE_ITEM_NAME,\r\n  U.CE_COUNTRY_NAME,\r\n  U.END_CUSTOMER_KEY,\r\n  U.BILL_TO_CUSTOMER_KEY,\r\n  U.SHIP_TO_CUSTOMER_KEY,\r\n  U.SOLD_TO_CUSTOMER_KEY,\r\n  U.DV_RECURRING_OFFER_CD\r\n  FROM\r\n  (SELECT\r\n  DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\n  'REVENUE' REVENUE_OR_COGS_TYPE_CD,\r\n  CISCO_PRODUCT_KEY PRODUCT_KEY,\r\n  CISCO_PRODUCT_KEY GOODS_PRODUCT_KEY,\r\n  'UNKNOWN' FINANCIAL_ACCOUNT_CD,\r\n  'UNKNOWN' REV_MEASURE_TRNSCTN_TYPE_CD,\r\n  -9999 TRIANGULATION_TYPE_ID_INT,\r\n  'UNKNOWN' PRDT_SUBGROUP_ALLOC_SRC_CD,\r\n  SALES_TERRITORY_KEY SALES_TERRITORY_KEY,\r\n  SALES_TERRITORY_KEY TRNGLTD_SALES_TERRITORY_KEY,\r\n  -9999 SALES_ORDER_LINE_KEY,\r\n  -9999 SRC_RPRTD_SRVC_CONTRACT_NUM,\r\n  SUM (\r\n     CASE\r\n        WHEN NVL (CUSTOMER_TRANSACTION_TYPE_CD, 'INV') NOT IN ('CM','DM')\r\n        THEN\r\n           NVL (EXTENDED_GROSS_REVENUE_USD_AMT, 0)\r\n        ELSE\r\n           (CASE\r\n               WHEN ACQUISITION_SOURCE_CD = 'IRONPORT'\r\n               THEN\r\n                  NVL (EXTENDED_NET_REVENUE_USD_AMT, 0)\r\n               ELSE\r\n                  NVL (EXTENDED_SELLING_PRICE_USD_AMT, 0)\r\n            END)\r\n     END) REV_PROFITABILITY_AMT,\r\n  COMPANY_CD,\r\n  'UNK' ISO_COUNTRY_CD,\r\n   'PRODUCT' PRODUCT_TYPE,\r\n   CAST(CASE\r\n     WHEN NVL (CUSTOMER_TRANSACTION_TYPE_CD, 'INV') IN ('CM','DM')\r\n     THEN\r\n    CUSTOMER_TRANSACTION_TYPE_CD\r\n     ELSE\r\n        'Direct Shipped Revenue'\r\n  END AS VARCHAR(100))PNL_LINE_ITEM_NAME,\r\n  ACQUISITION_SOURCE_CD CE_COUNTRY_NAME,\r\n  -999 END_CUSTOMER_KEY ,\r\n  -999 BILL_TO_CUSTOMER_KEY  ,\r\n  -999 SHIP_TO_CUSTOMER_KEY ,\r\n  -999 SOLD_TO_CUSTOMER_KEY  ,\r\n  CAST (TRIM(COALESCE(FDI.CISCO_PRODUCT_KEY,-999)) || '~' || TRIM(COALESCE(FDI.CISCO_PRODUCT_KEY,-999)) || '~' ||-9999|| '~' ||-9999 AS VARCHAR(70))  DV_RECURRING_OFFER_CD\r\n  FROM \r\n  $$FINLGLVWDB.N_APSP_FDI_REVENUE_TRX FDI\r\n  INNER JOIN $$STGDB.WI_PNL_MTH_CNTL_FDI_REV FY ON \r\n  FDI.DV_FISCAL_YEAR_MTH_NUMBER_INT=FY.FISCAL_YEAR_MONTH_INT\r\n  WHERE FY.INC_FLAG ='Y'\r\n  AND ADJUSTMENT_TYPE_CD='As Invoiced'\r\n  AND SERVICE_PRODUCT_FLG='N'\r\n  AND CISCO_PRODUCT_KEY NOT IN (SELECT BP.ITEM_KEY FROM $$COMREFVWDB.R_PRODUCTS BP WHERE\r\n  BP.BK_TECHNOLOGY_GROUP_ID in ('TOTAL_CISCO', 'TBA', 'MISC', 'SERVICE', 'SERVICE-TG'))\r\n  GROUP BY\r\n  DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\n  CISCO_PRODUCT_KEY,\r\n  SALES_TERRITORY_KEY,\r\n  CUSTOMER_TRANSACTION_TYPE_CD,\r\n  ACQUISITION_SOURCE_CD,\r\n  COMPANY_CD\r\n  \r\n  UNION ALL\r\n  \r\n  SELECT\r\n  DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\n  'REVENUE' REVENUE_OR_COGS_TYPE_CD,\r\n  CISCO_PRODUCT_KEY PRODUCT_KEY,\r\n  CISCO_PRODUCT_KEY GOODS_PRODUCT_KEY,\r\n  'UNKNOWN' FINANCIAL_ACCOUNT_CD,\r\n  'UNKNOWN' REV_MEASURE_TRNSCTN_TYPE_CD,\r\n  -9999 TRIANGULATION_TYPE_ID_INT,\r\n  'UNKNOWN' PRDT_SUBGROUP_ALLOC_SRC_CD,\r\n  SALES_TERRITORY_KEY,\r\n  SALES_TERRITORY_KEY TRNGLTD_SALES_TERRITORY_KEY,\r\n  -9999 SALES_ORDER_LINE_KEY,\r\n  -9999 SRC_RPRTD_SRVC_CONTRACT_NUM,\r\n  SUM (NVL (EXTENDED_NET_REVENUE_USD_AMT, 0))  REV_PROFITABILITY_AMT,\r\n  COMPANY_CD,\r\n  'UNK' ISO_COUNTRY_CD,\r\n   'PRODUCT' PRODUCT_TYPE,\r\n   ADJUSTMENT_TYPE_CD PNL_LINE_ITEM_NAME,\r\n   ACQUISITION_SOURCE_CD CE_COUNTRY_NAME,\r\n  -999 END_CUSTOMER_KEY ,\r\n  -999 BILL_TO_CUSTOMER_KEY  ,\r\n  -999 SHIP_TO_CUSTOMER_KEY ,\r\n  -999 SOLD_TO_CUSTOMER_KEY  ,\r\n  CAST (TRIM(COALESCE(FDI.CISCO_PRODUCT_KEY,-999)) || '~' || TRIM(COALESCE(FDI.CISCO_PRODUCT_KEY,-999)) || '~' ||-9999|| '~' ||-9999 AS VARCHAR(70))  DV_RECURRING_OFFER_CD\r\n  FROM $$FINLGLVWDB.N_APSP_FDI_REVENUE_TRX FDI\r\n  INNER JOIN $$STGDB.WI_PNL_MTH_CNTL_FDI_REV FY ON \r\n  FDI.DV_FISCAL_YEAR_MTH_NUMBER_INT=FY.FISCAL_YEAR_MONTH_INT\r\n  WHERE FY.INC_FLAG ='Y'\r\n  AND ADJUSTMENT_TYPE_CD NOT IN 'As Invoiced'\r\n  AND SERVICE_PRODUCT_FLG='N'\r\n  AND CISCO_PRODUCT_KEY NOT IN (SELECT BP.ITEM_KEY FROM $$COMREFVWDB.R_PRODUCTS BP WHERE\r\n  BP.BK_TECHNOLOGY_GROUP_ID in ('TOTAL_CISCO', 'TBA', 'MISC', 'SERVICE', 'SERVICE-TG'))\r\n  GROUP BY\r\n  DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\n  CISCO_PRODUCT_KEY,\r\n  SALES_TERRITORY_KEY,\r\n  ACQUISITION_SOURCE_CD,\r\n  COMPANY_CD,\r\n  ADJUSTMENT_TYPE_CD\r\n  \r\n  UNION ALL\r\n  \r\n  SELECT\r\n  DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\n  'COGS' REVENUE_OR_COGS_TYPE_CD,\r\n  CISCO_PRODUCT_KEY PRODUCT_KEY,\r\n  CISCO_PRODUCT_KEY GOODS_PRODUCT_KEY,\r\n  'UNKNOWN' FINANCIAL_ACCOUNT_CD,\r\n  'UNKNOWN' REV_MEASURE_TRNSCTN_TYPE_CD,\r\n  -9999 TRIANGULATION_TYPE_ID_INT,\r\n  'UNKNOWN' PRDT_SUBGROUP_ALLOC_SRC_CD,\r\n  SALES_TERRITORY_KEY,\r\n  SALES_TERRITORY_KEY TRNGLTD_SALES_TERRITORY_KEY,\r\n  -9999 SALES_ORDER_LINE_KEY,\r\n  -9999 SRC_RPRTD_SRVC_CONTRACT_NUM,\r\n  SUM (NVL (EXTENDED_NET_COST_USD_AMT, 0) * -1) REV_PROFITABILITY_AMT,\r\n  COMPANY_CD,\r\n  'UNK' ISO_COUNTRY_CD,\r\n   'PRODUCT' PRODUCT_TYPE,\r\n  CAST (CASE\r\n     WHEN     ADJUSTMENT_TYPE_CD IN ('As Invoiced')\r\n          AND NVL (CUSTOMER_TRANSACTION_TYPE_CD, 'INV') NOT IN ('CM','DM')\r\n     THEN\r\n        'Direct Cost'\r\n     WHEN ADJUSTMENT_TYPE_CD NOT IN ('As Invoiced')\r\n     THEN ADJUSTMENT_TYPE_CD\r\n  END AS VARCHAR(100)) PNL_LINE_ITEM_NAME,\r\n   ACQUISITION_SOURCE_CD CE_COUNTRY_NAME,\r\n  -999 END_CUSTOMER_KEY ,\r\n  -999 BILL_TO_CUSTOMER_KEY  ,\r\n  -999 SHIP_TO_CUSTOMER_KEY ,\r\n  -999 SOLD_TO_CUSTOMER_KEY  ,\r\n  CAST (TRIM(COALESCE(FDI.CISCO_PRODUCT_KEY,-999)) || '~' || TRIM(COALESCE(FDI.CISCO_PRODUCT_KEY,-999)) || '~' ||-9999|| '~' ||-9999 AS VARCHAR(70))  DV_RECURRING_OFFER_CD\r\n  FROM $$FINLGLVWDB.N_APSP_FDI_REVENUE_TRX FDI\r\n  INNER JOIN $$STGDB.WI_PNL_MTH_CNTL_FDI_REV FY ON \r\n  FDI.DV_FISCAL_YEAR_MTH_NUMBER_INT=FY.FISCAL_YEAR_MONTH_INT\r\n  WHERE FY.INC_FLAG ='Y'\r\n  AND SERVICE_PRODUCT_FLG='N'\r\n  AND CISCO_PRODUCT_KEY NOT IN (SELECT BP.ITEM_KEY FROM $$COMREFVWDB.R_PRODUCTS BP WHERE\r\n  BP.BK_TECHNOLOGY_GROUP_ID in ('TOTAL_CISCO', 'TBA', 'MISC', 'SERVICE', 'SERVICE-TG'))\r\n  GROUP BY\r\n  DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\n  CISCO_PRODUCT_KEY,\r\n  SALES_TERRITORY_KEY,\r\n  CUSTOMER_TRANSACTION_TYPE_CD,\r\n  ACQUISITION_SOURCE_CD,\r\n  COMPANY_CD,\r\n  ADJUSTMENT_TYPE_CD\r\n  \r\n  UNION ALL\r\n  \r\n  SELECT\r\n  DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\n  'REVENUE' REVENUE_OR_COGS_TYPE_CD,\r\n  CISCO_PRODUCT_KEY PRODUCT_KEY,\r\n  CISCO_PRODUCT_KEY GOODS_PRODUCT_KEY,\r\n  'UNKNOWN' FINANCIAL_ACCOUNT_CD,\r\n  'UNKNOWN' REV_MEASURE_TRNSCTN_TYPE_CD,\r\n  -9999 TRIANGULATION_TYPE_ID_INT,\r\n  'UNKNOWN' PRDT_SUBGROUP_ALLOC_SRC_CD,\r\n  SALES_TERRITORY_KEY,\r\n  SALES_TERRITORY_KEY TRNGLTD_SALES_TERRITORY_KEY,\r\n  -9999 SALES_ORDER_LINE_KEY,\r\n  -9999 SRC_RPRTD_SRVC_CONTRACT_NUM,\r\n  SUM (COALESCE (EXTENDED_NET_REVENUE_USD_AMT, 0) * SPH.ALLOCATION_PERCENTAGE) REV_PROFITABILITY_AMT,\r\n  COMPANY_CD,\r\n  'UNK' ISO_COUNTRY_CD,\r\n   'SERVICE' PRODUCT_TYPE,\r\n  CAST ( COALESCE ( SUBSTR (\r\n        CASE SPH.BK_SERVICE_CATEGORY_ID\r\n           WHEN 'ADVANCED SERVICES'\r\n           THEN\r\n              CASE\r\n                 WHEN SPH.BK_ALLOCATED_SERVC_GROUP_ID = 'AS SUBSCRIPTION'\r\n                 THEN  'AS-S Misc Entries'\r\n                 WHEN SPH.BK_ALLOCATED_SERVC_GROUP_ID IN ('AS TRANSACTION', 'AS ADVISORY')\r\n                 THEN 'AS-T Misc Revenue'\r\n                 WHEN SPH.BK_ALLOCATED_SERVC_GROUP_ID = 'AS FIXED'\r\n                 THEN 'AS-Fixed Revenue'\r\n              END /*cms changes*/\r\n           WHEN 'TECHNICAL SUPPORT SERVICES' THEN\r\n     CASE \r\n             WHEN SPH.BK_ALLOCATED_SERVC_GROUP_ID='CLOUD MANAGED SERVICES' \r\n             THEN 'CMS Non LMY Revenue'\r\n           ELSE 'TS Misc Entries' END /*cms changes*/\r\n           WHEN 'TECHNICAL SUPPORT SERVICES' THEN \r\n CASE \r\n           WHEN SPH.BK_ALLOCATED_SERVC_GROUP_ID='TRAINING' \r\n           THEN 'Training - Revenue'\r\n           ELSE  'Other Service Revenue' END /*WW-TSS CHANGE*/\r\n        END, 1, 80),'')AS VARCHAR(100)) PNL_LINE_ITEM_NAME,\r\n   ACQUISITION_SOURCE_CD CE_COUNTRY_NAME, \r\n  -999 END_CUSTOMER_KEY ,\r\n  -999 BILL_TO_CUSTOMER_KEY  ,\r\n  -999 SHIP_TO_CUSTOMER_KEY ,\r\n  -999 SOLD_TO_CUSTOMER_KEY  ,\r\n  CAST (TRIM(COALESCE(FDI.CISCO_PRODUCT_KEY,-999)) || '~' || TRIM(COALESCE(FDI.CISCO_PRODUCT_KEY,-999)) || '~' ||-9999|| '~' ||-9999 AS VARCHAR(70))  DV_RECURRING_OFFER_CD\r\n  FROM\r\n  $$FINLGLVWDB.N_APSP_FDI_REVENUE_TRX FDI\r\n  INNER JOIN  $$COMREFVWDB.R_PRODUCTS_FIN P\r\n  ON FDI.CISCO_PRODUCT_KEY=P.ITEM_KEY\r\n  INNER JOIN $$COMREFVWDB.R_TRX_PRODUCT TPRDS\r\n  ON P.ITEM_KEY=TPRDS.PRODUCT_KEY\r\n  INNER JOIN $$COMREFVWDB.MT_CS_DEAL_SVC_FIN_HIER_ALLOC SPH\r\n  ON (CASE WHEN P.GOODS_OR_SERVICE_TYPE ='GOODS' THEN P.RU_BK_PRODUCT_SUBGROUP_ID ELSE P.RU_BK_SERVICE_PROD_SUBGROUP_ID END=SPH.BK_PRODUCT_SUBGROUP_ID)\r\n  INNER JOIN $$STGDB.WI_PNL_MTH_CNTL_FDI_REV FY ON \r\n  FDI.DV_FISCAL_YEAR_MTH_NUMBER_INT=FY.FISCAL_YEAR_MONTH_INT\r\n  WHERE FY.INC_FLAG ='Y'\r\n  AND SERVICE_PRODUCT_FLG='Y'\r\n  AND SPH.DV_PRDT_SUB_GRP_ALLOC_SRC_CD='SPA' \r\n  GROUP BY\r\n  DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\n  CISCO_PRODUCT_KEY,\r\n  SALES_TERRITORY_KEY,\r\n  CUSTOMER_TRANSACTION_TYPE_CD,\r\n  ACQUISITION_SOURCE_CD,\r\n  COMPANY_CD,\r\n  SPH.BK_SERVICE_CATEGORY_ID,\r\n  SPH.BK_ALLOCATED_SERVC_GROUP_ID\r\n  )U",
