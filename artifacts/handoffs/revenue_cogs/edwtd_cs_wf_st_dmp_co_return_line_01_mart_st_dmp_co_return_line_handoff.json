      "attributes": {
        "Sql Query": "SELECT \r\n$$BatchId AS BATCH_ID,\r\n CCRL.RETURN_LINE_ID,\r\n CCRL.RETURN_ID,\r\n CCRL.PARENT_RETURN_LINE_ID,\r\n CCRL.PART_NUMBER,\r\n CCRL.DESCRIPTION,\r\n CCRL.LINE_NUMBER,\r\n CCRL.UNIT_NET_PRICE,\r\n CCRL.QUANTITY,\r\n CCRL.EXT_NET_PRICE,\r\n CCRL.SHIP_TO_SITE_USE_ID,\r\n CCRL.ORIG_ERP_LINE_ID,\r\n CAST(CCRL.REQUESTED_SHIP_DATE AS VARCHAR(19)),\r\n CAST(CCRL.ACTUAL_SHIP_DATE AS VARCHAR(19)),\r\n CAST(CCRL.CREATED_ON AS VARCHAR(19)),\r\n CCRL.CREATED_BY,\r\n CAST(CCRL.UPDATED_ON AS VARCHAR(19)),\r\n CCRL.UPDATED_BY,\r\n CCRL.STATUS,\r\n CCRL.ACTIVE,\r\n CCRL.HAS_CHILDREN,\r\n CCRL.GRAND_PARENT_RETURN_LINE_ID,\r\n CCRL.TERRITORY_ID,\r\n CCRL.SHARE_NODE_ID,\r\n CCRL.ITEM_TYPE,\r\n CCRL.UNIT_LIST_PRICE,\r\n CURRENT_TIMESTAMP(0) AS CREATE_DATETIME,\r\n CAST(CCRL.SOURCE_COMMIT_TIME AS VARCHAR(19)),\r\n CAST(CCRL.REFRESH_DATETIME AS VARCHAR(19)),\r\n 'I' as ACTION_CODE \r\nFROM\r\n $$NRTACCUMVWDB.DMP_CO_RETURN_LINE  CCRL\r\n WHERE  SOURCE_COMMIT_TIME > '$$LastExtractDate' \r\nAND SOURCE_DML_TYPE<>'DELETE'\r\nAND RETURN_ID IN (\r\nSELECT RETURN_ID FROM $$GGSRCVWDB.GG_DMP_CO_RETURN_HEADER WHERE RETURN_STATUS <> 1)\r\nQUALIFY RANK () OVER (PARTITION BY CCRL.RETURN_LINE_ID ORDER BY CCRL.RETURN_LINE_ID, CCRL.REFRESH_DATETIME DESC ) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "CALL COLLECT_STATS_WRAP('$$NRTACCUMDB','DMP_CO_RETURN_LINE','D');",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
