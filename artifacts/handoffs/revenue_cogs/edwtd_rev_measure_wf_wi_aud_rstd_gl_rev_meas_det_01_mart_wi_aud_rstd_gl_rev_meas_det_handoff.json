      "attributes": {
        "Sql Query": "SELECT \r\n'MT_RSTD_GL_REV_MEASURE' AS AUDIT_TABLE_NAME ,\r\nNGRM.REVENUE_MEASURE_KEY, \r\nNGRM.DV_FISCAL_YEAR_MTH_NUMBER_INT, \r\nNGRM.REV_MEASURE_TRANS_TYPE_CD, \r\nUSER AS EDW_CREATE_USER, \r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DATEETIME, \r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DATETIME\r\n FROM $$FINLGLVWDB.N_GL_REV_MEASURE NGRM\r\n INNER JOIN  $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR       RFMY  ON (\r\n( RFMY.PREVIOUS_FSCL_MONTH_FLAG      = 'Y' \r\n\t AND CURRENT_DATE BETWEEN RFMY.FISCAL_MONTH_END_DATE + 1 AND  RFMY.FISCAL_MONTH_END_DATE + 6) \r\nOR RFMY.CURRENT_FISCAL_MONTH_FLAG    = 'Y'   \r\n)\r\nWHERE RFMY.FISCAL_YEAR_MONTH_INT  = NGRM.DV_FISCAL_YEAR_MTH_NUMBER_INT  \r\nGROUP BY 1, 2, 3, 4, 5, 6, 7, 8 \r\n\r\nMINUS\r\n\r\nSELECT \r\n'MT_RSTD_GL_REV_MEASURE' AS AUDIT_TABLE_NAME ,\r\nMTRGRM.REVENUE_MEASURE_KEY, \r\nMTRGRM.DV_FISCAL_YEAR_MTH_NUMBER_INT, \r\nMTRGRM.REV_MEASURE_TRANS_TYPE_CD, \r\nUSER AS EDW_CREATE_USER, \r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DATEETIME, \r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DATETIME\r\n FROM $$FINLGLVWDB.MT_RSTD_GL_REV_MEASURE  MTRGRM\r\n INNER JOIN  $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR       RFMY  ON (\r\n( RFMY.PREVIOUS_FSCL_MONTH_FLAG      = 'Y' \r\n\t AND CURRENT_DATE BETWEEN RFMY.FISCAL_MONTH_END_DATE + 1 AND  RFMY.FISCAL_MONTH_END_DATE + 6) \r\nOR RFMY.CURRENT_FISCAL_MONTH_FLAG    = 'Y'   \r\n)\r\nWHERE RFMY.FISCAL_YEAR_MONTH_INT  = MTRGRM.DV_FISCAL_YEAR_MTH_NUMBER_INT  \r\nGROUP BY 1, 2, 3, 4, 5, 6, 7, 8",
        "User Defined Join": "",
