      "attributes": {
        "Sql Query": "SELECT\t\r\nBATCH_ID,\r\nSITE_ID,\r\nLOCATION,\r\nCOUNTRY,\r\nCREATED_BY,\r\nLAST_UPDATED_BY,\r\nCREATED_DATE,\r\nLAST_UPDATED_DATE,\r\nSTATUS,\r\nCREATE_DATETIME,\r\nACTION_CODE,\r\n'RI' EXCEPTION_TYPE\r\nFROM $$STGDB.ST_XXCMF_EM_LOC SXEC\r\nWHERE\tNOT EXISTS (\r\n\t\t\t\tSELECT 1 FROM $$ETLVWDB.EL_XXCMF_EM_SUPPLIER_LOC EXESL\r\n\t\t\t\t\r\n\t\t\t\tINNER JOIN $$INVFLMTVWDB.N_MFG_OEM_SUPPLIER_PARTY NMOESP\r\n\t\t\t\tON EXESL.MANUFACTURER_ID = NMOESP.SK_MANUFACTURER_ID_INT\r\n\r\n\t\t\t\tINNER JOIN $$COMREFVWDB.N_ISO_COUNTRY NIC\r\n\t\t\t\tON COALESCE(SXEC.COUNTRY,'UN') = NIC.ISO_COUNTRY_SHORT_CODE\r\n\t\t\t\t\r\n\t\t\t\tWHERE SXEC.SITE_ID = EXESL.SITE_ID\r\n\t\t\t\t)",
