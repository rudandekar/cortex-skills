      "attributes": {
        "Sql Query": "SELECT\r\nRANK() OVER (ORDER BY STSMT.SK_GID_ID ) + MAX_SMSMT.SHIPPING_MILESTONE_TYPE_KEY as SHIPPING_MILESTONE_TYPE_KEY, \r\nSTSMT.SK_GID_ID as SM_GID_ID \r\nFROM\r\n(\r\nSELECT DISTINCT SSMT.SK_GID_ID FROM\r\n(SELECT SSMTA.SK_GID_ID FROM $$STGDB.ST_SHIPPING_MILESTONE_TYPE SSMTA\r\nUNION ALL\r\nSELECT SSMTB.SK_GID_SUCC_ID FROM $$STGDB.ST_SHIPPING_MILESTONE_TYPE SSMTB) SSMT\r\n) STSMT,\r\n(SELECT COALESCE( MAX(SHIPPING_MILESTONE_TYPE_KEY),0)  SHIPPING_MILESTONE_TYPE_KEY FROM $$ETLVWDB.SM_SHIPPING_MILESTONE_TYPE) MAX_SMSMT\r\nWHERE  NOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.SM_SHIPPING_MILESTONE_TYPE\r\nSSMSMT\r\nWHERE SSMSMT.SK_GID_ID=STSMT.SK_GID_ID)",
