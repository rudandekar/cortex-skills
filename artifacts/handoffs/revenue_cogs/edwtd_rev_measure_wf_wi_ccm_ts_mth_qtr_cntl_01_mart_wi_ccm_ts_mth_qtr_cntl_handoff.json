      "attributes": {
        "Sql Query": "/*SELECT \r\nRFM.FISCAL_QUARTER_NAME\r\n,RFM.FISCAL_YEAR_MONTH_INT\r\n,SUBSTR(RFM.FISCAL_MONTH_NAME,1,3)||'FY'||SUBSTR(RFM.FISCAL_MONTH_NAME,9,2) CCM_FISCAL_MONTH\r\n,RANK(RFM.FISCAL_YEAR_MONTH_INT) MONTH_RANK\r\nFROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\n,( SELECT FISCAL_QUARTER_NAME,FISCAL_YEAR_MONTH_INT  FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR  WHERE PREVIOUS_FSCL_MONTH_FLAG = 'Y'       ) PFM\r\n,( SELECT FISCAL_QUARTER_NAME FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR  WHERE CURRENT_FISCAL_MONTH_FLAG = 'Y'     ) CFM\r\nWHERE RFM.FISCAL_QUARTER_NAME = PFM.FISCAL_QUARTER_NAME \r\nAND RFM.FISCAL_YEAR_MONTH_INT = PFM.FISCAL_YEAR_MONTH_INT \r\nAND CFM.FISCAL_QUARTER_NAME = PFM.FISCAL_QUARTER_NAME \r\nQUALIFY ROW_NUMBER() OVER ( PARTITION BY RFM.FISCAL_YEAR_MONTH_INT ORDER BY RFM.FISCAL_YEAR_MONTH_INT DESC ) = 1\r\nUNION\r\nSELECT \r\nRFM.FISCAL_QUARTER_NAME\r\n,RFM.FISCAL_YEAR_MONTH_INT\r\n,SUBSTR(RFM.FISCAL_MONTH_NAME,1,3)||'FY'||SUBSTR(RFM.FISCAL_MONTH_NAME,9,2) CCM_FISCAL_MONTH\r\n,RANK(RFM.FISCAL_YEAR_MONTH_INT) MONTH_RANK\r\nFROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\n,( SELECT FISCAL_QUARTER_NAME FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR WHERE  PREVIOUS_FSCL_MONTH_FLAG = 'Y'   ) PFM\r\n,( SELECT FISCAL_QUARTER_NAME  FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR WHERE CURRENT_FISCAL_MONTH_FLAG = 'Y'   ) CFM\r\nWHERE RFM.FISCAL_QUARTER_NAME = PFM.FISCAL_QUARTER_NAME \r\nAND CFM.FISCAL_QUARTER_NAME <> PFM.FISCAL_QUARTER_NAME \r\nQUALIFY ROW_NUMBER() OVER ( PARTITION BY RFM.FISCAL_YEAR_MONTH_INT ORDER BY RFM.FISCAL_YEAR_MONTH_INT DESC ) = 1\r\n*/\r\n\r\nSELECT \r\nRFM.FISCAL_QUARTER_NAME\r\n,RFM.FISCAL_YEAR_MONTH_INT\r\n,SUBSTR(RFM.FISCAL_MONTH_NAME,1,3)||'FY'||SUBSTR(RFM.FISCAL_MONTH_NAME,9,2) CCM_FISCAL_MONTH\r\n,RANK(RFM.FISCAL_YEAR_MONTH_INT) MONTH_RANK\r\nFROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nWHERE PREVIOUS_FSCL_MONTH_FLAG = 'Y'",
