      "attributes": {
        "Sql Query": "SELECT\r\n RANK() OVER (ORDER BY TRX.TRANSACTION_DIST_ID,\r\n NSSC.SOURCE_SYSTEM_CODE )+ SM_KEY_TAB.MAX_KEY AS AR_TRX_2TIER_INVOICE_KEY,\r\n CAST(TRX.TRANSACTION_DIST_ID AS INTEGER) AS SK_TRANSACTION_ID_INT,\r\n NSSC.SOURCE_SYSTEM_CODE AS SS_CD,\r\n CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\n USER AS EDW_CREATE_USER\r\n FROM $$STGDB.WI_XLA_AE_LINE_2TIER_INCR TRX,\r\n $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC,\r\n (SELECT COALESCE(MAX(AR_TRX_2TIER_INVOICE_KEY ),10000) MAX_KEY FROM \r\n  $$ETLVWDB.SM_AR_TRX_2TIER_INVOICE) SM_KEY_TAB\r\n WHERE NOT EXISTS\r\n (\r\n SELECT 1 FROM $$ETLVWDB.SM_AR_TRX_2TIER_INVOICE SM_TAB\r\n WHERE CAST(TRX.TRANSACTION_DIST_ID AS INTEGER) = SM_TAB.SK_TRANSACTION_ID_INT\r\n AND NSSC.GLOBAL_NAME=TRX.GLOBAL_NAME\r\n AND NSSC.SOURCE_SYSTEM_CODE=SM_TAB.SS_CD)\r\n AND NSSC.GLOBAL_NAME=TRX.GLOBAL_NAME \r\n QUALIFY ROW_NUMBER() OVER(PARTITION BY SK_TRANSACTION_ID_INT,SS_CD ORDER BY SK_TRANSACTION_ID_INT )=1",
