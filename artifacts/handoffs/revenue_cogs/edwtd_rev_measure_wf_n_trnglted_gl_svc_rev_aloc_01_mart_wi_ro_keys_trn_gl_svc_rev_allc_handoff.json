      "attributes": {
        "Sql Query": "SELECT\r\nDV_PRODUCT_KEY,\r\nPRODUCT_KEY,\r\nSALES_ORDER_KEY,\r\nSK_OFFER_ATTRIBUTION_ID_INT,\r\nDV_RECURRING_OFFER_CD\r\nFROM\r\n(SELECT \r\nBK_PRODUCT_KEY   DV_PRODUCT_KEY,\r\nBK_PRODUCT_KEY   PRODUCT_KEY,\r\n-9999 SALES_ORDER_KEY,\r\n-9999 SK_OFFER_ATTRIBUTION_ID_INT,\r\nCAST (TRIM(COALESCE(NFRT.BK_PRODUCT_KEY  ,-999)) || '~' || TRIM(COALESCE(NFRT.BK_PRODUCT_KEY  ,-999)) || '~' ||-9999|| '~' ||-9999 AS VARCHAR(70))  DV_RECURRING_OFFER_CD\r\nFROM $$WORKDB.W_TRNGLTED_GL_SVC_REV_ALLOCATN NFRT, \r\n$$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMT\r\nWHERE RFMT.FISCAL_YEAR_AGE  IN (0,1,2,3) \r\n--AND NFRT.FISCAL_YEAR_NUM_INT = RFMT.FISCAL_YEAR_NUMBER_INT\r\nAND NFRT.BK_FISCAL_YEAR_MTH_NUMBER_INT  = RFMT.FISCAL_YEAR_MONTH_INT\r\n)A\r\nWHERE DV_RECURRING_OFFER_CD NOT IN (\r\nSELECT DV_RECURRING_OFFER_CD FROM $$FINLGLVWDB.MT_RECURRING_OFFER_REVENUE )\r\nGROUP BY 1,2,DV_RECURRING_OFFER_CD",
