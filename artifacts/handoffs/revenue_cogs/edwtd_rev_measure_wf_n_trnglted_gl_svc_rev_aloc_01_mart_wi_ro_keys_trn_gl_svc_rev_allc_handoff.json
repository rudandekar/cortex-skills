        "Sql Query": "SELECT \r\nWGSRA.TRNGTD_GL_SVC_REV_ALCTN_KEY, \r\nWGSRA.BK_CORPORATE_REVENUE_FLG, \r\nWGSRA.BK_REV_MEASURE_TRNSCTN_TYPE_CD, \r\nWGSRA.BK_TRANSACTION_TYPE_CATEGRY_CD, \r\nWGSRA.BK_IC_REVENUE_FLG, \r\nWGSRA.BK_REVENUE_FLG, \r\nWGSRA.BK_CHARGES_FLG, \r\nWGSRA.BK_MISC_FLG, \r\nWGSRA.BK_SERVICE_FLG, \r\nWGSRA.BK_INTERNATIONAL_DEMO_FLG, \r\nWGSRA.BK_REPLACEMENT_DEMO_FLG, \r\nWGSRA.BK_TRNGLTD_SALES_TERRITORY_KEY, \r\nWGSRA.BK_SALES_TERRITORY_KEY, \r\nWGSRA.BK_PRODUCT_KEY, \r\nWGSRA.BK_ADJUSTMENT_TYPE_CD, \r\nWGSRA.BK_REVENUE_OR_COGS_TYPE_CD, \r\nWGSRA.BK_FINANCIAL_ACCOUNT_CD, \r\nWGSRA.BK_DIRECT_CORP_ADJ_TYPE_CD, \r\nWGSRA.COMP_US_NET_PRICE_AMT, \r\nWGSRA.COMP_US_NET_LIST_PRICE_AMT, \r\nWGSRA.COMP_US_GROSS_LIST_PRICE_AM, \r\nWGSRA.COMP_US_NET_COST_AMT, \r\nWGSRA.COMP_US_GROSS_REV_AMT, \r\nWGSRA.COMP_US_NET_REV_AMT, \r\nWGSRA.COMP_US_2TIER_CMDM_AMT, \r\nWGSRA.COMP_US_GROSS_COST_AMT, \r\nWGSRA.COMP_US_STNDRD_PRICE_AMT, \r\nWGSRA.BK_FISCAL_YEAR_MTH_NUMBER_INT, \r\nWGSRA.TRIANGULATION_TYPE_ID_INT, \r\nWGSRA.EDW_CREATE_DTM, \r\nWGSRA.EDW_CREATE_USER, \r\nWGSRA.EDW_UPDATE_DTM, \r\nWGSRA.EDW_UPDATE_USER,\r\nWGSRA.BK_PRDT_SUBGROUP_ALLOC_SRC_CD,\r\nWGSRA.SALES_ORDER_LINE_KEY,\r\nWGSRA.PNL_LINE_ITEM_NAME, /*Added as part of ICPM P&L Hierarchy*/\r\nWGSRA.BK_DEAL_ID\r\nFROM\r\n$$WORKDB.W_TRNGLTED_GL_SVC_REV_ALLOCATN WGSRA\r\nWHERE 1=1\r\n\r\n/*NOT EXISTS (SELECT 1 FROM $$FINLGLVWDB.N_TRNGLTED_GL_SVC_REV_ALLOCATN NGSRA\r\nWHERE WGSRA.TRNGTD_GL_SVC_REV_ALCTN_KEY = NGSRA.TRNGTD_GL_SVC_REV_ALCTN_KEY)*/",
