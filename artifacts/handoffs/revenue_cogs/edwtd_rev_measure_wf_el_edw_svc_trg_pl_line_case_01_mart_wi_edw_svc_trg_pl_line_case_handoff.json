      "attributes": {
        "Sql Query": "SELECT \r\nPNL.FISCAL_MONTH,\r\n'SELECT \r\nGL.DV_FISCAL_YEAR_MTH_NUMBER_INT   BK_FISCAL_YEAR_MTH_NUMBER_INT          ,\r\nGL.REVENUE_MEASURE_KEY,\r\nGL.REV_MEASURE_TRANS_TYPE_CD,\r\nCOALESCE(MCS_SVC_FH_ME.ALLOCATION_PERCENTAGE,1),\r\n'||PNL.CASE_STATEMENT||'\r\n  FROM $FINLGLVWDB.N_GL_REV_MEASURE  GL \r\nLEFT JOIN $FINLGLVWDB.N_FCM_DEAL_MAPPING FCM ON GL.DV_ERP_DEAL_ID=FCM.BK_DEAL_ID \r\nAND GL.DV_FISCAL_YEAR_MTH_NUMBER_INT=FCM.BK_DV_FISCAL_YEAR_MTH_NUM_INT \r\nLEFT JOIN (SELECT GL.DV_SALES_ORDER_LINE_KEY  FROM $FINLGLVWDB.N_GL_REV_MEASURE  GL \r\nWHERE  GL.DV_FISCAL_YEAR_MTH_NUMBER_INT = '||TRIM(PNL.FISCAL_MONTH)||' AND GL.DV_SALES_ORDER_LINE_KEY < 0 \r\nAND GL .DV_ATTRIBUTION_CD IN (''STANDALONE'',''ATTRIBUTED'') \r\nGROUP BY 1) DistinctGL \r\nON  GL.DV_SALES_ORDER_LINE_KEY=DistinctGL.DV_SALES_ORDER_LINE_KEY  \r\nINNER JOIN $COMREFVWDB.R_FISCAL_MONTH_TO_YEAR FY ON GL.DV_FISCAL_YEAR_MTH_NUMBER_INT=FY.FISCAL_YEAR_MONTH_INT         \r\nINNER JOIN  $FINLGLVWDB.N_AR_TRX_LINE ATL   \r\nON CASE WHEN GL.DV_AR_TRX_LINE_KEY < 0 THEN -9999 ELSE GL.DV_AR_TRX_LINE_KEY END= ATL.AR_TRX_LINE_KEY\r\nINNER JOIN  $SLSORDVWDB.N_SALES_ORDER_TV SO  \r\nON   CASE WHEN GL.SALES_ORDER_KEY <=  -1000000 THEN -9999 ELSE GL.SALES_ORDER_KEY  END =SO.SALES_ORDER_KEY\r\nINNER JOIN $COMREFVWDB.R_PRODUCTS_FIN   P   ON  GL.PRODUCT_KEY=P.ITEM_KEY   AND ((GL.REVENUE_TRANSFER_KEY < 0\r\n AND GL.ADJSMT_RBT_TRX_LIN_GL_DIST_KEY < 0  AND ATL.BK_AR_TRX_LINE_TYPE=''LINE'' AND GL.DD_BK_FINANCIAL_ACCOUNT_CD NOT IN (''41001'',''43310'', ''43320''))\r\n                     OR (GL.REV_MEASURE_TRANS_TYPE_CD = ''IND_ADJ'' AND  P.RU_BK_PRODUCT_FAMILY_ID <> ''SERVICE'')\r\n\t\t\t\t\t OR (GL.REV_MEASURE_TRANS_TYPE_CD = ''DRCT_AS_T'') \r\n                OR (GL.REV_MEASURE_TRANS_TYPE_CD = ''AR-OOD'')  \r\n\t\t\t\tOR (GL.REVENUE_TRANSFER_KEY > 0 AND GL.DD_BK_FINANCIAL_ACCOUNT_CD NOT IN (''41001'',''43310'', ''43320''))\r\n\t\t\t\tOR (GL.ADJSMT_RBT_TRX_LIN_GL_DIST_KEY > 0 AND GL.DD_BK_FINANCIAL_ACCOUNT_CD NOT IN (''41001'',''43310'', ''43320'')))\r\n/* INNER JOIN $SLSORDVWDB.MT_CS_DEAL_SO_LINE_LINK MCS_LN_LK  ON (CASE  WHEN GL.DV_SALES_ORDER_LINE_KEY > 0  THEN  GL.DV_SALES_ORDER_LINE_KEY  ELSE  DistinctGL.DV_SALES_ORDER_LINE_KEY END  = MCS_LN_LK.SALES_ORDER_LINE_KEY) AND GL.DV_ATTRIBUTION_CD = MCS_LN_LK.DV_ATTRIBUTION_CD\r\n                                            AND (CASE WHEN P.GOODS_OR_SERVICE_TYPE =''GOODS'' THEN P.RU_BK_PRODUCT_SUBGROUP_ID ELSE P.RU_BK_SERVICE_PROD_SUBGROUP_ID END = MCS_LN_LK.BK_PRODUCT_SUBGROUP_ID )   */\r\nLEFT JOIN $COMREFVWDB.MT_CS_DEAL_SVC_FIN_HIER_ALLOC MCS_SVC_FH_ME      /* ON MCS_LN_LK.APPROVED_DEAL_ID=MCS_SVC_FH_ME.APPROVED_DEAL_ID */ \r\nON CASE WHEN P.GOODS_OR_SERVICE_TYPE =''GOODS'' THEN P.RU_BK_PRODUCT_SUBGROUP_ID ELSE P.RU_BK_SERVICE_PROD_SUBGROUP_ID END = MCS_SVC_FH_ME.BK_PRODUCT_SUBGROUP_ID \r\n WHERE 1=1\r\n       AND  GL.DV_SERVICE_FLG=''Y''\r\n       AND  GL.DV_COMP_US_NET_REV_AMT <> 0\r\n AND GL .DV_ATTRIBUTION_CD IN (''STANDALONE'',''ATTRIBUTED'')\r\n AND MCS_SVC_FH_ME.DV_PRDT_SUB_GRP_ALLOC_SRC_CD=''SPA''\r\n\t   AND  GL.DV_FISCAL_YEAR_MTH_NUMBER_INT = '||TRIM(PNL.FISCAL_MONTH)||'\r\nGROUP BY 1,2,3,4,5'\r\n\r\nFROM \r\n$$ETLVWDB.EL_EDW_SVC_TRG_PL_LINE_CASE PNL\r\nINNER JOIN $$STGDB.ST_EDW_SVC_TRG_PL_LINE_CASE STG\r\nON PNL.FISCAL_MONTH = STG.FISCAL_MONTH",
        "User Defined Join": "",
