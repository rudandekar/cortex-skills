      "attributes": {
        "Sql Query": "SELECT\r\nWSSC.ORIGINAL_SALES_TERRITORY_KEY  ,\r\nWSSC.TRIANGULATED_SALES_TERR_KEY   ,\r\nWSSC.BK_SRC_RPRTD_SRVC_CONTRACT_NUM,\r\nWSSC.SERVICE_PRODUCT_KEY           ,\r\nWSSC.GOODS_PRODUCT_KEY             ,\r\nWSSC.BK_TRIANGULATION_TYPE_CD      ,\r\nWSSC.BK_C3_CUSTOMER_THEATER_NAME   ,\r\nWSSC.BK_C3_CUST_MARKET_SEGMENT_NAME,\r\nWSSC.SSC_DPT_PSNL_RSRC_COST_USD_AMT,\r\nWSSC.SSC_DEPRECIATION_COST_USD_AMT ,\r\nWSSC.SSC_REPAIR_COST_USD_AMT       ,\r\nWSSC.SSC_DUTY_VAT_COST_USD_AMT     ,\r\nWSSC.SSC_TRDPRTY_LGSTS_COST_USD_AMT,\r\nWSSC.SSC_TRDPRTY_MNTNC_COST_USD_AMT,\r\nWSSC.SSC_ORIG_EQPT_MFG_COST_USD_AMT,\r\nWSSC.SSC_WARRANTY_PCT              ,\r\nWSSC.SERVICE_CONTRACT_NUM          ,\r\nWSSC.BK_ST_ENRCHMNT_MTHDLGY_CD     ,\r\nWSSC.BK_FISCAL_YEAR_MTH_NUMBER_INT ,\r\nWSSC.SERVICE_REQUEST_SSC_COST_KEY,\r\nWSSC.SHIPPED_QTY,\r\nWSSC.EDW_CREATE_DTM                ,\r\nWSSC.EDW_CREATE_USER               ,\r\nWSSC.EDW_UPDATE_DTM                ,\r\nWSSC.EDW_UPDATE_USER  \r\n\r\nFROM \r\n$$WORKDB.W_TSS_SRVC_SPRT_CTR_CGS_TRGLTN   WSSC\r\nWHERE NOT EXISTS (SELECT 1 FROM  $$FINLGLVWDB.N_TSS_SRVC_SPRT_CTR_CGS_TRGLTN NSSC\r\nWHERE NSSC.ORIGINAL_SALES_TERRITORY_KEY = WSSC.ORIGINAL_SALES_TERRITORY_KEY\r\nAND  NSSC.TRIANGULATED_SALES_TERR_KEY = WSSC.TRIANGULATED_SALES_TERR_KEY\r\nAND  NSSC.BK_SRC_RPRTD_SRVC_CONTRACT_NUM = WSSC.BK_SRC_RPRTD_SRVC_CONTRACT_NUM\r\nAND  NSSC.SERVICE_PRODUCT_KEY = WSSC.SERVICE_PRODUCT_KEY\r\nAND  NSSC.GOODS_PRODUCT_KEY = WSSC.GOODS_PRODUCT_KEY\r\nAND  NSSC.BK_TRIANGULATION_TYPE_CD = WSSC.BK_TRIANGULATION_TYPE_CD\r\nAND  NSSC.BK_C3_CUSTOMER_THEATER_NAME = WSSC.BK_C3_CUSTOMER_THEATER_NAME\r\nAND  NSSC.BK_C3_CUST_MARKET_SEGMENT_NAME= WSSC.BK_C3_CUST_MARKET_SEGMENT_NAME\r\nAND  NSSC.BK_FISCAL_YEAR_MTH_NUMBER_INT = WSSC.BK_FISCAL_YEAR_MTH_NUMBER_INT)",
