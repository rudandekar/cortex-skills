        "Sql Query": "SELECT \r\nX.BK_CUSTOMS_PRICING_METHOD_CD AS BK_CUSTOMS_PRICING_METHOD_CD ,\r\nX.BK_SS_CD,\r\n'N' AS SOURCE_DELETED_FLG,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\nX.EL_PRICE_METHOD_ID_INT\r\nFROM\r\n(\r\n SELECT METHOD_NAME AS BK_CUSTOMS_PRICING_METHOD_CD,\r\n        CAST('CG' AS VARCHAR(8)) BK_SS_CD,\r\n\t\tPRICE_METHOD_ID AS EL_PRICE_METHOD_ID_INT \r\n FROM $$STGDB.ST_XXCP_PRICING_METHOD_CG1 \r\n WHERE METHOD_NAME IS NOT NULL\r\n  UNION\r\n SELECT METHOD_NAME AS BK_CUSTOMS_PRICING_METHOD_CD,\r\n\t\tCAST('C3' AS VARCHAR(8)) BK_SS_CD,\r\n\t\tPRICE_METHOD_ID AS EL_PRICE_METHOD_ID_INT \r\n FROM $$STGDB.ST_CP_PRICING_METHOD_C3 \r\n WHERE METHOD_NAME IS NOT NULL\r\n) X\r\nWHERE NOT EXISTS\r\n(\r\n SELECT 1 \r\n   FROM $$FINLGLVWDB.N_CUSTOMS_PRICING_METHOD\t NCPM\r\n  WHERE NCPM.BK_CUSTOMS_PRICING_METHOD_CD = X.BK_CUSTOMS_PRICING_METHOD_CD\r\n)",
