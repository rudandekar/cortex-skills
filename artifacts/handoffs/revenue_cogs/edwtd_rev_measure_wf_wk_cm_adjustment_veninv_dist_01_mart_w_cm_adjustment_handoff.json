      "attributes": {
        "Sql Query": "SELECT\r\nNVID.VENDOR_INVOICE_DISTRIB_KEY    CM_ADJUSTMENT_KEY,\r\nNSOB.FUNCTIONAL_CURRENCY_CODE\t\tFUNCTIONAL_CURRENCY_CODE,\r\nNGLA.BK_FINANCIAL_ACCOUNT_CODE\t\tBK_FINANCIAL_ACCOUNT_CODE,\r\nRANDOM(1000000,1001800)*-1 \t\tas\t\t\tBILL_TO_CUSTOMER_KEY,\r\nNVI.BK_VENDOR_INVOICE_NUM\t\t\t\t\tBK_AR_TRX_NUM,\r\n'UNKNOWN'\tas\t\t\t\t\t\tRU_CUST_PURCHASE_ORDER_NUM,\t\r\n'UNKNOWN' as\t\t\t\t\tAR_TYPE_CD,\t\t\r\n( COALESCE(NVID.VNDR_INV_DISTRIB_AMT,0)*-1 * COALESCE(NCCDR_FUNC.PL_CONVERSION_RATE, 1)\t) DV_AR_ADJ_TRX_FUNCTIONAL_AMT,\r\n( \r\nCASE WHEN ( BK_FINANCIAL_ACCOUNT_CODE = '11560' AND NVI.SET_OF_BOOKS_KEY               = 1 AND NVID.DD_BK_COMPANY_CD               ='020' )  THEN \r\n(COALESCE(NVID.VNDR_INV_DISTRIB_AMT,0) *-1 * COALESCE(NCCDR_USD.PL_CONVERSION_RATE, 1) )*-1\r\nELSE (COALESCE(NVID.VNDR_INV_DISTRIB_AMT,0)*-1 * COALESCE(NCCDR_USD.PL_CONVERSION_RATE, 1) )\r\nEND \r\n)\t\t\t\t\tDV_AR_ADJ_TRX_USD_AMT,\r\nNVID.VNDR_INV_DISTRIB_ACCT_DT\t\t\t\t\tGL_DT,                       \r\nNULL\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tGL_POSTED_DT,\r\n'UNKNOWN'        as\t\t\t\tAR_ADJ_TRX_REASON_CD,\r\nCOALESCE(NCPVP.AP_VENDOR_NAME,'UNKNOWN') as VENDOR_NAME,\r\nNVI.OPERATING_UNIT_NAME_CD        \t\t\tOPERATING_UNIT_NAME_CD,\r\n'PAYABLES'\t\t\t\t\t\t\t\t\t\t\t\t\t\tCUST_TRX_TYPE_CATEGORY_CD ,\r\nNFM.BK_FISCAL_YEAR_NUMBER_INT*100 + NFM.BK_FISCAL_MONTH_NUMBER_INT\tFISCAL_YEAR_MONTH_NUM_INT,\r\nNVID.DD_BK_COMPANY_CD,\r\nNVI.SET_OF_BOOKS_KEY,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) as EDW_CREATE_DATETIME,\r\nUSER as EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) as EDW_UPDATE_DATETIME,\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM \r\n$$FINLGLVWDB.N_VENDOR_INVOICE_DISTRIBUTION NVID\r\nINNER JOIN $$FINLGLVWDB.N_VENDOR_INVOICE NVI\r\n\tON ( NVID.VENDOR_INVOICE_KEY= NVI.VENDOR_INVOICE_KEY)\r\nINNER JOIN $$COMREFVWDB.N_FISCAL_MONTH NFM\r\n\tON ( nvid.VNDR_INV_DISTRIB_ACCT_DT BETWEEN FISCAL_MONTH_START_DATE AND FISCAL_MONTH_END_DATE ) \r\nINNER JOIN $$FINLGLVWDB.N_GENERAL_LEDGER_ACCOUNT NGLA\r\n\tON ( NGLA.GENERAL_LEDGER_ACCOUNT_KEY = NVID.GENERAL_LEDGER_ACCOUNT_KEY)\r\nINNER JOIN $$FINLGLVWDB.N_SET_OF_BOOKS NSOB\r\n \tON ( NSOB.SET_OF_BOOKS_KEY   = NVI.SET_OF_BOOKS_KEY              \t)\r\nLEFT OUTER  JOIN $$COMREFVWDB.N_ACCTS_PYBL_VNDR_PRTY NCPVP\r\n\tON ( NVID.AP_VENDOR_PARTY_KEY              =NCPVP.AP_VENDOR_PARTY_KEY )\t\r\nLEFT OUTER  JOIN $$FINLGLVWDB.N_CURRENCY_CONV_DAILY_RATE NCCDR_USD\r\n\tON ( NCCDR_USD.BK_FROM_CURRENCY_CODE = NVI.TRANSACTIONAL_CURRENCY_CD       \r\n\tAND NCCDR_USD.BK_TO_CURRENCY_CODE = 'USD'\r\n\tAND NCCDR_USD.BK_CONVERSION_DATE = NVID.VNDR_INV_DISTRIB_ACCT_DT)\r\nLEFT OUTER  JOIN $$FINLGLVWDB.N_CURRENCY_CONV_DAILY_RATE NCCDR_FUNC\r\n\tON ( NCCDR_FUNC.BK_FROM_CURRENCY_CODE = NVI.TRANSACTIONAL_CURRENCY_CD  \r\n\tAND NCCDR_FUNC.BK_TO_CURRENCY_CODE = FUNCTIONAL_CURRENCY_CODE\r\n\tAND NCCDR_FUNC.BK_CONVERSION_DATE = NVID.VNDR_INV_DISTRIB_ACCT_DT)\r\nWHERE \r\n NVID.VNDR_INV_DISTRIB_POSTED_FLG='Y'\r\nAND BK_FINANCIAL_ACCOUNT_CODE      IN('11575','11596','11597','11598','11599','11560','11561')\r\nAND NVID.EDW_UPDATE_DTM > ( SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS\r\nWHERE JOB_STREAM_ID = 'wf_WK_CM_ADJUSTMENT_VENINV_DIST')",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
