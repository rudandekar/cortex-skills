      "attributes": {
        "Sql Query": "SELECT EFLV.LOOKUP_CODE AS BK_GEOGRAPHIC_LOCATION_CD,\r\nEFLV.MEANING AS GEOGRAPHIC_REGION_CD ,\r\n 'I' ACTION_CODE,\r\n(CASE WHEN NRGL.BK_GEOGRAPHIC_LOCATION_CD  IS NOT NULL THEN 'U' ELSE 'I' END) AS DML_TYPE\r\n FROM $$ETLVWDB.EL_FND_LOOKUP_VALUES EFLV\r\n LEFT OUTER JOIN $$INVFLMTVWDB.N_R2_GEOGRAPHIC_LOCATION  NRGL\r\n ON NRGL.BK_GEOGRAPHIC_LOCATION_CD=EFLV.LOOKUP_CODE\r\nWHERE EFLV.LOOKUP_TYPE='XXSCM_R2AS_THEATER'\r\nAND EFLV.GLOBAL_NAME='CG'",
