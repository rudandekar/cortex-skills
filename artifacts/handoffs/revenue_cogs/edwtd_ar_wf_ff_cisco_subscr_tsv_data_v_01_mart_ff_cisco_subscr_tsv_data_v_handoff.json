      "attributes": {
        "Sql Query": "SELECT \r\nREPLACE(REPLACE(REPLACE(TSV.SUBSCRIPTION_REF_ID,CHR(13),CHR(32)),CHR(10),CHR(32)),CHR(9),CHR(32)),\r\nREPLACE(REPLACE(REPLACE(TSV.SUBSCRIPTION_ID,CHR(13),CHR(32)),CHR(10),CHR(32)),CHR(9),CHR(32)),\r\nREPLACE(REPLACE(REPLACE(TSV.STATUS,CHR(13),CHR(32)),CHR(10),CHR(32)),CHR(9),CHR(32)),\r\nTSV.INITIAL_TERM,\r\nTSV.RENEWAL_TERM,\r\nREPLACE(REPLACE(REPLACE(TSV.PREPAYMENT_TERM\t,CHR(13),CHR(32)),CHR(10),CHR(32)),CHR(9),CHR(32)),\r\nTSV.RENEWAL_COUNTER,\r\nTSV.BDOM\t,\r\nTSV.TERM_START_DATE\t,\r\nTSV.TERM_END_DATE\t,\r\nREPLACE(REPLACE(REPLACE(TSV.OFFER_TYPE,CHR(13),CHR(32)),CHR(10),CHR(32)),CHR(9),CHR(32)),\r\nREPLACE(REPLACE(REPLACE(TSV.BILLING_MODEL,CHR(13),CHR(32)),CHR(10),CHR(32)),CHR(9),CHR(32)),\r\nREPLACE(REPLACE(REPLACE(TSV.LINE_STATUS,CHR(13),CHR(32)),CHR(10),CHR(32)),CHR(9),CHR(32)),\r\nREPLACE(REPLACE(REPLACE(TSV.LAST_ORDER_TYPE,CHR(13),CHR(32)),CHR(10),CHR(32)),CHR(9),CHR(32)),\r\nREPLACE(REPLACE(REPLACE(TSV.CURRENCY_CODE,CHR(13),CHR(32)),CHR(10),CHR(32)),CHR(9),CHR(32)),\r\nREPLACE(REPLACE(REPLACE(TSV.PRODUCT_ID,CHR(13),CHR(32)),CHR(10),CHR(32)),CHR(9),CHR(32)),\r\nTSV.TSV_AMOUNT\t,\r\nTSV.CREATION_DATE\t,\r\nTSV.LAST_MODIFIED_DATE\t,\r\nTSV.CANCEL_DATE,\r\nREPLACE(REPLACE(REPLACE(TSV.CHARGE_TYPE,CHR(13),CHR(32)),CHR(10),CHR(32)),CHR(9),CHR(32)),\r\nREPLACE(REPLACE(REPLACE(TSV.OFFER_CODE,CHR(13),CHR(32)),CHR(10),CHR(32)),CHR(9),CHR(32)),\r\nTSV.UNBILLED_AMOUNT,\r\nCOALESCE(TSV.FLEXUP_SKU,'N')    FLEXUP_SKU /*Added as part of Athena Sep release --mahhr*/\r\nFROM\r\n--ENT_SAAS_DATA.CISCO_SUBSCR_TSV_DATA_V TSV\r\nXXSBP_SUBSCRIPTION_TSV_DATA_V TSV\r\nWHERE TSV.LAST_MODIFIED_DATE >=to_date('$$LastExtractDate','mm/dd/yyyy hh24:mi:ss')",
