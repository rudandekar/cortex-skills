      "attributes": {
        "Sql Query": "SELECT\t\r\n       EM_CMT_DTL.ITEM_KEY,\r\n       EM_CMT_DTL.INVENTORY_ORGN_NAME_KEY,\r\n       EM_CMT_DTL.BK_SUPPLY_COMMIT_PLANNED_DT  AS BK_SUPPLY_COMMIT_PLANNED_DT,\r\n       EM_CMT_DTL.SUPPLY_COMMIT_START_DT AS SUPPLY_COMMIT_START_DT,\r\n       EM_CMT_DTL.SUPPLY_COMMIT_END_DT AS SUPPLY_COMMIT_END_DT,\r\n       EM_CMT_DTL.COMMIT_MESSAGE_TXT,\r\n       EM_CMT_DTL.COMMITTED_ITEM_QTY,\r\n       EM_CMT_DTL.PIP_INVENTORY_ORG_KEY,\r\n       CAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) AS EDW_CREATE_DTM,\r\n       CAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) AS EDW_UPDATE_DTM,\r\n       EM_CMT_DTL.ACTION_CODE,\r\n       (\r\n\t\tCASE\r\n\t\t\tWHEN\tNCISC.ITEM_KEY IS NULL\r\n\tAND\r\n                    NCISC.INVENTORY_ORGN_NAME_KEY IS NULL\r\n\tAND\r\n                   NCISC.BK_SUPPLY_COMMIT_PLANNED_DT IS NULL\r\n\tAND\r\n                    NCISC.SUPPLY_COMMIT_START_DT IS NULL THEN 'I' ELSE'U' END) AS DML_TYPE                   \r\nFROM\r\n(\r\nSELECT\t\r\n       NP.ITEM_KEY,\r\n       NCIO1.INVENTORY_ORGN_NAME_KEY,\r\n       SEC.PLAN_DATE AS BK_SUPPLY_COMMIT_PLANNED_DT,\r\n       SECD.PERIOD_START AS SUPPLY_COMMIT_START_DT,\r\n       SECD.PERIOD_END AS SUPPLY_COMMIT_END_DT,\r\n       SECD.COMMIT_MESSAGE AS COMMIT_MESSAGE_TXT,\r\n       SECD.COMMITMENT_QTY AS COMMITTED_ITEM_QTY,\r\n       NCIO2.INVENTORY_ORGN_NAME_KEY AS PIP_INVENTORY_ORG_KEY,\r\n       SECD.ACTION_CODE\r\nFROM\r\n   $$STGDB.ST_EM_COMMITMENT AS SEC,\r\n   $$STGDB.ST_EM_COMMITMENT_DETAIL AS SECD,\r\n   $$COMREFVWDB.N_PRODUCT NP,\r\n   $$COMREFVWDB.N_CISCO_INVENTORY_ORG NCIO1,\r\n   $$STGDB.ST_CG1_MTL_PARAMETER SMMP1, /* Replaced ST_MF_MTL_PARAMETERS SMMP1 as part of Q1FY14 SJPROD Sunset*/\r\n   $$COMREFVWDB.N_CISCO_INVENTORY_ORG NCIO2,\r\n   $$STGDB.ST_CG1_MTL_PARAMETER SMMP2 /* Replaced ST_MF_MTL_PARAMETERS SMMP2 as part of Q1FY14 SJPROD Sunset*/\r\nWHERE\r\n  NCIO1.INV_ORG_EFFECTIVE_END_DATE = '3500-01-01'\r\n\tAND\tNCIO2.INV_ORG_EFFECTIVE_END_DATE = '3500-01-01'\r\n\tAND\tSEC.COMMITMENT_ID = SECD.COMMITMENT_ID\r\n\tAND\t SMMP1.ATTRIBUTE13 = SEC.PARTNER_ID\r\n\tAND\tSMMP2.ATTRIBUTE13 = SEC.PIP_PARTNER_ID\r\n\tAND\tNP.BK_PRODUCT_ID = SEC.PRODUCT_ID\r\n\tAND\tNCIO1.SK_ORGANIZATION_ID_INT = SMMP1.ORGANIZATION_ID\r\n\tAND\tNCIO2.SK_ORGANIZATION_ID_INT = SMMP2.ORGANIZATION_ID\r\nUNION\tALL\r\nSELECT\t\r\n       NP.ITEM_KEY AS ITEM_KEY,\r\n       NCIO1.INVENTORY_ORGN_NAME_KEY AS INVENTORY_ORGN_NAME_KEY,\r\n       EXCEP.PLAN_DATE AS BK_SUPPLY_COMMIT_PLANNED_DT,\r\n       EXCEP.PERIOD_START AS SUPPLY_COMMIT_START_DT,\r\n       EXCEP.PERIOD_END AS SUPPLY_COMMIT_END_DT,\r\n       EXCEP.COMMIT_MESSAGE AS COMMIT_MESSAGE_TXT,\r\n       EXCEP.COMMITMENT_QTY AS COMMITTED_ITEM_QTY,\r\n       NCIO2.INVENTORY_ORGN_NAME_KEY AS PIP_INVENTORY_ORG_KEY,\r\n       EXCEP.ACTION_CODE\r\nFROM\r\n   $$EXCEPDB.EX_EM_COMMITMENT_DETAIL EXCEP,\r\n   $$COMREFVWDB.N_PRODUCT NP,\r\n   $$COMREFVWDB.N_CISCO_INVENTORY_ORG NCIO1,\r\n   $$STGDB.ST_CG1_MTL_PARAMETER SMMP1, /* Replaced ST_MF_MTL_PARAMETERS SMMP1 as part of Q1FY14 SJPROD Sunset*/\r\n   $$COMREFVWDB.N_CISCO_INVENTORY_ORG NCIO2,\r\n   $$STGDB.ST_CG1_MTL_PARAMETER SMMP2 /* Replaced ST_MF_MTL_PARAMETERS SMMP2 as part of Q1FY14 SJPROD Sunset*/\r\nWHERE\r\n NCIO1.INV_ORG_EFFECTIVE_END_DATE = '3500-01-01'\r\n\tAND\tNCIO2.INV_ORG_EFFECTIVE_END_DATE = '3500-01-01'\r\n\tAND\tSMMP1.ATTRIBUTE13 = EXCEP.PARTNER_ID\r\n\tAND\tSMMP2.ATTRIBUTE13 = EXCEP.PIP_PARTNER_ID\r\n\tAND\tNP.BK_PRODUCT_ID = EXCEP.PRODUCT_ID\r\n\tAND\tNCIO1.SK_ORGANIZATION_ID_INT = SMMP1.ORGANIZATION_ID\r\n\tAND\tNCIO2.SK_ORGANIZATION_ID_INT = SMMP2.ORGANIZATION_ID\r\n) EM_CMT_DTL\r\nLEFT OUTER JOIN $$INVFLMTVWDB.N_CM_ITEM_SUPPLY_COMMIT NCISC\r\n\tON\t          NCISC.ITEM_KEY = EM_CMT_DTL.ITEM_KEY\r\n\tAND\tNCISC.INVENTORY_ORGN_NAME_KEY = EM_CMT_DTL.INVENTORY_ORGN_NAME_KEY\r\n\tAND\tNCISC.BK_SUPPLY_COMMIT_PLANNED_DT = EM_CMT_DTL.BK_SUPPLY_COMMIT_PLANNED_DT \r\n\tAND\tNCISC.SUPPLY_COMMIT_START_DT=EM_CMT_DTL.SUPPLY_COMMIT_START_DT",
        "User Defined Join": "",
