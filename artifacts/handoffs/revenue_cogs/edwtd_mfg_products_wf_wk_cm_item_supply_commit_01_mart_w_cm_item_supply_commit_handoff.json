      "attributes": {
        "Sql Query": "SELECT \r\n      SECD.BATCH_ID,\r\n      SEC.PRODUCT_ID,\r\n      SEC.PARTNER_ID,\r\n      SEC.PLAN_DATE,\r\n      SEC.CREATION_DATE,\r\n      SEC.LAST_UPDATE,\r\n      SECD.COMMITMENT_DETAIL_ID,\r\n      SECD.COMMITMENT_ID,\r\n      SECD.PERIOD_START,\r\n      SECD.PERIOD_END,\r\n      SECD.COMMIT_MESSAGE,\r\n      SECD.COMMITMENT_QTY,\r\n      SEC.PIP_PARTNER_ID,\r\n      SECD.CREATE_DATETIME,\r\n      'RI' AS EXCEPTION_TYPE,\r\n      SECD.ACTION_CODE\r\n   FROM $$STGDB.ST_EM_COMMITMENT  SEC\r\n\tINNER JOIN\r\n        $$STGDB.ST_EM_COMMITMENT_DETAIL  SECD\r\n ON\r\n      SEC.COMMITMENT_ID = SECD.COMMITMENT_ID     \r\n     WHERE NOT EXISTS \r\n                        (SELECT 1\r\n                            FROM \r\n                                    $$COMREFVWDB.N_PRODUCT NP\r\n                                WHERE NP.BK_PRODUCT_ID = SEC.PRODUCT_ID)\r\n\r\nUNION\r\n \r\nSELECT\r\n      SECD.BATCH_ID, \r\n      SEC.PRODUCT_ID,\r\n      SEC.PARTNER_ID,\r\n      SEC.PLAN_DATE,\r\n      SEC.CREATION_DATE,\r\n      SEC.LAST_UPDATE,\r\n      SECD.COMMITMENT_DETAIL_ID,\r\n      SECD.COMMITMENT_ID,\r\n      SECD.PERIOD_START,\r\n      SECD.PERIOD_END,\r\n      SECD.COMMIT_MESSAGE,\r\n      SECD.COMMITMENT_QTY,\r\n      SEC.PIP_PARTNER_ID,\r\n      SECD.CREATE_DATETIME,\r\n      'RI' AS EXCEPTION_TYPE,\r\n      SECD.ACTION_CODE\r\n   FROM $$STGDB.ST_EM_COMMITMENT SEC\r\n\tINNER JOIN\r\n        $$STGDB.ST_EM_COMMITMENT_DETAIL SECD\r\n ON\r\n      SEC.COMMITMENT_ID = SECD.COMMITMENT_ID\r\n     WHERE NOT EXISTS \r\n                        (SELECT 1\r\n                            FROM \r\n                                    $$COMREFVWDB.N_CISCO_INVENTORY_ORG NCIO\r\n                                WHERE NCIO.INV_ORG_EFFECTIVE_END_DATE = '3500-01-01'\r\n  AND NCIO.SK_ORGANIZATION_ID_INT  IN (SELECT SMMP.ORGANIZATION_ID\r\n                                                                       FROM $$STGDB.ST_CG1_MTL_PARAMETER SMMP /* Replaced ST_MF_MTL_PARAMETERS SMMP as part of Q1FY14 SJPROD Sunset*/\r\n                                                                       WHERE SMMP.ATTRIBUTE13=SEC.PARTNER_ID))\r\nUNION\r\n\r\nSELECT \r\n      SECD.BATCH_ID,\r\n      SEC.PRODUCT_ID,\r\n      SEC.PARTNER_ID,\r\n      SEC.PLAN_DATE,\r\n      SEC.CREATION_DATE,\r\n      SEC.LAST_UPDATE,\r\n      SECD.COMMITMENT_DETAIL_ID,\r\n      SECD.COMMITMENT_ID,\r\n      SECD.PERIOD_START,\r\n      SECD.PERIOD_END AS SUPPLY_COMMIT_END_DT,\r\n      SECD.COMMIT_MESSAGE AS COMMIT_MESSAGE_TXT,\r\n      SECD.COMMITMENT_QTY,\r\n      SEC.PIP_PARTNER_ID,\r\n      SECD.CREATE_DATETIME,\r\n      'RI' AS EXCEPTION_TYPE,\r\n      SECD.ACTION_CODE\r\n   FROM $$STGDB.ST_EM_COMMITMENT SEC\r\n\tINNER JOIN\r\n        $$STGDB.ST_EM_COMMITMENT_DETAIL SECD\r\n ON\r\n      SEC.COMMITMENT_ID = SECD.COMMITMENT_ID\r\n     WHERE NOT EXISTS \r\n                        (SELECT 1\r\n                            FROM \r\n                                    $$COMREFVWDB.N_CISCO_INVENTORY_ORG NCIO_PIP\r\n                                WHERE NCIO_PIP.INV_ORG_EFFECTIVE_END_DATE = '3500-01-01' \r\nAND NCIO_PIP.SK_ORGANIZATION_ID_INT IN (SELECT SMMP.ORGANIZATION_ID\r\n                                                                       FROM $$STGDB.ST_CG1_MTL_PARAMETER SMMP /* Replaced ST_MF_MTL_PARAMETERS SMMP as part of Q1FY14 SJPROD Sunset*/\r\n                                                                         WHERE SMMP.ATTRIBUTE13=SEC.PIP_PARTNER_ID))",
