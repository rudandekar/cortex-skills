      "attributes": {
        "Sql Query": "SELECT\r\nBK_PRODUCT_FAMILY_ID,\r\nMPM_NAME,\r\nDMO_NAME,\r\nVP_NAME\r\nFROM\r\n(SELECT \r\nNPF.BK_PRODUCT_FAMILY_ID AS BK_PRODUCT_FAMILY_ID,\r\nSRHP.New_MPM AS MPM_NAME,\r\nSRHP.DMO AS DMO_NAME,\r\nSRHP.VP AS VP_NAME,\r\n(CASE WHEN NSPRS.BK_PRODUCT_FAMILY_ID IS NOT NULL  THEN 'U' ELSE 'I' END) AS DML_TYPE \r\nFROM \r\n$$SOPDATAVWDB.SC_PF_RPRTNG_STRUCTURE SRHP\r\nINNER JOIN \r\n$$COMREFDB.N_PRODUCT_FAMILY NPF\r\nON \r\nNPF.BK_PRODUCT_FAMILY_ID=SRHP.PF\r\nLEFT JOIN $$INVFLMTVWDB.N_SC_PF_RPRTNG_STRUCTURE NSPRS\r\nON NSPRS.BK_PRODUCT_FAMILY_ID=SRHP.PF\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY  SRHP.PF ORDER BY SRHP.BATCH_ID  DESC) = 1 \r\n) A\r\nwhere A.DML_TYPE='I'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
