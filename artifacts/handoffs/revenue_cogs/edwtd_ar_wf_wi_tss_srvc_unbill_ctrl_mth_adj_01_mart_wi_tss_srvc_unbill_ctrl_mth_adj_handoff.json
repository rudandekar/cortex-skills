      "attributes": {
        "Sql Query": "SELECT \r\n TRANSACTION_TYPE,\r\n MAX(PROCESSED_FISCAL_MTH) AS FISCAL_YEAR_MONTH_INT\r\n FROM $$FINLGLVWDB.MT_RSTD_UNBILLED_REVENUE UNB\r\n LEFT JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\n ON RFM.FISCAL_YEAR_MONTH_INT = UNB.PROCESSED_FISCAL_MTH\r\n WHERE PREVIOUS_FSCL_MONTH_FLAG      ='Y' \r\n AND TRANSACTION_TYPE NOT IN ('ERP','NET_ADJ_ERP','SBP','SBP_ACCRUALS','NET_ADJ_SBP','OPL','OPL_ACCRUALS')\r\n GROUP BY 1",
