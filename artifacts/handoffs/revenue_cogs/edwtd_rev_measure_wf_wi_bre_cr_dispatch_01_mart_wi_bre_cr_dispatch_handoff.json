      "attributes": {
        "Sql Query": "SELECT BRE_TRX_LOG_ID,CREATION_DATE,TRANSACTION_ID,EVENTDATETIMEC,COLLABORATIONEXTIDC,EVENTTYPEC,B.FISCAL_MONTH_ID\r\nFROM $$ETLVWDB.EL_TSS_SRM_CBEBRE_LOGS A , (SELECT * FROM $$STGDB.WI_ACTS_CTRL WHERE FISCAL_MONTH_STATUS_IND='WIP')  B,\r\n$$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR C\r\nWHERE  UPPER(EVENTTYPEC) LIKE 'CR DISPATCH%'\r\nAND B.FISCAL_MONTH_ID = C.FISCAL_YEAR_MONTH_INT\r\nAND A.CREATION_DATE BETWEEN C.FISCAL_MONTH_START_DATE AND C.FISCAL_MONTH_END_DATE",
