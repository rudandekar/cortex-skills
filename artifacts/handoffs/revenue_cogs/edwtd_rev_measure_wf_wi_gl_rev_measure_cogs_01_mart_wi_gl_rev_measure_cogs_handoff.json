        "Sql Query": "SELECT INIT_QUERY.SALES_ORDER_KEY\r\n\t\t, INIT_QUERY.SALES_ORDER_LINE_KEY\r\n\t\t, INIT_QUERY.RU_PARNT_SLS_ORDER_LINE_KEY\r\n\t\t, INIT_QUERY.BK_SO_NUMBER_INT \r\n\t\t, INIT_QUERY.BK_SO_LINE_NUMBER_INT\r\n\t\t, INIT_QUERY.SK_SO_LINE_ID_INT    LINE_ID \r\n\t\t, INIT_QUERY.ERP_PARENT_LINE_ID\r\n\t\t, INIT_QUERY.ITEM_TYPE_CODE\r\n\t\t, INIT_QUERY.BK_PRODUCT_ID\r\n\t\t, INIT_QUERY.RU_BK_PRODUCT_FAMILY_ID\r\n\t\t, INIT_QUERY.BK_BUSINESS_UNIT_ID\r\n\t\t, INIT_QUERY.BK_TECHNOLOGY_GROUP_ID\r\n\t\t, INIT_QUERY.SK_INVENTORY_ITEM_ID_INT   \r\n\t\t, INIT_QUERY.SS_CODE\r\n\t\t, INIT_QUERY.DD_SHIPMENT_CONFIRMED_DTM\r\n\t\t, INIT_QUERY.BK_SHIP_FROM_INV_ORG_NAME_CODE\r\n\t\t, INIT_QUERY.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n\t\t, INIT_QUERY.DV_EXTENDED_QTY\r\n\t\t, INIT_QUERY.DD_EXTENDED_NET_QTY AS DV_EXTENDED_NET_QTY\r\n\t\t, INIT_QUERY.SUM_EXT_UNIT_SELLING_PRICE AS DV_COMP_US_EXT_SELLING_PRC_AMT\r\n\t\t, INIT_QUERY.UNIT_SALE_PRICE\r\n\t\t, INIT_QUERY.SUM_DV_COMP_US_NET_COST_AMT AS DV_COMP_US_NET_COST_AMT\r\n\t\t, INIT_QUERY.SUM_DV_COMP_US_GROSS_COST_AMT AS DV_COMP_US_GROSS_COST_AMT\r\n\t\t, CASE ITEM_TYPE_CODE \r\n\t\tWHEN 'STANDARD' THEN SUM_DV_COMP_US_NET_COST_AMT \r\n\t\tWHEN 'MODEL' THEN EDW_QUERY.TOTAL_EDW_COST1  END DV_COMP_US_EDW_COST_AMT\r\n\t\tFROM \r\n\t\t(\r\n\t\tSELECT \r\n\t\tNGRM.SALES_ORDER_KEY\r\n\t\t, NSOL.SALES_ORDER_LINE_KEY\r\n\t\t, NSOL.RU_PARNT_SLS_ORDER_LINE_KEY\r\n\t\t, NSO.BK_SO_NUMBER_INT \r\n\t\t, NSOL.BK_SO_LINE_NUMBER_INT\r\n\t\t, NSOL.SK_SO_LINE_ID_INT     \r\n\t\t, NSOLPRNT.SK_SO_LINE_ID_INT    ERP_PARENT_LINE_ID\r\n\t\t, NPROD.SK_INVENTORY_ITEM_ID_INT   \r\n\t\t, RPROD.BK_PRODUCT_ID\r\n\t\t, RPROD.RU_BK_PRODUCT_FAMILY_ID\r\n\t\t, RPROD.BK_BUSINESS_UNIT_ID\r\n\t\t, RPROD.BK_TECHNOLOGY_GROUP_ID\r\n\t\t, NSOL.ITEM_TYPE_CODE\r\n\t\t, NSOL.SS_CODE\r\n\t\t, CAST(NSOL.DD_SHIPMENT_CONFIRMED_DTM AS TIMESTAMP(0)) AS DD_SHIPMENT_CONFIRMED_DTM\r\n\t\t, NSOL.BK_SHIP_FROM_INV_ORG_NAME_CODE\r\n\t\t, NGRM.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n\t\t, NSOL.UNIT_SALE_PRICE\r\n\t\t, SUM (DV_COMP_US_NET_COST_AMT) SUM_DV_COMP_US_NET_COST_AMT\r\n\t\t, SUM(DV_COMP_US_GROSS_COST_AMT) SUM_DV_COMP_US_GROSS_COST_AMT\r\n\t\t, SUM( DV_EXTENDED_QTY) AS DV_EXTENDED_QTY\r\n\t\t, SUM(DD_EXTENDED_NET_QTY) AS DD_EXTENDED_NET_QTY\r\n\t\t, SUM( NSOL.UNIT_SALE_PRICE * DV_EXTENDED_QTY)   SUM_EXT_UNIT_SELLING_PRICE\r\n\t\t FROM $$FINLGLVWDB.N_GL_REV_MEASURE NGRM\r\n\t\t JOIN $$SLSORDVWDB.N_SALES_ORDER NSO ON NGRM.SALES_ORDER_KEY = NSO.SALES_ORDER_KEY\r\n\t\t JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE NSOL ON NGRM.SALES_ORDER_LINE_KEY = NSOL.SALES_ORDER_LINE_KEY\r\n\t\t JOIN $$COMREFVWDB.R_PRODUCTS RPROD ON NGRM.PRODUCT_KEY = RPROD.ITEM_KEY  AND RPROD.BK_PRODUCT_ID <> 'ERP_NA_PROD' \r\n\t\t JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE NSOLPRNT ON  NSOLPRNT.SALES_ORDER_LINE_KEY =       NSOL.RU_PARNT_SLS_ORDER_LINE_KEY\r\n\t\t JOIN $$FINLGLVWDB.N_AR_TRX_LINE NARTRX ON NGRM.AR_TRX_LINE_KEY = NARTRX.AR_TRX_LINE_KEY   AND NARTRX.BK_AR_TRX_LINE_TYPE = 'LINE' \r\n\t\t JOIN $$COMREFVWDB.N_PRODUCT NPROD ON NPROD.ITEM_KEY = RPROD.ITEM_KEY\r\n                 WHERE  NGRM.DV_FISCAL_YEAR_MTH_NUMBER_INT IN (SELECT  FISCMTH.FISCAL_YEAR_MONTH_INT FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR FISCMTH \r\n\t\t WHERE CAST( CURRENT_DATE  - 1 AS DATE)  BETWEEN FISCAL_MONTH_START_DATE       AND  FISCAL_MONTH_END_DATE) \r\n\t\tAND NGRM.DV_CORPORATE_REVENUE_FLG = 'Y'\r\n\t\tAND NGRM.DV_SERVICE_FLG = 'N'\r\n\t\tAND NGRM.TRANSACTION_TYPE_CATEGORY_CD NOT IN ('ERP_ADJ', 'CM', 'DM' )  \r\n\t\tGROUP BY NSOL.UNIT_SALE_PRICE\r\n\t\t, NSO.BK_SO_NUMBER_INT \r\n\t\t, NSOL.SK_SO_LINE_ID_INT\r\n\t\t, NSOL.ITEM_TYPE_CODE    \r\n\t\t, NSOL.RU_PARNT_SLS_ORDER_LINE_KEY   \r\n\t\t, NSOL.SALES_ORDER_LINE_KEY\r\n\t\t, RPROD.BK_PRODUCT_ID\r\n\t\t, NSOL.BK_SO_LINE_NUMBER_INT\r\n\t\t, NSOLPRNT.SK_SO_LINE_ID_INT \r\n\t\t, RPROD.RU_BK_PRODUCT_FAMILY_ID\r\n\t\t, RPROD.BK_BUSINESS_UNIT_ID\r\n\t\t, RPROD.BK_TECHNOLOGY_GROUP_ID\r\n\t\t, NGRM.SALES_ORDER_KEY\r\n\t\t, NSOL.DD_SHIPMENT_CONFIRMED_DTM\r\n\t\t, NSOL.BK_SHIP_FROM_INV_ORG_NAME_CODE     \r\n\t\t, NPROD.SK_INVENTORY_ITEM_ID_INT \r\n\t\t, NGRM.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n\t\t, NSOL.SS_CODE\r\n\t\t)   INIT_QUERY\r\n\t\tLEFT JOIN (SELECT  \r\n\t\tNSO.BK_SO_NUMBER_INT \r\n\t\t, NSOL.RU_PARNT_SLS_ORDER_LINE_KEY\r\n\t\t, NSOL.SS_CODE\r\n\t\t, SUM (DV_COMP_US_NET_COST_AMT) TOTAL_EDW_COST1\r\n\t\t  FROM $$FINLGLVWDB.N_GL_REV_MEASURE NGRM\r\n\t\t JOIN $$SLSORDVWDB.N_SALES_ORDER NSO ON NGRM.SALES_ORDER_KEY = NSO.SALES_ORDER_KEY\r\n\t\t JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE NSOL ON NGRM.SALES_ORDER_LINE_KEY = NSOL.SALES_ORDER_LINE_KEY\r\n\t\t WHERE  NGRM.DV_FISCAL_YEAR_MTH_NUMBER_INT IN (SELECT  FISCMTH.FISCAL_YEAR_MONTH_INT FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR FISCMTH \r\n\t\t WHERE CAST( CURRENT_DATE  - 1 AS DATE)  BETWEEN FISCAL_MONTH_START_DATE       AND  FISCAL_MONTH_END_DATE) \r\n\t\t  AND  NGRM.DV_CORPORATE_REVENUE_FLG = 'Y'\r\n\t\tAND NGRM.DV_SERVICE_FLG = 'N'\r\n\t\tAND NGRM.TRANSACTION_TYPE_CATEGORY_CD NOT IN ('ERP_ADJ', 'CM', 'DM' )  \r\n\t\tAND NSOL.ITEM_TYPE_CODE NOT IN ( 'STANDARD')  \r\n\t\tGROUP BY  NSO.BK_SO_NUMBER_INT \r\n\t\t, NSOL.RU_PARNT_SLS_ORDER_LINE_KEY \r\n\t\t, NSOL.SS_CODE )  EDW_QUERY \r\n\t\tON   EDW_QUERY.BK_SO_NUMBER_INT = INIT_QUERY.BK_SO_NUMBER_INT\r\n\t\t\t AND EDW_QUERY.RU_PARNT_SLS_ORDER_LINE_KEY = INIT_QUERY.RU_PARNT_SLS_ORDER_LINE_KEY \r\n\t\t\t AND INIT_QUERY.SS_CODE = EDW_QUERY.SS_CODE",
