      "attributes": {
        "Sql Query": "SELECT BK_CONTRACT_NUMBER_INT, CONTRACT_EFFECTIVE_DT,  CONTRACT_EXPIRATION_DT,  CONTRACT_STATUS_CD, CMS_REFERENCE_ROLE, \r\nRU_CMS_CONTRACT_NUM_INT, RU_CMS_CONTRACT_VER_NUM_INT\r\nFROM (SELECT  \r\n  SECCM.ECLM_CONTRACT_NUMBER  BK_CONTRACT_NUMBER_INT,\r\n  SECCM.EFFECTIVE_START_DATE  CONTRACT_EFFECTIVE_DT,\r\n  SECCM.EXPIRATION_DATE  CONTRACT_EXPIRATION_DT,\r\n  SECCM.ECLM_CONTRACT_STATUS  CONTRACT_STATUS_CD,\r\n    (CASE WHEN SECCM.CMS_CONTRACT_NUMBER IS NOT NULL THEN 'Y' ELSE 'N' END) CMS_REFERENCE_ROLE,\r\n    SECCM.CMS_CONTRACT_NUMBER  RU_CMS_CONTRACT_NUM_INT,\r\n    SECCM.CMS_VERSION RU_CMS_CONTRACT_VER_NUM_INT\r\n  FROM  $$STGDB.ST_ECLM_CMS_CONTRACT_MAPPING SECCM\r\n  GROUP BY \r\n  SECCM.ECLM_CONTRACT_NUMBER,\r\n  SECCM.EFFECTIVE_START_DATE,\r\n  SECCM.EXPIRATION_DATE,\r\n  SECCM.ECLM_CONTRACT_STATUS,\r\n  SECCM.CMS_CONTRACT_NUMBER,\r\nSECCM.CMS_VERSION)A",
