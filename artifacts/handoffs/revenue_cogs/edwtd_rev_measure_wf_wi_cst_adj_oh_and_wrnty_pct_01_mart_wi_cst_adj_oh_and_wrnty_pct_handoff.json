      "attributes": {
        "Sql Query": "SELECT \r\n SUBREF.FISCAL_QUARTER_NAME ,\r\n SUBREF.NET_TS_FETCH_COA_AMT , \r\n (SSCAGGR.DEPT_COST + SSCAGGR.DEPRECIATION_COST + SSCAGGR.REPAIR_COST + SSCAGGR.DUTY_VAT_COST + SSCAGGR.TPL_COST + SSCAGGR.TPM_COST + SSCAGGR.OEM_COST)TOTAL_SSC_COST,\r\n SUBREF.SSC_WARRANTY_CREDIT_AMT,\r\n SUBREF.TAC_WARRANTY_CREDIT_AMT,\r\n ( NET_TS_FETCH_COA_AMT  - ( TOTAL_SSC_COST - SSC_WARRANTY_CREDIT_AMT ) -  (TACAGGR.TAC_OT_COST+ TACAGGR.TBO_COST-TAC_WARRANTY_CREDIT_AMT))  AS ADJ_OH_COST,\r\n ( TOTAL_SSC_COST - SSC_WARRANTY_CREDIT_AMT )*100/TOTAL_SSC_COST  SSC_COGS_PCT  ,\r\n (1-SUBREF.TAC_WARRANTY_CREDIT_AMT/(TACAGGR.TAC_OT_COST+TACAGGR.TBO_COST+OH_COST*ADJUSTED_OH_PCT/100))*100 TAC_COGS_PCT,\r\n ( ADJ_OH_COST*100/ TACAGGR.OH_COST ) AS ADJUSTED_OH_PCT    \r\n FROM \r\n (\r\n                                 SELECT \r\n                                 CNTRL.FISCAL_QUARTER_NAME,\r\n                                 SUM(       DEPT_COST                          )               DEPT_COST                          ,\r\n                                 SUM(       DEPRECIATION_COST                        )               DEPRECIATION_COST                        ,\r\n                                 SUM(       REPAIR_COST                      )               REPAIR_COST                      ,\r\n                                 SUM(       DUTY_VAT_COST )               DUTY_VAT_COST ,\r\n                                 SUM(       TPL_COST                             )               TPL_COST                             ,\r\n                                 SUM(       TPM_COST                            )               TPM_COST                            ,\r\n                                 SUM(       OEM_COST                           )               OEM_COST                \r\n                                 FROM \r\n                                 $$STGDB.WI_CST_SSC_COGS SCTTC \r\n                                 INNER JOIN $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID CNTRL\r\n                                 ON CNTRL.FISCAL_MONTH_NAME = SCTTC.FISCAL_MONTH \r\n                                 GROUP BY CNTRL.FISCAL_QUARTER_NAME\r\n ) SSCAGGR\r\n INNER JOIN \r\n (      SELECT \r\n         CNTRL.FISCAL_QUARTER_NAME \r\n         ,SUM(TAC_BB_COST                   )  TAC_BB_COST  \r\n         ,SUM(TAC_OT_COST                   )  TAC_OT_COST \r\n         ,SUM(TBO_COST                      )  TBO_COST  \r\n         ,SUM(OH_COST          )  OH_COST      \r\n         FROM \r\n         $$STGDB.WI_EDW_TS_TAC_COGS SCTTC \r\n         INNER JOIN $$STGDB.WI_TSS_COST_CNTRL_MONTH_ID CNTRL\r\n         ON CNTRL.FISCAL_MONTH_NAME = SCTTC.FISCAL_MONTH \r\n         GROUP BY CNTRL.FISCAL_QUARTER_NAME \r\n ) TACAGGR\r\n ON TACAGGR.FISCAL_QUARTER_NAME =SSCAGGR.FISCAL_QUARTER_NAME\r\n INNER JOIN $$STGDB.WI_CST_SUBCRIPTION_REF_DATA SUBREF\r\n ON TACAGGR.FISCAL_QUARTER_NAME = SUBREF.FISCAL_QUARTER_NAME",
        "User Defined Join": "",
