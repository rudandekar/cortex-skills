      "attributes": {
        "Sql Query": "SELECT\r\nBK_DFRD_REV_MSR_LVL_TWO_NAME  ,             \r\n BK_SERVICE_FLG ,             \r\n DFRD_REV_MEASURE_LVL_ONE_NAME     ,             \r\n BALANCE_TREND_RPRT_FLG,            \r\n BALANCE_WATERFALL_RPRT_FLG        ,\r\nBRIDGE_RPRT_FLG    ,               \r\n REVENUE_TREND_RPRT_FLG,            \r\n REVENUE_WATERFALL_RPRT_FLG,    \r\n CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,               \r\n START_TV_DT  ,                 \r\n END_TV_DT     ,\r\nPRODUCT_SUBSCRIPTION_FLG,\r\n'I' ACTION_CODE,\r\nDML_TYPE                \r\n   \r\n FROM\r\n(\r\nSELECT \r\n TVOUTPUT.BK_DFRD_REV_MSR_LVL_TWO_NAME,\r\nTVOUTPUT.BK_SERVICE_FLG,\r\nTVOUTPUT.DFRD_REV_MEASURE_LVL_ONE_NAME,\r\nTVOUTPUT.BALANCE_TREND_RPRT_FLG,            \r\n TVOUTPUT.BALANCE_WATERFALL_RPRT_FLG        ,\r\nTVOUTPUT.BRIDGE_RPRT_FLG    ,               \r\n TVOUTPUT.REVENUE_TREND_RPRT_FLG,            \r\n TVOUTPUT.REVENUE_WATERFALL_RPRT_FLG,   \r\n CAST(TVOUTPUT.UPDATE_DATETIME AS DATE)  AS START_TV_DT,\r\n  \r\n COALESCE (MAX (CAST(TVOUTPUT.UPDATE_DATETIME  AS DATE) - INTERVAL '1' DAY) \r\n OVER (PARTITION BY TVOUTPUT.BK_DFRD_REV_MSR_LVL_TWO_NAME,TVOUTPUT.BK_SERVICE_FLG/*, TVOUTPUT.PRODUCT_SUBSCRIPTION_FLG*/\r\nORDER BY TVOUTPUT.START_TV_DT ASC ROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING), \r\n DATE '3500-01-01') AS END_TV_DT,\r\nROW_NUMBER () OVER (PARTITION BY TVOUTPUT.BK_DFRD_REV_MSR_LVL_TWO_NAME,TVOUTPUT.BK_SERVICE_FLG, TVOUTPUT.PRODUCT_SUBSCRIPTION_FLG\r\nORDER BY TVOUTPUT.START_TV_DT ASC) AS RANK_INDEX,\r\n\r\n (CASE WHEN RANK_INDEX = 1 AND TV_3NF.BK_DFRD_REV_MSR_LVL_TWO_NAME  IS NOT NULL  AND TV_3NF.BK_SERVICE_FLG  IS NOT NULL AND TV_3NF.PRODUCT_SUBSCRIPTION_FLG IS NOT NULL THEN 'U'ELSE 'I' END ) AS DML_TYPE ,\r\n\r\n TVOUTPUT.PRODUCT_SUBSCRIPTION_FLG\r\n\r\n FROM\r\n(\r\nSELECT\r\nBK_DFRD_REV_MSR_LVL_TWO_NAME  ,             \r\n BK_SERVICE_FLG ,             \r\n DFRD_REV_MEASURE_LVL_ONE_NAME     ,             \r\n BALANCE_TREND_RPRT_FLG,            \r\n BALANCE_WATERFALL_RPRT_FLG        ,\r\nBRIDGE_RPRT_FLG    ,               \r\n REVENUE_TREND_RPRT_FLG,            \r\n REVENUE_WATERFALL_RPRT_FLG,    \r\n START_TV_DT,            \r\n CREATE_DATETIME,\r\nUPDATE_DATETIME ,    \r\n ROW_NUMBER () OVER (PARTITION BY \r\n BK_DFRD_REV_MSR_LVL_TWO_NAME  ,             \r\n BK_SERVICE_FLG ,             \r\n DFRD_REV_MEASURE_LVL_ONE_NAME     ,             \r\n BALANCE_TREND_RPRT_FLG,            \r\n BALANCE_WATERFALL_RPRT_FLG        ,\r\nBRIDGE_RPRT_FLG    ,               \r\n REVENUE_TREND_RPRT_FLG,            \r\n REVENUE_WATERFALL_RPRT_FLG,PRODUCT_SUBSCRIPTION_FLG ORDER BY UPDATE_DATETIME DESC) AS ROW_NUM,\r\nPRODUCT_SUBSCRIPTION_FLG \r\n \r\n FROM \r\n (\r\nSELECT\r\nMEASURE_LEVEL_2 AS BK_DFRD_REV_MSR_LVL_TWO_NAME,   \r\n SERVICE_FLAG  AS BK_SERVICE_FLG   ,  \r\n MEASURE_LEVEL_1  AS DFRD_REV_MEASURE_LVL_ONE_NAME ,                       \r\n BALANCE_TREND_FLAG AS BALANCE_TREND_RPRT_FLG,            \r\n BALANCE_WATERFALL_FLAG AS  BALANCE_WATERFALL_RPRT_FLG      ,\r\nBRIDGE_FLAG  AS BRIDGE_RPRT_FLG  ,               \r\n REVENUE_TREND_FLAG AS REVENUE_TREND_RPRT_FLG,            \r\n REVENUE_WATERFALL_FLAG AS REVENUE_WATERFALL_RPRT_FLG,   \r\n CAST(UPDATE_DATETIME AS DATE) AS START_TV_DT,            \r\n CREATE_DATETIME,\r\nUPDATE_DATETIME,\r\nPROD_SUBSCRIPTION_FLG AS PRODUCT_SUBSCRIPTION_FLG\r\nFROM \r\n$$STGDB.ST_DFR_MEASURE_REPORTING ST\r\n        \r\n UNION ALL\r\n    \r\n SELECT  \r\n BK_DFRD_REV_MSR_LVL_TWO_NAME  ,             \r\n BK_SERVICE_FLG ,             \r\n DFRD_REV_MEASURE_LVL_ONE_NAME     ,             \r\n BALANCE_TREND_RPRT_FLG,            \r\n BALANCE_WATERFALL_RPRT_FLG        ,\r\nBRIDGE_RPRT_FLG    ,               \r\n REVENUE_TREND_RPRT_FLG,            \r\n REVENUE_WATERFALL_RPRT_FLG,    \r\n START_TV_DT, \r\n CAST(TV_3NF.START_TV_DT AS TIMESTAMP(0))  CREATE_DATETIME, \r\n CAST(TV_3NF.START_TV_DT AS TIMESTAMP(0))  UPDATE_DATETIME,\r\nPRODUCT_SUBSCRIPTION_FLG\r\nFROM\r\n$$FINLGLVWDB.N_FIN_DFRD_REV_MEASURE_HIER_TV TV_3NF\r\nWHERE\r\n(BK_DFRD_REV_MSR_LVL_TWO_NAME,BK_SERVICE_FLG) IN ( SELECT \r\n MEASURE_LEVEL_2,SERVICE_FLAG\r\nFROM $$STGDB.ST_DFR_MEASURE_REPORTING)\r\nAND TV_3NF.END_TV_DT = CAST ('3500-01-01' AS DATE)\r\n) TVINPUT\r\n   \r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY TVINPUT.BK_DFRD_REV_MSR_LVL_TWO_NAME,TVINPUT.BK_SERVICE_FLG, TVINPUT.PRODUCT_SUBSCRIPTION_FLG, CAST(TVINPUT.UPDATE_DATETIME AS DATE)\r\nORDER BY TVINPUT.UPDATE_DATETIME DESC) = 1\r\n   \r\n ) TVOUTPUT\r\nLEFT JOIN   $$FINLGLVWDB.N_FIN_DFRD_REV_MEASURE_HIER_TV TV_3NF\r\nON TVOUTPUT.BK_DFRD_REV_MSR_LVL_TWO_NAME = TV_3NF.BK_DFRD_REV_MSR_LVL_TWO_NAME\r\nAND TVOUTPUT.BK_SERVICE_FLG = TV_3NF.BK_SERVICE_FLG\r\nAND TVOUTPUT.PRODUCT_SUBSCRIPTION_FLG = TV_3NF.PRODUCT_SUBSCRIPTION_FLG\r\nAND TV_3NF.END_TV_DT =CAST ('3500-01-01' AS DATE)\r\nWHERE TVOUTPUT.ROW_NUM = 1\r\n)A",
        "User Defined Join": "",
