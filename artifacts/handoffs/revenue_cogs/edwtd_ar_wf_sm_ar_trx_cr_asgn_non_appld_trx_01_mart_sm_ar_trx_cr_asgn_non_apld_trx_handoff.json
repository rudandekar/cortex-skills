      "attributes": {
        "Sql Query": "SELECT\r\n\r\nROW_NUMBER() OVER (ORDER BY GLOBAL_NAME, HEADER_SEQ_ID ) + CSM_HDR.HEADER_ID_KEY as AS_PAID_INVNTRY_ITEM_LINK_KEY, \r\nCSM.HEADER_SEQ_ID AS HEADER_SEQ_ID,\r\nCSM.GLOBAL_NAME as GLOBAL_NAME ,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER as  EDW_CREATE_USER\r\n\r\nFROM\r\n\r\n(SELECT DISTINCT  GLOBAL_NAME, HEADER_SEQ_ID FROM $$STGDB.WI_AR_TRX_CR_ASGN_NON_APP_TRX)CSM,\r\n\r\n(SELECT COALESCE( MAX(AR_TRX_CR_ASGN_NON_APPLIED_KEY),0) HEADER_ID_KEY FROM $$TRANSLATIONDB.SM_AR_TRX_CR_ASGN_NON_APLD_TRX) CSM_HDR\r\n\r\nWHERE NOT EXISTS\r\n\r\n(SELECT 1 FROM \r\n$$TRANSLATIONDB.SM_AR_TRX_CR_ASGN_NON_APLD_TRX SMAR\r\n\r\nWHERE CSM.GLOBAL_NAME=SMAR.SS_CD\r\nAND CSM.HEADER_SEQ_ID=SMAR.SK_HEADER_SEQUENCE_ID_INT)",
