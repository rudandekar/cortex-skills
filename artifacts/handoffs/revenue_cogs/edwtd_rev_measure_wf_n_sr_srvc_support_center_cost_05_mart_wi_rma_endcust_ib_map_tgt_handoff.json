        "Sql Query": "SELECT \r\nFISCAL_QUARTER_NAME\r\n,FISCAL_YEAR_MONTH_INT\r\n,SERVICE_CONTRACT\r\n,DV_END_CUSTOMER_NAME\r\n,DV_COMP_US_NET_REV_AMT\r\n,SUM(DV_COMP_US_NET_REV_AMT) OVER(PARTITION BY FISCAL_QUARTER_NAME,SERVICE_CONTRACT) TOTAL_COMP_US_NET_REV_AMT\r\n,COUNT  (DV_END_CUSTOMER_NAME) OVER(PARTITION BY FISCAL_QUARTER_NAME,SERVICE_CONTRACT) SLK_DIST_COUNT\r\nFROM\r\n(\r\n\tSELECT \r\n\tREV_MTH.FISCAL_QUARTER_NAME\r\n\t,REV_MTH.FISCAL_YEAR_MONTH_INT\r\n\t,ENDCUST.GU_PRIMARY_NAME AS DV_END_CUSTOMER_NAME\r\n\t,COALESCE(SOLTV.RU_SERVICE_CONTRACT_NUMBER, ITEM_LINE.SERVICE_CONTRACT_NOTE_TXT) AS SERVICE_CONTRACT\r\n\t,SUM(DV_COMP_US_NET_REV_AMT) DV_COMP_US_NET_REV_AMT\r\n\t--FROM $$FINLGLVWDB.N_GL_REV_MEASURE GL\r\nFROM $$FINLGLVWDB.MT_RSTD_GL_REV_MEASURE GL\r\n\t--MT_TSS_SERVICE_REVENUE GL\r\n\tINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE_TV SOLTV \r\n\tON SOLTV.SALES_ORDER_LINE_KEY = (CASE WHEN GL.SALES_ORDER_LINE_KEY >0 THEN GL.SALES_ORDER_LINE_KEY ELSE GL.DV_SALES_ORDER_LINE_KEY END )\r\n\t\r\n\t\r\n\tLEFT OUTER JOIN  FINLGLVWDB.N_AR_TRX_ITEM_LINE  ITEM_LINE   \r\n\tON GL.AR_TRX_LINE_KEY=ITEM_LINE.AR_TRX_LINE_KEY \r\n\t\r\n\tINNER JOIN $$COMREFVWDB.MT_ENDCUST_CUSTOMER_PARTY_HIER ENDCUST \r\n\tON ENDCUST.END_CUSTOMER_KEY=GL.END_CUSTOMER_KEY\r\n\tINNER JOIN (SELECT CTRL_FISCAL.FISCAL_QUARTER_NAME,RFISCAL.FISCAL_QTR_AGO_MONTH_NUMBER, RFISCAL.FISCAL_MONTH_AGO_MONTH_NUMBER,CTRL_FISCAL.FISCAL_YEAR_MONTH_INT   \r\n\tFROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFISCAL  \r\n\tINNER JOIN $$STGDB.WI_CCM_TS_MTH_QTR_CNTL CTRL_FISCAL\r\n\tON  CTRL_FISCAL.FISCAL_YEAR_MONTH_INT=RFISCAL.FISCAL_YEAR_MONTH_INT AND CTRL_FISCAL.MONTH_RANK=1) REV_MTH\r\n\tON 1=1 \r\n\tWHERE GL.DV_FISCAL_YEAR_MTH_NUMBER_INT  BETWEEN REV_MTH.FISCAL_QTR_AGO_MONTH_NUMBER AND   REV_MTH.FISCAL_MONTH_AGO_MONTH_NUMBER\r\n\t--AND GL.DV_ATTRIBUTION_CD IN ('STANDALONE','ATTRIBUTED') \r\nAND GL.DV_CORPORATE_REVENUE_FLG = 'Y'\r\nAND SOLTV.RU_SERVICE_CONTRACT_NUMBER IS NOT NULL\r\n--AND GL.DV_SERVICE_FLG='Y'\r\nGROUP BY 1,2,3,4\r\n) GL_REV_DRIVER\r\nQUALIFY SLK_DIST_COUNT=1",
