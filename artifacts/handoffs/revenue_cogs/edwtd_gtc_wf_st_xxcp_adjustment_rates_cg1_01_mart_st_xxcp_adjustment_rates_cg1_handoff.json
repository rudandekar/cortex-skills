        "Sql Query": "SELECT CG1_XXCP_ADJUSTMENT_RATES.ADJUSTMENT_RATE_ID, CG1_XXCP_ADJUSTMENT_RATES.RATE_SET_ID, CG1_XXCP_ADJUSTMENT_RATES.OWNER, CG1_XXCP_ADJUSTMENT_RATES.PARTNER, CG1_XXCP_ADJUSTMENT_RATES.AR_QUALIFIER1, CG1_XXCP_ADJUSTMENT_RATES.AR_QUALIFIER2, CG1_XXCP_ADJUSTMENT_RATES.EFFECTIVE_FROM_DATE, CG1_XXCP_ADJUSTMENT_RATES.EFFECTIVE_TO_DATE, CG1_XXCP_ADJUSTMENT_RATES.RATE, CG1_XXCP_ADJUSTMENT_RATES.RATE_DISPLAYED, CG1_XXCP_ADJUSTMENT_RATES.ATTRIBUTE1, CG1_XXCP_ADJUSTMENT_RATES.ATTRIBUTE2, CG1_XXCP_ADJUSTMENT_RATES.ATTRIBUTE3, CG1_XXCP_ADJUSTMENT_RATES.ATTRIBUTE4, CG1_XXCP_ADJUSTMENT_RATES.ATTRIBUTE5, CG1_XXCP_ADJUSTMENT_RATES.SECONDARY_RATE, CG1_XXCP_ADJUSTMENT_RATES.SECONDARY_RATE_DISPLAYED, CG1_XXCP_ADJUSTMENT_RATES.CREATED_BY, CG1_XXCP_ADJUSTMENT_RATES.CREATION_DATE, CG1_XXCP_ADJUSTMENT_RATES.LAST_UPDATED_BY, CG1_XXCP_ADJUSTMENT_RATES.LAST_UPDATE_DATE, CG1_XXCP_ADJUSTMENT_RATES.LAST_UPDATE_LOGIN, CG1_XXCP_ADJUSTMENT_RATES.MD_ID, CG1_XXCP_ADJUSTMENT_RATES.SOURCE_ID, CG1_XXCP_ADJUSTMENT_RATES.SOURCE_DML_TYPE, CG1_XXCP_ADJUSTMENT_RATES.SOURCE_COMMIT_TIME, CG1_XXCP_ADJUSTMENT_RATES.REFRESH_DATETIME, 1 AS BATCH_ID,\r\nCURRENT_TIMESTAMP(0) AS CREATE_DATETIME,\r\n'I' AS ACTION_CD\r\nFROM\r\n$$NRTACCUMVWDB.CG1_XXCP_ADJUSTMENT_RATES\r\nWHERE   SOURCE_COMMIT_TIME > '$$LastExtractDate' \r\nAND   SOURCE_DML_TYPE <> 'DELETE'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY CG1_XXCP_ADJUSTMENT_RATES.ADJUSTMENT_RATE_ID ORDER BY   REFRESH_DATETIME DESC) = 1",
