      "attributes": {
        "Sql Query": "SELECT \r\nRANK () OVER (ORDER BY N_OM.SK_ADJUSTMENT_ID_INT, N_OM.SS_CODE ) + SMATKEY.MAX_VAL AS  AR_ADJUSTMENT_KEY, \r\nN_OM.SK_ADJUSTMENT_ID_INT AS SK_ADJUSTMENT_ID_INT ,\r\nN_OM.SS_CODE AS SS_CD,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER\r\nFROM \r\n(SELECT COALESCE(MAX(SM.AR_ADJUSTMENT_KEY),0) MAX_VAL \r\n FROM $$ETLVWDB.SM_AR_ADJUSTMENT_TRX SM) SMATKEY,\r\n$$FINLGLVWDB.N_AR_ADJUSTMENT_TRX N_OM\r\nWHERE NOT EXISTS (SELECT 1 FROM $$ETLVWDB.SM_AR_ADJUSTMENT_TRX SM_OM_I\r\nWHERE SM_OM_I.SK_ADJUSTMENT_ID_INT = N_OM.SK_ADJUSTMENT_ID_INT \r\nAND SM_OM_I.SS_CD = N_OM.SS_CODE)",
