      "attributes": {
        "Sql Query": "DROP TABLE EC_SR_IB_BASED;\r\nCREATE MULTISET VOLATILE TABLE EC_SR_IB_BASED AS\r\n(\r\nSELECT\r\nDISTINCT\r\nSRC_RPTD_SR_NUMBER_INT\r\n,CNTL.FISCAL_QUARTER_NAME\r\n,SR.FISCAL_YEAR_MONTH_INT,\r\nCOALESCE(PV.CURRENT_SERIAL_NUMBER,000000) AS BK_CUST_RPRTD_PRD_SERIAL_NUM\r\nFROM $$FINLGLVWDB.N_SR_TECH_ASSISTANCE_CNTR_COST SR\r\nINNER JOIN $$STGDB.WI_CCM_TS_MTH_QTR_CNTL CNTL\r\nON CNTL.FISCAL_YEAR_MONTH_INT = SR.FISCAL_YEAR_MONTH_INT\r\nINNER JOIN (SELECT DISTINCT INCIDENT_NUMBER,CURRENT_SERIAL_NUMBER FROM $$ETLONLYDB.EL_TSS_INCIDENTS_F_V\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY INCIDENT_NUMBER ORDER BY CLOSED_DATE DESC)=1)PV\r\nON PV.INCIDENT_NUMBER=CAST(SR.SRC_RPTD_SR_NUMBER_INT AS VARCHAR(50))\r\n) WITH DATA PRIMARY INDEX (SRC_RPTD_SR_NUMBER_INT ,FISCAL_QUARTER_NAME,BK_CUST_RPRTD_PRD_SERIAL_NUM) ON COMMIT PRESERVE ROWS;\r\n\r\nCOLLECT STATS ON EC_SR_IB_BASED COLUMN ( SRC_RPTD_SR_NUMBER_INT);\r\nCOLLECT STATS ON EC_SR_IB_BASED COLUMN ( FISCAL_YEAR_MONTH_INT);\r\nCOLLECT STATS ON EC_SR_IB_BASED COLUMN ( BK_CUST_RPRTD_PRD_SERIAL_NUM);\r\n\r\nDROP TABLE IB;\r\nCREATE MULTISET VOLATILE TABLE IB AS\r\n(\r\nSELECT\r\nDISTINCT\r\nDU_BK_SERIAL_NUM,INSTALLED_CUSTOMER_PARTY_KEY\r\nFROM\r\n$$IBVWDB.N_INSTALLED_PRODUCT WHERE DU_BK_SERIAL_NUM IN(SEL BK_CUST_RPRTD_PRD_SERIAL_NUM FROM EC_SR_IB_BASED GROUP BY 1)\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY DU_BK_SERIAL_NUM ORDER BY IP_KEY DESC)=1\r\n) WITH DATA PRIMARY INDEX (DU_BK_SERIAL_NUM ,INSTALLED_CUSTOMER_PARTY_KEY) ON COMMIT PRESERVE ROWS;\r\n\r\nCOLLECT STATS ON IB COLUMN ( DU_BK_SERIAL_NUM);\r\nCOLLECT STATS ON IB COLUMN ( INSTALLED_CUSTOMER_PARTY_KEY);\r\n\r\nSELECT\t\t\t\t\t\t\t\t\t\r\nCTRL.FISCAL_QUARTER_NAME\r\n,SR.FISCAL_YEAR_MONTH_INT\r\n,SR.SRC_RPTD_SR_NUMBER_INT\r\n,ENDCUST.GU_PRIMARY_NAME AS DV_END_CUSTOMER_NAME\r\n,ROW_NUMBER() OVER (PARTITION BY SR.SRC_RPTD_SR_NUMBER_INT ORDER BY ENDCUST.END_CUSTOMER_KEY DESC) SL_NUM\r\n,CAST(COUNT(ENDCUST.GU_PRIMARY_NAME) OVER (PARTITION BY SRC_RPTD_SR_NUMBER_INT,SR.FISCAL_YEAR_MONTH_INT) AS BIGINT )NO_OF_END_CUST\r\nFROM EC_SR_IB_BASED SR\t\t\t\t\t\t\t\t\t\r\nINNER JOIN IB IB \r\nON IB.DU_BK_SERIAL_NUM=SR.BK_CUST_RPRTD_PRD_SERIAL_NUM\r\nINNER JOIN $$COMREFVWDB.MT_ENDCUST_CUSTOMER_PARTY_HIER ENDCUST \r\nON ENDCUST.END_CUSTOMER_KEY=IB.INSTALLED_CUSTOMER_PARTY_KEY\r\nINNER JOIN  $$STGDB.WI_CCM_TS_MTH_QTR_CNTL CTRL\r\nON  CTRL.FISCAL_YEAR_MONTH_INT=SR.FISCAL_YEAR_MONTH_INT",
        "User Defined Join": "",
