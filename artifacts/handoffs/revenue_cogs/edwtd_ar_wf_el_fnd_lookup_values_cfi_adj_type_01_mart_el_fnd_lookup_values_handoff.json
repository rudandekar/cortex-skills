      "attributes": {
        "Sql Query": "SELECT \r\nST.LOOKUP_TYPE, \r\nST.LANG, \r\nST.SECURITY_GROUP_ID, \r\nST.LOOKUP_CODE, \r\nST.MEANING, \r\nST.VIEW_APPLICATION_ID, \r\nST.GLOBAL_NAME, \r\nST.ENABLED_FLAG, \r\nST.DESCRIPTION, \r\nST.CREATE_DATETIME, \r\nST.LAST_UPDATE_DATE as GES_UPDATE_DATE, \r\nST.START_DATE_ACTIVE, \r\nST.END_DATE_ACTIVE, \r\nST.ATTRIBUTE1, \r\nST.ATTRIBUTE2, \r\nST.ATTRIBUTE3, \r\nST.ATTRIBUTE4, \r\nST.ATTRIBUTE5 \r\nFROM\r\n  $$STGDB.ST_CG_FND_LOOKUP_VALUES_AR ST\r\nQUALIFY ROW_NUMBER() OVER( PARTITION BY LOOKUP_TYPE, LANG, SECURITY_GROUP_ID, LOOKUP_CODE, VIEW_APPLICATION_ID\r\n        ORDER BY LAST_UPDATE_DATE DESC)  =1\r\nWHERE ST.LANG = 'US'\r\nAND  ST.LOOKUP_TYPE='RMA RESERVE'\r\nAND NOT EXISTS\r\n (SELECT 1 FROM \r\n $$ETLVWDB.EL_FND_LOOKUP_VALUES ELFNDLKPVAL\r\n WHERE  ELFNDLKPVAL.LOOKUP_TYPE = ST.LOOKUP_TYPE \r\n AND    ELFNDLKPVAL.LANG =ST.LANG\r\n AND    ELFNDLKPVAL.SECURITY_GROUP_ID= ST.SECURITY_GROUP_ID\r\n AND    ELFNDLKPVAL.LOOKUP_CODE=ST.LOOKUP_CODE\r\n AND    ELFNDLKPVAL.VIEW_APPLICATION_ID=ST.VIEW_APPLICATION_ID\r\n AND    ELFNDLKPVAL.GLOBAL_NAME=ST.GLOBAL_NAME)",
        "User Defined Join": "",
