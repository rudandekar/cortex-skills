        "Sql Query": "SELECT\t\r\nWATR.BK_FINANCIAL_ACCOUNT_CD, \r\nWATR.BK_FISCAL_CALENDAR_CD, \r\nWATR.BK_START_FISCAL_YEAR_NUM_INT, \r\nWATR.BK_START_FISCAL_MONTH_NUM_INT, \r\nWATR.BK_CFI_THEATER_NAME, \r\nWATR.DISTRIBUTION_TYPE_CD, \r\nWATR.TWO_TIER_RULE_NAME,\r\nWATR.RESERVE_PERCENT_RT, \r\nWATR.SET_OF_BOOKS_KEY, \r\nWATR.OPERATING_UNIT_NAME_CD, \r\nWATR.END_FISCAL_YEAR_NUM_INT, \r\nWATR.END_FISCAL_MONTH_NUM_INT, \r\nWATR.SK_RULE_ID_INT, \r\nWATR.SS_CD, \r\nWATR.EDW_CREATE_DTM, \r\nWATR.EDW_CREATE_USER, \r\nWATR.EDW_UPDATE_DTM, \r\nWATR.EDW_UPDATE_USER \r\nFROM\t\r\n$$WORKDB.W_AR_TRX_2TIER_RULE WATR\r\nWHERE\tNOT EXISTS(\r\nSELECT\t1 \r\nFROM\t$$SLSORDVWDB.N_AR_TRX_2TIER_RULE NATR\r\nWHERE\tNATR.BK_CFI_THEATER_NAME= WATR.BK_CFI_THEATER_NAME  \r\n\tAND\t      \r\nNATR.BK_FINANCIAL_ACCOUNT_CD=WATR.BK_FINANCIAL_ACCOUNT_CD \r\n\tAND\t       \r\nNATR.BK_FISCAL_CALENDAR_CD=WATR.BK_FISCAL_CALENDAR_CD \r\n\tAND\t        \r\nNATR.BK_START_FISCAL_MONTH_NUM_INT=WATR.BK_START_FISCAL_MONTH_NUM_INT \r\n\tAND\t\r\nNATR.BK_START_FISCAL_YEAR_NUM_INT=WATR.BK_START_FISCAL_YEAR_NUM_INT)",
