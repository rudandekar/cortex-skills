      "attributes": {
        "Sql Query": "SELECT\r\nATTR_BUNDLE_SPLIT.HANDSHAKE_BUNDLE_PRODUCT_KEY ,\r\nATTR_BUNDLE_SPLIT.BK_HANDSHAKE_BUNDLE_TYPE_NAME ,\r\nFISC.FISCAL_YEAR_MONTH_INT  FISCAL_YEAR_MONTH_NUM_INT,\r\nCOALESCE (cast(ATTR_BUNDLE_SPLIT.BOOKINGS_REVENUE_SPLIT_PCT as decimal(18,6))/100,1)      BOOKINGS_REVENUE_SPLIT_PCT,\r\nCOALESCE( cast(ATTR_BUNDLE_SPLIT.COGS_SPLIT_PCT as decimal(18,6))/100,1)                COGS_SPLIT_PCT,\r\nDRV.ITEM_KEY AS PRE_ITEM_KEY  ,\r\nCASE WHEN\r\nATTR_BUNDLE_SPLIT.HANDSHAKE_BUNDLE_PRODUCT_KEY IS NULL\r\nTHEN  DRV.PRODUCT_FAMILY_ID\r\nELSE ATTR_BUNDLE_SPLIT.PRODUCT_FAMILY_IDP  END POST_PRODUCT_FAMILY_ID,\r\nDRV.PRODUCT_FAMILY_ID   AS SOURCE_PRODUCT_FAMILY_ID ,          \r\nCASE WHEN\r\nATTR_BUNDLE_SPLIT.HANDSHAKE_BUNDLE_PRODUCT_KEY IS NULL\r\nTHEN  DRV.ITEM_KEY\r\nELSE ATTR_BUNDLE_SPLIT.ITEM_KEYP  END POST_ITEM_KEY,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER ,              \r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM ,\r\nUSER EDW_UPDATE_USER              \r\nFROM\r\n(SELECT\r\nITEM_KEY ,\r\nRU_BK_PRODUCT_FAMILY_ID AS PRODUCT_FAMILY_ID             \r\nFROM $$COMREFVWDB.R_PRODUCTS_FIN RFIN\r\nINNER JOIN $$COMREFVWDB.R_TRX_PRODUCT  RTRX\r\nON (RFIN.ITEM_KEY=RTRX.PRODUCT_KEY)\r\n)DRV\r\nLEFT OUTER JOIN\r\n(\r\nSELECT\r\nBUNPRD.HANDSHAKE_BUNDLE_PRODUCT_KEY  ,\r\nBUNPRD.BK_HANDSHAKE_BUNDLE_TYPE_NAME    ,\r\nSPLT.DV_FISCAL_YEAR_MONTH_NUM_INT ,\r\nPRD.RU_BK_PRODUCT_FAMILY_ID AS PRODUCT_FAMILY_ID             ,\r\nPRD.ITEM_KEY       ,\r\nPRD1.BK_PRODUCT_ID AS PRODUCT_ID   ,\r\nPRD1.ITEM_KEY ITEM_KEYP,\r\nPRD1.RU_BK_PRODUCT_FAMILY_ID          PRODUCT_FAMILY_IDP   ,\r\nSPLT.BOOKINGS_REVENUE_SPLIT_PCT    ,\r\nSPLT.COGS_SPLIT_PCT \r\nFROM $$INVFLMTVWDB.N_HNDSHK_BNDL_TYP_FMLY_SPLT SPLT\r\nINNER JOIN $$INVFLMTVWDB.N_HNDSHK_BUNDLE_PRODUCT  BUNPRD\r\nON SPLT.BK_HANDSHAKE_BUNDLE_TYPE_NAME =BUNPRD.BK_HANDSHAKE_BUNDLE_TYPE_NAME\r\nINNER JOIN (SEL RFIN.*, RTRX.PRODUCT_KEY FROM $$COMREFVWDB.R_PRODUCTS_FIN RFIN\r\nINNER JOIN $$COMREFVWDB.R_TRX_PRODUCT RTRX  ON (RFIN.ITEM_KEY=RTRX.PRODUCT_KEY)) PRD\r\nON BUNPRD.HANDSHAKE_BUNDLE_PRODUCT_KEY  =PRD.ITEM_KEY\r\nINNER JOIN (SEL RFIN.*, RTRX.PRODUCT_KEY FROM $$COMREFVWDB.R_PRODUCTS_FIN RFIN\r\nINNER JOIN $$COMREFVWDB.R_TRX_PRODUCT  RTRX ON (RFIN.ITEM_KEY=RTRX.PRODUCT_KEY)) PRD1\r\nON TRIM(SPLT.BK_PRODUCT_FAMILY_ID)||'_ADJ_PROD'=PRD1.BK_PRODUCT_ID\r\nWHERE SPLT.BK_ALLOCATION_TYPE_CD ='FORECAST'\r\nAND BUNPRD.BK_ALLOCATION_TYPE_CD ='FORECAST'\r\n) ATTR_BUNDLE_SPLIT\r\nON (DRV.ITEM_KEY =ATTR_BUNDLE_SPLIT.HANDSHAKE_BUNDLE_PRODUCT_KEY),\r\n(SEL * FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR FISYM\r\nWHERE CURRENT_FISCAL_MONTH_FLAG ='Y') FISC",
        "User Defined Join": "",
        "Source Filter": "",
