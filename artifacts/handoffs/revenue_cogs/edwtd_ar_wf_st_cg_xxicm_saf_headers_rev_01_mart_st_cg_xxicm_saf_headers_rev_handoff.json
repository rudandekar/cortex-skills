      "attributes": {
        "Sql Query": "SELECT 1 AS BATCH_ID,SAF_HEADER_ID, SAF_ID, SAF_TYPE, SAF_REASON, SAF_DATE, SAF_STATUS, SAF_AMOUNT, SPECIAL_REQUEST, EMAIL_ADDRESS, INITIATOR_ROLE_ID, INITIATOR_GROUP_ID, COLLECTOR_ID, COMMENTS, ITEM_KEY, CASH_RECEIPT_ID, ALERT_STATUS, ORG_ID, FUNC_SAF_AMOUNT, FUNC_CURRENCY_CODE, TRAN_CURRENCY_CODE, EXCHANGE_RATE_TYPE, EXCHANGE_RATE, EXCHANGE_DATE, CREATED_BY, CREATION_DATE, LAST_UPDATED_BY, LAST_UPDATE_DATE, LAST_UPDATE_LOGIN, SOURCE_COMMIT_TIME\r\n , 'CG'AS GLOBAL_NAME  \r\n ,CURRENT_TIMESTAMP(0)  AS CREATE_DATETIME               \r\n ,'I' as ACTION_CODE\r\n ,D_ATTRIBUTE1 ,\r\n N_ATTRIBUTE1,\r\n D_ATTRIBUTE2,\r\n C_ATTRIBUTE8 /*ADDED AS PART OF ACCRUED REBATES Q1FY20*/\r\n FROM\r\n (\r\n SELECT * FROM $$NRTACCUMVWDB.CG1_XXICM_SAF_HEADERS_ALL\r\n WHERE \r\n ORG_ID NOT IN (SELECT ORG_ID FROM $$ETLVWDB.EL_CG1_ENABLED_ORG)\r\n /*AND D_ATTRIBUTE2 IS NOT NULL  \r\n AND N_ATTRIBUTE1 IS NOT NULL*/ /*COMMENTING HERE AND WILL ADD AT W_AR_CMDM_ADJ_REQUEST :ACCRUED REBATES Q1FY20*/\r\n AND SOURCE_COMMIT_TIME >= '$$LastExtractDate' QUALIFY ROW_NUMBER () OVER (PARTITION BY SAF_HEADER_ID ORDER BY REFRESH_DATETIME DESC)=1\r\n ) CG1_XXICM_SAF_HEADERS_ALL\r\n WHERE CG1_XXICM_SAF_HEADERS_ALL.SOURCE_DML_TYPE <> 'DELETE'",
