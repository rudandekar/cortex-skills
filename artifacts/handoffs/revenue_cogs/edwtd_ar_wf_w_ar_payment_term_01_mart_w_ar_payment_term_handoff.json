      "attributes": {
        "Sql Query": "SELECT \r\nBK_AR_PAYMENT_TERM_NAME,\r\nAR_PAYMENT_TERM_DESCR, \r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'=' ACTION_CODE,\r\n'=' DML_TYPE \r\nFROM\r\n(\r\n\tSELECT\r\n\tNAME AS BK_AR_PAYMENT_TERM_NAME,\r\n\tDESCRIPTION AS AR_PAYMENT_TERM_DESCR, \r\n\t1 AS PRIORITY_CODE\r\n\tFROM $$STGDB.ST_CG_AR_PYMNT_TERM SOAPT\r\n\tINNER JOIN $$ETLVWDB.EL_AR_PAYMENT_TERM  EAPT \r\n\t\tON  EAPT.SK_PAYMENT_TERM_ID=SOAPT.TERM_ID \r\n\t\tAND EAPT.GLOBAL_NAME=SOAPT.GLOBAL_NAME\r\n\r\n\tUNION\r\n\tSELECT\r\n\tNAME AS BK_AR_PAYMENT_TERM_NAME,\r\n\tDESCRIPTION AS AR_PAYMENT_TERM_DESCR, \r\n\tCASE WHEN SOAPT.GLOBAL_NAME ='UO' THEN 2\r\n\t\t ELSE 3\r\n\tEND AS PRIORITY_CODE\r\n\tFROM $$STGDB.ST_OM_AR_PYMNT_TERM_REV SOAPT\r\n\tINNER JOIN $$ETLVWDB.EL_AR_PAYMENT_TERM EAPT \r\n\t\tON EAPT.SK_PAYMENT_TERM_ID=SOAPT.TERM_ID \r\n\t\tAND EAPT.GLOBAL_NAME=SOAPT.GLOBAL_NAME\r\n\r\n) TMP_VW\r\n\r\nQUALIFY ROW_NUMBER () OVER(PARTITION BY TMP_VW.BK_AR_PAYMENT_TERM_NAME ORDER BY TMP_VW.PRIORITY_CODE)=1",
