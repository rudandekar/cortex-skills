      "attributes": {
        "Sql Query": "SELECT \r\nNACRD.AR_CASH_RECEIPT_TRX_DETAIL_KEY CM_ADJUSTMENT_KEY,\r\nNSOB.FUNCTIONAL_CURRENCY_CODE\t\tFUNCTIONAL_CURRENCY_CODE,\r\nNGLA.BK_FINANCIAL_ACCOUNT_CODE\t\tBK_FINANCIAL_ACCOUNT_CODE,\r\n(CASE WHEN NAT.BILL_TO_CUSTOMER_KEY IS NULL  THEN RANDOM(1000000,1001800)*-1 ELSE NAT.BILL_TO_CUSTOMER_KEY END) as BILL_TO_CUSTOMER_KEY,  \r\nNAT.BK_AR_TRX_NUMBER\t\t\tBK_AR_TRX_NUM,\r\nCOALESCE(NAT.RU_CUST_PURCHASE_ORDER_NUMBER,'UNKNOWN') AS RU_CUST_PURCHASE_ORDER_NUM,\r\n'UNKNOWN' as\tAR_TYPE_CD,\t\t\r\n(( NACRD.RU_ERND_DISC_TAKEN_TRXL_CR_AMT) + (NACRD.RU_ERND_DISC_TAKEN_TRXL_DR_AMT*-1)) * COALESCE(NCCDR_FUNC.PL_CONVERSION_RATE, 1)*-1\tDV_AR_ADJ_TRX_FUNCTIONAL_AMT,\r\n(\r\nCASE WHEN ( BK_FINANCIAL_ACCOUNT_CODE = '11560' AND NACR.BK_SET_OF_BOOKS_KEY = 500 AND NACR.BK_COMPANY_CD ='020' )  THEN \r\n((( NACRD.RU_ERND_DISC_TAKEN_TRXL_CR_AMT) + (NACRD.RU_ERND_DISC_TAKEN_TRXL_DR_AMT*-1)) * COALESCE(NCCDR_USD.PL_CONVERSION_RATE, 1) )*-1\r\nELSE ((( NACRD.RU_ERND_DISC_TAKEN_TRXL_CR_AMT) + (NACRD.RU_ERND_DISC_TAKEN_TRXL_DR_AMT*-1)) * COALESCE(NCCDR_USD.PL_CONVERSION_RATE, 1) )\r\nEND \r\n)\t\t\t\t\tDV_AR_ADJ_TRX_USD_AMT,\r\nCAST (NACRD.GL_DTM AS DATE)\t\tGL_DT,                       \r\nNACRD.GL_POSTED_DT\t\t\tGL_POSTED_DT,\r\nCOALESCE(NAT.AR_TRX_REASON_CODE,'UNKNOWN') AS \tAR_ADJ_TRX_REASON_CD,\r\n'UNKNOWN'\t\tVENDOR_NAME,\r\nBK_OPERATING_UNIT_NAME_CODE\t\tOPERATING_UNIT_NAME_CD,\r\n'TRD_RECPTS'\t\t\t\tCUST_TRX_TYPE_CATEGORY_CD ,\r\nNFM.BK_FISCAL_YEAR_NUMBER_INT*100 + NFM.BK_FISCAL_MONTH_NUMBER_INT\tFISCAL_YEAR_MONTH_NUM_INT,\r\nNACR.BK_COMPANY_CD,\r\nNACR.BK_SET_OF_BOOKS_KEY,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) as EDW_CREATE_DATETIME,\r\nUSER as EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) as EDW_UPDATE_DATETIME,\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM\r\n$$FINLGLVWDB.N_AR_CASH_RECEIPT_TRX_DETAIL NACRD\r\nINNER JOIN $$COMREFVWDB.N_FISCAL_MONTH NFM\r\n\tON ( CAST(NACRD.GL_DTM  AS DATE) BETWEEN FISCAL_MONTH_START_DATE AND FISCAL_MONTH_END_DATE ) \r\nINNER JOIN $$FINLGLVWDB.N_AR_CASH_RECEIPT NACR\r\n\tON ( NACR.AR_CASH_RECEIPT_KEY     = NACRD.AR_CASH_RECEIPT_KEY  )\r\nINNER   JOIN $$FINLGLVWDB.N_AR_TRX NAT\r\n\tON ( NACRD.RU_APPLIED_AR_TRX_KEY = NAT.AR_TRX_KEY )\r\nINNER  JOIN   $$FINLGLVWDB.N_GENERAL_LEDGER_ACCOUNT NGLA\r\n\tON ( NACRD.RU_EARNED_DISC_GL_ACCOUNT_KEY               = NGLA.GENERAL_LEDGER_ACCOUNT_KEY )\r\nINNER JOIN $$FINLGLVWDB.N_SET_OF_BOOKS NSOB\r\n \tON ( NACR.BK_SET_OF_BOOKS_KEY   = NSOB.SET_OF_BOOKS_KEY\t)\r\nINNER JOIN $$ETLVWDB.EV_OP_UNIT_GAAP_COMPANY EOUGC\r\n\tON (EOUGC.BK_COMPANY_CODE = NACR.BK_COMPANY_CD\r\n\tAND EOUGC.SET_OF_BOOKS_KEY = NACR.BK_SET_OF_BOOKS_KEY   )\r\nLEFT OUTER  JOIN $$FINLGLVWDB.N_CURRENCY_CONV_DAILY_RATE NCCDR_USD\r\n\tON ( NCCDR_USD.BK_FROM_CURRENCY_CODE = BK_TRANSACTIONAL_CURRENCY_CD  \r\n\tAND NCCDR_USD.BK_TO_CURRENCY_CODE = 'USD'\r\n\tAND NCCDR_USD.BK_CONVERSION_DATE = CAST(NACRD.GL_DTM  AS DATE) )\r\nLEFT OUTER  JOIN $$FINLGLVWDB.N_CURRENCY_CONV_DAILY_RATE NCCDR_FUNC\r\n\tON ( NCCDR_FUNC.BK_FROM_CURRENCY_CODE = BK_TRANSACTIONAL_CURRENCY_CD  \r\n\tAND NCCDR_FUNC.BK_TO_CURRENCY_CODE = FUNCTIONAL_CURRENCY_CODE\r\n\tAND NCCDR_FUNC.BK_CONVERSION_DATE = CAST(NACRD.GL_DTM  AS DATE) )\r\nWHERE \r\n NACRD.GL_POSTED_DT                   IS NOT NULL\r\nAND (( NACRD.RU_ERND_DISC_TAKEN_TRXL_CR_AMT) + (NACRD.RU_ERND_DISC_TAKEN_TRXL_DR_AMT*-1)) <>0\r\nAND BK_FINANCIAL_ACCOUNT_CODE      IN('11575','11596','11597','11598','11599','11560','11561')\r\nAND NACRD.EDW_UPDATE_DTM > ( SELECT LAST_EXTRACT_DATE \r\nFROM $$ETLVWDB.DW_JOB_STREAMS\r\nWHERE JOB_STREAM_ID = 'wf_WK_CM_ADJUSTMENT_CSHRCPT_DTL')",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
  ],
