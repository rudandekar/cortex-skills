      "attributes": {
        "Sql Query": "SELECT CBCD.CALENDAR_CODE, \r\n CBCD.EXCEPTION_SET_ID, \r\n CBCD.CALENDAR_DATE, \r\n CBCD.LAST_UPDATED_BY, \r\n CBCD.CREATION_DATE, \r\n CBCD.CREATED_BY, \r\n CBCD.LAST_UPDATE_LOGIN, \r\n CBCD.LAST_UPDATE_DATE,\r\n CBCD.SEQ_NUM, \r\n CBCD.NEXT_SEQ_NUM, \r\n CBCD.PRIOR_SEQ_NUM, \r\n CBCD.NEXT_DATE, \r\n CBCD.PRIOR_DATE, \r\n CBCD.REQUEST_ID, \r\n CBCD.PROGRAM_APPLICATION_ID, \r\n CBCD.PROGRAM_ID, \r\n CBCD.PROGRAM_UPDATE_DATE, \r\n $$BatchId AS BATCH_ID, \r\n'I' AS ACTION_CODE, \r\n 'CG' AS GLOBAL_NAME,  \r\nCURRENT_TIMESTAMP(0) AS CREATE_DATETIME , \r\n CBCD.SOURCE_COMMIT_TIME, \r\n CBCD.REFRESH_DATETIME \r\nFROM\r\n $$NRTACCUMVWDB.CG1_BOM_CALENDAR_DATES CBCD\r\n where\r\nSOURCE_COMMIT_TIME > '$$LastExtractDate'\r\nAND SOURCE_DML_TYPE IN ( 'SQL COMPUPDATE','INSERT')\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY CALENDAR_DATE, CALENDAR_CODE, EXCEPTION_SET_ID ORDER BY REFRESH_DATETIME DESC)=1",
