      "attributes": {
        "Sql Query": "SELECT TMP.DELIVERY_ASSIGNMENT_ID, TMP.DELIVERY_DETAIL_ID, TMP.CREATION_DATE, TMP.CREATED_BY, TMP.LAST_UPDATE_DATE, TMP.LAST_UPDATED_BY, TMP.DELIVERY_ID, TMP.PARENT_DELIVERY_ID, TMP.PARENT_DELIVERY_DETAIL_ID, TMP.LAST_UPDATE_LOGIN, TMP.PROGRAM_APPLICATION_ID, TMP.PROGRAM_ID, TMP.PROGRAM_UPDATE_DATE, TMP.REQUEST_ID, TMP.ACTIVE_FLAG, TMP.WDA_TYPE, \r\nTMP.SOURCE_DML_TYPE, TMP.SOURCE_COMMIT_TIME, 'CG' AS GLOBAL_NAME, TMP.REFRESH_DATETIME  FROM\r\n(SELECT DELIVERY_ASSIGNMENT_ID, DELIVERY_DETAIL_ID, CREATION_DATE, CREATED_BY, LAST_UPDATE_DATE, LAST_UPDATED_BY, DELIVERY_ID, PARENT_DELIVERY_ID, PARENT_DELIVERY_DETAIL_ID, LAST_UPDATE_LOGIN, PROGRAM_APPLICATION_ID, PROGRAM_ID, PROGRAM_UPDATE_DATE, REQUEST_ID, ACTIVE_FLAG, WDA_TYPE, \r\nSOURCE_DML_TYPE, SOURCE_COMMIT_TIME,  REFRESH_DATETIME \r\nFROM $$NRTACCUMVWDB.CG1_WSH_DELIVERY_ASSIGNM  \r\nWHERE  SOURCE_COMMIT_TIME > '$$LastExtractDate' \r\nAND SOURCE_COMMIT_TIME <=  '$$EndLastExtractDate'\r\nAND SOURCE_DML_TYPE<>'DELETE')TMP\r\nQUALIFY RANK () OVER (PARTITION BY TMP.DELIVERY_ASSIGNMENT_ID ORDER BY TMP.DELIVERY_ASSIGNMENT_ID, TMP.REFRESH_DATETIME DESC ) = 1",
        "User Defined Join": "",
