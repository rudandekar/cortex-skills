      "attributes": {
        "Sql Query": "SELECT\t\r\nFISCAL.BK_FISCAL_CALENDAR_CODE  BK_FISCAL_CALENDAR_CD,    \r\nFISCAL.BK_FISCAL_YEAR_NUMBER_INT  ,\r\nFISCAL.BK_FISCAL_MONTH_NUMBER_INT     ,\r\nACCNT.BK_FINANCIAL_ACCOUNT_CODE ,\r\nDEPT.BK_DEPARTMENT_CODE, \r\nDEPT.BK_COMPANY_CODE, \r\nST.SALES_TERRITORY_KEY   BK_SALES_TERRITORY_KEY,\r\nIRCAT.BK_ADJUSTMENT_TYPE_CD         ,\r\nIRCAT.BK_REVENUE_OR_COGS_TYPE_CD    ,\r\nSTG.ALLOCATION_TYPE BK_ADV_SRVCS_CGS_TRGLN_TYPE_CD,\r\nSUM(ZEROIFNULL(STG.AMOUNT)) ADVANCED_SERVICES_COGS_USD_AMT,   \r\n( FISCAL.BK_FISCAL_YEAR_NUMBER_INT * 100 ) +FISCAL.BK_FISCAL_MONTH_NUMBER_INT DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\nSTG.ALLOCATION_METHOD,\r\n'I' ACTION_CODE,\r\n'I' DML_TYPE,\r\nCASE \r\n\tWHEN IRCAT.BK_ADJUSTMENT_TYPE_CD ='AS COGS AE SYSTEM ALLOCATION' \r\n\tAND RPT.BK_PNL_MEASURE_NAME ='Cloud and Managed Services' THEN 11969520 \r\n     WHEN IRCAT.BK_ADJUSTMENT_TYPE_CD <>'AS COGS AE SYSTEM ALLOCATION' \r\n\tAND IRCAT.BK_ADJUSTMENT_TYPE_CD ='Cloud and Managed Services' THEN 11969520 \r\n               ELSE 5970786 \r\nEND\tDV_GOODS_PRDT_KEY,\r\nSTG.BK_AS_PROJECT_CD\r\nFROM $$STGDB.ST_AE_ASCOGS_ALLOCATION_PUB STG\r\nINNER JOIN $$COMREFVWDB.N_FISCAL_MONTH  FISCAL  \r\n\tON ( FISCAL.BK_FISCAL_YEAR_NUMBER_INT * 100 + FISCAL.BK_FISCAL_MONTH_NUMBER_INT ) = STG.FISCAL_MONTH_ID\r\nINNER JOIN $$FINLGLVWDB.N_FINANCIAL_ACCOUNT ACCNT  \r\n\tON ACCNT.BK_FINANCIAL_ACCOUNT_CODE = STG.ACCOUNT_CODE\r\nINNER JOIN  $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT DEPT  \r\n\tON DEPT.BK_COMPANY_CODE  = SUBSTR(STG.DEPT_NUMBER, 1, 3 )  \r\n\tAND DEPT.BK_DEPARTMENT_CODE = SUBSTR(STG.DEPT_NUMBER,4 )  \r\nINNER JOIN $$COMREFVWDB.N_SALES_TERRITORY ST  \r\n\tON ST.BK_SALES_TERRITORY_NAME_CODE  =  STG.SALES_TERRITORY_CODE\r\nINNER JOIN $$FINLGLVWDB.N_INDRCT_REV_COGS_ADJ_TYPE IRCAT  \r\n\tON IRCAT.SK_ADJUSTMENT_TYPE_ID_INT = STG.SUB_MEASURE_KEY\r\nLEFT JOIN $$FINLGLVWDB.N_APSP_PNL_ASCOGS_DPT_ACCT_MPG RPT   \r\n\tON \r\nDEPT.BK_COMPANY_CODE||DEPT.BK_DEPARTMENT_CODE = RPT.BK_COMPANY_CODE||RPT.BK_DEPARTMENT_CD\r\nGROUP BY \r\nFISCAL.BK_FISCAL_CALENDAR_CODE         ,    \r\nFISCAL.BK_FISCAL_YEAR_NUMBER_INT  ,\r\nFISCAL.BK_FISCAL_MONTH_NUMBER_INT     ,\r\nACCNT.BK_FINANCIAL_ACCOUNT_CODE ,\r\nDEPT.BK_DEPARTMENT_CODE, \r\nDEPT.BK_COMPANY_CODE, \r\nST.SALES_TERRITORY_KEY   ,\r\nIRCAT.BK_ADJUSTMENT_TYPE_CD         ,\r\nIRCAT.BK_REVENUE_OR_COGS_TYPE_CD    ,\r\nSTG.ALLOCATION_TYPE ,\r\nDV_FISCAL_YEAR_MTH_NUMBER_INT ,\r\nSTG.ALLOCATION_METHOD,\r\nDV_GOODS_PRDT_KEY,\r\nSTG.BK_AS_PROJECT_CD",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
