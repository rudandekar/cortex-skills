      "attributes": {
        "Sql Query": "SELECT\t\r\nTMP.BK_FISCAL_YEAR_MTH_NUMBER_INT \r\n,TMP.BK_SALES_TERRITORY_KEY     \r\n,TMP.BK_TRNGLTD_SALES_TERRITORY_KEY\r\n,TMP.RECORD_TYPE\r\n,SH.L1_SALES_TERRITORY_NAME_CODE\r\n,SH.L2_SALES_TERRITORY_NAME_CODE\r\n,SH.L3_SALES_TERRITORY_NAME_CODE\r\n,SH.L1_SALES_TERRITORY_DESCR \r\n,SH.L2_SALES_TERRITORY_DESCR \r\n,SH.L3_SALES_TERRITORY_DESCR \r\n,TMP.ISO_COUNTRY_NAME              \r\n,TMP.ISO_COUNTRY_CODE              \r\n,TMP.EXT_THEATER_NAME              \r\n,TMP.EXTERNAL_GEO                  \r\n,TMP.INTERNAL_GEO                  \r\n,TMP.SFH_THEATER                   \r\n,TMP.SFH_SUB_THEATER               \r\n,TMP.SUBSALES_NAME                 \r\n,TMP.SALES_COVERAGE_CODE\r\n,TMP.TOTAL_REV\r\n,TMP.COMP_US_NET_REV_AMT AS ATTR_REV\r\n,TMP.COMP_US_NET_REV_AMT/TMP.TOTAL_REV AS ATTR_ALLOC_PCT\r\nFROM\t\r\n(\r\nSELECT\tDISTINCT\r\nBK_FISCAL_YEAR_MTH_NUMBER_INT \r\n,BK_SALES_TERRITORY_KEY     \r\n,BK_TRNGLTD_SALES_TERRITORY_KEY\r\n,RECORD_TYPE  \r\n,SALES_TERRITORY_KEY           \r\n,ISO_COUNTRY_NAME              \r\n,ISO_COUNTRY_CODE              \r\n,EXT_THEATER_NAME              \r\n,EXTERNAL_GEO                  \r\n,INTERNAL_GEO                  \r\n,SFH_THEATER                   \r\n,SFH_SUB_THEATER               \r\n,SUBSALES_NAME                 \r\n,SALES_COVERAGE_CODE                 \r\n,COMP_US_NET_REV_AMT\r\n,COALESCE(NULLIFZERO(SUM(COMP_US_NET_REV_AMT) OVER (PARTITION BY BK_FISCAL_YEAR_MTH_NUMBER_INT,\r\n\t\tBK_SALES_TERRITORY_KEY,RECORD_TYPE)),1) TOTAL_REV\r\nFROM\t $$STGDB.WI_AE_DISTI_L3) TMP\r\nINNER JOIN $$COMREFVWDB.$$MAP_TGT_VAR1  SH\r\n\tON\tSH.SALES_TERRITORY_KEY=TMP.SALES_TERRITORY_KEY",
        "User Defined Join": "",
