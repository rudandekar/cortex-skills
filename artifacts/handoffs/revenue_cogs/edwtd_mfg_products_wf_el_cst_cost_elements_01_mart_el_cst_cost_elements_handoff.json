      "attributes": {
        "Sql Query": "SELECT COST_ELEMENT_ID, LAST_UPDATE_DATE, LAST_UPDATED_BY, CREATION_DATE, CREATED_BY, LAST_UPDATE_LOGIN, COST_ELEMENT, DESCRIPTION, REQUEST_ID, PROGRAM_APPLICATION_ID,\r\nPROGRAM_ID, PROGRAM_UPDATE_DATE, GLOBAL_NAME, GES_UPDATE_DATE, BATCH_ID, CREATE_DATETIME, ACTION_CODE \r\nFROM \r\n(SELECT SCCCE.COST_ELEMENT_ID, SCCCE.LAST_UPDATE_DATE, SCCCE.LAST_UPDATED_BY, SCCCE.CREATION_DATE, SCCCE.CREATED_BY, SCCCE.LAST_UPDATE_LOGIN, SCCCE.COST_ELEMENT, SCCCE.DESCRIPTION, SCCCE.REQUEST_ID, SCCCE.PROGRAM_APPLICATION_ID, \r\nSCCCE.PROGRAM_ID, SCCCE.PROGRAM_UPDATE_DATE, SCCCE.GLOBAL_NAME, SCCCE.GES_UPDATE_DATE, SCCCE.BATCH_ID, SCCCE.CREATE_DATETIME, SCCCE.ACTION_CODE \r\nFROM\r\n$$STGDB.ST_CG1_CST_COST_ELEMENTS SCCCE \r\nunion all\r\nSELECT SMCCE.COST_ELEMENT_ID, SMCCE.LAST_UPDATE_DATE, SMCCE.LAST_UPDATED_BY, SMCCE.CREATION_DATE, SMCCE.CREATED_BY, SMCCE.LAST_UPDATE_LOGIN, SMCCE.COST_ELEMENT, SMCCE.DESCRIPTION, SMCCE.REQUEST_ID, SMCCE.PROGRAM_APPLICATION_ID, SMCCE.PROGRAM_ID, SMCCE.PROGRAM_UPDATE_DATE, SMCCE.GLOBAL_NAME, SMCCE.GES_UPDATE_DATE, SMCCE.BATCH_ID, SMCCE.CREATE_DATETIME, SMCCE.ACTION_CODE \r\nFROM\r\n$$STGDB.ST_MF_CST_COST_ELEMENTS SMCCE ) CCE\r\nWHERE (CCE.COST_ELEMENT_ID,CCE.GLOBAL_NAME) NOT IN (SELECT ECCE.COST_ELEMENT_ID,GLOBAL_NAME  FROM $$ETLONLYDB.EL_CST_COST_ELEMENTS ECCE)",
