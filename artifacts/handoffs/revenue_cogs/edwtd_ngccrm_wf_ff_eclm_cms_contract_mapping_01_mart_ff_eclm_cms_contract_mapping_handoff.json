      "attributes": {
        "Sql Query": "SELECT \r\n  TO_NUMBER(ECBMV.ECLM_CONTRACT_NUMBER),   \r\n  TO_NUMBER(ECBMV.CMS_CONTRACT_NUMBER), \r\n  TO_NUMBER(ECBMV.CMS_VERSION), \r\n  TO_NUMBER(EBCDV.RELATED_CONTRACT_NUMBER), \r\n  EBCDV.RELATIONSHIP, \r\n  EBCDV.CONTRACT_NEGOTIATOR, \r\n  EBCDV.ECLM_CONTRACT_STATUS, \r\n  EBCDV.EFFECTIVE_START_DATE, \r\n  EBCDV.EXPIRATION_DATE, \r\n  EBCDV.UPDATED_DATE \r\nFROM  ECLM_CMS_BIDS_MAPPING_VW  ECBMV\r\nINNER JOIN ECLM_BIDS_CONTRACT_DATA_VW EBCDV ON\r\nEBCDV.ECLM_CONTRACT_NUMBER = ECBMV.ECLM_CONTRACT_NUMBER\r\nWHERE  EBCDV.UPDATED_DATE > TO_DATE('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS')",
