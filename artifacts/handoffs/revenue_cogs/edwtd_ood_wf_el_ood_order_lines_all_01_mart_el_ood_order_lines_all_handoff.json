      "attributes": {
        "Sql Query": "SELECT\r\nCAST(LINE_ID AS BIGINT),\r\nCAST(LINE_NUMBER AS DECIMAL(27,6)),\r\nCAST(ORDERED_ITEM AS VARCHAR(50)),\r\nCAST(ORIG_SYS_DOCUMENT_REF AS VARCHAR(50)),\r\nCAST(ORIG_SYS_LINE_REF AS VARCHAR(50)),\r\nCREATION_DATE,\r\nLAST_UPDATE_DATE,\r\nACTION_CODE,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_UPDATE_DTM,\r\n'CG' AS SS_CODE,\r\nCAST('OOD' AS VARCHAR(10)) AS IDENTIFIER\r\nFROM $$STGDB.ST_OOD_ORDER_LINES_ALL SOAPT WHERE NOT EXISTS (SELECT 1 FROM $$ETLVWDB.EL_OOD_ORDER_LINES_ALL EAPT \r\nWHERE SOAPT.LINE_ID = EAPT.LINE_ID)\r\n\r\nUNION ALL\r\n\r\nSELECT\r\nLINE_ID,\r\nLINE_NUMBER,\r\nORDERED_ITEM,\r\nORIG_SYS_DOCUMENT_REF,\r\nORIG_SYS_LINE_REF,\r\nCREATION_DATE,\r\nLAST_UPDATE_DATE,\r\nACTION_CODE,\r\nCAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) EDW_UPDATE_DTM,\r\n'CG' AS SS_CODE,\r\n'FUSN' AS IDENTIFIER\r\nFROM $$STGDB.ST_OOD_FUSN_ORDER_LINES_ALL SOFAPT WHERE NOT EXISTS (SELECT 1 FROM $$ETLVWDB.EL_OOD_ORDER_LINES_ALL EAPT \r\nWHERE SOFAPT.LINE_ID = EAPT.LINE_ID)",
