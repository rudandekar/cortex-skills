      "attributes": {
        "Sql Query": "SELECT\r\nWISM.APSP_MBR_SLS_ADJSTMT_FORM_KEY\r\n,WISM.DV_SAF_USD_AMT\r\n,WISM.SK_CUST_TRX_ID_LINT\r\n,WISM.SALES_ORDER_KEY\r\n,WISM.PURCHASE_ORDER_KEY\r\n,WISM.SALES_TERRITORY_KEY\r\n,WISM.ERP_CUST_ACCT_LOC_USE_KEY\r\n,WISM.ITEM_KEY\r\n,WISM.SK_SAF_ID_INT\r\n,WISM.EDW_CREATE_DTM\r\n,WISM.EDW_CREATE_USER\r\n,WISM.EDW_UPDATE_DTM\r\n,WISM.EDW_UPDATE_USER\r\nFROM\r\n$$STGDB.WI_SM_APSP_MBR WISM\r\nWHERE WISM.SAF_TYPE  IN ( 'SPECIAL_DEBIT','SPECIAL_INVOICE','SPECIAL_CREDIT','CASH_APPLICATION','WRITE_OFF')",
