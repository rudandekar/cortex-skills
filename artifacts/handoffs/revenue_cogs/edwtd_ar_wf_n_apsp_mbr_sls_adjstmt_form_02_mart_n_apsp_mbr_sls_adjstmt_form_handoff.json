      ],
      "attributes": {
        "Sql Query": "SELECT\r\nrow_number() over(order by SK_SAF_ID_INT, SK_CUST_TRX_ID_LINT, SALES_ORDER_KEY, PURCHASE_ORDER_KEY, SALES_TERRITORY_KEY, ERP_CUST_ACCT_LOC_USE_KEY desc) APSP_MBR_SLS_ADJSTMT_FORM_KEY,\r\nU.SAF_AMOUNT,\r\nU.SK_CUST_TRX_ID_LINT,\r\nU.SALES_ORDER_KEY,\r\nU.PURCHASE_ORDER_KEY,\r\nU.SALES_TERRITORY_KEY,\r\nU.ERP_CUST_ACCT_LOC_USE_KEY,\r\nU.ITEM_KEY,\r\nU.SK_SAF_ID_INT,\r\nU.SAF_TYPE_CD,\r\nU.EDW_CREATE_DTM,\r\nU.EDW_CREATE_USER,\r\nU.EDW_UPDATE_DTM,\r\nU.EDW_UPDATE_USER\r\nFROM (\r\nSELECT\r\nCOALESCE((SINV.AMOUNT* ( NSCA.SCA_SALES_COMMISSION_PCT /100)      ), 0.00) AS   SAF_AMOUNT\r\n,COALESCE(NARTRX.SK_CUSTOMER_TRX_ID_LINT,0.00)   AS SK_CUST_TRX_ID_LINT\r\n,COALESCE(NSO.SALES_ORDER_KEY  , -999) AS SALES_ORDER_KEY\r\n,-999  AS  PURCHASE_ORDER_KEY\r\n,COALESCE(NSCA.SALES_TERRITORY_KEY , -999) AS SALES_TERRITORY_KEY\r\n,COALESCE(MTEPE.END_CUSTOMER_KEY , -999)   AS ERP_CUST_ACCT_LOC_USE_KEY\r\n,COALESCE(NSOL.PRODUCT_KEY , -999) AS ITEM_KEY\r\n,COALESCE(ARCMDM.BK_SAF_ID_INT, -999) AS SK_SAF_ID_INT\r\n,ARCMDM.SAF_TYPE_CD                   \r\n,CURRENT_TIMESTAMP(0)  EDW_CREATE_DTM\r\n,USER   EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0)    EDW_UPDATE_DTM\r\n,USER EDW_UPDATE_USER\r\nFROM\r\n$$FINLGLVWDB.N_AR_CMDM_ADJ_REQUEST ARCMDM\r\nINNER JOIN   $$ETLVWDB.EL_OM_XXCAC_SAF_INVOICES SINV\r\nON SINV.SAF_ID=ARCMDM.BK_SAF_ID_INT\r\nAND ARCMDM.BK_SALES_ADJ_FORM_STATUS_CD    IN ('IN_PROGRESS','Approve')  AND ARCMDM.SS_CD='CG' AND ARCMDM.SOURCE_CREATED_DTM   > '2014-03-08' (DATE)\r\nINNER JOIN   $$FINLGLVWDB.N_AR_TRX  NARTRX\r\nON NARTRX.SK_CUSTOMER_TRX_ID_LINT    =SINV.CUSTOMER_TRX_ID\r\nAND ARCMDM.SAF_TYPE_CD    NOT IN ( 'SPECIAL_DEBIT','SPECIAL_INVOICE','SPECIAL_CREDIT','CASH_APPLICATION','WRITE_OFF')\r\nINNER JOIN\r\n$$SLSORDVWDB.N_SALES_ORDER_tv NSO\r\nON\r\nNSO.SALES_ORDER_KEY=NARTRX.SALES_ORDER_KEY\r\nINNER JOIN\r\n(SELECT NSOL.*\r\nFROM    $$SLSORDVWDB.N_SALES_ORDER_LINE NSOL\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY NSOL.BK_SO_NUMBER_INT ORDER BY NSOL.BK_SO_NUMBER_INT DESC)=1) NSOL\r\nON\r\nNSOL.SALES_ORDER_KEY=NSO.SALES_ORDER_KEY\r\nINNER  JOIN   $$NRTNCRVWDB.N_SCA_FOR_ALL_TRX_NRT_HIST_TV NSCA\r\nON\r\nNSOL.SALES_ORDER_LINE_KEY=NSCA.RU_SALES_ORDER_LINE_KEY       \r\nAND NSCA.BK_SALES_CREDIT_TYPE_CODE IN('Direct Sales','L') AND NSCA.SS_CD  ='CG'\r\nAND NSCA.END_TV_DTM  ='3500-01-01' (DATE) AND NSCA.SCA_SOURCE_TYPE_CD = 'O'\r\nINNER JOIN\r\n$$SLSORDVWDB.N_SO_END_CUSTOMER_TV NSOEC\r\nON\r\nNSOL.SALES_ORDER_KEY=NSOEC.SALES_ORDER_KEY\r\nINNER JOIN\r\n$$COMREFVWDB.MT_ERP_POS_ENDCUST MTEPE\r\nON\r\nMTEPE.END_CUSTOMER_KEY=NSOEC.END_CUSTOMER_KEY\r\nAND NSOEC.END_TV_DATETIME='3500-01-01' (DATE)\r\n\r\n\r\n\r\nUNION ALL\r\n\r\nSELECT\r\nCOALESCE((ELH.SAF_AMOUNT * (ELOM.SPLIT_PERCENT/100) ), 0.00)  SAF_AMOUNT\r\n,0.00 AS SK_CUST_TRX_ID_LINT\r\n, -999 AS SALES_ORDER_KEY\r\n,-999 AS PURCHASE_ORDER_KEY\r\n,COALESCE(NST.SALES_TERRITORY_KEY, -999) AS SALES_TERRITORY_KEY\r\n,-999 AS ERP_CUST_ACCT_LOC_USE_KEY\r\n, COALESCE(SAL.PRODUCT_KEY, -999) AS ITEM_KEY\r\n,COALESCE(ELH.SAF_ID , -999)   AS SK_SAF_ID_INT\r\n,ELH.SAF_TYPE\r\n,CURRENT_TIMESTAMP(0)  EDW_CREATE_DTM\r\n,USER   EDW_CREATE_USER\r\n,CURRENT_TIMESTAMP(0)    EDW_UPDATE_DTM\r\n,USER EDW_UPDATE_USER\r\nFROM\r\n$$ETLVWDB.EL_OM_XXCAC_SAF_HEADER     ELH    \r\nINNER JOIN    $$ETLVWDB.EL_OM_XXCAC_SAF_INVOICES ELINV     ON ELH.SAF_ID = ELINV.SAF_ID\r\nAND ELH.SAF_STATUS IN ('IN_PROGRESS','Approve')  AND ELH.GLOBAL_NAME = 'CG' AND ELH.CREATION_DATE  > '2014-03-08' (DATE)\r\nINNER JOIN  $$ETLVWDB.EL_CG_XXICM_SAF_SALESREPS_ALL  ELOM\r\nON ELOM.SAF_INVOICE_ID    =  ELINV.SAF_INVOICE_ID\r\nINNER JOIN\r\n$$FINLGLVWDB.N_SPECIAL_CONDITION_SAF_LINE SAL\r\nON\r\nSAL.BK_SALES_ADJ_FORM_ID_INT  =ELH.SAF_ID\r\nAND ELH.SAF_TYPE  IN ( 'SPECIAL_DEBIT','SPECIAL_INVOICE','SPECIAL_CREDIT') AND SAL.BK_SS_CD='CG'\r\nINNER JOIN  $$COMREFVWDB.N_SALES_TERRITORY       NST\r\nON      NST.SHARE_NODE_ID_INT     =  ELOM.TERRITORY_ID\r\n)U",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
