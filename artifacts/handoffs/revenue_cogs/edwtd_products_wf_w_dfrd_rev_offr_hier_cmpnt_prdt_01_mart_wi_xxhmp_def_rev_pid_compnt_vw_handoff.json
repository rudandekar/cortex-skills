      ],
      "attributes": {
        "Sql Query": "SELECT\r\n   PRODUCT_KEY ,           \r\n   DFRD_REV_OFFR_HIER_NODE_KEY,     \r\n   CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\n   USER AS EDW_CREATE_USER,\r\n   CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n   USER AS EDW_UPDATE_USER,               \r\n   START_TV_DT  ,                 \r\n   END_TV_DT     ,\r\n   ACTION_CODE,\r\n   DML_TYPE                \r\n   FROM\r\n   (\r\n   SELECT \r\n   TVOUTPUT.PRODUCT_KEY,\r\n   TVOUTPUT.DFRD_REV_OFFR_HIER_NODE_KEY,\r\n \r\n   CAST(TVOUTPUT.START_TV_DT AS DATE)  AS START_TV_DT,\r\n   \r\n    (CASE WHEN TVOUTPUT.RELATIONSHIP_END_DATE <= CURRENT_DATE THEN RELATIONSHIP_END_DATE\r\n   ELSE COALESCE (MAX (CAST(TVOUTPUT.START_TV_DT  AS DATE) - INTERVAL '1' DAY) \r\n   OVER (PARTITION BY TVOUTPUT.PRODUCT_KEY\r\n   ORDER BY TVOUTPUT.START_TV_DT ASC ROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING), DATE '3500-01-01') END ) AS END_TV_DT,\r\n  \r\n   TVOUTPUT.ACTION_CODE AS ACTION_CODE, \r\n   --TVOUTPUT.EXCEPTION_TYPE AS EXCEPTION_TYPE,\r\n   \r\n   ROW_NUMBER () OVER (PARTITION BY TVOUTPUT.PRODUCT_KEY  ORDER BY TVOUTPUT.START_TV_DT ASC) AS RANK_INDEX,\r\n   ( CASE WHEN RANK_INDEX = 1 AND TV_3NF.PRODUCT_KEY  IS NOT NULL  THEN 'U'ELSE 'I' END ) AS DML_TYPE, \r\n   TVOUTPUT.LAST_UPDATE_DATE AS TRANSACTION_DATE\r\n   \r\n   FROM\r\n   (\r\n   SELECT\r\n   PRODUCT_KEY,\r\n   DFRD_REV_OFFR_HIER_NODE_KEY,\r\n   START_TV_DT,\r\n   CREATE_DATETIME,\r\n   ACTION_CODE, \r\n   --EXCEPTION_TYPE,\r\n   LAST_UPDATE_DATE,\r\n   RELATIONSHIP_END_DATE,\r\n   ROW_NUMBER () OVER (PARTITION BY PRODUCT_KEY,DFRD_REV_OFFR_HIER_NODE_KEY ORDER BY LAST_UPDATE_DATE DESC) AS ROW_NUM  \r\n   FROM \r\n   (\r\n   SELECT\r\n   NPT.ITEM_KEY PRODUCT_KEY ,\r\n   SM_NODE.DFRD_REV_OFFR_HIER_NODE_KEY ,\r\n   CAST(ST.RELATIONSHIP_START_DATE AS DATE) AS START_TV_DT,\r\n   CURRENT_TIMESTAMP(0) AS CREATE_DATETIME,\r\n   'X' ACTION_CODE,\r\n  -- 'NE' EXCEPTION_TYPE,\r\n   ST.SOURCE_UPDATE_DATE AS LAST_UPDATE_DATE ,\r\n   ST.RELATIONSHIP_END_DATE  \r\n   FROM $$STGDB.WI_XXHMP_DEF_REV_PID_COMPNT_VW ST \r\nINNER JOIN  $$ETLVWDB.SM_DFRD_REV_OFFR_HIER_NODE SM_NODE\r\nON ST.NODE_ID = SM_NODE.SK_NODE_ID_INT\r\nINNER JOIN $$COMREFVWDB.N_PRODUCT_TV NPT\r\nON  NPT.BK_PRODUCT_ID = ST.PRODUCT_ID\r\nWHERE NPT.END_TV_DATE = '3500-01-01'\r\n\r\n \r\n    UNION ALL\r\n    \r\n   SELECT  \r\n   TV_3NF.PRODUCT_KEY,\r\n   TV_3NF.DFRD_REV_OFFR_HIER_NODE_KEY,\r\n    TV_3NF.START_TV_DT,\r\n   CAST(TV_3NF.START_TV_DT AS TIMESTAMP(0))  CREATE_DATETIME, \r\n   'X' ACTION_CODE, \r\n --  'NE' EXCEPTION_TYPE,\r\n    CAST(TV_3NF.START_TV_DT AS TIMESTAMP(0))  LAST_UPDATE_DATE,\r\n    TV_3NF.END_TV_DT AS RELATIONSHIP_END_DATE \r\n   FROM\r\n   $$FINLGLVWDB.N_DFRD_REV_OFFR_HIER_CMPNT_PRDT_TV TV_3NF\r\n   WHERE\r\n   (TV_3NF.PRODUCT_KEY) IN ( \r\n   SELECT NPT.ITEM_KEY  \r\n   FROM $$STGDB.WI_XXHMP_DEF_REV_PID_COMPNT_VW WI \r\n   INNER JOIN $$COMREFVWDB.N_PRODUCT_TV NPT\r\nON  NPT.BK_PRODUCT_ID = WI.PRODUCT_ID\r\nWHERE NPT.END_TV_DATE = '3500-01-01'  )\r\n   AND TV_3NF.END_TV_DT = CAST ('3500-01-01' AS DATE)\r\n   ) TVINPUT\r\n   \r\n   QUALIFY ROW_NUMBER () OVER (PARTITION BY TVINPUT.PRODUCT_KEY,  CAST(TVINPUT.LAST_UPDATE_DATE AS DATE)\r\n   ORDER BY TVINPUT.LAST_UPDATE_DATE DESC) = 1\r\n   \r\n   ) TVOUTPUT\r\n   LEFT JOIN $$FINLGLVWDB.N_DFRD_REV_OFFR_HIER_CMPNT_PRDT_TV TV_3NF\r\n   ON TVOUTPUT.PRODUCT_KEY = TV_3NF.PRODUCT_KEY\r\n   AND TV_3NF.END_TV_DT =CAST ('3500-01-01' AS DATE)\r\n   WHERE TVOUTPUT.ROW_NUM = 1\r\n   )A",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
