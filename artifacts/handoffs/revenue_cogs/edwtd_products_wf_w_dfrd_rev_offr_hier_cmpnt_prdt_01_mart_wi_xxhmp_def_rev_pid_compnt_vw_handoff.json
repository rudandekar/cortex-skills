      "attributes": {
        "Sql Query": "SELECT\r\nNODE_ID                       \t,\r\nPRODUCT_ID                    \t,\r\nRELATIONSHIP_START_DATE       \t,\r\nRELATIONSHIP_END_DATE         \t,\r\nSOURCE_UPDATE_DATE            \t, \r\n'RI' EXCEPTION_TYPE                 \r\nFROM $$STGDB.WI_XXHMP_DEF_REV_PID_COMPNT_VW  ST\r\nWHERE    NOT EXISTS\r\n(SELECT 1 FROM $$COMREFVWDB.N_PRODUCT_TV NPT\r\n   WHERE NPT.END_TV_DATE = '3500-01-01'\r\n    AND NPT.BK_PRODUCT_ID = ST.PRODUCT_ID\r\n    )",
