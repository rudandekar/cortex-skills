      "attributes": {
        "Sql Query": "SELECT\r\nNODE_ID                       \t,\r\nPRODUCT_ID                    \t,\r\nRELATIONSHIP_START_DATE       \t,\r\nRELATIONSHIP_END_DATE         \t,\r\nSOURCE_UPDATE_DATE            \t           \t\r\nFROM $$STGDB.ST_XXHMP_DEF_REV_PID_COMP_VW\r\nQUALIFY ROW_NUMBER () OVER(PARTITION BY PRODUCT_ID \r\nORDER BY SOURCE_UPDATE_DATE DESC, CHANGE_ID DESC ) =1\r\n\r\nUNION \r\n\r\nSELECT\r\nNODE_ID                       \t,\r\nPRODUCT_ID                    \t,\r\nRELATIONSHIP_START_DATE       \t,\r\nRELATIONSHIP_END_DATE         \t,\r\nSOURCE_UPDATE_DATE            \t               \t\r\nFROM  $$EXCEPDB.EX_XXHMP_DEF_REV_PID_COMPNT_VW  EX \r\n  WHERE EXISTS\r\n  (\r\n  SELECT 1 FROM $$COMREFVWDB.N_PRODUCT_TV NPT\r\n   WHERE NPT.END_TV_DATE = '3500-01-01'\r\n    AND NPT.BK_PRODUCT_ID = EX.PRODUCT_ID\r\n  )",
