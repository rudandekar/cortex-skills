        "Sql Query": "SELECT\r\nXPT.TRX_ID                        ,\r\nXPT.SOURCE_TRX_ID                 ,\r\nXPT.SOURCE_TRX_VERSION_ID         ,\r\nXPT.TRX_SOURCE_TYPE               ,\r\nXPT.TRX_VERSION_ID                ,\r\nXPT.TRX_RETURN_LINE_ID            ,\r\nXPT.TRX_RETURN_HEADER_ID          ,\r\nXPT.TRX_APPLIED_LINE_ID           ,\r\nXPT.TRX_APPLIED_HEADER_ID         ,\r\nXPT.TRX_HEADER_ID                 ,\r\nXPT.TRX_UPSTREAM_CODE             ,\r\nXPT.TRX_ORIG_CODE                 ,\r\nXPT.TRX_USAGE_CODE                ,\r\nXPT.TRX_TYPE_CODE                 ,\r\nXPT.DEAL_ID                       ,\r\nXPT.ORDER_QUANTITY                ,\r\nXPT.CANCEL_QUANTITY               ,\r\nXPT.PRICE                         ,\r\nXPT.CURRENCY_CODE                 ,\r\nXPT.CHANGE_TYPE_CODE              ,\r\nXPT.SOURCE_CREATION_DATE          ,\r\nXPT.TRX_NUMBER                    ,\r\nXPT.TRX_VALUE                     ,\r\nXPT.TRX_USD_VALUE                 ,\r\nXPT.REPORTING_DATE                ,\r\nXPT.OTM_DATE                      ,\r\nXPT.OTM_BATCH_ID                  ,\r\nXPT.OBJECT_VERSION_NUMBER         ,\r\nXPT.CREATION_DATE                 ,\r\nXPT.CREATED_BY                    ,\r\nXPT.LAST_UPDATE_DATE              ,\r\nXPT.LAST_UPDATED_BY               ,\r\nXPT.LAST_UPDATE_LOGIN             ,\r\nXPT.SOURCE_DML_TYPE               ,\r\nXPT.SOURCE_COMMIT_TIME            ,\r\nXPT.REFRESH_DATETIME              \r\nFROM\r\n$$NRTACCUMVWDB.XXOTM_PHX_TRX  XPT\r\nWHERE  XPT.TRX_SOURCE_TYPE='RTE_ADJ'\r\nAND XPT.SOURCE_COMMIT_TIME >= '$$LastExtractDate' \r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY XPT.TRX_ID ORDER BY XPT.REFRESH_DATETIME DESC) = 1",
