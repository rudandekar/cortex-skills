      "attributes": {
        "Sql Query": "SELECT MT_UN.PROCESSED_FISCAL_MTH,\r\nABS(ROUND(SUM(MT_UN.UNBILLED_REVENUE + MT_TSS_UN.TSS_UNBILLED_REVENUE))) AS TSS_UB_AMT_MISMATCH ,\r\n'SBP' AS AUDIT_TRXN_TYPE,\r\n'MT_TSS_UNBILLED_REVENUE' AS AUDIT_TABLE,\r\n   Current_Date AS AUDIT_DATE\r\nFROM\r\n(SELECT MT.PROCESSED_FISCAL_MTH AS PROCESSED_FISCAL_MTH,MT.TRANSACTION_TYPE AS TRANSACTION_TYPE,\r\nSUM((MT.UNBILLED_REVENUE_AMT  *  COALESCE(SFH.ALLOCATION_PERCENTAGE,1)) ) AS UNBILLED_REVENUE\r\nFROM $$FINLGLVWDB.MT_RSTD_UNBILLED_REVENUE MT\r\nINNER JOIN $$COMREFVWDB.MT_CS_DEAL_SVC_FIN_HIER_ALLOC SFH                     \r\nON SFH.ITEM_KEY =  MT.ATTRIBUTED_PRODUCT_KEY \r\nAND SFH.BK_SERVICE_CATEGORY_ID='TECHNICAL SUPPORT SERVICES'\r\nAND SFH.DV_PRDT_SUB_GRP_ALLOC_SRC_CD='SPA'\r\nWHERE TRANSACTION_TYPE IN ('SBP','SBP ACCURALS','NET_ADJ_SBP')\r\nAND MT.PROCESSED_FISCAL_MTH = (SELECT FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_SRVC_UNBILL_CTRL_MTH GROUP BY 1)\r\nAND MT.CORP_FLG='Y' AND MT.SERVICE_FLG = 'Y'                        \t\r\nGROUP BY 1,2) MT_UN\r\nLEFT JOIN\r\n(SELECT MT.PROCESSED_FISCAL_MTH AS PROCESSED_FISCAL_MTH ,MT.TRANSACTION_TYPE AS TRANSACTION_TYPE,\r\nSUM(MT.TSS_UNBILLED_REVENUE_AMT)*-1 AS TSS_UNBILLED_REVENUE \r\nFROM $$FINLGLVWDB.MT_TSS_UNBILLED_REVENUE MT\r\nWHERE TRANSACTION_TYPE IN ('SBP','SBP ACCURALS','NET_ADJ_SBP')\r\nAND MT.PROCESSED_FISCAL_MTH = (SELECT FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_TSS_SRVC_UNBILL_CTRL_MTH GROUP BY 1) \r\nGROUP BY 1,2) MT_TSS_UN\r\nON MT_UN.PROCESSED_FISCAL_MTH=MT_TSS_UN.PROCESSED_FISCAL_MTH\r\nAND MT_UN.TRANSACTION_TYPE=MT_TSS_UN.TRANSACTION_TYPE\r\nGROUP BY 1",
