      "attributes": {
        "Sql Query": "SELECT\r\n cast( NDCAT.BK_DIRECT_CORP_ADJ_TYPE_CD  AS VARCHAR(100))    BK_DIRECT_CORP_ADJ_TYPE_CD     ,\r\n CAST('UNKNOWN' AS VARCHAR(100))  BK_ADJUSTMENT_TYPE_CD,\r\n\r\n  CASE WHEN NDCAT.BK_DIRECT_CORP_ADJ_TYPE_CD  = 'Net Accounting Adjustment Auto'   THEN 'REVENUE' \r\n \t\t\tWHEN  BK_DIRECT_CORP_ADJ_TYPE_CD IN ( 'Royalty Auto', 'Revenue Share COGS Auto' )  THEN 'COGS'  \r\n \t\t\tELSE CAST('UNKNOWN' AS VARCHAR(100))   \r\n END AS BK_REVENUE_OR_COGS_TYPE_CD,  /*  changed as part Royalty Q3FY16 */\r\n\r\n DIRECT_CORP_ADJ_START_DTM      EFFECTIVE_START_DTM   ,\r\n cast (DIRECT_CORP_ADJ_END_DTM as timestamp(0))        EFFECTIVE_END_DTM     ,\r\n DIRECT_CORP_ADJ_DESCR         ADJUSTMENT_TYPE_DESCR          ,\r\n CASE \r\n WHEN BK_DIRECT_CORP_ADJ_TYPE_CD='As Invoiced-FCM Product' THEN CAST('Other Product LMY Revenue' AS VARCHAR(100))\r\n WHEN BK_DIRECT_CORP_ADJ_TYPE_CD='As Invoiced-FCM Service' THEN CAST('Other Service LMY Revenue' AS VARCHAR(100))\r\n ELSE CAST(BK_DIRECT_CORP_ADJ_TYPE_CD AS VARCHAR(100))   END     L3_HIERARCHY_NODE_TYPE_ID,\r\n NDCAT.BK_DIRECT_CORP_ADJ_LVL2_TYP_CD L2_HIERARCHY_NODE_TYPE_ID     ,\r\n NDCATL2.BK_DIRECT_CORP_ADJ_LVL1_TYP_CD L1_HIERARCHY_NODE_TYPE_ID     ,\r\n NDCATL2.DIRECT_CORP_ADJ_LVL2_DESCR         DIRECT_CORP_ADJ_LVL2_DESCR     ,\r\n NDCATL1.DIRECT_CORP_ADJ_LVL1_DESCR         DIRECT_CORP_ADJ_LVL1_DESCR     ,\r\n CAST(NULL AS VARCHAR(100)) ADJUSTMENT_SOURCE_CD           ,\r\n CAST(NULL AS VARCHAR(100))  DISCOUNT_FLG                   ,\r\n CAST(NULL AS VARCHAR(100))  STATUS_FLG                     ,\r\n CAST(NULL AS VARCHAR(100))  SOX_TIE_IN_DESCR               ,\r\n CAST(NULL AS VARCHAR(100))  ADJ_DATA_UPDATE_FREQUENCY_CD   ,\r\n CAST(NULL AS VARCHAR(100))  DATA_ROUTE_DESCR               ,\r\n cast ( -999 AS INTEGER) CRTD_BY_CISCO_WORKER_PARTY_KEY ,\r\n -cast ( -999 AS INTEGER)  UPD_BY_CISCO_WORKER_PARTY_KEY  ,\r\n Cast ('DIRECT' AS VARCHAR(15)) DIRECT_INDIRECT_TYPE  ,\r\n 'N' AS DUAL_GAAP_FLG\r\n FROM \r\n  $$FINLGLVWDB.N_DIRECT_CORP_ADJ_TYPE NDCAT,\r\n  $$FINLGLVWDB.N_DIRECT_CORP_ADJ_TYPE_LVL1 NDCATL1,\r\n  $$FINLGLVWDB.N_DIRECT_CORP_ADJ_TYPE_LVL2 NDCATL2\r\n WHERE\r\n  NDCATL2.BK_DIRECT_CORP_ADJ_LVL2_TYP_CD = NDCAT.BK_DIRECT_CORP_ADJ_LVL2_TYP_CD\r\n AND\r\n  NDCATL2.BK_DIRECT_CORP_ADJ_LVL1_TYP_CD = NDCATL1.BK_DIRECT_CORP_ADJ_LVL1_TYP_CD\r\n UNION ALL\r\n  sel \r\n CAST('UNKNOWN' AS VARCHAR(100))   BK_DIRECT_CORP_ADJ_TYPE_CD     ,\r\n BK_ADJUSTMENT_TYPE_CD          BK_ADJUSTMENT_TYPE_CD          ,\r\n BK_REVENUE_OR_COGS_TYPE_CD     BK_REVENUE_OR_COGS_TYPE_CD    ,\r\n ADJ_TYPE_EFFECTIVE_START_DTM   EFFECTIVE_START_DTM   ,\r\n cast(ADJ_TYPE_EFFECTIVE_END_DTM as timestamp(0))     EFFECTIVE_END_DTM     ,\r\n cast(ADJUSTMENT_TYPE_DESCR     AS  VARCHAR(100))          ADJUSTMENT_TYPE_DESCR          ,\r\n MIDDLE1.BK_IROCA_HIERARCHY_NODE_ID     L3_HIERARCHY_NODE_TYPE_ID     ,\r\n MIDDLE2.BK_IROCA_HIERARCHY_NODE_ID     L2_HIERARCHY_NODE_TYPE_ID     ,\r\n ROOT.BK_IROCA_HIERARCHY_NODE_ID           L1_HIERARCHY_NODE_TYPE_ID     ,\r\n 'NA' DIRECT_CORP_ADJ_LVL2_DESCR     ,\r\n 'NA'  DIRECT_CORP_ADJ_LVL1_DESCR     ,\r\n ADJUSTMENT_SOURCE_CD           ADJUSTMENT_SOURCE_CD           ,\r\n DISCOUNT_FLG                   DISCOUNT_FLG                   ,\r\n STATUS_FLG                     STATUS_FLG                     ,\r\n SOX_TIE_IN_DESCR               SOX_TIE_IN_DESCR               ,\r\n ADJ_DATA_UPDATE_FREQUENCY_CD   ADJ_DATA_UPDATE_FREQUENCY_CD   ,\r\n DATA_ROUTE_DESCR               DATA_ROUTE_DESCR               ,\r\n CRTD_BY_CISCO_WORKER_PARTY_KEY CRTD_BY_CISCO_WORKER_PARTY_KEY ,\r\n UPD_BY_CISCO_WORKER_PARTY_KEY  UPD_BY_CISCO_WORKER_PARTY_KEY  ,\r\n 'INDIRECT' DIRECT_INDIRECT_TYPE ,\r\n NIRCAT.DUAL_GAAP_FLG\r\n FROM $$FINLGLVWDB.N_INDRCT_REV_COGS_ADJ_TYPE NIRCAT\r\n INNER JOIN $$FINLGLVWDB.N_IROCA_HIERARCHY_NODE LEAF\r\n ON ( NIRCAT.BK_IROCA_HIERARCHY_NODE_ID = LEAF.BK_IROCA_HIERARCHY_NODE_ID\r\n AND LEAF.NODE_TYPE= 'LEAF' )\r\n INNER JOIN $$FINLGLVWDB.N_IROCA_HIERARCHY_NODE MIDDLE1\r\n ON ( MIDDLE1.BK_IROCA_HIERARCHY_NODE_ID = LEAF.RU_PARENT_HIERARCHY_NODE_ID \r\n AND MIDDLE1.NODE_TYPE = 'MIDDLE')\r\n INNER JOIN $$FINLGLVWDB.N_IROCA_HIERARCHY_NODE MIDDLE2\r\n ON ( MIDDLE2.BK_IROCA_HIERARCHY_NODE_ID = MIDDLE1.RU_PARENT_HIERARCHY_NODE_ID\r\n AND MIDDLE2.NODE_TYPE = 'MIDDLE' )\r\n INNER JOIN $$FINLGLVWDB.N_IROCA_HIERARCHY_NODE ROOT\r\n ON ( ROOT.BK_IROCA_HIERARCHY_NODE_ID = MIDDLE2.RU_PARENT_HIERARCHY_NODE_ID \r\n AND ROOT.NODE_TYPE= 'ROOT' )",
        "User Defined Join": "",
