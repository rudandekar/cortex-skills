      "attributes": {
        "Sql Query": "SELECT\r\nSRC.DV_FISCAL_YEAR_MTH_NUMBER_INT\r\n,'MT_PNL_REV_COST_MSR_AS_REV' AS AUDIT_TABLE\r\n,CURRENT_DATE AS AUDIT_DATE\r\n,ABS(ROUND(COALESCE(SRC.SRC_COST,1)-COALESCE(TGT.TGT_COST,1),4)) AS COST_MISMATCH_AMT\r\nFROM\r\n(SELECT DV_FISCAL_YEAR_MTH_NUMBER_INT , \r\nSUM(COMP_US_NET_REV_AMT)  AS SRC_COST\r\nFROM $$STGDB.WI_SERVICE_REVENUE_AS  REV_INCR\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR  B        \r\nON REV_INCR.DV_FISCAL_YEAR_MTH_NUMBER_INT          =B.FISCAL_YEAR_MONTH_INT      \r\nGROUP BY 1) SRC\r\nLEFT JOIN\r\n(SELECT DV_FISCAL_YEAR_MTH_NUMBER_INT,\r\nSUM(COMP_US_NET_REV_AMT) AS TGT_COST\r\nFROM $$FINLGLVWDB.MT_PNL_REV_COST_MSR REV_INCR\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR  B        \r\nON REV_INCR.DV_FISCAL_YEAR_MTH_NUMBER_INT          =B.FISCAL_YEAR_MONTH_INT      \r\nWHERE  DV_PNL_REV_COST_TYPE_CD LIKE 'AS%'        \r\nGROUP BY 1) TGT\r\nON SRC.DV_FISCAL_YEAR_MTH_NUMBER_INT=TGT.DV_FISCAL_YEAR_MTH_NUMBER_INT",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
