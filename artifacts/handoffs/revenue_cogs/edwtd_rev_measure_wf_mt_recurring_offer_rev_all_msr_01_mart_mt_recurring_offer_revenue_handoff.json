      "attributes": {
        "Sql Query": "SELECT\r\nEL.DV_RECURRING_OFFER_CD,\r\nEL.PRODUCT_KEY,\r\nEL.DV_PRODUCT_KEY,\r\nEL.SALES_ORDER_KEY,\r\nEL.SK_OFFER_ATTRIBUTION_ID_INT,\r\n COALESCE (ATTRIB.ENTERPRISE_SKU_PRDT_KEY,-999) AS ENTERPRISE_SKU_PRDT_KEY ,\r\n \r\n  CASE WHEN NSO.CSCC_FLG = 'Y' AND OFFER_ENT.BK_PARENT_OFFER_TYPE_NAME = 'Cisco One' THEN ATTRIB.ENTERPRISE_SKU_PRDT_KEY\r\n   WHEN OFFER_BUN.BK_PARENT_OFFER_TYPE_NAME = 'Cisco One' /*AND MT_MAP.PRODUCT_KEY IS NOT NULL*/  THEN  EL.DV_PRODUCT_KEY\r\n   ELSE COALESCE(EL.PRODUCT_KEY ,-999)\r\n   END AS DV_RO_PRODUCT_KEY ,\r\n   \r\n/* CASE WHEN NSO.CSCC_FLG = 'Y' AND OFFER_ENT.BK_PARENT_OFFER_TYPE_NAME = 'Cisco One' THEN ALLC_ENT.BK_OFFER_TYPE_NAME\r\n WHEN OFFER_BUN.BK_PARENT_OFFER_TYPE_NAME = 'Cisco One' *//*AND MT_MAP.PRODUCT_KEY IS NOT NULL*/ /*THEN  ALLC_BUN.BK_OFFER_TYPE_NAME\r\n WHEN OFFER_BUN.BUNDLE_PRDT_OFFR_FLG = 'Y' THEN ALLC_BUN.BK_OFFER_TYPE_NAME \r\n ELSE COALESCE( MT.BK_OFFER_TYPE_NAME,'Others')\r\n END AS DV_BK_OFFER_TYPE_NAME ,*/\r\nCASE \r\nWHEN NSOA.ORDER_ORIGIN_CD IN ('CCW-FSUB','SOWB-FSUB')  AND NSOA.FSUB_ELIGIBLE_FLG = 'Y' THEN NSOA.BK_OFFER_TYPE_NAME\r\nWHEN NSO.CSCC_FLG = 'Y' AND OFFER_ENT.BK_PARENT_OFFER_TYPE_NAME = 'Cisco One' \r\n        THEN CASE WHEN  OFFER_ENT.BUNDLE_SKU_CARVE_OUT_TYPE = 'Service'\r\n\t\tAND COALESCE(OFFER_ATTR.BK_PARENT_OFFER_TYPE_NAME,'Others') = OFFER_ENT.OFFER_TYPE_CD  \r\n\t\tTHEN MT.BK_OFFER_TYPE_NAME /* Priority 1 */\r\n\t\tELSE COALESCE( ALLC_ENT.BK_OFFER_TYPE_NAME,'Others') END  /* Priority 2 */   \r\n\r\n\tWHEN OFFER_BUN.BUNDLE_PRDT_OFFR_FLG = 'Y' AND OFFER_BUN.BUNDLE_SKU_CARVE_OUT_TYPE = 'Product'\r\n\t\tTHEN CASE WHEN OFFER_BUN.CARVE_OUT_FLG = 'Y'\r\n\t\tAND COALESCE(OFFER_ATTR.BK_PARENT_OFFER_TYPE_NAME,'Others') = OFFER_BUN.OFFER_TYPE_CD \r\n\t\t\tTHEN OFFER_ATTR.BK_OFFER_TYPE_NAME \r\n\t\t\tELSE COALESCE( OFFER_BUN.BK_OFFER_TYPE_NAME,'Others') END\t/* Priority 3 : C1NG purchases  */ \t\r\n\r\n    WHEN  OFFER_BUN.BK_PARENT_OFFER_TYPE_NAME = 'Cisco One' \r\n\t\tAND OFFER_BUN.BUNDLE_SKU_CARVE_OUT_TYPE = 'Service'\r\n\t\tTHEN CASE WHEN  OFFER_BUN.CARVE_OUT_FLG = 'Y'\r\n\t\t  AND COALESCE(OFFER_ATTR.BK_PARENT_OFFER_TYPE_NAME,'Others')= OFFER_BUN.OFFER_TYPE_CD  \r\n\t\t  THEN OFFER_ATTR.BK_OFFER_TYPE_NAME\r\n\t\t\t\t\tELSE COALESCE( OFFER_BUN.BK_OFFER_TYPE_NAME,'Others') END\t/* Priority 3 : C1NG renewal  */ \t\r\n\t\t\t\t   \r\n    WHEN OFFER_BUN.BUNDLE_PRDT_OFFR_FLG = 'Y' THEN ALLC_BUN.BK_OFFER_TYPE_NAME /* Priority 4 */ \r\n         \r\n\tWHEN OFFER_BUN.BK_PARENT_OFFER_TYPE_NAME = 'Cisco One' THEN  ALLC_BUN.BK_OFFER_TYPE_NAME /* This is not req'd if all Cisco One OL2's have Bundle Flag = Y */\r\n\t\t \r\n\t\t ELSE COALESCE( MT.BK_OFFER_TYPE_NAME,'Others') /* Priority 5 & 6 */ \r\n  END AS DV_BK_OFFER_TYPE_NAME ,   /* Added as part of Q3FY20 ICPM MAR REL */\r\n \r\n \r\nCASE WHEN  EL.SOURCE_ORIGIN IN ('WI_CCRM_REC_REV_TBA_RO_KEYS','WI_RECUR_OFFER_KEYS_DEF_TRX',\r\n'WI_RO_KEYS_APSP_FDI_REV_TRX') THEN COALESCE(NSO.CSCC_FLG,'N') \r\nELSE COALESCE(NSO.CSCC_FLG,'N') END AS CSCC_FLG,\r\n   \r\n   CASE WHEN XCAT_FLAG='Y' THEN 'Y' \r\n        WHEN NSO.CSCC_FLG = 'Y' AND OFFER_ENT.BK_PARENT_OFFER_TYPE_NAME = 'Cisco One' THEN ALLC_ENT.ELA_FLG\r\n     WHEN OFFER_BUN.BK_PARENT_OFFER_TYPE_NAME = 'Cisco One' /*AND MT_MAP.PRODUCT_KEY IS NOT NULL */ THEN  ALLC_BUN.ELA_FLG\r\n\r\nWHEN ALLC_BUN.ITEM_KEY \r\n\t\t= (SELECT DISTINCT ITEM_KEY FROM $$STGDB.WI_XXITM_ELA_DEFAULT_ITMS_TB EX\r\n\t\tWHERE ALLC_BUN.ITEM_KEY = EX.ITEM_KEY AND EX.REPORT_BUN_PID_FLAG = 'Y' AND EX.END_DATE = '3500-01-01') THEN ALLC_BUN.ELA_FLG\r\n        ELSE COALESCE(MT.ELA_FLG,'N') END AS ELA_FLAG ,\r\n     \r\n CASE WHEN NSO.XCAT_FLG = 'Y' THEN 'Y' ELSE CASE WHEN MT.XCAT_FLG='Y' THEN 'Y' ELSE 'N' END END XCAT_FLAG,\r\n \r\n /* CASE WHEN OFFER_BUN.BK_PARENT_OFFER_TYPE_NAME = 'Cisco One' AND MT_MAP.PRODUCT_KEY IS NOT NULL\r\n THEN  ALLC_BUN.RECURRING_OFFER_FLG\r\n        ELSE COALESCE(MT.RECURRING_OFFER_FLG,'N') END AS RECURRING_OFFER_FLG ,*/\r\n\t\t\r\n/*ADDED AS PART OF RO PRDT CHNGS Q4FY19 BY SVAKULAB*/\r\nCASE WHEN  'N' = (SEL ST.RO_FLG FROM $$ETLVWDB.EL_RO_FLG ST)\r\nTHEN CASE WHEN NP.GOODS_OR_SERVICE_TYPE='GOODS' AND ELA_FLAG='Y' THEN 'Y'\r\nELSE COALESCE (MT.RECURRING_OFFER_FLG,'N') \r\nEND\r\nELSE \r\nCOALESCE(MT.RECURRING_OFFER_FLG,'N')\r\nEND AS RECURRING_OFFER_FLAG,\r\n\r\n CASE WHEN  OFFER_DV.BK_PARENT_OFFER_TYPE_NAME = 'Cisco One' AND MT.PRODUCT_CATEGORY_CD IN ('Software','Software Service') \r\n       AND MT.RU_SOFTWARE_USAGE_TYPE_CD IN ('System SW','UNKNOWN') /*AND MT_MAP.PRODUCT_KEY IS NOT NULL*/ THEN 'On-Premise' \r\n  ELSE COALESCE(MT.RU_SOFTWARE_USAGE_TYPE_CD,'UNKNOWN')  END AS DV_RU_SOFTWARE_USAGE_TYPE_CD,\r\n  CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\n  USER AS EDW_CREATE_USER ,\r\n  CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n  USER AS EDW_UPDATE_USER    \r\n \r\n FROM \r\n $$ETLVWDB.EL_RO_REVENUE EL\r\n  \r\n LEFT OUTER JOIN  $$ETLVWDB.EL_RO_SALES_ORDER_ATHENA NSOA \r\n ON NSOA.SALES_ORDER_KEY = EL.SALES_ORDER_KEY\r\n \r\n LEFT OUTER JOIN  $$ETLVWDB.EL_RO_SALES_ORDER NSO\r\n ON NSO.SALES_ORDER_KEY = EL.SALES_ORDER_KEY\r\n \r\n LEFT OUTER JOIN  $$ETLVWDB.EL_RO_SOL_OFFER_ATTRIBUTION  ATTRIB\r\n ON EL.SK_OFFER_ATTRIBUTION_ID_INT = ATTRIB.SK_OFFER_ATTRIBUTION_ID_INT \r\n AND ATTRIB.END_TV_DTM = '3500-01-01 00:00:00' \r\n AND ATTRIB.ENTERPRISE_SKU_PRDT_KEY > 0\r\n AND ATTRIB.ATTRIBUTION_CD IN (SELECT  ATTRIBUTION_CD FROM $$ETLVWDB.EL_RO_OFFER_ATTRB_CODE)\r\n \r\n LEFT OUTER JOIN $$COMREFVWDB.MT_RECURRING_OFFER_PRODUCT ALLC_ENT\r\n  ON ATTRIB.ENTERPRISE_SKU_PRDT_KEY = ALLC_ENT.ITEM_KEY  \r\n   LEFT OUTER JOIN $$COMREFVWDB.N_OFFER_TYPE  OFFER_ENT \r\n   ON OFFER_ENT.BK_OFFER_TYPE_NAME = ALLC_ENT.BK_OFFER_TYPE_NAME \r\n \r\n  INNER JOIN $$COMREFVWDB.MT_RECURRING_OFFER_PRODUCT   ALLC_BUN \r\n   ON EL.DV_PRODUCT_KEY = ALLC_BUN.ITEM_KEY   \r\n  INNER JOIN $$COMREFVWDB.N_OFFER_TYPE     OFFER_BUN \r\n   ON OFFER_BUN.BK_OFFER_TYPE_NAME = ALLC_BUN.BK_OFFER_TYPE_NAME\r\n \r\n LEFT OUTER JOIN $$COMREFVWDB.MT_RECURRING_OFFER_PRODUCT MT\r\n ON  MT.ITEM_KEY = EL.PRODUCT_KEY\r\n \r\n/*\r\n  LEFT OUTER JOIN \r\n  ( SELECT PRODUCT_KEY, DV_PRODUCT_KEY FROM $$COMREFVWDB.MT_OFFER_TYPE_PRDT_MAP GROUP BY 1,2) MT_MAP \r\n   ON WI.PRODUCT_KEY = MT_MAP.PRODUCT_KEY \r\n   AND WI.DV_PRODUCT_KEY = MT_MAP.DV_PRODUCT_KEY\r\n*//* commented as part of Dec3rd rel */  \r\n\r\n/* Added as part of Q3FY20 ICPM MAR REL */\r\n  LEFT OUTER JOIN $$COMREFVWDB.N_PRODUCT NP_ESKU_SRVC\r\n  ON ATTRIB.ENTERPRISE_SKU_PRDT_KEY=NP_ESKU_SRVC.ITEM_KEY\r\n\t\r\n  LEFT OUTER JOIN $$COMREFVWDB.N_OFFER_TYPE     OFFER_ATTR\r\n  ON OFFER_ATTR.BK_OFFER_TYPE_NAME = MT.BK_OFFER_TYPE_NAME\r\n\t\r\n  LEFT OUTER JOIN $$COMREFVWDB.N_PRODUCT NP_BUN\r\n  ON EL.DV_PRODUCT_KEY=NP_BUN.ITEM_KEY\r\n\r\n INNER JOIN $$COMREFVWDB.N_OFFER_TYPE     OFFER_DV \r\n ON OFFER_DV.BK_OFFER_TYPE_NAME = DV_BK_OFFER_TYPE_NAME  \r\n \r\n /* ADDED AS A PART OF OCT RELEASE RO_FLG CHANGE */\r\n   LEFT OUTER JOIN $$COMREFVWDB.N_PRODUCT NP\r\n   ON EL.PRODUCT_KEY=NP.ITEM_KEY\r\n\r\n\r\n\r\nWHERE  NOT EXISTS (\r\nSELECT DV_RECURRING_OFFER_CD FROM $$FINLGLVWDB.MT_RECURRING_OFFER_REVENUE MTB\r\nWHERE MTB.DV_RECURRING_OFFER_CD=EL.DV_RECURRING_OFFER_CD)",
        "User Defined Join": "",
