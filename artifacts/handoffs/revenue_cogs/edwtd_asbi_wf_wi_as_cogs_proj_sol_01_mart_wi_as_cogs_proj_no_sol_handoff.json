      ],
      "attributes": {
        "Sql Query": "SELECT \r\nAPNS.BK_AS_PROJECT_CD,AS_PROJECT_CLASS_CD,AS_PROJECT_NAME,ERP_WIPS_CUSTOMER_NAME,PROJET_BUSINESS_MODEL,CURRENT_VERSION_FLG,\r\nSUM(RU_PROJ_REV_BDGT_USD_AMT ) AS REVENUE_AMOUNT\r\n,SUM(RU_PROJ_COST_BDGT_USD_AMT     ) AS COST\r\nFROM \r\n$$STGDB.WI_AS_COGS_PROJ_NO_SOL APNS\r\nLEFT OUTER JOIN $$SERVICEVWDB.N_AS_PROJECT_BUDGET NAP\r\nON APNS.BK_AS_PROJECT_CD =NAP.BK_AS_PROJECT_CD\r\nAND \r\nCURRENT_VERSION_FLG ='Y'\r\nAND BK_AS_PROJECT_BUDGET_TYPE_CD IN ('AS Approved Revenue Budget','AS Approved Cost Budget')\r\nAND BK_AS_PROJ_BDGT_PRCSS_STAT_CD ='Y'\r\nGROUP BY 1,2,3,4,5,6",
        "User Defined Join": "",
