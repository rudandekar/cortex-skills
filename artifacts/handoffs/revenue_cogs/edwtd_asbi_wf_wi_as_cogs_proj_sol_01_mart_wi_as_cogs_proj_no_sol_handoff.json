      ],
      "attributes": {
        "Sql Query": "SELECT \r\nmap2.BK_AS_PROJECT_CD,\r\nmap2.AS_PROJECT_CLASS_CD,\r\nMAP2.AS_PROJECT_NAME, \r\nPRJ_CUST.ERP_WIPS_CUSTOMER_NAME,\r\nCASE WHEN map2.AS_PROJECT_CLASS_CD ='SUBSCRIPTION'\r\n                                  THEN map2.AS_SUBSCRIPTION_BUSINESS_MODEL \r\n                ELSE\r\n                                map2.AS_PROJECT_SUB_TYPE \r\nEND PROJET_BUSINESS_MODEL,\r\nAS_LOCAL_DEAL_ID_INT \r\nFROM $$ASBIVWDB.MT_AS_PROJECT map2 \r\nINNER JOIN \r\n(SELECT \r\nDISTINCT PRJ.BK_AS_PROJECT_CD \r\nFROM \r\n$$SERVICEVWDB.N_AS_TASK_RESOURCE_EXPENDITURE natre \r\nINNER JOIN $$SERVICEVWDB.N_AS_PROJECT_TASK PT\r\nON NATRE.AS_PROJECT_TASK_KEY = PT.AS_PROJECT_TASK_KEY \r\nINNER JOIN $$SERVICEVWDB.N_AS_PROJECT PRJ\r\nON PT.BK_AS_PROJECT_CD  = PRJ.BK_AS_PROJECT_CD\r\nINNER JOIN  $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDY\r\nON NATRE.BK_AS_TASK_RSRC_EXPNDTR_DT =FDY.CALENDAR_DATE--JOIN BASED ON EXPENDITURE ITEM DATE TO FISCAL DAY TO YEAR WITH EXPENDITURE TYPE AS as EMPLOYEE LABOUR , as vENDOR lABOR ,As TRAVEL HOURS ,AS VENDOR TRAVEL HOURS, AS ENG LABOUR , ENG VENDOR LABOUR ,SINGLE PID LABOR (spid)\r\nWHERE NATRE.AS_TASK_RSRC_EXPNDTR_USD_AMT <>0\r\nAND FDY.FISCAL_MONTH_AGE =0\r\nAND BK_AS_TASK_RSRC_EXPNDTR_TYP_CD IN ('AS Employee Labor','AS Travel Hours','AS Vendor Labor','AS Vendor SPID Labor','AS Vendor Travel','AS Vendor Travel Hours','ENG Employee Labor','ENG Vendor Labor'--,'ENG Travel Hours','ENG Vendor Travel'\r\n)) PRJ_EXP\r\nON MAP2.BK_AS_PROJECT_CD  = PRJ_EXP.BK_AS_PROJECT_CD\r\nINNER JOIN $$COMREFVWDB.MT_ERP_POS_SOLDTO_HIER PRJ_CUST\r\nON MAP2.PROJECT_CUST_ACCT_KEY  = PRJ_CUST.SOLD_TO_CUSTOMER_KEY\r\nWHERE MAP2.BK_AS_PROJECT_CD NOT IN \r\n(\r\nSELECT BK_AS_PROJECT_CD \r\nFROM $$SERVICEVWDB.N_SOL_WITH_AS_PROJECT nswap \r\nUNION\r\nSELECT \r\nBK_AS_PROJECT_CD \r\nFROM $$SERVICEVWDB.N_AS_PROJ_TO_SALES_ORDER_LINK naptsol \r\n)\r\nAND LATEST_RECORD_FLG  ='Y'\r\nAND MAP2.AS_PROJECT_CLASS_CD  IN ('SUBSCRIPTION','TRANSACTION','FIXED','CAP','INTERNAL') \r\nAND (MAP2.AS_PROJECT_STATUS_NAME IN ('ACTIVE','DELIVERY CLOSE','ON HOLD') OR (MAP2.AS_PROJECT_STATUS_NAME IN ('CLOSED') \r\nAND COALESCE(MAP2.AS_PROJECT_CLOSED_DT , MAP2.AS_PROJECT_ACTUAL_FINISH_DT , AS_PROJECT_COMPLETION_DT ,MAP2.DV_AS_PROJ_STATUS_CHANGED_DT) >\r\n(SELECT MIN(NFY.FISCAL_MONTH_START_DATE) FROM $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR nfy WHERE NFY.FISCAL_YEAR_MONTH_INT >=(SELECT FISCAL_YEAR_MONTH_INT FROM $$STGDB.WI_AS_COGS_PNL_MTH_CNTL WHERE INC_FLAG ='Y')) -- FOR PRODUCTION ONLY BASED ON A CURRENT MONTH BUT FOR STG IT WILL BE FOR ONE YEAR\r\n))",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
