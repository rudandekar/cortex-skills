      ],
      "attributes": {
        "Sql Query": "SELECT \r\nMA.BK_AS_PROJECT_CD,MA.AS_LOCAL_DEAL_ID_INT,NSOLP.SALES_ORDER_LINE_KEY,BK_SO_NUMBER_INT,\r\nPRJ_CUST.GU_PRIMARY_NAME AS CUSTOMER_NAME    \r\n,MA.AS_PROJECT_CLASS_CD\r\nFROM $$SERVICEVWDB.N_SOL_WITH_AS_PROJECT NSOLP\r\nINNER JOIN  $$ASBIVWDB.MT_AS_PROJECT MA\r\nON NSOLP.BK_AS_PROJECT_CD=MA.BK_AS_PROJECT_CD\r\nAND LATEST_RECORD_FLG='Y'\r\nINNER JOIN $$SLSORDVWDB.N_SALES_ORDER_LINE SOL\r\nON NSOLP.SALES_ORDER_LINE_KEY = SOL.SALES_ORDER_LINE_KEY\r\nINNER JOIN $$COMREFVWDB.MT_ERP_POS_SOLDTO_HIER PRJ_CUST\r\nON MA.PROJECT_CUST_ACCT_KEY  = PRJ_CUST.SOLD_TO_CUSTOMER_KEY\r\nINNER JOIN  $$COMREFVWDB.MT_SVC_FINANCE_HIERARCHY DYN \r\nON DYN.ITEM_KEY=SOL.PRODUCT_KEY \r\nAND DYN.BK_SERVICE_CATEGORY_ID  IN  ( 'ADVANCED SERVICES'  ) \r\nAND DYN.BK_ALLOCATED_SERVC_GROUP_ID <> 'UNKNOWN'  \r\nGROUP BY 1,2,3,4,5,6",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
