      ],
      "attributes": {
        "Sql Query": "SEL TGT.PROCESSED_FISCAL_MTH, Abs(Round (UR_LOCAL_AMT-UR_AMT)) AS REV_MISMATCH_AMT,\r\n   'SBP' AS AUDIT_TRXN_TYPE,\r\n   'MT_UNBILLED_REVENUE' AS AUDIT_TABLE,\r\n   Current_Date AS AUDIT_DATE\r\n   FROM (\r\n   SEL PROCESSED_FISCAL_MTH, Cast(Sum(UNBILLED_REVENUE_AMT/PL_CONVERSION_RATE) AS DECIMAL(26,7)) AS UR_AMT  FROM $$FINLGLDB.MT_UNBILLED_REVENUE\r\nWHERE PROCESSED_FISCAL_MTH IN ( SELECT FISCAL_YEAR_MONTH_INT FROM  $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR WHERE CURRENT_FISCAL_MONTH_FLAG ='Y' \r\n UNION ALL\r\nSELECT FISCAL_YEAR_MONTH_INT FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR WHERE FISCAL_MONTH_END_DATE =Current_Date-1\r\n  AND PREVIOUS_FSCL_MONTH_FLAG IN 'Y' GROUP BY 1\r\n)\r\n   AND TRANSACTION_TYPE='SBP' \r\n   AND SUBSCRIPTION_LINE_TSV_KEY NOT IN 855532\r\n   GROUP BY 1) TGT\r\n   LEFT JOIN \r\n   (\r\n   SEL '1900' AS PROCESSED_FISCAL_MTH, Sum(UNBILLED_REV_LOCAL_AMT) AS UR_LOCAL_AMT FROM $$FINLGLVWDB.N_SUBSCRIPTION_LINE_TSV \r\n  WHERE SUBSCRIPTION_STATUS_CD IN ('ACTIVE','RENEWED','UNKNOWN','Not Active') AND  SUBSCRIPTION_LINE_TSV_KEY NOT IN 855532\r\n  GROUP BY 1 )SRC\r\nON 1=1\r\nUNION ALL\r\nSEL TGT.PROCESSED_FISCAL_MTH, Abs(Round (UR_LOCAL_AMT-UR_AMT)) AS REV_MISMATCH_AMT,\r\n   'SBP' AS AUDIT_TRXN_TYPE,\r\n   'MT_UNBILLED_REVENUE' AS AUDIT_TABLE,\r\n   Current_Date AS AUDIT_DATE\r\n   FROM (\r\n   SEL PROCESSED_FISCAL_MTH, Cast(Sum(DV_TOTAL_SALES_VALUE_AMT/PL_CONVERSION_RATE) AS DECIMAL(26,7)) AS UR_AMT  FROM $$FINLGLDB.MT_UNBILLED_REVENUE\r\nWHERE PROCESSED_FISCAL_MTH IN ( SELECT FISCAL_YEAR_MONTH_INT FROM  $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR WHERE CURRENT_FISCAL_MONTH_FLAG ='Y' \r\n UNION ALL\r\nSELECT FISCAL_YEAR_MONTH_INT FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR WHERE FISCAL_MONTH_END_DATE =Current_Date-1\r\n  AND PREVIOUS_FSCL_MONTH_FLAG IN 'Y' GROUP BY 1\r\n)\r\n   AND TRANSACTION_TYPE='SBP' \r\n   AND SUBSCRIPTION_LINE_TSV_KEY NOT IN 855532\r\n   GROUP BY 1) TGT\r\n   LEFT JOIN \r\n   (\r\n   SEL '1900' AS PROCESSED_FISCAL_MTH, Sum(TSV_LOCAL_AMT) AS UR_LOCAL_AMT FROM $$FINLGLVWDB.N_SUBSCRIPTION_LINE_TSV \r\n  WHERE SUBSCRIPTION_STATUS_CD IN ('ACTIVE','RENEWED','UNKNOWN','Not Active') AND  SUBSCRIPTION_LINE_TSV_KEY NOT IN 855532\r\n  GROUP BY 1 )SRC\r\nON 1=1",
