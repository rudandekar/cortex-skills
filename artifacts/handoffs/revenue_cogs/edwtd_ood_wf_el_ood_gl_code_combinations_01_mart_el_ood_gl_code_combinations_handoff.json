      "attributes": {
        "Sql Query": "SELECT \r\n      CAST(CODE_COMBINATION_ID AS BIGINT),\r\n      LAST_UPDATE_DATE ,\r\n      CAST(CHART_OF_ACCOUNTS_ID AS BIGINT) ,\r\n      ACCOUNT_TYPE,\r\n      ENABLED_FLAG ,\r\n      PRESERVE_FLAG,\r\n      CAST(SEGMENT1 AS VARCHAR(25)),\r\n      CAST(SEGMENT2 AS VARCHAR(25)),\r\n      CAST(SEGMENT3 AS VARCHAR(25)),\r\n      CAST(SEGMENT4 AS VARCHAR(25)),\r\n      CAST(SEGMENT5 AS VARCHAR(25)),\r\n      CAST(SEGMENT6 AS VARCHAR(25)),\r\n      START_DATE_ACTIVE,\r\n      END_DATE_ACTIVE,\r\n      CREATE_DATETIME,\r\n\t  CAST('OOD' AS VARCHAR(10)) AS IDENTIFIER\r\nFROM $$STGDB.ST_OOD_GL_CODE_COMBINATIONS SOAPT WHERE NOT EXISTS (SEL 1 FROM $$ETLVWDB.EL_OOD_GL_CODE_COMBINATIONS EAPT \r\nWHERE SOAPT.CODE_COMBINATION_ID= EAPT.CODE_COMBINATION_ID )\r\n\r\nUNION ALL\r\n\r\nSELECT \r\n      CODE_COMBINATION_ID,\r\n      LAST_UPDATE_DATE ,\r\n      CHART_OF_ACCOUNTS_ID ,\r\n      ACCOUNT_TYPE,\r\n      ENABLED_FLAG ,\r\n      PRESERVE_FLAG,\r\n      SEGMENT1,\r\n      SEGMENT2,\r\n      SEGMENT3,\r\n      SEGMENT4,\r\n      SEGMENT5,\r\n      SEGMENT6,\r\n      START_DATE_ACTIVE,\r\n      END_DATE_ACTIVE,\r\n      CREATE_DATETIME,\r\n\t  'FUSN' AS IDENTIFIER\t  \r\nFROM $$STGDB.ST_OOD_FUSN_GL_CODE_COMBINATIONS SOFAPT WHERE NOT EXISTS (SEL 1 FROM $$ETLVWDB.EL_OOD_GL_CODE_COMBINATIONS EAPT \r\nWHERE SOFAPT.CODE_COMBINATION_ID= EAPT.CODE_COMBINATION_ID )",
