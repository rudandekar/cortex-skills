      "attributes": {
        "Sql Query": "SELECT \r\n\r\n'N' AS SOURCE_DELETE_FLAG,\r\nS.ASSIGNMENT_MODE,\r\nS.COPY_FROM_MINX_ORDER_NUMBER,\r\nS.COPY_FROM_SOURCE_HEADER_ID,\r\nS.COPY_FROM_SOURCE_TYPE,\r\nS.CREATED_BY,\r\nS.CREATION_DATE,\r\nS.DEAL_SCMT_ID,\r\nS.GES_UPDATE_DATE,\r\nS.GLOBAL_NAME,\r\nS.HEADER_SEQ_ID,\r\nS.INTERFACED_TO_CDW_FLAG,\r\nS.LAST_UPDATED_BY,\r\nS.LAST_UPDATE_DATE,\r\nS.LAST_UPDATE_LOGIN,\r\nS.MINX_ORDER_NUMBER,\r\nS.SALESREP_ID,\r\nS.SALES_CREDIT_TYPE_ID,\r\nS.SOURCE_HEADER_ID,\r\nS.SOURCE_TYPE,\r\nS.SPLIT_PERCENT,\r\nS.TERRITORY_ID\r\nFROM \r\n$$STGDB.ST_OM_CSM_HDR_SC_NONAPPLD S \r\n\r\n\r\nUNION ALL\r\n\r\nSELECT \r\n\r\n'Y' AS SOURCE_DELETE_FLAG,\r\nSD.ASSIGNMENT_MODE,\r\nSD.COPY_FROM_MINX_ORDER_NUMBER,\r\nSD.COPY_FROM_SOURCE_HEADER_ID,\r\nSD.COPY_FROM_SOURCE_TYPE,\r\nSD.CREATED_BY,\r\nSD.CREATION_DATE,\r\nSD.DEAL_SCMT_ID,\r\nSD.GES_DELETE_DATE,\r\nSD.GLOBAL_NAME,\r\nSD.HEADER_SEQ_ID,\r\nSD.INTERFACED_TO_CDW_FLAG,\r\nSD.LAST_UPDATED_BY,\r\nSD.LAST_UPDATE_DATE,\r\nSD.LAST_UPDATE_LOGIN,\r\nSD.MINX_ORDER_NUMBER,\r\nSD.SALESREP_ID,\r\nSD.SALES_CREDIT_TYPE_ID,\r\nSD.SOURCE_HEADER_ID,\r\nSD.SOURCE_TYPE,\r\nSD.SPLIT_PERCENT,\r\nSD.TERRITORY_ID\r\nFROM \r\n$$STGDB.ST_OM_CSM_HDR_SC_NONAPPLD_DEL  SD \r\n\r\nWHERE  NOT EXISTS\r\n\r\n(SELECT S.GLOBAL_NAME, S.HEADER_SEQ_ID FROM $$STGDB.ST_OM_CSM_HDR_SC_NONAPPLD S\r\nWHERE S.HEADER_SEQ_ID=SD.HEADER_SEQ_ID\r\nAND  S.GLOBAL_NAME = SD.GLOBAL_NAME\r\nAND  S.SOURCE_TYPE=SD.SOURCE_TYPE\r\n)\r\n\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY HEADER_SEQ_ID,GLOBAL_NAME,GES_DELETE_DATE ORDER BY GES_DELETE_DATE DESC)=1",
