      "attributes": {
        "Sql Query": "SELECT \r\n DRVD.REVENUE_MEASURE_KEY           ,\r\n DRVD.PRODUCT_KEY                   ,\r\n DRVD.DV_FISCAL_YEAR_MTH_NUMBER_INT ,\r\n DRVD.REV_MEASURE_TRANS_TYPE_CD     ,\r\n DRVD.DV_CORPORATE_REVENUE_FLG      ,\r\n DRVD.DV_COMP_US_NET_PRICE_AMT      ,\r\n DRVD.DV_COMP_US_NET_LIST_PRICE_AMT ,\r\n DRVD.DV_COMP_US_GROSS_LIST_PRICE_AM,\r\n DRVD.DV_COMP_US_NET_COST_AMT       ,\r\n DRVD.DV_COMP_US_GROSS_REV_AMT      ,\r\n DRVD.DV_COMP_US_NET_REV_AMT        ,\r\n DRVD.DV_COMP_US_2TIER_CMDM_AMT     ,\r\n DRVD.DV_COMP_US_GROSS_COST_AMT     ,\r\n DRVD.DV_COMP_US_STANDARD_PRICE_AMT ,\r\n DRVD.EDW_CREATE_USER               ,\r\n DRVD.EDW_CREATE_DATETIME           ,\r\n DRVD.EDW_UPDATE_USER               ,\r\n DRVD.EDW_UPDATE_DATETIME           ,\r\n DRVD.BK_HANDSHAKE_BUNDLE_TYPE_NAME ,\r\n /* OA Q1FY15 changes */\r\n DRVD.DV_ATTRIBUTION_CD,\r\n DRVD.DV_PRODUCT_KEY\r\n /* OA Q1FY15 changes */\r\n,DRVD.POB_TYPE_CD /* NRS MPOB Change */\r\n ,DRVD.NRS_TRANSITION_FLG /*Added as part of NRS PI3 changes*/\r\n,DRVD.DD_COMP_US_ORIG_LIST_PRICE\r\n,DRVD.DD_COMP_US_ORIG_EXT_LIST_PRICE \r\n FROM(\r\n SELECT \r\n NINVM.REVENUE_MEASURE_KEY           ,\r\n NHBP.HANDSHAKE_BUNDLE_PRODUCT_KEY PRODUCT_KEY                   ,\r\n NINVM.DV_FISCAL_YEAR_MTH_NUMBER_INT ,\r\n NINVM.REV_MEASURE_TRANS_TYPE_CD     ,\r\n NINVM.DV_CORPORATE_REVENUE_FLG      ,\r\n NINVM.DV_COMP_US_NET_PRICE_AMT      ,\r\n NINVM.DV_COMP_US_NET_LIST_PRICE_AMT ,\r\n NINVM.DV_COMP_US_GROSS_LIST_PRICE_AM,\r\n NINVM.DV_COMP_US_NET_COST_AMT       ,\r\n NINVM.DV_COMP_US_GROSS_REV_AMT      ,\r\n NINVM.DV_COMP_US_NET_REV_AMT        ,\r\n NINVM.DV_COMP_US_2TIER_CMDM_AMT     ,\r\n NINVM.DV_COMP_US_GROSS_COST_AMT     ,\r\n NINVM.DV_COMP_US_STANDARD_PRICE_AMT ,\r\n NINVM.EDW_CREATE_USER               ,\r\n NINVM.EDW_CREATE_DATETIME           ,\r\n NINVM.EDW_UPDATE_USER               ,\r\n NINVM.EDW_UPDATE_DATETIME,           \r\n NHBP.BK_HANDSHAKE_BUNDLE_TYPE_NAME,\r\n /* OA Q1FY15 changes */\r\n NINVM.DV_ATTRIBUTION_CD             ,\r\n NINVM.PRODUCT_KEY DV_PRODUCT_KEY\r\n /* OA Q1FY15 changes */\r\n,NINVM.POB_TYPE_CD \r\n ,NINVM.NRS_TRANSITION_FLG /*Added as part of NRS PI3 changes*/\r\n,NINVM.DD_COMP_US_ORIG_LIST_PRICE\r\n,NINVM.DD_COMP_US_ORIG_EXT_LIST_PRICE \r\n FROM $$FINLGLVWDB.N_INV_REV_MEASURE NINVM\r\n INNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR FISYM\r\n ON(NINVM.DV_FISCAL_YEAR_MTH_NUMBER_INT =FISYM.FISCAL_YEAR_MONTH_INT)\r\n INNER JOIN  $$INVFLMTVWDB.N_HNDSHK_BUNDLE_PRODUCT NHBP\r\n ON (NINVM.PRODUCT_KEY=NHBP.HANDSHAKE_BUNDLE_PRODUCT_KEY AND NHBP.BK_ALLOCATION_TYPE_CD='ACTUAL' )\r\n WHERE NINVM.EDW_UPDATE_DATETIME>(SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS WHERE JOB_STREAM_ID='wf_MT_ATTR_INV_REV_MEASURE' AND JOB_GROUP_ID='EDWTD_BNDL_ATTR_REVM')\r\n AND FISYM.FISCAL_MONTH_AGE IN (1,0,-1)      \r\n AND NINVM.REV_MEASURE_TRANS_TYPE_CD NOT IN('IND_ADJ','DRCT_AS_T')     /* DRCT_AS_T  is  Added   */\r\n AND NINVM.DV_CORPORATE_REVENUE_FLG      ='Y'\r\n AND NINVM.DV_ATTRIBUTION_CD = 'STANDALONE' /* OA Q1FY15 changes */\r\n \r\n UNION ALL\r\n SELECT \r\n NINVM.REVENUE_MEASURE_KEY           ,\r\n NHBP.HANDSHAKE_BUNDLE_PRODUCT_KEY PRODUCT_KEY                   ,\r\n NINVM.DV_FISCAL_YEAR_MTH_NUMBER_INT ,\r\n NINVM.REV_MEASURE_TRANS_TYPE_CD     ,\r\n NINVM.DV_CORPORATE_REVENUE_FLG      ,\r\n NINVM.DV_COMP_US_NET_PRICE_AMT      ,\r\n NINVM.DV_COMP_US_NET_LIST_PRICE_AMT ,\r\n NINVM.DV_COMP_US_GROSS_LIST_PRICE_AM,\r\n NINVM.DV_COMP_US_NET_COST_AMT       ,\r\n NINVM.DV_COMP_US_GROSS_REV_AMT      ,\r\n NINVM.DV_COMP_US_NET_REV_AMT        ,\r\n NINVM.DV_COMP_US_2TIER_CMDM_AMT     ,\r\n NINVM.DV_COMP_US_GROSS_COST_AMT     ,\r\n NINVM.DV_COMP_US_STANDARD_PRICE_AMT ,\r\n NINVM.EDW_CREATE_USER               ,\r\n NINVM.EDW_CREATE_DATETIME           ,\r\n NINVM.EDW_UPDATE_USER               ,\r\n NINVM.EDW_UPDATE_DATETIME           ,\r\n NHBP.BK_HANDSHAKE_BUNDLE_TYPE_NAME,\r\n /* OA Q1FY15 changes */\r\n NINVM.DV_ATTRIBUTION_CD             ,\r\n NINVM.PRODUCT_KEY DV_PRODUCT_KEY\r\n /* OA Q1FY15 changes */\r\n ,NINVM.POB_TYPE_CD \r\n  ,NINVM.NRS_TRANSITION_FLG /*Added as part of NRS PI3 changes*/\r\n,NINVM.DD_COMP_US_ORIG_LIST_PRICE\r\n,NINVM.DD_COMP_US_ORIG_EXT_LIST_PRICE \r\n FROM $$FINLGLVWDB.N_INV_REV_MEASURE NINVM\r\n INNER JOIN $$INVFLMTVWDB.N_HNDSHK_BUNDLE_PRODUCT NHBP\r\n ON (NINVM.PRODUCT_KEY=NHBP.HANDSHAKE_BUNDLE_PRODUCT_KEY AND NHBP.BK_ALLOCATION_TYPE_CD='ACTUAL')\r\n WHERE  NINVM.REV_MEASURE_TRANS_TYPE_CD ='IND_ADJ'\r\n AND NINVM.DV_CORPORATE_REVENUE_FLG      ='Y'\r\n AND NINVM.DV_FISCAL_YEAR_MTH_NUMBER_INT IN  (SELECT FISCAL_MONTH_ID FROM $$STGDB.ST_AE_OPEN_PERIOD WHERE OPEN_FLAG='Y')\r\n AND NINVM.BK_ADJUSTMENT_TYPE_CD NOT IN ('GL ADJUSTMENTS AS SUBSCRIPTION','GL ADJUSTMENTS - AS TRANSACTIO','R2A COGS')\r\n AND NINVM.DV_ATTRIBUTION_CD = 'STANDALONE' /* OA Q1FY15 changes */\r\n \r\n /* DRCT_AS_T  is  added  as part of june  release 2012*/\r\n \r\n UNION ALL\r\n SELECT \r\n NINVM.REVENUE_MEASURE_KEY           ,\r\n NHBP.HANDSHAKE_BUNDLE_PRODUCT_KEY PRODUCT_KEY                   ,\r\n NINVM.DV_FISCAL_YEAR_MTH_NUMBER_INT ,\r\n NINVM.REV_MEASURE_TRANS_TYPE_CD     ,\r\n NINVM.DV_CORPORATE_REVENUE_FLG      ,\r\n NINVM.DV_COMP_US_NET_PRICE_AMT      ,\r\n NINVM.DV_COMP_US_NET_LIST_PRICE_AMT ,\r\n NINVM.DV_COMP_US_GROSS_LIST_PRICE_AM,\r\n NINVM.DV_COMP_US_NET_COST_AMT       ,\r\n NINVM.DV_COMP_US_GROSS_REV_AMT      ,\r\n NINVM.DV_COMP_US_NET_REV_AMT        ,\r\n NINVM.DV_COMP_US_2TIER_CMDM_AMT     ,\r\n NINVM.DV_COMP_US_GROSS_COST_AMT     ,\r\n NINVM.DV_COMP_US_STANDARD_PRICE_AMT ,\r\n NINVM.EDW_CREATE_USER               ,\r\n NINVM.EDW_CREATE_DATETIME           ,\r\n NINVM.EDW_UPDATE_USER               ,\r\n NINVM.EDW_UPDATE_DATETIME           ,\r\n NHBP.BK_HANDSHAKE_BUNDLE_TYPE_NAME  ,\r\n /* OA Q1FY15 changes */\r\n NINVM.DV_ATTRIBUTION_CD             ,\r\n NINVM.PRODUCT_KEY DV_PRODUCT_KEY\r\n /* OA Q1FY15 changes */\r\n ,NINVM.POB_TYPE_CD \r\n  ,NINVM.NRS_TRANSITION_FLG /*Added as part of NRS PI3 changes*/\r\n,NINVM.DD_COMP_US_ORIG_LIST_PRICE\r\n,NINVM.DD_COMP_US_ORIG_EXT_LIST_PRICE \r\n FROM $$FINLGLVWDB.N_INV_REV_MEASURE NINVM\r\n INNER JOIN $$INVFLMTVWDB.N_HNDSHK_BUNDLE_PRODUCT NHBP\r\n ON (NINVM.PRODUCT_KEY=NHBP.HANDSHAKE_BUNDLE_PRODUCT_KEY\r\n  AND NHBP.BK_ALLOCATION_TYPE_CD ='ACTUAL' )\r\n INNER JOIN $$STGDB.WI_ATTR_INV_FISCL_MTH_MAX_BND   MAX1\r\n ON NINVM.DV_FISCAL_YEAR_MTH_NUMBER_INT= MAX1.DV_FISCAL_YEAR_MTH_NUMBER_INT \r\n INNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR FISYM\r\n  ON (NINVM.DV_FISCAL_YEAR_MTH_NUMBER_INT =FISYM.FISCAL_YEAR_MONTH_INT)\r\n WHERE  NINVM.REV_MEASURE_TRANS_TYPE_CD IN ('DRCT_AS_T', 'IND_ADJ')\r\n  AND NINVM.DV_CORPORATE_REVENUE_FLG      ='Y'\r\n  AND NINVM.BK_ADJUSTMENT_TYPE_CD  IN ('GL ADJUSTMENTS AS SUBSCRIPTION','GL ADJUSTMENTS - AS TRANSACTIO','UNKNOWN','R2A COGS') \r\n  AND FISYM.FISCAL_MONTH_AGE IN (1,0,-1)  \r\n  AND NINVM.DV_ATTRIBUTION_CD = 'STANDALONE' /* OA Q1FY15 changes */\r\n ) DRVD",
        "User Defined Join": "",
