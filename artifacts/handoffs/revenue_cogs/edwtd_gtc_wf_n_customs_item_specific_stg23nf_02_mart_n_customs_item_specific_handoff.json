        }
      ],
      "attributes": {
        "Sql Query": "SELECT \r\nIQ.SPECIFIC_NAME,\r\nIQ.DESCRIPTION, \r\nIQ.SOURCE_DELETED_FLAG,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER EDW_UPDATE_USER,\r\nIQ.SK_SPECIFIC_ID_INT,\r\nIQ.CUSTOMS_ITEM_SPECIFIC_KEY,\r\nIQ.ITEM_CLSFCTN_METHOD_CD\r\nFROM (\r\n  SELECT ST.SPECIFIC_NAME,\r\n  DESCRIPTION, \r\n  (CASE WHEN ST.ACTIVE_FLAG =  'Y' THEN 'N' ELSE 'Y' END) AS SOURCE_DELETED_FLAG,\r\n   SM.SK_SPECIFIC_ID_INT,\r\n   SM.CUSTOMS_ITEM_SPECIFIC_KEY,\r\n   (CASE WHEN ST.DATA_SOURCE_ID=1 THEN 'CCAP' ELSE 'SPECIFIC' END) AS ITEM_CLSFCTN_METHOD_CD\r\nFROM $$STGDB.ST_XXCFI_CB_SPECIFICS ST\r\nINNER JOIN $$ETLVWDB.SM_CUSTOMS_ITEM_SPECIFIC SM\r\nON (ST.SPECIFIC_ID=SM.SK_SPECIFIC_ID_INT)\r\n) IQ \r\nwhere NOT EXISTS \r\n( SELECT 1 \r\nFROM   $$FINLGLVWDB.N_CUSTOMS_ITEM_SPECIFIC\r\nWHERE  CUSTOMS_ITEM_SPECIFIC_KEY = IQ.CUSTOMS_ITEM_SPECIFIC_KEY)",
