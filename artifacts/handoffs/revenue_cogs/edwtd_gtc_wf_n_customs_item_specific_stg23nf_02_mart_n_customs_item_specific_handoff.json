        {
          "name": "EDW_CREATE_USER",
          "datatype": "string",
          "porttype": "INPUT/OUTPUT",
          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "SELECT \r\n                (RANK() OVER (ORDER BY SXRI.SK_SPECIFIC_ID_INT) + SM.MAX_KEY) AS CUSTOMS_ITEM_SPECIFIC_KEY,\r\n                SXRI.SK_SPECIFIC_ID_INT,\r\n                CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\n                USER AS EDW_CREATE_USER\r\nFROM \r\n                (\r\n                                SELECT \r\n                                                WIC.SPECIFIC_ID AS SK_SPECIFIC_ID_INT\r\n                                                FROM $$STGDB.ST_XXCFI_CB_SPECIFICS WIC\r\n                                \r\n                ) SXRI,\r\n                (SELECT COALESCE(MAX(CUSTOMS_ITEM_SPECIFIC_KEY),0) AS MAX_KEY\r\n                FROM     $$ETLVWDB.SM_CUSTOMS_ITEM_SPECIFIC) SM\r\n                WHERE 1=1\r\n                AND NOT EXISTS\r\n                ( SELECT 1\r\n                   FROM $$ETLVWDB.SM_CUSTOMS_ITEM_SPECIFIC SM1\r\n                   WHERE  SXRI.SK_SPECIFIC_ID_INT = SM1.SK_SPECIFIC_ID_INT\r\n                                                                \r\n                )",
        "User Defined Join": "",
