      "attributes": {
        "Sql Query": "SELECT\r\n\r\nW.AR_TRX_CR_ASGN_NON_APPLIED_KEY,\r\nW.SOURCE_DELETED_FLG,\r\nW.SALES_COMMISSION_PCT,          \r\nW.SOURCE_LAST_UPDATE_DTM,\r\nW.SOURCE_CREATE_DTM,       \r\nW.SALES_REP_NUM,         \r\nW.SALES_TERRITORY_KEY,\r\nW.SALES_CREDIT_TYPE_CD,          \r\nW.AR_TRANSACTION_KEY,         \r\nW.SK_HEADER_SEQUENCE_ID_INT,     \r\nW.SS_CD,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS  EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' ACTION_CODE,\r\nCASE WHEN NATTRX.AR_TRX_CR_ASGN_NON_APPLIED_KEY IS NULL THEN 'I' ELSE 'U' END AS DML_TYPE\r\n\r\nFROM\r\n(\r\nSELECT \r\n\r\nSM.AR_TRX_CR_ASGN_NON_APPLIED_KEY \t\t\tAS \tAR_TRX_CR_ASGN_NON_APPLIED_KEY,\r\nWI.SOURCE_DELETED_FLG\t\t\t\t\t\t\tAS SOURCE_DELETED_FLG  , \r\nWI.SPLIT_PERCENT \t\t\tAS SALES_COMMISSION_PCT,\r\nWI.LAST_UPDATE_DATE\tAS SOURCE_LAST_UPDATE_DTM,\r\nWI.CREATION_DATE \t\t\tAS SOURCE_CREATE_DTM,\r\nESR.SALES_REP_NUMBER \t\t\t\tAS SALES_REP_NUM,\r\nEST.SALES_TERRITORY_KEY\t\t\tAS SALES_TERRITORY_KEY ,\r\nESCT.NAME\t\t\t\t\t\t\t\t\t\tAS SALES_CREDIT_TYPE_CD,\r\nNAT.AR_TRX_KEY\t\t\t\t\t\tAS AR_TRANSACTION_KEY,\r\nWI.HEADER_SEQ_ID \t\t\tAS SK_HEADER_SEQUENCE_ID_INT,\r\nCASE WHEN WI.GLOBAL_NAME ='UO' THEN 'QTC' \r\n                      WHEN WI.GLOBAL_NAME ='BO' THEN 'BV' END  AS SS_CD\r\nFROM\r\n\r\n$$STGDB.WI_AR_TRX_CR_ASGN_NON_APP_TRX WI,\r\n$$TRANSLATIONDB.SM_AR_TRX_CR_ASGN_NON_APLD_TRX SM,\r\n$$ETLVWDB.EL_SALES_REP\t\tESR,\r\n$$ETLVWDB.EL_SALES_TERRITORY\t\tEST,\r\n$$ETLVWDB.EL_SALES_CREDIT_TYPES \t\tESCT,\r\n$$FINLGLVWDB.N_AR_TRX \tNAT\r\n\r\nWHERE\r\n\r\nWI.HEADER_SEQ_ID=SM.SK_HEADER_SEQUENCE_ID_INT\r\nAND WI.GLOBAL_NAME=SM.SS_CD\r\n\r\nAND WI.SALESREP_ID=ESR.SALES_REP_ID\r\nAND WI.GLOBAL_NAME= ESR.GLOBAL_NAME\r\n\r\nAND WI.TERRITORY_ID=EST.TERRITORY_ID\r\nAND WI.GLOBAL_NAME= EST.GLOBAL_NAME\r\n\r\nAND WI.SALES_CREDIT_TYPE_ID=ESCT.SK_CREDIT_TYPE_ID\r\nAND WI.GLOBAL_NAME= ESCT.GLOBAL_NAME\r\n\r\nAND WI.SOURCE_HEADER_ID=NAT.SK_CUSTOMER_TRX_ID_LINT\r\nAND CASE WHEN WI.GLOBAL_NAME ='UO' THEN 'QTC' \r\n                      WHEN WI.GLOBAL_NAME ='BO' THEN 'BV' ELSE NULL END  = NAT.SS_CODE\r\n\r\nUNION ALL\r\n\r\nSELECT \r\n\r\n EX_OM.AR_TRX_CR_ASGN_NON_APPLIED_KEY,\r\n EX_OM.SOURCE_DELETED_FLG\t\t\t\t\t\t\tAS SOURCE_DELETED_FLG  , \r\n EX_OM.SPLIT_PERCENT \t\t\tAS SALES_COMMISSION_PCT,\r\n EX_OM.LAST_UPDATE_DATE\tAS SOURCE_LAST_UPDATE_DTM,\r\n EX_OM.CREATION_DATE \t\t\tAS SOURCE_CREATE_DTM,\r\nESR.SALES_REP_NUMBER \t\t\t\tAS SALES_REP_NUM,\r\nEST.SALES_TERRITORY_KEY\t\t\tAS SALES_TERRITORY_KEY ,\r\nESCT.NAME\t\t\t\t\t\t\t\t\t\tAS SALES_CREDIT_TYPE_CD,\r\nNAT.AR_TRX_KEY\t\t\t\t\t\tAS AR_TRANSACTION_KEY,\r\n EX_OM.HEADER_SEQ_ID \t\t\tAS SK_HEADER_SEQUENCE_ID_INT,\r\nCASE WHEN  EX_OM.GLOBAL_NAME ='UO' THEN 'QTC' \r\n                      WHEN EX_OM.GLOBAL_NAME ='BO' THEN 'BV' END  AS SS_CD\r\nFROM\r\n\r\n$$EXCEPDB.EX_AR_TRX_CR_ASGN_NON_APP_TRX EX_OM,\r\n$$ETLVWDB.EL_SALES_REP\t\tESR,\r\n$$ETLVWDB.EL_SALES_TERRITORY\t\tEST,\r\n$$ETLVWDB.EL_SALES_CREDIT_TYPES \t\tESCT,\r\n$$FINLGLVWDB.N_AR_TRX \tNAT\r\n\r\nWHERE\r\nEX_OM.SALESREP_ID=ESR.SALES_REP_ID\r\nAND  EX_OM.GLOBAL_NAME= ESR.GLOBAL_NAME\r\n\r\nAND  EX_OM.TERRITORY_ID=EST.TERRITORY_ID\r\nAND  EX_OM.GLOBAL_NAME= EST.GLOBAL_NAME\r\n\r\nAND  EX_OM.SALES_CREDIT_TYPE_ID=ESCT.SK_CREDIT_TYPE_ID\r\nAND  EX_OM.GLOBAL_NAME= ESCT.GLOBAL_NAME\r\n\r\nAND  EX_OM.SOURCE_HEADER_ID=NAT.SK_CUSTOMER_TRX_ID_LINT\r\nAND CASE WHEN  EX_OM.GLOBAL_NAME ='UO' THEN 'QTC' \r\n                      WHEN  EX_OM.GLOBAL_NAME ='BO' THEN 'BV' ELSE NULL END  = NAT.SS_CODE\r\n) W\r\n\r\nLEFT JOIN\r\n$$FINLGLVWDB.N_AR_TRX_CR_ASGN_NON_APPLD_TRX  NATTRX\r\nON W.AR_TRX_CR_ASGN_NON_APPLIED_KEY = NATTRX.AR_TRX_CR_ASGN_NON_APPLIED_KEY",
