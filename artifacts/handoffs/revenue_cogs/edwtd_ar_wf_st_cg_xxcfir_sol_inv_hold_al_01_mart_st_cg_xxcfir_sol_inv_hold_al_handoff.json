      "attributes": {
        "Sql Query": "SELECT \r\n 1 AS BATCH_ID,\r\n CXSIHA.DB_SOURCE_NAME, \r\n CXSIHA.ORDER_NUMBER, \r\n CXSIHA.SO_LINE_ID,\r\n CXSIHA.INV_HOLD, \r\n CXSIHA.ORG_ID, \r\n CXSIHA.TRX_NUMBER, \r\n CXSIHA.TRX_DATE, \r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE1,\r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE2, \r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE3, \r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE4, \r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE5, \r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE6,\r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE7,\r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE8,\r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE9, \r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE10, \r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE11,\r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE12,\r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE13, \r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE14, \r\n CXSIHA.INTERFACE_LINE_ATTRIBUTE15,\r\n CXSIHA.CREATION_DATE, \r\n CXSIHA.CREATED_BY, \r\n CXSIHA.LAST_UPDATE_DATE, \r\n CXSIHA.LAST_UPDATED_BY, \r\n CXSIHA.LAST_UPDATE_LOGIN,\r\n CXSIHA.SOURCE_COMMIT_TIME,\r\n 'CG' AS GLOBAL_NAME,  \r\n CURRENT_TIMESTAMP(0) AS CREATE_DATETIME, \r\n 'I' AS ACTION_CODE \r\nFROM\r\n( \r\n SELECT * FROM $$NRTACCUMVWDB.CG1_XXCFIR_SOL_INV_HOLD_ALL\r\n WHERE\r\n SOURCE_COMMIT_TIME >= '$$LastExtractDate'\r\n AND ORG_ID NOT IN (SEL ORG_ID FROM $$ETLVWDB.EL_CG1_ENABLED_ORG)\r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY DB_SOURCE_NAME, SO_LINE_ID ORDER BY REFRESH_DATETIME DESC)=1\r\n)CXSIHA\r\nWHERE CXSIHA.SOURCE_DML_TYPE <> 'DELETE'",
