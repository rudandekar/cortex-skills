      ],
      "attributes": {
        "Sql Query": "SELECT MT_UN.PROCESSED_FISCAL_MTH,\r\nABS(ROUND(SUM(MT_UN.UNBILLED_REVENUE + MT_UN_RSTD.RSTD_UNBILLED_REVENUE))) AS UNBILLED_AMT_MISMATCH ,\r\n'RSTD_UNBILLED' AS AUDIT_TRXN_TYPE,\r\n'MT_RSTD_UNBILLED_REVENUE' AS AUDIT_TABLE,\r\n   Current_Date AS AUDIT_DATE\r\nFROM\r\n(SELECT MT.PROCESSED_FISCAL_MTH AS PROCESSED_FISCAL_MTH,MT.TRANSACTION_TYPE AS TRANSACTION_TYPE,\r\nSUM(MT.UNBILLED_REVENUE_AMT) AS UNBILLED_REVENUE\r\nFROM $$FINLGLVWDB.MT_UNBILLED_REVENUE MT\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nON MT.PROCESSED_FISCAL_MTH =RFM.FISCAL_YEAR_MONTH_INT\r\nAND (CURRENT_FISCAL_MONTH_FLAG     IN 'Y' OR PREVIOUS_FSCL_MONTH_FLAG    IN 'Y')\r\n--WHERE PROCESSED_FISCAL_MTH=202002 \r\nGROUP BY 1,2) MT_UN\r\nLEFT JOIN\r\n(SELECT MT.PROCESSED_FISCAL_MTH AS PROCESSED_FISCAL_MTH ,MT.TRANSACTION_TYPE AS TRANSACTION_TYPE,\r\nSUM(MT.UNBILLED_REVENUE_AMT)*-1 AS RSTD_UNBILLED_REVENUE \r\nFROM $$FINLGLVWDB.MT_RSTD_UNBILLED_REVENUE MT\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM\r\nON MT.PROCESSED_FISCAL_MTH =RFM.FISCAL_YEAR_MONTH_INT\r\nAND (CURRENT_FISCAL_MONTH_FLAG     IN 'Y' OR PREVIOUS_FSCL_MONTH_FLAG    IN 'Y')\r\n--WHERE PROCESSED_FISCAL_MTH=202002 \r\nGROUP BY 1,2) MT_UN_RSTD\r\nON MT_UN.PROCESSED_FISCAL_MTH=MT_UN_RSTD.PROCESSED_FISCAL_MTH\r\nAND MT_UN.TRANSACTION_TYPE=MT_UN_RSTD.TRANSACTION_TYPE\r\nGROUP BY 1",
        "User Defined Join": "",
