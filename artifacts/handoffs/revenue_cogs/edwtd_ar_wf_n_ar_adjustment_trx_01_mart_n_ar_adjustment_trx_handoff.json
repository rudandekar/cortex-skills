        "Sql Query": "SELECT \r\n WAAT.BK_AR_ADJ_NUMBER,\r\n WAAT.BK_COMPANY_CODE,\r\n WAAT.BK_SET_OF_BOOKS_KEY,\r\n WAAT.AR_ADJ_TRX_REASON_CODE,\r\n WAAT.GL_DATE,\r\n WAAT.GL_POSTED_DATE,\r\n WAAT.ADJUSTMENT_SOURCE_TYPE_CODE,\r\n WAAT.TRANSACTION_DATETIME,\r\n WAAT.AR_ADJ_TRX_FUNCTIONAL_AMT, \r\n WAAT.AR_ADJ_TRX_TRANSACTIONAL_AMT, \r\n WAAT.BK_AR_ADJ_TYPE_CODE, \r\n WAAT.AR_TRX_KEY,\r\n WAAT.SK_ADJUSTMENT_ID_INT,\r\n WAAT.SS_SOURCE_APPLICATION_CODE,\r\n WAAT.SS_CODE,\r\n WAAT.GENERAL_LEDGER_ACCOUNT_KEY,\r\n WAAT.EDW_CREATE_USER, \r\n WAAT.EDW_UPDATE_USER,\r\n WAAT.EDW_CREATE_DATETIME,\r\n WAAT.EDW_UPDATE_DATETIME,\r\n WAAT.AR_ADJ_TRX_ITEM_USD_AMT,\r\n WAAT.AR_ADJ_TRX_ITEM_TRXL_AMT,\r\n WAAT.AR_ADJ_TRX_FREIGHT_USD_AMT,\r\n WAAT.AR_ADJ_TRX_FREIGHT_TRXL_AMT,\r\n WAAT.AR_ADJ_TRX_TAX_USD_AMT,\r\n WAAT.AR_ADJ_TRX_TAX_TRXN_AMT, \r\n WAAT.AR_TYPE_CD,\r\n  WAAT.AR_ADJ_TRX_USD_AMT, \r\n WAAT.AR_ADJUSTMENT_STATUS_CD \r\n FROM\r\n  $$WORKDB.W_AR_ADJUSTMENT_TRX WAAT \r\n WHERE NOT EXISTS (SELECT 1 FROM $$FINLGLVWDB.N_AR_ADJUSTMENT_TRX NAAT\r\n   WHERE WAAT.BK_AR_ADJ_NUMBER = NAAT.BK_AR_ADJ_NUMBER\r\n   AND  WAAT.BK_COMPANY_CODE = NAAT.BK_COMPANY_CODE\r\n   AND  WAAT.BK_SET_OF_BOOKS_KEY = NAAT.BK_SET_OF_BOOKS_KEY\r\n   AND  WAAT.SS_CODE = NAAT.SS_CODE)",
