      "attributes": {
        "Sql Query": "SELECT STG_CG1_XXGCO_OE_ORDER_CONTACT.HEADER_ID, TRANSLATE(STG_CG1_XXGCO_OE_ORDER_CONTACT.LAST_NAME using unicode_to_latin with error) AS LAST_NAME, TRANSLATE(STG_CG1_XXGCO_OE_ORDER_CONTACT.FIRST_NAME using unicode_to_latin with error) AS FIRST_NAME, TRANSLATE(STG_CG1_XXGCO_OE_ORDER_CONTACT.EMAIL_ADDRESS using unicode_to_latin with error) AS EMAIL_ADDRESS, \r\nSTG_CG1_XXGCO_OE_ORDER_CONTACT.CREATION_DATE, STG_CG1_XXGCO_OE_ORDER_CONTACT.CREATED_BY, STG_CG1_XXGCO_OE_ORDER_CONTACT.LAST_UPDATED_BY, STG_CG1_XXGCO_OE_ORDER_CONTACT.LAST_UPDATE_DATE, \r\nTRANSLATE(STG_CG1_XXGCO_OE_ORDER_CONTACT.CONTACT_TYPE using unicode_to_latin with error) AS CONTACT_TYPE, TRANSLATE(STG_CG1_XXGCO_OE_ORDER_CONTACT.TELEPHONE using unicode_to_latin with error) AS TELEPHONE, TRANSLATE(STG_CG1_XXGCO_OE_ORDER_CONTACT.TRAIL_FILE_NAME using unicode_to_latin with error) AS TRAIL_FILE_NAME, TRANSLATE(STG_CG1_XXGCO_OE_ORDER_CONTACT.SOURCE_DML_TYPE using unicode_to_latin with error) AS SOURCE_DML_TYPE, \r\nSTG_CG1_XXGCO_OE_ORDER_CONTACT.SOURCE_COMMIT_TIME, STG_CG1_XXGCO_OE_ORDER_CONTACT.REFRESH_DATETIME \r\nFROM\r\n $$ACCUMSTGDB.STG_CG1_XXGCO_OE_ORDER_CONTACT STG_CG1_XXGCO_OE_ORDER_CONTACT,\r\n (\r\n select HEADER_ID ,translate(LAST_NAME using unicode_to_latin with error) as last_name ,translate(FIRST_NAME using unicode_to_latin with error) as FIRST_NAME,CONTACT_TYPE ,REFRESH_DATETIME from $$ACCUMSTGDB.STG_CG1_XXGCO_OE_ORDER_CONTACT\r\n minus\r\n select HEADER_ID ,LAST_NAME ,FIRST_NAME ,CONTACT_TYPE ,REFRESH_DATETIME from $$NRTACCUMDB.CG1_XXGCO_OE_ORD_CONT\r\n ) ACM\r\n  where \r\n ACM.HEADER_ID = STG_CG1_XXGCO_OE_ORDER_CONTACT.HEADER_ID  and  COALESCE(ACM.LAST_NAME,'UNK') = COALESCE((translate(STG_CG1_XXGCO_OE_ORDER_CONTACT.LAST_NAME using unicode_to_latin with error)),'UNK')  \r\n  and COALESCE(ACM.FIRST_NAME,'UNK')=COALESCE((translate(STG_CG1_XXGCO_OE_ORDER_CONTACT.FIRST_NAME using unicode_to_latin with error)),'UNK')  and ACM.CONTACT_TYPE=STG_CG1_XXGCO_OE_ORDER_CONTACT.CONTACT_TYPE and ACM.REFRESH_DATETIME=STG_CG1_XXGCO_OE_ORDER_CONTACT.REFRESH_DATETIME",
