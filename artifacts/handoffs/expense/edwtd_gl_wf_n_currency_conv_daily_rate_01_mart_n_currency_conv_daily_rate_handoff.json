      "attributes": {
        "Sql Query": "SELECT \r\n WCCDR.BK_FROM_CURRENCY_CODE,\r\n WCCDR.BK_TO_CURRENCY_CODE,\r\n WCCDR.PL_CONVERSION_RATE,\r\n WCCDR.BALANCE_SHEET_CONV_RATE,\r\n WCCDR.MONTHLY_BUDGET_CONV_RATE,\r\n WCCDR.ANNUAL_BUDGET_CONV_RATE,\r\n WCCDR.SK_FROM_CURRENCY_CODE,\r\n WCCDR.SK_TO_CURRENCY_CODE,\r\n WCCDR.SK_CONVERSION_DATE,\r\n WCCDR.SK_CONVERSION_TYPE_CODE,\r\n WCCDR.BK_CONVERSION_DATE,\r\n WCCDR.EDW_CREATE_DATETIME,\r\n WCCDR.EDW_UPDATE_DATETIME,\r\n WCCDR.EDW_CREATE_USER,\r\n WCCDR.EDW_UPDATE_USER,\r\n WCCDR.ACTION_CODE \r\nFROM\r\n\t(\r\n\tSELECT \r\n\t\tWCCDR1.BK_FROM_CURRENCY_CODE,\r\n\t\tWCCDR1.BK_TO_CURRENCY_CODE,\r\n\t\tWCCDR1.PL_CONVERSION_RATE,\r\n\t\tWCCDR1.BALANCE_SHEET_CONV_RATE,\r\n\t\tWCCDR1.MONTHLY_BUDGET_CONV_RATE,\r\n\t\tWCCDR1.ANNUAL_BUDGET_CONV_RATE,\r\n\t\tWCCDR1.SK_FROM_CURRENCY_CODE,\r\n\t\tWCCDR1.SK_TO_CURRENCY_CODE,\r\n\t\tWCCDR1.SK_CONVERSION_DATE, \r\n\t\tWCCDR1.SK_CONVERSION_TYPE_CODE,\r\n\t\tWCCDR1.BK_CONVERSION_DATE,\r\n\t\tCURRENT_TIMESTAMP(0) EDW_CREATE_DATETIME,\r\n\t\tCURRENT_TIMESTAMP(0) EDW_UPDATE_DATETIME,\r\n\t\tUSER EDW_CREATE_USER, \r\n\t\tUSER EDW_UPDATE_USER, \r\n\t\tWCCDR1.ACTION_CODE \r\n\tFROM $$WORKDB.W_CURRENCY_CONV_DAILY_RATE WCCDR1\r\n\tUNION ALL\r\n\tSELECT DISTINCT\r\n\t\t'USD'\tBK_FROM_CURRENCY_CODE,\r\n\t\t'USD'\tBK_TO_CURRENCY_CODE,\r\n\t\t1\tPL_CONVERSION_RATE,\r\n\t\t1\tBALANCE_SHEET_CONV_RATE,\r\n\t\t1\tMONTHLY_BUDGET_CONV_RATE,\r\n\t\t1\tANNUAL_BUDGET_CONV_RATE,\r\n\t\t'USD'\tSK_FROM_CURRENCY_CODE, \r\n\t\t'USD'\tSK_TO_CURRENCY_CODE,\r\n\t\tWCCDR2.SK_CONVERSION_DATE, \r\n\t\tWCCDR2.SK_CONVERSION_TYPE_CODE,\r\n\t\tWCCDR2.BK_CONVERSION_DATE,\r\n\t\tCURRENT_TIMESTAMP(0) EDW_CREATE_DATETIME,\r\n\t\tCURRENT_TIMESTAMP(0) EDW_UPDATE_DATETIME,\r\n\t\tUSER EDW_CREATE_USER,\r\n\t\tUSER EDW_UPDATE_USER,\r\n\t\tWCCDR2.ACTION_CODE \r\n\tFROM $$WORKDB.W_CURRENCY_CONV_DAILY_RATE WCCDR2\r\n\t) WCCDR\r\n\tWHERE NOT EXISTS (SELECT 1 FROM\r\n\t\t\t$$FINLGLVWDB.N_CURRENCY_CONV_DAILY_RATE NCCDR\r\n\t\t\tWHERE WCCDR.BK_FROM_CURRENCY_CODE = NCCDR.BK_FROM_CURRENCY_CODE\r\n\t\t\tAND WCCDR.BK_TO_CURRENCY_CODE= NCCDR.BK_TO_CURRENCY_CODE\r\n\t\t\tAND WCCDR.BK_CONVERSION_DATE = NCCDR.BK_CONVERSION_DATE)",
