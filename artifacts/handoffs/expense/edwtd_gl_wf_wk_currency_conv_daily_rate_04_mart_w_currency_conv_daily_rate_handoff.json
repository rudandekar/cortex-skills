      "attributes": {
        "Sql Query": "SELECT   SMGDR.BATCH_ID,\r\n         SMGDR.FROM_CURRENCY,\r\n         SMGDR.TO_CURRENCY,\r\n         SMGDR.CONVERSION_DATE,\r\n         SMGDR.GLOBAL_NAME,\r\n         SMGDR.CONVERSION_TYPE,\r\n         SMGDR.CONVERSION_RATE,\r\n         SMGDR.CREATE_DATETIME,\r\n         SMGDR.ACTION_CODE\r\n  FROM   (SELECT   SMGDRBE.BATCH_ID,\r\n                   SMGDRBE.FROM_CURRENCY,\r\n                   SMGDRBE.TO_CURRENCY,\r\n                   SMGDRBE.CONVERSION_DATE,\r\n                   SMGDRBE.GLOBAL_NAME,\r\n                   SMGDRBE.CONVERSION_TYPE,\r\n                   SMGDRBE.CONVERSION_RATE,\r\n                   SMGDRBE.CREATE_DATETIME,\r\n                   SMGDRBE.ACTION_CODE\r\n            FROM   $$STGDB.ST_MF_GL_DAILY_RATES SMGDRBE\r\n           WHERE   SMGDRBE.FROM_CURRENCY IN\r\n                         (SELECT   DISTINCT NICT.BK_ISO_CURRENCY_CODE\r\n                            FROM   $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\n                   AND SMGDRBE.TO_CURRENCY IN\r\n                            (SELECT   DISTINCT NICT.BK_ISO_CURRENCY_CODE\r\n                               FROM   $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\n                   AND SMGDRBE.GLOBAL_NAME = 'BE'\r\n                   AND SMGDRBE.CONVERSION_TYPE = 'Corporate'\r\n          UNION ALL\r\n          SELECT   SMGDRUS.BATCH_ID,\r\n                   SMGDRUS.FROM_CURRENCY,\r\n                   SMGDRUS.TO_CURRENCY,\r\n                   SMGDRUS.CONVERSION_DATE,\r\n                   SMGDRUS.GLOBAL_NAME,\r\n                   SMGDRUS.CONVERSION_TYPE,\r\n                   SMGDRUS.CONVERSION_RATE,\r\n                   SMGDRUS.CREATE_DATETIME,\r\n                   SMGDRUS.ACTION_CODE\r\n            FROM   $$STGDB.ST_MF_GL_DAILY_RATES SMGDRUS\r\n           WHERE   SMGDRUS.FROM_CURRENCY IN\r\n                         (SELECT   DISTINCT NICT.BK_ISO_CURRENCY_CODE\r\n                            FROM   $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\n                   AND SMGDRUS.TO_CURRENCY IN\r\n                            (SELECT   DISTINCT NICT.BK_ISO_CURRENCY_CODE\r\n                               FROM   $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\n                   AND SMGDRUS.GLOBAL_NAME = 'US'\r\n                   AND SMGDRUS.CONVERSION_TYPE = 'Corporate' /* Added CONVERSION_TYPE = 'Corporate' by taking it out from source to stage workflow */\r\n                   AND NOT EXISTS\r\n                         (SELECT   1\r\n                            FROM   $$STGDB.ST_MF_GL_DAILY_RATES SMGDR\r\n                           WHERE   SMGDR.GLOBAL_NAME = 'BE'\r\n                                   AND SMGDR.FROM_CURRENCY =\r\n                                         SMGDRUS.FROM_CURRENCY\r\n                                   AND SMGDR.TO_CURRENCY =\r\n                                         SMGDRUS.TO_CURRENCY\r\n                                   AND SMGDR.CONVERSION_DATE =\r\n                                         SMGDRUS.CONVERSION_DATE\r\n                                   AND SMGDR.CONVERSION_TYPE = 'Corporate')\r\n\t\t) SMGDR\r\nUNION ALL\r\nSELECT   EMOGDR.BATCH_ID,\r\n         EMOGDR.FROM_CURRENCY,\r\n         EMOGDR.TO_CURRENCY,\r\n         EMOGDR.CONVERSION_DATE,\r\n         EMOGDR.GLOBAL_NAME,\r\n         EMOGDR.CONVERSION_TYPE,\r\n         EMOGDR.CONVERSION_RATE,\r\n         EMOGDR.CREATE_DATETIME,\r\n         EMOGDR.ACTION_CODE\r\n  FROM   (SELECT   EMOGDRBE.BATCH_ID,\r\n                   EMOGDRBE.FROM_CURRENCY,\r\n                   EMOGDRBE.TO_CURRENCY,\r\n                   EMOGDRBE.CONVERSION_DATE,\r\n                   EMOGDRBE.GLOBAL_NAME,\r\n                   EMOGDRBE.CONVERSION_TYPE,\r\n                   EMOGDRBE.CONVERSION_RATE,\r\n                   EMOGDRBE.CREATE_DATETIME,\r\n                   EMOGDRBE.ACTION_CODE\r\n            FROM   $$EXCEPDB.EX_MF_OM_GL_DAILY_RATES EMOGDRBE\r\n           WHERE   EMOGDRBE.FROM_CURRENCY IN\r\n                         (SELECT   DISTINCT NICT.BK_ISO_CURRENCY_CODE\r\n                            FROM   $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\n                   AND EMOGDRBE.TO_CURRENCY IN\r\n                            (SELECT   DISTINCT NICT.BK_ISO_CURRENCY_CODE\r\n                               FROM   $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\n                   AND EMOGDRBE.EXCEPTION_TYPE = 'RI'\r\n                   AND EMOGDRBE.GLOBAL_NAME = 'BE'\r\n                   AND EMOGDRBE.CONVERSION_TYPE = 'Corporate'\r\n          UNION ALL\r\n          SELECT   EMOGDRUS.BATCH_ID,\r\n                   EMOGDRUS.FROM_CURRENCY,\r\n                   EMOGDRUS.TO_CURRENCY,\r\n                   EMOGDRUS.CONVERSION_DATE,\r\n                   EMOGDRUS.GLOBAL_NAME,\r\n                   EMOGDRUS.CONVERSION_TYPE,\r\n                   EMOGDRUS.CONVERSION_RATE,\r\n                   EMOGDRUS.CREATE_DATETIME,\r\n                   EMOGDRUS.ACTION_CODE\r\n            FROM   $$EXCEPDB.EX_MF_OM_GL_DAILY_RATES EMOGDRUS\r\n           WHERE   EMOGDRUS.FROM_CURRENCY IN\r\n                         (SELECT   DISTINCT NICT.BK_ISO_CURRENCY_CODE\r\n                            FROM   $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\n                   AND EMOGDRUS.TO_CURRENCY IN\r\n                            (SELECT   DISTINCT NICT.BK_ISO_CURRENCY_CODE\r\n                               FROM   $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\n                   AND EMOGDRUS.EXCEPTION_TYPE = 'RI'\r\n                   AND EMOGDRUS.GLOBAL_NAME = 'US'\r\n                   AND EMOGDRUS.CONVERSION_TYPE = 'Corporate'\r\n                   AND NOT EXISTS\r\n                         (SELECT   1\r\n                            FROM   $$EXCEPDB.EX_MF_OM_GL_DAILY_RATES EMOGDR\r\n                           WHERE   EMOGDR.GLOBAL_NAME = 'BE'\r\n                                   AND EMOGDR.FROM_CURRENCY =\r\n                                         EMOGDRUS.FROM_CURRENCY\r\n                                   AND EMOGDR.TO_CURRENCY =\r\n                                         EMOGDRUS.TO_CURRENCY\r\n                                   AND EMOGDR.CONVERSION_DATE =\r\n                                         EMOGDRUS.CONVERSION_DATE\r\n                                   AND EMOGDR.CONVERSION_TYPE = 'Corporate')\r\n\t\t) EMOGDR",
        "User Defined Join": "",
