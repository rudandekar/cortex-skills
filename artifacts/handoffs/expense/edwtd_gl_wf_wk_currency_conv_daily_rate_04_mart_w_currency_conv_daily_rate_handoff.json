      "attributes": {
        "Sql Query": "SELECT \r\nSMGDR.BATCH_ID, \r\nSMGDR.FROM_CURRENCY, \r\nSMGDR.TO_CURRENCY, \r\nSMGDR.CONVERSION_DATE, \r\nSMGDR.GLOBAL_NAME, \r\nSMGDR.CONVERSION_TYPE,\r\nSMGDR.CONVERSION_RATE, \r\nSMGDR.CREATE_DATETIME, \r\nSMGDR.ACTION_CODE,\r\n'RI' EXCEPTION_TYPE \r\nFROM \r\n$$STGDB.ST_MF_GL_DAILY_RATES SMGDR\r\nWHERE\r\n     SMGDR.FROM_CURRENCY NOT IN (SELECT DISTINCT  NICT.BK_ISO_CURRENCY_CODE \r\n\tfrom $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\nAND  SMGDR.TO_CURRENCY NOT IN (SELECT DISTINCT  NICT.BK_ISO_CURRENCY_CODE  \r\n\tfrom $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\nAND SMGDR.CONVERSION_TYPE = 'Corporate'",
