      "attributes": {
        "Sql Query": "SELECT \r\n WEFC.FISCAL_MONTH_NUMBER_INT,\r\n WEFC.FISCAL_YEAR_NUMBER_INT,\r\n WEFC.FISCAL_CALENDAR_CD,\r\n WEFC.EXPENSE_FUTURE_PUBLICATION_DT,\r\n WEFC.COMPANY_CD,\r\n WEFC.DEPARTMENT_CD,\r\n WEFC.FINANCIAL_ACCOUNT_CD,\r\n WEFC.FINANCIAL_ACCOUNT_LOCALITY_INT,\r\n WEFC.FUNCTIONAL_COMMIT_AMT,\r\n WEFC.USD_COMMIT_AMT,\r\n WEFC.USD_COMMIT_AT_ACTUAL_RATE_AMT,\r\n WEFC.USD_COMMIT_AT_BUDGET_RATE_AMT,\r\n WEFC.EDW_CREATE_USER,\r\n WEFC.EDW_UPDATE_USER,\r\n WEFC.EDW_CREATE_DTM,\r\n WEFC.EDW_UPDATE_DTM,\r\n WEFC.FUNCTIONAL_CURRENCY_CD \r\n FROM\r\n $$WORKDB.W_EXPENSE_FUTURE_COMMIT WEFC\r\n  WHERE \r\n NOT EXISTS ( SELECT 1 FROM $$FINLGLVWDB.N_EXPENSE_FUTURE_COMMIT NEFC\r\n\t\t      WHERE WEFC.FISCAL_MONTH_NUMBER_INT = NEFC.FISCAL_MONTH_NUMBER_INT\r\n\t\t AND WEFC.FISCAL_YEAR_NUMBER_INT = NEFC.FISCAL_YEAR_NUMBER_INT\r\n\t\t      AND WEFC.FISCAL_CALENDAR_CD = NEFC.FISCAL_CALENDAR_CD AND\r\nWEFC.EXPENSE_FUTURE_PUBLICATION_DT=NEFC.EXPENSE_FUTURE_PUBLICATION_DT\r\n\t\t      AND WEFC.COMPANY_CD = NEFC.COMPANY_CD\r\n\t\t      AND WEFC.DEPARTMENT_CD = NEFC.DEPARTMENT_CD\r\n\t\t      AND WEFC.FINANCIAL_ACCOUNT_CD = NEFC.FINANCIAL_ACCOUNT_CD\r\n\t\t      AND WEFC.FINANCIAL_ACCOUNT_LOCALITY_INT = NEFC.FINANCIAL_ACCOUNT_LOCALITY_INT)",
