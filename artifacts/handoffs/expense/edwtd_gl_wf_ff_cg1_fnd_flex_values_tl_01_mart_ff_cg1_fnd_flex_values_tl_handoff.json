      "attributes": {
        "Sql Query": "SELECT CG1_FND_FLEX_VALUES_TL.FLEX_VALUE_ID,\r\nreplace(replace(replace(CG1_FND_FLEX_VALUES_TL.LANGUAGE,chr(10),' '),chr(13),' ') ,chr(234),' ')LANGUAGE, \r\n CG1_FND_FLEX_VALUES_TL.LAST_UPDATE_DATE,\r\n  CG1_FND_FLEX_VALUES_TL.LAST_UPDATED_BY,\r\n   CG1_FND_FLEX_VALUES_TL.CREATION_DATE, \r\n   CG1_FND_FLEX_VALUES_TL.CREATED_BY,\r\n   replace(replace(replace(CG1_FND_FLEX_VALUES_TL.SOURCE_LANG,chr(10),' '),chr(13),' ') ,chr(234),' ')SOURCE_LANG,\r\nreplace(replace(replace(CG1_FND_FLEX_VALUES_TL.FLEX_VALUE_MEANING,chr(10),' '),chr(13),' ') ,chr(234),' ')FLEX_VALUE_MEANING,  \r\n      CG1_FND_FLEX_VALUES_TL.LAST_UPDATE_LOGIN,\r\n      replace(replace(replace(CG1_FND_FLEX_VALUES_TL.DESCRIPTION,chr(10),' '),chr(13),' ') ,chr(234),' ')DESCRIPTION, \r\n        CG1_FND_FLEX_VALUES_TL.GES_UPDATE_DATE, \r\n    replace(replace(replace(CG1_FND_FLEX_VALUES_TL.GLOBAL_NAME,chr(10),' '),chr(13),' ') ,chr(234),' ')GLOBAL_NAME\r\n\r\nFROM\r\n CG1_FND_FLEX_VALUES_TL\r\n WHERE\r\nCG1_FND_FLEX_VALUES_TL.GES_UPDATE_DATE> to_date('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS')",
