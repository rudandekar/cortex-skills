      "attributes": {
        "Sql Query": "SELECT\r\nNCCDRM.BK_FROM_CURRENCY_CODE\r\n,NCCDRM.BK_TO_CURRENCY_CODE \r\n,(NFM.BK_FISCAL_YEAR_NUMBER_INT *100 + NFM.BK_FISCAL_MONTH_NUMBER_INT) AS FISCAL_YEAR_MONTH_NUM_INT\r\n,MAX(NCCDRM.PL_CONVERSION_RATE) PL_CONVERSION_RATE\r\n,MAX(NCCDRM.BALANCE_SHEET_CONV_RATE) BALANCE_SHEET_CONV_RATE\r\n,MAX(NCCDRM.MONTHLY_BUDGET_CONV_RATE) MONTHLY_BUDGET_CONV_RATE\r\n,MAX(NCCDRM.ANNUAL_BUDGET_CONV_RATE) ANNUAL_BUDGET_CONV_RATE\r\nFROM\r\n\t$$FINLGLVWDB.N_CURRENCY_CONV_DAILY_RATE NCCDRM ,\r\n\t$$COMREFVWDB.N_FISCAL_MONTH NFM,\r\n\t(\r\n\tSELECT\r\n\tPLRT.BK_FROM_CURRENCY_CODE\r\n\t,PLRT.BK_TO_CURRENCY_CODE\r\n\t,PLRT.BK_FISCAL_MONTH_NUMBER_INT\r\n\t,PLRT.BK_FISCAL_YEAR_NUMBER_INT\r\n\t,PLRT.BK_CONVERSION_DATE_MAX\r\n\t,BSRT.BK_CONVERSION_DATE_MAX AS BK_CONVERSION_DATE_MAX_BSRT\r\n\tFROM\r\n\t\t(SELECT \r\n\t\t\tBK_FROM_CURRENCY_CODE\r\n\t\t\t,BK_TO_CURRENCY_CODE\r\n\t\t\t,BK_FISCAL_MONTH_NUMBER_INT\r\n\t\t\t,BK_FISCAL_YEAR_NUMBER_INT\r\n\t\t\t,MAX(BK_CONVERSION_DATE)BK_CONVERSION_DATE_MAX\r\n\t\tFROM\r\n\t\t\t$$FINLGLVWDB.N_CURRENCY_CONV_DAILY_RATE NCCDR,\r\n\t\t\t$$COMREFVWDB.N_FISCAL_MONTH NFIS\r\n\t\tWHERE NCCDR.BK_CONVERSION_DATE BETWEEN NFIS.FISCAL_MONTH_START_DATE AND NFIS.FISCAL_MONTH_END_DATE \r\n\t\t\tAND (NCCDR.BK_TO_CURRENCY_CODE = 'USD' OR NCCDR.BK_FROM_CURRENCY_CODE = 'USD')\r\n\t\t\t/*AND (PL_CONVERSION_RATE IS NOT NULL OR BALANCE_SHEET_CONV_RATE IS NOT NULL)  \r\n\t\t\tAND PL_CONVERSION_RATE IS NOT NULL*/\r\n\t\tGROUP BY BK_FROM_CURRENCY_CODE,BK_TO_CURRENCY_CODE,BK_FISCAL_MONTH_NUMBER_INT,BK_FISCAL_YEAR_NUMBER_INT\r\n\t\t) PLRT\r\n\t\tLEFT OUTER JOIN\r\n\t\t(\r\n\t\tSELECT \r\n\t\t\t BK_FROM_CURRENCY_CODE\r\n\t\t\t,BK_TO_CURRENCY_CODE\r\n\t\t\t,BK_FISCAL_MONTH_NUMBER_INT\r\n\t\t\t,BK_FISCAL_YEAR_NUMBER_INT\r\n\t\t\t,MAX(BK_CONVERSION_DATE) BK_CONVERSION_DATE_MAX\r\n\t\tFROM\r\n\t\t\t$$FINLGLVWDB.N_CURRENCY_CONV_DAILY_RATE NCCDR,\r\n\t\t\t$$COMREFVWDB.N_FISCAL_MONTH NFIS\r\n\t\t\tWHERE NCCDR.BK_CONVERSION_DATE BETWEEN NFIS.FISCAL_MONTH_START_DATE AND NFIS.FISCAL_MONTH_END_DATE \r\n\t\t\t\tAND (NCCDR.BK_TO_CURRENCY_CODE = 'USD' OR NCCDR.BK_FROM_CURRENCY_CODE = 'USD')\r\n\t\t\t\t/*AND (PL_CONVERSION_RATE IS NOT NULL OR BALANCE_SHEET_CONV_RATE IS NOT NULL)  \r\n\t\t\t\tAND BALANCE_SHEET_CONV_RATE IS NOT NULL*/\r\n\t\tGROUP BY BK_FROM_CURRENCY_CODE,BK_TO_CURRENCY_CODE,BK_FISCAL_MONTH_NUMBER_INT,BK_FISCAL_YEAR_NUMBER_INT\r\n\t\t) BSRT\r\n\t\tON PLRT.BK_FROM_CURRENCY_CODE \t\t= BSRT.BK_FROM_CURRENCY_CODE\r\n\t\tAND PLRT.BK_TO_CURRENCY_CODE \t\t= BSRT.BK_TO_CURRENCY_CODE\r\n\t\tAND PLRT.BK_FISCAL_MONTH_NUMBER_INT \t= BSRT.BK_FISCAL_MONTH_NUMBER_INT\r\n\t\tAND PLRT.BK_FISCAL_YEAR_NUMBER_INT \t= BSRT.BK_FISCAL_YEAR_NUMBER_INT\r\n\t)PL_CONV\r\nWHERE\t    NCCDRM.BK_CONVERSION_DATE BETWEEN NFM.FISCAL_MONTH_START_DATE  AND NFM.FISCAL_MONTH_END_DATE \r\n\tAND NCCDRM.BK_FROM_CURRENCY_CODE = PL_CONV.BK_FROM_CURRENCY_CODE\r\n\tAND NCCDRM.BK_TO_CURRENCY_CODE = PL_CONV.BK_TO_CURRENCY_CODE\r\n\tAND NFM.BK_FISCAL_MONTH_NUMBER_INT = PL_CONV.BK_FISCAL_MONTH_NUMBER_INT\r\n\tAND NFM.BK_FISCAL_YEAR_NUMBER_INT = PL_CONV.BK_FISCAL_YEAR_NUMBER_INT\r\n\tAND (NCCDRM.BK_FROM_CURRENCY_CODE,NCCDRM.BK_TO_CURRENCY_CODE ,(NFM.BK_FISCAL_YEAR_NUMBER_INT *100 +  NFM.BK_FISCAL_MONTH_NUMBER_INT)) NOT IN \r\n\t\t(SELECT BK_FROM_CURRENCY_CD,BK_TO_CURRENCY_CD,\r\n\t\t\tFISCAL_YEAR_MONTH_NUM_INT FROM $$FINLGLVWDB.MT_MONTHLY_CONVERSION_RATE )\r\nGROUP BY \r\n\tNCCDRM.BK_FROM_CURRENCY_CODE\r\n\t,NCCDRM.BK_TO_CURRENCY_CODE \r\n\t,(NFM.BK_FISCAL_YEAR_NUMBER_INT *100 + NFM.BK_FISCAL_MONTH_NUMBER_INT)",
        "User Defined Join": "",
