      "attributes": {
        "Sql Query": "SELECT\r\nCAST(COALESCE(CAST(LAST_UPDATE_DATE AS VARCHAR(19)),CAST(CURRENT_TIMESTAMP(0) AS VARCHAR(19))) AS TIMESTAMP(0)) AS LAST_UPDATE_DATE\r\n,'-1' AS LAST_UPDATED_BY\r\n,CAST(TO_DATE(SUBSTR(CREATION_DATE,1,10)) AS TIMESTAMP(0)) AS CREATION_DATE\r\n,'-1' AS CREATED_BY\r\n,'-1' AS LAST_UPDATE_LOGIN\r\n,UOM_CODE\r\n,UOM_CLASS\r\n,CAST(TO_DATE(SUBSTR(DISABLE_DATE,1,10)) AS TIMESTAMP(0)) AS DISABLE_DATE\r\n,COALESCE(REQUEST_ID,0) AS REQUEST_ID\r\n,INVENTORY_ITEM_ID\r\n,CONVERSION_RATE\r\n,DEFAULT_CONVERSION_FLAG\r\n,COALESCE(UOM_LENGTH,0) AS UOM_LENGTH\r\n,COALESCE(UOM_WIDTH,0) AS UOM_WIDTH\r\n,COALESCE(UOM_HEIGHT,0) AS UOM_HEIGHT\r\n,DIMENSION_UOM\r\n,CURRENT_TIMESTAMP(0) AS REFRESH_DATETIME\r\n,OFFSET_NUMBER\r\n,PARTITION_NUMBER\r\n,RECORD_COUNT\r\nFROM $$STGDB.PST_CLOUD_MTL_UOM_CONVERSIONS",
