      "attributes": {
        "Sql Query": "SELECT   \r\nNFA.BK_FIXED_ASSET_NUM ,  \r\nNFA.BK_COMPANY_CD  ,      \r\nNFA.SET_OF_BOOKS_KEY ,\r\nCASE \r\nWHEN  A.PR_COUNT > 1 AND NPR.BK_PURCHASE_REQUISITION_NUM IS NULL THEN -998\r\nWHEN  A.PR_COUNT > 1 AND NPR.BK_PURCHASE_REQUISITION_NUM IS NOT NULL THEN  COALESCE(NPR.BK_PURCHASE_REQUISITION_NUM ,-999) \r\nWHEN  A.PR_COUNT = 1  THEN  COALESCE(NPR.BK_PURCHASE_REQUISITION_NUM ,-999) \r\nWHEN  A.PR_COUNT = 0 THEN -999 \r\nEND  AS BK_PURCHASE_RQSTN_NUM,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,               \r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM $$FINLGLVWDB.N_FIXED_ASSET NFA   \r\nLEFT JOIN  $$ETLVWDB.EL_FA_ADDITIONS_B EFAB   \r\nON (NFA.BK_FIXED_ASSET_NUM =EFAB.ASSET_NUMBER   )    \r\nLEFT JOIN $$ETLVWDB.EL_FA_ASSET_INVOICES EFAI \r\nON  (EFAB.ASSET_ID = EFAI.ASSET_ID AND  EFAB.GLOBAL_NAME  = EFAI.GLOBAL_NAME)\r\nLEFT JOIN $$ETLVWDB.EL_AP_INVOICE_DISTRI_ALL EAPID\r\nON ( EFAI.INVOICE_DISTRIBUTION_ID = EAPID.INVOICE_DISTRIBUTION_ID  )\r\n\r\nLEFT JOIN $$FINLGLVWDB.N_PO_SHIPMENT_DISTRIBUTION NPSD \r\nON  (EAPID.PO_DISTRIBUTION_ID = NPSD.SK_PO_DISTRIBUTION_ID_INT)\r\nLEFT  JOIN $$FINLGLVWDB.N_PURCHASE_REQN_LINE_DISTRIB NPRLD \r\n\r\nON NPSD.PURCHASE_REQN_LINE_DISTRIB_KEY=NPRLD.PURCHASE_REQN_LINE_DISTRIB_KEY\r\nLEFT JOIN $$FINLGLVWDB.N_PURCHASE_REQUISITION_LINE NPRL\r\nON (NPRLD.PURCHASE_REQUISITION_LINE_KEY = NPRL.PURCHASE_REQUISITION_LINE_KEY )   \r\nLEFT JOIN $$FINLGLVWDB.N_PURCHASE_REQUISITION NPR\r\nON (NPRL.BK_PURCHASE_REQUISITION_NUM = NPR.BK_PURCHASE_REQUISITION_NUM    )\r\n\r\nINNER JOIN \r\n(\r\n\r\nSELECT   \r\nNFA.BK_FIXED_ASSET_NUM  AS  FIXED_ASSET_NUM,  \r\nNFA.BK_COMPANY_CD  AS COMANY_CD ,      \r\nNFA.SET_OF_BOOKS_KEY  AS SOB,\r\nCOUNT( DISTINCT NPRL.BK_PURCHASE_REQUISITION_NUM) AS PR_COUNT\r\nFROM $$FINLGLVWDB.N_FIXED_ASSET NFA   \r\nLEFT JOIN  $$ETLVWDB.EL_FA_ADDITIONS_B EFAB   \r\nON (NFA.BK_FIXED_ASSET_NUM =EFAB.ASSET_NUMBER   )    \r\nLEFT JOIN $$ETLVWDB.EL_FA_ASSET_INVOICES EFAI \r\nON  (EFAB.ASSET_ID = EFAI.ASSET_ID \r\nAND  EFAB.GLOBAL_NAME  = EFAI.GLOBAL_NAME)\r\nLEFT JOIN $$ETLVWDB.EL_AP_INVOICE_DISTRI_ALL EAPID\r\nON ( EFAI.INVOICE_DISTRIBUTION_ID = EAPID.INVOICE_DISTRIBUTION_ID )\r\n\r\nLEFT JOIN $$FINLGLVWDB.N_PO_SHIPMENT_DISTRIBUTION NPSD \r\nON  (EAPID.PO_DISTRIBUTION_ID = NPSD.SK_PO_DISTRIBUTION_ID_INT)\r\nLEFT  JOIN $$FINLGLVWDB.N_PURCHASE_REQN_LINE_DISTRIB NPRLD \r\n\r\nON NPSD.PURCHASE_REQN_LINE_DISTRIB_KEY=NPRLD.PURCHASE_REQN_LINE_DISTRIB_KEY\r\nLEFT JOIN $$FINLGLVWDB.N_PURCHASE_REQUISITION_LINE NPRL\r\nON (NPRLD.PURCHASE_REQUISITION_LINE_KEY = NPRL.PURCHASE_REQUISITION_LINE_KEY )   \r\nLEFT JOIN $$FINLGLVWDB.N_PURCHASE_REQUISITION NPR\r\nON (NPRL.BK_PURCHASE_REQUISITION_NUM = NPR.BK_PURCHASE_REQUISITION_NUM    )\r\n\r\nWHERE NFA.INTERNAL_EQUIPMENT_ROLE ='N'\r\nAND ((EFAI.DATE_INEFFECTIVE IS NULL) OR (EFAI.DATE_INEFFECTIVE <= DATE))  \r\n\r\nGROUP BY 1,2,3) A\r\nON \r\n(NFA.BK_FIXED_ASSET_NUM = A. FIXED_ASSET_NUM\r\nAND NFA.BK_COMPANY_CD  = A.COMANY_CD      \r\nAND NFA.SET_OF_BOOKS_KEY =A.SOB)\r\n\r\nWHERE \r\n ((EFAI.DATE_INEFFECTIVE IS NULL) OR (EFAI.DATE_INEFFECTIVE <= DATE))  \r\nAND ( BK_PURCHASE_RQSTN_NUM<> -998 )\r\nAND \r\n NFA.INTERNAL_EQUIPMENT_ROLE ='N'\r\n\r\n\r\n\r\nQUALIFY ROW_NUMBER() OVER ( PARTITION BY  NFA.BK_FIXED_ASSET_NUM,NFA.BK_COMPANY_CD  ,      \r\nNFA.SET_OF_BOOKS_KEY,BK_PURCHASE_RQSTN_NUM\r\n  ORDER BY NFA.BK_FIXED_ASSET_NUM,NFA.BK_COMPANY_CD  ,      \r\nNFA.SET_OF_BOOKS_KEY,BK_PURCHASE_RQSTN_NUM\r\nDESC ) =1\r\n\r\n\r\n\r\nUNION ALL\r\n\r\nSELECT \r\nBK_FIXED_ASSET_NUM,\r\nBK_COMPANY_CD,\r\nSET_OF_BOOKS_KEY,\r\nBK_PURCHASE_RQSTN_NUM,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,               \r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM \r\n(\r\nSELECT   \r\nNFA.BK_FIXED_ASSET_NUM ,  \r\nNFA.BK_COMPANY_CD  ,      \r\nNFA.SET_OF_BOOKS_KEY ,\r\nCASE WHEN SMFCB.SEGMENT1||'.'||SMFCB.SEGMENT2 ='INT.2WAY' THEN COALESCE(EFAB.ATTRIBUTE27 ,-999) \r\n  ELSE  COALESCE(EFAB.ATTRIBUTE16,-999)    \r\nEND AS PURCHASE_REQUISITION_NUM,\r\nCOALESCE(NPR.BK_PURCHASE_REQUISITION_NUM,-999) AS BK_PURCHASE_RQSTN_NUM\r\nFROM $$FINLGLVWDB.N_FIXED_ASSET NFA     \r\nLEFT JOIN $$ETLVWDB.EL_FA_ADDITIONS_B EFAB  \r\nON (NFA.BK_FIXED_ASSET_NUM =EFAB.ASSET_NUMBER   )    \r\nLEFT JOIN  $$STGDB.ST_MF_FA_CATEGORIES_B SMFCB  \r\nON (EFAB.ASSET_CATEGORY_ID = SMFCB.CATEGORY_ID\r\nAND EFAB.GLOBAL_NAME = SMFCB.GLOBAL_NAME  )        \r\nLEFT JOIN $$FINLGLVWDB.N_PURCHASE_REQUISITION NPR\r\nON  (PURCHASE_REQUISITION_NUM  = NPR.BK_PURCHASE_REQUISITION_NUM )\r\nWHERE NFA.INTERNAL_EQUIPMENT_ROLE ='Y'\r\n)A",
        "User Defined Join": "",
