          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "SELECT  \r\nEXPUPD.FROM_CURRENCY_CODE,\r\nEXPUPD.TO_CURRENCY_CODE,\r\nEXPUPD.FISCAL_MONTH_START_DATE,\r\nEXPUPD.PL_CONVERSION_DAILY_RATE,\r\nEXPUPD.DV_CONVERSION_RATE,\r\nEXPUPD.FISCAL_YEAR_MONTH_NUM_INT,\r\n'Corporate' SK_CONVERSION_TYPE_CODE\r\nFROM   \r\n(\r\n                SELECT\r\n                                SPFRP.CURRENCY_CODE FROM_CURRENCY_CODE ,\r\n                                'USD' TO_CURRENCY_CODE,\r\n                                NFM.FISCAL_MONTH_START_DATE,\r\n                                null PL_CONVERSION_DAILY_RATE,\r\n                                (\r\nCASE      \r\n                WHEN  SPFRP.CONVERSION_RATE = 0 THEN 0 \r\n                ELSE       1/SPFRP.CONVERSION_RATE \r\nEND       ) DV_CONVERSION_RATE,\r\n                                ( (NFM.BK_FISCAL_YEAR_NUMBER_INT*100 )+BK_FISCAL_MONTH_NUMBER_INT)  FISCAL_YEAR_MONTH_NUM_INT\r\n                FROM \r\n                                $$STGDB.ST_PL_FX_RATE_PUBLISH SPFRP \r\n                INNER JOIN  $$COMREFVWDB.N_FISCAL_MONTH NFM \r\n                ON         SPFRP.FISCAL_MONTH_ID = FISCAL_YEAR_MONTH_NUM_INT-100\r\n                and spfrp. currency_code <> 'USD'\r\n                UNION ALL\r\n                SELECT\r\n                                'USD' FROM_CURRENCY_CODE ,\r\n                                'USD' TO_CURRENCY_CODE,\r\n                                NFM.FISCAL_MONTH_START_DATE,\r\n                                1  PL_CONVERSION_DAILY_RATE,\r\n                                1 DV_CONVERSION_RATE,\r\n                (              (NFM.BK_FISCAL_YEAR_NUMBER_INT*100 )+BK_FISCAL_MONTH_NUMBER_INT )  FISCAL_YEAR_MONTH_NUM_INT\r\n                FROM\r\n                                 (SELECT DISTINCT (FISCAL_MONTH_ID +100) as fiscal_month_id FROM $$STGDB.ST_PL_FX_RATE_PUBLISH ) SPFRP\r\n                INNER JOIN $$COMREFVWDB.N_FISCAL_MONTH NFM \r\n                ON         SPFRP.FISCAL_MONTH_ID = FISCAL_YEAR_MONTH_NUM_INT \r\n                UNION ALL /* 3RD YEAR*/\r\n                                SELECT\r\n                                SPFRP.CURRENCY_CODE FROM_CURRENCY_CODE ,\r\n                                'USD' TO_CURRENCY_CODE,\r\n                                NFM.FISCAL_MONTH_START_DATE,\r\n                                null PL_CONVERSION_DAILY_RATE,\r\n                                (\r\nCASE      \r\n                WHEN  SPFRP.CONVERSION_RATE = 0 THEN 0 \r\n                ELSE       1/SPFRP.CONVERSION_RATE \r\nEND       ) DV_CONVERSION_RATE,\r\n                                ( (NFM.BK_FISCAL_YEAR_NUMBER_INT*100 )+BK_FISCAL_MONTH_NUMBER_INT)  FISCAL_YEAR_MONTH_NUM_INT\r\n                FROM \r\n                                $$STGDB.ST_PL_FX_RATE_PUBLISH SPFRP \r\n                INNER JOIN  $$COMREFVWDB.N_FISCAL_MONTH NFM \r\n                ON         SPFRP.FISCAL_MONTH_ID = FISCAL_YEAR_MONTH_NUM_INT-200\r\n                and spfrp. currency_code <> 'USD'\r\n                UNION ALL\r\n                SELECT\r\n                                'USD' FROM_CURRENCY_CODE ,\r\n                                'USD' TO_CURRENCY_CODE,\r\n                                NFM.FISCAL_MONTH_START_DATE,\r\n                                1  PL_CONVERSION_DAILY_RATE,\r\n                                1 DV_CONVERSION_RATE,\r\n                (              (NFM.BK_FISCAL_YEAR_NUMBER_INT*100 )+BK_FISCAL_MONTH_NUMBER_INT )  FISCAL_YEAR_MONTH_NUM_INT\r\n                FROM\r\n                                 (SELECT DISTINCT (FISCAL_MONTH_ID +200) as fiscal_month_id FROM $$STGDB.ST_PL_FX_RATE_PUBLISH ) SPFRP\r\n                INNER JOIN $$COMREFVWDB.N_FISCAL_MONTH NFM \r\n                ON         SPFRP.FISCAL_MONTH_ID = FISCAL_YEAR_MONTH_NUM_INT \r\n)EXPUPD\r\nWHERE NOT EXISTS (\r\nSELECT  1 \r\nFROM   $$FINLGLVWDB.N_CURRENCY_CONV_DAILY_RATE NCCDR\r\n                                WHERE NCCDR.BK_FROM_CURRENCY_CODE = EXPUPD.FROM_CURRENCY_CODE\r\n                                AND NCCDR.BK_TO_CURRENCY_CODE = EXPUPD.TO_CURRENCY_CODE\r\n                                AND NCCDR.BK_CONVERSION_DATE = EXPUPD.FISCAL_MONTH_START_DATE)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
