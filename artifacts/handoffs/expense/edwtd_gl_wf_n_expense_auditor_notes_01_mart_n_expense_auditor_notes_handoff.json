        "Sql Query": "SELECT\r\nWEAN.EXPENSE_AUDITOR_NOTES_KEY,\r\nWEAN.EXPENSE_REPORT_KEY,\r\nWEAN.ER_DETAILED_AUDITOR_NOTES_TXT, \r\nWEAN.DV_ER_DETL_AUD_ABBR_NOTES_TXT,\r\nWEAN.ENTERED_BY_CSCO_WRKR_PRTY_KEY,\r\nWEAN.ENTERED_DTM,\r\nWEAN.DV_ENTERED_DT,\r\nWEAN.SK_NOTE_ID_INT,\r\nWEAN.SS_CD,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nCURRENT_USER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nCURRENT_USER AS  EDW_UPDATE_USER \r\nFROM\r\n$$WORKDB.W_EXPENSE_AUDITOR_NOTES WEAN\r\nWHERE \r\nWEAN.EXPENSE_REPORT_KEY NOT IN ( 1136683,1147479 )\r\nAND NOT EXISTS \r\n( SELECT 1 FROM $$FINLGLVWDB.N_EXPENSE_AUDITOR_NOTES NEAN\r\nWHERE \r\nNEAN.EXPENSE_AUDITOR_NOTES_KEY = WEAN.EXPENSE_AUDITOR_NOTES_KEY )",
