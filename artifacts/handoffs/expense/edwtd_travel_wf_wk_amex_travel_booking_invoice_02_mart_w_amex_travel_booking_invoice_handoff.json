      "attributes": {
        "Sql Query": "select \r\n\t SBI.PNR_LOCATOR4  as BK_AMEX_PNR_LOCATOR_ID\r\n\t,SBI.CUSTOMER_ID4 as BK_AMEX_CUSTOMER_ID \r\n\t,SBI.PAX_SEQUENCE4 as BK_AMEX_PAX_SEQUENCE_INT\r\n\t,SBI.GDS_CODE4     as BK_AMEX_GDS_CD\r\n\t,SBI.GROSS_AIR_CONVERTED_AMOUNT  as GROSS_FARE_REPORTING_AMT\r\n\t,COALESCE(EBI.Ticket_Gross_Fare,0)    as TOTAL_TKT_GRSS_FARE_RPRTG_AMT\r\n\t,SBI.FARE_GROSS   as GROSS_FARE_LOCAL_AMT\r\n\t,COALESCE(SBI.FARE_LOWEST,0)  as LOWEST_FARE_REPORTING_AMT\r\n\t,COALESCE(SBI.FORM_OF_PAYMENT,'=')  as FORM_OF_PAYMENT_CD\r\n\t,SBI.FULL_FARE  as FULL_FARE_REPORTING_AMT\r\n\t,SBI.TICKET_NUMBER   as FIRST_TICKET_NUM\r\n\t,COALESCE(SBI.TICKET_PREPAID,'=') as TICKET_PREPAID_FLG\r\n\t,COALESCE(SBI.VALIDATING_AIRLINE,'UNK')  as VALIDATING_CARRIER_CD\r\n\t,COALESCE(SBI.REASON_CODE1,'=')   as REASON_CD\r\n\t,COALESCE(SBI.DOM_INTL_FLAG,'=')  as DOMESTIC_INTERNATIONAL_CD\r\n\t,COALESCE(cast(SBI.INVOICE_DATE as date),cast( '1900-01-01' as date) ) as AMEX_TRAVEL_BOOKING_INVOICE_DT\r\n\t, COALESCE(BK_ISO_CURRENCY_CODE  ,'UNK')  as LOCAL_CURRENCY_CD\r\n    ,'I' as ACTION_CODE\t\r\n    ,'I' as DML_TYPE    \r\nfrom $$STGDB.ST_BOOKED_INVOICE  SBI\r\nLEFT OUTER  JOIN $$FINLGLVWDB.N_ISO_CURRENCY_TV  NIC\r\n  ON( SBI.ORIGINAL_CURRENCY2 =  NIC.BK_ISO_CURRENCY_CODE\r\n  \t\t\tand  NIC.END_TV_DATE =  '3500-01-01'  )\r\nInner Join  $$FINLGLVWDB.N_AMEX_TRAVEL_BOOKING  NATB  \r\n\tON   (\tNATB.BK_AMEX_PNR_LOCATOR_ID        =  SBI.PNR_LOCATOR4\r\n\t\t\t\tand NATB.BK_AMEX_GDS_CD        =          SBI.GDS_CODE4\r\n\t\t\t\tand NATB.BK_AMEX_CUSTOMER_ID           = SBI.CUSTOMER_ID4\r\n\t\t\t\tand NATB.BK_AMEX_PAX_SEQUENCE_INT      =SBI.PAX_SEQUENCE4  )\r\nINNER  JOIN  $$ETLVWDB.EL_BOOKED_INVOICE EBI \r\n ON(  EBI.PNR_LOCATOR4      =  SBI.PNR_LOCATOR4\r\n\t and EBI.GDS_CODE4      =   SBI.GDS_CODE4                  \r\n\t and EBI.CUSTOMER_ID4   =    SBI.CUSTOMER_ID4       \r\n\t and EBI.PAX_SEQUENCE4  =    SBI.PAX_SEQUENCE4   \r\n\t)",
