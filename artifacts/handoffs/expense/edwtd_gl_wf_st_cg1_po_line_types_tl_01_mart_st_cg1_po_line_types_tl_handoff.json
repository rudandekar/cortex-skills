      "attributes": {
        "Sql Query": "SELECT   \r\n$$BatchId AS BATCH_ID, \r\n'I' AS ACTION_CODE, \r\nLINE_TYPE_ID,\r\nLANGUAGE_CODE,\r\nSOURCE_LANG,\r\nDESCRIPTION,\r\nLINE_TYPE,\r\nLAST_UPDATE_DATE,\r\nLAST_UPDATED_BY,\r\nLAST_UPDATE_LOGIN,\r\nCREATION_DATE,\r\nCREATED_BY,\r\nSOURCE_COMMIT_TIME, \r\nREFRESH_DATETIME, \r\n'CG' AS GLOBAL_NAME, \r\n  CURRENT_TIMESTAMP(0) AS CREATE_DATETIME \r\nFROM\r\n $$NRTACCUMVWDB.CG1_PO_LINE_TYPES_TL \r\n  WHERE \r\n  LANGUAGE_CODE = 'US'\r\n  AND   SOURCE_DML_TYPE IN ( 'SQL COMPUPDATE','INSERT')\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY LINE_TYPE_ID, LANGUAGE_CODE  ORDER BY REFRESH_DATETIME DESC)=1",
