        "Sql Query": "SELECT \r\n  EL.LOOKUP_CODE AS BK_VENDOR_INV_LINE_TYPE_CD,\r\n  EL.MEANING AS VENDOR_INV_LINE_TYPE_NAME,\r\n  EL.DESCRIPTION AS VENDOR_INV_LINE_TYPE_DESCR\r\nFROM\r\n(\r\nSELECT \r\n LOOKUP_CODE,\r\n MEANING,\r\n DESCRIPTION,\r\n GLOBAL_NAME\r\nFROM\r\n  $$ETLVWDB.EL_FND_LOOKUP_VALUES\r\nWHERE LOOKUP_TYPE ='INVOICE LINE TYPE' and global_name='BE' \r\nUNION ALL\r\nSELECT \r\n LOOKUP_CODE,\r\n MEANING,\r\n DESCRIPTION,\r\n GLOBAL_NAME\r\nFROM\r\n  $$ETLVWDB.EL_FND_LOOKUP_VALUES\r\nWHERE LOOKUP_TYPE ='INVOICE LINE TYPE' and global_name='CG'\r\n  AND LOOKUP_CODE NOT IN \r\n  (\r\n   SELECT LOOKUP_CODE FROM $$ETLVWDB.EL_FND_LOOKUP_VALUES\r\n   WHERE LOOKUP_TYPE ='INVOICE LINE TYPE' and global_name='BE'\r\n  )\r\n)EL",
