          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "select \r\n  BK_COMPANY_CODE,                                                                                                                                               \r\n  DD_BK_DEPT_CD,                                                                                                                                                   \r\n  DD_FINANCIAL_ACCOUNT_CD,                                                                                                                                         \r\n  DD_BK_SUBACCOUNT_CD ,                                                                                                                                            \r\n  DD_BK_PROJECT_CD ,                                                                                                                                               \r\n  DV_FISCAL_YEAR_MONTH_NUM_INT,                                                                                                                                    \r\n  sum( Coalesce ( RU_DV_USD_DEBIT_AMT ,0) - Coalesce (RU_DV_USD_CREDIT_AMT ,0))  as NET_USD_AMT,                                                                   \r\n  sum(Coalesce ( RU_FUNCTIONAL_DEBIT_AMT ,0) - Coalesce (RU_FUNCTIONAL_CREDIT_AMT ,0)) as NET_FUNCTIONAL_AMT,                                                      \r\n  sum(Coalesce ( RU_TRANSACTIONAL_DEBIT_AMT ,0) - Coalesce (RU_TRANSACTIONAL_CREDIT_AMT ,0)) as NET_TRANSACTIONAL_AMT,                                             \r\n  sum( ( Coalesce ( RU_TRANSACTIONAL_DEBIT_AMT ,0) - Coalesce (RU_TRANSACTIONAL_CREDIT_AMT ,0) ) * MONTHLY_BUDGET_CONV_RT )  AS  NET_USD_ACTUALS_AT_BUD_RT_AMT \r\nfrom \r\n  $$FINLGLVWDB.N_JOURNAL_ENTRY_LINE NJEL\r\nINNER JOIN $$FINLGLVWDB.N_JOURNAL_ENTRY NJE\r\n  ON (      NJEL.BK_JOURNAL_ENTRY_NUMBER_INT = NJE.BK_JOURNAL_ENTRY_NUMBER_INT\r\n        and NJEL.SET_OF_BOOKS_KEY = NJE.SET_OF_BOOKS_KEY\r\n      )\r\nINNER JOIN $$FINLGLVWDB.MT_MONTHLY_CONVERSION_RATE MMCR\r\n  ON (     MMCR.BK_FROM_CURRENCY_CD = NJE.TRANSACTIONAL_CURRENCY_CD \r\n       and MMCR.BK_TO_CURRENCY_CD = 'USD'\r\n       and MMCR.FISCAL_YEAR_MONTH_NUM_INT = NJEL.DV_FISCAL_YEAR_MONTH_NUM_INT \r\n      )\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR NFM\r\n  ON (      NJEL.DV_FISCAL_YEAR_MONTH_NUM_INT = NFM. FISCAL_YEAR_MONTH_INT \r\n        and FISCAL_YEAR_AGE  between 0 and 4\r\n      )\r\nINNER JOIN $$FINLGLVWDB.R_FINANCIAL_ACCOUNT_HIERARCHY RFAH\r\n  ON (     RFAH.BK_FINANCIAL_ACCOUNT_CODE = NJEL.DD_FINANCIAL_ACCOUNT_CD\r\n       AND RFAH.LEVEL03_ACCT_GROUP_ID ='EXPENSE' and RFAH.LEVEL04_ACCT_GROUP_ID<> 'Non Expense SSOT Other'\r\n      )\r\n\r\nINNER JOIN $$FINLGLVWDB.N_SET_OF_BOOKS NSOB  /* added */\r\n\tON NSOB.SET_OF_BOOKS_KEY = NJE.SET_OF_BOOKS_KEY\r\n\t\t  \r\nwhere  (  NJEL.DD_FINANCIAL_COMPANY_MAPPED_CD  IN ( 'MO' , 'MC' )  /* added where condition */\r\n               or(  NJEL.DD_FINANCIAL_COMPANY_MAPPED_CD =  'UO'    \r\n\t\t\t\t\t\tAND NJE.BK_JOURNAL_ENTRY_CATEGORY_NAME =  'Revaluation'     \r\n\t\t\t\t\t\tAND NJE.BK_JOURNAL_ENTRY_SOURCE_NAME = 'Revaluation' \r\n\t\t\t\t\t\tAND NSOB.PUSH_TO_GLBL_CONSOL_BOOKS_FLG ='Y' \r\n\t\t\t    \t)\r\n\t\t\t\t)  \r\n        group by 1,2,3,4,5,6",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
