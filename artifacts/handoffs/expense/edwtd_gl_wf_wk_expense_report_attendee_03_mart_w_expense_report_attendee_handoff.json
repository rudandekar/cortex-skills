      "attributes": {
        "Sql Query": "SELECT \r\nSM_ERA.EXPENSE_REPORT_ATTENDEE_KEY, \r\nSRC.NAME,\r\nN_ERL.EXPENSE_REPORT_LINE_KEY, \r\nSRC.ATTENDEE_TYPE, \r\nSRC.TITLE_CD, \r\nSRC.EMPLOYER_ADDRESS, \r\nSRC.EMPLOYER,\r\nSRC.ATTENDEE_LINE_ID,\r\nSM_ERA.SS_CD SS_CD \r\nFROM \r\n(\r\nSELECT \r\n(CASE \r\nWHEN NAME IS NULL THEN 'UNKNOWN'\r\nELSE NAME\r\nEND) NAME,\r\n(CASE \r\nWHEN ATTENDEE_TYPE IS NULL THEN '='\r\nELSE ATTENDEE_TYPE\r\nEND) ATTENDEE_TYPE, \r\nTITLE_CD, \r\nEMPLOYER_ADDRESS, \r\nEMPLOYER,\r\nATTENDEE_LINE_ID,\r\nREPORT_LINE_ID,\r\nGLOBAL_NAME \r\nFROM\r\n$$STGDB.ST_MF_OIE_ATTENDEES_ALL ST_MOA\r\nUNION\r\nSELECT \r\n(CASE \r\nWHEN NAME IS NULL THEN 'UNKNOWN'\r\nELSE NAME\r\nEND) NAME,\r\n(CASE \r\nWHEN ATTENDEE_TYPE IS NULL THEN '='\r\nELSE ATTENDEE_TYPE\r\nEND) ATTENDEE_TYPE, \r\nTITLE_CD, \r\nEMPLOYER_ADDRESS, \r\nEMPLOYER,\r\nATTENDEE_LINE_ID,\r\nREPORT_LINE_ID,\r\nGLOBAL_NAME \r\nFROM\r\n$$EXCEPDB.EX_MF_OIE_ATTENDEES_ALL ) SRC,\r\n$$COMREFVWDB.N_SOURCE_SYSTEM_CODES N_SS_CD,\r\n$$TRANSLATIONDB.SM_EXPENSE_REPORT_ATTENDEE  SM_ERA,\r\n$$FINLGLVWDB.N_EXPENSE_REPORT_LINE N_ERL\r\nWHERE\r\nSRC.ATTENDEE_LINE_ID = SM_ERA.SK_ATTENDEE_LINE_ID_INT\r\nAND N_ERL.SK_REPORT_LINE_ID_INT = SRC.REPORT_LINE_ID\r\nAND SRC.GLOBAL_NAME = N_SS_CD.GLOBAL_NAME\r\nAND N_SS_CD.SOURCE_SYSTEM_CODE = SM_ERA.SS_CD\r\nAND N_SS_CD.SOURCE_SYSTEM_CODE = N_ERL.BK_SS_CD",
