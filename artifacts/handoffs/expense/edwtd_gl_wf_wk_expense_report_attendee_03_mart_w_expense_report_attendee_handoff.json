      "attributes": {
        "Sql Query": "SELECT RANK() OVER (ORDER BY ST_MF_ATT.ATTENDEE_LINE_ID,\r\nST_MF_ATT.GLOBAL_NAME) + MAX_VAL EXPENSE_REPORT_ATTENDEE_KEY,\r\nST_MF_ATT.ATTENDEE_LINE_ID SK_ATTENDEE_LINE_ID_INT, \r\nN_SS_CD.SOURCE_SYSTEM_CODE SS_CD\r\nFROM\r\n$$STGDB.ST_MF_OIE_ATTENDEES_ALL ST_MF_ATT,\r\n$$COMREFVWDB.N_SOURCE_SYSTEM_CODES N_SS_CD,\r\n(SELECT COALESCE(MAX(EXPENSE_REPORT_ATTENDEE_KEY),0)MAX_VAL \r\nFROM $$TRANSLATIONDB.SM_EXPENSE_REPORT_ATTENDEE) SM_EXPENSE_REPORT_ATTENDEE\r\nWHERE\r\nST_MF_ATT.GLOBAL_NAME = N_SS_CD.GLOBAL_NAME\r\nAND \r\nNOT EXISTS\r\n(\r\nSELECT \r\n1 \r\nFROM\r\n$$TRANSLATIONDB.SM_EXPENSE_REPORT_ATTENDEE SM_EXP_REP_ATT\r\nWHERE\r\nSM_EXP_REP_ATT.SK_ATTENDEE_LINE_ID_INT = ST_MF_ATT.ATTENDEE_LINE_ID \r\nAND SM_EXP_REP_ATT.SS_CD = N_SS_CD.SOURCE_SYSTEM_CODE\r\n)",
