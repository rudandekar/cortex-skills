      "attributes": {
        "Sql Query": "SELECT \r\nST_ATT.BATCH_ID, \r\nST_ATT.ATTENDEE_LINE_ID, \r\nST_ATT.REPORT_LINE_ID, \r\nST_ATT.LAST_UPDATE_DATE, \r\nST_ATT.LAST_UPDATED_BY, \r\nST_ATT.CREATION_DATE, \r\nST_ATT.CREATED_BY, \r\nST_ATT.EMPLOYEE_FLAG, \r\nST_ATT.EMPLOYEE_ID, \r\nST_ATT.ATTENDEE_TYPE, \r\nST_ATT.NAME, \r\nST_ATT.TITLE_CD, \r\nST_ATT.EMPLOYER, \r\nST_ATT.EMPLOYER_ADDRESS, \r\nST_ATT.TAX_ID, \r\nST_ATT.ORG_ID, \r\nST_ATT.LAST_UPDATE_LOGIN, \r\nST_ATT.GES_UPDATE_DATE, \r\nST_ATT.GLOBAL_NAME, \r\nST_ATT.CREATE_DATETIME, \r\nST_ATT.ACTION_CODE \r\nFROM\r\n$$STGdb.ST_MF_OIE_ATTENDEES_ALL ST_ATT\r\nWHERE\r\nNOT EXISTS (\r\nSELECT 1 FROM $$WORKdb.W_EXPENSE_REPORT_ATTENDEE  W_ERA,\r\n$$COMREFVWdb.N_SOURCE_SYSTEM_CODES N_SS_CD\r\nWHERE \r\nST_ATT.ATTENDEE_LINE_ID = W_ERA.SK_ATTENDEE_LINE_ID_INT   \r\nAND ST_ATT.GLOBAL_NAME = N_SS_CD.GLOBAL_NAME\r\nAND N_SS_CD.SOURCE_SYSTEM_CODE = W_ERA.SS_CD\r\n)",
        "User Defined Join": "",
