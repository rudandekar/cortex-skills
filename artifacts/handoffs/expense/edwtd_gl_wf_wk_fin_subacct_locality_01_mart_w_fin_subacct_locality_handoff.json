      "attributes": {
        "Sql Query": "SELECT\r\n\tTVOUTPUT.BATCH_ID,\r\n\tTVOUTPUT.BK_SUBACCOUNT_LOCALITY_INT,\r\n\tTVOUTPUT.SUBACCOUNT_LOCALITY_NAME,\r\n\tTVOUTPUT.SK_SI_FLEX_STRUCT_ID_INT,\r\n\tTVOUTPUT.EDW_CREATE_DATETIME,\r\n\tTVOUTPUT.ACTION_CODE,\r\nTVOUTPUT.START_TV_DATE START_DATE_ACTIVE,\r\n\tCOALESCE(MAX (TVOUTPUT.START_TV_DATE - INTERVAL '1' DAY)\r\n\tOVER (PARTITION BY TVOUTPUT.BK_SUBACCOUNT_LOCALITY_INT  ORDER BY\r\n\tTVOUTPUT.START_TV_DATE ASC ROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING), DATE '3500-01-01') AS END_DATE_ACTIVE,\r\n\tROW_NUMBER() OVER (PARTITION BY TVOUTPUT.BK_SUBACCOUNT_LOCALITY_INT  \r\n\tORDER BY  TVOUTPUT.START_TV_DATE ASC) AS  RANK_INDEX,\r\n\t(CASE WHEN  RANK_INDEX = 1 AND NFSLTV_OUT.BK_SUBACCOUNT_LOCALITY_INT IS NOT NULL THEN 'U' ELSE 'I' END) AS DML_TYPE\r\nFROM\r\n(\r\n\tSELECT\r\n\tBATCH_ID,\r\n\tBK_SUBACCOUNT_LOCALITY_INT,\r\n\tSUBACCOUNT_LOCALITY_NAME,\r\n\tSK_SI_FLEX_STRUCT_ID_INT,\r\n\tSTART_TV_DATE,\r\n\tEDW_CREATE_DATETIME,\r\n\tACTION_CODE,\r\n\tEXCEPTION_TYPE,\r\n\tROW_NUMBER() OVER (PARTITION BY TVINPUT.BK_SUBACCOUNT_LOCALITY_INT, SUBACCOUNT_LOCALITY_NAME\r\n\tORDER BY EDW_CREATE_DATETIME DESC) AS ROW_NUM\r\n\tFROM\r\n\t(\r\n\t\tSELECT \r\n\t\t\tSSIFVSS.BATCH_ID,\r\n\t\t\tSSIFVSS.SI_FLEX_VALUE_SET_ID BK_SUBACCOUNT_LOCALITY_INT,\r\n\t\t\tSSIFVSS.SI_FLEX_VALUE_SET_DESC SUBACCOUNT_LOCALITY_NAME,\r\n\t\t\tSSIFVSS.SI_FLEX_STRUCT_ID SK_SI_FLEX_STRUCT_ID_INT,\r\n\t\t\tCAST(SSIFVSS.CREATE_DATETIME AS DATE) START_TV_DATE,\r\n\t\t\tSSIFVSS.CREATE_DATETIME  EDW_CREATE_DATETIME,\r\n\t\t\tSSIFVSS.ACTION_CODE,\r\n\t\t\t'NE' EXCEPTION_TYPE\r\n\t\tFROM $$STGDB.STSI_FLEX_VALUE_SET_STRUCT SSIFVSS\r\n\t\t\tWHERE SSIFVSS.SI_FLEX_STRUCT_ID  IN \r\n \t\t\t(\r\n\t\t\tSELECT DISTINCT SSISAI.SI_FLEX_STRUCT_ID FROM $$STGDB.ST_SI_SUB_ACCOUNT_INFO SSISAI\r\n\t\t\tUNION ALL\r\n\t\t\tSELECT ESSAI.SI_FLEX_STRUCT_ID FROM $$EXCEPDB.EX_SI_SUB_ACCOUNT_INFO ESSAI\r\n\t\t\tUNION ALL\r\n\t\t\tSELECT NFST.SK_SI_FLEX_STRUCT_ID_INT FROM $$FINLGLVWDB.N_FINANCIAL_SUBACCOUNT_TV NFST WHERE NFST.END_TV_DATE = 16000101\r\n\t\t\t)\r\n\t\tUNION ALL\r\n\t\tSELECT \r\n\t\t\t-999 BATCH_ID,\r\n\t\t\tNFSLTV.BK_SUBACCOUNT_LOCALITY_INT,\r\n\t\t\tNFSLTV.SUBACCOUNT_LOCALITY_NAME,\r\n\t\t\tNFSLTV.SK_SI_FLEX_STRUCT_ID_INT,\r\n\t\t\tNFSLTV.START_TV_DATE,\r\n\t\t\tNFSLTV.EDW_UPDATE_DATETIME EDW_CREATE_DATETIME,\r\n\t\t\t'X' ACTION_CODE,\r\n\t\t\t'NE' EXCEPTION_TYPE\r\n\t\tFROM $$FINLGLVWDB.N_FIN_SUBACCT_LOCALITY_TV  NFSLTV\r\n\t\tWHERE EXISTS (SELECT 1 FROM $$STGDB.STSI_FLEX_VALUE_SET_STRUCT SSIFVSS\r\n\t\t\t\tWHERE SSIFVSS.SI_FLEX_VALUE_SET_ID = NFSLTV.BK_SUBACCOUNT_LOCALITY_INT)\r\n\t\tAND NFSLTV.END_TV_DATE = 16000101\r\n\t)TVINPUT\r\n\tQUALIFY ROW_NUMBER () OVER (PARTITION BY TVINPUT.BK_SUBACCOUNT_LOCALITY_INT, TVINPUT.START_TV_DATE \r\n\tORDER BY TVINPUT.EDW_CREATE_DATETIME DESC) = 1\r\n)TVOUTPUT \r\n\tLEFT JOIN $$FINLGLVWDB.N_FIN_SUBACCT_LOCALITY_TV NFSLTV_OUT ON\r\n\tTVOUTPUT.BK_SUBACCOUNT_LOCALITY_INT = NFSLTV_OUT.BK_SUBACCOUNT_LOCALITY_INT \r\n\tAND NFSLTV_OUT.END_TV_DATE = 16000101\r\nWHERE ROW_NUM = 1",
