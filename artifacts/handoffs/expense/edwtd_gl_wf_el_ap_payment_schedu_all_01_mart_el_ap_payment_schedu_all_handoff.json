      "attributes": {
        "Sql Query": "Select \r\n      MF_APSA.GLOBAL_NAME,\r\n      MF_APSA.GES_UPDATE_DATE ,\r\n      MF_APSA.HOLD_FLAG,\r\n      MF_APSA.INVOICE_ID,\r\n      MF_APSA.PAYMENT_NUM,\r\n\tMF_APSA.CREATION_DATE\r\n      from \r\n      (Select \r\n      SMAPSA.GLOBAL_NAME,\r\n      SMAPSA.GES_UPDATE_DATE ,\r\n      SMAPSA.HOLD_FLAG,\r\n      SMAPSA.INVOICE_ID,\r\n      SMAPSA.PAYMENT_NUM,\r\n\t\tSMAPSA.CREATION_DATE\r\n      from $$STGDB.ST_MF_AP_PAYMENT_SCHEDU_ALL  SMAPSA\r\n\t  \r\n\t  UNION\r\n\t  Select \r\n      SCAPSA.GLOBAL_NAME,\r\n      SCAPSA.GES_UPDATE_DATE ,\r\n      SCAPSA.HOLD_FLAG,\r\n      SCAPSA.INVOICE_ID,\r\n      SCAPSA.PAYMENT_NUM,\r\n\t\tSCAPSA.CREATION_DATE\r\n      from $$STGDB.ST_CG1_AP_PAYMENT_SCHEDULES  SCAPSA\r\n      )MF_APSA\r\n      where (MF_APSA.GLOBAL_NAME ,MF_APSA.INVOICE_ID ,MF_APSA.PAYMENT_NUM)\r\n      NOT IN\r\n      (SELECT  EAPSA.GLOBAL_NAME ,EAPSA.INVOICE_ID ,EAPSA.PAYMENT_NUM from $$ETLVWDB.EL_AP_PAYMENT_SCHEDU_ALL EAPSA)",
