      "attributes": {
        "Sql Query": "SELECT\r\n MOCGP.ATTRIBUTE1,\r\n MOCGP.ATTRIBUTE2,\r\n MOCGP.ATTRIBUTE3,\r\n MOCGP.ATTRIBUTE4,\r\n MOCGP.ATTRIBUTE5,\r\n MOCGP.BUSINESS_UNIT_CODE,\r\n MOCGP.CREATED_BY,\r\n MOCGP.CREATION_DATE,\r\n MOCGP.DEPARTMENT_ID,\r\n MOCGP.ENABLED_FLAG,\r\n MOCGP.END_DATE_ACTIVE,\r\n MOCGP.GES_PK_ID,\r\n MOCGP.GES_UPDATE_DATE,\r\n MOCGP.GLOBAL_NAME,\r\n MOCGP.LAST_UPDATED_BY,\r\n MOCGP.LAST_UPDATE_DATE,\r\n MOCGP.LAST_UPDATE_LOGIN,\r\n MOCGP.PARENT_PROGRAM,\r\n MOCGP.PROJECT_ID,\r\n MOCGP.PROJECT_MGR,\r\n MOCGP.PROJECT_NAME,\r\n MOCGP.PROJECT_SEGMENT,\r\n MOCGP.START_DATE_ACTIVE,\r\n MOCGP.SUMMARY_FLAG \r\n FROM \r\n(SELECT\r\n SMCGP.ATTRIBUTE1,\r\n SMCGP.ATTRIBUTE2,\r\n SMCGP.ATTRIBUTE3,\r\n SMCGP.ATTRIBUTE4,\r\n SMCGP.ATTRIBUTE5,\r\n SMCGP.BUSINESS_UNIT_CODE,\r\n SMCGP.CREATED_BY,\r\n SMCGP.CREATION_DATE,\r\n SMCGP.DEPARTMENT_ID,\r\n SMCGP.ENABLED_FLAG,\r\n SMCGP.END_DATE_ACTIVE,\r\n SMCGP.GES_PK_ID,\r\n SMCGP.GES_UPDATE_DATE,\r\n SMCGP.GLOBAL_NAME,\r\n SMCGP.LAST_UPDATED_BY,\r\n SMCGP.LAST_UPDATE_DATE,\r\n SMCGP.LAST_UPDATE_LOGIN,\r\n SMCGP.PARENT_PROGRAM,\r\n SMCGP.PROJECT_ID,\r\n SMCGP.PROJECT_MGR,\r\n SMCGP.PROJECT_NAME,\r\n SMCGP.PROJECT_SEGMENT,\r\n SMCGP.START_DATE_ACTIVE,\r\n SMCGP.SUMMARY_FLAG \r\nFROM\r\n $$STGDB.ST_MF_CFI_GL_PROJECTS SMCGP\r\nUNION ALL\r\nSELECT\r\n SMCGP.ATTRIBUTE1,\r\n SMCGP.ATTRIBUTE2,\r\n SMCGP.ATTRIBUTE3,\r\n SMCGP.ATTRIBUTE4,\r\n SMCGP.ATTRIBUTE5,\r\n SMCGP.BUSINESS_UNIT_CODE,\r\n SMCGP.CREATED_BY,\r\n SMCGP.CREATION_DATE,\r\n SMCGP.DEPARTMENT_ID,\r\n SMCGP.ENABLED_FLAG,\r\n SMCGP.END_DATE_ACTIVE,\r\n SMCGP.GES_PK_ID,\r\n SMCGP.LAST_UPDATE_DATE,\r\n SMCGP.GLOBAL_NAME,\r\n SMCGP.LAST_UPDATED_BY,\r\n SMCGP.LAST_UPDATE_DATE,\r\n SMCGP.LAST_UPDATE_LOGIN,\r\n SMCGP.PARENT_PROGRAM,\r\n SMCGP.PROJECT_ID,\r\n SMCGP.PROJECT_MGR,\r\n SMCGP.PROJECT_NAME,\r\n SMCGP.PROJECT_SEGMENT,\r\n SMCGP.START_DATE_ACTIVE,\r\n SMCGP.SUMMARY_FLAG \r\nFROM\r\n $$STGDB.ST_CG1_XXCFI_GL_PROJECTS SMCGP \r\n  UNION ALL\r\n SELECT\r\n SOCGP.ATTRIBUTE1,\r\n SOCGP.ATTRIBUTE2,\r\n SOCGP.ATTRIBUTE3,\r\n SOCGP.ATTRIBUTE4,\r\n SOCGP.ATTRIBUTE5,\r\n SOCGP.BUSINESS_UNIT_CODE,\r\n SOCGP.CREATED_BY,\r\n SOCGP.CREATION_DATE,\r\n SOCGP.DEPARTMENT_ID,\r\n SOCGP.ENABLED_FLAG,\r\n SOCGP.END_DATE_ACTIVE,\r\n SOCGP.GES_PK_ID,\r\n SOCGP.GES_UPDATE_DATE,\r\n SOCGP.GLOBAL_NAME,\r\n SOCGP.LAST_UPDATED_BY,\r\n SOCGP.LAST_UPDATE_DATE,\r\n SOCGP.LAST_UPDATE_LOGIN,\r\n SOCGP.PARENT_PROGRAM,\r\n SOCGP.PROJECT_ID,\r\n SOCGP.PROJECT_MGR,\r\n SOCGP.PROJECT_NAME,\r\n SOCGP.PROJECT_SEGMENT,\r\n SOCGP.START_DATE_ACTIVE,\r\n SOCGP.SUMMARY_FLAG \r\nFROM\r\n$$STGDB.ST_OM_CFI_GL_PROJECTS  SOCGP\r\nWHERE SOCGP.GLOBAL_NAME='BO'  )  MOCGP\r\n WHERE ( MOCGP.GES_PK_ID,MOCGP.GLOBAL_NAME) NOT IN\r\n  (SELECT   ELCGP.GES_PK_ID,ELCGP.GLOBAL_NAME\r\n FROM  $$ETLVWDB.EL_CFI_GL_PROJECTS   ELCGP)",
