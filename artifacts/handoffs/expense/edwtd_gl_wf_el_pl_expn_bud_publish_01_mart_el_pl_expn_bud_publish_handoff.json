      "attributes": {
        "Sql Query": "SELECT\r\n(NFM.BK_FISCAL_YEAR_NUMBER_INT *100)+NFM.BK_FISCAL_MONTH_NUMBER_INT AS FISCAL_YEAR_MONTH_ID,\r\nSPEBPO.DEPT_ID,\r\nSPEBPO.ACCOUNT_ID,\r\nSPEBPO.M1,\r\nSPEBPO.M2,\r\nSPEBPO.M3,\r\nSPEBPO.M4,\r\nSPEBPO.M5,\r\nSPEBPO.M6,\r\nSPEBPO.M7,\r\nSPEBPO.M8,\r\nSPEBPO.M9,\r\nSPEBPO.M10,\r\nSPEBPO.M11,\r\nSPEBPO.M12,\r\nSPEBPO.REFRESH_DATE\r\nFROM \r\n(\r\nSELECT \r\nSPEBP.DEPT_ID,\r\nSPEBP.ACCOUNT_ID,\r\nSPEBP.M1,\r\nSPEBP.M2,\r\nSPEBP.M3,\r\nSPEBP.M4,\r\nSPEBP.M5,\r\nSPEBP.M6,\r\nSPEBP.M7,\r\nSPEBP.M8,\r\nSPEBP.M9,\r\nSPEBP.M10,\r\nSPEBP.M11,\r\nSPEBP.M12,\r\nSPEBP.REFRESH_DATE\r\nfrom $$STGDB.ST_PL_EXPN_BUD_PUBLISH SPEBP\r\nUNION ALL\r\nSELECT \r\nPEBPT.DEPT_ID,\r\nPEBPT.ACCOUNT_ID,\r\nPEBPT.M1,\r\nPEBPT.M2,\r\nPEBPT.M3,\r\nPEBPT.M4,\r\nPEBPT.M5,\r\nPEBPT.M6,\r\nPEBPT.M7,\r\nPEBPT.M8,\r\nPEBPT.M9,\r\nPEBPT.M10,\r\nPEBPT.M11,\r\nPEBPT.M12,\r\nPEBPT.REFRESH_DATE\r\nfrom $$STGDB.ST_PL_EXPN_PUBLISH_TIEOUT PEBPT\r\n) SPEBPO, $$COMREFVWDB.N_FISCAL_MONTH NFM\r\nWHERE (CAST(SPEBPO.REFRESH_DATE AS DATE) BETWEEN FISCAL_MONTH_START_DATE AND FISCAL_MONTH_END_DATE)\r\nAND ((FISCAL_YEAR_MONTH_ID,DEPT_ID,ACCOUNT_ID,REFRESH_DATE) NOT IN (SELECT EPEBP.FISCAL_YEAR_MONTH_ID,\r\nEPEBP.DEPT_ID,\r\nEPEBP.ACCOUNT_ID,EPEBP.REFRESH_DATE \r\nFROM $$ETLVWDB.EL_PL_EXPN_BUD_PUBLISH EPEBP))",
