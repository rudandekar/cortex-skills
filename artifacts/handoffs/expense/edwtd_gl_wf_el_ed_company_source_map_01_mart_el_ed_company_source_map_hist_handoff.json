      "attributes": {
        "Sql Query": "SELECT SECSM.COMPANY, \r\nSECSM.GLOBAL_NAME, \r\nSECSM.SET_OF_BOOKS_ID, \r\nSECSM.CURRENCY_CODE, \r\nSECSM.START_FISCAL_PERIOD_ID, \r\nCOALESCE(SECSM.END_FISCAL_PERIOD_ID,'350012') AS END_FSCL_PERIOD_ID\r\nFROM\r\n$$STGDB.ST_ED_COMPANY_SOURCE_MAP SECSM\r\nWHERE\r\n(COMPANY,SET_OF_BOOKS_ID,GLOBAL_NAME,CURRENCY_CODE,START_FISCAL_PERIOD_ID,END_FISCAL_PERIOD_ID) NOT IN \r\n\t(\r\n\tSELECT COMPANY,SET_OF_BOOKS_ID,GLOBAL_NAME,CURRENCY_CODE,START_FISCAL_PERIOD_ID,END_FISCAL_PERIOD_ID \r\n\tFROM $$STGDB.ST_ED_COMPANY_SOURCE_MAP  WHERE\r\n   \t(COMPANY = '177' AND SET_OF_BOOKS_ID =177 AND END_FISCAL_PERIOD_ID = '200508') OR (COMPANY = '540' AND SET_OF_BOOKS_ID = 22 AND END_FISCAL_PERIOD_ID = '200510')\r\n\t)\r\nAND\r\n (SECSM.COMPANY, \r\nSECSM.GLOBAL_NAME, \r\nSECSM.START_FISCAL_PERIOD_ID,\r\nEND_FSCL_PERIOD_ID) NOT IN\r\n(SELECT ELEDCSM.COMPANY,\r\nELEDCSM.GLOBAL_NAME, \r\nELEDCSM.START_FISCAL_PERIOD_ID,\r\nCOALESCE(ELEDCSM.END_FISCAL_PERIOD_ID,'350012') END_FSCL_PERIOD_ID\r\nFROM\r\n$$ETLVWDB.EL_ED_COMPANY_SOURCE_MAP ELEDCSM\r\n)",
