          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "SELECT PDIST.SK_PO_DISTRIBUTION_ID_INT     ,\r\n SUM (COALESCE (UNIT_PRICE,0) * COALESCE(XAU.INVOICE_QUANTITY,0))  ARIBA_AMOUNT\r\n        FROM $$ETLVWDB.EL_ARIBA_URAP_INVOICE XAU\r\n        INNER JOIN $$FINLGLVWDB.N_PO_SHIPMENT_DISTRIBUTION PDIST\r\nON XAU.CFN_PO_NUMBER = PDIST.BK_PURCHASE_ORDER_NUM         \r\n             AND XAU.PO_LINE_NUMBER = PDIST.BK_PURCHASE_ORDER_LINE_NUM_INT\r\n       WHERE     XAU.STATUS = 'ACTIVE'\r\n             AND XAU.TRANSACTION_TYPE = 'UAUR_PO_INV'\r\n             AND XAU.INACTIVE_DATE IS NULL \r\n\t\t\t AND PDIST.SS_CD                         ='EMEA'\r\n             AND XAU.STAGE_ACCOUNTING_DATE <= (SELECT FISCAL_MONTH_END_DATE FROM $$COMREFVWDB.N_FISCAL_MONTH \r\n WHERE DV_CURRENT_FISCAL_MONTH_FLAG = 'Y') \r\nAND NOT EXISTS (SELECT 1\r\n                       FROM $$FINLGLVWDB.N_VENDOR_INVOICE     AIA,\r\n                           $$FINLGLVWDB.N_VENDOR_INVOICE_LINE AILA\r\n                             WHERE     AIA.VENDOR_INVOICE_SOURCE_CD       LIKE 'ARIBA%'\r\n                            AND AIA.BK_VENDOR_INVOICE_NUM          = XAU.INVOICE_NUMBER\r\n                            AND AILA.SK_INVOICE_ID_INT              = AIA.SK_INVOICE_ID_INT\r\n                            AND AILA.SK_VENDOR_INVOICE_LINE_NUM_INT = XAU.INVOICE_LINE_NUMBER\r\n                            AND AILA.POSTING_DT                     <= (SELECT FISCAL_MONTH_END_DATE FROM $$COMREFVWDB.N_FISCAL_MONTH  WHERE DV_CURRENT_FISCAL_MONTH_FLAG = 'Y')) \r\n\t\t\t\t\t\t\tGROUP BY 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
