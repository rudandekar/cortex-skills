        "Sql Query": "SELECT ARIBA.PO_DISTRIBUTION_ID, \r\n  COALESCE(AP.AP_AMOUNT, 0) + COALESCE (ARIBA.ARIBA_AMOUNT, 0) PAID_AMOUNT\r\nFROM $$STGDB.WI_ARIBA_URAP_INV_ARIBA_AMT ARIBA\r\nLEFT OUTER JOIN $$STGDB.WI_ARIBA_URAP_INV_AP_AMT AP\r\nON AP.PO_DISTRIBUTION_ID = ARIBA.PO_DISTRIBUTION_ID\r\nGROUP BY 1,2",
