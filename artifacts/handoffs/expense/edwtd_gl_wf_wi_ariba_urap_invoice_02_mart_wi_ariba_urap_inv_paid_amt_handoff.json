      ],
      "attributes": {
        "Sql Query": "SELECT NPOSD.SK_PO_DISTRIBUTION_ID_INT, \r\nSUM((COALESCE (NVID.VNDR_INV_DISTRIB_INVOICED_QTY,0 ) *  COALESCE (NVID.VNDR_INV_DISTRIB_UNIT_PRC_AMT,0 ) )  )AP_AMOUNT\r\nFROM $$FINLGLVWDB.N_VENDOR_INVOICE_DISTRIBUTION  NVID\r\nINNER JOIN $$FINLGLVWDB.N_PO_SHIPMENT_DISTRIBUTION NPOSD\r\nON NVID.PO_SHIPMENT_DISTRIBUTION_KEY=NPOSD.PO_SHIPMENT_DISTRIBUTION_KEY\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR  RFMY\r\nON  RFMY.FISCAL_YEAR_MONTH_INT=(NVID.FISCAL_YEAR_NUMBER_INT *100 + NVID.FISCAL_MONTH_NUMBER_INT)\r\nAND CURRENT_FISCAL_MONTH_FLAG='Y'\r\nAND NVID.SS_CD='EMEA'\r\nGROUP BY 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
