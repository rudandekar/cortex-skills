      "attributes": {
        "Sql Query": "SELECT\r\n     EBP.PNR_LOCATOR   AS BK_AMEX_PNR_LOCATOR_ID                                      \t\r\n    ,EBP.GDS_CODE      AS BK_AMEX_GDS_CD                                              \t\r\n    ,EBP.CUSTOMER_ID   AS BK_AMEX_CUSTOMER_ID                                         \r\n    ,EBP.PAX_SEQUENCE  AS BK_AMEX_PAX_SEQUENCE_INT                                    \r\n    ,EBP.DEPART_DATE   AS TRIP_START_DT                                               \r\n    ,EBP.BOOKING_DATE  AS AMEX_TRAVEL_BOOKING_DT                                      \r\n    ,COALESCE (NCWP.CISCO_WORKER_PARTY_KEY,-999 )   AS TRAVELER_CISCO_WRKR_PARTY_KEY   \r\n    ,COALESCE ( NARFT.BK_REASON_FOR_TRAVEL_CD,EBP.UDID_INFO_NUM8,'UNKNOWN')  AS BK_REASON_FOR_TRAVEL_CD  /* Updated in R10 */\r\n    ,COALESCE ( NFD.BK_DEPARTMENT_CODE, 'UNKNOW') AS  FINANCIAL_DEPARTMENT_CD         \r\n    ,COALESCE (NFD.BK_COMPANY_CODE,'UNK') AS FINANCIAL_DEPT_COMPANY_CD \r\n   /* New columns in R10  */\r\n\t,EBP.AGENT_ID\tas BOOKING_AGENT_ID_NUM\r\n    ,EBP.AGENT_TICKETING\tas TICKETING_AGENT_ID_NUM\r\n    ,EBP.CAR_CONVERTED_AMOUNT\t  as  INITIAL_CAR_RENTAL_RPRTNG_AMT\r\n    ,COALESCE(NIC.BK_ISO_CURRENCY_CODE  ,EBI.CONVERTED_CURRENCY2  ,'UNK') as REPORTING_CURRENCY_CD\r\n    ,EBP.CAR_DAYS\t   as INITIAL_CAR_DAYS_RESERVED_CNT\r\n\t,EBP.HOTEL_CONVERTED_AMOUNT\t as INITIAL_HOTEL_REPORTING_AMT\r\n\t,EBP.HOTEL_NIGHTS\t as INITIAL_HOTEL_NIGHTS_CNT\r\n\t,EBP.ITINERARY\tas  ITINERARY_DESCR\r\n    ,EBP.PHONE_AGENCY\tas TRAVEL_AGENCY_PHONE_NUM\r\n\t,EBP.PHONE_DEFAULT\t as RPRTD_PASSNGR_BUSINESS_PH_NUM\r\n\t,EBP.PHONE_HOME as RPRTD_PASSNGR_HOME_PH_NUM\r\n\t,EBP.PHONE_FAX\t as RPRTD_PASSNGR_FAX_NUM\r\n\t,EBP.RETURN_DATE as PASSENGER_RETURN_DT\r\n\t,COALESCE( EBP.SEAT_PREFERENCE,'=')  as SEAT_TYPE_PREFERENCE_CD\r\n\t,EBP.STATEMENT1 as STATEMENT_NUM\r\n\t,EBP.TICKETED_INDICATOR\t as TICKETED_FLG\t\r\n    ,'I' as ACTION_CODE\r\n    ,'I' AS DML_TYPE  \r\nFROM $$ETLVWDB.EL_BOOKED_PNR EBP\r\nLeft Outer JOIN $$FINLGLVWDB.N_AMEX_REASON_FOR_TRAVEL NARFT\r\n \tON EBP.UDID_INFO_NUM8= NARFT.BK_REASON_FOR_TRAVEL_CD\r\nLEFT OUTER JOIN \r\n\t\t( select  CAST(BK_EMPLOYEE_ID AS INTEGER)  as BK_EMPLOYEE_ID_INT ,  CISCO_WORKER_PARTY_KEY\r\n \t\t\tfrom \t$$COMREFVWDB.N_CISCO_WORKER_PARTY_TV \r\n\t\t\tWHERE \r\n\t\t\tUPPER ( BK_EMPLOYEE_ID ) (CASESPECIFIC) = LOWER (BK_EMPLOYEE_ID ) (CASESPECIFIC) \r\n\t\t\tAND END_TV_DATE ='3500-01-01'  \t\r\n\t\t\tQUALIFY  ROW_NUMBER() OVER (PARTITION BY  CAST(BK_EMPLOYEE_ID AS INTEGER) \r\n\t\t\t\t\t\t\t\t\tORDER BY CISCO_WORKER_PARTY_KEY  ASC)  =1\r\n\t\t) NCWP\r\n\tON NCWP.BK_EMPLOYEE_ID_INT = cast ( EBP.EMPLID as integer) \r\nLeft Outer Join  $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT NFD\r\n\t\tON ( NFD.BK_COMPANY_CODE         =  SUBSTR( EBP.DEPARTMENT_CODE,1,3) \r\n\t\t\t AND  NFD.BK_DEPARTMENT_CODE =  SUBSTR( EBP.DEPARTMENT_CODE,4,6) \r\n            )\r\n /* New in R10  */\r\nLEFT OUTER JOIN  $$ETLVWDB.EL_BOOKED_INVOICE EBI \r\n ON(  EBI.PNR_LOCATOR4   =  EBP.PNR_LOCATOR\r\n\t and EBI.GDS_CODE4          =   EBP.GDS_CODE                    \r\n\t and EBI.CUSTOMER_ID4    =    EBP.CUSTOMER_ID              \r\n\t and EBI.PAX_SEQUENCE4 =    EBP.PAX_SEQUENCE     \r\n\t)\r\nleft outer  JOIN $$FINLGLVWDB.N_ISO_CURRENCY_TV  NIC\r\n  ON( EBI.CONVERTED_CURRENCY2   =  NIC.BK_ISO_CURRENCY_CODE  \r\n       and NIC.END_TV_DATE =  '3500-01-01' )",
        "User Defined Join": "",
        "Source Filter": "",
