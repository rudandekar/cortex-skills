      "attributes": {
        "Sql Query": "SELECT\r\nCLIENT_MEETING_ID             ,\r\nCREATION_DATE                 ,\r\nMEETING_START_DT              ,\r\nMEETING_END_DT            ,    \r\nMEETING_STATUS            ,    \r\nEXPECTED_ATTENDEES_CNT        ,\r\nESTIMATED_MEETING_BUDGET      ,\r\nEVENT_TYPE_ATTR          ,     \r\nMEETING_GL                   , \r\nREQUESTOR_EMAIL        ,       \r\nMEETING_SITE_CD           ,  \r\nCURRENT_TIMESTAMP(0),  \r\nACTION_CODE                   ,\r\n'RI - EMAIL ID missing in cisco worker party' EXCEPTION_TYPE\r\nFROM\r\n$$STGDB.ST_EXPENSABLE_MEETING STG\r\nWHERE NOT EXISTS (SELECT 1 FROM $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP WHERE STG.REQUESTOR_EMAIL=(TRIM(NCWP.CISCO_EMAIL_ADDRESS)||'@cisco.com'))\r\nUNION ALL\r\nSELECT\r\nCLIENT_MEETING_ID             ,\r\nCREATION_DATE                 ,\r\nMEETING_START_DT              ,\r\nMEETING_END_DT            ,    \r\nMEETING_STATUS            ,    \r\nEXPECTED_ATTENDEES_CNT        ,\r\nESTIMATED_MEETING_BUDGET      ,\r\nEVENT_TYPE_ATTR          ,     \r\nMEETING_GL                   , \r\nREQUESTOR_EMAIL        ,       \r\nMEETING_SITE_CD           ,    \r\nCURRENT_TIMESTAMP(0), \r\nACTION_CODE                   ,\r\n'RI - Financial account code missing' EXCEPTION_TYPE\r\nFROM\r\n$$STGDB.ST_EXPENSABLE_MEETING STGFA\r\nWHERE NOT EXISTS (SELECT 1 FROM $$FINLGLVWDB.N_FINANCIAL_ACCOUNT NFA WHERE STGFA.MEETING_GL=NFA.BK_FINANCIAL_ACCOUNT_CODE)",
