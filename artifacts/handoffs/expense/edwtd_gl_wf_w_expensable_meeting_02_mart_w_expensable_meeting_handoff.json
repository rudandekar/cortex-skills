      "attributes": {
        "Sql Query": "SELECT\r\nCLIENT_MEETING_ID,\r\nCOALESCE(CREATION_DATE,TIMESTAMP '3500-01-01 00:00:00') CREATION_DATE,\r\nCOALESCE(CREATION_DATE,DATE '3500-01-01') DV_CREATION_DATE,\r\nCOALESCE(MEETING_START_DT,DATE '3500-01-01') MEETING_START_DT ,\r\nCOALESCE(MEETING_END_DT,DATE '3500-01-01') MEETING_END_DT ,\r\nCOALESCE(MEETING_STATUS,'UNKNOWN'),\r\nCOALESCE(EXPECTED_ATTENDEES_CNT,-999),\r\nCOALESCE(ESTIMATED_MEETING_BUDGET,'UNKNOWN'),\r\nCOALESCE(EVENT_TYPE_ATTR,'UNKNOWN'),\r\nCOALESCE(NCWP.CISCO_WORKER_PARTY_KEY,-999) CISCO_WORKER_PARTY_KEY,\r\nCOALESCE(MEETING_SITE_CD,'UNKNOWN'),\r\nCOALESCE(BK_FINANCIAL_ACCOUNT_CODE,'UNKNOWN'),\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER ,\r\nACTION_CODE,\r\n'I' DML_TYPE\r\nFROM\r\n$$STGDB.ST_EXPENSABLE_MEETING STEXP\r\nINNER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP\r\nON\r\nSTEXP.REQUESTOR_EMAIL=(TRIM(NCWP.CISCO_EMAIL_ADDRESS)||'@cisco.com')\r\nLEFT JOIN\r\n$$FINLGLVWDB.N_FINANCIAL_ACCOUNT NFA\r\nON\r\nSTEXP.MEETING_GL=NFA.BK_FINANCIAL_ACCOUNT_CODE",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
