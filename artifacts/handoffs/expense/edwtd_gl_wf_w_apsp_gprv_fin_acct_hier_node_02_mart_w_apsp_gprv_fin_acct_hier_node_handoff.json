      "attributes": {
        "Sql Query": "SELECT ACCOUNT_GROUP_ID\r\n,NODE_TYPE\r\n,PARENT_ACCOUNT_GROUP_ID\r\n,ACCT_NODE_LEVEL_NUMBER_INT\r\nFROM ( \r\nselect CATEGORY_LEVEL1 AS ACCOUNT_GROUP_ID\r\n,3 AS ACCT_NODE_LEVEL_NUMBER_INT\r\n,'MIDDLE' AS NODE_TYPE\r\n,CATEGORY AS PARENT_ACCOUNT_GROUP_ID\r\nfrom $$STGDB.ST_RV_ACCOUNT_HIERARCHY\r\nWHERE HIERARCHY_TYPE = 'Sub'\r\nAND CATEGORY_LEVEL2 IS NOT NULL\r\nGROUP BY CATEGORY_LEVEL1, CATEGORY \r\nUNION ALL\r\nselect CATEGORY_LEVEL2 AS ACCOUNT_GROUP_ID\r\n,4 AS ACCT_NODE_LEVEL_NUMBER_INT\r\n,'LEAF' AS NODE_TYPE\r\n,CATEGORY_LEVEL1 AS PARENT_ACCOUNT_GROUP_ID\r\nfrom $$STGDB.ST_RV_ACCOUNT_HIERARCHY\r\nWHERE HIERARCHY_TYPE = 'Sub'  AND CATEGORY_LEVEL2 IS NOT NULL\r\nGROUP BY CATEGORY_LEVEL1, CATEGORY_LEVEL2 \r\nUNION ALL\r\nselect CATEGORY_LEVEL1 AS ACCOUNT_GROUP_ID\r\n,3 AS ACCT_NODE_LEVEL_NUMBER_INT\r\n,'LEAF' AS NODE_TYPE\r\n,CATEGORY AS PARENT_ACCOUNT_GROUP_ID\r\nfrom $$STGDB.ST_RV_ACCOUNT_HIERARCHY\r\nWHERE HIERARCHY_TYPE = 'Sub'\r\nAND CATEGORY_LEVEL2 IS NULL\r\nGROUP BY CATEGORY_LEVEL1, CATEGORY \r\nUNION ALL\r\nSELECT 'ALL' AS ACCOUNT_GROUP_ID\r\n,1 AS ACCT_NODE_LEVEL_NUMBER_INT\r\n,'ROOT' AS NODE_TYPE\r\n,'NONE' AS PARENT_ACCOUNT_GROUP_ID\r\nfrom $$STGDB.ST_RV_ACCOUNT_HIERARCHY\r\nWHERE HIERARCHY_TYPE = 'Sub'\r\nGROUP BY 'ALL', 1, 'ROOT', 'NONE'\r\nUNION ALL\r\nselect CATEGORY AS ACCOUNT_GROUP_ID\r\n,2 AS ACCT_NODE_LEVEL_NUMBER_INT\r\n,'MIDDLE' AS NODE_TYPE\r\n,'ALL' AS PARENT_ACCOUNT_GROUP_ID\r\nfrom $$STGDB.ST_RV_ACCOUNT_HIERARCHY\r\nWHERE HIERARCHY_TYPE = 'Sub'\r\nGROUP BY CATEGORY\r\n) AA",
