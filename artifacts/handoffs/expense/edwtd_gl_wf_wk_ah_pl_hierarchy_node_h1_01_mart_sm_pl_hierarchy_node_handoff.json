        }
      ],
      "attributes": {
        "Sql Query": "SELECT\r\nST.PL_HIERARCHY_NODE_KEY,\r\nST.PL_HIER_NODE_LEVEL_NUMBER_INT,\r\nST.PARENT_PL_HIER_NODE_KEY,\r\nST.PL_HIERARCHY_NODE_NM,\r\nST.NODE_VALUE_CD, \r\nST.NODE_TYPE,\r\nST.NODE_ID_INT,\r\nST.BK_PROFIT_CENTER_NAME,\r\n'ROLLING-WORKING' AS BK_FD_ALTERNATE_HIERARCHY_ID,\r\nST.START_TV_DT ,\r\n'3500-01-01' AS  END_TV_DT,\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM\r\n(\r\n\t\tSELECT\t\r\n\t\t\t     SPLHN.PL_HIERARCHY_NODE_KEY,\r\n\t\t\t     CAST(SOSHP.PUBLISHED_DATE AS DATE) START_TV_DT,\r\n\t\t\t\t CASE\r\n\t\t\t\t\tWHEN\tSOSHP.NODE_VALUE ='450'\r\n\t\t\t\t\tAND\t\tSOSHP.NODE_TYPE='P' THEN 'ROOT'\r\n\t\t\t\t\tWHEN\tSOSHP.NODE_TYPE='D' THEN 'LEAF'\r\n\t\t\t\t\tELSE\t'MIDDLE'\r\n\t\t\t\t END\t AS NODE_TYPE,\r\n\t\t\t     SOSHP.NODE_VALUE AS NODE_VALUE_CD,\r\n\t\t\t     SMPARENT.PL_HIERARCHY_NODE_KEY AS PARENT_PL_HIER_NODE_KEY,\r\n\t\t\t     SOSHPP.LEVEL_NO AS PL_HIER_NODE_LEVEL_NUMBER_INT,\r\n\t\t\t     SOSHP.NODE_DESC    PL_HIERARCHY_NODE_NM ,\r\n\t\t\t     SOSHP.NODE_ID NODE_ID_INT,\r\n\t\t\t     COALESCE(GEN2 ,'UNKNOWN') AS BK_PROFIT_CENTER_NAME \r\n\t\tFROM\t$$STGDB.ST_SI_HIERARCHY_AH_PUBLISHED SOSHP \r\n\t\tLEFT OUTER JOIN $$ETLONLYDB.EL_PROFIT_CENTER_HIERARCHY EPCH\r\n\t\t\tON (  EPCH.PL_NODE_VALUE = SOSHP.NODE_VALUE )\r\n           ,$$ETLVWDB.SM_PL_HIERARCHY_NODE  SPLHN\r\n\t       ,(SELECT\tSI.NODE_ID,SI.NODE_VALUE,SI.NODE_DESC, SINODE.PL_HIERARCHY_NODE_KEY\r\n\t\t\t  FROM  $$STGDB.WI_SI_HIERARCHY_AH_PUBLISHED SI,\r\n\t\t\t\t\t$$ETLVWDB.SM_PL_HIERARCHY_NODE SINODE\r\n\t\t\t  WHERE  SI.NODE_ID= SINODE.SK_NODE_ID_INT) SMPARENT,\r\n\t    \t$$STGDB.WI_SI_HIERARCHY_AH_PUBLISHED SOSHPP\r\n\t\tWHERE\t\t\r\n\t\t\t\tSOSHP.NODE_ID = SPLHN.SK_NODE_ID_INT\r\n\t\t\t\tAND\tSOSHP.PARENT_NODE_ID = SMPARENT.NODE_ID\r\n\t\t\t\tAND\tSOSHP.NODE_ID = SOSHPP.NODE_ID\r\n\t\t\t\tAND\tSOSHP.HIERARCHY_TYPE='P/L'\r\n\r\nUNION ALL\r\n\t\tSELECT\t\r\n\t\t\t     SPLHN.PL_HIERARCHY_NODE_KEY,\r\n\t\t\t     CAST(SOSHP.PUBLISHED_DATE AS DATE) START_TV_DT,\r\n\t\t\t     CASE\r\n\t\t\t\t\tWHEN\tSOSHP.NODE_VALUE ='450'\r\n\t\t\t\t\tAND\t\tSOSHP.NODE_TYPE='P' THEN 'ROOT'\r\n\t\t\t\t\tWHEN\tSOSHP.NODE_TYPE='D' THEN 'LEAF'\r\n\t\t\t\t\tELSE\t'MIDDLE'\r\n\t\t\t\t\tEND\t AS NODE_TYPE,\r\n\t\t\t     SOSHP.NODE_VALUE AS NODE_VALUE_CD,\r\n\t\t\t     NULL AS PARENT_PL_HIER_NODE_KEY,\r\n\t\t\t     SOSHPP.LEVEL_NO AS PL_HIER_NODE_LEVEL_NUMBER_INT,\r\n\t\t\t     SOSHP.NODE_DESC    PL_HIERARCHY_NODE_NM ,\r\n\t\t\t     SOSHP.NODE_ID NODE_ID_INT,\r\n\t\t\t     COALESCE(GEN2 ,'UNKNOWN') AS BK_PROFIT_CENTER_NAME \r\n\t\tFROM  $$STGDB.ST_SI_HIERARCHY_AH_PUBLISHED SOSHP \r\n\t\t\tLEFT OUTER JOIN $$ETLONLYDB.EL_PROFIT_CENTER_HIERARCHY EPCH\r\n\t\t\tON (  EPCH.PL_NODE_VALUE = SOSHP.NODE_VALUE )\r\n\t\t\t ,$$ETLVWDB.SM_PL_HIERARCHY_NODE  SPLHN,\r\n\t\t     $$STGDB.WI_SI_HIERARCHY_AH_PUBLISHED SOSHPP\r\n\t\tWHERE\t\t\r\n\t\t      SOSHP.NODE_ID = SPLHN.SK_NODE_ID_INT\r\n\t\t\t\tAND\tSOSHP.NODE_ID = SOSHPP.NODE_ID\r\n\t\t\t\tAND\tSOSHP.HIERARCHY_TYPE='P/L'\r\n\t\t\t\tAND SOSHP.NODE_VALUE = '450'\r\n\t\r\n )ST",
        "User Defined Join": "",
        "Source Filter": "",
