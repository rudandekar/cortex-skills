      "attributes": {
        "Sql Query": "SELECT \r\n'Fiscal Year' BK_FISCAL_CALENDAR_CD,\r\nSTPUB.FISCAL_MONTH_ID/100 BK_FISCAL_YEAR_NUM_INT ,  \r\nSTPUB.FISCAL_MONTH_ID-(STPUB.FISCAL_MONTH_ID/100)*100 BK_FISCAL_MONTH_NUM_INT,\r\nNFDTV.BK_DEPARTMENT_CODE BK_DEPARTMENT_CD,\r\n '00000' BK_FINANCIAL_ACCOUNT_CD, /* NFACTV.BK_FINANCIAL_ACCOUNT_CODE BK_FINANCIAL_ACCOUNT_CD,*/\r\nNST.SALES_TERRITORY_KEY SALES_TERRITORY_KEY  ,\r\nNCMC.BK_CNTRBTN_MRGN_CATEGORY_CD BK_CNTRBTN_MRGN_CATEGORY_CD  ,\r\nNPTV.ITEM_KEY PRODUCT_KEY ,\r\nNFDTV.BK_COMPANY_CODE BK_COMPANY_CD ,\r\nSTPUB.PNL_MEASURE_NAME BK_OPEX_MAPPING_TYPE_NAME,\r\n'000' BK_FINANCIAL_LOCATION_CD, /* NFLTV.BK_FINANCIAL_LOCATION_CODE BK_FINANCIAL_LOCATION_CD, */\r\n'000' BK_SUBACCOUNT_CD, /* STPUB.SUB_ACCOUNT_CD BK_SUBACCOUNT_CD, */\r\nNCMRC.BK_CB_MRGN_ROLLUP_CAT_CD BK_CB_MRGN_ROLLUP_CAT_CD  ,\r\n/* STPUB.END_FISCAL_MONTH/100 OPEX_END_FISCAL_YEAR_NUM_INT      ,*/\r\nSTPUB.FISCAL_MONTH_ID/100 OPEX_END_FISCAL_YEAR_NUM_INT      ,\r\n/* STPUB.END_FISCAL_MONTH -(STPUB.END_FISCAL_MONTH/100 ) *100 OPEX_END_FISCAL_MONTH_NUM_INT   ,*/\r\nSTPUB.FISCAL_MONTH_ID -(STPUB.FISCAL_MONTH_ID/100 ) *100 OPEX_END_FISCAL_MONTH_NUM_INT   ,\r\n/* STPUB.START_FISCAL_MONTH/100 OPEX_STRT_FISCAL_YEAR_NUM_INT, */\r\nSTPUB.FISCAL_MONTH_ID/100 OPEX_STRT_FISCAL_YEAR_NUM_INT,\r\n/* STPUB.START_FISCAL_MONTH-(STPUB.START_FISCAL_MONTH/100)*100 OPEX_STRT_FISCAL_MONTH_NUM_INT,*/\r\nSTPUB.FISCAL_MONTH_ID-(STPUB.FISCAL_MONTH_ID/100)*100 OPEX_STRT_FISCAL_MONTH_NUM_INT,\r\nSTPUB.FISCAL_MONTH_ID DV_BK_FISCAL_YEAR_MONTH_INT , \r\n'N' INCREMENTAL_FLG , /* STPUB.INCREMENTAL_FLAG INCREMENTAL_FLG ,*/\r\nSUM(STPUB.ALLOCATION_PERCENTAGE)  OPEX_ALLOCATION_PERCENT     ,\r\n'=' BK_PROJECT_CODE, /* NFPTV.BK_PROJECT_CODE BK_PROJECT_CODE ,*/\r\n -999 BK_SUBACCOUNT_LOCALITY_INT      , \r\n -999 BK_FIN_ACCT_LOCALITY_INT    , \r\n -999 BK_PROJECT_LOCALITY_INT     , \r\n'UNKNOWN' BK_PRODUCT_FAMILY_ID  ,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM ,\r\nUSER EDW_CREATE_USER ,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM ,\r\nUSER EDW_UPDATE_USER,\r\n'N' TG_SHARED_FLAG , /*STPUB.TG_SHARED_FLAG */\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM $$STGDB.ST_AE_OPXALOC_ALLOCATION_PUB STPUB\r\nINNER JOIN $$COMREFVWDB.N_FISCAL_MONTH NFM \r\nON STPUB.FISCAL_MONTH_ID = (NFM.BK_FISCAL_YEAR_NUMBER_INT*100+NFM.BK_FISCAL_MONTH_NUMBER_INT) \r\n\r\n/* INNER JOIN $$FINLGLVWDB.N_FINANCIAL_ACCOUNT NFACTV  \r\nON NFACTV.BK_FINANCIAL_ACCOUNT_CODE = STPUB.FINANCIAL_ACCOUNT_CD */\r\n/* Commented as part of Q4FY20 ICPM DFA - OPEX */\r\n/* INNER JOIN ( SELECT BK_PROJECT_CODE FROM $$FINLGLVWDB.N_FINANCIAL_PROJECT GROUP BY 1 ) NFPTV\r\nON NFPTV.BK_PROJECT_CODE =STPUB.PROJECT_CD  */\r\n\r\nINNER JOIN $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT NFDTV \r\nON NFDTV.BK_DEPARTMENT_CODE = STPUB.DEPARTMENT_CD  \r\nAND NFDTV.BK_COMPANY_CODE = STPUB.COMPANY_CD \r\n\r\n/* INNER JOIN $$FINLGLVWDB.N_FINANCIAL_LOCATION NFLTV \r\nON NFLTV.BK_FINANCIAL_LOCATION_CODE=  STPUB.LOCATION_CD */\r\n\r\nINNER JOIN $$FINLGLVWDB.N_CNTRBTN_MRGN_CATEGORY NCMC\r\nON NCMC.SK_SUB_MEASURE_KEY_INT = STPUB.SUB_MEASURE_KEY \r\n\r\nINNER JOIN $$FINLGLVWDB.N_CNTRBTN_MRGN_ROLLUP_CATEGORY NCMRC \r\nON NCMRC.SK_MEASURE_ID_INT = STPUB.MEASURE_ID\r\n\r\n/*\r\nINNER JOIN $$COMREFVWDB.N_SALES_TERRITORY NST\r\nON NST.BK_SALES_TERRITORY_NAME_CODE =STPUB.SALES_TERRITORY_CODE\r\nAND BK_SALES_HIERARCHY_TYPE_CODE IN ( 'CORP. REVENUE', 'UNKNOWN' )\r\n*/\r\n\r\nINNER JOIN $$COMREFVWDB.R_SALES_HIERARCHY NST\r\nON NST.SALES_TERRITORY_NAME_CODE=STPUB.SALES_TERRITORY_CODE\r\nAND NST.SALES_TERRITORY_TYPE_CODE IN ('CORP. REVENUE','UNKNOWN')\r\n\r\nINNER JOIN $$COMREFVWDB.N_PRODUCT NPTV \r\nON NPTV.BK_PRODUCT_ID = STPUB.PRODUCT_ID\r\n\r\nGROUP BY \r\nNFDTV.BK_DEPARTMENT_CODE \r\n/*,NFACTV.BK_FINANCIAL_ACCOUNT_CODE*/\r\n,NST.SALES_TERRITORY_KEY\r\n,NCMC.BK_CNTRBTN_MRGN_CATEGORY_CD\r\n,NPTV.ITEM_KEY\r\n,NFDTV.BK_COMPANY_CODE\r\n,STPUB.PNL_MEASURE_NAME\r\n/*,NFLTV.BK_FINANCIAL_LOCATION_CODE\r\n,STPUB.SUB_ACCOUNT_CD */\r\n,NCMRC.BK_CB_MRGN_ROLLUP_CAT_CD\r\n/*,STPUB.END_FISCAL_MONTH\r\n,STPUB.START_FISCAL_MONTH */\r\n,STPUB.FISCAL_MONTH_ID \r\n/*,STPUB.INCREMENTAL_FLAG\r\n,NFPTV.BK_PROJECT_CODE\r\n,STPUB.TG_SHARED_FLAG */",
        "User Defined Join": "",
