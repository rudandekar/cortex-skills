      "attributes": {
        "Sql Query": "SELECT  \r\n'Fiscal Year' BK_FISCAL_CALENDAR_CD,\r\nSTEXP.FISCAL_YEAR_MONTH_NUM_INT/100 BK_FISCAL_YEAR_NUM_INT ,  \r\nSTEXP.FISCAL_YEAR_MONTH_NUM_INT-(STEXP.FISCAL_YEAR_MONTH_NUM_INT/100)*100 BK_FISCAL_MONTH_NUM_INT,\r\nNFD. BK_DEPARTMENT_CODE BK_DEPARTMENT_CD,\r\nNFAC.BK_FINANCIAL_ACCOUNT_CODE   BK_FINANCIAL_ACCOUNT_CD            ,\r\nNFL.BK_FINANCIAL_LOCATION_CODE  BK_FINANCIAL_LOCATION_CD         ,\r\nNFPRJ.BK_PROJECT_CODE  BK_PROJECT_CODE ,\r\nSTEXP.SUB_ACCOUNT_CODE  BK_SUBACCOUNT_CD, \r\nNPRDT.ITEM_KEY     PRODUCT_KEY     ,\r\nNFD.BK_COMPANY_CODE      BK_COMPANY_CD   ,\r\nSUBSTR(STEXP.CLARITY_PROJECT_ID,1,2) BK_CLARITY_PROJECT_TYPE_CD,\r\nSUBSTR(STEXP.CLARITY_PROJECT_ID,2) BK_CLARITY_PROJECT_NUM,\r\n'FIN_OPEX' BK_SS_CLARITY_TRACKED_PROJ_CD   ,\r\nSTEXP.ALLOCATED_FLAG  ALLOCATED_FLG   ,\r\nSTEXP.PLATFORM PLATFORM_NAME    ,\r\nSUM(STEXP.FUNCTIONAL_AMT) OPEX_FUNCTIONAL_AMT           ,\r\nSUM(STEXP.USD_AMT) OPEX_USD_AMT    ,\r\nSTEXP.FISCAL_YEAR_MONTH_NUM_INT DV_BK_FISCAL_YEAR_MONTH_INT,\r\nSUM(STEXP.FTE_COUNT) FTE_CNT         ,\r\n-999  BK_PROJECT_LOCALITY_INT           ,  \r\n -999  BK_SUBACCOUNT_LOCALITY_INT       , \r\n -999  BK_FIN_ACCT_LOCALITY_INT          , \r\nSTEXP.BK_FUNCTIONAL_CURRENCY_CODE  FUNCTIONAL_CURRENCY_CD          ,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM  ,\r\nUSER EDW_CREATE_USER ,\r\nCURRENT_TIMESTAMP(0) EDW_UPDATE_DTM  ,\r\nUSER EDW_UPDATE_USER ,\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE                 \r\nFROM $$STGDB.ST_FIN_CLARITY_PROJ_EXPENSE STEXP     \r\n\r\nINNER JOIN $$COMREFVWDB. N_FISCAL_MONTH NFM \r\nON STEXP.FISCAL_YEAR_MONTH_NUM_INT=(NFM.BK_FISCAL_YEAR_NUMBER_INT*100+NFM.BK_FISCAL_MONTH_NUMBER_INT)      \r\n\r\nINNER JOIN $$FINLGLVWDB. N_FINANCIAL_DEPARTMENT NFD    \r\nON NFD.BK_DEPARTMENT_CODE    = STEXP. DEPARTMENT_CODE \r\nAND  NFD. BK_COMPANY_CODE    = STEXP. COMPANY_CODE   \r\n\r\nINNER JOIN $$FINLGLVWDB.N_FINANCIAL_ACCOUNT NFAC                        \r\nON NFAC. BK_FINANCIAL_ACCOUNT_CODE  = STEXP.FINANCIAL_ACCOUNT_CODE  \r\n\r\nINNER JOIN $$FINLGLVWDB.N_FINANCIAL_LOCATION NFL                    \r\nON NFL.BK_FINANCIAL_LOCATION_CODE     = STEXP.LOCATION_CODE \r\n\r\nINNER JOIN $$COMREFVWDB.N_PRODUCT NPRDT                       \r\nON NPRDT.BK_PRODUCT_ID    = STEXP.PRODUCT_ID     \r\n\r\nINNER JOIN (SELECT BK_PROJECT_CODE FROM $$FINLGLVWDB.N_FINANCIAL_PROJECT GROUP BY 1  )      NFPRJ       \r\nON NFPRJ.BK_PROJECT_CODE  = STEXP.PROJECT_CODE\r\n\r\nGROUP BY \r\nNFD. BK_DEPARTMENT_CODE ,\r\nNFAC.BK_FINANCIAL_ACCOUNT_CODE              ,\r\nNFL.BK_FINANCIAL_LOCATION_CODE          ,\r\nNFPRJ.BK_PROJECT_CODE   ,\r\nSTEXP.SUB_ACCOUNT_CODE  , \r\nNPRDT.ITEM_KEY          ,\r\nNFD.BK_COMPANY_CODE         ,\r\nSUBSTR(STEXP.CLARITY_PROJECT_ID,1,2) ,\r\nSUBSTR(STEXP.CLARITY_PROJECT_ID,2),\r\nSTEXP.ALLOCATED_FLAG    ,\r\nSTEXP.PLATFORM     ,\r\nSTEXP.FISCAL_YEAR_MONTH_NUM_INT ,\r\nSTEXP.BK_FUNCTIONAL_CURRENCY_CODE",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
