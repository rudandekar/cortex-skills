      "attributes": {
        "Sql Query": "SELECT\r\nELPLTT.CREATION_DATE ,\r\nELPLTT.DESCRIPTION ,\r\nELPLTT.LANGUAGE_CODE ,\r\nELPLTT.LAST_UPDATE_DATE ,\r\nELPLTT.LINE_TYPE ,\r\nELPLTT.LINE_TYPE_ID ,\r\nELPLTT.SOURCE_LANG,\r\nELPLTT.GES_UPDATE_DATE ,\r\nELPLTT.GLOBAL_NAME \r\nFROM\r\n( SELECT\r\nSMPLTT.CREATION_DATE ,\r\nSMPLTT.DESCRIPTION ,\r\nSMPLTT.LANGUAGE_CODE ,\r\nSMPLTT.LAST_UPDATE_DATE ,\r\nSMPLTT.LINE_TYPE ,\r\nSMPLTT.LINE_TYPE_ID ,\r\nSMPLTT.SOURCE_LANG,\r\nSMPLTT.GES_UPDATE_DATE ,\r\nSMPLTT.GLOBAL_NAME \r\nFROM $$STGDB.ST_MF_PO_LINE_TYPES_TL SMPLTT\r\nUNION ALL\r\nSELECT\r\nSCPLTT.CREATION_DATE ,\r\nSCPLTT.DESCRIPTION ,\r\nSCPLTT.LANGUAGE_CODE,\r\nSCPLTT.LAST_UPDATE_DATE ,\r\nSCPLTT.LINE_TYPE ,\r\nSCPLTT.LINE_TYPE_ID ,\r\nSCPLTT.SOURCE_LANG,\r\nSCPLTT.LAST_UPDATE_DATE ,\r\nSCPLTT.GLOBAL_NAME \r\nFROM $$STGDB.ST_CG1_PO_LINE_TYPES_TL SCPLTT\r\n/*\r\nUNION ALL\r\nSELECT\r\nSOPLTT.CREATION_DATE ,\r\nSOPLTT.DESCRIPTION ,\r\nSOPLTT.LANGUAGE_CODE ,\r\nSOPLTT.LAST_UPDATE_DATE ,\r\nSOPLTT.LINE_TYPE ,\r\nSOPLTT.LINE_TYPE_ID ,\r\nSOPLTT.SOURCE_LANG,\r\nSOPLTT.GES_UPDATE_DATE ,\r\nSOPLTT.GLOBAL_NAME \r\nFROM $$STGDB.ST_OM_PO_LINE_TYPES_TL SOPLTT\r\n*/\r\n) ELPLTT\r\nWHERE \r\n(\r\nELPLTT.LANGUAGE_CODE ,\r\nELPLTT.LINE_TYPE_ID ,\r\nELPLTT.GLOBAL_NAME\r\n) \r\nNOT IN \r\n(\r\nSELECT EPLTT.LANGUAGE_CODE ,\r\nEPLTT.LINE_TYPE_ID ,\r\nEPLTT.GLOBAL_NAME FROM $$ETLVWDB.EL_PO_LINE_TYPES_TL EPLTT\r\n)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "/*COLLECT STATS ON $$STGDB.ST_MF_PO_LINE_TYPES_TL;\r\nCOLLECT STATS ON $$STGDB.ST_CG1_PO_LINE_TYPES_TL;*/\r\n\r\nCALL COLLECT_STATS_WRAP('$$STGDB','ST_MF_PO_LINE_TYPES_TL','D') ;\r\nCALL COLLECT_STATS_WRAP('$$STGDB','ST_CG1_PO_LINE_TYPES_TL','D') ;\r\n\r\n/* Bedrock2.0 change - removed OM flow\r\nCOLLECT STATS ON  $$STGDB.ST_OM_PO_LINE_TYPES_TL;\r\n*/\r\n\r\nUPDATE ELPLTT FROM $$ETLVWDB.EL_PO_LINE_TYPES_TL ELPLTT,\r\n(SELECT\r\nSMPLTT.CREATION_DATE ,\r\nSMPLTT.DESCRIPTION ,\r\nSMPLTT.LANGUAGE_CODE ,\r\nSMPLTT.LAST_UPDATE_DATE ,\r\nSMPLTT.LINE_TYPE ,\r\nSMPLTT.LINE_TYPE_ID ,\r\nSMPLTT.SOURCE_LANG,\r\nSMPLTT.GES_UPDATE_DATE ,\r\nSMPLTT.GLOBAL_NAME \r\nFROM $$STGDB.ST_MF_PO_LINE_TYPES_TL SMPLTT\r\nUNION ALL\r\nSELECT \r\nSCPLTT.CREATION_DATE ,\r\nSCPLTT.DESCRIPTION ,\r\nSCPLTT.LANGUAGE_CODE ,\r\nSCPLTT.LAST_UPDATE_DATE ,\r\nSCPLTT.LINE_TYPE ,\r\nSCPLTT.LINE_TYPE_ID ,\r\nSCPLTT.SOURCE_LANG,\r\nSCPLTT.LAST_UPDATE_DATE ,\r\nSCPLTT.GLOBAL_NAME \r\nFROM $$STGDB.ST_CG1_PO_LINE_TYPES_TL SCPLTT\r\n\r\n/* Bedrock2.0 change - removed OM flow\r\nUNION ALL\r\nSELECT\r\nSOPLTT.CREATION_DATE ,\r\nSOPLTT.DESCRIPTION ,\r\nSOPLTT.LANGUAGE_CODE ,\r\nSOPLTT.LAST_UPDATE_DATE ,\r\nSOPLTT.LINE_TYPE ,\r\nSOPLTT.LINE_TYPE_ID ,\r\nSOPLTT.SOURCE_LANG,\r\nSOPLTT.GES_UPDATE_DATE ,\r\nSOPLTT.GLOBAL_NAME \r\nFROM $$STGDB.ST_OM_PO_LINE_TYPES_TL SOPLTT\r\n*/\r\n) SMOPLTT\r\nSET\r\nCREATION_DATE=SMOPLTT.CREATION_DATE ,\r\nDESCRIPTION=SMOPLTT.DESCRIPTION ,\r\nLINE_TYPE=SMOPLTT.LINE_TYPE ,\r\nSOURCE_LANG=SMOPLTT.SOURCE_LANG,\r\nGES_UPDATE_DATE=SMOPLTT.GES_UPDATE_DATE\r\nWHERE\r\nELPLTT.LANGUAGE_CODE=SMOPLTT.LANGUAGE_CODE \r\nAND ELPLTT.LINE_TYPE_ID=SMOPLTT.LINE_TYPE_ID\r\nAND ELPLTT.GLOBAL_NAME=SMOPLTT.GLOBAL_NAME",
