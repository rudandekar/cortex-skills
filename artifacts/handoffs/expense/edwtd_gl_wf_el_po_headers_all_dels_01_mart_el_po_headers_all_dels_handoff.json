      "attributes": {
        "Sql Query": "SELECT \r\nELPHAD.APPROVED_DATE,\r\nELPHAD.APPROVED_FLAG,\r\nELPHAD.CREATION_DATE,\r\nELPHAD.GES_DELETE_DATE,\r\nELPHAD.GLOBAL_NAME,\r\nELPHAD.LAST_UPDATE_DATE,\r\nELPHAD.PO_HEADER_ID,\r\nELPHAD.TERMS_ID,\r\nELPHAD.ORG_ID,\r\nELPHAD.TYPE_LOOKUP_CODE\r\nFROM\r\n(\r\nSELECT\r\nSMPHAD.APPROVED_DATE,\r\nSMPHAD.APPROVED_FLAG,\r\nSMPHAD.CREATION_DATE,\r\nSMPHAD.GES_DELETE_DATE,\r\nSMPHAD.GLOBAL_NAME,\r\nSMPHAD.LAST_UPDATE_DATE,\r\nSMPHAD.PO_HEADER_ID,\r\nSMPHAD.TERMS_ID,\r\nSMPHAD.ORG_ID,\r\nSMPHAD.TYPE_LOOKUP_CODE\r\nFROM \r\n$$STGDB.ST_MF_PO_HEADERS_ALL_DELS SMPHAD\r\nUNION ALL\r\nSELECT\r\nSCPHAD.APPROVED_DATE,\r\nSCPHAD.APPROVED_FLAG,\r\nSCPHAD.CREATION_DATE,\r\nSCPHAD.GES_DELETE_DATE,\r\nSCPHAD.GLOBAL_NAME,\r\nSCPHAD.LAST_UPDATE_DATE,\r\nSCPHAD.PO_HEADER_ID,\r\nSCPHAD.TERMS_ID,\r\nSCPHAD.ORG_ID,\r\nSCPHAD.TYPE_LOOKUP_CODE\r\nFROM \r\n$$STGDB.ST_CG1_PO_HEADERS_ALL_DELS SCPHAD\r\n)ELPHAD\r\nwhere\r\n(ELPHAD.PO_HEADER_ID,ELPHAD.GLOBAL_NAME) NOT IN (SELECT EPHAD.PO_HEADER_ID,EPHAD.GLOBAL_NAME from $$ETLVWDB.EL_PO_HEADERS_ALL_DELS EPHAD)",
