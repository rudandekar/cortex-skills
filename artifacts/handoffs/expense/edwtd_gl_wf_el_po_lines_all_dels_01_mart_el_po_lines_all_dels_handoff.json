      "attributes": {
        "Sql Query": "SELECT \r\nEOMLD.CREATION_DATE,                 \r\nEOMLD.LAST_UPDATE_DATE,              \r\nEOMLD.LINE_NUM,                      \r\nEOMLD.LINE_TYPE_ID,                  \r\nEOMLD.ORG_ID,                        \r\nEOMLD.PO_HEADER_ID,                  \r\nEOMLD.PO_LINE_ID,                    \r\nEOMLD.GES_DELETE_DATE,               \r\nEOMLD.GLOBAL_NAME \r\nFROM\r\n(SELECT \r\nSMPLAD.CREATION_DATE,                   \r\nSMPLAD.LAST_UPDATE_DATE,              \r\nSMPLAD.LINE_NUM,                      \r\nSMPLAD.LINE_TYPE_ID,                  \r\nSMPLAD.ORG_ID,                        \r\nSMPLAD.PO_HEADER_ID,                  \r\nSMPLAD.PO_LINE_ID,                    \r\nSMPLAD.GES_DELETE_DATE,               \r\nSMPLAD.GLOBAL_NAME                   \r\nFROM\r\n$$STGDB.ST_MF_PO_LINES_ALL_DELS SMPLAD\r\nUNION ALL\r\nSELECT\r\nSCPLAD.CREATION_DATE,                   \r\nSCPLAD.LAST_UPDATE_DATE,              \r\nSCPLAD.LINE_NUM,                      \r\nSCPLAD.LINE_TYPE_ID,                  \r\nSCPLAD.ORG_ID,                        \r\nSCPLAD.PO_HEADER_ID,                  \r\nSCPLAD.PO_LINE_ID,                    \r\nSCPLAD.GES_DELETE_DATE,               \r\nSCPLAD.GLOBAL_NAME                   \r\nFROM\r\n$$STGDB.ST_CG1_PO_LINES_ALL_DELS SCPLAD\r\n) EOMLD\r\n\r\n WHERE (EOMLD.PO_LINE_ID,EOMLD.GLOBAL_NAME) \r\n NOT IN ( SELECT  EOMLD.PO_LINE_ID,EOMLD.GLOBAL_NAME\r\n \r\nFROM $$ETLVWDB.EL_PO_LINES_ALL_DELS EOMLD)",
