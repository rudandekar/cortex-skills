      "attributes": {
        "Sql Query": "SELECT \r\n\t NVID.VENDOR_INVOICE_DISTRIB_KEY AS  VENDOR_INVOICE_DISTRIB_KEY   \r\n\t,NVID.VNDR_INV_DISTRIB_AMT     AS VNDR_INV_DISTRIB_AMT\r\n\t,NVI.SK_INVOICE_ID_INT AS INVOICE_ID\t\r\n\t,STEXAID.OLD_DIST_LINE_NUMBER AS OLD_DIST_LINE_NUMBER\r\n\t,STEXAID.OLD_DISTRIBUTION_ID AS OLD_DISTRIBUTION_ID\r\n\t,STEXAID.DIST_CODE_COMBINATION_ID   AS DIST_CODE_COMBINATION_ID   \r\n\t,STEXAID.PRICE_VAR_CODE_COMBINATION_ID AS PRICE_VAR_CODE_COMBINATION_ID\r\n\t,STEXAID.RATE_VAR_CODE_COMBINATION_ID AS RATE_VAR_CODE_COMBINATION_ID\r\n\t,NVID.SK_INVOICE_DISTRIBUTION_ID_INT AS SK_INVOICE_DISTRIBUTION_ID_INT\r\n\t,NVID.BK_VNDR_INV_DSTRBN_TRX_TYPE_CD AS VNDR_INV_DISTRIB_TRX_TYPE_CD\r\n\t,NVID.DD_BK_COMPANY_CD AS DD_BK_COMPANY_CD\r\n\t,NSOB.SET_OF_BOOKS_KEY AS SET_OF_BOOKS_KEY\r\n    ,COALESCE(WECSM.CURRENCY_CODE,NSOB.FUNCTIONAL_CURRENCY_CODE) as BK_FUNCTIONAL_CURRENCY_CD\r\n\t,NVI.TRANSACTIONAL_CURRENCY_CD  TRANSACTIONAL_CURRENCY_CD\t\r\n\t,(NVID.FISCAL_YEAR_NUMBER_INT*100 +NVID.FISCAL_MONTH_NUMBER_INT ) AS DV_FISCAL_YEAR_MONTH_NUM_INT\t\r\n\t, ' ' as RU_DV_USD_AMT\r\n\t,' ' as RU_FUNCTIONAL_AMT\r\n\t,STEXAID.GLOBAL_NAME\r\nFROM \r\n(\r\n   \tSELECT \r\n\t\t\t INVOICE_DISTRIBUTION_ID\r\n\t\t\t,GLOBAL_NAME\r\n\t\t\t,PERIOD_NAME \r\n\t\t\t,OLD_DISTRIBUTION_ID\r\n\t\t\t,OLD_DIST_LINE_NUMBER\r\n\t\t\t,DIST_CODE_COMBINATION_ID      \r\n\t\t\t,PRICE_VAR_CODE_COMBINATION_ID \r\n\t\t\t,RATE_VAR_CODE_COMBINATION_ID  \r\n\t\t\t,SET_OF_BOOKS_ID                  \r\n\t\t\tFROM $$ETLVWDB.EL_AP_INVOICE_DISTRI_ALL WHERE POSTED_FLAG='Y' AND GLOBAL_NAME='BE'\r\n)STEXAID\r\n\r\nINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\n\tON (NSSC.GLOBAL_NAME = STEXAID.GLOBAL_NAME )\r\nINNER JOIN \t $$FINLGLVWDB.N_VENDOR_INVOICE_DISTRIBUTION NVID\r\n      \tON (NVID.SK_INVOICE_DISTRIBUTION_ID_INT=STEXAID.INVOICE_DISTRIBUTION_ID \r\n     \tAND NVID.SS_CD=NSSC.SOURCE_SYSTEM_CODE)\r\nINNER JOIN  $$FINLGLVWDB.N_VENDOR_INVOICE  NVI     \r\n   ON    NVI.VENDOR_INVOICE_KEY          =   NVID.VENDOR_INVOICE_KEY\r\nINNER JOIN  $$FINLGLVWDB.N_SET_OF_BOOKS  NSOB\r\n\tON\t STEXAID.SET_OF_BOOKS_ID           =   NSOB.SK_SET_OF_BOOKS_ID_INT\r\n\tAND  NSSC.SOURCE_SYSTEM_CODE           =   NSOB.SS_CODE                        \r\nLEFT OUTER JOIN $$STGDB.WI_ED_COMPANY_SOURCE_MAP WECSM\r\n    ON  WECSM.SET_OF_BOOKS_ID            =    NSOB.SK_SET_OF_BOOKS_ID_INT\r\n\tAND\tWECSM.GLOBAL_NAME                =    NSSC.GLOBAL_NAME\r\n\tAND\tWECSM.COMPANY                    =    NVID.DD_BK_COMPANY_CD                \r\n\tAND\tWECSM.BK_FISCAL_YEAR_NUMBER_INT  =    NVID.FISCAL_YEAR_NUMBER_INT \r\n\tAND WECSM.BK_FISCAL_MONTH_NUMBER_INT =    NVID.FISCAL_MONTH_NUMBER_INT",
        "User Defined Join": "",
