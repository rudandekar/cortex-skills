      "attributes": {
        "Sql Query": "SELECT \r\n\tTVOUTPUT.BATCH_ID,\r\n\tTVOUTPUT.BK_FINANCIAL_THEATER_NAME_CODE,\r\n\tTVOUTPUT.START_TV_DATE AS START_DATE_ACTIVE,\r\n\tTVOUTPUT.SK_THEATER_ID_INT,\r\n\tCOALESCE (MAX (TVOUTPUT.START_TV_DATE - INTERVAL '1' DAY)\r\n\tOVER (PARTITION BY TVOUTPUT.BK_FINANCIAL_THEATER_NAME_CODE\r\n\tORDER BY TVOUTPUT.START_TV_DATE ASC ROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING), DATE '3500-01-01') AS END_DATE_ACTIVE,\r\n\tTVOUTPUT.ACTION_CODE,\r\n\tROW_NUMBER () OVER (PARTITION BY TVOUTPUT.BK_FINANCIAL_THEATER_NAME_CODE \r\n\tORDER BY TVOUTPUT.START_TV_DATE ASC) AS RANK_INDEX,\r\n\t(CASE WHEN RANK_INDEX = 1 and NFTTV_OUT.BK_FINANCIAL_THEATER_NAME_CODE IS NOT NULL \r\n\tTHEN 'U' ELSE 'I' END) as DML_TYPE\r\nFROM( SELECT \r\n\t\tBATCH_ID,\r\n\t\tBK_FINANCIAL_THEATER_NAME_CODE,\r\n\t\tSTART_TV_DATE,\r\n\t\tSK_THEATER_ID_INT,\r\n\t\tEDW_CREATE_DATETIME,\r\n\t\tACTION_CODE,\r\n\t\tEXCEPTION_TYPE,\r\n\t\tROW_NUMBER () OVER (PARTITION BY BK_FINANCIAL_THEATER_NAME_CODE\r\n\t\tORDER BY EDW_CREATE_DATETIME DESC) AS ROW_NUM\r\n\tFROM(\r\n\t\t SELECT \r\n\t\t\tSST.BATCH_ID BATCH_ID,\r\n\t\t\tSST.THEATER_NAME BK_FINANCIAL_THEATER_NAME_CODE,\r\n\t\t\tCAST(SST.CREATE_DATETIME AS DATE) START_TV_DATE,\r\n\t\t\tSST.THEATER_ID SK_THEATER_ID_INT,\r\n\t\t\tSST.CREATE_DATETIME EDW_CREATE_DATETIME,\r\n\t\t\tSST.ACTION_CODE ACTION_CODE,\r\n\t\t\t'NE' EXCEPTION_TYPE\r\n\t\t FROM $$STGDB.ST_SI_THEATER SST\r\n\t\tUNION ALL\r\n\t\t SELECT \r\n\t\t\t-999 BATCH_ID,\r\n\t\t\tNFTTV.BK_FINANCIAL_THEATER_NAME_CODE,\r\n\t\t\tNFTTV.START_TV_DATE,\r\n\t\t\tNFTTV.SK_THEATER_ID_INT,\r\n\t\t\tNFTTV.EDW_UPDATE_DATETIME EDW_CREATE_DATETIME,\r\n\t\t\t'X' ACTION_CODE,\r\n\t\t\t'NE' EXCEPTION_TYPE\r\n\t\t FROM $$FINLGLVWDB.N_FINANCIAL_THEATER_TV NFTTV\r\n\t\tWHERE EXISTS (SELECT 1 FROM $$STGDB.ST_SI_THEATER SST\r\n\t\t\tWHERE SST.THEATER_NAME=NFTTV.BK_FINANCIAL_THEATER_NAME_CODE)\r\n\t\tAND END_TV_DATE=16000101\r\n\t\t) TVINPUT\r\n\t\tQUALIFY ROW_NUMBER () OVER (PARTITION BY TVINPUT. BK_FINANCIAL_THEATER_NAME_CODE, TVINPUT.START_TV_DATE\r\n\t\tORDER BY TVINPUT.EDW_CREATE_DATETIME DESC) = 1\r\n\t) TVOUTPUT\r\nLEFT JOIN $$FINLGLVWDB.N_FINANCIAL_THEATER_TV NFTTV_OUT\r\nON TVOUTPUT.BK_FINANCIAL_THEATER_NAME_CODE=NFTTV_OUT.BK_FINANCIAL_THEATER_NAME_CODE\r\nand NFTTV_OUT.END_TV_DATE =16000101\r\nWHERE TVOUTPUT.ROW_NUM = 1",
