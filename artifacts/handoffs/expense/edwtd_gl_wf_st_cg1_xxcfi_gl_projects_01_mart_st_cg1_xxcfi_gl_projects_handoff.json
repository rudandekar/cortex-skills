      "attributes": {
        "Sql Query": "SELECT\r\n$$BatchId AS BATCH_ID,\r\n'I' AS ACTION_CODE,\r\nPROJECT_ID,\r\nPROJECT_SEGMENT,\r\nPROJECT_NAME,\r\nPARENT_PROGRAM,\r\nBUSINESS_UNIT_CODE,\r\nSTART_DATE_ACTIVE,\r\nEND_DATE_ACTIVE,\r\nENABLED_FLAG,\r\nPROJECT_MGR,\r\nDEPARTMENT_ID,\r\nATTRIBUTE1,\r\nATTRIBUTE2,\r\nATTRIBUTE3,\r\nATTRIBUTE4,\r\nATTRIBUTE5,\r\nLAST_UPDATED_BY,\r\nLAST_UPDATE_DATE,\r\nLAST_UPDATE_LOGIN,\r\nCREATED_BY,\r\nCREATION_DATE,\r\nSUMMARY_FLAG,\r\nGES_PK_ID,\r\nPROJECT_NAME_20,\r\nSOURCE_COMMIT_TIME,\r\nREFRESH_DATETIME,\r\n'CG' AS GLOBAL_NAME,\r\nCURRENT_TIMESTAMP(0) AS CREATE_DATETIME\r\nFROM\r\n$$NRTACCUMVWDB.CG1_XXCFI_GL_PROJECTS\r\nWHERE \r\nSOURCE_COMMIT_TIME > '$$LastExtractDate'\r\nAND   SOURCE_DML_TYPE IN ( 'SQL COMPUPDATE','INSERT')\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY PROJECT_ID,PROJECT_SEGMENT ORDER BY REFRESH_DATETIME DESC)=1",
