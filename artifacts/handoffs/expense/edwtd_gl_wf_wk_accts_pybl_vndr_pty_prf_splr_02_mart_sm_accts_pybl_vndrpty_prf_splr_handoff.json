      "attributes": {
        "Sql Query": "SELECT \r\nSM.ACCTS_PYBL_VNDRPTY_PRF_SPLRKEY,\r\nST.USING_ORGANIZATION_ID AS USING_INVENTORY_ORG_KEY,\r\n NP.AP_VENDOR_PARTY_KEY AS AP_VENDOR_PARTY_KEY       ,\r\n COALESCE( ST.SEGMENT1,'UNKNOWN' ) AS BK_PURCHASING_ITEM_CATEGORY_ID,\r\nCOALESCE ( ST.OWNING_ORGANIZATION_ID, -999) OWNING_INVENTORY_ORG_KEY,\r\nCOALESCE( ST.VENDOR_BUSINESS_TYPE, 'UNKNOWN')  VENDOR_BUSINESS_TYPE_CD,\r\nCOALESCE (ST.ATTRIBUTE2 , 'UNKNOWN') SUPPLIER_STATUS_CD,\r\nCOALESCE ( ST.ATTRIBUTE3 , 'UNKNOWN') SUPPLIER_SEGMENT_STATUS_CD,\r\nCOALESCE ( ST.ATTRIBUTE4, 'UNKNOWN')  PARENT_SUPPLIER_NAME,\r\nCOALESCE (ST.DISABLE_FLAG,'N') DISABLED_FLG,\r\nCOALESCE (NSP.AP_VENDOR_SITE_PARTY_KEY , -999) PREF_SUPPLIER_VENDOR_PRTY_KEY,\r\nCOALESCE ( ST.NAME,'UNKNOWN') BK_OPERATING_UNIT_NAME_CD ,\r\nCURRENT_TIMESTAMP(0) AS CREATION_DATE , \r\nUSER AS CREATED_BY ,\r\nCURRENT_TIMESTAMP(0) AS LAST_UPDATE_DATE ,\r\nUSER LAST_UPDATED_BY ,\r\n'I' ACTION_CODE,\r\n'I' DML_TYPE\r\nFROM \r\n(SELECT\r\nUSING_ORGANIZATION_ID,SEGMENT1,OWNING_ORGANIZATION_ID,VENDOR_BUSINESS_TYPE,ATTRIBUTE2,ATTRIBUTE3,ATTRIBUTE4,DISABLE_FLAG,NAME,VENDOR_SITE_ID,VENDOR_ID\r\nFROM $$STGDB.ST_PO_APPROVED_SUPPLIER_LIST  \r\n QUALIFY ROW_NUMBER() OVER ( PARTITION BY OWNING_ORGANIZATION_ID, VENDOR_ID, SEGMENT1 ORDER BY OWNING_ORGANIZATION_ID, VENDOR_ID, SEGMENT1) = 1\r\n)  ST\r\nINNER JOIN $$COMREFVWDB.N_ACCTS_PYBL_VNDR_PRTY  NP \r\nON   ST.VENDOR_ID  = NP.SK_VENDOR_ID_INT AND NP.BK_SS_CD = 'EMEA'\r\nINNER JOIN $$ETLVWDB.SM_ACCTS_PYBL_VNDRPTY_PRF_SPLR SM\r\nON SM.OWNING_INVENTORY_ORG_KEY = ST.OWNING_ORGANIZATION_ID\r\nAND SM.AP_VENDOR_PARTY_KEY = NP.AP_VENDOR_PARTY_KEY\r\nAND SM.BK_PURCHASING_ITEM_CATEGORY_ID = ST.SEGMENT1 \r\nLEFT JOIN $$COMREFVWDB.N_ACCTS_PYBL_VNDR_SITE_PRTY_TV NSP\r\nON   ST.VENDOR_SITE_ID  = NSP.SK_VENDOR_SITE_ID_INT \r\nAND NSP.AP_VENDOR_PARTY_KEY=NP.AP_VENDOR_PARTY_KEY\r\nAND NSP.END_TV_DT = CAST ('3500-01-01' AS DATE)",
        "User Defined Join": "",
