      "attributes": {
        "Sql Query": "SELECT \r\n ROW_NUMBER()OVER(ORDER BY OWNING_ORGANIZATION_ID, VENDOR_ID, SEGMENT1) + MAX_VAL AS ACCTS_PYBL_VNDRPTY_PRF_SPLRKEY,\r\n COALESCE( ST.OWNING_ORGANIZATION_ID , -999 ) AS OWNING_INVENTORY_ORG_KEY ,   \r\n NP.AP_VENDOR_PARTY_KEY AS AP_VENDOR_PARTY_KEY       ,   \r\n COALESCE( ST.SEGMENT1,'UNKNOWN' ) AS BK_PURCHASING_ITEM_CATEGORY_ID,\r\n CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM ,             \r\n USER AS EDW_CREATE_USER      \r\nFROM \r\n(SELECT OWNING_ORGANIZATION_ID, VENDOR_ID, SEGMENT1\r\n FROM \r\n $$STGDB.ST_PO_APPROVED_SUPPLIER_LIST  \r\n QUALIFY ROW_NUMBER() OVER ( PARTITION BY OWNING_ORGANIZATION_ID, VENDOR_ID, SEGMENT1 ORDER BY OWNING_ORGANIZATION_ID, VENDOR_ID, SEGMENT1) = 1\r\n ) ST,\r\n(SELECT COALESCE(MAX(ACCTS_PYBL_VNDRPTY_PRF_SPLRKEY), 0)  AS MAX_VAL FROM $$ETLVWDB.SM_ACCTS_PYBL_VNDRPTY_PRF_SPLR ) SM_MAX ,\r\n $$COMREFVWDB.N_ACCTS_PYBL_VNDR_PRTY  NP WHERE  ST.VENDOR_ID  = NP.SK_VENDOR_ID_INT AND BK_SS_CD = 'EMEA'\r\nAND NOT EXISTS( SELECT 1 FROM  $$ETLVWDB.SM_ACCTS_PYBL_VNDRPTY_PRF_SPLR SM,\r\n $$COMREFVWDB.N_ACCTS_PYBL_VNDR_PRTY  NP WHERE  ST.VENDOR_ID  = NP.SK_VENDOR_ID_INT AND BK_SS_CD = 'EMEA'\r\nAND SM.OWNING_INVENTORY_ORG_KEY = ST.OWNING_ORGANIZATION_ID\r\nAND SM.AP_VENDOR_PARTY_KEY = NP.AP_VENDOR_PARTY_KEY\r\nAND SM.BK_PURCHASING_ITEM_CATEGORY_ID = ST.SEGMENT1)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
