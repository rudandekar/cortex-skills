      "attributes": {
        "Sql Query": "SELECT \r\n   EFAI.AP_DISTRIBUTION_LINE_NUMBER ,\r\n   EFAI.ASSET_ID ,\r\n   EFAI.ASSET_INVOICE_ID ,\r\n     EFAI.DATE_EFFECTIVE ,\r\n   EFAI.DATE_INEFFECTIVE ,\r\n   EFAI.DELETED_FLAG ,\r\n    EFAI.FEEDER_SYSTEM_NAME ,\r\n   EFAI.GES_PK_ID ,\r\n   EFAI.GLOBAL_NAME ,\r\n   EFAI.INVOICE_ID ,\r\n   EFAI.INVOICE_NUMBER ,\r\n   EFAI.INVOICE_TRANSACTION_ID_IN ,\r\n   EFAI.INVOICE_TRANSACTION_ID_OUT ,\r\n    EFAI.PO_NUMBER ,\r\n   EFAI.PO_VENDOR_ID ,\r\n   EFAI.INVOICE_DISTRIBUTION_ID\r\n FROM\r\n  (\r\n  SELECT \r\n   SMFAI.AP_DISTRIBUTION_LINE_NUMBER ,\r\n   SMFAI.ASSET_ID ,\r\n   SMFAI.ASSET_INVOICE_ID ,\r\n   SMFAI.DATE_EFFECTIVE ,\r\n   SMFAI.DATE_INEFFECTIVE ,\r\n   SMFAI.DELETED_FLAG ,\r\n   SMFAI.FEEDER_SYSTEM_NAME ,\r\n   SMFAI.GES_PK_ID ,\r\n   SMFAI.GLOBAL_NAME ,\r\n   SMFAI.INVOICE_ID ,\r\n   SMFAI.INVOICE_NUMBER ,\r\n   SMFAI.INVOICE_TRANSACTION_ID_IN ,\r\n   SMFAI.INVOICE_TRANSACTION_ID_OUT ,\r\n   SMFAI.PO_NUMBER ,\r\n   SMFAI.PO_VENDOR_ID,\r\n   SMFAI.INVOICE_DISTRIBUTION_ID\r\n FROM $$STGDB.ST_MF_FA_ASSET_INVOICES SMFAI WHERE SMFAI.DATE_INEFFECTIVE IS NULL\r\n  ) EFAI\r\n WHERE\r\n   ( EFAI.GES_PK_ID ,EFAI.GLOBAL_NAME)\r\n NOT IN\r\n   (SELECT ELFAI.GES_PK_ID ,ELFAI.GLOBAL_NAME \r\n   FROM $$ETLVWDB.EL_FA_ASSET_INVOICES ELFAI)",
        "User Defined Join": "",
