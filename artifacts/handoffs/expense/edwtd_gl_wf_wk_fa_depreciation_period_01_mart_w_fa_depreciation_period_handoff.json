      "attributes": {
        "Sql Query": "SELECT \r\nELFDP.BOOK_TYPE_CODE as BK_FA_BOOK_TYPE_CD ,\r\nELFDP.PERIOD_COUNTER as BK_DPRCTN_PERIOD_SEQ_NUM_INT ,\r\nELFDP.PERIOD_OPEN_DATE as PERIOD_ACTUAL_OPEN_DTM ,\r\nELFDP.PERIOD_CLOSE_DATE as PERIOD_ACTUAL_CLOSED_DTM ,\r\nELFDP.PERIOD_COUNTER as SK_PERIOD_COUNTER_INT ,\r\nNSSC.SOURCE_SYSTEM_CODE as SS_CD,\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE ,\r\n(ELFDP.FISCAL_YEAR*100+ELFDP.PERIOD_NUM) AS DV_FISCAL_YEAR_MONTH_INT\r\nFROM \r\n\t( \tSELECT BOOK_TYPE_CODE, PERIOD_COUNTER ,PERIOD_OPEN_DATE, PERIOD_CLOSE_dATE, PERIOD_NAME, GLOBAL_NAME, PERIOD_NUM, FISCAL_YEAR\r\n\t\tFROM $$STGDB.ST_MF_FA_DEPRN_PERIODS\r\n\t\t/*\r\n\t\tBedrock2.0 change - removed OM flow\r\n\t\tUNION ALL\r\n\t\tSELECT BOOK_TYPE_CODE, PERIOD_COUNTER ,PERIOD_OPEN_DATE, PERIOD_CLOSE_dATE, PERIOD_NAME, GLOBAL_NAME, PERIOD_NUM, FISCAL_YEAR \r\n\t\tFROM $$STGDB.ST_OM_FA_DEPRN_PERIODS\r\n\t\tWHERE (BOOK_TYPE_CODE,PERIOD_COUNTER) NOT IN (\tSELECT BOOK_TYPE_CODE,PERIOD_COUNTER \r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\tFROM $$STGDB.ST_MF_FA_DEPRN_PERIODS) \r\n\t\t*/\r\n)\r\nELFDP,\r\n$$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\nWHERE ELFDP.GLOBAL_NAME = NSSC.GLOBAL_NAME",
        "User Defined Join": "",
