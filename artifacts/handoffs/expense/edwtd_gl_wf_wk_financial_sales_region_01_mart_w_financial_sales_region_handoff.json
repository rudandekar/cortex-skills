      "attributes": {
        "Sql Query": "SELECT\r\nTVOUTPUT.BATCH_ID, \r\nTVOUTPUT.BK_FINANCIAL_SALES_REGION_ID,\r\nTVOUTPUT.START_TV_DT AS START_DATE_ACTIVE,\r\nTVOUTPUT.FINANCIAL_SALES_REGION_DESCR,\r\nTVOUTPUT.SK_REGION_ID_INT,\r\nCOALESCE (MAX (TVOUTPUT.START_TV_DT - INTERVAL '1' DAY)\r\nOVER (PARTITION BY TVOUTPUT.BK_FINANCIAL_SALES_REGION_ID\r\nORDER\tBY TVOUTPUT.START_TV_DT ASC ROWS BETWEEN 1 FOLLOWING\r\n\tAND\t1 FOLLOWING), DATE '3500-01-01') AS END_DATE_ACTIVE,\r\nTVOUTPUT.ACTION_CODE,\r\nROW_NUMBER () OVER (PARTITION BY TVOUTPUT.BK_FINANCIAL_SALES_REGION_ID\r\nORDER\tBY TVOUTPUT.START_TV_DT ASC) AS RANK_INDEX,\r\n(\r\n\t\tCASE\r\n\t\t\tWHEN\tRANK_INDEX = 1\r\n\tAND\tNFSR_OUT.BK_FINANCIAL_SALES_REGION_ID IS NOT NULL \r\nTHEN 'U'\r\n\t\t\tELSE\t'I' END) AS DML_TYPE\r\nFROM(\r\nSELECT\t\r\n\t\tBATCH_ID,\r\n\t\tBK_FINANCIAL_SALES_REGION_ID,\r\n\t\tSTART_TV_DT,\r\n        FINANCIAL_SALES_REGION_DESCR,\r\n        SK_REGION_ID_INT,\r\n\t\tEDW_CREATE_DTM,\r\n\t\tACTION_CODE,\r\n\t\tEXCEPTION_TYPE,\r\n\t\tROW_NUMBER () OVER (PARTITION BY BK_FINANCIAL_SALES_REGION_ID, FINANCIAL_SALES_REGION_DESCR\r\n\t\tORDER\tBY EDW_CREATE_DTM DESC) AS ROW_NUM\r\n\tFROM(\r\nSELECT\t\r\n\t     SML.BATCH_ID,\r\n\t     SML.REGION_VALUE BK_FINANCIAL_SALES_REGION_ID,\r\nCAST(COALESCE(SML.LAST_UPDATE_DATE,SML.CREATE_DATETIME) AS DATE) START_TV_DT,\r\n\t     SML.REGION_DESC FINANCIAL_SALES_REGION_DESCR,\r\n\t     SML.REGION_ID SK_REGION_ID_INT ,\r\n\t     SML.CREATE_DATETIME EDW_CREATE_DTM,\r\n         SML.ACTION_CODE ACTION_CODE,\r\n\t     'NE' EXCEPTION_TYPE\r\nFROM\t$$STGDB.ST_SI_REGION SML\r\nUNION\tALL\r\nSELECT\r\n\t       -999 BATCH_ID, \r\n\t       NFSR.BK_FINANCIAL_SALES_REGION_ID,\r\n\t       NFSR.START_TV_DT,\r\n\t       NFSR.FINANCIAL_SALES_REGION_DESCR,\r\n           NFSR.SK_REGION_ID_INT ,\r\n           NFSR.EDW_UPDATE_DTM EDW_CREATE_DTM,\r\n           'X' ACTION_CODE,\r\n\t       'NE' EXCEPTION_TYPE\r\nFROM\t$$FINLGLVWDB.N_FINANCIAL_SALES_REGION_TV NFSR\r\nWHERE\tEXISTS (\r\nSELECT\t1\r\nFROM\t$$STGDB.ST_SI_REGION SML\r\n\t\t\tWHERE\tSML.REGION_VALUE=NFSR.BK_FINANCIAL_SALES_REGION_ID)\r\n\t\tAND\tEND_TV_DT=16000101\r\n\t\t) TVINPUT\r\n\t\tQUALIFY\tROW_NUMBER () OVER (PARTITION BY TVINPUT.BK_FINANCIAL_SALES_REGION_ID, TVINPUT.START_TV_DT\r\n\t\tORDER\tBY TVINPUT.EDW_CREATE_DTM DESC) = 1\r\n\t) TVOUTPUT\r\nLEFT JOIN $$FINLGLVWDB.N_FINANCIAL_SALES_REGION_TV NFSR_OUT  \r\n\tON\tTVOUTPUT.BK_FINANCIAL_SALES_REGION_ID=NFSR_OUT.BK_FINANCIAL_SALES_REGION_ID\r\n\tAND\tNFSR_OUT.END_TV_DT =16000101\r\nWHERE\tTVOUTPUT.ROW_NUM = 1",
        "User Defined Join": "",
