      "attributes": {
        "Sql Query": "SELECT MF_AP_NOTES.NOTE_ID,\r\nREPLACE(REPLACE(MF_AP_NOTES.SOURCE_OBJECT_CODE,CHR(10),CHR(32)),CHR(13),CHR(32)) SOURCE_OBJECT_CODE, \r\nMF_AP_NOTES.SOURCE_OBJECT_ID,\r\nREPLACE(REPLACE(MF_AP_NOTES.NOTE_TYPE, CHR(10),CHR(32)),CHR(13),CHR(32)) NOTE_TYPE,\r\nMF_AP_NOTES.ENTERED_BY,\r\nMF_AP_NOTES.ENTERED_DATE,\r\nREPLACE(REPLACE(MF_AP_NOTES.SOURCE_LANG,CHR(10),CHR(32)),CHR(13),CHR(32)) SOURCE_LANG,\r\nMF_AP_NOTES.CREATION_DATE,\r\nMF_AP_NOTES.CREATED_BY,\r\nMF_AP_NOTES.LAST_UPDATE_DATE,\r\nMF_AP_NOTES.LAST_UPDATED_BY,\r\nREPLACE(REPLACE(SUBSTR(MF_AP_NOTES.NOTES_DETAIL,1,63990),CHR(10),CHR(32)),CHR(13),CHR(32)) NOTES_DETAIL,\r\nMF_AP_NOTES.LAST_UPDATE_LOGIN,\r\nMF_AP_NOTES.GES_UPDATE_DATE,\r\nMF_AP_NOTES.GLOBAL_NAME\r\nFROM\r\n MF_AP_NOTES\r\nWHERE  GES_UPDATE_DATE>TO_DATE('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS')",
