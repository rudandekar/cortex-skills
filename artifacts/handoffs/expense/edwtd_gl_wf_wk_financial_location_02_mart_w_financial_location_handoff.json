      "attributes": {
        "Sql Query": "SELECT\r\n\tTVOUTPUT.BK_COMPANY_CODE,\r\n\tTVOUTPUT.BK_FINANCIAL_LOCATION_CODE,\r\n\tTVOUTPUT.LOCATION_NAME LOCATION_NAME,\r\n\tTVOUTPUT.SK_LOCATION_VALUE_CODE,\r\n\tTVOUTPUT.ACTION_CODE,\r\n\tTVOUTPUT.EXCEPTION_TYPE,\r\n\tTVOUTPUT.START_TV_DATE START_DATE_ACTIVE,\r\n\tCOALESCE(MAX(CAST(TVOUTPUT.START_TV_DATE AS DATE) - INTERVAL '1' DAY ) \r\n\tOVER (PARTITION BY TVOUTPUT.BK_FINANCIAL_LOCATION_CODE\r\n\tORDER\tBY TVOUTPUT.START_TV_DATE ROWS BETWEEN 1 FOLLOWING\r\n\tAND\t1 FOLLOWING), DATE '3500-01-01') AS END_DATE_ACTIVE,\r\n\tROW_NUMBER() OVER (PARTITION BY TVOUTPUT.BK_FINANCIAL_LOCATION_CODE\r\n\tORDER\tBY TVOUTPUT.START_TV_DATE ASC) AS RANK_INDEX,\r\n\t(CASE WHEN\tRANK_INDEX = 1 AND NFLTV.BK_FINANCIAL_LOCATION_CODE IS NOT NULL THEN 'U' ELSE\t'I' END) AS DML_TYPE \r\nFROM\t(\r\n\tSELECT\r\n\tBATCH_ID,\r\n\tBK_COMPANY_CODE,\r\n\tBK_FINANCIAL_LOCATION_CODE,\r\n\tLOCATION_NAME,\r\n\tSK_LOCATION_VALUE_CODE,\r\n\tSTART_TV_DATE,\r\n\tEDW_CREATE_DATETIME,\r\n\tACTION_CODE,\r\n\tEXCEPTION_TYPE,\r\n\tROW_NUMBER() OVER (PARTITION BY \r\n\tTVINPUT.BK_COMPANY_CODE,TVINPUT.BK_FINANCIAL_LOCATION_CODE, TVINPUT.LOCATION_NAME\r\n\tORDER\tBY EDW_CREATE_DATETIME DESC) AS ROW_NUM\r\n\tFROM\r\n\t(\r\n\t\t\tSELECT\r\n\t\t\tSSLI.BATCH_ID,\r\n\t\t\tSSLI.COMPANY_VALUE BK_COMPANY_CODE,\r\n\t\t\tSSLI.LOCATION_VALUE BK_FINANCIAL_LOCATION_CODE,\r\n\t\t\tSSLI.LOCATION_NAME LOCATION_NAME,\r\n\t\t\tSSLI.LOCATION_VALUE SK_LOCATION_VALUE_CODE,\r\n\t\t\tCAST(SSLI.CREATE_DATETIME AS DATE) START_TV_DATE,\r\n\t\t\tSSLI.CREATE_DATETIME EDW_CREATE_DATETIME,\r\n\t\t\tSSLI.ACTION_CODE,\r\n\t\t\t'NE' EXCEPTION_TYPE\r\n\t\tFROM\t$$STGDB.ST_SI_LOCATION_INFO SSLI LEFT OUTER JOIN\r\n\t\t\t$$FINLGLVWDB.N_FINANCIAL_COMPANY_TV NFCTV\r\nON\t\tSSLI.COMPANY_VALUE = NFCTV.BK_COMPANY_CODE\r\n\tAND\tNFCTV.END_TV_DATE=16000101\r\n\tUNION\tALL \r\n\t\tSELECT\r\n\t\t\tESLI.BATCH_ID,\r\n\t\t\tESLI.COMPANY_VALUE BK_COMPANY_CODE, \r\n\t\t\tESLI.LOCATION_VALUE BK_FINANCIAL_LOCATION_CODE,\r\n\t\t\tESLI.LOCATION_NAME LOCATION_NAME,\r\n\t\t\tESLI.LOCATION_VALUE SK_LOCATION_VALUE_CODE,\r\n\t\t\tCAST(ESLI.CREATE_DATETIME AS DATE) START_TV_DATE,\r\n\t\t\tESLI.CREATE_DATETIME EDW_CREATE_DATETIME,\r\n\t\t\tESLI.ACTION_CODE,\r\n\t\t\tESLI.EXCEPTION_TYPE\r\n\t\tFROM\t$$EXCEPDB.EX_SI_LOCATION_INFO ESLI LEFT OUTER JOIN\r\n\t\t\t$$FINLGLVWDB.N_FINANCIAL_COMPANY_TV NFCTV\r\n\t\tON\tESLI.COMPANY_VALUE=NFCTV.BK_COMPANY_CODE\r\n\tAND\tNFCTV.END_TV_DATE=16000101\r\n\tUNION\tALL\r\n\t\tSELECT\r\n\t\t\t-999 BATCH_ID,\r\n\t\t\tNFLTV.BK_COMPANY_CODE,\r\n\t\t\tNFLTV.BK_FINANCIAL_LOCATION_CODE,\r\n\t\t\tNFLTV.LOCATION_NAME,\r\n\t\t\tNFLTV.SK_LOCATION_VALUE_CODE,\r\n\t\t\tNFLTV.START_TV_DATE,\r\n\t\t\tNFLTV.EDW_UPDATE_DATETIME EDW_CREATE_DATETIME,\r\n\t\t\t'X' ACTION_CODE,\r\n\t\t\t'NE' EXCEPTION_TYPE\r\n\t\tFROM\t$$FINLGLVWDB.N_FINANCIAL_LOCATION_TV NFLTV\r\n\tWHERE\tNFLTV.BK_FINANCIAL_LOCATION_CODE IN \r\n\t (SELECT SSLI.LOCATION_VALUE FROM $$STGDB.ST_SI_LOCATION_INFO SSLI\r\n   \t  UNION ALL\r\n\t SELECT ESLI.LOCATION_VALUE FROM $$EXCEPDB.EX_SI_LOCATION_INFO ESLI)\r\n\tAND\tNFLTV.END_TV_DATE = 16000101\r\n\t)TVINPUT\r\nQUALIFY\tROW_NUMBER () OVER (PARTITION BY TVINPUT. BK_FINANCIAL_LOCATION_CODE, TVINPUT.START_TV_DATE \r\n\tORDER\tBY TVINPUT.EDW_CREATE_DATETIME DESC) = 1\r\n     )TVOUTPUT\r\nLEFT JOIN $$FINLGLVWDB.N_FINANCIAL_LOCATION_TV NFLTV\r\n\tON\tTVOUTPUT. BK_FINANCIAL_LOCATION_CODE = NFLTV. BK_FINANCIAL_LOCATION_CODE\r\n\tAND\tNFLTV.END_TV_DATE= 16000101\r\nWHERE\tROW_NUM=1",
        "User Defined Join": "",
