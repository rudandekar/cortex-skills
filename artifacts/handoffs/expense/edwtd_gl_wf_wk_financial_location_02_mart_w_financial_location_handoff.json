      "attributes": {
        "Sql Query": "SELECT\r\n\t\t\tSTSILOCINFO.BATCH_ID,\r\n\t\t\tSTSILOCINFO.LOCATION_VALUE,\r\n\t\t\tSTSILOCINFO.LOCATION_NAME,\r\n\t\t\tSTSILOCINFO.COMPANY_VALUE,\r\n\t\t\tSTSILOCINFO.CREATE_DATETIME,\r\n\t\t\tSTSILOCINFO.ACTION_CODE \r\nFROM\r\n\t\t\t$$STGDB.ST_SI_LOCATION_INFO STSILOCINFO\r\n\t\t\tWHERE STSILOCINFO.LOCATION_VALUE <> '000' AND \r\n(NOT EXISTS (SELECT 1 from \r\n\t$$FINLGLVWDB. N_FINANCIAL_COMPANY_TV NFINCOM WHERE \r\n\tSTSILOCINFO.COMPANY_VALUE = NFINCOM.BK_COMPANY_CODE))",
