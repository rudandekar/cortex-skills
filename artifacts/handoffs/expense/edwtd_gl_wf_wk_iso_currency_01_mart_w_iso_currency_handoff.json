      "attributes": {
        "Sql Query": "SELECT\r\nTVOUTPUT.BATCH_ID, \r\nTVOUTPUT.BK_ISO_CURRENCY_CODE, \r\nTVOUTPUT.START_TV_DATE as START_DATE_ACTIVE,\r\nCOALESCE (MAX(CAST (TVOUTPUT.START_TV_DATE AS DATE)- INTERVAL '1' DAY)\r\nOVER (PARTITION BY TVOUTPUT.BK_ISO_CURRENCY_CODE \r\nORDER BY TVOUTPUT.START_TV_DATE ASC ROWS \r\nBETWEEN 1 FOLLOWING AND 1 FOLLOWING), DATE '3500-01-01' ) AS END_DATE_ACTIVE,\r\nTVOUTPUT.ISO_CURRENCY_NAME, \r\nTVOUTPUT.SOURCE_SYSTEM_CODE, \r\nTVOUTPUT.ISO_CURRENCY_ENABLED_FLAG, \r\nTVOUTPUT.EDW_CREATE_DATETIME,\r\nTVOUTPUT.ACTION_CODE,\r\nROW_NUMBER() OVER(PARTITION BY TVOUTPUT.BK_ISO_CURRENCY_CODE ORDER BY TVOUTPUT.START_TV_DATE ASC) AS RANK_INDEX,\r\n(CASE WHEN RANK_INDEX = 1 AND NICTV.BK_ISO_CURRENCY_CODE IS NOT NULL THEN 'U' ELSE 'I' END) AS DML_TYPE\r\nFROM\r\n(\r\n\t\tSELECT\r\n\t\tBATCH_ID, \r\n\t\tBK_ISO_CURRENCY_CODE, \r\n\t\tSTART_TV_DATE, \r\n\t\tEND_TV_DATE, \r\n\t\tISO_CURRENCY_NAME,\r\n\t\tSOURCE_SYSTEM_CODE, \r\n\t\tISO_CURRENCY_ENABLED_FLAG, \r\n\t\tEDW_CREATE_DATETIME,\r\n\t\tACTION_CODE,\r\n\t\tROW_NUMBER() OVER( PARTITION BY BK_ISO_CURRENCY_CODE ,ISO_CURRENCY_NAME,ISO_CURRENCY_ENABLED_FLAG\r\n\t\tORDER BY EDW_CREATE_DATETIME DESC) AS ROW_NUM \r\n\t\tFROM \r\n\t\t(\r\n\t\t\tSELECT\r\n\t\t\tMF_CURRENCY.BATCH_ID, \r\n\t\t\tMF_CURRENCY.BK_ISO_CURRENCY_CODE, \r\n\t\t\tMF_CURRENCY.START_TV_DATE, \r\n\t\t\tMF_CURRENCY.END_TV_DATE, \r\n\t\t\tMF_CURRENCY.ISO_CURRENCY_NAME,\r\n\t\t\tMF_CURRENCY.SOURCE_SYSTEM_CODE, \r\n\t\t\tMF_CURRENCY.ISO_CURRENCY_ENABLED_FLAG,\r\n\t\t\tMF_CURRENCY.EDW_CREATE_DATETIME,\r\n\t\t\tMF_CURRENCY.ACTION_CODE\r\n\t\t\tFROM \r\n\t\t\t( \r\n\t\t\t\tSELECT\r\n\t\t\t\t\tSMFC.BATCH_ID, \r\n\t\t\t\t\tSMFC.CURRENCY_CODE BK_ISO_CURRENCY_CODE, \r\n\t\t\t\t\tCAST(SMFC.CREATE_DATETIME AS DATE) START_TV_DATE, \r\n\t\t\t\t\tCAST(SMFC.CREATE_DATETIME AS DATE) END_TV_DATE, \r\n\t\t\t\t\tSMFCT.DESCRIPTION ISO_CURRENCY_NAME,\r\n\t\t\t\t\tNSSC.SOURCE_SYSTEM_CODE , \r\n\t\t\t\t\tSMFC.ENABLED_FLAG ISO_CURRENCY_ENABLED_FLAG, \r\n\t\t\t\t\tSMFC.CREATE_DATETIME EDW_CREATE_DATETIME,\r\n\t\t\t\t\tSMFC.ACTION_CODE\r\n\t\t\t\tFROM\r\n\t\t\t\t\t$$STGDB.ST_MF_FND_CURRENCIES SMFC, \r\n\t\t\t\t\t$$STGDB.ST_MF_FND_CURRENCIES_TL SMFCT, \r\n\t\t\t\t\t$$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\n\t\t\t\tWHERE \r\n\t\t\t\t\tSMFCT.CURRENCY_CODE = SMFC.CURRENCY_CODE\r\n\t\t\t\t\tAND SMFCT.GLOBAL_NAME = SMFC.GLOBAL_NAME\r\n\t\t\t\t\tAND SMFCT.GLOBAL_NAME = NSSC.GLOBAL_NAME\r\n\t\t\t\t\tAND SMFCT.LANGUAGE_CODE ='US'\r\n\t\t\t\t\tAND SMFC.GLOBAL_NAME = 'BE'\r\n\t\t\t\t\tAND CHARACTER_LENGTH(SMFC.CURRENCY_CODE)=3\r\n\t\t\t\t/*  Removed as part of SJPROD Retirement \r\n\t\t\t\tunion all\r\n\t\t\t\tSELECT\r\n\t\t\t\t\tSMFC.BATCH_ID, \r\n\t\t\t\t\tSMFC.CURRENCY_CODE BK_ISO_CURRENCY_CODE, \r\n\t\t\t\t\tCAST(SMFC.CREATE_DATETIME AS DATE) START_TV_DATE, \r\n\t\t\t\t\tCAST(SMFC.CREATE_DATETIME AS DATE) END_TV_DATE, \r\n\t\t\t\t\tSMFCT.DESCRIPTION ISO_CURRENCY_NAME,\r\n\t\t\t\t\tNSSC.SOURCE_SYSTEM_CODE, \r\n\t\t\t\t\tSMFC.ENABLED_FLAG ISO_CURRENCY_ENABLED_FLAG, \r\n\t\t\t\t\tSMFC.CREATE_DATETIME EDW_CREATE_DATETIME,\r\n\t\t\t\t\tSMFC.ACTION_CODE\r\n\t\t\t\tFROM\r\n\t\t\t\t\t$$STGDB.ST_MF_FND_CURRENCIES SMFC, \r\n\t\t\t\t\t$$STGDB.ST_MF_FND_CURRENCIES_TL SMFCT, \r\n\t\t\t\t\t$$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\n\t\t\t\tWHERE \r\n\t\t\t\t\tSMFCT.CURRENCY_CODE = SMFC.CURRENCY_CODE\r\n\t\t\t\t\tAND SMFCT.GLOBAL_NAME = SMFC.GLOBAL_NAME\r\n\t\t\t\t\tAND SMFCT.GLOBAL_NAME = NSSC.GLOBAL_NAME\r\n\t\t\t\t\tAND SMFCT.LANGUAGE_CODE='US'\r\n\t\t\t\t\tAND SMFC.GLOBAL_NAME = 'US'\r\n\t\t\t\t\tAND CHARACTER_LENGTH(SMFC.CURRENCY_CODE)=3\r\n\t\t\t\t\tAND SMFC.CURRENCY_CODE NOT IN \r\n\t\t\t\t\t\t(\tselect SMFC.CURRENCY_CODE\r\n\t\t\t\t\t\t\tFROM\r\n\t\t\t\t\t\t\t$$STGDB.ST_MF_FND_CURRENCIES SMFC, \r\n\t\t\t\t\t\t\t$$STGDB.ST_MF_FND_CURRENCIES_TL SMFCT, \r\n\t\t\t\t\t\t\t$$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\n\t\t\t\t\t\t\tWHERE \r\n\t\t\t\t\t\t\tSMFCT.CURRENCY_CODE = SMFC.CURRENCY_CODE\r\n\t\t\t\t\t\t\tAND SMFCT.GLOBAL_NAME = SMFC.GLOBAL_NAME\r\n\t\t\t\t\t\t\tAND SMFCT.GLOBAL_NAME = NSSC.GLOBAL_NAME\r\n\t\t\t\t\t\t\tAND SMFCT.LANGUAGE_CODE ='US'\r\n\t\t\t\t\t\t\tAND SMFC.GLOBAL_NAME = 'BE'\r\n\t\t\t\t\t\t\tAND CHARACTER_LENGTH(SMFC.CURRENCY_CODE)=3) */\r\n\t\t\t\tUNION ALL\r\n\t\t\t\tSELECT\r\n\t\t\t\t\tSMFC.BATCH_ID, \r\n\t\t\t\t\tSMFC.CURRENCY_CODE BK_ISO_CURRENCY_CODE, \r\n\t\t\t\t\tCAST(SMFC.CREATE_DATETIME AS DATE) START_TV_DATE, \r\n\t\t\t\t\tCAST(SMFC.CREATE_DATETIME AS DATE) END_TV_DATE, \r\n\t\t\t\t\tSMFCT.DESCRIPTION ISO_CURRENCY_NAME,\r\n\t\t\t\t\tNSSC.SOURCE_SYSTEM_CODE, \r\n\t\t\t\t\tSMFC.ENABLED_FLAG ISO_CURRENCY_ENABLED_FLAG, \r\n\t\t\t\t\tSMFC.CREATE_DATETIME EDW_CREATE_DATETIME,\r\n\t\t\t\t\tSMFC.ACTION_CODE\r\n\t\t\t\tFROM\r\n\t\t\t\t\t$$STGDB.ST_CG1_FND_CURRENCIES SMFC, \r\n\t\t\t\t\t$$STGDB.ST_CG1_FND_CURRENCIES_TL SMFCT, \r\n\t\t\t\t\t$$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\n\t\t\t\tWHERE \r\n\t\t\t\t\tSMFCT.CURRENCY_CODE = SMFC.CURRENCY_CODE\r\n\t\t\t\t\tAND SMFCT.GLOBAL_NAME = SMFC.GLOBAL_NAME\r\n\t\t\t\t\tAND SMFCT.GLOBAL_NAME = NSSC.GLOBAL_NAME\r\n\t\t\t\t\tAND SMFCT.LANGUAGE_CODE='US'\r\n\t\t\t\t\tAND SMFC.GLOBAL_NAME = 'CG'\r\n\t\t\t\t\tAND CHARACTER_LENGTH(SMFC.CURRENCY_CODE)=3\r\n\t\t\t\t\tAND SMFC.CURRENCY_CODE NOT IN \r\n\t\t\t\t\t\t(\tselect SMFC.CURRENCY_CODE\r\n\t\t\t\t\t\t\tFROM\r\n\t\t\t\t\t\t\t$$STGDB.ST_MF_FND_CURRENCIES SMFC, \r\n\t\t\t\t\t\t\t$$STGDB.ST_MF_FND_CURRENCIES_TL SMFCT, \r\n\t\t\t\t\t\t\t$$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\n\t\t\t\t\t\t\tWHERE \r\n\t\t\t\t\t\t\tSMFCT.CURRENCY_CODE = SMFC.CURRENCY_CODE\r\n\t\t\t\t\t\t\tAND SMFCT.GLOBAL_NAME = SMFC.GLOBAL_NAME\r\n\t\t\t\t\t\t\tAND SMFCT.GLOBAL_NAME = NSSC.GLOBAL_NAME\r\n\t\t\t\t\t\t\tAND SMFCT.LANGUAGE_CODE ='US'\r\n\t\t\t\t\t\t\tAND CHARACTER_LENGTH(SMFC.CURRENCY_CODE)=3\r\n\r\n\t\t\t\t)\r\n\t\t\t) MF_CURRENCY\r\n\t\t\t/* \r\n\t\t\tBedrock2.0 change - removed OM flow\r\n\t\t\t\r\n\t\t\tUNION ALL\r\n\t\t\tSELECT\r\n\t\t\t\tOM_CURRENCY.BATCH_ID, \r\n\t\t\t\tOM_CURRENCY.BK_ISO_CURRENCY_CODE, \r\n\t