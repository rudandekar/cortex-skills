      "attributes": {
        "Sql Query": "SELECT \r\nST.RELATIONSHIP_ID, \r\nST.SOURCE_LEDGER_ID,\r\nST.TARGET_LEDGER_ID, \r\nST.SLA_LEDGER_ID, \r\nST.PRIMARY_LEDGER_ID, \r\nST.TARGET_CURRENCY_CODE, \r\nST.TARGET_LEDGER_NAME, \r\nST.TARGET_LEDGER_SHORT_NAME, \r\nST.TARGET_LEDGER_CATEGORY_CODE, \r\nST.RELATIONSHIP_TYPE_CODE, \r\nST.RELATIONSHIP_ENABLED_FLAG, \r\nST.CREATION_DATE,\r\nST.ORG_ID, \r\nST.LAST_UPDATE_DATE, \r\nST.GES_UPDATE_DATE ,\r\nST.GLOBAL_NAME, \r\nST.CREATE_DATETIME,\r\nST.APPLICATION_ID\r\nFROM\r\n(\r\nSELECT \r\nSMGLR.RELATIONSHIP_ID, \r\nSMGLR.SOURCE_LEDGER_ID,\r\nSMGLR.TARGET_LEDGER_ID, \r\nSMGLR.SLA_LEDGER_ID, \r\nSMGLR.PRIMARY_LEDGER_ID, \r\nSMGLR.TARGET_CURRENCY_CODE, \r\nSMGLR.TARGET_LEDGER_NAME, \r\nSMGLR.TARGET_LEDGER_SHORT_NAME, \r\nSMGLR.TARGET_LEDGER_CATEGORY_CODE, \r\nSMGLR.RELATIONSHIP_TYPE_CODE, \r\nSMGLR.RELATIONSHIP_ENABLED_FLAG, \r\nSMGLR.CREATION_DATE,\r\nSMGLR.ORG_ID, \r\nSMGLR.LAST_UPDATE_DATE, \r\nSMGLR.GES_UPDATE_DATE ,\r\nSMGLR.GLOBAL_NAME, \r\nSMGLR.CREATE_DATETIME,\r\nSMGLR.APPLICATION_ID\r\nFROM\r\n $$STGDB.ST_MF_GL_LEDGER_RELATNSHPS SMGLR \r\n\r\nUNION ALL\r\n\r\nSELECT \r\nSCGLR.RELATIONSHIP_ID, \r\nSCGLR.SOURCE_LEDGER_ID,\r\nSCGLR.TARGET_LEDGER_ID, \r\nSCGLR.SLA_LEDGER_ID, \r\nSCGLR.PRIMARY_LEDGER_ID, \r\nSCGLR.TARGET_CURRENCY_CODE, \r\nSCGLR.TARGET_LEDGER_NAME, \r\nSCGLR.TARGET_LEDGER_SHORT_NAME, \r\nSCGLR.TARGET_LEDGER_CATEGORY_CODE, \r\nSCGLR.RELATIONSHIP_TYPE_CODE, \r\nSCGLR.RELATIONSHIP_ENABLED_FLAG, \r\nSCGLR.CREATION_DATE,\r\nSCGLR.ORG_ID, \r\nSCGLR.LAST_UPDATE_DATE, \r\nSCGLR.GES_UPDATE_DATE ,\r\nSCGLR.GLOBAL_NAME, \r\nSCGLR.CREATE_DATETIME,\r\nSCGLR.APPLICATION_ID\r\nFROM\r\n $$STGDB.ST_CG1_GL_LEDGER_RELATIONSH SCGLR ) ST\r\nWHERE (ST.RELATIONSHIP_ID,ST.GLOBAL_NAME) NOT IN \r\n (SELECT EL.RELATIONSHIP_ID,EL.GLOBAL_NAME FROM $$ETLVWDB.EL_GL_LEDGER_RELATIONSHIPS EL)",
