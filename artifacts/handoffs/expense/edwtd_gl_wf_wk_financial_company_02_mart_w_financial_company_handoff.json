      "attributes": {
        "Sql Query": "SELECT \r\nSTSICI.BATCH_ID,\r\nSTSICI.COMPANY_VALUE,\r\nSTSICI.THEATER_ID,\r\nSTSICI.COMPANY_NAME,\r\nSTSICI.FUNCTIONAL_CURRENCY_CODE,\r\nSTSICI.ENABLED_FLAG,\r\nSTSICI.USAGE_DESCRIPTION,\r\nSTSICI.START_DATE,\r\nSTSICI.END_DATE,\r\nSTSICI.CREATE_DATETIME,\r\nSTSICI.ACTION_CODE\r\nFROM\r\n$$STGDB.ST_SI_COMPANY_INFO STSICI\r\nWHERE\r\n(NOT EXISTS (SELECT 1 from $$FINLGLVWDB.N_FINANCIAL_THEATER_TV NFTTV \r\nWHERE STSICI.THEATER_ID = NFTTV.SK_THEATER_ID_INT\r\nAND NFTTV.END_TV_DATE=16000101 )\r\nOR\r\nNOT EXISTS (SELECT 1 FROM $$FINLGLVWDB.N_ISO_CURRENCY_TV NICTV \r\nWHERE STSICI.FUNCTIONAL_CURRENCY_CODE = NICTV.BK_ISO_CURRENCY_CODE\r\nAND NICTV.END_TV_DATE=16000101 ))",
