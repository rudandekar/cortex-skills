      "attributes": {
        "Sql Query": "SELECT\r\n\tTVOUTPUT.BK_COMPANY_CODE,\r\n\tCAST(TVOUTPUT.START_TV_DATE As DATE) START_DATE_ACTIVE,\r\n\tCAST(COALESCE (MAX (TVOUTPUT.START_TV_DATE - INTERVAL '1' DAY)\r\n\tOVER (PARTITION BY TVOUTPUT.BK_COMPANY_CODE \r\n\tORDER BY TVOUTPUT.START_TV_DATE ASC ROWS BETWEEN 1 FOLLOWING AND 1 FOLLOWING),\r\n\tDATE '3500-01-01') As DATE) END_DATE_ACTIVE,\r\n\tTVOUTPUT.FIN_COMPANY_NAME,\r\n\tTVOUTPUT.FIN_COMPANY_ENABLED_FLAG, \r\n\tTVOUTPUT.FIN_COMPANY_USAGE_DESCRIPTION,\r\n\tCAST(TVOUTPUT.FIN_COMPANY_START_DATE AS DATE) FIN_COMPANY_START_DATE,\r\n\tCAST(TVOUTPUT.FIN_COMPANY_END_DATE AS DATE) FIN_COMPANY_END_DATE,\r\n\tTVOUTPUT.BK_FUNCTIONAL_CURRENCY_CODE,\r\n\tTVOUTPUT.BK_FINANCIAL_THEATER_NAME_CODE,\r\n\tTVOUTPUT.SK_COMPANY_VALUE_CODE,\r\n\tTVOUTPUT.ACTION_CODE, \r\n\tROW_NUMBER () OVER (PARTITION BY TVOUTPUT.BK_COMPANY_CODE \r\n\tORDER BY TVOUTPUT.START_TV_DATE ASC) As RANK_INDEX,\r\n\t(CASE WHEN RANK_INDEX = 1 AND NFCTV_OUT.BK_COMPANY_CODE IS NOT NULL THEN 'U'ELSE 'I' END) AS DML_TYPE\r\nFROM\t(\r\n\tSELECT\r\n\t\tBATCH_ID,\r\n\t\tBK_COMPANY_CODE,\r\n\t\tFIN_COMPANY_NAME,\r\n\t\tFIN_COMPANY_ENABLED_FLAG, \r\n\t\tFIN_COMPANY_USAGE_DESCRIPTION, \r\n\t\tSTART_TV_DATE,\r\n\t\tEDW_CREATE_DATETIME, \r\n\t\tACTION_CODE, \r\n\t\tEXCEPTION_TYPE,\r\n\t\tFIN_COMPANY_START_DATE,\r\n\t\tFIN_COMPANY_END_DATE,\r\n\t\tBK_FUNCTIONAL_CURRENCY_CODE,\r\n\t\tBK_FINANCIAL_THEATER_NAME_CODE,\r\n\t\tSK_COMPANY_VALUE_CODE,\r\n\t\tROW_NUMBER () OVER (PARTITION BY BK_COMPANY_CODE,\r\n\t\t\t\t\t\t FIN_COMPANY_NAME,\r\n\t\t\t\t\t\t FIN_COMPANY_ENABLED_FLAG,\r\n\t\t\t\t\t\t FIN_COMPANY_START_DATE,\r\n\t\t\t\t\t\t FIN_COMPANY_END_DATE,\r\n\t\t\t\t\t\t BK_FUNCTIONAL_CURRENCY_CODE,\r\n\t\t\t\t\t\t BK_FINANCIAL_THEATER_NAME_CODE\r\n\t\tORDER\tBY EDW_CREATE_DATETIME DESC) AS ROW_NUM \r\n\tFROM\t(\r\n\t\tSELECT\r\n\t\t\tSTSICI.BATCH_ID, \r\n\t\t\tSTSICI.COMPANY_VALUE BK_COMPANY_CODE , \r\n\t\t\tSTSICI.COMPANY_NAME FIN_COMPANY_NAME,\r\n\t\t\tSTSICI.ENABLED_FLAG FIN_COMPANY_ENABLED_FLAG ,\r\n\t\t\tSTSICI.USAGE_DESCRIPTION FIN_COMPANY_USAGE_DESCRIPTION,\r\n\t\t\tCAST (STSICI.CREATE_DATETIME AS DATE) START_TV_DATE,\r\n\t\t\tSTSICI.CREATE_DATETIME EDW_CREATE_DATETIME,\r\n\t\t\tSTSICI.ACTION_CODE, \r\n\t\t\t'NE' EXCEPTION_TYPE,\r\n\t\t\tCAST(STSICI.START_DATE AS DATE) FIN_COMPANY_START_DATE,\r\n\t\t\tCAST(STSICI.END_DATE AS DATE) FIN_COMPANY_END_DATE, \r\n\t\t\tSTSICI.FUNCTIONAL_CURRENCY_CODE  BK_FUNCTIONAL_CURRENCY_CODE,\r\n\t\t\tNFTTV.BK_FINANCIAL_THEATER_NAME_CODE BK_FINANCIAL_THEATER_NAME_CODE,\r\n\t\t\tSTSICI.COMPANY_VALUE SK_COMPANY_VALUE_CODE\r\n\t\tFROM\r\n\t\t\t$$STGDB.ST_SI_COMPANY_INFO STSICI,\r\n\t\t\t$$FINLGLVWDB.N_FINANCIAL_THEATER_TV NFTTV,\r\n\t\t\t$$FINLGLVWDB.N_ISO_CURRENCY_TV NICTV\r\n\t\tWHERE\tSTSICI.FUNCTIONAL_CURRENCY_CODE = NICTV.BK_ISO_CURRENCY_CODE\r\n\t\t  AND   STSICI.THEATER_ID=NFTTV.SK_THEATER_ID_INT\r\n\t\t  AND   NFTTV.END_TV_DATE=16000101\r\n\t\t  AND   NICTV.END_TV_DATE=16000101\r\n\t\tUNION ALL\r\n\t\tSELECT\t\r\n\t\t\tEXSICI.BATCH_ID, \r\n\t\t\tEXSICI.COMPANY_VALUE BK_COMPANY_CODE, \r\n\t\t\tEXSICI.COMPANY_NAME  FIN_COMPANY_NAME,\r\n\t\t\tEXSICI.ENABLED_FLAG  FIN_COMPANY_ENABLED_FLAG,\r\n\t\t\tEXSICI.USAGE_DESCRIPTION FIN_COMPANY_USAGE_DESCRIPTION,\r\n\t\t\tCAST(EXSICI.CREATE_DATETIME AS DATE) START_TV_DATE,\r\n\t\t\tEXSICI.CREATE_DATETIME EDW_CREATE_DATETIME,\r\n\t\t\tEXSICI.ACTION_CODE,\r\n\t\t\tEXSICI.EXCEPTION_TYPE,\r\n\t\t\tCAST(EXSICI.START_DATE AS DATE) FIN_COMPANY_START_DATE,\r\n\t\t\tCAST(EXSICI.END_DATE AS DATE) FIN_COMPANY_END_DATE, \r\n\t\t\tEXSICI.FUNCTIONAL_CURRENCY_CODE BK_FUNCTIONAL_CURRENCY_CODE,\r\n\t\t\tNFTTV.BK_FINANCIAL_THEATER_NAME_CODE BK_FINANCIAL_THEATER_NAME_CODE,\r\n\t\t\tEXSICI.COMPANY_VALUE SK_COMPANY_VALUE_CODE \r\n\t\tFROM\t\r\n\t\t\t$$EXCEPDB.EX_SI_COMPANY_INFO EXSICI,\r\n\t\t\t$$FINLGLVWDB.N_FINANCIAL_THEATER_TV NFTTV,\r\n\t\t\t$$FINLGLVWDB.N_ISO_CURRENCY_TV NICTV\r\n\t\tWHERE \tEXSICI.FUNCTIONAL_CURRENCY_CODE = NICTV.BK_ISO_CURRENCY_CODE\r\n\t\t  AND EXSICI.THEATER_ID=NFTTV.SK_THEATER_ID_INT\r\n\t\t  AND NFTTV.END_TV_DATE=16000101\r\n\t\t  AND NICTV.END_TV_DATE=16000101\r\n\t\tUNION ALL\r\n\t\tSELECT\r\n\t\t\t-999 BATCH_ID,\r\n\t\t\tNFCTV.BK_COMPANY_CODE,\r\n\t\t\tNFCTV.FIN_COMPANY_NAME,\r\n\t\t\tNFCTV.FIN_COMPANY_ENABLED_FLAG,\r\n\t\t\tNFCTV.FIN_COMPANY_USAGE_DESCRIPTION,\r\n\t\t\tNFCTV.START_TV_DATE,\r\n\t\t\tNFCTV.EDW_UPDATE_DATETIME EDW_CREATE_DATETIME,\r\n\t\t\t'X' ACTION_CODE,\r\n\t\t\t'NE' EXCEPTION_TYPE,\r\n\t\t\tNFCTV.FIN_COMPANY_START_DATE,\r\n\t\t\tNFCTV.FIN_COMPANY_END_DATE, \r\n\t\t\tNFCTV.BK_FUNCTIONAL_CURRENCY_CODE,\r\n\t\t\tNFCTV.BK_FINANCIAL_THEATER_NAME_CODE,\r\n\t\t\tNFCTV.SK_COMPANY_VALUE_CODE\r\n\t\t\tFROM\t$$FINLGLVWDB.N_FINANCIAL_COMPANY_TV NFCTV\r\n\t\tWHERE\tNFCTV.BK_COMPANY_CODE IN\r\n\t\t\t(\r\n\t\t\tSELECT STSICI.COMPANY_VALUE FROM $$STGDB.ST_SI_COMPANY_INFO STSICI\r\n\t\t\tUNION ALL\r\n\t\t\tSELECT EXSICI.COMPANY_VALUE FROM $$EXCEPDB.EX_SI_COMPANY_INFO EXSICI\r\n\t\t\t)\r\n\t\t  AND NFCTV.END_TV_DATE=16000101\r\n\t\t)  TVINPUT\r\n\t\tQUALIFY ROW_NUMBER () OVER (PARTITION BY BK_COMPANY_CODE,TVINPUT.START_TV_DATE\r\n\t\tORDER BY TVINPUT.EDW_CREATE_DATETIME DESC) = 1\r\n\t)  TVOUTPUT\r\nLEFT JOIN $$FINLGLVWDB.N_FINANCIAL_COMPANY_TV NFCTV_OUT\r\nON TVOUTPUT.BK_COMPANY_CODE = NFCTV_OUT.BK_COMPANY_CODE\r\nAND NFCTV_OUT.END_TV_DATE =16000101 \r\nWHERE TVOUTPUT.ROW_NUM = 1",
        "User Defined Join": "",
