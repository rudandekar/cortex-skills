      "attributes": {
        "Sql Query": "SELECT\r\nAE_HEADER_ID,\r\nAPPLICATION_ID,\r\nLEDGER_ID,\r\nENTITY_ID,\r\nEVENT_ID,\r\nEVENT_TYPE_CODE,\r\nACCOUNTING_DATE,\r\nJE_CATEGORY_NAME,\r\nPRODUCT_RULE_CODE,\r\nCREATION_DATE,\r\nPARENT_AE_HEADER_ID,\r\nPARENT_AE_LINE_NUM,\r\nGES_UPDATE_DATE,\r\nGLOBAL_NAME,\r\nGL_TRANSFER_STATUS_CODE\r\n\r\nFROM\r\n(\r\nSELECT \r\nAE_HEADER_ID,\r\nAPPLICATION_ID,\r\nCAST(LEDGER_ID AS BIGINT) AS LEDGER_ID,\r\nENTITY_ID,\r\nEVENT_ID,\r\nEVENT_TYPE_CODE,\r\nACCOUNTING_DATE,\r\nJE_CATEGORY_NAME,\r\nPRODUCT_RULE_CODE,\r\nCREATION_DATE,\r\nPARENT_AE_HEADER_ID,\r\nPARENT_AE_LINE_NUM,\r\nGES_UPDATE_DATE,\r\nGLOBAL_NAME,\r\nGL_TRANSFER_STATUS_CODE\r\nFROM $$STGDB.ST_MF_XLA_AE_HEADERS \r\nUNION\r\n\r\nSELECT \r\nAE_HEADER_ID,\r\nAPPLICATION_ID,\r\nLEDGER_ID,\r\nENTITY_ID,\r\nEVENT_ID,\r\nEVENT_TYPE_CODE,\r\nACCOUNTING_DATE,\r\nJE_CATEGORY_NAME,\r\nPRODUCT_RULE_CODE,\r\nCREATION_DATE,\r\nPARENT_AE_HEADER_ID,\r\nPARENT_AE_LINE_NUM,\r\nGES_UPDATE_DATE,\r\nGLOBAL_NAME,\r\nGL_TRANSFER_STATUS_CODE\r\nFROM $$STGDB.ST_CG1_XLA_AE_HEADERS \r\n)STUXAH\r\n\r\nWHERE (STUXAH.AE_HEADER_ID,STUXAH.GLOBAL_NAME)\r\nNOT IN\r\n(SELECT EL.AE_HEADER_ID,EL.GLOBAL_NAME FROM $$ETLVWDB.EL_XLA_AE_HEADERS EL)",
