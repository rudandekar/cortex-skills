      "attributes": {
        "Sql Query": "SELECT ELPCGA.ATTRIBUTE1,\r\n\tELPCGA.ATTRIBUTE10,\r\n\tELPCGA.ATTRIBUTE11,\r\n\tELPCGA.ATTRIBUTE14,\r\n\tELPCGA.ATTRIBUTE2,\r\n\tELPCGA.ATTRIBUTE8,\r\n\tELPCGA.CONTROL_GROUP_ID,\r\n\tELPCGA.CONTROL_GROUP_NAME,\r\n\tELPCGA.CREATION_DATE,\r\n\tELPCGA.ENABLED_FLAG,\r\n\tELPCGA.GES_UPDATE_DATE,\r\n\tELPCGA.GLOBAL_NAME,\r\n\tELPCGA.LAST_UPDATE_DATE,\r\n\tELPCGA.ORG_ID\r\nFROM\r\n\r\n\r\n( SELECT \r\n\r\n        SMPCGA.ATTRIBUTE1,\r\n\tSMPCGA.ATTRIBUTE10,\r\n\tSMPCGA.ATTRIBUTE11,\r\n\tSMPCGA.ATTRIBUTE14,\r\n\tSMPCGA.ATTRIBUTE2,\r\n\tSMPCGA.ATTRIBUTE8,\r\n\tSMPCGA.CONTROL_GROUP_ID,\r\n\tSMPCGA.CONTROL_GROUP_NAME,\r\n\tSMPCGA.CREATION_DATE,\r\n\tSMPCGA.ENABLED_FLAG,\r\n\tSMPCGA.GES_UPDATE_DATE,\r\n\tSMPCGA.GLOBAL_NAME,\r\n\tSMPCGA.LAST_UPDATE_DATE,\r\n\tSMPCGA.ORG_ID\r\nFROM $$STGDB.ST_MF_PO_CONTROL_GROUPS_ALL SMPCGA\r\n\r\nUNION ALL\r\n\r\n\r\nSELECT  \r\n        SCPCGA.ATTRIBUTE1,\r\n\tSCPCGA.ATTRIBUTE10,\r\n\tSCPCGA.ATTRIBUTE11,\r\n\tSCPCGA.ATTRIBUTE14,\r\n\tSCPCGA.ATTRIBUTE2,\r\n\tSCPCGA.ATTRIBUTE8,\r\n\tSCPCGA.CONTROL_GROUP_ID,\r\n\tSCPCGA.CONTROL_GROUP_NAME,\r\n\tSCPCGA.CREATION_DATE,\r\n\tSCPCGA.ENABLED_FLAG,\r\n\tSCPCGA.GES_UPDATE_DATE,\r\n\tSCPCGA.GLOBAL_NAME,\r\n\tSCPCGA.LAST_UPDATE_DATE,\r\n\tSCPCGA.ORG_ID\r\nFROM $$STGDB.ST_CG1_PO_CONTROL_GROUPS_AL SCPCGA\r\n)ELPCGA\r\nWHERE(ELPCGA.CONTROL_GROUP_ID,ELPCGA.GLOBAL_NAME) NOT IN\r\n(SELECT EPCGA.CONTROL_GROUP_ID,EPCGA.GLOBAL_NAME FROM $$ETLVWDB.EL_PO_CONTROL_GROUPS_ALL EPCGA)",
