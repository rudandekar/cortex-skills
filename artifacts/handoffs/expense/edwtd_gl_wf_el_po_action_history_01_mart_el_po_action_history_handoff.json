      "attributes": {
        "Sql Query": "SELECT SMPAH.ACTION_CODE_VALUE,\r\n\tSMPAH.ACTION_DATE,\r\n\tSMPAH.CREATION_DATE,\r\n\tSMPAH.EMPLOYEE_ID,\r\n\tSMPAH.LAST_UPDATE_DATE,\r\n\tSMPAH.NOTE,\r\n\tSMPAH.OBJECT_ID,\r\n\tSMPAH.OBJECT_REVISION_NUM,\r\n\tSMPAH.OBJECT_SUB_TYPE_CODE,\r\n\tSMPAH.OBJECT_TYPE_CODE,\r\n\tSMPAH.OFFLINE_CODE,\r\n\tSMPAH.GES_PK_ID,\r\n\tSMPAH.SEQUENCE_NUM,\r\n\tSMPAH.GES_UPDATE_DATE,\r\n\tSMPAH.GLOBAL_NAME\r\nFROM $$STGDB.ST_MF_PO_ACTION_HISTORY SMPAH\r\nWHERE(SMPAH.GES_PK_ID ,SMPAH.GLOBAL_NAME) NOT IN\r\n(SELECT EPAH.GES_PK_ID ,EPAH.GLOBAL_NAME FROM $$ETLVWDB.EL_PO_ACTION_HISTORY EPAH)\r\n\r\nUNION ALL\r\n\r\nSELECT SCXFPA.ACTION_CODE_VALUE,\r\n\tSCXFPA.ACTION_DATE,\r\n\tSCXFPA.CREATION_DATE,\r\n\tSCXFPA.EMPLOYEE_ID,\r\n\tSCXFPA.LAST_UPDATE_DATE,\r\n\tSCXFPA.NOTE,\r\n\tSCXFPA.OBJECT_ID,\r\n\tSCXFPA.OBJECT_REVISION_NUM,\r\n\tSCXFPA.OBJECT_SUB_TYPE_CODE,\r\n\tSCXFPA.OBJECT_TYPE_CODE,\r\n\tSCXFPA.OFFLINE_CODE,\r\n\tSCXFPA.POAH_ID AS GES_PK_ID,\r\n\tSCXFPA.SEQUENCE_NUM,\r\n\tSCXFPA.GES_UPDATE_DATE,\r\n\tSCXFPA.GLOBAL_NAME\r\nFROM $$STGDB.ST_CG1_XXSCM_FIN_PO_ACTION SCXFPA\r\nWHERE(SCXFPA.POAH_ID, SCXFPA.GLOBAL_NAME) NOT IN\r\n(SELECT EPAH.GES_PK_ID, EPAH.GLOBAL_NAME FROM $$ETLVWDB.EL_PO_ACTION_HISTORY EPAH)",
