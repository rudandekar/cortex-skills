      "attributes": {
        "Sql Query": "select \r\nBATCH_ID                      \r\n,DEPRECIABLE_LIFE              \r\n,READ_ONLY                     \r\n,DESCRIPTION                   \r\n,ACCOUNT_TYPE                  \r\n,COMMENTS                      \r\n,GL_ACCOUNT_MAP                \r\n,PARENT_ACCT_ID                \r\n,ACCOUNT_ID                    \r\n,CA                            \r\n,IT                            \r\n,WPR                           \r\n,MFG                           \r\n,CDO                           \r\n,SALES                         \r\n,CAP_ACCOUNT_ID                \r\n,DEP_ACCOUNT_ID                \r\n,LINE_ACCOUNT                  \r\n,UI_TAB                        \r\n,TAB_DISPLAY_FLAG              \r\n,CIP_FLAG                      \r\n,ROLLUP_FLAG                   \r\n,CATAGORY                      \r\n,UPLOAD_FLAG                   \r\n,FI                            \r\n,CM_FLAG                       \r\n,HR                            \r\n,PL_ACCOUNT                    \r\n,CREATE_DATETIME               \r\n,ACTION_CODE                   \r\n,'RI' as EXCEPTION_TYPE                \r\nfrom\r\n$$STGDB.ST_CAP_ACCOUNTS \r\nWHERE \r\nNOT EXISTS(SELECT 1 FROM $$FINLGLVWDB.N_FINANCIAL_ACCOUNT NFA\r\n            WHERE (substr(trim(ACCOUNT_ID),1,5) =NFA.BK_FINANCIAL_ACCOUNT_CODE))",
