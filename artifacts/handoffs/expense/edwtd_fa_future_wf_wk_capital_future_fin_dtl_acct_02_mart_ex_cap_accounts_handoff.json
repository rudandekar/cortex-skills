      "attributes": {
        "Sql Query": "SELECT \r\n\tNFA.BK_FINANCIAL_ACCOUNT_CODE AS BK_FINANCIAL_ACCOUNT_CD,\r\nSUBSTR(TRIM(SECA.ACCOUNT_ID),7) AS BK_CPTL_FUTURE_FIN_DTL_ACCT_CD , \r\n\tSECA.ACCOUNT_ID AS SK_ACCOUNT_ID,\r\n\tSECA.ACCOUNT_TYPE AS ACCOUNT_TYPE_CD, \r\n\tSECA.ACTION_CODE AS ACTION_CODE,\r\n\t'I' AS DML_TYPE\r\nFROM\r\n\t(\r\n\t  select \r\n\t  SCA.ACCOUNT_ID,\r\n\t  SCA.ACTION_CODE,\r\n\t  SCA.ACCOUNT_TYPE FROM\r\n\t$$STGDB.ST_CAP_ACCOUNTS SCA\r\n)SECA\r\nINNER JOIN  $$FINLGLVWDB.N_FINANCIAL_ACCOUNT NFA\r\n\tON (SUBSTR(TRIM(SECA.ACCOUNT_ID),1,5) =NFA.BK_FINANCIAL_ACCOUNT_CODE)",
