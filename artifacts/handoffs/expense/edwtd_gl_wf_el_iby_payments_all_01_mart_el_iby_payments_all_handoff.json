      "attributes": {
        "Sql Query": "SELECT SMIPA.PAYMENT_ID, \r\nSMIPA.PAYMENT_METHOD_CODE, \r\nSMIPA.PAYMENT_STATUS, \r\nSMIPA.PAYMENT_AMOUNT, \r\nSMIPA.PAYMENT_CURRENCY_CODE, \r\nSMIPA.INTERNAL_BANK_ACCOUNT_ID, \r\nSMIPA.ORG_ID, \r\nSMIPA.CREATION_DATE, \r\nSMIPA.LAST_UPDATE_DATE, \r\nSMIPA.PAYMENT_DATE, \r\nSMIPA.EXTERNAL_BANK_ACCOUNT_ID, \r\nSMIPA.GLOBAL_NAME, \r\nSMIPA.GES_UPDATE_DATE, \r\nSMIPA.CREATE_DATETIME\r\nFROM \r\n(SELECT SMIPA.PAYMENT_ID, \r\nSMIPA.PAYMENT_METHOD_CODE, \r\nSMIPA.PAYMENT_STATUS, \r\nSMIPA.PAYMENT_AMOUNT, \r\nSMIPA.PAYMENT_CURRENCY_CODE, \r\nSMIPA.INTERNAL_BANK_ACCOUNT_ID, \r\nSMIPA.ORG_ID, \r\nSMIPA.CREATION_DATE, \r\nSMIPA.LAST_UPDATE_DATE, \r\nSMIPA.PAYMENT_DATE, \r\nSMIPA.EXTERNAL_BANK_ACCOUNT_ID, \r\nSMIPA.GLOBAL_NAME, \r\nSMIPA.GES_UPDATE_DATE, \r\nSMIPA.CREATE_DATETIME \r\nFROM\r\n $$STGDB.ST_MF_IBY_PAYMENTS_ALL SMIPA ) SMIPA\r\n WHERE (SMIPA.PAYMENT_ID,SMIPA.GLOBAL_NAME)\r\n       NOT IN \r\n\t   (SELECT EIPA.PAYMENT_ID,EIPA.GLOBAL_NAME FROM $$ETLVWDB.EL_IBY_PAYMENTS_ALL EIPA)",
