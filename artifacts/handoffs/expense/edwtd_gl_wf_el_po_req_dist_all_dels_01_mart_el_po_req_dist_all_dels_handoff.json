      "attributes": {
        "Sql Query": "SELECT \r\nELPRDAD.CODE_COMBINATION_ID,\r\nELPRDAD.CREATION_DATE, \r\nELPRDAD.DISTRIBUTION_ID, \r\nELPRDAD.DISTRIBUTION_NUM, \r\nELPRDAD.LAST_UPDATE_DATE, \r\nELPRDAD.ORG_ID, \r\nELPRDAD.REQUISITION_LINE_ID, \r\nELPRDAD.SET_OF_BOOKS_ID, \r\nELPRDAD.SOURCE_REQ_DISTRIBUTION_ID, \r\nELPRDAD.GES_DELETE_DATE, \r\nELPRDAD.GLOBAL_NAME \r\nFROM\r\n( SELECT\r\nSMPRDAD.CODE_COMBINATION_ID,\r\nSMPRDAD.CREATION_DATE, \r\nSMPRDAD.DISTRIBUTION_ID, \r\nSMPRDAD.DISTRIBUTION_NUM, \r\nSMPRDAD.LAST_UPDATE_DATE, \r\nSMPRDAD.ORG_ID, \r\nSMPRDAD.REQUISITION_LINE_ID, \r\nSMPRDAD.SET_OF_BOOKS_ID, \r\nSMPRDAD.SOURCE_REQ_DISTRIBUTION_ID, \r\nSMPRDAD.GES_DELETE_DATE, \r\nSMPRDAD.GLOBAL_NAME \r\nFROM $$STGDB.ST_MF_PO_REQ_DIST_ALL_DELS SMPRDAD\r\nUNION ALL\r\nSELECT\r\nSCPRDD.CODE_COMBINATION_ID,\r\nSCPRDD.CREATION_DATE, \r\nSCPRDD.DISTRIBUTION_ID, \r\nSCPRDD.DISTRIBUTION_NUM, \r\nSCPRDD.LAST_UPDATE_DATE, \r\nSCPRDD.ORG_ID, \r\nSCPRDD.REQUISITION_LINE_ID, \r\nSCPRDD.SET_OF_BOOKS_ID, \r\nSCPRDD.SOURCE_REQ_DISTRIBUTION_ID, \r\nSCPRDD.GES_DELETE_DATE, \r\nSCPRDD.GLOBAL_NAME \r\nFROM $$STGDB.ST_CG1_PO_REQ_DISTRIB_DELS SCPRDD) ELPRDAD\r\nWHERE ( ELPRDAD.DISTRIBUTION_ID ,ELPRDAD.GLOBAL_NAME) NOT IN (SELECT EPRDAD.DISTRIBUTION_ID,EPRDAD.GLOBAL_NAME FROM $$ETLVWDB.EL_PO_REQ_DIST_ALL_DELS EPRDAD)",
