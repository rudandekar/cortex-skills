      "attributes": {
        "Sql Query": "SELECT \tPCR.AMOUNT_LIMIT,\r\n\tPCR.ATTRIBUTE1,\r\n       PCR.ATTRIBUTE10,\r\n       PCR.ATTRIBUTE2,\r\n\tPCR.ATTRIBUTE3,\r\n\tPCR.ATTRIBUTE4,\r\n\tPCR.ATTRIBUTE5,\r\n\tPCR.ATTRIBUTE6,\r\n\tPCR.ATTRIBUTE7,\r\n\tPCR.ATTRIBUTE_CATEGORY,\r\n\tPCR.CONTROL_GROUP_ID,\r\n\tPCR.CONTROL_RULE_ID,\r\n\tPCR.CREATION_DATE,\r\n\tPCR.GES_UPDATE_DATE,\r\n\tPCR.GLOBAL_NAME,\r\n\tPCR.INACTIVE_DATE,\r\n\tPCR.LAST_UPDATE_DATE,\r\n\tPCR.LOCATION_ID,\r\n\tPCR.OBJECT_CODE,\r\n\tPCR.RULE_TYPE_CODE,\r\n\tPCR.SEGMENT2_HIGH,\r\n\tPCR.SEGMENT2_LOW,\r\n\tPCR.SEGMENT3_HIGH,\r\n\tPCR.SEGMENT3_LOW,\r\n\tPCR.SEGMENT4_HIGH,\r\n\tPCR.SEGMENT4_LOW,\r\n\tPCR.SEGMENT5_HIGH,\r\n\tPCR.SEGMENT5_LOW ,\r\n\tPCR.SEGMENT6_HIGH ,\r\n\tPCR.SEGMENT6_LOW \r\n\r\nFROM(select SMPCR.AMOUNT_LIMIT,\r\n\tSMPCR.ATTRIBUTE1,\r\n        SMPCR.ATTRIBUTE10,\r\n        SMPCR.ATTRIBUTE2,\r\n\tSMPCR.ATTRIBUTE3,\r\n\tSMPCR.ATTRIBUTE4,\r\n\tSMPCR.ATTRIBUTE5,\r\n\tSMPCR.ATTRIBUTE6,\r\n\tSMPCR.ATTRIBUTE7,\r\n\tSMPCR.ATTRIBUTE_CATEGORY,\r\n\tSMPCR.CONTROL_GROUP_ID,\r\n\tSMPCR.CONTROL_RULE_ID,\r\n\tSMPCR.CREATION_DATE,\r\n\tSMPCR.GES_UPDATE_DATE,\r\n\tSMPCR.GLOBAL_NAME,\r\n\tSMPCR.INACTIVE_DATE,\r\n\tSMPCR.LAST_UPDATE_DATE,\r\n\tSMPCR.LOCATION_ID,\r\n\tSMPCR.OBJECT_CODE,\r\n\tSMPCR.RULE_TYPE_CODE,\r\n\tSMPCR.SEGMENT2_HIGH,\r\n\tSMPCR.SEGMENT2_LOW,\r\n\tSMPCR.SEGMENT3_HIGH,\r\n\tSMPCR.SEGMENT3_LOW,\r\n\tSMPCR.SEGMENT4_HIGH,\r\n\tSMPCR.SEGMENT4_LOW,\r\n\tSMPCR.SEGMENT5_HIGH,\r\n\tSMPCR.SEGMENT5_LOW ,\r\n\tSMPCR.SEGMENT6_HIGH ,\r\n\tSMPCR.SEGMENT6_LOW \r\nfrom $$STGDB.ST_MF_PO_CONTROL_RULES SMPCR\r\nunion all\r\nselect SCPCR.AMOUNT_LIMIT,\r\n\tSCPCR.ATTRIBUTE1,\r\n        SCPCR.ATTRIBUTE10,\r\n        SCPCR.ATTRIBUTE2,\r\n\tSCPCR.ATTRIBUTE3,\r\n\tSCPCR.ATTRIBUTE4,\r\n\tSCPCR.ATTRIBUTE5,\r\n\tSCPCR.ATTRIBUTE6,\r\n\tSCPCR.ATTRIBUTE7,\r\n\tSCPCR.ATTRIBUTE_CATEGORY,\r\n\tSCPCR.CONTROL_GROUP_ID,\r\n\tSCPCR.CONTROL_RULE_ID,\r\n\tSCPCR.CREATION_DATE,\r\n\tSCPCR.GES_UPDATE_DATE,\r\n\tSCPCR.GLOBAL_NAME,\r\n\tSCPCR.INACTIVE_DATE,\r\n\tSCPCR.LAST_UPDATE_DATE,\r\n\tSCPCR.LOCATION_ID,\r\n\tSCPCR.OBJECT_CODE,\r\n\tSCPCR.RULE_TYPE_CODE,\r\n\tSCPCR.SEGMENT2_HIGH,\r\n\tSCPCR.SEGMENT2_LOW,\r\n\tSCPCR.SEGMENT3_HIGH,\r\n\tSCPCR.SEGMENT3_LOW,\r\n\tSCPCR.SEGMENT4_HIGH,\r\n\tSCPCR.SEGMENT4_LOW,\r\n\tSCPCR.SEGMENT5_HIGH,\r\n\tSCPCR.SEGMENT5_LOW ,\r\n\tSCPCR.SEGMENT6_HIGH ,\r\n\tSCPCR.SEGMENT6_LOW \r\nfrom $$STGDB.ST_CG1_PO_CONTROL_RULES SCPCR) PCR\r\nWHERE(PCR.CONTROL_RULE_ID ,PCR.GLOBAL_NAME) NOT IN\r\n(SELECT EPCR.CONTROL_RULE_ID ,EPCR.GLOBAL_NAME FROM $$ETLVWDB.EL_PO_CONTROL_RULES EPCR)",
