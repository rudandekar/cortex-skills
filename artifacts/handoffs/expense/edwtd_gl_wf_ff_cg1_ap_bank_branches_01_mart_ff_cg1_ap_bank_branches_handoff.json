      "attributes": {
        "Sql Query": "SELECT BRANCH.PARTY_ID BANK_BRANCH_ID , \r\nREPLACE(REPLACE(REPLACE(BRANCH.PARTY_NAME,CHR(10),' '),CHR(13),' '),CHR(234),'e')  BANK_BRANCH_NAME,\r\n REPLACE(REPLACE(REPLACE(BANK.PARTY_NAME,CHR(10),' '),CHR(13),' '),CHR(234),'e')   BANK_NAME , \r\n PF.BANK_OR_BRANCH_NUMBER BANK_NUM, \r\n BRANCH.LAST_UPDATED_BY,\r\n BRANCH.CREATION_DATE,\r\n BRANCH.CREATED_BY, \r\n BRANCH.LAST_UPDATE_DATE,\r\n BRANCH.GES_UPDATE_DATE, \r\n BRANCH.GLOBAL_NAME \r\n    FROM\r\n            OPS$GGADM.CG1_HZ_PARTIES BRANCH,\r\n            OPS$GGADM.CG1_HZ_PARTIES BANK,\r\n            OPS$GGADM.CG1_HZ_RELATIONSHIPS RS,\r\n            OPS$GGADM.CG1_HZ_ORGANIZATION_PROFILES PF\r\n        \r\n    WHERE\r\n            BRANCH.PARTY_ID = RS.SUBJECT_ID AND\r\n            BANK.PARTY_ID = RS.OBJECT_ID AND\r\n            BRANCH.PARTY_ID = PF.PARTY_ID AND\r\n            RELATIONSHIP_CODE = 'BRANCH_OF' AND \r\n            DIRECTIONAL_FLAG = 'B' AND\r\n            SUBJECT_TYPE = 'ORGANIZATION' AND\r\nBRANCH. GES_UPDATE_DATE> to_date('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS')",
        "User Defined Join": "",
