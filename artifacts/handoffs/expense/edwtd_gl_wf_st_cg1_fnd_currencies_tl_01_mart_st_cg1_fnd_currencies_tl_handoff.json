      "attributes": {
        "Sql Query": "SELECT \r\n$$BatchId AS BATCH_ID,\r\n'I' AS ACTION_CODE,\r\n CURRENCY_CODE, \r\n NAME, \r\n LANGUAGE_CODE,\r\n CREATED_BY, \r\n CREATION_DATE, \r\n LAST_UPDATED_BY, \r\n LAST_UPDATE_DATE,\r\n LAST_UPDATE_LOGIN, \r\n DESCRIPTION, \r\n SOURCE_LANG, \r\n SOURCE_DML_TYPE,\r\n SOURCE_COMMIT_TIME,\r\n REFRESH_DATETIME, \r\n'CG'AS GLOBAL_NAME , \r\nCURRENT_TIMESTAMP(0) AS CREATE_DATETIME\r\nFROM\r\n $$NRTACCUMVWDB.CG1_FND_CURRENCIES_TL \r\n WHERE LENGTH( CURRENCY_CODE)=3\r\n AND   SOURCE_COMMIT_TIME >'$$LastExtractDate'\r\nAND   SOURCE_DML_TYPE IN ( 'SQL COMPUPDATE','INSERT')\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY CURRENCY_CODE ,LANGUAGE_CODE ORDER BY REFRESH_DATETIME DESC)=1",
