      "attributes": {
        "Sql Query": "SELECT WFSA.BK_SUBACCOUNT_CODE,\r\nWFSA.SUBACCOUNT_NAME, \r\nWFSA.SUBACCOUNT_DESCRIPTION,\r\nWFSA.LOCAL_SUBACCT_OWNER_PARTY_KEY,\r\nWFSA.START_TV_DATE, \r\nWFSA.END_TV_DATE, \r\nWFSA.SK_ACCOUNT_VALUE_CODE,\r\nWFSA.SK_SI_FLEX_STRUCT_ID_INT, \r\nWFSA.SK_SUB_ACCOUNT_VALUE_CODE,\r\nWFSA.BK_SUBACCOUNT_LOCALITY_INT,\r\nWFSA.BK_FINANCIAL_ACCOUNT_CODE, \r\nWFSA.BK_FIN_ACCT_LOCALITY_INT \r\nFROM\r\n$$WORKDB.W_FINANCIAL_SUBACCOUNT WFSA\r\nWHERE WFSA.DML_TYPE='I'\r\nAND (WFSA.BK_SUBACCOUNT_CODE,WFSA.BK_SUBACCOUNT_LOCALITY_INT,\r\nWFSA.BK_FINANCIAL_ACCOUNT_CODE, \r\nWFSA.BK_FIN_ACCT_LOCALITY_INT,WFSA.START_TV_DATE) NOT IN\r\n(SELECT NFSA.BK_SUBACCOUNT_CODE,NFSA.BK_SUBACCOUNT_LOCALITY_INT,\r\nNFSA.BK_FINANCIAL_ACCOUNT_CODE, \r\nNFSA.BK_FIN_ACCT_LOCALITY_INT,NFSA.START_TV_DATE from $$FINLGLVWDB.N_FINANCIAL_SUBACCOUNT_TV NFSA)",
