      "attributes": {
        "Sql Query": "SELECT\r\n  NFSA.BK_FINANCIAL_ACCOUNT_CODE\r\n  ,NFSA.BK_SUBACCOUNT_CODE\r\n  ,CASE WHEN (TRIM(NFSA.BK_SUBACCOUNT_CODE) BETWEEN '001' AND '099') \r\n  THEN 'Local Sub-Account' \r\n  ELSE NFSA.SUBACCOUNT_NAME END SUB_ACCOUNT_NAME\r\n  ,NFSA.SUBACCOUNT_DESCRIPTION\r\n  ,NFSA.LOCAL_SUBACCT_OWNER_PARTY_KEY\r\n  ,NFA.RU_BK_PARENT_FIN_ACCT_CODE\r\n  ,NFA.ACCOUNT_GROUP_ID\r\n  ,NFA.FINANCIAL_ACCOUNT_TYPE\r\n  ,NFA.FINANCIAL_ACCOUNT_DESCRIPTION\r\n  ,NFA.FINANCIAL_ACCT_START_DATE\r\n  ,NFA.GLOBAL_ACCOUNT_OWNER_PARTY_KEY\r\n  ,NFA.PARENT_ROLE\r\n  ,NFA.FINANCIAL_ACCT_DISPLAY_SEQ_INT \r\n  ,NFA.CONTROLLABLE_ACCOUNT_FLG\r\n FROM\r\n  $$FINLGLVWDB.N_FINANCIAL_SUBACCOUNT_TV NFSA,\r\n  $$FINLGLVWDB.N_FINANCIAL_ACCOUNT_TV NFA\r\n WHERE\r\n  NFSA.END_TV_DATE='3500-01-01'\r\n AND NFA.END_TV_DATE='3500-01-01'\r\n AND (NFSA.BK_SUBACCOUNT_CODE,NFA.BK_FINANCIAL_ACCOUNT_CODE) NOT IN (SELECT BK_SUBACCOUNT_CD,BK_FINANCIAL_ACCOUNT_CD\r\n  FROM $$FINLGLVWDB.MT_ACCOUNT_SUB_ACCOUNT)\r\n AND NFSA.BK_FINANCIAL_ACCOUNT_CODE=NFA.BK_FINANCIAL_ACCOUNT_CODE\r\n QUALIFY ROW_NUMBER() OVER (PARTITION BY NFSA.BK_SUBACCOUNT_CODE,NFSA.BK_FINANCIAL_ACCOUNT_CODE\r\n ORDER BY NFSA.EDW_UPDATE_DATETIME DESC) = 1",
