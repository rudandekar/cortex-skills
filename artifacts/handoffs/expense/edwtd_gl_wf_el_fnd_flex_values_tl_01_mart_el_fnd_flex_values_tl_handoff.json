      "attributes": {
        "Sql Query": "SELECT\r\nEFFV.DESCRIPTION             ,  \r\nEFFV.FLEX_VALUE_ID           ,      \r\nEFFV.FLEX_VALUE_MEANING      ,      \r\nEFFV.GES_UPDATE_DATE         , \r\nEFFV.GLOBAL_NAME             ,      \r\nEFFV.LANGUAGE1               ,      \r\nEFFV.LAST_UPDATED_BY         ,      \r\nEFFV.LAST_UPDATE_DATE        ,   \r\nEFFV.LAST_UPDATE_LOGIN       ,      \r\nEFFV.SOURCE_LANG             \r\nFROM \r\n(SELECT \r\nSMFVT.DESCRIPTION             ,  \r\nSMFVT.FLEX_VALUE_ID           ,      \r\nSMFVT.FLEX_VALUE_MEANING      ,      \r\nSMFVT.GES_UPDATE_DATE         , \r\nSMFVT.GLOBAL_NAME             ,      \r\nSMFVT.LANGUAGE1               ,      \r\nSMFVT.LAST_UPDATED_BY         ,      \r\nSMFVT.LAST_UPDATE_DATE        ,   \r\nSMFVT.LAST_UPDATE_LOGIN       ,      \r\nSMFVT.SOURCE_LANG          \r\nFROM $$STGDB.ST_MF_FND_FLEX_VALUES_TL  SMFVT\r\nUNION ALL\r\nSELECT \r\nSOFVT.DESCRIPTION             ,  \r\nSOFVT.FLEX_VALUE_ID           ,      \r\nSOFVT.FLEX_VALUE_MEANING      ,      \r\nSOFVT.GES_UPDATE_DATE         , \r\nSOFVT.GLOBAL_NAME             ,      \r\nSOFVT.LANGUAGE1               ,      \r\nSOFVT.LAST_UPDATED_BY         ,      \r\nSOFVT.LAST_UPDATE_DATE        ,   \r\nSOFVT.LAST_UPDATE_LOGIN       ,      \r\nSOFVT.SOURCE_LANG                   \r\nFROM $$STGDB.ST_OM_FND_FLEX_VALUES_TL  SOFVT\r\nUNION ALL\r\nSELECT\r\nSCFVT.DESCRIPTION             ,  \r\nSCFVT.FLEX_VALUE_ID           ,      \r\nSCFVT.FLEX_VALUE_MEANING      ,      \r\nSCFVT.GES_UPDATE_DATE         , \r\nSCFVT.GLOBAL_NAME             ,      \r\nSCFVT.LANGUAGE1               ,      \r\nSCFVT.LAST_UPDATED_BY         ,      \r\nSCFVT.LAST_UPDATE_DATE        ,   \r\nSCFVT.LAST_UPDATE_LOGIN       ,      \r\nSCFVT.SOURCE_LANG \r\nFROM $$STGDB.ST_CG1_FND_FLEX_VALUES_TL  SCFVT\r\n)EFFV\r\nWHERE (EFFV.FLEX_VALUE_ID ,EFFV.GLOBAL_NAME ,EFFV.LANGUAGE1 ) \r\nNOT IN (SELECT  EFFVT.FLEX_VALUE_ID ,EFFVT.GLOBAL_NAME ,EFFVT.LANGUAGE1  FROM \r\n$$ETLVWDB.EL_FND_FLEX_VALUES_TL  EFFVT)",
