      "attributes": {
        "Sql Query": "SELECT MFOM_HLA.COUNTRY,\r\n\tMFOM_HLA.DESCRIPTION,\r\n\tMFOM_HLA.IN_ORGANIZATION_FLAG,\r\n\tMFOM_HLA.INACTIVE_DATE,\r\n\tMFOM_HLA.INVENTORY_ORGANIZATION_ID,\r\n\tMFOM_HLA.LOCATION_CODE,\r\n\tMFOM_HLA.LOCATION_ID,\r\n\tMFOM_HLA.OFFICE_SITE_FLAG,\r\n\tMFOM_HLA.SHIP_TO_LOCATION_ID,\r\n\tMFOM_HLA.GLOBAL_NAME\r\nFROM\r\n( \r\nSELECT SMHLA.COUNTRY,\r\n\tSMHLA.DESCRIPTION,\r\n\tSMHLA.IN_ORGANIZATION_FLAG,\r\n\tSMHLA.INACTIVE_DATE,\r\n\tSMHLA.INVENTORY_ORGANIZATION_ID,\r\n\tSMHLA.LOCATION_CODE,\r\n\tSMHLA.LOCATION_ID,\r\n\tSMHLA.OFFICE_SITE_FLAG,\r\n\tSMHLA.SHIP_TO_LOCATION_ID,\r\n\tSMHLA.GLOBAL_NAME\r\nFROM $$STGDB.ST_MF_HR_LOCATIONS_ALL SMHLA\r\n\r\nUNION ALL\r\n\r\nSELECT SOHLA.COUNTRY,\r\n\tSOHLA.DESCRIPTION,\r\n\tSOHLA.IN_ORGANIZATION_FLAG,\r\n\tSOHLA.INACTIVE_DATE,\r\n\tSOHLA.INVENTORY_ORGANIZATION_ID,\r\n\tSOHLA.LOCATION_CODE,\r\n\tSOHLA.LOCATION_ID,\r\n\tSOHLA.OFFICE_SITE_FLAG,\r\n\tSOHLA.SHIP_TO_LOCATION_ID,\r\n\tSOHLA.GLOBAL_NAME\r\nFROM $$STGDB.ST_OM_HR_LOCATIONS_ALL SOHLA\r\n\r\n)MFOM_HLA\r\nWHERE(MFOM_HLA.LOCATION_ID ,MFOM_HLA.GLOBAL_NAME) NOT IN\r\n(\r\nSELECT EHLA.LOCATION_ID ,EHLA.GLOBAL_NAME FROM $$ETLVWDB.EL_HR_LOCATIONS_ALL EHLA\r\n)",
