      "attributes": {
        "Sql Query": "SELECT \r\nMF_GL_BALANCES.ACTUAL_FLAG, \r\nTO_CHAR(MF_GL_BALANCES.BEGIN_BALANCE_CR),\r\nTO_CHAR(MF_GL_BALANCES.BEGIN_BALANCE_DR),\r\nMF_GL_BALANCES.CODE_COMBINATION_ID, MF_GL_BALANCES.CURRENCY_CODE, MF_GL_BALANCES.GES_PK_ID, \r\nMF_GL_BALANCES.GES_UPDATE_DATE, MF_GL_BALANCES.GLOBAL_NAME, \r\nMF_GL_BALANCES.LAST_UPDATED_BY, MF_GL_BALANCES.LAST_UPDATE_DATE, \r\nMF_GL_BALANCES.PERIOD_NAME, \r\nTO_CHAR(MF_GL_BALANCES.PERIOD_NET_CR),\r\nTO_CHAR(MF_GL_BALANCES.PERIOD_NET_DR),\r\nMF_GL_BALANCES.PERIOD_NUM, MF_GL_BALANCES.PERIOD_TYPE, MF_GL_BALANCES.PERIOD_YEAR, \r\nMF_GL_BALANCES.REVALUATION_STATUS,\r\n      CASE WHEN MF_GL_BALANCES.GLOBAL_NAME='US' THEN SET_OF_BOOKS_ID \r\n          WHEN MF_GL_BALANCES.GLOBAL_NAME='BE' then LEDGER_ID END AS SET_OF_BOOKS_ID , \r\nMF_GL_BALANCES.TRANSLATED_FLAG \r\nFROM\r\n MF_GL_BALANCES\r\nWHERE \r\nMF_GL_BALANCES.GES_UPDATE_DATE>to_date('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS') \r\nAND MF_GL_BALANCES.ACTUAL_FLAG='A'  \r\n --AND (MF_GL_BALANCES.TRANSLATED_FLAG IS NULL OR MF_GL_BALANCES.TRANSLATED_FLAG='Y')",
        "User Defined Join": "",
