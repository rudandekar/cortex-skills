      "attributes": {
        "Sql Query": "SELECT\r\nSTG.TELNUM AS BK_MOBILE_TELEPHONE_NUM\r\n,TO_DATE(STG.BILL_MONTH,'MON-YY') AS BK_BILLING_CYCLE_START_DT     \r\n,STG.VENDOR AS BK_MOBILE_CARRIER_NAME        \r\n,NFD.BK_DEPARTMENT_CODE AS BK_BILL_TO_DEPT_CD            \r\n,NFD.BK_COMPANY_CODE AS BK_BILL_TO_COMPANY_CD         \r\n,STG.SERVICE_TYPE AS BK_MOBILE_PLAN_TYPE_CD        \r\n,NCWP.CISCO_WORKER_PARTY_KEY  AS CISCO_WORKER_PARTY_KEY    \r\n,STG.AMOUNT_USD AS BILLED_USD_AMT                \r\n,STG.LASTREFRESHDATE AS SOURCE_REFRESH_DT             \r\n,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM                \r\n,USER EDW_CREATE_USER               \r\n,CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM                \r\n,USER EDW_UPDATE_USER \r\n,ACTION_CODE\r\n, 'I' AS DML_TYPE\r\nFROM $$STGDB.ST_EMAN_MOBILITY_SPEND_ALL STG\r\nINNER JOIN  $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT NFD\r\nON ( TRIM(NFD.BK_COMPANY_CODE )||TRIM (NFD.BK_DEPARTMENT_CODE ) =STG.DEPTID)\r\nINNER JOIN \r\n(SELECT CISCO_EMAIL_ADDRESS CEC_ID , CISCO_WORKER_PARTY_KEY,max(END_TV_DATE) AS END_TV_DT FROM $$COMREFVWDB.N_CISCO_WORKER_PARTY_TV NCWPT \r\ngroup by 1,2) NCWP\r\nON (NCWP.CEC_ID=STG.CEC_USERID)\r\nQUALIFY ROW_NUMBER()  OVER (PARTITION BY Emplid,TelNum,Bill_month,Vendor ORDER BY LASTREFRESHDATE  DESC )=1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
