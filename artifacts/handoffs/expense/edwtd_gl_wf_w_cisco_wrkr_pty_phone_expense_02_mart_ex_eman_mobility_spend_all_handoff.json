      ],
      "attributes": {
        "Sql Query": "SELECT EMPLID\r\n, CEC_USERID\r\n, DEPT_NAME\r\n, DEPTID\r\n, VENDOR\r\n, SERVICE_TYPE\r\n, TELNUM\r\n, TO_DATE(BILL_MONTH,'MON-YY')\r\n, AMOUNT_USD\r\n, LASTREFRESHDATE\r\n, CREATE_DATETIME\r\n, ACTION_CODE\r\n, 'Duplicate Rec for-Emplid,TelNum,Bill_month,Vendor' AS EXCEPTION_TYPE\r\nFROM\r\n $$STGDB.ST_EMAN_MOBILITY_SPEND_ALL\r\nWHERE EMPLID IS NOT NULL\r\n  QUALIFY count(1) OVER (PARTITION BY Emplid,TelNum,Bill_month,Vendor)>1\r\n  UNION ALL\r\n  SELECT EMPLID\r\n, CEC_USERID\r\n, DEPT_NAME\r\n, DEPTID\r\n, VENDOR\r\n, SERVICE_TYPE\r\n, TELNUM\r\n, TO_DATE(BILL_MONTH,'MON-YY')\r\n, AMOUNT_USD\r\n, LASTREFRESHDATE\r\n, CREATE_DATETIME\r\n, ACTION_CODE\r\n, 'EmployeeId is NULL' AS EXCEPTION_TYPE\r\nFROM\r\n$$STGDB.ST_EMAN_MOBILITY_SPEND_ALL\r\nWHERE EMPLID IS  NULL\r\n  QUALIFY count(1) OVER (PARTITION BY Emplid,TelNum,Bill_month,Vendor)>=1\r\n  UNION ALL\r\n    SELECT EMPLID\r\n, CEC_USERID\r\n, DEPT_NAME\r\n, DEPTID\r\n, VENDOR\r\n, SERVICE_TYPE\r\n, TELNUM\r\n, TO_DATE(BILL_MONTH,'MON-YY')\r\n, AMOUNT_USD\r\n, LASTREFRESHDATE\r\n, CREATE_DATETIME\r\n, ACTION_CODE\r\n, 'RI - Department code' AS EXCEPTION_TYPE\r\nFROM\r\n$$STGDB.ST_EMAN_MOBILITY_SPEND_ALL STG\r\nWHERE EMPLID IS NOT NULL AND NOT EXISTS (SELECT 1 FROM $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT NFD WHERE \r\n TRIM(NFD.BK_COMPANY_CODE )||TRIM (NFD.BK_DEPARTMENT_CODE ) =STG.DEPTID)\r\n UNION ALL\r\n SELECT EMPLID\r\n, CEC_USERID\r\n, DEPT_NAME\r\n, DEPTID\r\n, VENDOR\r\n, SERVICE_TYPE\r\n, TELNUM\r\n, TO_DATE(BILL_MONTH,'MON-YY')\r\n, AMOUNT_USD\r\n, LASTREFRESHDATE\r\n, CREATE_DATETIME\r\n, ACTION_CODE\r\n, 'RI - Cisco Worker Party Key' AS EXCEPTION_TYPE\r\nFROM\r\n$$STGDB.ST_EMAN_MOBILITY_SPEND_ALL STG\r\nWHERE EMPLID IS NOT NULL AND NOT EXISTS (SELECT 1 FROM  $$COMREFVWDB.N_CISCO_WORKER_PARTY_TV NCWP\r\nWHERE NCWP.CISCO_EMAIL_ADDRESS=STG.CEC_USERID)",
