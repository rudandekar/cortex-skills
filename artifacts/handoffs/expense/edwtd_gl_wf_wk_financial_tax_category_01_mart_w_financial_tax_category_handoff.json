      "attributes": {
        "Sql Query": "SELECT\r\nTVOUTPUT.BATCH_ID,\r\nTVOUTPUT.BK_FINANCIAL_TAX_CATEGORY_ID,\r\nTVOUTPUT.START_TV_DT AS START_DATE_ACTIVE,\r\nTVOUTPUT.FINANCIAL_TAX_CATEGORY_DESCR,\r\nTVOUTPUT.SK_TAX_CATEGORY_ID_INT,\r\nCOALESCE (MAX (TVOUTPUT.START_TV_DT - INTERVAL '1' DAY)\r\nOVER (PARTITION BY TVOUTPUT.BK_FINANCIAL_TAX_CATEGORY_ID\r\nORDER\tBY TVOUTPUT.START_TV_DT ASC ROWS BETWEEN 1 FOLLOWING\r\n\tAND\t1 FOLLOWING), DATE '3500-01-01') AS END_DATE_ACTIVE,\r\nTVOUTPUT.ACTION_CODE,\r\nROW_NUMBER () OVER (PARTITION BY TVOUTPUT.BK_FINANCIAL_TAX_CATEGORY_ID ORDER\tBY TVOUTPUT.START_TV_DT ASC) AS RANK_INDEX,\r\n(\r\n\t\tCASE\r\n\t\t\tWHEN\tRANK_INDEX = 1\r\n\tAnd\tNFTC_OUT.BK_FINANCIAL_TAX_CATEGORY_ID IS NOT NULL \r\nTHEN 'U'\r\n\t\t\tELSE\t'I' END) As DML_TYPE\r\nFROM(\r\nSELECT\t\r\n\t\tBATCH_ID,\r\n\t\tBK_FINANCIAL_TAX_CATEGORY_ID,\r\n\t\tSTART_TV_DT,\r\n        FINANCIAL_TAX_CATEGORY_DESCR,\r\n        SK_TAX_CATEGORY_ID_INT,\r\n\t\tEDW_CREATE_DATETIME,\r\n\t\tACTION_CODE,\r\n\t\tEXCEPTION_TYPE,\r\n\t\tROW_NUMBER () OVER (PARTITION BY BK_FINANCIAL_TAX_CATEGORY_ID, FINANCIAL_TAX_CATEGORY_DESCR\r\n\t\tORDER\tBY EDW_CREATE_DATETIME DESC) AS ROW_NUM\r\n\tFROM(\r\nSELECT\t\r\n\t     STC.BATCH_ID,\r\n\t     STC.TAX_CATEGORY_VALUE BK_FINANCIAL_TAX_CATEGORY_ID,\r\n\t\tCAST(COALESCE(STC.LAST_UPDATE_DATE,STC.CREATE_DATETIME) AS DATE) START_TV_DT,\r\n\t     STC.TAX_CATEGORY_DESC FINANCIAL_TAX_CATEGORY_DESCR,\r\n\t     STC.TAX_CATEGORY_ID SK_TAX_CATEGORY_ID_INT,\r\n\t     STC.CREATE_DATETIME EDW_CREATE_DATETIME,\r\n         STC.ACTION_CODE ACTION_CODE,\r\n\t     'NE' EXCEPTION_TYPE\r\nFROM\t$$STGDB.ST_SI_TAX_CATEGORY STC\r\nUNION\tALL\r\nSELECT\r\n\t       -999 BATCH_ID, \r\n\t       NFTC.BK_FINANCIAL_TAX_CATEGORY_ID,\r\n\t       NFTC.START_TV_DT,\r\n\t       NFTC.FINANCIAL_TAX_CATEGORY_DESCR,\r\n           NFTC.SK_TAX_CATEGORY_ID_INT,\r\n           NFTC.EDW_UPDATE_DTM EDW_CREATE_DATETIME,\r\n           'X' ACTION_CODE,\r\n\t       'NE' EXCEPTION_TYPE\r\nFROM\t$$FINLGLVWDB.N_FINANCIAL_TAX_CATEGORY_TV NFTC\r\nWHERE\tEXISTS (\r\nSELECT\t1 FROM $$STGDB.ST_SI_TAX_CATEGORY STC\r\n\t\t\tWHERE\tSTC.TAX_CATEGORY_VALUE=NFTC.BK_FINANCIAL_TAX_CATEGORY_ID)\r\n\t\tAND\tEND_TV_DT=16000101\r\n\t\t) TVINPUT\r\n\t\tQUALIFY\tROW_NUMBER () OVER (PARTITION BY TVINPUT.BK_FINANCIAL_TAX_CATEGORY_ID, TVINPUT.START_TV_DT\r\n\t\tORDER\tBY TVINPUT.EDW_CREATE_DATETIME DESC) = 1\r\n\t) TVOUTPUT\r\nLEFT JOIN $$FINLGLVWDB.N_FINANCIAL_TAX_CATEGORY_TV NFTC_OUT\r\n\tON\tTVOUTPUT.BK_FINANCIAL_TAX_CATEGORY_ID=NFTC_OUT.BK_FINANCIAL_TAX_CATEGORY_ID\r\n\tAnd\tNFTC_OUT.END_TV_DT =16000101\r\nWHERE\tTVOUTPUT.ROW_NUM = 1",
        "User Defined Join": "",
