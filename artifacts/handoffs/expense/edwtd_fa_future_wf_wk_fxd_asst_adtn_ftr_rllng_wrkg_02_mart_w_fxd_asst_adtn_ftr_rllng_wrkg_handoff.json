      ],
      "attributes": {
        "Sql Query": "SELECT \r\n\t     NCFPT.BK_CAPITAL_FUTURE_PROJ_ID_INT AS BK_CAPITAL_FUTURE_PROJ_ID_INT    \r\n\t    ,NFD.BK_DEPARTMENT_CODE AS BK_DEPARTMENT_CD\r\n\t    ,NFD.BK_COMPANY_CODE AS BK_COMPANY_CD\r\n\t    ,NCFFDA.BK_FINANCIAL_ACCOUNT_CD AS BK_FINANCIAL_ACCOUNT_CD\r\n\t    ,NCFFDA.BK_CPTL_FUTURE_FIN_DTL_ACCT_CD   AS BK_CPTL_FUTURE_FIN_DTL_ACCT_CD\r\n\t ,NCFO.BK_CPTL_FUTURE_ORG_ABBR_NAME  AS BK_RSPNSBL_CPTL_FTR_ORG_NAME\r\n\t   , NFM.FISCAL_MONTH_START_DATE  AS BK_PLANNED_FOR_DT\r\n\t    ,CASE WHEN SCRW.PERIOD_ID= -9999   then 'SPEND TO DATE ADJUSTMENT'\r\n\t          WHEN SCRW.PERIOD_ID= -8888    then 'FUTURE SPEND'\r\n\t          WHEN SCRW.PERIOD_ID= -7777   then 'PLANNED SPEND TO DATE'\r\n\t          WHEN SCRW.PERIOD_ID NOT IN (-9999, -8888,-7777) then 'FISCAL MONTH'\r\n\t     END AS BK_PLANNED_FOR_PERIOD_TYPE_CD\r\n\t    ,'ROLL WORKING'  as  BK_FA_ADDITION_FUTURE_TYPE\r\n\t    , sum(SCRW.OPEX_AMOUNT) as  ROLLING_WORKING_OPEX_USD_AMT   \r\n\t    , sum(SCRW.ASSET_AMOUNT) as  RLLNG_WRKNG_ASSET_COST_USD_AMT\r\n\t    ,'I' as ACTION_CODE\r\n\t ,'I' AS DML_TYPE\r\n\t  FROM \r\n\t (\r\n\t  SELECT\r\n\t   COALESCE( PROJECT_ID,-99999)  DV_PROJECT_ID,\r\n\t   COALESCE(ORG_ID,'NA') as DV_ORG_ID,\r\n\t   case when COUNTRY_DEPARTMENT = 'Unk_nown' \r\n\t     then 'UNK_UNKNOW'\r\n\t         else  COUNTRY_DEPARTMENT  end as DV_COUNTRY_DEPARTMENT,\r\n\t   ACCOUNT_ID,\r\n\t   PERIOD_ID,\r\n\t   (CASE WHEN PERIOD_ID IN (-9999, -8888,-7777) THEN 190099 \r\n\t        ELSE PERIOD_ID\r\n\t              END) as DV_PERIOD_ID,\r\n\t        case when ACCOUNT_ID like '6%' then  AMOUNT  * 1000\r\n\t                  else 0 end as OPEX_AMOUNT,\r\n\t         CASE When ACCOUNT_ID not like '6%' then   AMOUNT  * 1000\r\n\t           else 0 end as ASSET_AMOUNT,\r\n\t   ACTION_CODE\r\n\t  FROM $$STGDB.ST_CAP_ROLL_WORKING_PLAN \r\n\t  where ACCOUNT_ID <> '15040 CIP Activation-offset'\r\n\t  )SCRW  \r\n\tINNER  JOIN $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT NFD \r\n\t ON NFD.BK_COMPANY_CODE||'_'||NFD.BK_DEPARTMENT_CODE =  SCRW.DV_COUNTRY_DEPARTMENT \r\n\tINNER  JOIN  $$COMREFVWDB.N_FISCAL_MONTH NFM \r\n\t ON SCRW.DV_PERIOD_ID = (NFM.BK_FISCAL_YEAR_NUMBER_INT*100 + NFM.BK_FISCAL_MONTH_NUMBER_INT)  \r\n\tINNER JOIN $$FINLGLVWDB.N_CAPITAL_FUTURE_FIN_DTL_ACCT  NCFFDA   \r\n\t ON NCFFDA.SK_ACCOUNT_ID  = SCRW.ACCOUNT_ID  \r\n\tINNER JOIN $$FINLGLVWDB.N_CAPITAL_FUTURE_ORG   NCFO   \r\n\t ON NCFO.SK_ORG_ID = SCRW.DV_ORG_ID  \r\n\tINNER JOIN $$FINLGLVWDB.N_CAPITAL_FUTURE_PROJECT_TV  NCFPT \r\n\t    ON ( SCRW.DV_PROJECT_ID = NCFPT.BK_CAPITAL_FUTURE_PROJ_ID_INT\r\n\t      AND NCFPT.START_TV_DT='3500-01-01'\r\n )\r\ngroup by 1,2,3,4,5,6,7,8,9",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
