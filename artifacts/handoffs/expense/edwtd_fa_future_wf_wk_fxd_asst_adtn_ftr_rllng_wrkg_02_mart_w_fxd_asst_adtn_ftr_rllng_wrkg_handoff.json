      "attributes": {
        "Sql Query": "SELECT \r\nSCRW.BATCH_ID,                      \r\nSCRW.DV_PROJECT_ID ,\r\nSCRW.AMOUNT  ,\r\nSCRW.PERIOD_ID ,\r\nSCRW.ACCOUNT_ID,\r\nSCRW.DV_ORG_ID,\r\nSCRW.DV_COUNTRY_DEPARTMENT , \r\nSCRW.CIP_FLAG,\r\nSCRW.PERIOD_NAME,\r\nSCRW.CREATE_DATETIME  ,             \r\nSCRW.ACTION_CODE,\r\n'RI'EXCEPTION_TYPE \r\nFROM \r\n(SELECT\r\n            ST.BATCH_ID,\r\n\t\t COALESCE( ST.PROJECT_ID,-99999)  DV_PROJECT_ID,\r\n\t   COALESCE(ST.ORG_ID,'NA') as DV_ORG_ID,\r\n\t\t\tCASE WHEN ST.COUNTRY_DEPARTMENT = 'UNK_NOWN' \r\n\t\t\t\t THEN 'UNK_UNKNOW'\r\n\t\t\t      ELSE  ST.COUNTRY_DEPARTMENT  END AS DV_COUNTRY_DEPARTMENT,\r\n\t\t\tST.ACCOUNT_ID,\r\n\t\t\tST.PERIOD_ID,\r\n\t\t\t(CASE WHEN ST.PERIOD_ID IN (-9999, -8888,-7777) THEN 190099 \r\n\t\t\t  \t  ELSE ST.PERIOD_ID\r\n\t             END) AS DV_PERIOD_ID,\r\n\t\t\tST.AMOUNT,\r\n\t\t\tST.CIP_FLAG,\r\n\t\t\tST.PERIOD_NAME,\r\n\t\t\tST.CREATE_DATETIME  ,             \r\n            ST.ACTION_CODE \r\n\t\tFROM \r\n   $$STGDB.ST_CAP_ROLL_WORKING_PLAN ST\r\nwhere ACCOUNT_ID <> '15040 CIP Activation-offset' ) SCRW \r\nWHERE(NOT EXISTS (SELECT 1 FROM $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT NFD\r\n\tWHERE NFD.BK_COMPANY_CODE||'_'||NFD.BK_DEPARTMENT_CODE = SCRW.DV_COUNTRY_DEPARTMENT )\r\n\tOR NOT EXISTS(SELECT 1 FROM $$COMREFVWDB.N_FISCAL_MONTH NFM\r\n\tWHERE (NFM.BK_FISCAL_YEAR_NUMBER_INT*100 + NFM.BK_FISCAL_MONTH_NUMBER_INT) \t= SCRW.DV_PERIOD_ID)\r\n\tOR NOT EXISTS(SELECT 1 FROM $$FINLGLVWDB.N_CAPITAL_FUTURE_FIN_DTL_ACCT   NCFFDA   \r\n\tWHERE  NCFFDA.SK_ACCOUNT_ID = SCRW.ACCOUNT_ID )\r\n\tOR NOT EXISTS(SELECT 1 FROM $$FINLGLVWDB.N_CAPITAL_FUTURE_ORG  NCFO    \r\n\tWHERE NCFO.SK_ORG_ID = SCRW.DV_ORG_ID )\r\n\tOR NOT EXISTS(SELECT 1 FROM $$FINLGLVWDB.N_CAPITAL_FUTURE_PROJECT_TV  NCFPT \r\n     WHERE SCRW.DV_PROJECT_ID = NCFPT.BK_CAPITAL_FUTURE_PROJ_ID_INT\r\n     AND NCFPT.START_TV_DT='3500-01-01'\r\n    \t\t/* AND PROJECT_ACTIVE_STATUS_CD='Active' */ /* commented as part of CR */ \r\n    \t\t))",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
