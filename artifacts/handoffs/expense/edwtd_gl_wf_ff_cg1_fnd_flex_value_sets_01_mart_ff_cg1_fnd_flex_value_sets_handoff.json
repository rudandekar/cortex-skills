      "attributes": {
        "Sql Query": "SELECT CFFVS.FLEX_VALUE_SET_ID, \r\nREPLACE(REPLACE(CFFVS.FLEX_VALUE_SET_NAME,CHR(13),NULL),CHR(10),NULL),\r\nCFFVS.LAST_UPDATE_DATE,\r\nCFFVS.LAST_UPDATED_BY, \r\nCFFVS.CREATION_DATE, \r\nCFFVS.CREATED_BY, \r\nCFFVS.LAST_UPDATE_LOGIN, \r\nREPLACE(REPLACE(CFFVS.VALIDATION_TYPE,CHR(13),NULL),CHR(10),NULL), \r\nREPLACE(REPLACE(CFFVS.PROTECTED_FLAG,CHR(13),NULL),CHR(10),NULL),\r\nREPLACE(REPLACE(CFFVS.SECURITY_ENABLED_FLAG,CHR(13),NULL),CHR(10),NULL), \r\nREPLACE(REPLACE(CFFVS.LONGLIST_FLAG,CHR(13),NULL),CHR(10),NULL),\r\nREPLACE(REPLACE(CFFVS.FORMAT_TYPE,CHR(13),NULL),CHR(10),NULL), \r\nCFFVS.MAXIMUM_SIZE, \r\nREPLACE(REPLACE(CFFVS.ALPHANUMERIC_ALLOWED_FLAG,CHR(13),NULL),CHR(10),NULL),\r\nREPLACE(REPLACE(CFFVS.UPPERCASE_ONLY_FLAG,CHR(13),NULL),CHR(10),NULL),\r\nREPLACE(REPLACE(CFFVS.NUMERIC_MODE_ENABLED_FLAG,CHR(13),NULL),CHR(10),NULL), \r\nREPLACE(REPLACE(CFFVS.DESCRIPTION,CHR(13),NULL),CHR(10),NULL), \r\nREPLACE(REPLACE(CFFVS.DEPENDANT_DEFAULT_VALUE,CHR(13),NULL),CHR(10),NULL),\r\nREPLACE(REPLACE(CFFVS.DEPENDANT_DEFAULT_MEANING,CHR(13),NULL),CHR(10),NULL), \r\nCFFVS.PARENT_FLEX_VALUE_SET_ID, \r\nREPLACE(REPLACE(CFFVS.MINIMUM_VALUE,CHR(13),NULL),CHR(10),NULL),\r\nREPLACE(REPLACE(CFFVS.MAXIMUM_VALUE,CHR(13),NULL),CHR(10),NULL), \r\nCFFVS.NUMBER_PRECISION, \r\nCFFVS.GES_UPDATE_DATE, \r\nREPLACE(REPLACE(CFFVS.GLOBAL_NAME,CHR(13),NULL),CHR(10),NULL)\r\nFROM\r\n CG1_FND_FLEX_VALUE_SETS CFFVS\r\nWHERE\r\n CFFVS.GES_UPDATE_DATE>to_date('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS')",
