      "attributes": {
        "Sql Query": "SELECT ACCOUNT_TYPE, \r\nCOALESCE(ALTERNATE_CODE_COMBINATION_ID,0) AS ALTERNATE_CODE_COMBINATION_ID, \r\nCOALESCE(COMPANY_COST_CENTER_ORG_ID,0) AS COMPANY_COST_CENTER_ORG_ID,\r\nDETAIL_POSTING_ALLOWED_FLAG, \r\nENABLED_FLAG, \r\nCAST(SUBSTR(END_DATE_ACTIVE,1,10) AS TIMESTAMP(0)) AS END_DATE_ACTIVE,\r\nCODE_COMBINATION_ID, \r\nCAST(COALESCE(CAST(LAST_UPDATE_DATE AS VARCHAR(19)),CAST(CURRENT_TIMESTAMP(0) AS VARCHAR(19))) AS TIMESTAMP(0))\r\n AS LAST_UPDATE_DATE,\r\nLEDGER_SEGMENT, \r\nLEDGER_TYPE_CODE, \r\nSEGMENT1, \r\nSEGMENT2, \r\nSEGMENT3, \r\nSEGMENT4, \r\nSEGMENT5, \r\nSEGMENT6, \r\nCAST(SUBSTR(START_DATE_ACTIVE,1,10) AS TIMESTAMP(0)) AS START_DATE_ACTIVE,\r\nSUMMARY_FLAG, \r\n'-1' AS LAST_UPDATED_BY, \r\nOFFSET_NUMBER, \r\nPARTITION_NUMBER, \r\nRECORD_COUNT, \r\nCURRENT_TIMESTAMP(0) AS CREATE_DATETIME\r\nFROM \r\n$$STGDB.PST_CLOUD_GL_CODE_COMBINATIONS",
