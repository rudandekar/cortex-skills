      "attributes": {
        "Sql Query": "SELECT \r\n OPEX_CLARITY.FISCAL_YEAR_MONTH_NUM_INT,\r\n OPEX_CLARITY.DEPARTMENT_CODE,\r\n OPEX_CLARITY.COMPANY_CODE,\r\n OPEX_CLARITY.FINANCIAL_ACCOUNT_CODE,\r\n OPEX_CLARITY.SUB_ACCOUNT_CODE, \r\n OPEX_CLARITY.LOCATION_CODE, \r\n OPEX_CLARITY.PROJECT_CODE,\r\n COALESCE(OPEX_CLARITY.CLARITY_PROJECT_ID,'UNKNOWN'),\r\n OPEX_CLARITY.PRODUCT_ID, \r\n COALESCE(OPEX_CLARITY.FTE_COUNT,0), \r\n COALESCE(OPEX_CLARITY.BK_FUNCTIONAL_CURRENCY_CODE,'UNK'),\r\n COALESCE(OPEX_CLARITY.FUNCTIONAL_AMT,0.0000000),\r\n COALESCE(OPEX_CLARITY.USD_AMT,0.0000000),\r\n COALESCE(OPEX_CLARITY.PLATFORM,'UNKNOWN'),\r\n COALESCE(OPEX_CLARITY.ALLOCATED_FLAG ,'N')\r\nFROM\r\n FINREVRPT.FIN_CLARITY_PROJ_EXPENSE OPEX_CLARITY\r\n WHERE OPEX_CLARITY.FISCAL_YEAR_MONTH_NUM_INT   = (SELECT FISCAL_MONTH_ID FROM FINREVRPT.FIN_CLARITY_OPEN_PERIOD WHERE OPEN_FLAG='Y')",
