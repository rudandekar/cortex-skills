      "attributes": {
        "Sql Query": "SELECT\r\nNFDTV.BK_COMPANY_CODE BK_COMPANY_CODE,\r\nNFDTV.BK_DEPARTMENT_CODE BK_DEPARTMENT_CODE,\r\nNOPEX.CNTRBTN_MRGN_ROLLUP_NAME  BK_FUNCTIONAL_OPEX_NAME,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE,\r\n 'N' RSTD_FLAG,\r\nRFM.FISCAL_YEAR_NUMBER_INT RESTATED_FISCAL_YR_NUM_INT,\r\nRFM.FISCAL_MONTH_NUMBER_INT RESTATED_FISCAL_MTH_NUM_INT\r\nFROM\r\n$$STGDB.ST_AE_OPXALOC_DEPT_OPEX_MAP STMAP\r\nINNER JOIN $$FINLGLVWDB.N_FINANCIAL_DEPARTMENT NFDTV        \r\nON NFDTV.BK_DEPARTMENT_CODE = STMAP.DEPARTMENT_CD                \r\nAND NFDTV.BK_COMPANY_CODE = STMAP.COMPANY_CD\r\nINNER JOIN $$FINLGLVWDB.N_CNTRBTN_MRGN_ROLLUP_CATEGORY NOPEX\r\nON STMAP.OPEX_NAME=NOPEX.CNTRBTN_MRGN_ROLLUP_NAME \r\nINNER JOIN $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFM \r\nON RFM.FISCAL_YEAR_NUMBER_INT*100 + RFM.FISCAL_MONTH_NUMBER_INT = 201403 /*STMAP.RSTD_FISCAL_MONTH_ID */\r\n/* Commented as part of Q4FY20 ICPM DFA - OPEX */",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
