      "attributes": {
        "Sql Query": "SELECT \r\nSOMGDR.BATCH_ID, \r\nSOMGDR.FROM_CURRENCY,\r\nSOMGDR.TO_CURRENCY, \r\nSOMGDR.CONVERSION_DATE, \r\nSOMGDR.GLOBAL_NAME, \r\nSOMGDR.CONVERSION_TYPE, \r\nSOMGDR.CONVERSION_RATE, \r\nSOMGDR.CREATE_DATETIME, \r\nSOMGDR.ACTION_CODE \r\nFROM\r\n(\r\nSELECT \r\nSOMGDRBO.BATCH_ID, \r\nSOMGDRBO.FROM_CURRENCY,\r\nSOMGDRBO.TO_CURRENCY, \r\nSOMGDRBO.CONVERSION_DATE, \r\nSOMGDRBO.GLOBAL_NAME, \r\nSOMGDRBO.CONVERSION_TYPE, \r\nSOMGDRBO.CONVERSION_RATE, \r\nSOMGDRBO.CREATE_DATETIME, \r\nSOMGDRBO.ACTION_CODE \r\nFROM\r\n$$STGDB.ST_OM_GL_DAILY_RATES SOMGDRBO\r\nWHERE\r\nSOMGDRBO.FROM_CURRENCY IN (SELECT DISTINCT  NICT.BK_ISO_CURRENCY_CODE  \r\n  from $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT )\r\nAND  SOMGDRBO.TO_CURRENCY IN (SELECT DISTINCT  NICT.BK_ISO_CURRENCY_CODE\r\n  from $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\nAND  SOMGDRBO.GLOBAL_NAME = 'BO'\r\nand SOMGDRBO.CONVERSION_TYPE = 'Corporate'\r\nUNION ALL\r\nSELECT\r\nSOMGDRUO.BATCH_ID, \r\nSOMGDRUO.FROM_CURRENCY,\r\nSOMGDRUO.TO_CURRENCY, \r\nSOMGDRUO.CONVERSION_DATE, \r\nSOMGDRUO.GLOBAL_NAME, \r\nSOMGDRUO.CONVERSION_TYPE, \r\nSOMGDRUO.CONVERSION_RATE, \r\nSOMGDRUO.CREATE_DATETIME, \r\nSOMGDRUO.ACTION_CODE \r\nFROM\r\n$$STGDB.ST_OM_GL_DAILY_RATES SOMGDRUO\r\nWHERE\r\nSOMGDRUO.FROM_CURRENCY IN (SELECT DISTINCT  NICT.BK_ISO_CURRENCY_CODE\r\n\tfrom $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\nAND  SOMGDRUO.TO_CURRENCY IN (SELECT DISTINCT  NICT.BK_ISO_CURRENCY_CODE \r\n\tfrom $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\nAND  SOMGDRUO.GLOBAL_NAME = 'UO'\r\nand SOMGDRUO.CONVERSION_TYPE = 'Corporate'\r\nAND   NOT EXISTS (SELECT  1 \r\n\t\tFROM $$STGDB.ST_OM_GL_DAILY_RATES SOMGDR\r\n\t\tWHERE SOMGDR.GLOBAL_NAME = 'BO'\r\n\t\tAND SOMGDR.FROM_CURRENCY = SOMGDRUO.FROM_CURRENCY\r\n\t\tAND SOMGDR.TO_CURRENCY = SOMGDRUO.TO_CURRENCY\r\n\t\tAND SOMGDR.CONVERSION_DATE = SOMGDRUO.CONVERSION_DATE\r\n\t\tand SOMGDR.CONVERSION_TYPE = 'Corporate')\r\n)SOMGDR\r\nWHERE\r\n(SOMGDR.FROM_CURRENCY, SOMGDR.TO_CURRENCY, CAST(SOMGDR.CONVERSION_DATE AS DATE)) \r\n NOT IN ( SELECT SMGDR.FROM_CURRENCY, SMGDR.TO_CURRENCY, CAST(SMGDR.CONVERSION_DATE AS DATE) \r\n        FROM $$STGDB.ST_MF_GL_DAILY_RATES SMGDR\r\n        where CONVERSION_TYPE = 'Corporate')\r\nUNION ALL\r\nSELECT \r\nEMOGDR.BATCH_ID, \r\nEMOGDR.FROM_CURRENCY,\r\nEMOGDR.TO_CURRENCY, \r\nEMOGDR.CONVERSION_DATE, \r\nEMOGDR.GLOBAL_NAME, \r\nEMOGDR.CONVERSION_TYPE, \r\nEMOGDR.CONVERSION_RATE, \r\nEMOGDR.CREATE_DATETIME, \r\nEMOGDR.ACTION_CODE \r\nFROM\r\n(SELECT \r\nEMOGDRBO.BATCH_ID, \r\nEMOGDRBO.FROM_CURRENCY,\r\nEMOGDRBO.TO_CURRENCY, \r\nEMOGDRBO.CONVERSION_DATE, \r\nEMOGDRBO.GLOBAL_NAME, \r\nEMOGDRBO.CONVERSION_TYPE, \r\nEMOGDRBO.CONVERSION_RATE, \r\nEMOGDRBO.CREATE_DATETIME, \r\nEMOGDRBO.ACTION_CODE \r\nFROM\r\n$$EXCEPDB.EX_MF_OM_GL_DAILY_RATES EMOGDRBO\r\nWHERE\r\nEMOGDRBO.FROM_CURRENCY IN (SELECT DISTINCT  NICT.BK_ISO_CURRENCY_CODE \r\n    from $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\nAND EMOGDRBO.TO_CURRENCY IN (SELECT DISTINCT  NICT.BK_ISO_CURRENCY_CODE \r\n\tfrom $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\nAND  EMOGDRBO.EXCEPTION_TYPE = 'RI'\r\nAND  EMOGDRBO.GLOBAL_NAME = 'BO'\r\nand EMOGDRBO.CONVERSION_TYPE = 'Corporate'\r\nUNION ALL\r\nSELECT \r\nEMOGDRUO.BATCH_ID, \r\nEMOGDRUO.FROM_CURRENCY,\r\nEMOGDRUO.TO_CURRENCY, \r\nEMOGDRUO.CONVERSION_DATE, \r\nEMOGDRUO.GLOBAL_NAME, \r\nEMOGDRUO.CONVERSION_TYPE, \r\nEMOGDRUO.CONVERSION_RATE, \r\nEMOGDRUO.CREATE_DATETIME, \r\nEMOGDRUO.ACTION_CODE \r\nFROM\r\n$$EXCEPDB.EX_MF_OM_GL_DAILY_RATES EMOGDRUO\r\nWHERE\r\n     EMOGDRUO.FROM_CURRENCY IN (SELECT DISTINCT  NICT.BK_ISO_CURRENCY_CODE  \r\n\tfrom $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\nAND  EMOGDRUO.TO_CURRENCY IN (SELECT DISTINCT  NICT.BK_ISO_CURRENCY_CODE  \r\n\tfrom $$FINLGLVWDB.N_ISO_CURRENCY_TV NICT)\r\nAND  EMOGDRUO.EXCEPTION_TYPE = 'RI'\r\nAND  EMOGDRUO.GLOBAL_NAME = 'UO'\r\nand  EMOGDRUO.CONVERSION_TYPE = 'Corporate'\r\nAND   NOT EXISTS (SELECT  1 \r\n\t\tFROM $$EXCEPDB.EX_MF_OM_GL_DAILY_RATES EMOGDR\r\n\t\tWHERE  EMOGDR.GLOBAL_NAME = 'BO'\r\n\t\tAND EMOGDR.FROM_CURRENCY = EMOGDRUO.FROM_CURRENCY\r\n\t\tAND EMOGDR.TO_CURRENCY = EMOGDRUO.TO_CURRENCY\r\n\t\tAND EMOGDR.CONVERSION_DATE = EMOGDRUO.CONVERSION_DATE\r\n\t\tand EMOGDR.CONVERSION_TYPE = 'Corporate' )\r\n)EMOGDR\r\nWHERE  \r\n(EMOGDR.FROM_CURRENCY, EMOGDR.TO_CURRENCY, CAST(EMOGDR.CONVERSION_DATE AS DATE)) \r\n NOT IN ( SELECT EMOGDR.FROM_CURRENCY, EMOGDR.TO_CURRENCY, CAST(EMOGDR.CONVERSION_DATE AS DATE) \r\n        FROM $$EXCEPDB.EX_MF_OM_GL_DAILY_RATES EMOGDR WHERE EMOGDR.GLOBAL_NAME IN ('US','BE') and CONVERSION_TYPE = 'Corporate' )",
