      "attributes": {
        "Sql Query": "SELECT\r\n BK_FINANCIAL_ACCOUNT_CODE\r\n,node_level01_ID\r\n,node_level02_ID\r\n,node_level03_ID\r\n,node_level04_ID\r\n,Null as node_level05_ID\r\n,Null As node_level06_ID\r\n,Null As node_level07_ID\r\n,Null As node_level08_ID\r\n,Null As node_level09_ID\r\n,Null As node_level10_ID\r\n,Null As node_level11_ID\r\n,Null As node_level12_ID\r\n,Null As node_level13_ID\r\n,Null As node_level14_ID\r\n,Null As node_level15_ID\r\n,'Sub'\r\nFROM\r\n(\r\nSelect\t\r\nCoalesce(level04.BK_GPRV_ACCOUNT_GROUP_ID \r\n,level03.BK_GPRV_ACCOUNT_GROUP_ID ,level02.BK_GPRV_ACCOUNT_GROUP_ID \r\n,level01.BK_GPRV_ACCOUNT_GROUP_ID \r\n) As Financial_account_group_id\r\n,nfatv.BK_FINANCIAL_ACCOUNT_CODE \r\n,level01.BK_GPRV_ACCOUNT_GROUP_ID As node_level01_ID\r\n,level02.BK_GPRV_ACCOUNT_GROUP_ID As node_level02_ID\r\n,level03.BK_GPRV_ACCOUNT_GROUP_ID As node_level03_ID\r\n,level04.BK_GPRV_ACCOUNT_GROUP_ID As node_level04_ID\r\nFrom\r\n(\r\nSelect\t*\r\nFrom\t $$FINLGLVWDB.N_APSP_GPRV_FIN_ACCT_HIER_NODE\r\nWhere\tDV_ACCOUNT_NODE_LEVEL_NUM_INT = 1\r\n) level01\r\nLeft Outer Join\r\n(\r\nSelect\t*\r\nFrom\t $$FINLGLVWDB.N_APSP_GPRV_FIN_ACCT_HIER_NODE\r\nWhere\tDV_ACCOUNT_NODE_LEVEL_NUM_INT = 2\r\n) level02\r\n\tOn\tlevel01.BK_GPRV_ACCOUNT_GROUP_ID = level02.RU_PARENT_GRP_ACCT_GRP_ID\r\nLeft Outer Join\r\n(\r\nSelect\t*\r\nFrom\t $$FINLGLVWDB.N_APSP_GPRV_FIN_ACCT_HIER_NODE\r\nWhere\tDV_ACCOUNT_NODE_LEVEL_NUM_INT = 3\r\n) level03\r\n\tOn\tlevel02.BK_GPRV_ACCOUNT_GROUP_ID = level03.RU_PARENT_GRP_ACCT_GRP_ID\r\nLeft Outer Join\r\n(\r\nSelect\t*\r\nFrom\t $$FINLGLVWDB.N_APSP_GPRV_FIN_ACCT_HIER_NODE\r\nWhere\tDV_ACCOUNT_NODE_LEVEL_NUM_INT = 4\r\n) level04\r\n\tOn\tlevel03.BK_GPRV_ACCOUNT_GROUP_ID = level04.RU_PARENT_GRP_ACCT_GRP_ID\r\nInner Join\r\n\t$$FINLGLVWDB.n_financial_account  nfatv \r\n\tOn\tFinancial_account_group_id = nfatv.ACCOUNT_GROUP_ID AND FINANCIAL_ACCOUNT_TYPE='5'\r\n) A",
