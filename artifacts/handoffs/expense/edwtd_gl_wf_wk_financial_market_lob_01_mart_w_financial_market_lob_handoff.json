      "attributes": {
        "Sql Query": "SELECT\r\nTVOUTPUT.BK_FINANCIAL_MARKET_LOB_ID ,\r\nTVOUTPUT.START_TV_DATE AS START_TV_DT,\r\nTVOUTPUT.FINANCIAL_MARKET_LOB_DESCR,\r\nTVOUTPUT.SK_MARKET_LOB_ID,\r\nCOALESCE (MAX (TVOUTPUT.START_TV_DATE - INTERVAL '1' DAY)\r\nOVER (PARTITION BY TVOUTPUT.bk_FINANCIAL_MARKET_LOB_ID \r\nORDER BY TVOUTPUT.START_TV_DATE ASC ROWS BETWEEN 1 FOLLOWING\r\nAND 1 FOLLOWING), DATE '3500-01-01') AS END_TV_DT,\r\nTVOUTPUT.ACTION_CODE,\r\nROW_NUMBER () OVER (PARTITION BY TVOUTPUT.bk_FINANCIAL_MARKET_LOB_ID \r\nORDER BY TVOUTPUT.START_TV_DATE ASC) AS RANK_INDEX,\r\n(\r\nCASE\r\nWHEN RANK_INDEX = 1\r\nAnd NFML_OUT.bk_FINANCIAL_MARKET_LOB_ID IS NOT NULL \r\nTHEN 'U'\r\nELSE 'I' END) As DML_TYPE\r\nFROM(\r\nSELECT \r\nbk_FINANCIAL_MARKET_LOB_ID ,\r\nSTART_TV_DATE,\r\nFINANCIAL_MARKET_LOB_DESCr,\r\nSK_MARKET_LOB_ID,\r\nEDW_CREATE_DATETIME,\r\nACTION_CODE,\r\nEXCEPTION_TYPE,\r\nROW_NUMBER () OVER (PARTITION BY bk_FINANCIAL_MARKET_LOB_ID , FINANCIAL_MARKET_LOB_DESCr\r\nORDER BY EDW_CREATE_DATETIME DESC) AS ROW_NUM\r\nFROM(\r\nSELECT \r\nSML.MARKET_LOB_VALUE bk_FINANCIAL_MARKET_LOB_ID ,\r\nCAST(COALESCE(SML.LAST_UPDATE_DATE,SML.CREATE_DATETIME) AS DATE) START_TV_DATE,\r\nSML.MARKET_LOB_DESC FINANCIAL_MARKET_LOB_DESCr,\r\nSML.MARKET_LOB_ID SK_MARKET_LOB_ID,\r\nSML.CREATE_DATETIME EDW_CREATE_DATETIME,\r\nSML.ACTION_CODE ACTION_CODE,\r\n'NE' EXCEPTION_TYPE\r\nFROM $$STGDB.ST_SI_MARKET_LOB SML\r\nUNION ALL\r\nSELECT\r\nNFML.BK_FINANCIAL_MARKET_LOB_ID BK_FINANCIAL_MARKET_LOB_ID ,\r\nNFML.START_TV_DT,\r\nNFML.FINANCIAL_MARKET_LOB_DESCR,\r\nNFML.SK_MARKET_LOB_ID_INT,\r\nNFML.EDW_UPDATE_DTM EDW_CREATE_DATETIME,\r\n'X' ACTION_CODE,\r\n'NE' EXCEPTION_TYPE\r\nFROM $$FINLGLVWDB.N_FINANCIAL_MARKET_LOB_TV NFML \r\nWHERE EXISTS (\r\nSELECT 1\r\nFROM $$STGDB.ST_SI_MARKET_LOB SML\r\nWHERE SML.MARKET_LOB_VALUE=NFML.BK_FINANCIAL_MARKET_LOB_ID )\r\nAND END_TV_DT=16000101\r\n) TVINPUT\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY TVINPUT.bk_FINANCIAL_MARKET_LOB_ID , TVINPUT.START_TV_DATE\r\nORDER BY TVINPUT.EDW_CREATE_DATETIME DESC) = 1\r\n) TVOUTPUT\r\nLEFT JOIN $$FINLGLVWDB.N_FINANCIAL_MARKET_LOB_TV NFML_OUT\r\nON TVOUTPUT.BK_FINANCIAL_MARKET_LOB_ID =NFML_OUT.bk_FINANCIAL_MARKET_LOB_ID\r\nAnd NFML_OUT.END_TV_DT =16000101\r\nWHERE TVOUTPUT.ROW_NUM = 1",
        "User Defined Join": "",
