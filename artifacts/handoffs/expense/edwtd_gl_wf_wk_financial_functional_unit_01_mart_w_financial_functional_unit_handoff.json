      "attributes": {
        "Sql Query": "SELECT\r\nTVOUTPUT. BK_FUNCTIONAL_UNIT_ID,\r\nTVOUTPUT.START_TV_DT AS START_TV_DT,\r\nTVOUTPUT.FUNCTIONAL_UNIT_DESCR,\r\nTVOUTPUT.SK_FUNCTIONAL_UNIT_ID_INT,\r\nCOALESCE (MAX (TVOUTPUT.START_TV_DT - INTERVAL '1' DAY)\r\nOVER (PARTITION BY TVOUTPUT. BK_FUNCTIONAL_UNIT_ID\r\nORDER\tBY TVOUTPUT.START_TV_DT ASC ROWS BETWEEN 1 FOLLOWING\r\n\tAND\t1 FOLLOWING), DATE '3500-01-01') AS END_TV_DT,\r\nTVOUTPUT.ACTION_CODE,\r\nROW_NUMBER () OVER (PARTITION BY TVOUTPUT. BK_FUNCTIONAL_UNIT_ID ORDER BY TVOUTPUT.START_TV_DT ASC) AS RANK_INDEX,\r\n(\r\n\t\tCASE\r\n\t\t\tWHEN\tRANK_INDEX = 1\r\n\tAnd\tNFFU_OUT. BK_FUNCTIONAL_UNIT_ID IS NOT NULL \r\nTHEN 'U'\r\n\t\t\tELSE\t'I' END) As DML_TYPE\r\nFROM(\r\nSELECT\t\r\n\t\tBK_FUNCTIONAL_UNIT_ID,\r\n\t\tSTART_TV_DT,\r\n                FUNCTIONAL_UNIT_DESCR,\r\n                SK_FUNCTIONAL_UNIT_ID_INT,\r\n\t\tEDW_CREATE_DTM,\r\n\t\tACTION_CODE,\r\n\t\tEXCEPTION_TYPE,\r\n\t\tROW_NUMBER () OVER (PARTITION BY BK_FUNCTIONAL_UNIT_ID, FUNCTIONAL_UNIT_DESCR\r\n\t\tORDER\tBY EDW_CREATE_DTM DESC) AS ROW_NUM\r\n\tFROM(\r\nSELECT\t\r\n\t     SFU. FUNCTIONAL_UNIT_VALUE BK_FUNCTIONAL_UNIT_ID,\r\n     CAST(COALESCE(SFU.LAST_UPDATE_DATE,SFU.CREATE_DATETIME) AS DATE) START_TV_DT,\t     \r\n\tSFU. FUNCTIONAL_UNIT_DESC FUNCTIONAL_UNIT_DESCR,\r\n\t     SFU. FUNCTIONAL_UNIT_ID SK_FUNCTIONAL_UNIT_ID_INT,\r\n\t     SFU.CREATE_DATETIME EDW_CREATE_DTM,\r\n             SFU.ACTION_CODE ACTION_CODE,\r\n\t     'NE' EXCEPTION_TYPE\r\nFROM\t$$STGDB.ST_SI_FUNCTIONAL_UNIT  SFU\r\nUNION\tALL\r\nSELECT\r\n\t       NFFU. BK_FUNCTIONAL_UNIT_ID,\r\n\t       NFFU.START_TV_DT,\r\n\t       NFFU. FUNCTIONAL_UNIT_DESCR,\r\n                           NFFU. SK_FUNCTIONAL_UNIT_ID_INT,\r\n                           NFFU.EDW_UPDATE_DTM EDW_CREATE_DTM,\r\n                           'X' ACTION_CODE,\r\n\t       'NE' EXCEPTION_TYPE\r\nFROM\t$$FINLGLVWDB. N_FINANCIAL_FUNCTIONAL_UNIT_TV NFFU \r\nWHERE\tEXISTS (\r\nSELECT\t1 FROM $$STGDB.ST_SI_FUNCTIONAL_UNIT  SFU\r\n\t\t\tWHERE\tSFU.FUNCTIONAL_UNIT_VALUE =NFFU.BK_FUNCTIONAL_UNIT_ID)\r\n\t\tAND\tEND_TV_DT=16000101\r\n\t\t) TVINPUT\r\n\t\tQUALIFY\tROW_NUMBER () OVER (PARTITION BY TVINPUT. BK_FUNCTIONAL_UNIT_ID, TVINPUT.START_TV_DT\r\n\t\tORDER\tBY TVINPUT.EDW_CREATE_DTM DESC) = 1\r\n\t) TVOUTPUT\r\nLEFT JOIN $$FINLGLVWDB. N_FINANCIAL_FUNCTIONAL_UNIT_TV NFFU_OUT\r\n\tON\tTVOUTPUT. BK_FUNCTIONAL_UNIT_ID =NFFU_OUT. BK_FUNCTIONAL_UNIT_ID\r\n\tAnd\tNFFU_OUT.END_TV_DT =16000101\r\nWHERE\tTVOUTPUT.ROW_NUM = 1",
        "User Defined Join": "",
