      "attributes": {
        "Sql Query": "SELECT RANK () OVER (ORDER BY SOSHP.NODE_ID) + MAX_VAL PL_HIERARCHY_NODE_KEY,\r\nNODE_VALUE as  NODE_VALUE_CD, SOSHP.NODE_DESC PL_HIERARCHY_NODE_NM,NODE_ID SK_NODE_ID_INT FROM\r\n(SELECT NODE_ID,NODE_VALUE, NODE_DESC from $$STGDB.ST_ODS_SI_HIER_PUBLISHED WHERE HIERARCHY_TYPE='P/L') SOSHP,\r\n(SELECT COALESCE (MAX (PL_HIERARCHY_NODE_KEY),0) MAX_VAL from $$ETLVWDB.SM_PL_HIERARCHY_NODE) SPHN\r\nWHERE NOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.SM_PL_HIERARCHY_NODE SPHN \r\nWHERE NODE_ID=SPHN.SK_NODE_ID_INT)",
