      "attributes": {
        "Sql Query": "SELECT\r\n\tTVOUTPUT.PL_HIERARCHY_NODE_KEY,\r\n\tTVOUTPUT.START_TV_DT ,\r\n\tCOALESCE(MAX(TVOUTPUT.START_TV_DT - INTERVAL '1' DAY) OVER \r\n\t\t(PARTITION BY TVOUTPUT.PL_HIERARCHY_NODE_KEY\r\n\t\tORDER\tBY TVOUTPUT.START_TV_DT ROWS BETWEEN 1\r\n\t\tFOLLOWING\r\n\t\tAND\t1 FOLLOWING), DATE '3500-01-01') AS END_TV_DT,\r\n\tTVOUTPUT.NODE_TYPE,\r\n\tTVOUTPUT.NODE_VALUE_CD, \r\n\tTVOUTPUT.PARENT_PL_HIER_NODE_KEY,\r\n\tTVOUTPUT.PL_HIER_NODE_LEVEL_NUMBER_INT,\r\n\tTVOUTPUT.PL_HIERARCHY_NODE_NM,\r\n\tTVOUTPUT.NODE_ID_INT,\r\n\tTVOUTPUT.ACTION_CODE,\r\n\tROW_NUMBER() OVER(PARTITION BY TVOUTPUT.PL_HIERARCHY_NODE_KEY\r\n\tORDER\tBY TVOUTPUT.START_TV_DT ASC)\r\n\t\tAS RANK_INDEX,\r\n\t(\r\n\t\tCASE\r\n\t\t\tWHEN\tRANK_INDEX = 1\r\n\t\t\tAND\tNPHNT_OUT.PL_HIERARCHY_NODE_KEY IS NOT NULL THEN 'U'\r\n\t\t\tELSE\t'I' END) \r\n\t\tAS DML_TYPE\r\nFROM\r\n(\r\n\tSELECT\t\r\n\t\tPL_HIERARCHY_NODE_KEY,\r\n\t\tSTART_TV_DT,\r\n\t\tNODE_TYPE,\r\n\t\tNODE_VALUE_CD,\r\n\t\tPARENT_PL_HIER_NODE_KEY,\r\n\t\tPL_HIER_NODE_LEVEL_NUMBER_INT,\r\n\t\tPL_HIERARCHY_NODE_NM,\r\n\t\tNODE_ID_INT,\r\n\t\tEDW_CREATE_DTM,\r\n\t\tACTION_CODE,\r\n\t\tEXCEPTION_TYPE,\r\n\t\tROW_NUMBER () OVER (PARTITION BY PL_HIERARCHY_NODE_KEY, NODE_TYPE,PL_HIERARCHY_NODE_NM, PARENT_PL_HIER_NODE_KEY,PL_HIER_NODE_LEVEL_NUMBER_INT\r\n\t\tORDER\tBY EDW_CREATE_DTM DESC) AS ROW_NUM\r\n\tFROM\r\n\t(\r\n\t\tSELECT\t\r\n\t\t\t     SPLHN.PL_HIERARCHY_NODE_KEY,\r\n\t\t\t     CAST(CURRENT_TIMESTAMP(0) AS DATE) START_TV_DT,\r\n\t\t\t\t CASE\r\n\t\t\t\t\tWHEN\tSOSHP.NODE_VALUE ='450'\r\n\t\t\t\t\tAND\t\tSOSHP.NODE_TYPE='P' THEN 'ROOT'\r\n\t\t\t\t\tWHEN\tSOSHP.NODE_TYPE='D' THEN 'LEAF'\r\n\t\t\t\t\tELSE\t'MIDDLE'\r\n\t\t\t\t END\t AS NODE_TYPE,\r\n\t\t\t     SOSHP.NODE_VALUE AS NODE_VALUE_CD,\r\n\t\t\t     SMPARENT.PL_HIERARCHY_NODE_KEY AS PARENT_PL_HIER_NODE_KEY,\r\n\t\t\t     SOSHPP.LEVEL_NO AS PL_HIER_NODE_LEVEL_NUMBER_INT,\r\n\t\t\t     SOSHP.NODE_DESC    PL_HIERARCHY_NODE_NM ,\r\n\t\t\t     SOSHP.NODE_ID NODE_ID_INT,\r\n\t\t\t     CURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\n\t\t\t     'I' ACTION_CODE,\r\n\t\t\t     'NE' EXCEPTION_TYPE\r\n\t\tFROM\t$$ETLVWDB.EL_ODS_SI_HIER_PUBLISHED SOSHP \r\n\t           ,$$ETLVWDB.SM_PL_HIERARCHY_NODE  SPLHN\r\n\t\t       ,(SELECT\tSI.NODE_ID,SI.NODE_VALUE,SI.NODE_DESC, SINODE.PL_HIERARCHY_NODE_KEY\r\n\t\t\t\t  FROM  $$STGDB.WI_ODS_SI_HIER_PUBLISHED_PL SI,\r\n\t\t\t\t\t\t$$ETLVWDB.SM_PL_HIERARCHY_NODE SINODE\r\n\t\t\t\t  WHERE  SI.NODE_ID= SINODE.SK_NODE_ID_INT) SMPARENT\r\n\t\t    \t,$$STGDB.WI_ODS_SI_HIER_PUBLISHED_PL SOSHPP\r\n\t\tWHERE\t\t\r\n\t\t\t\tSOSHP.NODE_ID = SPLHN.SK_NODE_ID_INT\r\n\t\t\t\tAND\tSOSHP.PARENT_NODE_ID = SMPARENT.NODE_ID\r\n\t\t\t\tAND\tSOSHP.NODE_ID = SOSHPP.NODE_ID\r\n\t\t\t\tAND\tSOSHP.HIERARCHY_TYPE='P/L'\r\n\r\nUNION ALL\r\n\t\tSELECT\t\r\n\t\t\t     SPLHN.PL_HIERARCHY_NODE_KEY,\r\n\t\t\t     CAST(CURRENT_TIMESTAMP(0) AS DATE) START_TV_DT,\r\n\t\t\t     CASE\r\n\t\t\t\t\tWHEN\tSOSHP.NODE_VALUE ='450'\r\n\t\t\t\t\tAND\t\tSOSHP.NODE_TYPE='P' THEN 'ROOT'\r\n\t\t\t\t\tWHEN\tSOSHP.NODE_TYPE='D' THEN 'LEAF'\r\n\t\t\t\t\tELSE\t'MIDDLE'\r\n\t\t\t\t\tEND\t AS NODE_TYPE,\r\n\t\t\t     SOSHP.NODE_VALUE AS NODE_VALUE_CD,\r\n\t\t\t     NULL AS PARENT_PL_HIER_NODE_KEY,\r\n\t\t\t     SOSHPP.LEVEL_NO AS PL_HIER_NODE_LEVEL_NUMBER_INT,\r\n\t\t\t     SOSHP.NODE_DESC    PL_HIERARCHY_NODE_NM ,\r\n\t\t\t     SOSHP.NODE_ID NODE_ID_INT,\r\n\t\t\t     CURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\n\t\t\t     'I' ACTION_CODE,\r\n\t\t\t     'NE' EXCEPTION_TYPE\r\n\t\tFROM  $$ETLVWDB.EL_ODS_SI_HIER_PUBLISHED SOSHP \r\n\t         ,$$ETLVWDB.SM_PL_HIERARCHY_NODE  SPLHN\r\n\t\t     ,$$STGDB.WI_ODS_SI_HIER_PUBLISHED_PL SOSHPP\r\n\t\tWHERE\t\t\r\n\t\t      SOSHP.NODE_ID = SPLHN.SK_NODE_ID_INT\r\n\t\t\t\tAND\tSOSHP.NODE_ID = SOSHPP.NODE_ID\r\n\t\t\t\tAND\tSOSHP.HIERARCHY_TYPE='P/L'\r\n\t\t\t\tAND SOSHP.NODE_VALUE = '450'\r\n\t\r\n UNION\tALL\r\n\t\tSELECT\t\r\n\t\t\t     NPHNT.PL_HIERARCHY_NODE_KEY,\r\n\t\t\t     NPHNT.START_TV_DT,\r\n\t\t\t     NPHNT.NODE_TYPE,\r\n\t\t\t     NPHNT.NODE_VALUE_CD,\r\n\t\t\t     NPHNT.PARENT_PL_HIER_NODE_KEY,\r\n\t\t\t     NPHNT.PL_HIER_NODE_LEVEL_NUMBER_INT,\r\n\t\t\t     NPHNT.PL_HIERARCHY_NODE_NM,\r\n\t\t\t     NPHNT.NODE_ID_INT,\r\n\t\t\t     NPHNT.EDW_UPDATE_DTM EDW_CREATE_DTM,\r\n\t\t\t     'X' ACTION_CODE,\r\n\t\t\t     'NE' EXCEPTION_TYPE\r\n\t\tFROM\t$$FINLGLVWDB.N_PL_HIERARCHY_NODE_TV  NPHNT \r\n\t    WHERE \tEND_TV_DT =16000101\r\n\t\t\t\t\tAND (NPHNT.NODE_ID_INT)\r\n\t\t\t\t\tIN ( SELECT SOSHP.NODE_ID FROM \r\n\t\t\t\t\t$$ETLVWDB.EL_ODS_SI_HIER_PUBLISHED SOSHP \r\n\t\t\t\t\tWHERE SOSHP.HIERARCHY_TYPE='P/L')\r\n\r\n\t)TVINPUT\r\n\tQUALIFY\tROW_NUMBER() OVER (PARTITION BY TVINPUT.PL_HIERARCHY_NODE_KEY,TVINPUT.START_TV_DT\r\n\tORDER\tBY TVINPUT.EDW_CREATE_DTM DESC) =1\t\r\n) TVOUTPUT\r\nLEFT JOIN $$FINLGLVWDB.N_PL_HIERARCHY_NODE_TV NPHNT_OUT\r\n\tON\tTVOUTPUT.PL_HIERARCHY_NODE_KEY = NPHNT_OUT.PL_HIERARCHY_NODE_KEY\r\n\tAND\tNPHNT_OUT.END_TV_DT =16000101\r\nWHERE\tTVOUTPUT.ROW_NUM = 1",
        "User Defined Join": "",
