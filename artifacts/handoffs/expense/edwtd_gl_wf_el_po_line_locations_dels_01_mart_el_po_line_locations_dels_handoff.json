      "attributes": {
        "Sql Query": "SELECT EPLLD.APPROVED_DATE,\r\nEPLLD.APPROVED_FLAG,\r\nEPLLD.CREATION_DATE,\r\nEPLLD.LAST_UPDATE_DATE,\r\nEPLLD.LINE_LOCATION_ID,\r\nEPLLD.ORG_ID,\r\nEPLLD.PO_HEADER_ID,\r\nEPLLD.PO_LINE_ID,\r\nEPLLD.GES_DELETE_DATE,\r\nEPLLD.GLOBAL_NAME\r\nFROM\r\n(\r\nSELECT SMPLLAD.APPROVED_DATE,\r\nSMPLLAD.APPROVED_FLAG,\r\nSMPLLAD.CREATION_DATE,\r\nSMPLLAD.LAST_UPDATE_DATE,\r\nSMPLLAD.LINE_LOCATION_ID,\r\nSMPLLAD.ORG_ID,\r\nSMPLLAD.PO_HEADER_ID,\r\nSMPLLAD.PO_LINE_ID,\r\nSMPLLAD.GES_DELETE_DATE,\r\nSMPLLAD.GLOBAL_NAME\r\nFROM $$STGDB.ST_MF_PO_LINE_LOC_ALL_DELS SMPLLAD\r\nUNION ALL\r\nSELECT SCPLLAD.APPROVED_DATE,\r\nSCPLLAD.APPROVED_FLAG,\r\nSCPLLAD.CREATION_DATE,\r\nSCPLLAD.LAST_UPDATE_DATE,\r\nSCPLLAD.LINE_LOCATION_ID,\r\nSCPLLAD.ORG_ID,\r\nSCPLLAD.PO_HEADER_ID,\r\nSCPLLAD.PO_LINE_ID,\r\nSCPLLAD.GES_DELETE_DATE,\r\nSCPLLAD.GLOBAL_NAME\r\nFROM $$STGDB.ST_CG1_PO_LINE_LOC_AL_DELS SCPLLAD\r\n) EPLLD\r\nWHERE \r\n(EPLLD.LINE_LOCATION_ID,EPLLD.GLOBAL_NAME) NOT IN \r\n (SELECT ELPLLD.LINE_LOCATION_ID,ELPLLD.GLOBAL_NAME FROM $$ETLVWDB.EL_PO_LINE_LOCATIONS_DELS ELPLLD)",
