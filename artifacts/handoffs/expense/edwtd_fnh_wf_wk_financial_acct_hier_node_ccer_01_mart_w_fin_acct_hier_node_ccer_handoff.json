      "attributes": {
        "Sql Query": "SELECT\r\n\t\tTVOUTPUT.ACCOUNT_GROUP_ID,\r\n\t\tTVOUTPUT.START_TV_DT ,\r\n\t\tCOALESCE(MAX(TVOUTPUT.START_TV_DT - INTERVAL '1' DAY) OVER \r\n\t\t\t(PARTITION BY TVOUTPUT.ACCOUNT_GROUP_ID ORDER BY TVOUTPUT.START_TV_DT ROWS BETWEEN 1\r\n\t\t\tFOLLOWING AND 1 FOLLOWING), DATE '3500-01-01') AS END_TV_DT,\r\n\t\tTVOUTPUT.ACCT_NODE_LEVEL_NUMBER_INT,\r\n\t\tTVOUTPUT.NODE_TYPE, \r\n\t\tTVOUTPUT.PARENT_ACCOUNT_GROUP_ID,\r\n\t\tTVOUTPUT.ACTION_CODE,\r\n\t\tROW_NUMBER() OVER(PARTITION BY TVOUTPUT.ACCOUNT_GROUP_ID ORDER BY TVOUTPUT.START_TV_DT ASC)\r\n\t\t\tAS RANK_INDEX,\r\n\t\t(CASE WHEN RANK_INDEX = 1 AND NFAHNT_OUT.ACCOUNT_GROUP_ID IS NOT NULL THEN 'U' ELSE 'I' END) \r\n\t\t\tAS DML_TYPE,\r\n\t\tTVOUTPUT.ACCOUNT_GROUP_DESCR,  /* Added New column in Q1FY13 */\r\n\t\tTVOUTPUT.AH_REPORTING_SEQUENCE_NUM_INT /* Added New column in Q1FY13 */\r\n\tFROM\r\n\t(\r\n\t\tSELECT\t\r\n\t\t\tACCOUNT_GROUP_ID,\r\n\t\t\tSTART_TV_DT,\r\n\t\t\tACCT_NODE_LEVEL_NUMBER_INT,\r\n\t\t\tNODE_TYPE,\r\n\t\t\tPARENT_ACCOUNT_GROUP_ID,\r\n\t\t\tEDW_CREATE_DTM,\r\n\t\t\tACTION_CODE,\r\n\t\t\tEXCEPTION_TYPE,\r\n\t\t\tROW_NUMBER () OVER (PARTITION BY ACCOUNT_GROUP_ID,PARENT_ACCOUNT_GROUP_ID, NODE_TYPE,ACCT_NODE_LEVEL_NUMBER_INT,\r\nACCOUNT_GROUP_DESCR ORDER\tBY EDW_CREATE_DTM DESC) AS ROW_NUM,\r\n\t\t\tACCOUNT_GROUP_DESCR,\r\n\t\t\tAH_REPORTING_SEQUENCE_NUM_INT\r\n\t\tFROM(\r\n\t\r\n\t\tSELECT\r\n\t\t\t\tSTACCT.ACCOUNT_GROUP_ID1 AS ACCOUNT_GROUP_ID,\r\n\t\t\t\tSTACCT.START_TV_DT,\r\n\t\t\t\tSTACCT.ACCT_NODE_LEVEL_NUMBER_INT,\r\n\t\t\t\tSTACCT.NODE_TYPE,\r\n\t\t\t\tSTACCT.PARENT_ACCOUNT_GROUP_ID,\r\n\t\t\t\tSTACCT.EDW_CREATE_DTM,\r\n\t\t\t\t'I' AS ACTION_CODE,\r\n\t\t\t\t'NE' AS EXCEPTION_TYPE,\r\n\t\t\t\tACCOUNT_GROUP_DESCR,\r\n\t\t\t\tAH_REPORTING_SEQUENCE_NUM_INT\r\n\t\t\tFROM\r\n\t\t\t(\r\n\t\t\t\tSELECT \r\n\t\t\t\t\tST.CHILD_ACCOUNT  AS ACCOUNT_GROUP_ID1\r\n\t\t\t\t\t,case when  ST.PARENT_ACCOUNT is null then 'NO PARENT' \r\n\t\t\t\t\t\t\t\telse ST.PARENT_ACCOUNT  end as PARENT_ACCOUNT_GROUP_ID\r\n\t\t\t\t\t,Case when ST.PARENT_ACCOUNT is null then 'ROOT' \r\n\t\t\t\t\t\t\t\twhen ST_PARENT1 .PARENT_ACCOUNT  is null then 'LEAF' \r\n\t\t\t\t\t\t\t\telse 'MIDDLE' end as   NODE_TYPE\r\n\t\t\t\t\t,WI_LEVEL.LEVEL_NO as  ACCT_NODE_LEVEL_NUMBER_INT\r\n\t\t\t\t\t,CURRENT_DATE AS START_TV_DT\r\n\t\t\t\t\t,CAST(CURRENT_TIMESTAMP(0) AS TIMESTAMP(0)) AS EDW_CREATE_DTM\r\n\t\t\t\t\t,ST.CHILD_ACCOUNT_DESC as ACCOUNT_GROUP_DESCR\r\n\t\t\t\t\t,coalesce( ST.SEQ_NO,99999) as AH_REPORTING_SEQUENCE_NUM_INT    \r\n\t\t\t\tFROM \r\n\t\t\t\t\t$$STGDB.ST_N_FINANCIAL_ACCOUNT_PC_HIER ST\r\n\t\t\t\tInner Join  $$STGDB.WI_CCER_ACCOUNT_HIE_LEVEL WI_LEVEL\r\n\t\t\t\t\ton WI_LEVEL.CHILD_ACCOUNT=ST.CHILD_ACCOUNT\r\n\t\t\t\t\tand  WI_LEVEL.NODE_TYPE in ('ROOT' , 'MIDDLE' )  /* to eliminate Leaf ,Account records */\r\n\t\t\t\tLeft OUTER Join \r\n\t\t\t\t\t\t(Select distinct ST1.PARENT_ACCOUNT \r\n\t\t\t\t\t\t\tfrom $$STGDB.ST_N_FINANCIAL_ACCOUNT_PC_HIER ST1,\r\n\t\t\t\t\t\t\t\t\t$$STGDB.WI_CCER_ACCOUNT_HIE_LEVEL WI_LEVEL\r\n\t\t\t\t\t\t\twhere  WI_LEVEL.CHILD_ACCOUNT=ST1.CHILD_ACCOUNT\r\n\t\t\t\t\t\t\tand  WI_LEVEL.NODE_TYPE in ('ROOT' , 'MIDDLE' )  \r\n\t\t\t\t\t\t) ST_PARENT1\r\n\t\t\t\t\t\ton ST.CHILD_ACCOUNT  = ST_PARENT1.PARENT_ACCOUNT\t\r\n\t\t\t)STACCT\r\n\t\t\tUNION\tALL\r\n\t\t\tSELECT\t\r\n\t\t\t\t     NFAHNT.ACCOUNT_GROUP_ID,\r\n\t\t\t\t     NFAHNT.START_TV_DT,\r\n\t\t\t\t     NFAHNT.ACCT_NODE_LEVEL_NUMBER_INT,\r\n\t\t\t\t     NFAHNT.NODE_TYPE,\r\n\t\t\t\t     NFAHNT.PARENT_ACCOUNT_GROUP_ID,\r\n\t\t\t\t     NFAHNT.EDW_UPDATE_DTM AS EDW_CREATE_DTM,\r\n\t\t\t\t     'X' ACTION_CODE,\r\n\t\t\t\t     'NE' EXCEPTION_TYPE,\r\n\t\t\t\t\t NFAHNT.ACCOUNT_GROUP_DESCR,\r\n\t\t\t\t\t NFAHNT.AH_REPORTING_SEQUENCE_NUM_INT\r\n\t\t\tFROM\t$$CCERTEMPVWDB.N_FINANCIAL_ACCT_HIER_NODE_TV  NFAHNT \r\n\t\t\twhere END_TV_DT =16000101 \r\n\t\t)TVINPUT\r\n\t\tQUALIFY ROW_NUMBER() OVER (PARTITION BY TVINPUT.ACCOUNT_GROUP_ID,ACCT_NODE_LEVEL_NUMBER_INT,TVINPUT.START_TV_DT\r\n\t\tORDER BY TVINPUT.EDW_CREATE_DTM DESC) =1\t\r\n\t) TVOUTPUT\r\n\tLEFT JOIN $$CCERTEMPVWDB.N_FINANCIAL_ACCT_HIER_NODE_TV NFAHNT_OUT\r\n\t\tON\t TVOUTPUT.ACCOUNT_GROUP_ID = NFAHNT_OUT.ACCOUNT_GROUP_ID\r\n\t\tAND   TVOUTPUT.ACCT_NODE_LEVEL_NUMBER_INT = NFAHNT_OUT.ACCT_NODE_LEVEL_NUMBER_INT\r\n\t\tAND\tNFAHNT_OUT.END_TV_DT =16000101\r\n\tWHERE\tTVOUTPUT.ROW_NUM = 1",
        "User Defined Join": "",
