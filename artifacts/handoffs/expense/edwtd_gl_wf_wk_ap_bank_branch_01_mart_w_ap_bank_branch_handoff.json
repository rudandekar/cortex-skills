      "attributes": {
        "Sql Query": "SELECT \r\n   SABB.AP_BANK_BRANCH_KEY,\r\n   SMOABB.BANK_BRANCH_NAME,\r\n   SMOABB.BANK_NAME,\r\n   SMOABB.BANK_BRANCH_ID,\r\n   SMOABB.BANK_NUM,\r\n   NSSC.SOURCE_SYSTEM_CODE,\r\n  'N ' AS  SOURCE_DELETED_FLAG ,\r\n   SMOABB.ACTION_CODE,\r\n   'I' as DML_TYPE\r\nFROM\r\n( \r\n\tSELECT \r\n\t\tBANK_BRANCH_NAME,\r\n\t\tBANK_NAME,\r\n\t\tBANK_BRANCH_ID,\r\n\t\tBANK_NUM,\r\n\t\tGLOBAL_NAME,\r\n\t\tACTION_CODE\r\n\tFROM \r\n\t\t$$STGDB.ST_CG1_AP_BANK_BRANCHES SMABB /* Changed as part of SJProd Sunset */\r\n\t\tWHERE GLOBAL_NAME='CG'\r\n\tUNION ALL\r\n\tSELECT \r\n\t\tBRANCH.PARTY_NAME BANK_BRANCH_NAME,\r\n\t\tBANK.PARTY_NAME BANK_NAME,\r\n\t\tBRANCH.PARTY_ID BANK_BRANCH_ID,\r\n\t\tPF.BANK_OR_BRANCH_NUMBER  BANK_NUM,\r\n\t\tBRANCH.GLOBAL_NAME ,\r\n\t\tBRANCH.ACTION_CODE\r\n\tFROM\r\n\t\t\t$$STGDB.ST_MF_HZ_PARTIES_AP BRANCH,\r\n\t\t\t$$STGDB.ST_MF_HZ_PARTIES_AP BANK,\r\n\t\t\t$$ETLVWDB.EL_HZ_RELATIONSHIPS RS,\r\n\t\t\t(\tSELECT * from $$ETLVWDB.EL_HZ_ORG_PROFILES \r\n\t\t\t\tQUALIFY ROW_NUMBER() OVER (PARTITION BY PARTY_ID,GLOBAL_NAME  ORDER BY LAST_UPDATE_DATE DESC) =1 \r\n\t\t\t)PF\r\n\tWHERE\r\n\t\t\tBRANCH.PARTY_ID = RS.SUBJECT_ID AND\r\n\t\t\tBRANCH.GLOBAL_NAME=RS.GLOBAL_NAME AND \r\n\t\t\tBANK.PARTY_ID = RS.OBJECT_ID AND\r\n\t\t\tBANK.GLOBAL_NAME=RS.GLOBAL_NAME AND\r\n\t\t\tBRANCH.PARTY_ID = PF.PARTY_ID AND\r\n\t\t\tBRANCH.GLOBAL_NAME=PF.GLOBAL_NAME AND\r\n\t\t\tRELATIONSHIP_CODE = 'BRANCH_OF' AND \r\n\t\t\tDIRECTIONAL_FLAG = 'B' AND\r\n\t\t\tSUBJECT_TYPE = 'ORGANIZATION' AND\r\n\t\t\tBRANCH.GLOBAL_NAME='BE'\r\n\t/*\r\n\tBedrock2.0 change - removed OM flow\r\n\tUNION ALL\r\n\tSELECT \r\n\t\tBANK_BRANCH_NAME,\r\n\t\tBANK_NAME,\r\n\t\tBANK_BRANCH_ID,\r\n\t\tBANK_NUM,\r\n\t\tGLOBAL_NAME,\r\n\t\tACTION_CODE\r\n\tFROM $$STGDB.ST_OM_AP_BANK_BRANCHES SOABB \r\n\t*/\r\n  )SMOABB\r\nINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC \r\n\t\tON (NSSC.GLOBAL_NAME = SMOABB.GLOBAL_NAME )\r\nINNER JOIN $$TRANSLATIONDB.SM_AP_BANK_BRANCH SABB\r\n                ON (SABB.SK_BANK_BRANCH_ID_INT=SMOABB.BANK_BRANCH_ID \r\n\t\t     AND SABB.SS_CD = NSSC.SOURCE_SYSTEM_CODE)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
