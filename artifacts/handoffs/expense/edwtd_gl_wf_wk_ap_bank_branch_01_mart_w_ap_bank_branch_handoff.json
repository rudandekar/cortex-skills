        "Sql Query": "SELECT   RANK () OVER (ORDER BY SMOAB.BANK_BRANCH_ID,SMOAB.SOURCE_SYSTEM_CODE) + MAX_VAL AP_BANK_BRANCH_KEY,\r\n       SMOAB.BANK_BRANCH_ID, SMOAB.SOURCE_SYSTEM_CODE\r\nFROM \r\n(\tSELECT SINT.BANK_BRANCH_ID, NSSC.SOURCE_SYSTEM_CODE\r\n    FROM \r\n\t(\tSELECT BANK_BRANCH_ID, GLOBAL_NAME FROM $$STGDB.ST_CG1_AP_BANK_BRANCHES WHERE GLOBAL_NAME='CG' /* Changed as part of SJProd Sunset */\r\n\t\tUNION ALL\r\n        SELECT BRANCH.PARTY_ID BANK_BRANCH_ID, BRANCH.GLOBAL_NAME\r\n\t\tFROM\t\t$$STGDB.ST_MF_HZ_PARTIES_AP BRANCH,\r\n\t\t\t\t\t$$ETLVWDB.EL_HZ_RELATIONSHIPS RS\r\n\t\tWHERE\r\n\t\t\t\t\tBRANCH.PARTY_ID = RS.SUBJECT_ID AND\r\n\t\t\t\t\tBRANCH.GLOBAL_NAME=RS.GLOBAL_NAME AND \r\n\t\t\t\t\tRELATIONSHIP_CODE = 'BRANCH_OF' AND \r\n\t\t\t\t\tDIRECTIONAL_FLAG = 'B' AND\r\n\t\t\t\t\tSUBJECT_TYPE = 'ORGANIZATION' AND\r\n\t\t\t\t\tBRANCH.GLOBAL_NAME='BE' \t\t\t\t\r\n        /*\r\n\t\tBedrock2.0 change - removed OM flow\r\n\t\tUNION ALL\r\n\t\tSELECT BANK_BRANCH_ID, GLOBAL_NAME \r\n\t\tFROM $$STGDB.ST_OM_AP_BANK_BRANCHES\r\n\t\t*/\r\n\t) SINT,           \r\n\t$$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\n\tWHERE NSSC.GLOBAL_NAME = SINT.GLOBAL_NAME\r\n\t\t\r\n) SMOAB,\r\n       (\tSELECT COALESCE (MAX (AP_BANK_BRANCH_KEY), 0) MAX_VAL\r\n\t\t\tFROM $$TRANSLATIONDB.SM_AP_BANK_BRANCH\r\n\t\t) SMAB\r\n WHERE NOT EXISTS (\r\n          SELECT 1\r\n            FROM $$TRANSLATIONDB.SM_AP_BANK_BRANCH SABB\r\n           WHERE SABB.SK_BANK_BRANCH_ID_INT = SMOAB.BANK_BRANCH_ID\r\n             AND SABB.SS_CD = SMOAB.SOURCE_SYSTEM_CODE)",
