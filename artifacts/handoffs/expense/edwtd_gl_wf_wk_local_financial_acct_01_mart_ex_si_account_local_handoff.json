      "attributes": {
        "Sql Query": "SELECT \r\n\t\tSSAL.BATCH_ID,\r\n\t\tSSAL.ACCOUNT_VALUE,\r\n\t\tSSAL.SI_FLEX_STRUCT_ID,\r\n\t\tSSAL.ENABLED_FLAG,\r\n\t\tSSAL.RECLASS_ACCOUNT_VALUE,\r\n\t\tSSAL.END_DATE,\r\n\t\tSSAL.CREATE_DATETIME,\r\n\t\tSSAL.ACTION_CODE\r\nFROM\r\n        $$STGDB.ST_SI_ACCOUNT_LOCAL SSAL\r\nWHERE   (\r\n\t\tNOT EXISTS\r\n\t\t\t(SELECT 1 \r\n\t\t\tFROM $$FINLGLVWDB.N_FIN_ACCT_LOCALITY_TV NFAL\r\n\t\t\tWHERE SSAL.SI_FLEX_STRUCT_ID = NFAL.SK_SI_FLEX_STRUCT_ID_INT)\r\n\t\tOR\tNOT EXISTS\r\n\t\t\t(SELECT 1\tFROM $$FINLGLVWDB.N_FINANCIAL_ACCOUNT_TV NFA \r\n\t\t\tWHERE SSAL.ACCOUNT_VALUE = NFA.BK_FINANCIAL_ACCOUNT_CODE)\r\n\t\tOR \t(NOT EXISTS \r\n\t\t\t    (SELECT 1 \tFROM $$FINLGLVWDB.N_FINANCIAL_ACCOUNT_TV   NFAT\r\n\t\t\t\tWHERE NFAT.BK_FINANCIAL_ACCOUNT_CODE = SSAL.RECLASS_ACCOUNT_VALUE)\r\n\t\t\t\tAND SSAL.RECLASS_ACCOUNT_VALUE IS NOT NULL)\r\n\t\t)",
