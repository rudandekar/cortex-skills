      "attributes": {
        "Sql Query": "SELECT\tCAST(TVOUTPUT.START_TV_DATE AS DATE) START_TV_DATE,\r\n\tCOALESCE (MAX (CAST (TVOUTPUT. START_TV_DATE AS DATE) - INTERVAL '1' DAY) \r\n\tOVER (PARTITION BY TVOUTPUT.BK_FIN_ACCT_LOCALITY_INT,TVOUTPUT.BK_FINANCIAL_ACCOUNT_CODE\r\n\tORDER\tBY TVOUTPUT.START_TV_DATE ASC ROWS BETWEEN 1 FOLLOWING\r\n\tAND\t1 FOLLOWING), DATE '3500-01-01') AS END_TV_DATE,\r\n\tTVOUTPUT.BK_FIN_ACCT_LOCALITY_INT,\r\n\tTVOUTPUT.RU_BK_RCLS_FIN_ACCT_LCLTY_INT,\r\n\tTVOUTPUT.BK_FINANCIAL_ACCOUNT_CODE,\r\n\tTVOUTPUT.RU_BK_RCLS_FIN_ACCT_CODE,\r\n\tTVOUTPUT.FIN_LOCAL_ACCT_ENABLED_FLAG,\r\n\tTVOUTPUT.FIN_LOCAL_ACCT_END_DATE,\r\n\tTVOUTPUT.RECLASS_ROLE,\r\n\tTVOUTPUT.SK_ACCOUNT_VALUE_CODE,\r\n     \tTVOUTPUT.ACTION_CODE,\r\n\tROW_NUMBER () OVER (PARTITION BY TVOUTPUT.BK_FIN_ACCT_LOCALITY_INT,\r\n\t\t\t\t\t TVOUTPUT.BK_FINANCIAL_ACCOUNT_CODE \r\n\tORDER\tBY TVOUTPUT.START_TV_DATE ASC) AS RANK_INDEX,\r\n\t(CASE WHEN RANK_INDEX = 1 And NLFAT.BK_FIN_ACCT_LOCALITY_INT IS NOT NULL THEN 'U' ELSE 'I' END) As DML_TYPE\r\nFROM\t\r\n\t(\r\n\tSELECT\tSTART_TV_DATE,\r\n\t\tBK_FIN_ACCT_LOCALITY_INT,\r\n\t\tRU_BK_RCLS_FIN_ACCT_LCLTY_INT,\r\n\t\tBK_FINANCIAL_ACCOUNT_CODE,\r\n\t\tRU_BK_RCLS_FIN_ACCT_CODE,\r\n\t\tFIN_LOCAL_ACCT_ENABLED_FLAG,\r\n\t\tFIN_LOCAL_ACCT_END_DATE,\r\n\t\tRECLASS_ROLE,\r\n\t\tSK_ACCOUNT_VALUE_CODE,\r\n\t     \tACTION_CODE,\r\n\t\tROW_NUMBER () OVER (PARTITION BY BK_FIN_ACCT_LOCALITY_INT,\r\n\t\t\t\t\t\t RU_BK_RCLS_FIN_ACCT_LCLTY_INT,\r\n\t\t\t\t\t\t BK_FINANCIAL_ACCOUNT_CODE,\r\n\t\t\t\t\t\t RU_BK_RCLS_FIN_ACCT_CODE,\r\n\t\t\t\t\t\t FIN_LOCAL_ACCT_ENABLED_FLAG,\r\n\t\t\t\t\t\t FIN_LOCAL_ACCT_END_DATE\r\n\t\tORDER\tBY EDW_CREATE_DATETIME  DESC) AS ROW_NUM\r\n\tFROM\t\r\n\t\t(\r\n\t\tSELECT \r\n\t\t\tMFOM_ACCT.START_TV_DATE,\r\n\t\t\tMFOM_ACCT.END_TV_DATE,\r\n\t\t\tMFOM_ACCT.BK_FIN_ACCT_LOCALITY_INT,\r\n\t\t\tMFOM_ACCT. RU_BK_RCLS_FIN_ACCT_LCLTY_INT,\r\n\t\t\tMFOM_ACCT.BK_FINANCIAL_ACCOUNT_CODE,\r\n\t\t\tMFOM_ACCT. RU_BK_RCLS_FIN_ACCT_CODE,\t\r\n\t\t\tMFOM_ACCT.FIN_LOCAL_ACCT_ENABLED_FLAG,\r\n\t\t\tMFOM_ACCT.FIN_LOCAL_ACCT_END_DATE,\r\n\t\t\tMFOM_ACCT.RECLASS_ROLE,\r\n\t\t\tMFOM_ACCT. SK_ACCOUNT_VALUE_CODE,\r\n\t\t\tMFOM_ACCT. EDW_CREATE_DATETIME,\r\n\t\t\tMFOM_ACCT. ACTION_CODE\r\n\t\tFROM\t\r\n\t\t\t(\r\n\t\t\tSELECT\r\n\t\t\t\tCAST(SSAL.CREATE_DATETIME AS DATE) START_TV_DATE,\r\n\t\t\t\tCAST(SSAL.CREATE_DATETIME AS DATE) END_TV_DATE,\r\n\t\t\t\tNFAL.BK_FIN_ACCT_LOCALITY_INT BK_FIN_ACCT_LOCALITY_INT,\r\n\t\t\t\tNFAL.BK_FIN_ACCT_LOCALITY_INT RU_BK_RCLS_FIN_ACCT_LCLTY_INT,\r\n\t\t\t\tSSAL.ACCOUNT_VALUE BK_FINANCIAL_ACCOUNT_CODE,\r\n\t\t\t\tSSAL.RECLASS_ACCOUNT_VALUE RU_BK_RCLS_FIN_ACCT_CODE,\t\r\n\t\t\t\tSSAL.ENABLED_FLAG FIN_LOCAL_ACCT_ENABLED_FLAG,\r\n\t\t\t\tCAST(SSAL.END_DATE AS DATE) FIN_LOCAL_ACCT_END_DATE,\r\n\t\t\t\t(CASE WHEN SSAL.RECLASS_ACCOUNT_VALUE IS NULL THEN 'N' ELSE 'Y' END) RECLASS_ROLE,\r\n\t\t\t\tSSAL.ACCOUNT_VALUE SK_ACCOUNT_VALUE_CODE,\r\n\t\t\t\tSSAL.CREATE_DATETIME EDW_CREATE_DATETIME,\r\n\t\t\t\tSSAL.ACTION_CODE ACTION_CODE\r\n\t\t\tFROM\t$$STGDB.ST_SI_ACCOUNT_LOCAL SSAL, \r\n\t\t\t\t$$FINLGLVWDB.N_FIN_ACCT_LOCALITY_TV NFAL,\r\n\t\t\t\t$$FINLGLVWDB.N_FINANCIAL_ACCOUNT_TV NFA\r\n\t\t\tWHERE SSAL.SI_FLEX_STRUCT_ID = NFAL.SK_SI_FLEX_STRUCT_ID_INT\r\n\t\t\t\t\tAND\tSSAL.ACCOUNT_VALUE = NFA.BK_FINANCIAL_ACCOUNT_CODE\r\n\t\t\t\t\tAND\tNFA.END_TV_DATE=16000101\r\n\t\t\t\t\tAND\tNFAL.END_TV_DATE=16000101\r\n\t\t\tUNION\tALL\r\n\t\t\tSELECT\t\r\n\t\t\t\tCAST(EXSAL.CREATE_DATETIME AS DATE) START_TV_DATE,\r\n\t\t\t\tCAST(EXSAL.CREATE_DATETIME AS DATE) END_TV_DATE,\r\n\t\t\t\tNFAL.BK_FIN_ACCT_LOCALITY_INT BK_FIN_ACCT_LOCALITY_INT,\r\n\t\t\t\tNFAL.BK_FIN_ACCT_LOCALITY_INT RU_BK_RCLS_FIN_ACCT_LCLTY_INT,\r\n\t\t\t\tEXSAL.ACCOUNT_VALUE BK_FINANCIAL_ACCOUNT_CODE,\r\n\t\t\t\tEXSAL.RECLASS_ACCOUNT_VALUE RU_BK_RCLS_FIN_ACCT_CODE,\t\r\n\t\t\t\tEXSAL.ENABLED_FLAG FIN_LOCAL_ACCT_ENABLED_FLAG,\r\n\t\t\t\tCAST(EXSAL.END_DATE AS DATE) FIN_LOCAL_ACCT_END_DATE,\r\n\t\t\t\t(CASE WHEN EXSAL.RECLASS_ACCOUNT_VALUE IS NULL THEN 'N' ELSE 'Y' END) RECLASS_ROLE,\r\n\t\t\t\tEXSAL.ACCOUNT_VALUE SK_ACCOUNT_VALUE_CODE,\r\n\t\t\t\tEXSAL.CREATE_DATETIME EDW_CREATE_DATETIME,\r\n\t\t\t\tEXSAL.ACTION_CODE ACTION_CODE\r\n\t\t\tFROM\t$$EXCEPDB.EX_SI_ACCOUNT_LOCAL EXSAL, \r\n\t\t\t\t$$FINLGLVWDB.N_FIN_ACCT_LOCALITY_TV NFAL,\r\n\t\t\t\t$$FINLGLVWDB.N_FINANCIAL_ACCOUNT_TV NFA\r\n\t\t\tWHERE\tEXSAL.SI_FLEX_STRUCT_ID = NFAL.SK_SI_FLEX_STRUCT_ID_INT\r\n\t\t\t\tAND\tEXSAL.ACCOUNT_VALUE = NFA.BK_FINANCIAL_ACCOUNT_CODE\r\n\t\t\t\tAND\tNFA.END_TV_DATE=16000101\r\n\t\t\t\tAND\tNFAL.END_TV_DATE=16000101\r\n\t\t\t) MFOM_ACCT LEFT JOIN $$FINLGLVWDB.N_FINANCIAL_ACCOUNT_TV NFAT\r\n\t\t\tON MFOM_ACCT. RU_BK_RCLS_FIN_ACCT_CODE = NFAT.BK_FINANCIAL_ACCOUNT_CODE\r\n\t\t\tUNION\tALL\r\n\t\t\tSELECT\t\r\n\t\t\t\tNLFAT.START_TV_DATE,\r\n\t\t\t\tNLFAT.END_TV_DATE,\r\n\t\t\t\tNLFAT.BK_FIN_ACCT_LOCALITY_INT,\r\n\t\t\t\tNLFAT.RU_BK_RCLS_FIN_ACCT_LCLTY_INT,\r\n\t\t\t\tNLFAT.BK_FINANCIAL_ACCOUNT_CODE,\r\n\t\t\t\tNLFAT.RU_BK_RCLS_FIN_ACCT_CODE,\r\n\t\t\t\tNLFAT.FIN_LOCAL_ACCT_ENABLED_FLAG,\r\n\t\t\t\tNLFAT.FIN_LOCAL_ACCT_END_DATE,\r\n\t\t\t\tNLFAT.RECLASS_ROLE,\r\n\t\t\t\tNLFAT.SK_ACCOUNT_VALUE_CODE,\r\n\t\t\t\tNLFAT.EDW_UPDATE_DATETIME EDW_CREATE_DATETIME,\t\r\n\t\t\t\t'X' ACTION_CODE\r\n\t\t\tFROM\t$$FINLGLVWDB.N_LOCAL_FINANCIAL_ACCT_TV NLFAT,\r\n\t\t\t\t$$FINLGLVWDB.N_FIN_ACCT_LOCALITY_TV NFALTV\r\n\t\t\tWHERE\tNLFAT.BK_FIN_ACCT_LOCALITY_INT =NFALTV.BK_FIN_ACCT_LOCALITY_INT  \r\n\t\t\t  AND\t(NLFAT.BK_FINANCIAL_ACCOUNT_CODE, NFALTV.SK_SI_FLEX_STRUCT_ID_INT) IN\r\n\t\t\t\t\t(\r\n\t\t\t\t\tSELECT\tSSAL.ACCOUNT_VALUE,SSAL.SI_FLEX_STRUCT_ID FROM $$STGDB.ST_SI_ACCOUNT_LOCAL SSAL\r\n\t\t\t\t\tUNION\r\n\t\t\t\t\tSELECT\tEXSAL.ACCOUNT_VALUE,EXSAL.SI_FLEX_STRUCT_ID FROM $$EXCEPDB.EX_SI_ACCOUNT_LOCAL EXSAL\r\n\t\t\t\t\t)\r\n\t\t\tAND\tNLFAT.END_TV_DATE=16000101\r\n\t) TVINPUT\r\n\tQUALIFY\tROW_NUMBER () OVER (PARTITION BY TVINPUT.BK_FIN_ACCT_LOCALITY_INT,\r\n\t\t\t\t\t\t TVINPUT.BK_FINANCIAL_ACCOUNT_CODE,\r\n\t\t\t\t\t\t TVINPUT.START_TV_DATE\r\n\tORDER\tBY TVINPUT.EDW_CREATE_DATETIME DESC) = 1\r\n) TVOUTPUT\r\nLEFT JOIN $$FINLGLVWDB.N_LOCAL_FINANCIAL_ACCT_TV NLFAT\r\n\tON\tTVOUTPUT.BK_FIN_ACCT_LOCALITY_INT = NLFAT.BK_FIN_ACCT_LOCALITY_INT\r\n\tAND TVOUTPUT. BK_FINANCIAL_ACCOUNT_CODE=NLFAT. BK_FINANCIAL_ACCOUNT_CODE\r\n\tAnd\tNLFAT.END_TV_DATE =16000101\r\nWHERE\tTVOUTPUT.ROW_NUM = 1",
