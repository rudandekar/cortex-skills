      "attributes": {
        "Sql Query": "SELECT \r\n SMOMCBT1.SEGMENT1 BK_PURCHASING_ITEM_CATEGORY_ID,\r\n COALESCE(SMOMCBT1.DESCRIPTION,'UNKNOWN') ITEM_CATEGORY_NAME,\r\n COALESCE (SMOMCBT1.ATTRIBUTE2,'UNKNOWN') GPS_SPEND_CATEGORY_CD ,\r\n COALESCE (SMOMCBT1.ATTRIBUTE3,'UNKNOWN') GPS_SPEND_SUB_CATEGORY_CD     \r\n FROM \r\n (\r\n SELECT SEGMENT1, DESCRIPTION, ATTRIBUTE2, ATTRIBUTE3 FROM  $$STGDB.ST_MF_MTL_CATEGORIES_B_TL SMMCBT\r\n UNION ALL\r\n SELECT SEGMENT1, DESCRIPTION ,'UNKNOWN','UNKNOWN' FROM  $$STGDB.ST_CG1_MTL_CATEGORIES_B_TL SCMCBT\r\n ) SMOMCBT1\r\n WHERE SMOMCBT1.SEGMENT1 IN \r\n (\r\n SELECT SMOMCBTIN.SEGMENT1\r\n FROM (\r\n SELECT SMMCBT.SEGMENT1, DESCRIPTION FROM  $$STGDB.ST_MF_MTL_CATEGORIES_B_TL SMMCBT\r\n UNION ALL \r\n SELECT SCMCBT.SEGMENT1, DESCRIPTION FROM  $$STGDB.ST_CG1_MTL_CATEGORIES_B_TL SCMCBT\r\n ) SMOMCBTIN\r\n GROUP BY SMOMCBTIN.SEGMENT1\r\n HAVING COUNT(1) =1\r\n ) \r\n UNION ALL\r\n SELECT SMOMCBTIN.SEGMENT1 BK_PURCHASING_ITEM_CATEGORY_ID,\r\n 'UNKNOWN' ITEM_CATEGORY_NAME,\r\n COALESCE (SMOMCBTIN.ATTRIBUTE2,'UNKNOWN') GPS_SPEND_CATEGORY_CD ,\r\n COALESCE (SMOMCBTIN.ATTRIBUTE3,'UNKNOWN') GPS_SPEND_SUB_CATEGORY_CD \r\n FROM (\r\n SELECT SEGMENT1, DESCRIPTION ,ATTRIBUTE2, ATTRIBUTE3 FROM  $$STGDB.ST_MF_MTL_CATEGORIES_B_TL SMMCBT\r\n UNION ALL \r\n SELECT SEGMENT1, DESCRIPTION ,'UNKNOWN','UNKNOWN' FROM  $$STGDB.ST_CG1_MTL_CATEGORIES_B_TL SCMCBT\r\n ) SMOMCBTIN\r\n  WHERE SMOMCBTIN.SEGMENT1 IN \r\n (\r\n  SELECT SMOMCBTIN.SEGMENT1\r\n FROM (\r\n SELECT SMMCBT.SEGMENT1, DESCRIPTION   FROM  $$STGDB.ST_MF_MTL_CATEGORIES_B_TL SMMCBT\r\n UNION ALL \r\n SELECT SCMCBT.SEGMENT1, DESCRIPTION  FROM   $$STGDB.ST_CG1_MTL_CATEGORIES_B_TL SCMCBT\r\n ) SMOMCBTIN\r\n GROUP BY SMOMCBTIN.SEGMENT1\r\n HAVING COUNT(1) >1\r\n) GROUP BY 1,2,3,4",
