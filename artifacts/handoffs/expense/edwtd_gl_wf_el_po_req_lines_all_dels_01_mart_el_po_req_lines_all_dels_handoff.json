      "attributes": {
        "Sql Query": "SELECT \r\nEPRLAD.LINE_LOCATION_ID,              \r\nEPRLAD.LINE_NUM,                      \r\nEPRLAD.LINE_TYPE_ID,                  \r\nEPRLAD.ORG_ID,                        \r\nEPRLAD.REQUISITION_HEADER_ID,         \r\nEPRLAD.REQUISITION_LINE_ID,          \r\nEPRLAD.GES_DELETE_DATE,               \r\nEPRLAD.GLOBAL_NAME  \r\nFROM\r\n(SELECT \r\nSMPRLAD.LINE_LOCATION_ID,              \r\nSMPRLAD.LINE_NUM,                      \r\nSMPRLAD.LINE_TYPE_ID,                  \r\nSMPRLAD.ORG_ID,                        \r\nSMPRLAD.REQUISITION_HEADER_ID,         \r\nSMPRLAD.REQUISITION_LINE_ID,          \r\nSMPRLAD.GES_DELETE_DATE,               \r\nSMPRLAD.GLOBAL_NAME   \r\nFROM\r\n$$STGDB.ST_MF_PO_REQ_LINES_ALL_DELS SMPRLAD\r\nUNION ALL\r\nSELECT \r\nSCPRLD.LINE_LOCATION_ID,              \r\nSCPRLD.LINE_NUM,                      \r\nSCPRLD.LINE_TYPE_ID,                  \r\nSCPRLD.ORG_ID,                        \r\nSCPRLD.REQUISITION_HEADER_ID,         \r\nSCPRLD.REQUISITION_LINE_ID,          \r\nSCPRLD.GES_DELETE_DATE,               \r\nSCPRLD.GLOBAL_NAME   \r\nFROM\r\n$$STGDB.ST_CG1_PO_REQ_LINES_DELS  SCPRLD\r\n) EPRLAD\r\n WHERE (EPRLAD.REQUISITION_LINE_ID,EPRLAD.GLOBAL_NAME) NOT IN (SELECT  EPRLAD.REQUISITION_LINE_ID,EPRLAD.GLOBAL_NAME \r\nFROM $$ETLVWDB.EL_PO_REQ_LINES_ALL_DELS EPRLAD)",
