      "attributes": {
        "Sql Query": "SELECT REASON_ID, \r\nREASON_NAME,\r\n-1 AS LAST_UPDATE_LOGIN, \r\nREASON_TYPE, \r\nCAST(COALESCE(CAST(LAST_UPDATE_DATE AS VARCHAR(19)),CAST(CURRENT_TIMESTAMP(0) AS VARCHAR(19))) AS TIMESTAMP(0))\r\n AS LAST_UPDATE_DATE, \r\n'-1' AS LAST_UPDATED_BY, \r\nCAST(TO_DATE(SUBSTR(CREATION_DATE,1,10)) AS TIMESTAMP(0)) AS CREATION_DATE, \r\n'-1' AS CREATED_BY, \r\nCURRENT_TIMESTAMP(0) AS GES_UPDATE_DATE, \r\nCURRENT_TIMESTAMP(0) AS CREATE_DATETIME,  \r\nOFFSET_NUMBER, \r\nPARTITION_NUMBER, \r\nRECORD_COUNT \r\nFROM\r\n$$STGDB.PST_CLOUD_MTL_TRANSACTION_REAS",
