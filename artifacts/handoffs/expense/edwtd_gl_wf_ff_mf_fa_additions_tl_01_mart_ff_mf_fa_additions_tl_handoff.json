      "attributes": {
        "Sql Query": "SELECT\r\nMF_FA_ADDITIONS_TL.ASSET_ID,\r\nMF_FA_ADDITIONS_TL.CREATED_BY, \r\nMF_FA_ADDITIONS_TL.CREATION_DATE, \r\nreplace(replace(replace(MF_FA_ADDITIONS_TL.DESCRIPTION,chr(10),' '),chr(13),' ') ,chr(234),' ')DESCRIPTION , \r\nMF_FA_ADDITIONS_TL.GES_UPDATE_DATE, \r\nMF_FA_ADDITIONS_TL.GLOBAL_NAME, \r\nMF_FA_ADDITIONS_TL.LANGUAGE, \r\nMF_FA_ADDITIONS_TL.LAST_UPDATED_BY,\r\nMF_FA_ADDITIONS_TL.LAST_UPDATE_DATE, \r\nMF_FA_ADDITIONS_TL.LAST_UPDATE_LOGIN, \r\nMF_FA_ADDITIONS_TL.SOURCE_LANG \r\nFROM\r\n MF_FA_ADDITIONS_TL\r\n WHERE MF_FA_ADDITIONS_TL.GES_UPDATE_DATE>to_date('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS')\r\n AND MF_FA_ADDITIONS_TL.LANGUAGE = 'US'",
