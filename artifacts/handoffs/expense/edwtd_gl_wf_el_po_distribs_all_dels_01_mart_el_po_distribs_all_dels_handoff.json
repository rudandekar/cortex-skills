      "attributes": {
        "Sql Query": "SELECT ELPDAD.DELIVER_TO_LOCATION_ID,\r\n ELPDAD.DELIVER_TO_PERSON_ID,\r\n ELPDAD.ORG_ID,\r\n ELPDAD.PO_DISTRIBUTION_ID,\r\n ELPDAD.PO_HEADER_ID,\r\n ELPDAD.PO_LINE_ID,\r\n ELPDAD.SET_OF_BOOKS_ID,\r\n ELPDAD.SOURCE_DISTRIBUTION_ID,\r\n ELPDAD.GES_DELETE_DATE,\r\n ELPDAD.GLOBAL_NAME \r\nFROM\r\n(SELECT SMPDAD.DELIVER_TO_LOCATION_ID,\r\n SMPDAD.DELIVER_TO_PERSON_ID,\r\n SMPDAD.ORG_ID,\r\n SMPDAD.PO_DISTRIBUTION_ID,\r\n SMPDAD.PO_HEADER_ID,\r\n SMPDAD.PO_LINE_ID,\r\n SMPDAD.SET_OF_BOOKS_ID,\r\n SMPDAD.SOURCE_DISTRIBUTION_ID,\r\n SMPDAD.GES_DELETE_DATE,\r\n SMPDAD.GLOBAL_NAME \r\nFROM  $$STGDB.ST_MF_PO_DISTRIBS_ALL_DELS SMPDAD\r\nUNION ALL\r\nSELECT SCPDAD.DELIVER_TO_LOCATION_ID,\r\n SCPDAD.DELIVER_TO_PERSON_ID,\r\n SCPDAD.ORG_ID,\r\n SCPDAD.PO_DISTRIBUTION_ID,\r\n SCPDAD.PO_HEADER_ID,\r\n SCPDAD.PO_LINE_ID,\r\n SCPDAD.SET_OF_BOOKS_ID,\r\n SCPDAD.SOURCE_DISTRIBUTION_ID,\r\n SCPDAD.GES_DELETE_DATE,\r\n SCPDAD.GLOBAL_NAME \r\nFROM  $$STGDB.ST_CG1_PO_DISTRIB_ALL_DELS SCPDAD\r\n )ELPDAD\r\nWHERE (ELPDAD.PO_DISTRIBUTION_ID ,ELPDAD.GLOBAL_NAME) NOT IN (SELECT EPDAD.PO_DISTRIBUTION_ID ,EPDAD.GLOBAL_NAME FROM $$ETLVWDB.EL_PO_DISTRIBS_ALL_DELS EPDAD)",
