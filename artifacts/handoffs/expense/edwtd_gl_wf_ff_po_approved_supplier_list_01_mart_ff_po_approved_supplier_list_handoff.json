      "attributes": {
        "Sql Query": "SELECT \r\nPO_APPROVED_SUPPLIER_LIST.USING_ORGANIZATION_ID,\r\nPO_APPROVED_SUPPLIER_LIST.OWNING_ORGANIZATION_ID,\r\nPO_APPROVED_SUPPLIER_LIST.VENDOR_BUSINESS_TYPE,\r\nPO_APPROVED_SUPPLIER_LIST.VENDOR_ID,\r\nMMCB.SEGMENT1,\r\nPO_APPROVED_SUPPLIER_LIST.ATTRIBUTE2,\r\nPO_APPROVED_SUPPLIER_LIST.ATTRIBUTE3,\r\nPO_APPROVED_SUPPLIER_LIST.ATTRIBUTE4,\r\nCOALESCE (PO_APPROVED_SUPPLIER_LIST.DISABLE_FLAG , 'N') DISABLE_FLAG,\r\nCOALESCE (PO_APPROVED_SUPPLIER_LIST.VENDOR_SITE_ID, -999) VENDOR_SITE_ID,\r\nCOALESCE ( HOU.NAME, 'UNKNOWN') NAME,\r\nPO_APPROVED_SUPPLIER_LIST.CREATED_BY,\r\nPO_APPROVED_SUPPLIER_LIST.CREATION_DATE,\r\nPO_APPROVED_SUPPLIER_LIST.LAST_UPDATED_BY,\r\nPO_APPROVED_SUPPLIER_LIST.LAST_UPDATE_DATE\r\nFROM  CFN_PO_APPROVED_SUPPLIER_LIST  PO_APPROVED_SUPPLIER_LIST\r\nLEFT JOIN CFN_ORG_ORGZN_DEFINITIONS OU\r\nON PO_APPROVED_SUPPLIER_LIST.USING_ORGANIZATION_ID    = OU.ORGANIZATION_ID\r\nLEFT JOIN CFN_HR_OPERATING_UNITS    HOU\r\nON OU.OPERATING_UNIT = HOU.ORGANIZATION_ID\r\nLEFT JOIN \tMF_MTL_CATEGORIES_B MMCB\r\nON MMCB.CATEGORY_ID = PO_APPROVED_SUPPLIER_LIST.CATEGORY_ID\r\nAND MMCB.GLOBAL_NAME = 'BE'\r\nWHERE PO_APPROVED_SUPPLIER_LIST.LAST_UPDATE_DATE > TO_DATE('$$LastExtractDate','MM/DD/YYYYHH24:MI:SS')",
        "User Defined Join": "",
        "Source Filter": "",
