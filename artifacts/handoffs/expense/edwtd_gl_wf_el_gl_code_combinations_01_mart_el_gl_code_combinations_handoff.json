      "attributes": {
        "Sql Query": "SELECT\r\n\tMFOM_GLCC.CODE_COMBINATION_ID\r\n\t,MFOM_GLCC.GLOBAL_NAME\r\n\t,MFOM_GLCC.SEGMENT1\r\n\t,MFOM_GLCC.SEGMENT2\r\n\t,MFOM_GLCC.SEGMENT3\r\n\t,MFOM_GLCC.SEGMENT4\r\n\t,MFOM_GLCC.SEGMENT5\r\n\t,MFOM_GLCC.SEGMENT6\r\n\t,MFOM_GLCC.CHART_OF_ACCOUNTS_ID\r\n\t,MFOM_GLCC.ENABLED_FLAG\r\n\t,MFOM_GLCC.START_DATE_ACTIVE\r\n\t,MFOM_GLCC.END_DATE_ACTIVE\r\n\t,MFOM_GLCC.ACCOUNT_TYPE\r\n\t,MFOM_GLCC.PRESERVE_FLAG\r\n\t,MFOM_GLCC.CREATE_DATETIME\r\n\t,MFOM_GLCC.LAST_UPDATE_DATE\r\nFROM\r\n(\r\nSELECT\r\n\t CAST(MFGLCC.CODE_COMBINATION_ID AS BIGINT) AS CODE_COMBINATION_ID\r\n\t,MFGLCC.GLOBAL_NAME\r\n\t,MFGLCC.SEGMENT1\r\n\t,MFGLCC.SEGMENT2\r\n\t,MFGLCC.SEGMENT3\r\n\t,MFGLCC.SEGMENT4\r\n\t,MFGLCC.SEGMENT5\r\n\t,MFGLCC.SEGMENT6\r\n\t,MFGLCC.CHART_OF_ACCOUNTS_ID\r\n\t,MFGLCC.ENABLED_FLAG\r\n\t,MFGLCC.START_DATE_ACTIVE\r\n\t,MFGLCC.END_DATE_ACTIVE\r\n\t,MFGLCC.ACCOUNT_TYPE\r\n\t,MFGLCC.PRESERVE_FLAG\r\n\t,MFGLCC.CREATE_DATETIME\r\n\t,MFGLCC.LAST_UPDATE_DATE\r\nFROM\t$$STGDB.ST_MF_GL_CODE_COMBINATIONS MFGLCC\r\nUNION ALL\r\nSELECT\r\n\tCAST(OMGLCC.CODE_COMBINATION_ID AS BIGINT) AS CODE_COMBINATION_ID\r\n\t,OMGLCC.GLOBAL_NAME\r\n\t,OMGLCC.SEGMENT1\r\n\t,OMGLCC.SEGMENT2\r\n\t,OMGLCC.SEGMENT3\r\n\t,OMGLCC.SEGMENT4\r\n\t,OMGLCC.SEGMENT5\r\n\t,OMGLCC.SEGMENT6\r\n\t,OMGLCC.CHART_OF_ACCOUNTS_ID\r\n\t,OMGLCC.ENABLED_FLAG\r\n\t,OMGLCC.START_DATE_ACTIVE\r\n\t,OMGLCC.END_DATE_ACTIVE\r\n\t,OMGLCC.ACCOUNT_TYPE\r\n\t,OMGLCC.PRESERVE_FLAG\r\n\t,OMGLCC.CREATE_DATETIME\r\n\t,OMGLCC.LAST_UPDATE_DATE\r\nFROM\t$$STGDB.ST_OM_GL_CODE_COMBINATIONS OMGLCC\r\n\r\nUNION ALL\r\nSELECT\r\n\t CG1GLCC.CODE_COMBINATION_ID\r\n\t,CG1GLCC.GLOBAL_NAME\r\n\t,CG1GLCC.SEGMENT1\r\n\t,CG1GLCC.SEGMENT2\r\n\t,CG1GLCC.SEGMENT3\r\n\t,CG1GLCC.SEGMENT4\r\n\t,CG1GLCC.SEGMENT5\r\n\t,CG1GLCC.SEGMENT6\r\n\t,CG1GLCC.CHART_OF_ACCOUNTS_ID\r\n\t,CG1GLCC.ENABLED_FLAG\r\n\t,CG1GLCC.START_DATE_ACTIVE\r\n\t,CG1GLCC.END_DATE_ACTIVE\r\n\t,CG1GLCC.ACCOUNT_TYPE\r\n\t,CG1GLCC.PRESERVE_FLAG\r\n\t,CG1GLCC.CREATE_DATETIME\r\n\t,CG1GLCC.LAST_UPDATE_DATE\r\nFROM\t$$STGDB.ST_CG1_GL_CODE_COMBINATIONS CG1GLCC\r\n\r\n) MFOM_GLCC\r\nWHERE (\tMFOM_GLCC.CODE_COMBINATION_ID,MFOM_GLCC.GLOBAL_NAME) NOT IN\r\n\t(SELECT\tELGLCC.CODE_COMBINATION_ID,ELGLCC.GLOBAL_NAME FROM $$ETLVWDB.EL_GL_CODE_COMBINATIONS ELGLCC)",
