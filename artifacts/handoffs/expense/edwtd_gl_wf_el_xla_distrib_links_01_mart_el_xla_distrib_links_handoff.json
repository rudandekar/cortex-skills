      "attributes": {
        "Sql Query": "SELECT  \r\nELMXDL.REF_AE_HEADER_ID\t,\r\nELMXDL.TEMP_LINE_NUM \t,\r\nELMXDL.APPLICATION_ID\t,\r\nELMXDL.AE_HEADER_ID\t,\r\nELMXDL.AE_LINE_NUM\t,\r\nELMXDL.SOURCE_DISTRIBUTION_TYPE\t,\r\nELMXDL.SOURCE_DISTRIBUTION_ID_NUM_1\t,\r\nELMXDL.SOURCE_DISTRIBUTION_ID_NUM_2\t,\r\nELMXDL.UPG_BATCH_ID\t,\r\nELMXDL.GLOBAL_NAME\t,\r\nELMXDL.GES_UPDATE_DATE\t,\r\nELMXDL.CREATE_DATETIME\t,\r\nELMXDL.ROUNDING_CLASS_CODE,\r\nELMXDL.SOURCE_DISTRIBUTION_ID_NUM_5\r\nFROM\r\n(\r\nSELECT \r\nSMXDL.REF_AE_HEADER_ID\t,\r\nSMXDL.TEMP_LINE_NUM \t,\r\nSMXDL.APPLICATION_ID\t,\r\nSMXDL.AE_HEADER_ID\t,\r\nSMXDL.AE_LINE_NUM\t,\r\nSMXDL.SOURCE_DISTRIBUTION_TYPE\t,\r\nSMXDL.SOURCE_DISTRIBUTION_ID_NUM_1\t,\r\nSMXDL.SOURCE_DISTRIBUTION_ID_NUM_2\t,\r\nSMXDL.UPG_BATCH_ID\t,\r\nSMXDL.GLOBAL_NAME\t,\r\nSMXDL.GES_UPDATE_DATE\t,\r\nSMXDL.CREATE_DATETIME,\r\nSMXDL.ROUNDING_CLASS_CODE,\r\nSMXDL.SOURCE_DISTRIBUTION_ID_NUM_5\t\r\nFROM\r\n$$STGDB.ST_MF_XLA_DISTRIB_LINKS  SMXDL\r\n\r\nUNION \r\nSELECT \r\nSCXDL.REF_AE_HEADER_ID\t,\r\nSCXDL.TEMP_LINE_NUM \t,\r\nSCXDL.APPLICATION_ID\t,\r\nSCXDL.AE_HEADER_ID\t,\r\nSCXDL.AE_LINE_NUM\t,\r\nSCXDL.SOURCE_DISTRIBUTION_TYPE\t,\r\nSCXDL.SOURCE_DISTRIBUTION_ID_NUM_1\t,\r\nSCXDL.SOURCE_DISTRIBUTION_ID_NUM_2\t,\r\nSCXDL.UPG_BATCH_ID\t,\r\nSCXDL.GLOBAL_NAME\t,\r\nSCXDL.GES_UPDATE_DATE\t,\r\nSCXDL.CREATE_DATETIME,\r\nSCXDL.ROUNDING_CLASS_CODE,\r\nSCXDL.SOURCE_DISTRIBUTION_ID_NUM_5\t\r\nFROM\r\n$$STGDB.ST_CG1_XLA_DISTRIBUTION_LINK  SCXDL\r\n) ELMXDL\r\nWHERE  \r\n(ELMXDL.REF_AE_HEADER_ID, ELMXDL.TEMP_LINE_NUM,ELMXDL.AE_HEADER_ID,ELMXDL.APPLICATION_ID /* AE_LINE_NUM */,ELMXDL.GLOBAL_NAME)\r\nNOT IN \r\n( SELECT  EMXDL.REF_AE_HEADER_ID, EMXDL.TEMP_LINE_NUM,EMXDL.AE_HEADER_ID,EMXDL.APPLICATION_ID /*AE_LINE_NUM */,EMXDL.GLOBAL_NAME FROM  \r\n$$ETLVWDB.EL_XLA_DISTRIB_LINKS  EMXDL)",
