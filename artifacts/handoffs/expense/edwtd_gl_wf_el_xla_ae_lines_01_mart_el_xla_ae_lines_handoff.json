      "attributes": {
        "Sql Query": "SELECT \r\nELMXAL.ACCOUNTING_CLASS_CODE ,        \r\nELMXAL.AE_HEADER_ID,                  \r\nELMXAL.AE_LINE_NUM,                   \r\nELMXAL.APPLICATION_ID,                \r\nELMXAL.GL_SL_LINK_ID ,                \r\nELMXAL.GL_SL_LINK_TABLE   ,\r\nELMXAL.SOURCE_TABLE ,   \r\nELMXAL.SOURCE_ID  , \r\nELMXAL.DESCRIPTION ,                \r\nELMXAL.GES_UPDATE_DATE   ,            \r\nELMXAL.GLOBAL_NAME  \r\nFROM\r\n(\r\nSELECT \r\nSTMXAL.ACCOUNTING_CLASS_CODE ,        \r\nSTMXAL.AE_HEADER_ID,                  \r\nSTMXAL.AE_LINE_NUM,                   \r\nSTMXAL.APPLICATION_ID,                \r\nSTMXAL.GL_SL_LINK_ID ,                \r\nSTMXAL.GL_SL_LINK_TABLE   ,           \r\nSTMXAL.SOURCE_TABLE ,                 \r\nSTMXAL.SOURCE_ID ,\r\nSTMXAL.DESCRIPTION,                   \r\nSTMXAL.GES_UPDATE_DATE  ,            \r\nSTMXAL.GLOBAL_NAME \r\nFROM $$STGDB.ST_MF_XLA_AE_LINES  STMXAL\r\nUNION ALL\r\nSELECT\r\nSTCXAL.ACCOUNTING_CLASS_CODE ,        \r\nSTCXAL.AE_HEADER_ID,                  \r\nSTCXAL.AE_LINE_NUM,                   \r\nSTCXAL.APPLICATION_ID,                \r\nSTCXAL.GL_SL_LINK_ID ,                \r\nSTCXAL.GL_SL_LINK_TABLE   ,           \r\nSTCXAL.SOURCE_TABLE ,                 \r\nSTCXAL.SOURCE_ID ,\r\nSTCXAL.DESCRIPTION,                   \r\nSTCXAL.GES_UPDATE_DATE  ,            \r\nSTCXAL.GLOBAL_NAME \r\nFROM $$STGDB.ST_CG1_XLA_AE_LINES  STCXAL\r\n) ELMXAL\r\nWHERE \r\n(ELMXAL.AE_HEADER_ID, ELMXAL.AE_LINE_NUM, ELMXAL.APPLICATION_ID,ELMXAL.GLOBAL_NAME)\r\nNOT IN \r\n( SELECT  EMXAL.AE_HEADER_ID, EMXAL.AE_LINE_NUM, EMXAL.APPLICATION_ID,EMXAL.GLOBAL_NAME FROM  $$ETLVWDB.EL_XLA_AE_LINES  EMXAL)",
