      "attributes": {
        "Sql Query": "SELECT \r\nA.LINE_TYPE,\r\nA.DESCRIPTION,\r\nA.ACTION_CODE,\r\nA.DML_TYPE,\r\nA.PURCHASE_BASIS\r\nfrom \r\n(\r\n\tSELECT\r\n\tSMOPLTT.LINE_TYPE,\r\n\tSMOPLTT.DESCRIPTION,\r\n\tSMOPLTT.ACTION_CODE,\r\n\t'I' as DML_TYPE,\r\n\tSMOPLTT.PURCHASE_BASIS,\r\n\tROW_NUMBER() OVER (PARTITION BY SMOPLTT.LINE_TYPE\r\n\tORDER BY SMOPLTT.GES_UPDATE_DATE DESC) AS ROW_NUM\r\n\tFROM \r\n\t(\r\n\t\tSELECT \r\n\t\tSMPLTT.LINE_TYPE ,SMPLTT.DESCRIPTION , \r\n\t\tSMPLTT.GES_UPDATE_DATE,\r\n\t\tSMPLTT.ACTION_CODE,\r\n\t\tSMPLB.PURCHASE_BASIS\r\n\t\tFROM \r\n\t    $$STGDB.ST_MF_PO_LINE_TYPES_TL SMPLTT,\r\n\t\t$$STGDB.ST_MF_PO_LINE_TYPES_B SMPLB\r\n\t\tWHERE \r\n\t\t\tSMPLTT.LINE_TYPE_ID = SMPLB.LINE_TYPE_ID\r\n\t\t\r\n\t\t\r\n\t\tUNION ALL\r\n\t\tSELECT \r\n\t\tSCPLTT.LINE_TYPE,\r\n\t\tSCPLTT.DESCRIPTION ,\r\n\t\tSCPLTT.LAST_UPDATE_DATE,\r\n\t\tSCPLTT.ACTION_CODE,\r\n\t\tSCPLB.PURCHASE_BASIS\r\n\t\tFROM \r\n\t\t$$STGDB.ST_CG1_PO_LINE_TYPES_TL SCPLTT,\r\n\t\t$$STGDB.ST_CG1_PO_LINE_TYPES_B SCPLB\r\n\t\tWHERE \r\n\t\tSCPLTT.LINE_TYPE_ID = SCPLB.LINE_TYPE_ID\r\n\t\t\r\n\t\t) SMOPLTT                  /* Added CG1 flow as a part of SJPROD Q1FY14 */\r\n) A  where A.row_num=1\r\n\r\n\t\t/*\r\n\t\tBedrock2.0 change - removed OM flow\r\n\t\tUNION ALL\r\n\t\tSELECT \r\n\t\tLINE_TYPE ,\r\n\t\tDESCRIPTION ,\r\n\t\tGES_UPDATE_DATE,\r\n\t\tACTION_CODE\r\n\t\tFROM $$STGDB.ST_OM_PO_LINE_TYPES_TL SOPLTT\r\n\t\t*/",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "/*COLLECT STATS ON $$STGDB.ST_MF_PO_LINE_TYPES_TL;*/\r\n\r\nCALL COLLECT_STATS_WRAP('$$STGDB','ST_MF_PO_LINE_TYPES_TL','D');\r\n\r\nCALL COLLECT_STATS_WRAP('$$STGDB','ST_CG1_PO_LINE_TYPES_TL','D');   /* Added CG1 flow as a part of Q1FY14 */\r\n\r\n/* Bedrock2.0 change - removed OM flow\r\nCOLLECT STATS ON $$STGDB.ST_OM_PO_LINE_TYPES_TL;\r\n*/\r\n\r\nDELETE FROM $$WORKDB.W_PURCHASE_ORDER_LINE_TYPE ALL;",
        "Post SQL": "",
        "Output is deterministic": "NO",
