        "Sql Query": "SELECT    \r\n\tSTMJL.JE_HEADER_ID AS BK_JOURNAL_ENTRY_NUMBER_INT \r\n\t,STMJL.JE_LINE_NUM AS BK_JOURNAL_ENTRY_LINE_NUM_INT \r\n\t,STMJL.GLOBAL_NAME AS GLOBAL_NAME\r\n\t, NVID.VENDOR_INVOICE_DISTRIB_KEY AS  VENDOR_INVOICE_DISTRIB_KEY   \r\n\t,NVID.VNDR_INV_DISTRIB_AMT     AS VNDR_INV_DISTRIB_AMT\r\n\t,NVI.SK_INVOICE_ID_INT AS INVOICE_ID\t\r\n\t,NVID.SK_INVOICE_DISTRIBUTION_ID_INT AS SK_INVOICE_DISTRIBUTION_ID_INT\r\n\t,NVID.BK_VNDR_INV_DSTRBN_TRX_TYPE_CD AS VNDR_INV_DISTRIB_TRX_TYPE_CD\r\n\t,NVID.DD_BK_COMPANY_CD AS BK_COMPANY_CD\r\n\t,NSOB_AP.SET_OF_BOOKS_KEY AS AP_SET_OF_BOOKS_KEY\r\n\t,'UNK' as  BK_FUNCTIONAL_CURRENCY_CD\r\n\t,NVI.TRANSACTIONAL_CURRENCY_CD  TRANSACTIONAL_CURRENCY_CD\t\r\n\t,(NVID.FISCAL_YEAR_NUMBER_INT*100 +NVID.FISCAL_MONTH_NUMBER_INT ) AS DV_FISCAL_YEAR_MONTH_NUM_INT\t\r\n\t, ' ' as DV_USD_AMT\r\n\t,' ' as DV_FUNCTIONAL_AMT\r\n\t,NSSC.GLOBAL_NAME as INVOICE_GLOBAL_NAME\r\n\t,XLA.AE_HEADER_ID \r\n\t,XLA.AE_LINE_NUM \t\r\n\t,NSOB_GL.SET_OF_BOOKS_KEY as GL_SET_OF_BOOKS_KEY\t\r\n\t\tFROM  \r\n               (\r\n\t\t\tSELECT \r\n\t\t\tJE_HEADER_ID,                  \r\n\t\t\tJE_LINE_NUM,                 \r\n\t\t\tREFERENCE_2,                   \r\n\t\t\tREFERENCE_3,                  \r\n\t\t\tGLOBAL_NAME,\r\n\t\t\tREFERENCE_7,\r\n\t\t\tREFERENCE_8,\r\n\t\t\tSET_OF_BOOKS_ID\r\n\t\t\tFROM $$STGDB.ST_MF_GL_JE_LINES\r\n\t\t\tWHERE STATUS='P' AND GLOBAL_NAME='BE'\r\n\t\t\tUNION ALL\r\n\t\t\tSELECT \r\n\t\t\tJE_HEADER_ID,                  \r\n\t\t\tJE_LINE_NUM,                 \r\n\t\t\tREFERENCE_2,                   \r\n\t\t\tREFERENCE_3,                  \r\n\t\t\tGLOBAL_NAME,\r\n\t\t\tREFERENCE_7,\r\n\t\t\tREFERENCE_8,\r\n\t\t\tSET_OF_BOOKS_ID\r\n\t\t\tFROM $$EXCEPDB.EX_GL_JE_LINES_VNDR_INVOICE\r\n\t\t\tWHERE  GLOBAL_NAME='BE'\r\n\t\t\t\t) STMJL\r\nINNER JOIN $$STGDB.WI_CG1_XLA_LINES_DISTB_LINKS  XLA\r\n\tON (\tXLA.GLOBAL_NAME='CG' \r\n\t\tAND XLA.AE_HEADER_ID = STMJL.REFERENCE_7\r\n\t\tAND XLA.AE_LINE_NUM =  STMJL.REFERENCE_8 \t\t\t)\t\t\r\nINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\n\tON (XLA.GLOBAL_NAME=NSSC.SOURCE_SYSTEM_CODE )\r\nINNER JOIN $$FINLGLVWDB.N_VENDOR_INVOICE_DISTRIBUTION NVID\r\n\tON\t( XLA.SOURCE_DISTRIBUTION_ID_NUM_1 = NVID.SK_INVOICE_DISTRIBUTION_ID_INT\r\n\t\tAND NSSC.SOURCE_SYSTEM_CODE  = NVID.SS_CD )\r\nINNER JOIN  $$FINLGLVWDB.N_VENDOR_INVOICE  NVI     \r\n\tON    NVI.VENDOR_INVOICE_KEY          =   NVID.VENDOR_INVOICE_KEY\r\nINNER JOIN  $$FINLGLVWDB.N_SET_OF_BOOKS  NSOB_AP\r\n\tON NVI.SET_OF_BOOKS_KEY            =   NSOB_AP.SET_OF_BOOKS_KEY    \r\nINNER JOIN $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC_GL\r\n\tON (STMJL.GLOBAL_NAME=NSSC_GL.GLOBAL_NAME  )\t\r\nINNER JOIN  $$FINLGLVWDB.N_SET_OF_BOOKS  NSOB_GL  /* Added GL SOB KEY flow to join with GL tables */\r\n\tON    (NSSC_GL.SOURCE_SYSTEM_CODE     =   NSOB_GL.SS_CODE \r\n\t and     STMJL. SET_OF_BOOKS_ID       =   NSOB_GL. SK_SET_OF_BOOKS_ID_INT   )   ;\t\r\n/* LEFT OUTER JOIN $$STGDB.WI_ED_COMPANY_SOURCE_MAP WECSM  \r\n\tON  (WECSM.SET_OF_BOOKS_ID            =    NSOB_AP.SK_SET_OF_BOOKS_ID_INT\r\n\t\tAND\tWECSM.GLOBAL_NAME                =    NSSC.GLOBAL_NAME\r\n\t\tAND\tWECSM.COMPANY                    =    NVID.DD_BK_COMPANY_CD                \r\n\t\tAND\tWECSM.BK_FISCAL_YEAR_NUMBER_INT  =    NVID.FISCAL_YEAR_NUMBER_INT \r\n\t\tAND   WECSM.BK_FISCAL_MONTH_NUMBER_INT =    NVID.FISCAL_MONTH_NUMBER_INT);\r\n\t\t*/  /* using JE_LINEs Currency from Work query*/",
        "User Defined Join": "",
