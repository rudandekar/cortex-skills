        "Sql Query": "SELECT \r\n SMOGJEL.BATCH_ID                      \r\n,SMOGJEL.ACCOUNTED_CR                  \r\n,SMOGJEL.ACCOUNTED_DR                  \r\n,SMOGJEL.CODE_COMBINATION_ID           \r\n,SMOGJEL.CREATED_BY                    \r\n,SMOGJEL.CREATION_DATE                 \r\n,SMOGJEL.EFFECTIVE_DATE                \r\n,SMOGJEL.ENTERED_CR                    \r\n,SMOGJEL.ENTERED_DR                    \r\n,SMOGJEL.INVOICE_AMOUNT                \r\n,SMOGJEL.INVOICE_DATE                  \r\n,SMOGJEL.INVOICE_IDENTIFIER            \r\n,SMOGJEL.JE_HEADER_ID                  \r\n,SMOGJEL.JE_LINE_NUM                   \r\n,SMOGJEL.LAST_UPDATED_BY               \r\n,SMOGJEL.LAST_UPDATE_DATE              \r\n,SMOGJEL.PERIOD_NAME                   \r\n,SMOGJEL.REFERENCE_9                   \r\n,SMOGJEL.REFERENCE_6                   \r\n,SMOGJEL.SET_OF_BOOKS_ID               \r\n,SMOGJEL.GLOBAL_NAME                   \r\n,SMOGJEL.GES_UPDATE_DATE               \r\n,SMOGJEL.CREATE_DATETIME               \r\n,SMOGJEL.ACTION_CODE                   \r\n,'RI' EXCEPTION_TYPE   \r\nFROM \r\n   (\r\n   \tSELECT \r\n\t\t SMGJEL.BATCH_ID\r\n\t\t,SMGJEL.ACCOUNTED_CR                  \r\n\t\t,SMGJEL.ACCOUNTED_DR                  \r\n\t\t,SMGJEL.CODE_COMBINATION_ID           \r\n\t\t,SMGJEL.CREATED_BY                    \r\n\t\t,SMGJEL.CREATION_DATE                 \r\n\t\t,SMGJEL.EFFECTIVE_DATE                \r\n\t\t,SMGJEL.ENTERED_CR                    \r\n\t\t,SMGJEL.ENTERED_DR                    \r\n\t\t,SMGJEL.INVOICE_AMOUNT                \r\n\t\t,SMGJEL.INVOICE_DATE                  \r\n\t\t,SMGJEL.INVOICE_IDENTIFIER            \r\n\t\t,SMGJEL.JE_HEADER_ID                  \r\n\t\t,SMGJEL.JE_LINE_NUM                   \r\n\t\t,SMGJEL.LAST_UPDATED_BY               \r\n\t\t,SMGJEL.LAST_UPDATE_DATE              \r\n\t\t,SMGJEL.PERIOD_NAME                   \r\n\t\t,SMGJEL.REFERENCE_9                   \r\n\t\t,SMGJEL.REFERENCE_6                   \r\n\t\t,SMGJEL.SET_OF_BOOKS_ID               \r\n\t\t,SMGJEL.GLOBAL_NAME                   \r\n\t\t,SMGJEL.GES_UPDATE_DATE               \r\n\t\t,SMGJEL.CREATE_DATETIME               \r\n\t\t,SMGJEL.ACTION_CODE \r\n\tFROM $$STGDB.ST_MF_GL_JE_LINES SMGJEL\r\n      WHERE SMGJEL.REFERENCE_6 = 'AP PAYMENTS' AND SMGJEL.REFERENCE_9 IS NOT NULL\r\n\tAND STATUS='P'\r\n)SMOGJEL\r\nWHERE NOT EXISTS \r\n(SELECT 1 FROM $$WORKDB. W_JEL_SRC_LNK_FRM_VNDR_INVPYMT WJEL,\r\n               $$FINLGLVWDB.N_SET_OF_BOOKS NSOB,\r\n\t\t\t\t$$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\n   WHERE   WJEL.BK_JOURNAL_ENTRY_LINE_NUM_INT =SMOGJEL.JE_LINE_NUM \r\n   AND   WJEL.BK_JOURNAL_ENTRY_NUMBER_INT = SMOGJEL.JE_HEADER_ID \r\n   AND   WJEL.SET_OF_BOOKS_KEY = NSOB.SET_OF_BOOKS_KEY\r\n   AND   NSSC.GLOBAL_NAME = SMOGJEL.GLOBAL_NAME\r\n   AND   NSOB.SS_CODE = NSSC.SOURCE_SYSTEM_CODE\r\n )",
