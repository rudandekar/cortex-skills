      "attributes": {
        "Sql Query": "SELECT\r\nNJE.BK_JOURNAL_ENTRY_NUMBER_INT ,\r\nNJE.BK_JOURNAL_ENTRY_LINE_NUM_INT ,\r\nNJE.BK_COMPANY_CODE ,\r\nNJE.SET_OF_BOOKS_KEY ,\r\nNVP.VENDOR_INVOICE_PAYMENT_KEY,\r\nNJE.DV_FISCAL_YEAR_MONTH_NUM_INT \r\nFROM \r\n(\r\n\tSELECT \r\n\t\tSMGJEL.JE_HEADER_ID,\r\n\t\tSMGJEL.JE_LINE_NUM,\r\n\t\tSMGJEL.GLOBAL_NAME ,\r\n\t\tSMGJEL.SET_OF_BOOKS_ID,\r\n\t\tcast(SMGJEL.REFERENCE_9 as INTEGER) REFERENCE_9,\r\n\t\tSMGJEL.REFERENCE_6\r\n\tFROM  $$STGDB.ST_MF_GL_JE_LINES SMGJEL\r\n\tWHERE \r\n\t\tSMGJEL.REFERENCE_6 = 'AP PAYMENTS' \r\n\t\tAND SMGJEL.REFERENCE_9 IS NOT NULL\r\n\t\tAND STATUS='P'\r\n\t\tAND GLOBAL_NAME ='BE' /*  9/21/2011 Bedrock2.0 change : Added filter GLOBAL_NAME ='BE' */\r\n\tUNION ALL\r\n\tSELECT \r\n\t\tEGJLVIP.JE_HEADER_ID,\r\n\t\tEGJLVIP.JE_LINE_NUM,\r\n\t\tEGJLVIP.GLOBAL_NAME ,\r\n\t\tEGJLVIP.SET_OF_BOOKS_ID,\r\n\t\tcast(EGJLVIP.REFERENCE_9 as INTEGER) REFERENCE_9,\r\n\t\tEGJLVIP.REFERENCE_6\r\n\tFROM  $$EXCEPDB.EX_GL_JE_LINES_VNDR_INVPYMT EGJLVIP\r\n) STEXJEL \r\nINNER JOIN  $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC \r\n\tON(STEXJEL.GLOBAL_NAME = NSSC.GLOBAL_NAME)\r\n/*  9/21/2011 Bedrock2.0 change : Added Inner join with NJH*/\r\nINNER JOIN $$FINLGLVWDB.N_JOURNAL_ENTRY NJH\r\n\tON (STEXJEL.JE_HEADER_ID = NJH.BK_JOURNAL_ENTRY_NUMBER_INT\r\n\tAND NJH.SS_CD = NSSC.SOURCE_SYSTEM_CODE)\t \r\nINNER JOIN  $$FINLGLVWDB.N_JOURNAL_ENTRY_LINE NJE\r\n\tON (STEXJEL.JE_HEADER_ID = NJE.BK_JOURNAL_ENTRY_NUMBER_INT\r\n\tAND STEXJEL.JE_LINE_NUM = NJE.BK_JOURNAL_ENTRY_LINE_NUM_INT \r\n\tAND NSSC. SOURCE_SYSTEM_CODE = NJE.SS_CD\r\n\tand NJE.JOURNAL_ENTRY_LINE_TYPE_CD = 'INVOICE PAYMENT JOURNAL ENTRY LINE' )\r\nINNER JOIN $$FINLGLVWDB.N_VENDOR_INVOICE_PAYMENT NVP\r\n\tON(STEXJEL.REFERENCE_9 = NVP.SK_INVOICE_PAYMENT_ID_INT\r\n\tAND NSSC.SOURCE_SYSTEM_CODE = NVP.SS_CD)\r\n/*  9/21/2011 Bedrock2.0 change : Added WHERE condition to pull Journal Entries  and Inv_Payment which are created in CFN */\r\nWHERE \r\n\tNJH.BK_JOURNAL_ENTRY_SOURCE_NAME  not like 'SJ%' \r\n/*  9/21/2011 Bedrock2.0 change : Added below flow to link GL(in CFN) and INV_Payment(at SJ) */\r\nUNION\r\nSELECT\r\nNJE.BK_JOURNAL_ENTRY_NUMBER_INT ,\r\nNJE.BK_JOURNAL_ENTRY_LINE_NUM_INT ,\r\nNJE.BK_COMPANY_CODE ,\r\nNJE.SET_OF_BOOKS_KEY ,\r\nNVP.VENDOR_INVOICE_PAYMENT_KEY,\r\nNJE.DV_FISCAL_YEAR_MONTH_NUM_INT \r\nFROM \r\n(\r\n\tSELECT \r\n\t\tSMGJEL.JE_HEADER_ID,\r\n\t\tSMGJEL.JE_LINE_NUM,\r\n\t\tSMGJEL.GLOBAL_NAME ,\r\n\t\tSMGJEL.SET_OF_BOOKS_ID,\r\n\t\tcast(SMGJEL.REFERENCE_9 as INTEGER) REFERENCE_9,\r\n\t\tSMGJEL.REFERENCE_6\r\n\tFROM  $$STGDB.ST_MF_GL_JE_LINES SMGJEL\r\n\tWHERE SMGJEL.REFERENCE_6 = 'AP PAYMENTS' \r\n\t\tAND SMGJEL.REFERENCE_9 IS NOT NULL\r\n\t\tAND STATUS='P'\r\n\t\tAND GLOBAL_NAME ='BE' /*  9/21/2011 Bedrock2.0 change : Added filter GLOBAL_NAME ='BE' */\r\n\tUNION ALL\r\n\tSELECT \r\n\t\tEGJLVIP.JE_HEADER_ID,\r\n\t\tEGJLVIP.JE_LINE_NUM,\r\n\t\tEGJLVIP.GLOBAL_NAME ,\r\n\t\tEGJLVIP.SET_OF_BOOKS_ID,\r\n\t\tcast(EGJLVIP.REFERENCE_9 as INTEGER) REFERENCE_9,\r\n\t\tEGJLVIP.REFERENCE_6\r\n\tFROM  $$EXCEPDB.EX_GL_JE_LINES_VNDR_INVPYMT EGJLVIP\r\n) STEXJEL \r\nINNER JOIN  $$COMREFVWDB.N_SOURCE_SYSTEM_CODES NSSC\r\n\tON(STEXJEL.GLOBAL_NAME = NSSC.GLOBAL_NAME)\r\n/*  9/21/2011 Bedrock2.0 change : Added Inner join with NJH*/\r\nINNER JOIN $$FINLGLVWDB.N_JOURNAL_ENTRY NJH\r\n\tON (STEXJEL.JE_HEADER_ID = NJH.BK_JOURNAL_ENTRY_NUMBER_INT\r\n\tAND NJH.SS_CD = NSSC.SOURCE_SYSTEM_CODE)\t\r\nINNER JOIN  $$FINLGLVWDB.N_JOURNAL_ENTRY_LINE NJE\r\n\tON (STEXJEL.JE_HEADER_ID = NJE.BK_JOURNAL_ENTRY_NUMBER_INT \r\n\tAND STEXJEL.JE_LINE_NUM = NJE.BK_JOURNAL_ENTRY_LINE_NUM_INT    \r\n\tAND NSSC. SOURCE_SYSTEM_CODE = NJE.SS_CD\r\n\tand NJE.JOURNAL_ENTRY_LINE_TYPE_CD = 'INVOICE PAYMENT JOURNAL ENTRY LINE' )\r\nINNER JOIN $$FINLGLVWDB.N_VENDOR_INVOICE_PAYMENT NVP\r\n\tON(STEXJEL.REFERENCE_9 = NVP.SK_INVOICE_PAYMENT_ID_INT\r\n\tAND NVP.SS_CD = 'MFG' ) /* 9/21/2011 Bedrock2.0 change : hardcoded 'MFG'  */\r\n/*  9/21/2011 Bedrock2.0 change : Added WHERE condition to pull only Journal Entries which are created in SJ and copied over to CFN */\r\nWHERE \r\n\tNJH.BK_JOURNAL_ENTRY_SOURCE_NAME  like 'SJ%'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
