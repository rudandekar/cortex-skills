      "attributes": {
        "Sql Query": "SELECT \r\n\tELFU.CREATED_BY,\r\n\tELFU.CREATION_DATE, \r\n\tELFU.DESCRIPTION,\r\n\tELFU.EMAIL_ADDRESS,\r\n\tELFU.EMPLOYEE_ID,\r\n\tELFU.END_DATE, \r\n\tELFU.GCN_CODE_COMBINATION_ID, \r\n\tELFU.GLOBAL_NAME,\r\n\tELFU.GES_UPDATE_DATE, \r\n\tELFU.LAST_UPDATE_DATE, \r\n\tELFU.LAST_UPDATED_BY,\r\n\tELFU.START_DATE, \r\n\tELFU.SUPPLIER_ID, \r\n\tELFU.USER_ID, \r\n\tELFU.USER_NAME,\r\n\tELFU.CMS_REPLICATION_DATE, \r\n\tELFU.CMS_REPLICATION_NUMBER \r\nFROM\r\n\t(SELECT \r\n\t\tSMFU.CREATED_BY,\r\n\t\tSMFU.CREATION_DATE, \r\n\t\tSMFU.DESCRIPTION,\r\n\t\tSMFU.EMAIL_ADDRESS,\r\n\t\tSMFU.EMPLOYEE_ID,\r\n\t\tSMFU.END_DATE, \r\n\t\tSMFU.GCN_CODE_COMBINATION_ID, \r\n\t\tSMFU.GLOBAL_NAME,\r\n\t\tSMFU.GES_UPDATE_DATE, \r\n\t\tSMFU.LAST_UPDATE_DATE, \r\n\t\tSMFU.LAST_UPDATED_BY,\r\n\t\tSMFU.START_DATE, \r\n\t\tSMFU.SUPPLIER_ID, \r\n\t\tSMFU.USER_ID, \r\n\t\tSMFU.USER_NAME,\r\n\t\tSMFU.CMS_REPLICATION_DATE, \r\n\t\tSMFU.CMS_REPLICATION_NUMBER \r\n\tFROM\r\n\t\t$$STGDB.ST_MF_FND_USER SMFU\r\n\tUNION ALL\r\n\tSELECT \r\n\t\tSCFU.CREATED_BY,\r\n\t\tSCFU.CREATION_DATE, \r\n\t\tSCFU.DESCRIPTION,\r\n\t\tSCFU.EMAIL_ADDRESS,\r\n\t\tSCFU.EMPLOYEE_ID,\r\n\t\tSCFU.END_DATE, \r\n\t\tSCFU.GCN_CODE_COMBINATION_ID, \r\n\t\tSCFU.GLOBAL_NAME,\r\n\t\tSCFU.GES_UPDATE_DATE, \r\n\t\tSCFU.LAST_UPDATE_DATE, \r\n\t\tSCFU.LAST_UPDATED_BY,\r\n\t\tSCFU.START_DATE, \r\n\t\tSCFU.SUPPLIER_ID, \r\n\t\tSCFU.USER_ID, \r\n\t\tSCFU.USER_NAME,\r\n\t\tNULL as CMS_REPLICATION_DATE, \r\n\t\tNULL as CMS_REPLICATION_NUMBER \r\n\tFROM\r\n\t\t$$STGDB.ST_CG1_FND_USER SCFU\r\n\tUNION ALL\t\r\n\tSELECT \r\n\t\tSOFU.CREATED_BY,\r\n\t\tSOFU.CREATION_DATE, \r\n\t\tSOFU.DESCRIPTION,\r\n\t\tSOFU.EMAIL_ADDRESS,\r\n\t\tSOFU.EMPLOYEE_ID,\r\n\t\tSOFU.END_DATE, \r\n\t\tSOFU.GCN_CODE_COMBINATION_ID, \r\n\t\tSOFU.GLOBAL_NAME,\r\n\t\tSOFU.GES_UPDATE_DATE, \r\n\t\tSOFU.LAST_UPDATE_DATE, \r\n\t\tSOFU.LAST_UPDATED_BY,\r\n\t\tSOFU.START_DATE, \r\n\t\tSOFU.SUPPLIER_ID, \r\n\t\tSOFU.USER_ID, \r\n\t\tSOFU.USER_NAME,\r\n\t\tSOFU.CMS_REPLICATION_DATE,\r\n\t\tSOFU.CMS_REPLICATION_NUMBER \r\n\tFROM\r\n\t\t$$STGDB.ST_OM_FND_USER SOFU\r\n\tUNION ALL\r\n\tSELECT \r\n\t\tSKFU.CREATED_BY,\r\n\t\tSKFU.CREATION_DATE, \r\n\t\tSKFU.DESCRIPTION,\r\n\t\tSKFU.EMAIL_ADDRESS,\r\n\t\tSKFU.EMPLOYEE_ID,\r\n\t\tSKFU.END_DATE, \r\n\t\tNULL AS GCN_CODE_COMBINATION_ID, \r\n\t\tSKFU.GLOBAL_NAME,\r\n\t\tSKFU.GES_UPDATE_DATE, \r\n\t\tSKFU.LAST_UPDATE_DATE, \r\n\t\tSKFU.LAST_UPDATED_BY,\r\n\t\tSKFU.START_DATE, \r\n\t\tSKFU.SUPPLIER_ID, \r\n\t\tSKFU.USER_ID, \r\n\t\tSKFU.USER_NAME,\r\n\t\tCAST('1900-01-01 00:00:00' AS TIMESTAMP(0))  AS CMS_REPLICATION_DATE,\r\n\t\tNULL AS CMS_REPLICATION_NUMBER\r\n\tFROM \r\n\t\t$$STGDB.ST_KS_FND_USER SKFU\r\n\tUNION ALL\r\n\tSELECT\r\n\t\tSCFU.CREATED_BY,\r\n\t\tSCFU.CREATION_DATE, \r\n\t\tSCFU.DESCRIPTION,\r\n\t\tSCFU.EMAIL_ADDRESS,\r\n\t\tSCFU.EMPLOYEE_ID,\r\n\t\tSCFU.END_DATE, \r\n\t\tSCFU.GCN_CODE_COMBINATION_ID, \r\n\t\tSCFU.GLOBAL_NAME,\r\n\t\tSCFU.GES_UPDATE_DATE, \r\n\t\tSCFU.LAST_UPDATE_DATE, \r\n\t\tSCFU.LAST_UPDATED_BY,\r\n\t\tSCFU.START_DATE, \r\n\t\tSCFU.SUPPLIER_ID, \r\n\t\tSCFU.USER_ID, \r\n\t\tSCFU.USER_NAME,\r\n\t\tCAST('1900-01-01 00:00:00' AS TIMESTAMP(0))  AS CMS_REPLICATION_DATE,\r\n\t\tNULL AS CMS_REPLICATION_NUMBER\r\n\tFROM \r\n\t\t$$STGDB.ST_CTS_FND_USER SCFU\r\n\tUNION ALL\r\n\tSELECT\r\n\t\tSCOFU.CREATED_BY,\r\n\t\tSCOFU.CREATION_DATE, \r\n\t\tSCOFU.DESCRIPTION,\r\n\t\tSCOFU.EMAIL_ADDRESS,\r\n\t\tSCOFU.EMPLOYEE_ID,\r\n\t\tSCOFU.END_DATE, \r\n\t\tSCOFU.GCN_CODE_COMBINATION_ID, \r\n\t\tSCOFU.GLOBAL_NAME,\r\n\t\tSCOFU.GES_UPDATE_DATE, \r\n\t\tSCOFU.LAST_UPDATE_DATE, \r\n\t\tSCOFU.LAST_UPDATED_BY,\r\n\t\tSCOFU.START_DATE, \r\n\t\tSCOFU.SUPPLIER_ID, \r\n\t\tSCOFU.USER_ID, \r\n\t\tSCOFU.USER_NAME,\r\n\t\tCAST('1900-01-01 00:00:00' AS TIMESTAMP(0))  AS CMS_REPLICATION_DATE,\r\n\t\tNULL AS CMS_REPLICATION_NUMBER\r\n\tFROM \r\n\t\t$$STGDB.ST_COE_FND_USER SCOFU\r\n\t) ELFU\r\nWHERE (ELFU.USER_ID,ELFU.GLOBAL_NAME) NOT IN (SELECT ELFU.USER_ID,ELFU.GLOBAL_NAME FROM  $$ETLVWDB.EL_FND_USER ELFU)",
