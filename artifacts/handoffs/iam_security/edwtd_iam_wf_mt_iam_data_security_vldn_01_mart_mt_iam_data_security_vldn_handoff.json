      "attributes": {
        "Sql Query": "SELECT FNL_QRY.CEC_ID AS CEC_ID\t,\r\nFNL_QRY.HIER_TYPE_DESCR AS HIER_TYPE_DESCR\t,\r\n'PMM' AS DV_APPLICATION_NAME,\r\nFNL_QRY.LEVEL_0_FLG AS DV_LEVEL_0_FLG\t,\r\nFNL_QRY.LEVEL_1_FLG\tAS DV_LEVEL_1_FLG\t,\r\nFNL_QRY.LEVEL_2_FLG\tAS DV_LEVEL_2_FLG\t,\r\nFNL_QRY.LEVEL_3_FLG\tAS DV_LEVEL_3_FLG\t,\r\nFNL_QRY.LEVEL_4_FLG\tAS DV_LEVEL_4_FLG\t,\r\nFNL_QRY.LEVEL_5_FLG\tAS DV_LEVEL_5_FLG\t,\r\nFNL_QRY.LEVEL_6_FLG\tAS DV_LEVEL_6_FLG\t,\r\nFNL_QRY.LEVEL_7_FLG\tAS DV_LEVEL_7_FLG\t,\r\nFNL_QRY.LEVEL_8_FLG\tAS DV_LEVEL_8_FLG\t,\r\nFNL_QRY.LEVEL_9_FLG\tAS DV_LEVEL_9_FLG\t,\r\nFNL_QRY.LEVEL_10_FLG\tAS DV_LEVEL_10_FLG\t,\r\nFNL_QRY.MAX_LVL_CD AS DV_MAX_LVL_CD\t,\r\nFNL_QRY.MIN_LVL_CD AS DV_MIN_LVL_CD,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER\r\nFROM(\r\n\r\n\r\nSELECT\tCAST(CEC_ID AS CHAR(8)) AS CEC_ID\r\n\t\t,CAST('PRODUCT' AS VARCHAR(50)) AS HIER_TYPE_DESCR\r\n\t\t,CAST(MAX(CASE        B.IAM_LEVEL_NUM   WHEN    0 THEN '1' ELSE         '0' END) AS VARCHAR(50))          AS LEVEL_0_FLG \r\n\t\t,CAST(MAX(CASE        B.IAM_LEVEL_NUM    WHEN    1 THEN '1' ELSE         '0' END) AS VARCHAR(50))          AS LEVEL_1_FLG                  \r\n\t\t,CAST(MAX(CASE        B.IAM_LEVEL_NUM    WHEN    2 THEN '1' ELSE         '0' END) AS VARCHAR(50))          AS LEVEL_2_FLG    \t\r\n\t\t,CAST('0' AS VARCHAR(50)) AS  LEVEL_3_FLG\r\n\t\t,CAST('0' AS VARCHAR(50)) LEVEL_4_FLG\r\n\t\t,CAST('0' AS VARCHAR(50)) LEVEL_5_FLG\r\n\t\t,CAST('0' AS VARCHAR(50)) LEVEL_6_FLG\r\n\t\t,CAST('0' AS VARCHAR(50)) LEVEL_7_FLG\r\n\t\t,CAST('0' AS VARCHAR(50)) LEVEL_8_FLG\r\n\t\t,CAST('0' AS VARCHAR(50)) LEVEL_9_FLG\r\n\t\t,CAST('0' AS VARCHAR(50)) LEVEL_10_FLG\r\n\t\t,(MAX ( B.IAM_LEVEL_NUM )) AS MAX_LVL_CD\r\n\t\t,CASE\tWHEN  MIN(iam_level_num) IS NULL THEN 0  ELSE MIN(iam_level_num) \tEND\tAS MIN_LVL_CD\r\n\r\nFROM\t(\r\nSELECT\t\r\n\t\tHIER.PRODUCT_HIER_KEY IAM_PRODUCT_HIER_KEY,\r\n\t\tHIER.IAM_LEVEL_NUM_INT AS IAM_LEVEL_NUM ,\r\n\t\tNIU.DD_CEC_ID  AS CEC_ID,\r\n\t\tHIER.ASSIGNMENT_TYPE  AS ASSIGNMENT_TYPE,\r\n\t   APP.APPLICATION_NAME AS APPLICATION_NAME \r\n\tFROM\r\n\t\t(\r\n\t\t\tSELECT\r\n\t\t\t\tBK_IAM_ROLE_NAME\r\n\t\t\t\t,PF.IAM_APPLICATION_KEY\r\n\t\t\t\t,BK_PRODUCT_FAMILY_ID  AS PRODUCT_HIER_KEY\r\n\t\t\t\t,ASSIGNMENT_TYPE\r\n\t\t\t\t,STANDARD_OR_EXCEPTION_FLG\r\n\t\t\t\t,EXCLUSIVE_OR_RESTRICTIVE_FLG\r\n\t\t\t\t,IAM_LEVEL_NUM_INT\r\n\t\t\t\t,IAM_USER_KEY\r\n\t\t\tFROM\r\n\t\t\t\t$$SECURITYVWDB.N_IAM_PRODUCT_FAMILY_LINK PF\r\n\t\t\tWHERE  PF.SOURCE_DELETED_FLG='N'\r\n\r\n\t\t\tUNION ALL\r\n\t\t\tSELECT\r\n\t\t\t\tBK_IAM_ROLE_NAME\r\n\t\t\t\t,BU.IAM_APPLICATION_KEY\r\n\t\t\t\t,BK_BUSINESS_UNIT_ID AS PRODUCT_HIER_KEY\r\n\t\t\t\t,ASSIGNMENT_TYPE\r\n\t\t\t\t,STANDARD_OR_EXCEPTION_FLG\r\n\t\t\t\t,EXCLUSIVE_OR_RESTRICTIVE_FLG\r\n\t\t\t\t,IAM_LEVEL_NUM_INT\r\n\t\t\t\t,IAM_USER_KEY\r\n\t\t\tFROM\r\n\t\t\t\t$$SECURITYVWDB.N_IAM_BUSINESS_UNIT_LINK  BU\r\n\t\t\tWHERE  BU.SOURCE_DELETED_FLG='N'\r\n\r\n\t\t\tUNION ALL\r\n\t\t\tSELECT\r\n\t\t\t\tBK_IAM_ROLE_NAME\r\n\t\t\t\t,TG.IAM_APPLICATION_KEY\r\n\t\t\t\t,BK_TECHNOLOGY_GROUP_ID AS PRODUCT_HIER_KEY\r\n\t\t\t\t,ASSIGNMENT_TYPE\r\n\t\t\t\t,STANDARD_OR_EXCEPTION_FLG\r\n\t\t\t\t,EXCLUSIVE_OR_RESTRICTIVE_FLG\r\n\t\t\t\t,IAM_LEVEL_NUM_INT\r\n\t\t\t\t,IAM_USER_KEY\r\n\t\t\tFROM\r\n\t\t\t\t$$SECURITYVWDB.N_IAM_TECHNOLOGY_GROUP_LINK TG\r\n\t\t\tWHERE TG.SOURCE_DELETED_FLG='N'\r\n\r\n\t\t\tUNION ALL\r\n\t\t\tSELECT\r\n\t\t\t\tBK_IAM_ROLE_NAME\r\n\t\t\t\t,TC.IAM_APPLICATION_KEY\r\n\t\t\t\t,BK_PRODUCT_HIER_COMPANY_ID AS PRODUCT_HIER_KEY\r\n\t\t\t\t,ASSIGNMENT_TYPE\r\n\t\t\t\t,STANDARD_OR_EXCEPTION_FLG\r\n\t\t\t\t,EXCLUSIVE_OR_RESTRICTIVE_FLG\r\n\t\t\t\t,IAM_LEVEL_NUM_INT\r\n\t\t\t\t,IAM_USER_KEY\r\n\t\t\tFROM\r\n\t\t\t\t$$SECURITYVWDB.N_IAM_PRODUCT_TOTAL_CISCO_LINK  TC\r\n\t\t\tWHERE TC.SOURCE_DELETED_FLG='N'\r\n\t\t) HIER,\r\n\t\t$$SECURITYVWDB.N_IAM_APPLICATION APP,\r\n\t\t$$SECURITYVWDB.N_IAM_USER NIU\r\n\tWHERE\r\n\t\tHIER.IAM_APPLICATION_KEY = APP.IAM_APPLICATION_KEY\r\n\t\tAND NIU.IAM_USER_KEY =  HIER.IAM_USER_KEY\r\n\t\tAND NIU.SOURCE_DELETED_FLG = 'N'\r\n\t\t\r\n\t\t) B\r\nWHERE\tB.ASSIGNMENT_TYPE = 'Visibility'     \r\nAND\t   \tB.APPLICATION_NAME = 'Finance BI Dashboard'      \r\nGROUP\tBY CEC_ID\r\nUNION ALL\r\nSELECT \r\n\t\t'GENERIC' AS CEC_ID,\r\n\t\t'PRODUCT' AS HIER_TYPE_DESCR\r\n\t\t,'0' AS LEVEL_0_FLG\r\n\t\t,'0' AS LEVEL_1_FLG\r\n\t\t,'0' AS LEVEL_2_FLG\r\n\t\t,'0' AS LEVEL_3_FLG\r\n\t\t,'0' AS LEVEL_4_FLG\r\n\t\t,'0' AS LEVEL_5_FLG\r\n\t\t,'0' AS LEVEL_6_FLG\r\n\t\t,'0' AS LEVEL_7_FLG\r\n\t\t,'0' AS LEVEL_8_FLG\r\n\t\t,'0' AS LEVEL_9_FLG\r\n\t\t,'0' AS LEVEL_10_FLG\r\n\t\t,0 AS MAX_LVL_CD\r\n\t\t,0 AS MIN_LVL_CD\r\nFROM  $$COMREFVWDB.R_DUAL\r\n\r\n\r\nUNION ALL\r\n\r\n\r\n\r\n\r\nSELECT                   \r\n                                b.CEC_ID AS CEC_ID,\r\n                                'SALES' AS HIER_TYPE_DESCR\r\n                                ,MAX(CASE        B.IAM_LEVEL_NUM    WHEN    0 THEN '1' ELSE         '0' END)          AS LEVEL_0_FLG \r\n                                ,MAX(CASE        B.IAM_LEVEL_NUM    WHEN    1 THEN '1' ELSE         '0' END)          AS LEVEL_1_FLG                  \r\n                                ,MAX(CASE        B.IAM_LEVEL_NUM    WHEN    2 THEN '1' ELSE         '0' END)          AS LEVEL_2_FLG                  \r\n                                ,MAX(CASE        B.IAM_LEVEL_NUM    WHEN    3 THEN '1' ELSE         '0' END)          AS LEVEL_3_FLG                                                 \r\n                                ,MAX(CASE        B.IAM_LEVEL_NUM    WHEN    4 THEN '1' ELSE         '0' END)          AS LEVEL_4_FLG                  \r\n                                ,MAX(CASE        B.IAM_LEVEL_NUM    WHEN    5 THEN '1' ELSE         '0' END)          AS LEVEL_5_FLG\r\n                                ,MAX(CASE        B.IAM_LEVEL_NUM    WHEN    6 THEN '1' ELSE         '0' END)          AS LEVEL_6_FLG\r\n\t\t\t\t\t\t\t\t,'0' LEVEL_7_FLG\r\n                                ,'0' LEVEL_8_FLG\r\n                                ,'0' LEVEL_9_FLG\r\n                                ,'0' LEVEL_10_FLG\r\n                                ,MAX ( B.IAM_LEVEL_NUM ) AS MAX_LVL_CD\r\n                                ,CASE    WHEN  MIN(iam_level_num) IS NULL THEN 0  ELSE MIN(iam_level_num)    END       AS MIN_LVL_CD\r\n\r\nFROM (\r\nSEL\tNIU.DD_CEC_ID AS CEC_ID ,\r\n\t\tSALES_TERR.DD_SALES_TERRITORY_DESCR AS SALES_TERR_DESCR,\r\n        SALES_TERR.ASSIGNMENT_TYPE AS ASSIGNMENT_TYPE,\r\n        SALES_TERR.DD_BK_SALES_HIER_TYPE_CD AS SALES_HIER_TYPE_CD,\r\n\t\tAPP.APPLICATION_NAME AS APPLICATION_NAME,\r\n        SALES_TERR.IAM_LEVEL_NUM_INT IAM_LEVEL_NUM\t\t\r\n\t\tFROM $$SECURITYVWDB.N_IAM_SALES_TERR_LNK SALES_TERR,\r\n\t $$SECURITYVWDB.N_IAM_APPLICATION APP,\r\n\t $$SECURITYVWDB.N_IAM_USER NIU\r\n\tWHERE \r\n\t SALES_TERR.IAM_APPLICATION_KEY = APP.IAM_APPLICATION_KEY \r\n\t \r\n\tAND\t\r\n\t NIU.IAM_USER_KEY =  SALES_TERR.IAM_USER_KEY\r\n\t \r\n\tAND\tSALES_TERR.SOURCE_DELETED_FLG            = 'N'\r\n\t \r\n\tAND\t APPLICATION_NAME='Finance BI Dashboard' ) B\r\nWHERE  B.ASSIGNMENT_TYPE = 'Visibility' \r\nAND       B.SALES_HIER_TYPE_CD = 'CORP. REVENUE' \r\nAND       B.APPLICATION_NAME = 'Finance BI Dashboard' \r\nGROUP BY B.CEC_ID\r\nUNION ALL\r\nSELECT \r\n                                'GENERIC' AS CEC_ID,\r\n                                'SALES' AS HIER_TYPE_DESCR\r\n                                ,'0' AS LEVEL_0_FLG\r\n                                ,'0' AS LEVEL_1_FLG\r\n                                ,'0' AS LEVEL_2_FLG\r\n                                ,'0' AS LEVEL_3_FLG\r\n                                ,'0' AS LEVEL_4_FLG\r\n                                ,'0' AS LEVEL_5_FLG\r\n                                ,'0' AS LEVEL_6_FLG\r\n                                ,'0' LEVEL_7_FLG\r\n                                ,'0' LEVEL_8_FLG\r\n                                ,'0' LEVEL_9_FLG\r\n                                ,'0' LEVEL_10_FLG\r\n                                ,0 AS MAX_LVL_CD\r\n                                ,0 AS MIN_LVL_CD\r\nFROM  $$COMREFVWDB.R_DUAL\r\n\r\nUNION ALL\r\n\r\n\r\n\r\n\r\nSELECT \r\nb.cec_id AS cec_id,\r\n'BE' AS HIER_TYPE_DESCR\r\n,MAX(CASE B.IAM_LEVEL_NUM WHEN 0 THEN '1' ELSE '0' END) AS LEVEL_0_FLG\r\n,MAX(CASE B.IAM_LEVEL_NUM WHEN 1 THEN '1' ELSE '0' END) AS LEVEL_1_FLG\r\n,MAX(CASE B.IAM_LEVEL_NUM WHEN 2 THEN '1' ELSE '0' END) AS LEVEL_2_FLG\r\n,MAX(CASE B.IAM_LEVEL_NUM WHEN 3 THEN '1' ELSE '0' END) AS LEVEL_3_FLG\r\n,MAX(CASE B.IAM_LEVEL_NUM WHEN 4 THEN '1' ELSE '0' END) AS LEVEL_4_FLG\r\n,'0' LEVEL_5_FLG\r\n,'0' LEVEL_6_FLG\r\n,'0' LEVEL_7_FLG\r\n,'0' LEVEL_8_FLG\r\n,'0' LEVEL_9_FLG\r\n,'0' LEVEL_10_FLG\r\n,MAX (B.IAM_LEVEL_NUM) AS MAX_LVL_CD\r\n\t\t,CASE\tWHEN  MIN(iam_level_num) IS NULL THEN 0  ELSE MIN(iam_level_num) \tEND\tAS MIN_LVL_CD\r\n\r\nFROM (SELECT  \r\n\t   HIER.ASSIGNMENT_TYPE_CD  AS ASSIGNMENT_TYPE_CD \r\n      ,HIER.BUSINESS_ENTITY_HIER_TYPE_CD        \t\t  \r\n\t  ,HIER.IAM_LEVEL_NUM_INT  AS IAM_LEVEL_NUM           \r\n\t  ,NIU.DD_CEC_ID AS CEC_ID\r\n\t  ,APP.APPLICATION_NAME AS APPLICATION_NAME\r\n\t\r\n\tFROM\r\n\t\r\n\t(SELECT \r\n\t   BK_IAM_ROLE_NAME              \r\n\t  ,BE.IAM_APPLICATION_KEY           \r\n\t  ,BK_BUSINESS_ENTITY_NAME  AS BUSINESS_ENTITY_HIER_NAME\r\n\t  ,BK_BUSINESS_ENTITY_TYPE_CD  AS BUSINESS_ENTITY_HIER_TYPE_CD      \r\n\t  ,ASSIGNMENT_TYPE_CD               \r\n\t  ,STANDARD_OR_EXCEPTION_FLG     \r\n\t  ,EXCLUSIVE_OR_RESTRICTIVE_FLG  \r\n\t  ,IAM_LEVEL_NUM_INT             \r\n\t  ,IAM_USER_KEY\r\n\tFROM\r\n\t$$SECURITYVWDB.N_IAM_BUSINESS_ENTITY_LINK BE\r\n\tWHERE  BE.SOURCE_DELETED_FLG='N'\r\n\tUNION ALL\r\n\tSELECT\r\n\t  BK_IAM_ROLE_NAME\r\n\t  ,SBE.IAM_APPLICATION_KEY\r\n\t  ,BK_SUB_BUSINESS_ENTITY_NAME  AS BUSINESS_ENTITY_HIER_NAME\r\n\t  ,BK_BUSINESS_ENTITY_TYPE_CD  AS BUSINESS_ENTITY_HIER_TYPE_CD  \r\n\t  ,ASSIGNMENT_TYPE_CD            \r\n\t  ,STANDARD_OR_EXCEPTION_FLG\r\n\t  ,EXCLUSIVE_OR_RESTRICTIVE_FLG\r\n\t  ,IAM_LEVEL_NUM_INT\r\n\t  ,IAM_USER_KEY\r\n\t  FROM\r\n\t$$SECURITYVWDB.N_IAM_SUB_BUSINESS_ENTITY_LINK  SBE\r\n\tWHERE  SBE.SOURCE_DELETED_FLG='N'\r\n\t) \r\n\t HIER,\r\n\t  $$SECURITYVWDB.N_IAM_APPLICATION APP,\r\n\t  $$SECURITYVWDB.N_IAM_USER NIU\r\n\tWHERE\r\n\t          HIER.IAM_APPLICATION_KEY = APP.IAM_APPLICATION_KEY\r\n\tAND NIU.IAM_USER_KEY =  HIER.IAM_USER_KEY\r\n\tAND NIU.SOURCE_DELETED_FLG = 'N'\r\n AND  APPLICATION_NAME = 'Finance BI Dashboard'\r\n\tAND BUSINESS_ENTITY_HIER_TYPE_CD='I') B\r\nWHERE   B.ASSIGNMENT_TYPE_CD = 'Visibility' \r\nAND B.APPLICATION_NAME = 'Finance BI Dashboard'\r\nGROUP BY b.cec_id\r\nUNION ALL\r\nSELECT \r\n\t\t'GENERIC' AS CEC_ID\r\n\t\t,'BE' AS HIER_TYPE_DESCR\r\n\t\t,'0' AS LEVEL_0_FLG\r\n\t\t,'0' AS LEVEL_1_FLG\r\n\t\t,'0' AS LEVEL_2_FLG\r\n\t\t,'0' LEVEL_3_FLG\r\n\t\t,'0' LEVEL_4_FLG\r\n\t\t,'0' LEVEL_5_FLG\r\n\t\t,'0' LEVEL_6_FLG\r\n\t\t,'0' LEVEL_7_FLG\r\n\t\t,'0' LEVEL_8_FLG\r\n\t\t,'0' LEVEL_9_FLG\r\n\t\t,'0' LEVEL_10_FLG\r\n\t\t,0 AS MAX_LVL_CD\r\n\t\t,0 AS MIN_LVL_CD\r\nFROM  $$COMREFVWDB.R_DUAL\r\n) FNL_QRY",
