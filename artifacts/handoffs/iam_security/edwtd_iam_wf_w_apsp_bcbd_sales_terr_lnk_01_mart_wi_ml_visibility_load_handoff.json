      "attributes": {
        "Sql Query": "SELECT\tBCBD_USER_KEY, BK_IAM_ROLE_NAME, IAM_APPLICATION_KEY, SALES_TERRITORY_KEY,\r\n\t\tCAST(BK_FISCAL_YEAR_NUMBER_INT AS VARCHAR(4) )  BK_FISCAL_YEAR_NUM,STANDARD_OR_EXCEPTION_FLG,IAM_LEVEL_NUM_INT,\r\n BICAFE_ROLE_NAME, CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCOALESCE(BK_SALES_TERR_ASSGNMNT_TYPE_CD,'DR'),\r\n 'I'    ACTION_CODE,\r\n'I'  DML_TYPE  \r\nFROM\t\r\n(\r\nSELECT\tBCBD_USER_KEY, BK_IAM_ROLE_NAME ,TERR_LNK. IAM_APPLICATION_KEY,\r\n\t\tSALES_TERRITORY_KEY, STANDARD_OR_EXCEPTION_FLG,IAM_LEVEL_NUM_INT,\r\nBK_IAM_ROLE_NAME  BICAFE_ROLE_NAME, CURRENT_DATE  CURR_DATE,TERR_LNK.BK_SALES_TERR_ASSGNMNT_TYPE_CD\r\nFROM\t$$SECURITYVWDB.N_IAM_SALES_TERR_LNK  TERR_LNK\r\nINNER JOIN $$TRANSLATIONDB.SM_APSP_BCBD_USER  SM\r\nON SM.IAM_USER_KEY=TERR_LNK.IAM_USER_KEY AND TERR_LNK.SOURCE_DELETED_FLG='N'\r\nINNER JOIN $$SECURITYVWDB.N_IAM_APPLICATION APP\r\n\tON\tAPP.IAM_APPLICATION_KEY=TERR_LNK.IAM_APPLICATION_KEY \r\n\tAND\tAPPLICATION_NAME='BI Cafe-2'\r\n WHERE\t  NOT  (IAM_LEVEL_NUM_INT = 0 \r\n\tOR\t( STANDARD_OR_EXCEPTION_FLG='S'  AND BK_IAM_ROLE_NAME LIKE  '%IBOT%'))) ST\r\n INNER JOIN $$COMREFVWDB.N_FISCAL_YEAR\r\n\tON\tCURR_DATE BETWEEN FISCAL_YEAR_START_DATE \r\n\tAND\tFISCAL_YEAR_END_DATE\r\n\r\nUNION \r\n\r\nSEL  SM.BCBD_USER_KEY,  SUBROLE_NAME, APP.IAM_APPLICATION_KEY, SALES_TERRITORY_KEY, \r\nFISCAL_YEAR, 'E'  STANDARD_OR_EXCEPTION_FLG, MIN_LEVEL, ROLE_NAME, CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCOALESCE(ST.BK_SALES_TERR_ASSGNMNT_TYPE_CD,'DR'),\r\n 'I'    ACTION_CODE,\r\n'I'  DML_TYPE\r\nFROM  $$STGDB.WI_USER_VISIBILITY_LOAD ST\r\nINNER JOIN  $$COMREFVWDB.N_SALES_TERRITORY_TV TERR\r\nON ST.TERRITORY_CODE=TERR.SALES_TERRITORY_DESCR  \r\nINNER JOIN  $$COMREFVWDB.N_FISCAL_MONTH  FIS_MTH\r\nON BK_FISCAL_YEAR_NUMBER_INT=ST.FISCAL_YEAR AND \r\nFISCAL_MONTH_END_DATE BETWEEN TERR.START_TV_DATE AND TERR.END_TV_DATE  AND BK_FISCAL_MONTH_NUMBER_INT=12\r\nINNER JOIN $$SECURITYVWDB.N_IAM_USER NIU\r\nON NIU.DD_CEC_ID = ST.USER_ID AND NIU.SOURCE_DELETED_FLG='N'\r\nINNER JOIN $$TRANSLATIONDB.SM_APSP_BCBD_USER  SM\r\nON NIU.IAM_USER_KEY=SM.IAM_USER_KEY\r\nINNER JOIN $$SECURITYVWDB.N_IAM_APPLICATION APP\r\n\tON\tAPP.SK_APPLICATION_ID_INT=1388\r\nWHERE  MIN_LEVEL <> 7\r\n\r\nUNION \r\n\r\nSEL SM.BCBD_USER_KEY, SUBROLE_NAME, APP.IAM_APPLICATION_KEY,\r\nSALES_TERRITORY_KEY, \r\nFISCAL_YEAR, 'E'  STANDARD_OR_EXCEPTION_FLG, MIN_LEVEL, ROLE_NAME, CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCOALESCE(ST.BK_SALES_TERR_ASSGNMNT_TYPE_CD,'DR'),\r\n 'I'    ACTION_CODE,\r\n'I'  DML_TYPE\r\nFROM $$STGDB.WI_ML_VISIBILITY_LOAD ST\r\nINNER JOIN $$TRANSLATIONDB.SM_APSP_BCBD_USER  SM\r\nON ST.USER_ID=SM.BK_BCBD_MAILER_ALIAS_ADDR\r\nINNER JOIN  $$COMREFVWDB.N_SALES_TERRITORY TERR\r\nON ST.TERRITORY_CODE=TERR.SALES_TERRITORY_DESCR\r\nINNER JOIN $$SECURITYVWDB.N_IAM_APPLICATION APP\r\nON\tAPP.SK_APPLICATION_ID_INT=1388",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
