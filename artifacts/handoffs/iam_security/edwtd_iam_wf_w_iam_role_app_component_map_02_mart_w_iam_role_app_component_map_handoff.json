      "attributes": {
        "Sql Query": "SELECT \r\nOUTPUT.BK_IAM_ROLE_NAME,\r\nOUTPUT.IAM_APPLICATION_KEY,\r\nOUTPUT.IAM_APPLICATION_COMPONENT_KEY,\r\nOUTPUT.SOURCE_DELETED_FLG,\r\nOUTPUT.EDW_CREATE_USER,\r\nOUTPUT.EDW_CREATE_DTM,\r\nOUTPUT.EDW_UPDATE_USER,\r\nOUTPUT.EDW_UPDATE_DTM,\r\nOUTPUT.ACTION_CODE,\r\nOUTPUT.DML_TYPE\r\nFROM(\r\nSELECT \r\nDT.BK_IAM_ROLE_NAME,\r\nDT.IAM_APPLICATION_KEY,\r\nDT.IAM_APPLICATION_COMPONENT_KEY,\r\nDT.SOURCE_DELETED_FLG,\r\nDT.EDW_CREATE_USER,\r\nDT.EDW_CREATE_DTM,\r\nDT.EDW_UPDATE_USER,\r\nDT.EDW_UPDATE_DTM,\r\nDT.ACTION_CODE,\r\nDT.DML_TYPE,\r\nDT.UPDATE_DATE\r\nFROM(\r\nSEL\r\nSIEURA.ROLE_NAME AS BK_IAM_ROLE_NAME,\r\nSIA.IAM_APPLICATION_KEY AS IAM_APPLICATION_KEY,\r\nSIAC.IAM_APPLICATION_COMPONENT_KEY AS IAM_APPLICATION_COMPONENT_KEY,\r\nCASE\r\nWHEN \r\nSIEURA.STATUS = 'A' THEN 'N' \r\nELSE 'Y'\r\nEND SOURCE_DELETED_FLG,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n'I' ACTION_CODE,\r\n CASE WHEN NIRAC.BK_IAM_ROLE_NAME IS NOT NULL AND  \r\n NIRAC.IAM_APPLICATION_KEY IS NOT NULL AND\r\n NIRAC.IAM_APPLICATION_COMPONENT_KEY IS NOT NULL\r\n THEN 'U' ELSE 'I' END DML_TYPE,\r\n SIEURA.UPDATE_DATE\r\nFROM \r\n$$STGDB.ST_IAM_EDWTD_USR_ROLE_APP SIEURA\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (SIEURA.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nINNER JOIN $$SECURITYVWDB.N_IAM_ROLE NIR\r\nON NIR.BK_IAM_ROLE_NAME = SIEURA.ROLE_NAME\r\nINNER JOIN $$ETLVWDB.SM_IAM_APPLICATION SIA\r\nON SIA.SK_APPLICATION_ID_INT=SIEURA.TOOL_ID\r\nINNER JOIN $$ETLVWDB.SM_IAM_APPLICATION_COMPONENT SIAC\r\nON SIAC.SK_APP_COMPONENT_ID_INT = SIEURA.APP_RES_ID\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_ROLE_APP_COMPONENT_MAP NIRAC\r\nON (NIRAC.BK_IAM_ROLE_NAME = SIEURA.ROLE_NAME \r\nAND NIRAC.IAM_APPLICATION_KEY = SIA.IAM_APPLICATION_KEY \r\nAND NIRAC.IAM_APPLICATION_COMPONENT_KEY = SIAC.IAM_APPLICATION_COMPONENT_KEY)\r\nUNION ALL\r\nSEL\r\nEIEURAC.ROLE_NAME AS BK_IAM_ROLE_NAME,\r\nSIA.IAM_APPLICATION_KEY AS IAM_APPLICATION_KEY,\r\nSIAC.IAM_APPLICATION_COMPONENT_KEY AS IAM_APPLICATION_COMPONENT_KEY,\r\nCASE\r\nWHEN\r\nEIEURAC.STATUS = 'A' THEN 'N'\r\nELSE 'Y'\r\nEND SOURCE_DELETED_FLG,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n'I' ACTION_CODE,\r\n CASE WHEN NIRAC.BK_IAM_ROLE_NAME IS NOT NULL AND  \r\n NIRAC.IAM_APPLICATION_KEY IS NOT NULL AND\r\n NIRAC.IAM_APPLICATION_COMPONENT_KEY IS NOT NULL\r\n THEN 'U' ELSE 'I' END DML_TYPE,\r\n EIEURAC.UPDATE_DATE\r\nFROM \r\n$$EXCEPDB.EX_IAM_EDWTD_USR_ROLE_APP_CM EIEURAC\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (EIEURAC.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nINNER JOIN $$SECURITYVWDB.N_IAM_ROLE NIR\r\nON NIR.BK_IAM_ROLE_NAME = EIEURAC.ROLE_NAME\r\nINNER JOIN $$ETLVWDB.SM_IAM_APPLICATION SIA\r\nON SIA.SK_APPLICATION_ID_INT=EIEURAC.TOOL_ID\r\nINNER JOIN $$ETLVWDB.SM_IAM_APPLICATION_COMPONENT SIAC\r\nON SIAC.SK_APP_COMPONENT_ID_INT=EIEURAC.APP_RES_ID\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_ROLE_APP_COMPONENT_MAP NIRAC\r\nON (NIRAC.BK_IAM_ROLE_NAME = EIEURAC.ROLE_NAME \r\nAND NIRAC.IAM_APPLICATION_KEY = SIA.IAM_APPLICATION_KEY \r\nAND NIRAC.IAM_APPLICATION_COMPONENT_KEY = SIAC.IAM_APPLICATION_COMPONENT_KEY)\r\n)DT\r\n)OUTPUT \r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY OUTPUT.BK_IAM_ROLE_NAME,\r\nOUTPUT.IAM_APPLICATION_KEY,OUTPUT.IAM_APPLICATION_COMPONENT_KEY ORDER BY OUTPUT.UPDATE_DATE DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
