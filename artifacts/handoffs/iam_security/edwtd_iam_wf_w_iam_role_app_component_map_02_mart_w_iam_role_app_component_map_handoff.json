      "attributes": {
        "Sql Query": "SEL\r\nIAM_USER_ID,\r\nROLE_ID,\r\nROLE_NAME,\r\nSIEURA.TOOL_ID,\r\nAPP_RES_ID,\r\nAPP_RES_VAL,\r\nAPP_RES_PATH,\r\nPROXY_FLAG,\r\nGRANTOR_UNIVERSAL_ID,\r\nGRANTOR_CEC_ID,\r\nGRANTOR_CCO_ID,\r\nSIEURA.STATUS,\r\nTR_FLAG,\r\nLAST_ACTION,\r\nCREATED_BY,\r\nSIEURA.CREATE_DATE,\r\nUPDATED_BY,\r\nSIEURA.UPDATE_DATE,\r\nACTION_CODE,\r\nBATCH_ID,CREATE_DATETIME,\r\n'RI' EXCEPTION_TYPE\r\nFROM $$STGDB.ST_IAM_EDWTD_USR_ROLE_APP SIEURA\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (SIEURA.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nWHERE NOT EXISTS (SELECT 1 FROM $$SECURITYVWDB.N_IAM_ROLE NIR\r\nWHERE SIEURA.ROLE_NAME=NIR.BK_IAM_ROLE_NAME)\r\nOR NOT EXISTS(SELECT 1 FROM $$ETLVWDB.SM_IAM_APPLICATION SIA\r\nWHERE SIA.SK_APPLICATION_ID_INT=SIEURA.TOOL_ID)\r\nOR NOT EXISTS(SELECT 1 FROM $$ETLVWDB.SM_IAM_APPLICATION_COMPONENT SIAC\r\nWHERE SIAC.SK_APP_COMPONENT_ID_INT=SIEURA.APP_RES_ID)",
