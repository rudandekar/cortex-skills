      "attributes": {
        "Sql Query": "SELECT \r\nOUTPUT.BK_APPLICATION_ATTRIBUTE_NAME,\r\nOUTPUT.BK_IAM_ROLE_NAME,\r\nOUTPUT.IAM_APPLICATION_KEY,\r\nOUTPUT.BK_ROLE_ATTRIBUTE_VALUE_NAME,\r\nOUTPUT.SOURCE_DELETED_FLG,\r\nOUTPUT.EDW_CREATE_USER,\r\nOUTPUT.EDW_CREATE_DTM,\r\nOUTPUT.EDW_UPDATE_USER,\r\nOUTPUT.EDW_UPDATE_DTM,\r\nOUTPUT.ACTION_CODE,\r\nOUTPUT.DML_TYPE\r\nFROM\r\n(\r\nSELECT \r\nDT.BK_APPLICATION_ATTRIBUTE_NAME,\r\nDT.BK_IAM_ROLE_NAME,\r\nDT.IAM_APPLICATION_KEY,\r\nDT.BK_ROLE_ATTRIBUTE_VALUE_NAME,\r\nDT.SOURCE_DELETED_FLG,\r\nDT.EDW_CREATE_USER,\r\nDT.EDW_CREATE_DTM,\r\nDT.EDW_UPDATE_USER,\r\nDT.EDW_UPDATE_DTM,\r\nDT.ACTION_CODE,\r\nDT.DML_TYPE,\r\nDT.UPDATE_DATE\r\nFROM\r\n(\r\nSELECT\r\nA.BK_APPLICATION_ATTRIBUTE_NAME,\r\nSIERT.ROLE_NAME  AS BK_IAM_ROLE_NAME,\r\nSIA.IAM_APPLICATION_KEY AS IAM_APPLICATION_KEY,\r\nA.BK_ROLE_ATTRIBUTE_VALUE_NAME,\r\nCASE WHEN  SIERT.STATUS='A' THEN 'N' \r\nELSE 'Y'    END SOURCE_DELETED_FLG,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NIRAT.BK_APPLICATION_ATTRIBUTE_NAME IS NOT NULL AND \r\nNIRAT.BK_IAM_ROLE_NAME IS NOT NULL AND NIRAT.IAM_APPLICATION_KEY IS NOT NULL AND\r\nNIRAT.BK_ROLE_ATTRIBUTE_VALUE_NAME IS NOT NULL THEN 'U' ELSE 'I' END DML_TYPE,\r\nSIERT.UPDATE_DATE\r\nFROM $$STGDB.ST_IAM_EDWTD_ROLE_TOOL  SIERT\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON ( SIERT.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A' )\r\nINNER JOIN $$ETLVWDB.SM_IAM_APPLICATION SIA\r\nON SIERT.TOOL_ID=SIA.SK_APPLICATION_ID_INT\r\nINNER JOIN $$SECURITYVWDB.N_IAM_ROLE NIR\r\nON SIERT.ROLE_NAME=NIR.BK_IAM_ROLE_NAME\r\nINNER JOIN\r\n(SEL ROLE_NAME,TYPE_NAME_1 AS  BK_APPLICATION_ATTRIBUTE_NAME ,\r\nTYPE_VAL_NAME_1 AS  BK_ROLE_ATTRIBUTE_VALUE_NAME \r\nFROM $$STGDB.ST_IAM_EDWTD_ROLE_TOOL  ROLE_TOOL\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON ROLE_TOOL.TOOL_ID=IAC.TOOL_ID \r\nAND IAC.STATUS ='A'\r\nAND (ROLE_TOOL.TYPE_NAME_1 IS NOT NULL OR ROLE_TOOL.TYPE_VAL_NAME_1 IS NOT NULL)\r\nUNION \r\nSEL ROLE_NAME, TYPE_NAME_2 AS BK_APPLICATION_ATTRIBUTE_NAM ,\r\nTYPE_VAL_NAME_1 AS  BK_ROLE_ATTRIBUTE_VALUE_NAME\r\nFROM $$STGDB.ST_IAM_EDWTD_ROLE_TOOL  ROLE_TOOL\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON ROLE_TOOL.TOOL_ID=IAC.TOOL_ID \r\nAND IAC.STATUS ='A'\r\nAND (ROLE_TOOL.TYPE_NAME_2 IS NOT NULL OR ROLE_TOOL.TYPE_VAL_NAME_2 IS NOT NULL)\r\n) A\r\nON\r\nSIERT.ROLE_NAME = A.ROLE_NAME\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_ROLE_APP_ATTRIBUTE\tNIRAT\r\nON NIRAT.BK_APPLICATION_ATTRIBUTE_NAME=A.BK_APPLICATION_ATTRIBUTE_NAME\r\nAND NIRAT.BK_IAM_ROLE_NAME=SIERT.ROLE_NAME\r\nAND NIRAT.IAM_APPLICATION_KEY=SIA.IAM_APPLICATION_KEY\r\nAND NIRAT.BK_ROLE_ATTRIBUTE_VALUE_NAME=A.BK_ROLE_ATTRIBUTE_VALUE_NAME\r\nUNION ALL\r\nSELECT\r\nA.BK_APPLICATION_ATTRIBUTE_NAME,\r\nEIERTAR.ROLE_NAME  AS BK_IAM_ROLE_NAME,\r\nSIA.IAM_APPLICATION_KEY AS IAM_APPLICATION_KEY,\r\nA.BK_ROLE_ATTRIBUTE_VALUE_NAME,\r\nCASE WHEN  EIERTAR.STATUS='A' THEN 'N' \r\nELSE 'Y'    END SOURCE_DELETED_FLG,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NIRAT.BK_APPLICATION_ATTRIBUTE_NAME IS NOT NULL AND \r\nNIRAT.BK_IAM_ROLE_NAME IS NOT NULL AND NIRAT.IAM_APPLICATION_KEY IS NOT NULL AND\r\nNIRAT.BK_ROLE_ATTRIBUTE_VALUE_NAME IS NOT NULL THEN 'U' ELSE 'I' END DML_TYPE,\r\nEIERTAR.UPDATE_DATE\r\nFROM $$EXCEPDB.EX_IAM_EDWTD_ROLE_TOOL_ATTR_R  EIERTAR\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON ( EIERTAR.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A' )\r\nINNER JOIN $$ETLVWDB.SM_IAM_APPLICATION SIA\r\nON EIERTAR.TOOL_ID=SIA.SK_APPLICATION_ID_INT\r\nINNER JOIN $$SECURITYVWDB.N_IAM_ROLE NIR\r\nON EIERTAR.ROLE_NAME=NIR.BK_IAM_ROLE_NAME\r\nINNER JOIN\r\n(SEL ROLE_NAME,TYPE_NAME_1 AS  BK_APPLICATION_ATTRIBUTE_NAME,\r\nTYPE_VAL_NAME_1 AS  BK_ROLE_ATTRIBUTE_VALUE_NAME  \r\nFROM $$EXCEPDB.EX_IAM_EDWTD_ROLE_TOOL_ATTR_R  ROLE_TOOL\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON ROLE_TOOL.TOOL_ID=IAC.TOOL_ID \r\nAND IAC.STATUS ='A'\r\nAND (ROLE_TOOL.TYPE_NAME_1 IS NOT NULL OR ROLE_TOOL.TYPE_VAL_NAME_1 IS NOT NULL)\r\nUNION \r\nSEL ROLE_NAME, TYPE_NAME_2 AS BK_APPLICATION_ATTRIBUTE_NAM ,\r\nTYPE_VAL_NAME_2 AS  BK_ROLE_ATTRIBUTE_VALUE_NAME\r\nFROM $$EXCEPDB.EX_IAM_EDWTD_ROLE_TOOL_ATTR_R  ROLE_TOOL\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON ROLE_TOOL.TOOL_ID=IAC.TOOL_ID \r\nAND IAC.STATUS ='A'\r\nAND (ROLE_TOOL.TYPE_NAME_2 IS NOT NULL OR ROLE_TOOL.TYPE_VAL_NAME_2 IS NOT NULL)\r\n) A\r\nON\r\nEIERTAR.ROLE_NAME = A.ROLE_NAME\r\nLEFT OUTER JOIN $$SECURITYVWDB. N_IAM_ROLE_APP_ATTRIBUTE\tNIRAT\r\nON NIRAT.BK_APPLICATION_ATTRIBUTE_NAME=A.BK_APPLICATION_ATTRIBUTE_NAME\r\nAND NIRAT.BK_IAM_ROLE_NAME=EIERTAR.ROLE_NAME\r\nAND NIRAT.IAM_APPLICATION_KEY=SIA.IAM_APPLICATION_KEY\r\nAND NIRAT.BK_ROLE_ATTRIBUTE_VALUE_NAME=A.BK_ROLE_ATTRIBUTE_VALUE_NAME\r\n)DT\r\n)OUTPUT \r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY OUTPUT.BK_APPLICATION_ATTRIBUTE_NAME,\r\nOUTPUT.BK_IAM_ROLE_NAME,OUTPUT.IAM_APPLICATION_KEY,OUTPUT.BK_ROLE_ATTRIBUTE_VALUE_NAME ORDER BY OUTPUT.UPDATE_DATE DESC) = 1",
        "User Defined Join": "",
