      "attributes": {
        "Sql Query": "SELECT \r\nSIU.IAM_USER_KEY AS IAM_USER_KEY,\r\nCOALESCE(SIUV.UNIVERSAL_ID,-999) AS BK_CPR_UNIVERSAL_ID_INT,\r\nNULL AS INTERNAL_ROLE,\r\nNULL AS CCO_ID,\r\nNULL AS EXTERNAL_ROLE,\r\nCASE WHEN SIUV.IAM_STATUS='A'\r\nTHEN 'N'\r\nWHEN SIUV.IAM_STATUS='I'\r\nTHEN 'Y'\r\nEND SOURCE_DELETED_FLG,\r\nNULL AS RU_EXTERNAL_USER_EMAIL_ADDR,\r\nNULL AS RU_CISCO_WORKER_PARTY_KEY,\r\nNULL AS DD_CEC_ID,\r\n'D' AS DD_BK_WORKER_TYPE_CD,\r\nSIUV.IAM_USER_ID AS SK_IAM_USER_ID_INT,\r\nCASE WHEN SIUV.CPR_ACCESS_LEVEL=4 AND SIUV.CEC_ID = SIUV.CCO_ID\r\nTHEN 'Y'\r\nWHEN SIUV.CPR_ACCESS_LEVEL=4 AND SIUV.CEC_ID <> SIUV.CCO_ID\r\nTHEN 'N'\r\nWHEN SIUV.CPR_ACCESS_LEVEL<>4\r\nTHEN 'Y'\r\nEND RU_EXTERNAL_FLG, \r\nCASE WHEN SIUV.CPR_ACCESS_LEVEL=4\r\nTHEN 'Y'\r\nELSE 'N'\r\nEND RU_INTERNAL_FLG,\r\nCASE WHEN SIUV.CPR_ACCESS_LEVEL=4 \r\nTHEN SIUV.CEC_ID\r\nELSE\r\nSIUV.CCO_ID\r\nEND RU_IAM_DUMMY_USER_NAME,\r\n'Y' DUMMY_USER_ROLE,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nSIUV.LOG_LEVEL  AS LOGGING_LEVEL_CD,\r\n'I' ACTION_CODE,\r\nCASE WHEN NIU.IAM_USER_KEY IS NOT NULL THEN 'U' ELSE 'I' END DML_TYPE\r\nFROM\r\n$$STGDB.ST_IAM_EDWTD_USER_DUMMY SIUV\r\nINNER JOIN\r\n$$ETLVWDB.SM_IAM_USER SIU\r\nON SIUV.IAM_USER_ID= SIU.SK_IAM_USER_ID_INT\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_USER NIU\r\nON NIU.IAM_USER_KEY = SIU.IAM_USER_KEY",
        "User Defined Join": "",
        "Source Filter": "",
