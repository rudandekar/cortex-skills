      "attributes": {
        "Sql Query": "SELECT\r\nOUTPUT.ROLE_NAME,\r\nOUTPUT.DESCRIPTION,\r\nOUTPUT.ROLE_CATEGORY,\r\nOUTPUT.SOURCE_DELETED_FLG,\r\nOUTPUT.EDW_CREATE_USER,\r\nOUTPUT.EDW_CREATE_DTM,\r\nOUTPUT.EDW_UPDATE_USER,\r\nOUTPUT.EDW_UPDATE_DTM,\r\nOUTPUT.ACTION_CODE,\r\nOUTPUT.DML_TYPE\r\nFROM\r\n(SELECT  \r\nSIR.ROLE_NAME,\r\nSIR.DESCRIPTION,\r\nSIR.ROLE_CATEGORY,\r\nCASE\r\n\tWHEN\t\r\n\t\tSIR.STATUS = 'A' THEN 'N' \r\n\tWHEN\tSIR.STATUS = 'I' THEN 'Y'\r\n\tELSE\r\n\t'='\r\nEND\tSOURCE_DELETED_FLG,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n'I' ACTION_CODE,\r\n CASE WHEN NIR.BK_IAM_ROLE_NAME IS NOT NULL THEN 'U' ELSE 'I' END DML_TYPE,\r\n SIR.UPDATE_DATE\r\nFROM\r\n$$STGDB.ST_IAM_EDWTD_ROLE_TOOL SIR\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (SIR.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_ROLE NIR\r\nON NIR.BK_IAM_ROLE_NAME = SIR.ROLE_NAME\r\n)OUTPUT\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY OUTPUT.ROLE_NAME ORDER BY OUTPUT.UPDATE_DATE DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
