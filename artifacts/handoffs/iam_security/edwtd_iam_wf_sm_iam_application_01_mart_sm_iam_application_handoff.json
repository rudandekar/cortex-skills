      "attributes": {
        "Sql Query": "SELECT \r\nRANK() OVER \r\n\t\t\t(ORDER BY \r\n\t\t\t\tSTAPP_BK.SK_APPLICATION_ID_INT) +  SMAPP_MAX.MAX_APP_SGK_VAL  IAM_APPLICATION_KEY,\r\nSTAPP_BK.SK_APPLICATION_ID_INT \t\tSK_APPLICATION_ID_INT,\r\nUSER \t\t\t\t\t\t\t\tEDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) \t\t\t\tEDW_CREATE_DTM\r\nFROM \r\n(\r\nSELECT \r\nDISTINCT STIA.APPLICATION_ID \t\tSK_APPLICATION_ID_INT\r\nFROM \r\n$$STGDB.ST_IAM_EDWTD_APPLICATION STIA\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (STIA.APPLICATION_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\n)  STAPP_BK,\r\n(SELECT COALESCE(MAX(IAM_APPLICATION_KEY),0)  MAX_APP_SGK_VAL\r\n    FROM $$ETLVWDB.SM_IAM_APPLICATION) SMAPP_MAX\r\n\tWHERE NOT EXISTS\r\n\t\t(SELECT 1 FROM $$ETLVWDB.SM_IAM_APPLICATION SIA \r\n\t\t\tWHERE SIA.SK_APPLICATION_ID_INT = STAPP_BK.SK_APPLICATION_ID_INT\r\n\t \t)",
