        "Sql Query": "SELECT\r\nNISTLTV.BK_IAM_ROLE_NAME ,\r\nNISTLTV.SALES_TERRITORY_KEY,           \r\nNISTLTV.IAM_APPLICATION_KEY,      \r\nNISTLTV.IAM_USER_KEY,     \r\nNISTLTV.ASSIGNMENT_TYPE,    \r\nNISTLTV.STANDARD_OR_EXCEPTION_FLG  ,   \r\nNISTLTV.EXCLUSIVE_OR_RESTRICTIVE_FLG,  \r\nNISTLTV.IAM_LEVEL_NUM_INT, \r\nNISTLTV.DD_BK_SALES_HIER_TYPE_CD,\r\nNISTLTV.DD_BK_SALES_TERR_NAME,\r\nNISTLTV.SOURCE_DELETED_FLG ,\r\nNISTLTV.DD_CEC_ID,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nNISTLTV.DD_SALES_TERRITORY_DESCR,\r\nNISTLTV.BK_SALES_TERR_ASSGNMNT_TYPE_CD\r\nFROM  $$SECURITYVWDB.N_IAM_SALES_TERR_LNK_TV NISTLTV\r\nWHERE  NOT EXISTS (SEL 1 FROM $$SECURITYVWDB.N_IAM_SALES_TERR_LNK NISTL\r\nWHERE NISTLTV.BK_IAM_ROLE_NAME = NISTL.BK_IAM_ROLE_NAME\r\nAND NISTLTV.SALES_TERRITORY_KEY = NISTL.SALES_TERRITORY_KEY\r\nAND NISTLTV.IAM_APPLICATION_KEY = NISTL.IAM_APPLICATION_KEY\r\nAND NISTLTV.IAM_USER_KEY = NISTL.IAM_USER_KEY\r\nAND NISTLTV.BK_SALES_TERR_ASSGNMNT_TYPE_CD=NISTL.BK_SALES_TERR_ASSGNMNT_TYPE_CD)\r\nAND NISTLTV.END_TV_DT='3500-01-01'",
