      "attributes": {
        "Sql Query": "SELECT \r\nOUTPUT.IAM_APPLICATION_KEY,\r\nOUTPUT.BK_APPLICATION_ATTRIBUTE_NAME,\r\nOUTPUT.EDW_CREATE_USER,\r\nOUTPUT.EDW_CREATE_DTM,\r\nOUTPUT.EDW_UPDATE_USER,\r\nOUTPUT.EDW_UPDATE_DTM,\r\nOUTPUT.ACTION_CODE,\r\nOUTPUT.DML_TYPE\r\nFROM\r\n(\r\nSELECT \r\nDT.IAM_APPLICATION_KEY,\r\nDT.BK_APPLICATION_ATTRIBUTE_NAME,\r\nDT.EDW_CREATE_USER,\r\nDT.EDW_CREATE_DTM,\r\nDT.EDW_UPDATE_USER,\r\nDT.EDW_UPDATE_DTM,\r\nDT.ACTION_CODE,\r\nDT.DML_TYPE,\r\nDT.UPDATE_DATE\r\nFROM\r\n(\r\nSELECT\r\nSIA.IAM_APPLICATION_KEY AS IAM_APPLICATION_KEY,\r\nA.BK_APPLICATION_ATTRIBUTE_NAME,\r\nUSER AS  EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM, \r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NIAA.IAM_APPLICATION_KEY IS NOT NULL AND  NIAA.BK_APPLICATION_ATTRIBUTE_NAME IS NOT NULL \r\n  THEN 'U'  ELSE 'I' END DML_TYPE,\r\n  SIERT.UPDATE_DATE\r\nFROM $$STGDB.ST_IAM_EDWTD_ROLE_TOOL SIERT \r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (SIERT.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nINNER JOIN $$ETLVWDB.SM_IAM_APPLICATION SIA\r\nON SIERT.TOOL_ID=SIA.SK_APPLICATION_ID_INT\r\nINNER JOIN\r\n(SEL ROLE_NAME,TYPE_NAME_1 AS  BK_APPLICATION_ATTRIBUTE_NAME  \r\nFROM $$STGDB.ST_IAM_EDWTD_ROLE_TOOL  ROLE_TOOL\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON ROLE_TOOL.TOOL_ID=IAC.TOOL_ID \r\nAND IAC.STATUS ='A'\r\nAND ROLE_TOOL.TYPE_NAME_1 IS NOT NULL\r\nUNION \r\nSEL ROLE_NAME, TYPE_NAME_2 AS BK_APPLICATION_ATTRIBUTE_NAM \r\nFROM $$STGDB.ST_IAM_EDWTD_ROLE_TOOL  ROLE_TOOL\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON ROLE_TOOL.TOOL_ID=IAC.TOOL_ID \r\nAND IAC.STATUS ='A'\r\nAND ROLE_TOOL.TYPE_NAME_2 IS NOT NULL\r\n) A\r\nON\r\nSIERT.ROLE_NAME = A.ROLE_NAME\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_APPLICATION_ATTRIBUTE NIAA\r\nON A.BK_APPLICATION_ATTRIBUTE_NAME=NIAA.BK_APPLICATION_ATTRIBUTE_NAME\r\nAND SIA.IAM_APPLICATION_KEY= NIAA.IAM_APPLICATION_KEY\r\n\r\nUNION ALL\r\n\r\nSEL \r\nSIA.IAM_APPLICATION_KEY AS IAM_APPLICATION_KEY,\r\nA.BK_APPLICATION_ATTRIBUTE_NAME,\r\nUSER AS  EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM, \r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NIAA.IAM_APPLICATION_KEY IS NOT NULL AND  NIAA.BK_APPLICATION_ATTRIBUTE_NAME IS NOT NULL \r\n  THEN 'U'  ELSE 'I' END DML_TYPE,\r\n  EIERTA.UPDATE_DATE\r\nFROM $$EXCEPDB.EX_IAM_EDWTD_ROLE_TOOL_ATTR EIERTA\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (EIERTA.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nINNER JOIN $$ETLVWDB.SM_IAM_APPLICATION SIA\r\nON EIERTA.TOOL_ID=SIA.SK_APPLICATION_ID_INT\r\nINNER JOIN\r\n(SEL ROLE_NAME,TYPE_NAME_1 AS  BK_APPLICATION_ATTRIBUTE_NAME  \r\nFROM $$EXCEPDB.EX_IAM_EDWTD_ROLE_TOOL_ATTR  ROLE_TOOL\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON ROLE_TOOL.TOOL_ID=IAC.TOOL_ID \r\nAND IAC.STATUS ='A'\r\nAND ROLE_TOOL.TYPE_NAME_1 IS NOT NULL\r\nUNION \r\nSEL ROLE_NAME, TYPE_NAME_2 AS BK_APPLICATION_ATTRIBUTE_NAM \r\nFROM $$EXCEPDB.EX_IAM_EDWTD_ROLE_TOOL_ATTR  ROLE_TOOL\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON ROLE_TOOL.TOOL_ID=IAC.TOOL_ID \r\nAND IAC.STATUS ='A'\r\nAND ROLE_TOOL.TYPE_NAME_2 IS NOT NULL\r\n) A\r\nON\r\nEIERTA.ROLE_NAME = A.ROLE_NAME\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_APPLICATION_ATTRIBUTE NIAA\r\nON A.BK_APPLICATION_ATTRIBUTE_NAME=NIAA.BK_APPLICATION_ATTRIBUTE_NAME\r\nAND SIA.IAM_APPLICATION_KEY= NIAA.IAM_APPLICATION_KEY\r\n)DT\r\n)OUTPUT \r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY OUTPUT.IAM_APPLICATION_KEY,\r\nOUTPUT.BK_APPLICATION_ATTRIBUTE_NAME ORDER BY OUTPUT.UPDATE_DATE DESC) = 1",
        "User Defined Join": "",
