      "attributes": {
        "Sql Query": "SELECT\r\nSIEBDA.BIZ_DATA_ATTRIB_NAME AS BK_BIZ_DATA_ATTRIBUTE_NAME,\r\nSIEBDA.BIZ_DATA_ATTRIB_DESCR AS BIZ_DATA_ATTRIBUTE_DESCR,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NIBDA.BK_BIZ_DATA_ATTRIBUTE_NAME IS NOT NULL\r\n  THEN 'U'  ELSE 'I' END DML_TYPE\r\nFROM $$STGDB.ST_IAM_EDWTD_BIZ_DATA_ATTRIB SIEBDA\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_BUSINESS_DATA_ATTRIBUTE NIBDA\r\nON NIBDA.BK_BIZ_DATA_ATTRIBUTE_NAME=SIEBDA.BIZ_DATA_ATTRIB_NAME\r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY SIEBDA.BIZ_DATA_ATTRIB_NAME ORDER BY SIEBDA.UPDATE_DATE DESC) = 1",
