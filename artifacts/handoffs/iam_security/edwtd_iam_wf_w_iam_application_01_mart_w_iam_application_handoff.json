      "attributes": {
        "Sql Query": "SELECT \r\nSMIA.IAM_APPLICATION_KEY AS IAM_APPLICATION_KEY,\r\nSIA.TRAINING_REQUIRED AS TRAINING_REQUIRED_FLG,\r\nSIA.APPLICATION_NAME AS APPLICATION_NAME,\r\nSIA.APPLICATION_ID AS SK_APPLICATION_ID,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n'I' ACTION_CODE,\r\n CASE WHEN NIA.IAM_APPLICATION_KEY IS NOT NULL THEN 'U' ELSE 'I' END DML_TYPE\r\nFROM\r\n$$STGDB.ST_IAM_EDWTD_APPLICATION SIA\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (SIA.APPLICATION_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nINNER JOIN \r\n$$ETLVWDB.SM_IAM_APPLICATION SMIA\r\nON SMIA.SK_APPLICATION_ID_INT = SIA.APPLICATION_ID \r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_APPLICATION NIA\r\nON NIA.IAM_APPLICATION_KEY = SMIA.IAM_APPLICATION_KEY",
        "User Defined Join": "",
