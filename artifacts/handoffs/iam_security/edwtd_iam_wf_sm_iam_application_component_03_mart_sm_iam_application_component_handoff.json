      ],
      "attributes": {
        "Sql Query": "SELECT \r\nRANK() OVER \r\n\t\t\t(ORDER BY \r\n\t\t\t\tSTAPP_BK.SK_APP_COMPONENT_ID_INT) +  SMAPP_MAX.MAX_APP_SGK_VAL  IAM_APPLICATION_COMPONENT_KEY,\r\nSTAPP_BK.SK_APP_COMPONENT_ID_INT \t\tSK_APP_COMPONENT_ID_INT,\r\nUSER \t\t\t\t\t\t\t\tEDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) \t\t\t\tEDW_CREATE_DTM\r\nFROM \r\n(\r\nSELECT \r\nDISTINCT STIA.APP_COMPONENT_ID AS SK_APP_COMPONENT_ID_INT\r\nFROM \r\n$$STGDB.ST_IAM_EDWTD_APP_COMPONENT  STIA \r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (STIA.APPLICATION_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nINNER JOIN $$ETLVWDB.SM_IAM_APPLICATION SIA\r\nON SIA.SK_APPLICATION_ID_INT =STIA.APPLICATION_ID\r\n)  STAPP_BK,\r\n(SELECT COALESCE(MAX(IAM_APPLICATION_COMPONENT_KEY),0)  MAX_APP_SGK_VAL\r\n    FROM $$ETLVWDB.SM_IAM_APPLICATION_COMPONENT) SMAPP_MAX\r\n  WHERE NOT EXISTS\r\n\t\t(SELECT 1 FROM $$ETLVWDB.SM_IAM_APPLICATION_COMPONENT SIA \r\n\t\t\tWHERE SIA.SK_APP_COMPONENT_ID_INT = STAPP_BK.SK_APP_COMPONENT_ID_INT\r\n\t \t)\r\n\tAND  NOT EXISTS\r\n\t\t(SELECT 1 FROM  \r\n\t\t\t(SELECT \r\n\t\t\t\tDISTINCT EIC.APP_COMPONENT_ID\t\t\t\t\r\n\t\t \tFROM  \r\n\t\t\t$$EXCEPDB.EX_IAM_EDWTD_APP_COMPONENT EIC  \r\n\t\t\t)  EXCEP_BK\r\n\t\t\tWHERE STAPP_BK.SK_APP_COMPONENT_ID_INT=EXCEP_BK.APP_COMPONENT_ID\r\n\t\t)",
        "User Defined Join": "",
        "Source Filter": "",
