      "attributes": {
        "Sql Query": "SELECT EIC.APPLICATION_ID,\r\n EIC.APP_COMPONENT_ID,\r\n EIC.PAR_APP_COMPONET_ID,\r\n EIC.APP_COMPONENT_NAME,\r\n EIC.APP_COMPONENT_DESCR,\r\n EIC.APP_COMPONENT_TYPE,\r\n EIC.LEAF_BRANCH,\r\n EIC.APP_COMPONENT_STATUS,\r\n EIC.CREATED_BY,\r\n EIC.CREATE_DATE,\r\n EIC.UPDATED_BY,\r\n EIC.UPDATE_DATE,\r\n EIC.ACTION_CODE,\r\n EIC.BATCH_ID,\r\n EIC.CREATE_DATETIME \r\nFROM\r\n $$EXCEPDB.EX_IAM_EDWTD_APP_COMPONENT EIC\r\n WHERE EIC.EXCEPTION_TYPE='RI'\r\nAND NOT EXISTS\r\n(SELECT 1 FROM $$STGDB.ST_IAM_EDWTD_APP_COMPONENT WIC\r\nWHERE WIC.APP_COMPONENT_ID=EIC.APP_COMPONENT_ID)\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY EIC.APP_COMPONENT_ID ORDER BY EIC.CREATE_DATETIME DESC)  =1",
