      "attributes": {
        "Sql Query": "SELECT\r\nOUTPUT.BK_IAM_ROLE_NAME,\r\nOUTPUT.IAM_USER_KEY,\r\nOUTPUT.STANDARD_OR_EXCEPTION_FLG,\r\nOUTPUT.PROXY_ROLE,\r\nOUTPUT.SOURCE_DELETED_FLG,\r\nOUTPUT.EDW_CREATE_USER,\r\nOUTPUT.EDW_CREATE_DTM,\r\nOUTPUT.EDW_UPDATE_USER,\r\nOUTPUT.EDW_UPDATE_DTM,\r\nOUTPUT.ACTION_CODE,\r\nOUTPUT.DML_TYPE,\r\nCOALESCE(PROXY_IAM_USER_KEY,'-999') as PROXY_IAM_USER_KEY,\r\nCOALESCE(PROXY_TYPE_CD,'UNKNOWN') AS PROXY_TYPE_CD\r\nFROM\r\n(\r\nSELECT\r\nDT.BK_IAM_ROLE_NAME,\r\nDT.IAM_USER_KEY,\r\nDT.STANDARD_OR_EXCEPTION_FLG,\r\nDT.PROXY_ROLE,\r\nDT.SOURCE_DELETED_FLG,\r\nDT.EDW_CREATE_USER,\r\nDT.EDW_CREATE_DTM,\r\nDT.EDW_UPDATE_USER,\r\nDT.EDW_UPDATE_DTM,\r\nDT.ACTION_CODE,\r\nDT.DML_TYPE,\r\nDT.UPDATE_DATE,\r\nDT.PROXY_IAM_USER_KEY,\r\nDT.PROXY_TYPE_CD\r\nFROM\r\n(SEL\r\nSIEURT.ROLE_NAME\t\tAS BK_IAM_ROLE_NAME,\r\nSIU.IAM_USER_KEY\t\tAS IAM_USER_KEY,\r\nSIEURT.USER_ROLE_EXPT_FLAG\t\tAS STANDARD_OR_EXCEPTION_FLG,\r\nSIEURT.PROXY_FLAG\t\tAS PROXY_ROLE,\t\r\nCASE\r\n\tWHEN\t\r\n\t\tSIEURT.STATUS = 'A' THEN 'N' \r\n\tWHEN\tSIEURT.STATUS = 'I' THEN 'Y'\r\nEND\t\t\tSOURCE_DELETED_FLG,\r\nUSER\t\t\t\tAS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0)\t\tAS EDW_CREATE_DTM,\r\nUSER\t\t\t\tAS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0)\t\tAS EDW_UPDATE_DTM,\r\n'I'\t\t\t\tACTION_CODE,\r\nCASE WHEN NIURM.IAM_USER_KEY IS NOT NULL AND NIURM.BK_IAM_ROLE_NAME IS NOT NULL \r\nTHEN 'U' ELSE 'I' END DML_TYPE,\r\nSIEURT.UPDATE_DATE,\r\nPROXY.PROXY_IAM_USER_KEY,\r\nPROXY.PROXY_TYPE_CD\r\nFROM \r\n$$STGDB.ST_IAM_EDWTD_USR_ROLE_TOOL   SIEURT\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON ( SIEURT.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A' )\r\nINNER JOIN $$SECURITYVWDB.N_IAM_USER SIU\r\nON SIU.SK_IAM_USER_ID_INT=SIEURT.IAM_USER_ID\r\nINNER JOIN $$SECURITYVWDB.N_IAM_ROLE NIR\r\nON SIEURT.ROLE_NAME=NIR.BK_IAM_ROLE_NAME\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_USER_ROLE_MAP NIURM\r\nON NIURM.IAM_USER_KEY = SIU.IAM_USER_KEY\r\nAND NIURM.BK_IAM_ROLE_NAME=SIEURT.ROLE_NAME\r\nLEFT OUTER JOIN\r\n(select NIU.IAM_USER_KEY AS PROXY_IAM_USER_KEY, STG.PROXY_TYPE_CODE AS PROXY_TYPE_CD,NIU.SK_IAM_USER_ID_INT, STG.IAM_USER_ID from $$STGDB.ST_IAM_EDWTD_USER_ROLE_PROXY STG\r\nINNER JOIN $$SECURITYVWDB.N_IAM_USER NIU\r\nON\t STG.PROXY_IAM_USER_ID = NIU.CCO_ID ) PROXY\r\nON SIU.CCO_ID=PROXY.IAM_USER_ID\r\n\r\nUNION ALL\r\n\r\nSEL\r\nEIEURT.ROLE_NAME\t\tAS BK_IAM_ROLE_NAME,\r\nSIU.IAM_USER_KEY\t\tAS IAM_USER_KEY,\r\nEIEURT.USER_ROLE_EXPT_FLAG  AS STANDARD_OR_EXCEPTION_FLG,\r\nEIEURT.PROXY_FLAG\t\tAS PROXY_ROLE,\t\r\nCASE\r\n\tWHEN\t\r\n\t\tEIEURT.STATUS = 'A' THEN 'N' \r\n\tWHEN\tEIEURT.STATUS = 'I' THEN 'Y'\r\nEND\t\t\tSOURCE_DELETED_FLG,\r\nUSER\t\t\t\tAS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0)\t\tAS EDW_CREATE_DTM,\r\nUSER\t\t\t\tAS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0)\t\tAS EDW_UPDATE_DTM,\r\n'I'\t\t\t\tACTION_CODE,\r\nCASE WHEN NIURM.IAM_USER_KEY IS NOT NULL AND NIURM.BK_IAM_ROLE_NAME IS NOT NULL \r\nTHEN 'U' ELSE 'I' END DML_TYPE,\r\nEIEURT.UPDATE_DATE,\r\nPROXY.PROXY_IAM_USER_KEY,\r\nPROXY.PROXY_TYPE_CD\r\nFROM \r\n$$EXCEPDB.EX_IAM_EDWTD_USR_ROLE_TOOL   EIEURT\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON ( EIEURT.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A' )\r\nINNER JOIN $$SECURITYVWDB.N_IAM_USER SIU\r\nON SIU.SK_IAM_USER_ID_INT=EIEURT.IAM_USER_ID\r\nINNER JOIN $$SECURITYVWDB.N_IAM_ROLE NIR\r\nON EIEURT.ROLE_NAME=NIR.BK_IAM_ROLE_NAME\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_USER_ROLE_MAP NIURM\r\nON NIURM.IAM_USER_KEY = SIU.IAM_USER_KEY\r\nAND NIURM.BK_IAM_ROLE_NAME=EIEURT.ROLE_NAME\r\nLEFT OUTER JOIN\r\n(select NIU.IAM_USER_KEY AS PROXY_IAM_USER_KEY, STG.PROXY_TYPE_CODE AS PROXY_TYPE_CD,NIU.SK_IAM_USER_ID_INT,  STG.IAM_USER_ID from $$STGDB.ST_IAM_EDWTD_USER_ROLE_PROXY STG\r\nINNER JOIN $$SECURITYVWDB.N_IAM_USER NIU\r\nON\t STG.PROXY_IAM_USER_ID = NIU.CCO_ID ) PROXY\r\nON SIU.CCO_ID=PROXY.IAM_USER_ID\r\n\r\n)DT\r\n)OUTPUT \r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY OUTPUT.BK_IAM_ROLE_NAME,\r\nOUTPUT.IAM_USER_KEY ORDER BY OUTPUT.UPDATE_DATE DESC) = 1",
        "User Defined Join": "",
