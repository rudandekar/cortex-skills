      "attributes": {
        "Sql Query": "SEL\r\nSIEURT.IAM_USER_ID,                   \r\nSIEURT.ROLE_ID,                       \r\nSIEURT.ROLE_NAME,                     \r\nSIEURT.TOOL_ID,                      \r\nSIEURT.ASSIGNED_APP_DELIM_LIST,       \r\nSIEURT.USER_ROLE_EXPT_FLAG,\r\nSIEURT.PROXY_FLAG,                    \r\nSIEURT.GRANTOR_UNIVERSAL_ID,          \r\nSIEURT.GRANTOR_CEC_ID,                \r\nSIEURT.GRANTOR_CCO_ID,               \r\nSIEURT.STATUS,                       \r\nSIEURT.TR_FLAG,                       \r\nSIEURT.LAST_ACTION,                   \r\nSIEURT.CREATED_BY,                    \r\nSIEURT.CREATE_DATE,                   \r\nSIEURT.UPDATED_BY,                    \r\nSIEURT.UPDATE_DATE,                   \r\nSIEURT.ACTION_CODE,                   \r\nSIEURT.BATCH_ID,                      \r\nSIEURT.CREATE_DATETIME,               \r\n'RI' EXCEPTION_TYPE\r\nFROM $$STGDB.ST_IAM_EDWTD_USR_ROLE_TOOL SIEURT\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON ( SIEURT.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A' )\r\nWHERE NOT EXISTS (SELECT 1 FROM $$SECURITYVWDB.N_IAM_ROLE NIR\r\nWHERE SIEURT.ROLE_NAME=NIR.BK_IAM_ROLE_NAME )\r\nOR NOT EXISTS (SELECT 1 FROM $$ETLVWDB.SM_IAM_USER SIU\r\nWHERE SIU.SK_IAM_USER_ID_INT=SIEURT.IAM_USER_ID )",
