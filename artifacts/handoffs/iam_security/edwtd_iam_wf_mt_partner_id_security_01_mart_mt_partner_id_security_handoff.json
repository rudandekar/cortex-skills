      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\n\r\n                NIU.IAM_USER_KEY,\r\n                NIU.BK_CPR_UNIVERSAL_ID_INT,\r\n                NIU.INTERNAL_ROLE,\r\n                NIU.CCO_ID,\r\n                NIU.EXTERNAL_ROLE,\r\n                NIU.SK_IAM_USER_ID_INT,\r\n                NIU.RU_EXTERNAL_USER_EMAIL_ADDR,\r\n                NIU.RU_CISCO_WORKER_PARTY_KEY,\r\n                NIU.DD_BK_WORKER_TYPE_CD,\r\n                NIU.DD_CEC_ID,\r\n                COALESCE (NIU.DUMMY_USER_ROLE,\t'=')  DUMMY_USER_ROLE, \r\n                COALESCE (NIU.RU_EXTERNAL_FLG,\t'=') RU_EXTERNAL_FLG, \r\n                COALESCE (NIU.RU_INTERNAL_FLG,\t'=') RU_INTERNAL_FLG,  \r\n                NIU.RU_IAM_DUMMY_USER_NAME,  \r\n                APP.IAM_APPLICATION_KEY,\r\n                APP.APPLICATION_NAME,\r\n                PARTNER.BK_IAM_ROLE_NAME,\r\n                PARTNER.ASSIGNMENT_TYPE,\r\n                PARTNER.STANDARD_OR_EXCEPTION_FLG,\r\n                PARTNER.EXCLUSIVE_OR_RESTRICTIVE_FLG,\r\n                PARTNER.IAM_LEVEL_NUM_INT,\r\n                MPH.PARTNER_ID_INT,\r\n                MPH.PARTNER_PARTY_KEY\r\nFROM \r\n                $$SECURITYVWDB.N_IAM_USER NIU,\r\n                $$SECURITYVWDB.N_IAM_APPLICATION APP,\r\n                $$SECURITYVWDB.N_IAM_PTNRS_HIER_LNK  PARTNER,\r\n      \t\t\t$$COMREFVWDB.MT_PARTNER_HIERARCHY MPH\r\nWHERE\r\n                PARTNER.IAM_APPLICATION_KEY = APP.IAM_APPLICATION_KEY\r\nAND        NIU.IAM_USER_KEY =  PARTNER.IAM_USER_KEY\r\nAND        NIU.SOURCE_DELETED_FLG='N'\r\nAND        PARTNER.SOURCE_DELETED_FLG='N'\r\nAND        MPH.PARTNER_SITE_PARTY_KEY = PARTNER.PARTNER_SITE_PARTY_KEY\r\nAND \t\tAPP.APPLICATION_NAME='MBR Channels'",
