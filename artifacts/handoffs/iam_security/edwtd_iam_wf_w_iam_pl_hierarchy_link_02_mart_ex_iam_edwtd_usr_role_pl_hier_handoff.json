      "attributes": {
        "Sql Query": "SELECT\r\nSIEURTH.ROLE_NAME AS BK_IAM_ROLE_NAME,\r\nNIU.IAM_USER_KEY AS IAM_USER_KEY,\r\nSIA.IAM_APPLICATION_KEY AS IAM_APPLICATION_KEY,\r\n PL_HIERARCHY_NODE_KEY,   \r\nNODE_ID_INT AS DD_NODE_ID_INT,\r\nSIEURTH.ASSIGNMENT_TYPE AS ASSIGNMENT_TYPE,\r\nSIEURTH.DATA_RES_EXPT_FLAG AS STANDARD_OR_EXCEPTION_FLG,\r\nSIEURTH.EXCL_RESTR_FLAG AS EXCLUSIVE_OR_RESTRICTIVE_FLG,\r\nCASE WHEN SIEURTH.STATUS='A' THEN 'N'\r\n WHEN  SIEURTH.STATUS='I' THEN 'Y' END  SOURCE_DELETED_FLG,\r\nSIEURTH.LVL_NUMBER AS IAM_LEVEL_NUM_INT,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n 'I'\tACTION_CODE,\r\n'I'  DML_TYPE\r\nFROM \r\n$$STGDB.ST_IAM_EDWTD_USR_ROLE_PL_HIER SIEURTH\r\n\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL  IAC\r\nON (SIEURTH.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\n\r\nINNER JOIN $$FINLGLVWDB.N_PL_HIERARCHY_NODE NTMSC\t\t\t\r\nON SIEURTH.ERP_SEGMENT_ID = NTMSC.NODE_ID_INT\r\n\r\nINNER JOIN $$SECURITYVWDB.N_IAM_ROLE NIR\r\nON SIEURTH.ROLE_NAME=NIR.BK_IAM_ROLE_NAME\r\n\r\nINNER JOIN $$SECURITYVWDB.N_IAM_USER NIU\r\nON NIU.SK_IAM_USER_ID_INT = SIEURTH.IAM_USER_ID \r\n\r\nINNER JOIN $$SECURITYVWDB.N_IAM_APPLICATION SIA\r\nON SIEURTH.TOOL_ID=SIA.SK_APPLICATION_ID_INT",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
