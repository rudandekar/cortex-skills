      "attributes": {
        "Sql Query": "SELECT SIEURTH.IAM_USER_ID, SIEURTH.ROLE_ID, SIEURTH.ROLE_NAME, SIEURTH.TOOL_ID, SIEURTH.DATA_STRUCT_TYPE, SIEURTH.LVL_NUMBER, SIEURTH.ERP_SEGMENT1, \r\nSIEURTH.ERP_SEGMENT_ID, SIEURTH.ASSIGNMENT_TYPE, SIEURTH.DATA_RES_EXPT_FLAG, SIEURTH.EXCL_RESTR_FLAG, SIEURTH.RESTRICTION_FLAG, SIEURTH.PROXY_FLAG, SIEURTH.GRANTOR_UNIVERSAL_ID, SIEURTH.GRANTOR_CEC_ID, SIEURTH.GRANTOR_CCO_ID, SIEURTH.STATUS, SIEURTH.TR_FLAG, SIEURTH.LAST_ACTION, SIEURTH.CREATED_BY, SIEURTH.CREATE_DATE, SIEURTH.UPDATED_BY, SIEURTH.UPDATE_DATE, SIEURTH.ACTION_CODE, SIEURTH.BATCH_ID, SIEURTH.CREATE_DATETIME ,\r\n'RI' AS EXCEPTION_TYPE\r\nFROM\r\n $$STGDB.ST_IAM_EDWTD_USR_ROLE_PL_HIER SIEURTH\r\n\r\nLEFT OUTER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL  IAC\r\nON (SIEURTH.TOOL_ID =  IAC.TOOL_ID AND IAC.STATUS  = 'A')\r\n\r\nLEFT OUTER  JOIN $$FINLGLVWDB.N_PL_HIERARCHY_NODE NTMSC\t\t\t\r\nON SIEURTH.ERP_SEGMENT_ID = NTMSC.NODE_ID_INT\r\n\r\nLEFT OUTER  JOIN $$SECURITYVWDB.N_IAM_ROLE NIR\r\nON SIEURTH.ROLE_NAME = NIR.BK_IAM_ROLE_NAME\r\n\r\nLEFT OUTER  JOIN $$SECURITYVWDB.N_IAM_USER NIU\r\nON NIU.SK_IAM_USER_ID_INT = SIEURTH.IAM_USER_ID \r\n\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_APPLICATION SIA\r\nON SIEURTH.TOOL_ID = SIA.SK_APPLICATION_ID_INT\r\n\r\nWHERE  (IAC.TOOL_ID  IS NULL  OR\r\nNTMSC.NODE_ID_INT  IS NULL OR\r\nNIR.BK_IAM_ROLE_NAME IS NULL OR\r\nNIU.SK_IAM_USER_ID_INT IS NULL  OR\r\nSIA.SK_APPLICATION_ID_INT IS NULL )",
