      "attributes": {
        "Sql Query": "SELECT\r\n\tst.ROLE_NAME,\r\n\tusr.IAM_USER_KEY,\r\n\tNCP.PARTNER_PARTY_KEY,             \r\n\tapp.IAM_APPLICATION_KEY,\r\n\tst.ASSIGNMENT_TYPE,\r\n\tst.DATA_RES_EXPT_FLAG AS STANDARD_OR_EXCEPTION_FLG,\r\n\tst.EXCL_RESTR_FLAG AS EXCLUSIVE_OR_RESTRICTIVE_FLG,\r\n\tCASE\t \r\n\t\tWHEN\t st.STATUS='A' THEN 'N'\r\n\t \r\n\t\tWHEN\t  st.STATUS='I' THEN 'Y' \r\n\tEND\t  SOURCE_DELETED_FLG,\r\n\tst.LVL_NUMBER AS IAM_LEVEL_NUM_INT,\r\n\tUSR.DD_CEC_ID AS DD_CEC_ID,\r\n\tst.ERP_SEGMENT1 AS SS_BK_BE_ID_INT\r\nFROM  (SEL * FROM $$STGDB.ST_IAM_EDWTD_USR_ROLE_PTR_HIER WHERE LVL_NUMBER=1) st\r\n\r\nINNER JOIN  $$ETLVWDB.IAM_APPLICATION_CTRL  ctrl\r\n\tON\t (st.TOOL_ID=ctrl.TOOL_ID \r\n\tAND\t ctrl.STATUS ='A')\r\n\r\nINNER JOIN $$SECURITYVWDB.N_IAM_ROLE rol\r\n\tON\t st.ROLE_NAME=rol.BK_IAM_ROLE_NAME\r\n\t\r\nINNER JOIN $$SECURITYVWDB.N_IAM_USER usr\r\n\tON\t usr.SK_IAM_USER_ID_INT = st.IAM_USER_ID \r\n\t\r\nINNER JOIN $$SECURITYVWDB.N_IAM_APPLICATION app\r\n\tON\t st.TOOL_ID= app.SK_APPLICATION_ID_INT\r\n\t\r\nINNER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER NCP\r\n\tON st.ERP_SEGMENT1 = NCP.BK_PARTNER_ID_INT",
