      "attributes": {
        "Sql Query": "SELECT \r\n\tst.IAM_USER_ID, \r\n\tst.ROLE_ID, \r\n\tst.ROLE_NAME, \r\n\tst.TOOL_ID, \r\n\tst.DATA_STRUCT_TYPE, \r\n\tst.LVL_NUMBER, \r\n\tst.ERP_SEGMENT1, \r\n\tst.ERP_SEGMENT_ID, \r\n\tst.ASSIGNMENT_TYPE, \r\n\tst.DATA_RES_EXPT_FLAG, \r\n\tst.EXCL_RESTR_FLAG, \r\n\tst.RESTRICTION_FLAG, \r\n\tst.PROXY_FLAG, \r\n\tst.GRANTOR_UNIVERSAL_ID, \r\n\tst.GRANTOR_CEC_ID, \r\n\tst.GRANTOR_CCO_ID, \r\n\tst.STATUS, \r\n\tst.TR_FLAG, \r\n\tst.LAST_ACTION, \r\n\tst.CREATED_BY, \r\n\tst.CREATE_DATE, \r\n\tst.UPDATED_BY, \r\n\tst.UPDATE_DATE, \r\n\tst.ACTION_CODE, \r\n\tst.BATCH_ID, \r\n\tst.CREATE_DATETIME,\r\n\t'RI' AS EXCEPTION_TYPE\r\nFROM\r\n\t(SEL * FROM $$STGDB.ST_IAM_EDWTD_USR_ROLE_PTR_HIER WHERE LVL_NUMBER =1) st\r\n\r\nLEFT OUTER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL  ctrl\r\n\tON\t (st.TOOL_ID=ctrl.TOOL_ID \r\n\tAND\t ctrl.STATUS ='A')\r\n\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_ROLE rol\r\n\tON\t st.ROLE_NAME=rol.BK_IAM_ROLE_NAME\r\n\t\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_USER usr\r\n\tON\t usr.SK_IAM_USER_ID_INT = st.IAM_USER_ID \r\n\t\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_APPLICATION app\r\n\tON\t st.TOOL_ID= app.SK_APPLICATION_ID_INT\r\n\t\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CHANNEL_PARTNER NCP\r\n\tON st.ERP_SEGMENT1 = NCP.BK_PARTNER_ID_INT  \r\n\t\r\nWHERE ctrl.TOOL_ID IS NULL \r\nOR rol.BK_IAM_ROLE_NAME IS NULL\r\nOR usr.SK_IAM_USER_ID_INT IS NULL\r\nOR app.SK_APPLICATION_ID_INT IS NULL\r\nOR NCP.BK_PARTNER_ID_INT IS NULL\r\nUNION ALL\r\nSELECT \r\n\tst.IAM_USER_ID, \r\n\tst.ROLE_ID, \r\n\tst.ROLE_NAME, \r\n\tst.TOOL_ID, \r\n\tst.DATA_STRUCT_TYPE, \r\n\tst.LVL_NUMBER, \r\n\tst.ERP_SEGMENT1, \r\n\tst.ERP_SEGMENT_ID, \r\n\tst.ASSIGNMENT_TYPE, \r\n\tst.DATA_RES_EXPT_FLAG, \r\n\tst.EXCL_RESTR_FLAG, \r\n\tst.RESTRICTION_FLAG, \r\n\tst.PROXY_FLAG, \r\n\tst.GRANTOR_UNIVERSAL_ID, \r\n\tst.GRANTOR_CEC_ID, \r\n\tst.GRANTOR_CCO_ID, \r\n\tst.STATUS, \r\n\tst.TR_FLAG, \r\n\tst.LAST_ACTION, \r\n\tst.CREATED_BY, \r\n\tst.CREATE_DATE, \r\n\tst.UPDATED_BY, \r\n\tst.UPDATE_DATE, \r\n\tst.ACTION_CODE, \r\n\tst.BATCH_ID, \r\n\tst.CREATE_DATETIME,\r\n\t'RI' AS EXCEPTION_TYPE\r\nFROM\r\n\t(SEL * FROM $$STGDB.ST_IAM_EDWTD_USR_ROLE_PTR_HIER WHERE LVL_NUMBER =0) st\r\n\r\nLEFT OUTER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL  ctrl\r\n\tON\t (st.TOOL_ID=ctrl.TOOL_ID \r\n\tAND\t ctrl.STATUS ='A')\r\n\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_ROLE rol\r\n\tON\t st.ROLE_NAME=rol.BK_IAM_ROLE_NAME\r\n\t\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_USER usr\r\n\tON\t usr.SK_IAM_USER_ID_INT = st.IAM_USER_ID \r\n\t\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_APPLICATION app\r\n\tON\t st.TOOL_ID= app.SK_APPLICATION_ID_INT\r\n\t\r\nWHERE ctrl.TOOL_ID IS NULL \r\nOR rol.BK_IAM_ROLE_NAME IS NULL\r\nOR usr.SK_IAM_USER_ID_INT IS NULL\r\nOR app.SK_APPLICATION_ID_INT IS NULL",
