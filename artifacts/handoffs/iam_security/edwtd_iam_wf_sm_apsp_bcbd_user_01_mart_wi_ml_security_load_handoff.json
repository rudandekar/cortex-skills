      "attributes": {
        "Sql Query": "SEL   IAM_USER_KEY, BK_BCBD_MAILER_ALIAS_ADDR,  BK_BCBD_USER_TYPE,  EDW_CREATE_DTM, EDW_CREATE_USER  FROM (  \r\n  SELECT distinct  IAM_USER_KEY, 'UNKNOWN' BK_BCBD_MAILER_ALIAS_ADDR,   'IAM USER' BK_BCBD_USER_TYPE, CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER  FROM  $$SECURITYVWDB.N_IAM_USER_ROLE_APP_MAP ROLE_APP\r\nINNER JOIN $$SECURITYVWDB.N_IAM_APPLICATION APP\r\nON APP.IAM_APPLICATION_KEY=ROLE_APP.IAM_APPLICATION_KEY AND APPLICATION_NAME='BI Cafe-2'\r\n  UNION\r\n  sel   distinct  IAM_USER_KEY, 'UNKNOWN' BK_BCBD_MAILER_ALIAS_ADDR,   'IAM USER' BK_BCBD_USER_TYPE, CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\n  USER AS EDW_CREATE_USER\r\n   from $$stgdb.ST_CA_FIN_VISIBILITY_SEC_LOAD st \r\n  INNER JOIN $$SECURITYVWDB.N_IAM_USER USR\r\n  ON ST.USER_ID=USR.DD_CEC_ID) ST \r\n  WHERE NOT EXISTS (SELECT 1 FROM $$ETLVWDB.SM_APSP_BCBD_USER SM \r\n  WHERE ST.IAM_USER_KEY=SM.IAM_USER_KEY AND SM.BK_BCBD_USER_TYPE= 'IAM USER')",
