      "attributes": {
        "Sql Query": "SELECT\r\nSM.BCBD_USER_KEY,\r\nSIEURTH.ROLE_NAME AS BK_IAM_ROLE_NAME,\r\nSIA.IAM_APPLICATION_KEY AS IAM_APPLICATION_KEY,\r\nSIEURTH.SALES_REP_NUMBER AS BK_SALES_REP_NUM,\r\nCAST(BK_FISCAL_YEAR_NUMBER_INT AS VARCHAR(4) )  BK_FISCAL_YEAR_NUM,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n 'I'    ACTION_CODE,\r\n'I'  DML_TYPE\r\n FROM (SEL IAM_USER_ID, ROLE_NAME, TOOL_ID, SALES_REP_NUMBER, CURRENT_DATE  CURR_DATE, DATA_RES_EXPT_FLAG FROM $$STGDB.ST_IAM_EDWTD_USR_ROLE_SHR_LVL7 A\r\nINNER JOIN   $$COMREFVWDB.N_ERP_SALES_REP B\r\nON A.ERP_SEGMENT1=B.ERP_SALES_REP_NAME  \r\nUNION\r\nSEL IAM_USER_ID, ROLE_NAME, TOOL_ID, SALES_REP_NUMBER, CURRENT_DATE  CURR_DATE, DATA_RES_EXPT_FLAG FROM $$STGDB.ST_IAM_EDWTD_USR_ROLE_SHR_LVL7 A\r\nINNER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY B\r\nON A.ERP_SEGMENT1=UPPER(B.CISCO_EMAIL_ADDRESS) \r\nINNER JOIN   $$COMREFVWDB.N_ERP_SALES_REP C\r\nON C.RU_CISCO_WORKER_PARTY_KEY=B.CISCO_WORKER_PARTY_KEY )  SIEURTH\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL  IAC\r\nON (SIEURTH.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nINNER JOIN $$SECURITYVWDB.N_IAM_ROLE NIR\r\nON SIEURTH.ROLE_NAME=NIR.BK_IAM_ROLE_NAME\r\nINNER JOIN $$SECURITYVWDB.N_IAM_USER NIU\r\nON NIU.SK_IAM_USER_ID_INT = SIEURTH.IAM_USER_ID \r\nINNER JOIN $$ETLVWDB.SM_APSP_BCBD_USER  SM\r\nON SM.IAM_USER_KEY=NIU.IAM_USER_KEY\r\nINNER JOIN $$SECURITYVWDB.N_IAM_APPLICATION SIA\r\nON SIEURTH.TOOL_ID=SIA.SK_APPLICATION_ID_INT\r\nINNER JOIN $$COMREFVWDB.N_FISCAL_YEAR \r\nON CURR_DATE BETWEEN FISCAL_YEAR_START_DATE AND FISCAL_YEAR_END_DATE\r\nWHERE NOT ( SIEURTH.DATA_RES_EXPT_FLAG='S'  AND SIEURTH.ROLE_NAME LIKE  '%IBOT%')\r\n AND NIU.SOURCE_DELETED_FLG='N'\r\n\r\nUNION ALL\r\n\r\nSEL  SM.BCBD_USER_KEY,  SUBROLE_NAME, SIA.IAM_APPLICATION_KEY, SALES_REP_NUMBER,\r\nFISCAL_YEAR, CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n 'I'    ACTION_CODE,\r\n'I'  DML_TYPE\r\nFROM (SEL  ST.USER_ID, SUBROLE_NAME, FISCAL_YEAR, SALES_REP_NUMBER, 1388 TOOL_ID\r\nFROM  $$STGDB.WI_USER_VISIBILITY_LOAD ST\r\ninner join $$COMREFVWDB.n_cisco_worker_party party\r\non party.cisco_email_address=st.TERRITORY_CODE\r\ninner join $$COMREFVWDB.N_ERP_SALES_REP SLS_REP\r\non SLS_REP.RU_CISCO_WORKER_PARTY_KEY=PARTY.CISCO_WORKER_PARTY_KEY   \r\nWHERE ST.MIN_LEVEL=7 \r\nUNION \r\nSEL  ST.USER_ID, SUBROLE_NAME, FISCAL_YEAR, SALES_REP_NUMBER, 1388 TOOL_ID\r\nFROM  $$STGDB.WI_USER_VISIBILITY_LOAD ST\r\ninner join $$COMREFVWDB.N_ERP_SALES_REP SLS_REP\r\non SLS_REP.ERP_SALES_REP_NAME=ST.TERRITORY_CODE \r\nWHERE ST.MIN_LEVEL=7 )ST\r\nINNER JOIN $$SECURITYVWDB.N_IAM_USER NIU\r\nON NIU.DD_CEC_ID = ST.USER_ID   AND NIU.SOURCE_DELETED_FLG='N'\r\nINNER JOIN $$ETLVWDB.SM_APSP_BCBD_USER  SM\r\nON NIU.IAM_USER_KEY=SM.IAM_USER_KEY\r\nINNER JOIN $$SECURITYVWDB.N_IAM_APPLICATION SIA\r\nON ST.TOOL_ID=SIA.SK_APPLICATION_ID_INT",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
