      "attributes": {
        "Sql Query": "sel DD_CEC_ID\r\n,IAM_LEVEL_NUM_INT\r\n,BIZ_ROLE_NAME\r\n,BK_IAM_ROLE_NAME\r\n, SALES_TERRITORY_DESCR\r\n,BI_CAFE_ROLE_NAME\r\n, BK_FISCAL_YEAR_NUM\r\n,LOAD_FLAG,\r\nCOALESCE(BK_SALES_TERR_ASSGNMNT_TYPE_CD,'DR')\r\nfrom (\r\nsel DD_CEC_ID\r\n,IAM_LEVEL_NUM_INT\r\n,NULL BIZ_ROLE_NAME\r\n,BK_IAM_ROLE_NAME\r\n, SALES_TERRITORY_DESCR\r\n,BICAFE_ROLE_NAME BI_CAFE_ROLE_NAME\r\n, BK_FISCAL_YEAR_NUM_INT BK_FISCAL_YEAR_NUM\r\n,'I'  LOAD_FLAG,\r\nBK_SALES_TERR_ASSGNMNT_TYPE_CD\r\nfrom  $$SECURITYVWDB.MT_APSP_BCBD_VISIBILITY\r\ninner join $$comrefvwDB.n_fiscal_year yr  \r\non yr.dv_previous_fiscal_year_number = BK_FISCAL_YEAR_NUM_INT\r\nwhere dv_current_fiscal_year_flag='Y'\r\nUNION ALL\r\nSEL  NIU.DD_CEC_ID\r\n,IAM_LEVEL_NUM_INT \r\n,NULL BIZ_ROLE_NAME \r\n,BK_IAM_ROLE_NAME \r\n,ERP_SALES_REP_NAME  \r\n, BK_IAM_ROLE_NAME\r\n, BK_FISCAL_YEAR_NUM\r\n, 'I'  LOAD_FLAG ,\r\n'DR' BK_SALES_TERR_ASSGNMNT_TYPE_CD \r\n FROM\r\n(SEL BCBD_USER_KEY, 7  IAM_LEVEL_NUM_INT, BK_IAM_ROLE_NAME, \r\nCISCO_EMAIL_ADDRESS ERP_SALES_REP_NAME, BK_FISCAL_YEAR_NUM\r\n FROM $$SECURITYVWDB.N_APSP_BCBD_ERP_SLS_REP_LNK NF\r\nINNER  JOIN $$COMREFVWDB.N_ERP_SALES_REP SLS_REP\r\nON NF.BK_SALES_REP_NUM=SLS_REP.SALES_REP_NUMBER\r\ninner join $$COMREFVWDB.n_cisco_worker_party party\r\non SLS_REP.RU_CISCO_WORKER_PARTY_KEY=PARTY.CISCO_WORKER_PARTY_KEY  \r\nWHERE   SLS_REP.RU_CISCO_WORKER_PARTY_KEY <> -999\r\nUNION \r\nSEL BCBD_USER_KEY, 7  IAM_LEVEL_NUM_INT, BK_IAM_ROLE_NAME, \r\nERP_SALES_REP_NAME, BK_FISCAL_YEAR_NUM\r\n FROM $$SECURITYVWDB.N_APSP_BCBD_ERP_SLS_REP_LNK NF\r\nINNER  JOIN $$COMREFVWDB.N_ERP_SALES_REP SLS_REP\r\nON NF.BK_SALES_REP_NUM=SLS_REP.SALES_REP_NUMBER\r\nWHERE ERP_SALES_REP_NAME NOT LIKE '%,%' ) NF\r\ninner join $$ETLVWDB.SM_APSP_BCBD_USER SM\r\nON NF.BCBD_USER_KEY=SM.BCBD_USER_KEY\r\nINNER JOIN $$SECURITYVWDB.N_IAM_USER NIU\r\nON NIU.IAM_USER_KEY = SM.IAM_USER_KEY   \r\ninner join $$comrefvwDB.n_fiscal_year yr  \r\non yr.dv_previous_fiscal_year_number = BK_FISCAL_YEAR_NUM\r\nwhere dv_current_fiscal_year_flag='Y')  NF\r\ninner join $$SERVICEVWDB.N_BI_CAFE_AR_APP_CTRL_PARAMTR PARM\r\non parm.PARAMETER_DESCR=NF.BK_IAM_ROLE_NAME  and PARAMETER_STATUS_FLG =  'Y'  \r\nwhere \r\nnot exists (sel 1 from  $$STGDB.WI_USER_VISIBILITY_LOAD st where st.FISCAL_YEAR=nf.BK_FISCAL_YEAR_NUM)",
