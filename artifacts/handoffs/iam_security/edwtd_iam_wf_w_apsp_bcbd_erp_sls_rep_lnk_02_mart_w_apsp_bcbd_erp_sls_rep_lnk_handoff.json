      "attributes": {
        "Sql Query": "SELECT ST.USER_ID, ST.MIN_LEVEL, ST.BIZ_ROLE_NAME, ST.SUBROLE_NAME, ST.TERRITORY_CODE, ST.ROLE_NAME, ST.FISCAL_YEAR , ST.LOAD_FLAG,\r\nCOALESCE(ST.SALES_TERRITORY_CODE,'DR')\r\nFROM $$STGDB.ST_CA_FIN_VISIBILITY_SEC_LOAD ST  WHERE ST.LOAD_TYPE='User_Visibility_load'  and  ST.LOAD_FLAG = 'I'\r\nMINUS\r\nSELECT  USER_ID, MIN_LEVEL, BIZ_ROLE_NAME, SUBROLE_NAME, TERRITORY_CODE, ROLE_NAME, FISCAL_YEAR , LOAD_FLAG ,COALESCE(BK_SALES_TERR_ASSGNMNT_TYPE_CD,'DR') FROM $$STGDB.WI_USER_VISIBILITY_LOAD",
