      "attributes": {
        "Sql Query": "SELECT \r\n SMIAC.IAM_APPLICATION_COMPONENT_KEY,\r\n WIC.APP_COMPONENT_NAME,\r\n WIC.APP_COMPONENT_DESCR,\r\n WIC.APP_COMPONENT_STATUS,\r\n WIC.APP_COMPONENT_TYPE,\r\n WIC.LEAF_BRANCH,\r\n SMIA.IAM_APPLICATION_KEY,\r\n WIC.APP_COMPONENT_ID,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n 'I' ACTION_CODE,\r\n CASE WHEN NIAC.IAM_APPLICATION_COMPONENT_KEY IS NOT NULL THEN 'U' ELSE 'I' END DML_TYPE\r\nFROM\r\n $$STGDB.ST_IAM_EDWTD_APP_COMPONENT WIC \r\n INNER JOIN \r\n $$ETLVWDB.SM_IAM_APPLICATION_COMPONENT SMIAC\r\n ON WIC.APP_COMPONENT_ID =SMIAC.SK_APP_COMPONENT_ID_INT\r\n INNER JOIN\r\n $$ETLVWDB.SM_IAM_APPLICATION SMIA\r\n ON SMIA.SK_APPLICATION_ID_INT = WIC.APPLICATION_ID\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (WIC.APPLICATION_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_APPLICATION_COMPONENT NIAC\r\nON NIAC.IAM_APPLICATION_COMPONENT_KEY = SMIAC.IAM_APPLICATION_COMPONENT_KEY\r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY WIC.APP_COMPONENT_ID ORDER BY WIC.UPDATE_DATE DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
