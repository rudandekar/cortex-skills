      "attributes": {
        "Sql Query": "SEL \r\n          SIERT.ROLE_ID ,\r\n\t      SIERT.ROLE_NAME ,\r\n\t      SIERT.TOOL_ID ,\r\n\t      SIERT.TYPE_NAME_1 ,\r\n\t      SIERT.TYPE_VAL_NAME_1 ,\r\n\t      SIERT.TYPE_NAME_2 ,\r\n\t      SIERT.TYPE_VAL_NAME_2 ,\r\n\t      SIERT.TYPE_NAME_3 ,\r\n\t      SIERT.TYPE_VAL_NAME_3 ,\r\n\t      SIERT.TYPE_NAME_4 ,\r\n\t      SIERT.TYPE_VAL_NAME_4 ,\r\n\t      SIERT.TYPE_NAME_5 ,\r\n\t      SIERT.TYPE_VAL_NAME_5 ,\r\n\t      SIERT.STATUS ,\r\n\t      SIERT.LAST_ACTION ,\r\n\t      SIERT.CREATED_BY ,\r\n\t      SIERT.CREATE_DATE ,\r\n\t      SIERT.UPDATED_BY ,\r\n\t      SIERT.UPDATE_DATE ,\r\n\t      SIERT.ACTION_CODE ,\r\n\t      SIERT.BATCH_ID ,\r\n\t      SIERT.CREATE_DATETIME ,\r\n\t      'RI'  EXCEPTION_TYPE \r\n\t      FROM  $$STGDB.ST_IAM_EDWTD_ROLE_TOOL SIERT\r\n\t      INNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\n          ON (SIERT.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\n\t       WHERE NOT EXISTS (SELECT 1 FROM $$SECURITYVWDB.N_IAM_ROLE NIR\r\n           WHERE SIERT.ROLE_NAME=NIR.BK_IAM_ROLE_NAME)\r\n           OR\r\n           NOT EXISTS(SELECT 1 FROM $$ETLVWDB.SM_IAM_APPLICATION SIA\r\n           WHERE SIA.SK_APPLICATION_ID_INT=SIERT.TOOL_ID)",
        "User Defined Join": "",
