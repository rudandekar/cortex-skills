        }
      ],
      "attributes": {
        "Sql Query": "SELECT\r\nSIERT.ROLE_NAME AS BK_IAM_ROLE_NAME,\r\nSIA.IAM_APPLICATION_KEY AS IAM_APPLICATION_KEY,\r\nCASE WHEN SIERT.STATUS='A'\r\nTHEN 'N'\r\nWHEN SIERT.STATUS='I'\r\nTHEN 'Y' END AS SOURCE_DELETED_FLG,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NIRAM.BK_IAM_ROLE_NAME IS NOT NULL AND  NIRAM.IAM_APPLICATION_KEY IS NOT NULL \r\n  THEN 'U'  ELSE 'I' END DML_TYPE  FROM \r\n( SELECT\r\nSIERT.ROLE_NAME ,\r\nSIERT.STATUS,\r\nSIERT.TOOL_ID,\r\nSIERT.UPDATE_DATE    \r\nFROM $$STGDB.ST_IAM_EDWTD_ROLE_TOOL SIERT\r\nUNION ALL\r\nSELECT\r\nEIERT.ROLE_NAME ,\r\nEIERT.STATUS,\r\nEIERT.TOOL_ID,\r\nEIERT.UPDATE_DATE    \r\nFROM $$EXCEPDB.EX_IAM_EDWTD_ROLE_TOOL EIERT) SIERT\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (SIERT.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nINNER JOIN $$SECURITYVWDB.N_IAM_ROLE NIR\r\nON SIERT.ROLE_NAME=NIR.BK_IAM_ROLE_NAME\r\nINNER JOIN $$ETLVWDB.SM_IAM_APPLICATION SIA\r\nON SIA.SK_APPLICATION_ID_INT=SIERT.TOOL_ID\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_ROLE_APPLICATION_MAP NIRAM\r\nON NIRAM.BK_IAM_ROLE_NAME=SIERT.ROLE_NAME\r\nAND NIRAM.IAM_APPLICATION_KEY=SIA.IAM_APPLICATION_KEY\r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY SIERT.ROLE_NAME,SIA.IAM_APPLICATION_KEY  ORDER BY SIERT.UPDATE_DATE  DESC) = 1",
        "User Defined Join": "",
