        "Sql Query": "SELECT\r\nNIA.APPLICATION_NAME,\r\nCOALESCE(NIST.IAM_USER_KEY,-999) AS IAM_USER_KEY,\r\nCOALESCE(NIST.IAM_APPLICATION_KEY,-999) AS IAM_APPLICATION_KEY,\r\nNIU.BK_CPR_UNIVERSAL_ID_INT,\r\nCOALESCE(NIU.INTERNAL_ROLE,'=') AS INTERNAL_ROLE,\r\nCOALESCE(NIU.EXTERNAL_ROLE,'=') AS EXTERNAL_ROLE,\r\nCOALESCE(NIU.RU_CISCO_WORKER_PARTY_KEY,-999) AS RU_CISCO_WORKER_PARTY_KEY,\r\nNIU.CCO_ID,\r\nNIST.SOURCE_DELETED_FLG,\r\nCOALESCE(NIU.DD_BK_WORKER_TYPE_CD,'=') AS DD_BK_WORKER_TYPE_CD,\r\nCOALESCE(NIST.DD_CEC_ID,-999) AS DD_CEC_ID,\r\nCOALESCE(NIU.RU_EXTERNAL_FLG,'=') AS RU_EXTERNAL_FLG,              \r\nCOALESCE(NIU.RU_INTERNAL_FLG,'=') AS RU_INTERNAL_FLG,\r\nNIU.RU_IAM_DUMMY_USER_NAME,\r\nNIU.RU_EXTERNAL_USER_EMAIL_ADDR,\r\nCOALESCE(NIST.BK_IAM_ROLE_NAME,'UNKNOWN') AS BK_IAM_ROLE_NAME         ,\r\nCOALESCE(NIST.SALES_TERRITORY_KEY,-999)   AS SALES_TERRITORY_KEY      ,\r\nNIST.ASSIGNMENT_TYPE               ,\r\nNIST.STANDARD_OR_EXCEPTION_FLG     ,\r\nNIST.EXCLUSIVE_OR_RESTRICTIVE_FLG  ,\r\nNIST.IAM_LEVEL_NUM_INT             ,\r\nCOALESCE(NIST.DD_BK_SALES_HIER_TYPE_CD,'UNKNOWN') AS  DD_BK_SALES_HIER_TYPE_CD     ,\r\nCOALESCE(NIST.DD_BK_SALES_TERR_NAME,'UNKNOWN') AS DD_BK_SALES_TERR_NAME         ,\r\nNIST.DD_SALES_TERRITORY_DESCR,\r\nFDT.FISCAL_YEAR_MONTH_INT,\r\nCOALESCE(NIU.DUMMY_USER_ROLE,'=') AS DUMMY_USER_ROLE  ,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM                ,\r\nUSER AS EDW_CREATE_USER               ,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM                ,\r\nUSER AS EDW_UPDATE_USER               ,\r\nFDT.FISCAL_MONTH_START_DATE AS START_TV_DT ,                  \r\nFDT.FISCAL_MONTH_END_DATE AS END_TV_DT ,\r\nNIST.BK_SALES_TERR_ASSGNMNT_TYPE_CD\r\nFROM $$SECURITYVWDB.N_IAM_SALES_TERR_LNK NIST\r\nINNER JOIN $$SECURITYVWDB.N_IAM_USER NIU\r\nON NIU.IAM_USER_KEY=NIST.IAM_USER_KEY\r\nINNER JOIN $$SECURITYVWDB.N_IAM_APPLICATION NIA\r\nON NIST.IAM_APPLICATION_KEY=NIA.IAM_APPLICATION_KEY\r\nINNER JOIN $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR FDT\r\nON CURRENT_DATE=FDT.CALENDAR_DATE\r\nWHERE\r\n(NIA.APPLICATION_NAME in(  'My Business Report Tool', 'MBR AM')\r\nOR (NIA.APPLICATION_NAME IN ('Sales BO','MBR Overlay') AND  NIST.BK_IAM_ROLE_NAME IN ('CV_BO_VIEW','CV_DB_ACCESS','CV_DB_ACCESS_ALL_VER','SLS_BO_OVL_VW','OVL_Territory') ))\r\nAND NIST.SOURCE_DELETED_FLG='N'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "DELETE FROM $$SECURITYVWDB.MT_IAM_SALESBO_SLS_TERR_LINK\r\nWHERE FISCAL_YEAR_MONTH_INT IN (SELECT FISCAL_YEAR_MONTH_INT FROM $$COMREFVWDB.R_FISCAL_DAY_TO_YEAR WHERE CALENDAR_DATE=CURRENT_DATE);",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
