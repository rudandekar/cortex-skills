      "attributes": {
        "Sql Query": "SELECT\r\nSIEURPH.ROLE_NAME AS BK_IAM_ROLE_NAME,\r\nNIU.IAM_USER_KEY AS IAM_USER_KEY,\r\nSIA.IAM_APPLICATION_KEY AS IAM_APPLICATION_KEY,\r\nSIEURPH.ERP_SEGMENT1 AS BUSINESS_UNIT_ID,\r\nSIEURPH.ASSIGNMENT_TYPE AS ASSIGNMENT_TYPE,\r\nSIEURPH.DATA_RES_EXPT_FLAG AS STANDARD_OR_EXCEPTION_FLG,\r\nSIEURPH.EXCL_RESTR_FLAG AS EXCLUSIVE_OR_RESTRICTIVE_FLG,\r\nCASE WHEN SIEURPH.STATUS = 'A' THEN 'N'\r\nWHEN SIEURPH.STATUS = 'I' THEN 'Y' END SOURCE_DELETED_FLG,\r\nSIEURPH.LVL_NUMBER AS IAM_LEVEL_NUM_INT,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n 'I'\tACTION_CODE,\r\nCASE WHEN NURPHB.BK_BUSINESS_UNIT_ID IS NOT NULL AND\r\nNURPHB.BK_IAM_ROLE_NAME IS NOT NULL AND\r\nNURPHB.IAM_USER_KEY IS NOT NULL AND\r\nNURPHB.IAM_APPLICATION_KEY IS NOT NULL\r\n THEN 'U' ELSE 'I' END DML_TYPE\r\nFROM \r\n(SEL \r\nSIEURPH.ROLE_NAME,\r\nSIEURPH.ERP_SEGMENT1,\r\nSIEURPH.ASSIGNMENT_TYPE,\r\nSIEURPH.DATA_RES_EXPT_FLAG ,\r\nSIEURPH.EXCL_RESTR_FLAG ,\r\nSIEURPH.STATUS,\r\nSIEURPH.LVL_NUMBER,\r\nSIEURPH.UPDATE_DATE,\r\nSIEURPH.TOOL_ID,\r\nSIEURPH.IAM_USER_ID \r\nFROM \r\n $$STGDB.ST_IAM_EDWTD_USR_ROL_PRD_HR  SIEURPH\r\n UNION ALL\r\n SEL\r\n SIEURPH.ROLE_NAME,\r\nSIEURPH.ERP_SEGMENT1,\r\nSIEURPH.ASSIGNMENT_TYPE,\r\nSIEURPH.DATA_RES_EXPT_FLAG ,\r\nSIEURPH.EXCL_RESTR_FLAG ,\r\nSIEURPH.STATUS,\r\nSIEURPH.LVL_NUMBER,\r\nSIEURPH.UPDATE_DATE,\r\nSIEURPH.TOOL_ID,\r\nSIEURPH.IAM_USER_ID \r\nFROM\r\n $$EXCEPDB.EX_IAM_USR_ROLE_PRD_HIER_BU SIEURPH) SIEURPH\r\nINNER JOIN  $$ETLVWDB.IAM_APPLICATION_CTRL  IAC\r\nON (SIEURPH.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nINNER JOIN  $$COMREFVWDB.N_BUSINESS_UNIT NBU\t\t\t\r\nON (SIEURPH.ERP_SEGMENT1 = NBU.BK_BUSINESS_UNIT_ID )\r\nINNER JOIN  $$SECURITYVWDB.N_IAM_ROLE NIR\r\nON ( SIEURPH.ROLE_NAME=NIR.BK_IAM_ROLE_NAME)\r\nINNER JOIN  $$SECURITYVWDB.N_IAM_USER NIU\r\nON (NIU.SK_IAM_USER_ID_INT = SIEURPH.IAM_USER_ID )\r\nINNER JOIN  $$ETLVWDB.SM_IAM_APPLICATION SIA\r\nON (SIEURPH.TOOL_ID=SIA.SK_APPLICATION_ID_INT)\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_BUSINESS_UNIT_LINK NURPHB\r\nON(NURPHB.BK_BUSINESS_UNIT_ID = NBU.BK_BUSINESS_UNIT_ID  AND\r\nNURPHB.BK_IAM_ROLE_NAME = SIEURPH.ROLE_NAME AND\r\nNURPHB.IAM_USER_KEY = NIU.IAM_USER_KEY AND\r\nNURPHB.IAM_APPLICATION_KEY = SIA.IAM_APPLICATION_KEY)\r\nwhere  SIEURPH.LVL_NUMBER = 2\r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY SIEURPH.ROLE_NAME,SIEURPH.IAM_USER_ID, SIA.IAM_APPLICATION_KEY,SIEURPH.ERP_SEGMENT1\r\n   ORDER BY SIEURPH.UPDATE_DATE  DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    },
