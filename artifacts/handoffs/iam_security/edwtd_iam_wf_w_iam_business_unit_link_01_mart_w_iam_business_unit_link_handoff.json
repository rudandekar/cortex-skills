      ],
      "attributes": {
        "Sql Query": "SEL\r\nSIEURPH.IAM_USER_ID,                   \r\nSIEURPH.ROLE_ID,                       \r\nSIEURPH.ROLE_NAME,                     \r\nSIEURPH.TOOL_ID ,                      \r\nSIEURPH.DATA_STRUCT_TYPE,              \r\nSIEURPH.LVL_NUMBER,                   \r\nSIEURPH.ERP_SEGMENT1,                  \r\nSIEURPH.ASSIGNMENT_TYPE ,              \r\nSIEURPH.DATA_RES_EXPT_FLAG,            \r\nSIEURPH.EXCL_RESTR_FLAG,               \r\nSIEURPH.RESTRICTION_FLAG ,             \r\nSIEURPH.PROXY_FLAG,                    \r\nSIEURPH.GRANTOR_UNIVERSAL_ID,          \r\nSIEURPH.GRANTOR_CEC_ID,                \r\nSIEURPH.GRANTOR_CCO_ID,                \r\nSIEURPH.STATUS,                        \r\nSIEURPH.TR_FLAG ,                      \r\nSIEURPH.LAST_ACTION ,                  \r\nSIEURPH.CREATED_BY ,                   \r\nSIEURPH.CREATE_DATE,                 \r\nSIEURPH.UPDATED_BY,                    \r\nSIEURPH.UPDATE_DATE,                   \r\nSIEURPH.ACTION_CODE,                   \r\nSIEURPH.BATCH_ID,                      \r\nSIEURPH.CREATE_DATETIME,       \r\n'RI' AS EXCEPTION_TYPE               \r\nFROM\r\n$$STGDB.ST_IAM_EDWTD_USR_ROL_PRD_HR SIEURPH\r\nINNER JOIN $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (SIEURPH.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nWHERE  SIEURPH.LVL_NUMBER = 2 AND (\r\nNOT EXISTS ( SELECT 1 FROM $$COMREFVWDB.N_BUSINESS_UNIT NBU\r\nWHERE  SIEURPH.ERP_SEGMENT1 = NBU.BK_BUSINESS_UNIT_ID)\r\nOR  NOT EXISTS ( SELECT 1 FROM $$SECURITYVWDB.N_IAM_ROLE NIR\r\nWHERE SIEURPH.ROLE_NAME=NIR.BK_IAM_ROLE_NAME )\r\nOR  NOT EXISTS ( SELECT 1 FROM $$SECURITYVWDB.N_IAM_USER NIU\r\nWHERE NIU.SK_IAM_USER_ID_INT = SIEURPH.IAM_USER_ID )\r\nOR NOT EXISTS (SELECT 1 FROM $$ETLVWDB.SM_IAM_APPLICATION SIA\r\nWHERE SIEURPH.TOOL_ID=SIA.SK_APPLICATION_ID_INT))",
        "User Defined Join": "",
