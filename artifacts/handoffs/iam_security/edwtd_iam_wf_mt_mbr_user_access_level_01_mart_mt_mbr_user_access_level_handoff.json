      "attributes": {
        "Sql Query": "SELECT \r\nDISTINCT DD_CEC_ID, MIN(IAM_LEVEL_NUM_INT) TOP_LEVEL_INT, (TOP_LEVEL_INT+1) SUBSEQUENT_LEVEL_INT ,\r\nCASE WHEN APPLICATION_NAME='My Business Report Tool' AND BK_SALES_TERR_ASSGNMNT_TYPE_CD='DR' THEN 'MBR RM DR'\r\nWHEN APPLICATION_NAME='My Business Report Tool' AND BK_SALES_TERR_ASSGNMNT_TYPE_CD='IS' THEN 'MBR RM IS'\r\nWHEN APPLICATION_NAME='MBR AM' THEN 'MBR AM'\r\nWHEN APPLICATION_NAME='MBR Overlay'  THEN 'MBR Overlay' ELSE NULL end  BK_APPLICATION_NAME,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER\r\nFROM $$SECURITYVWDB.MT_BUSMBR_IAM_SALES_TERR_LINK LNK, $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMY\r\nWHERE RFMY.FISCAL_YEAR_MONTH_INT = LNK.FISCAL_YEAR_MONTH_INT\r\nAND RFMY.CURRENT_FISCAL_MONTH_FLAG='Y'\r\nAND BK_IAM_ROLE_NAME <> 'Bookings 360'\r\nAND DD_CEC_ID<>'  -999' AND DD_CEC_ID IS NOT NULL AND BK_APPLICATION_NAME IS NOT NULL\r\nGROUP BY DD_CEC_ID,BK_APPLICATION_NAME\r\n\r\nUNION ALL\r\n\r\nSELECT \r\nDISTINCT DD_CEC_ID, MIN(IAM_LEVEL_NUM_INT) TOP_LEVEL_INT, (TOP_LEVEL_INT+1) SUBSEQUENT_LEVEL_INT ,\r\nCASE WHEN APPLICATION_NAME='My Business Report Tool' AND BK_SALES_TERR_ASSGNMNT_TYPE_CD='DR'  THEN 'MBR RM PREV' ELSE NULL END BK_APPLICATION_NAME,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER\r\nFROM $$SECURITYVWDB.MT_BUSMBR_IAM_SALES_TERR_LINK MBISTL\r\nWHERE FISCAL_YEAR_MONTH_INT=(SELECT MAX(FISCAL_YEAR_MONTH_INT) FROM $$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMY WHERE FISCAL_YEAR_AGE=1)\r\nAND BK_IAM_ROLE_NAME <> 'Bookings 360'\r\nAND DD_CEC_ID<>'  -999' AND DD_CEC_ID IS NOT NULL AND BK_APPLICATION_NAME IS NOT NULL\r\nGROUP BY DD_CEC_ID,BK_APPLICATION_NAME",
        "User Defined Join": "",
