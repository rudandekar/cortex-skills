      "attributes": {
        "Sql Query": "SELECT     \r\nSALES_TERR.DD_CEC_ID,\r\nSALES_TERR.BK_IAM_ROLE_NAME,\r\nH.SALES_TERRITORY_KEY,\r\nH.L1_SALES_TERRITORY_NAME_CODE,\r\nSALES_TERR.DD_SALES_TERRITORY_DESCR,\r\nSALES_TERR.START_TV_DT,\r\nSALES_TERR.END_TV_DT,\r\nSALES_TERR.FISCAL_YEAR_MONTH_INT,\r\nRFMY.FISCAL_MONTH_NAME,\r\nSALES_TERR.APPLICATION_NAME,\r\nSALES_TERR.BK_SALES_TERR_ASSGNMNT_TYPE_CD,\r\nSALES_TERR.IAM_LEVEL_NUM_INT\r\nFROM  \r\n$$SECURITYVWDB.MT_BUSMBR_IAM_SALES_TERR_LINK  SALES_TERR ,\r\n$$COMREFVWDB.R_SALES_HIERARCHY_TV  H  ,\r\n$$COMREFVWDB.R_FISCAL_MONTH_TO_YEAR RFMY\r\nWHERE   (SALES_TERR.FISCAL_YEAR_MONTH_INT =  H.DV_FISCAL_MONTH_TO_YEAR_KEY ) \r\nAND RFMY.FISCAL_YEAR_MONTH_INT = H.DV_FISCAL_MONTH_TO_YEAR_KEY\r\nAND    (\r\n(SALES_TERR.DD_BK_SALES_TERR_NAME =  H.L6_SALES_TERRITORY_NAME_CODE ) \r\nOR(SALES_TERR.DD_BK_SALES_TERR_NAME =  H.L5_SALES_TERRITORY_NAME_CODE ) \r\nOR(SALES_TERR.DD_BK_SALES_TERR_NAME =  H.L4_SALES_TERRITORY_NAME_CODE ) \r\nOR(SALES_TERR.DD_BK_SALES_TERR_NAME =  H.L3_SALES_TERRITORY_NAME_CODE ) \r\nOR(SALES_TERR.DD_BK_SALES_TERR_NAME =  H.L2_SALES_TERRITORY_NAME_CODE ) \r\nOR(SALES_TERR.DD_BK_SALES_TERR_NAME =  H.L1_SALES_TERRITORY_NAME_CODE ) \r\nOR(SALES_TERR.DD_BK_SALES_TERR_NAME =  H.L0_SALES_TERRITORY_NAME_CODE )\r\nOR(SALES_TERR.DD_BK_SALES_TERR_NAME =  H.L7_SALES_TERRITORY_NAME_CODE )\r\nOR(SALES_TERR.DD_BK_SALES_TERR_NAME =  H.L8_SALES_TERRITORY_NAME_CODE )\r\nOR(SALES_TERR.DD_BK_SALES_TERR_NAME =  H.L9_SALES_TERRITORY_NAME_CODE )\r\nOR(SALES_TERR.DD_BK_SALES_TERR_NAME =  H.L10_SALES_TERRITORY_NAME_CODE ))\r\nAND   SALES_TERR.APPLICATION_NAME  ='MBR Overlay'\r\nAND   SALES_TERR.BK_IAM_ROLE_NAME ='OVL_Territory'\r\nAND   SALES_TERR.BK_SALES_TERR_ASSGNMNT_TYPE_CD <> 'DR'\r\nAND RFMY.CURRENT_FISCAL_MONTH_FLAG    ='Y'",
        "User Defined Join": "",
