      "attributes": {
        "Sql Query": "SELECT\r\nSIEURBD.IAM_USER_ID  ,                 \r\nSIEURBD.ROLE_ID    ,                   \r\nSIEURBD.ROLE_NAME  ,                   \r\nSIEURBD.TOOL_ID  ,                     \r\nSIEURBD.BIZ_DATA_ATTRIB_NAME ,         \r\nSIEURBD.BIZ_DATA_ATTRIB_DESCR ,        \r\nSIEURBD.EXCL_RESTR_FLAG,               \r\nSIEURBD.PROXY_FLAG  ,                  \r\nSIEURBD.GRANTOR_UNIVERSAL_ID ,         \r\nSIEURBD.GRANTOR_CEC_ID  ,              \r\nSIEURBD.GRANTOR_CCO_ID ,               \r\nSIEURBD.STATUS ,                       \r\nSIEURBD.TR_FLAG ,                      \r\nSIEURBD.LAST_ACTION  ,                 \r\nSIEURBD.CREATED_BY ,                   \r\nSIEURBD.CREATE_DATE  ,                 \r\nSIEURBD.UPDATED_BY ,                   \r\nSIEURBD.UPDATE_DATE ,                  \r\nSIEURBD.ACTION_CODE,                   \r\nSIEURBD.BATCH_ID  ,                    \r\nSIEURBD.CREATE_DATETIME ,\r\n'RI' EXCEPTION_TYPE              \r\nFROM $$STGDB.ST_IAM_EDWTD_USR_ROLE_BIZ_DATA SIEURBD\r\nINNER JOIN  $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (SIEURBD.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nWHERE NOT EXISTS(SELECT 1 FROM $$SECURITYVWDB.N_IAM_BUSINESS_DATA_ATTRIBUTE NIBDA\r\nWHERE SIEURBD.BIZ_DATA_ATTRIB_NAME = NIBDA.BK_BIZ_DATA_ATTRIBUTE_NAME)\r\nOR NOT EXISTS(SELECT 1 FROM $$SECURITYVWDB.N_IAM_ROLE NIR\r\nWHERE SIEURBD.ROLE_NAME = NIR.BK_IAM_ROLE_NAME)\r\nOR NOT EXISTS(SELECT 1 FROM $$ETLVWDB.SM_IAM_USER SIU\r\nWHERE SIU.SK_IAM_USER_ID_INT=SIEURBD.IAM_USER_ID)\r\nOR NOT EXISTS(SELECT 1 FROM $$ETLVWDB.SM_IAM_APPLICATION SIA\r\nWHERE SIA.SK_APPLICATION_ID_INT=SIEURBD.TOOL_ID)",
