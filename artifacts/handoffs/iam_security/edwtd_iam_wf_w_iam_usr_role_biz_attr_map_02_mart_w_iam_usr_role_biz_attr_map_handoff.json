      "attributes": {
        "Sql Query": "SELECT \r\nOUTPUT.BK_BIZ_DATA_ATTRIBUTE_NAME,\r\nOUTPUT.BK_IAM_ROLE_NAME,\r\nOUTPUT.IAM_APPLICATION_KEY,\r\nOUTPUT.IAM_USER_KEY,\r\nOUTPUT.RESTRICT_OR_GRANT_FLG,\r\nOUTPUT.SOURCE_DELETED_FLG,\r\nOUTPUT.EDW_CREATE_USER,\r\nOUTPUT.EDW_CREATE_DTM,\r\nOUTPUT.EDW_UPDATE_USER,\r\nOUTPUT.EDW_UPDATE_DTM,\r\nOUTPUT.ACTION_CODE,\r\nOUTPUT.DML_TYPE\r\nFROM\r\n(\r\nSELECT \r\nDT.BK_BIZ_DATA_ATTRIBUTE_NAME,\r\nDT.BK_IAM_ROLE_NAME,\r\nDT.IAM_APPLICATION_KEY,\r\nDT.IAM_USER_KEY,\r\nDT.RESTRICT_OR_GRANT_FLG,\r\nDT.SOURCE_DELETED_FLG,\r\nDT.EDW_CREATE_USER,\r\nDT.EDW_CREATE_DTM,\r\nDT.EDW_UPDATE_USER,\r\nDT.EDW_UPDATE_DTM,\r\nDT.ACTION_CODE,\r\nDT.DML_TYPE,\r\nDT.UPDATE_DATE\r\nFROM\r\n(\r\nSELECT\r\nSIEURBD.BIZ_DATA_ATTRIB_NAME AS BK_BIZ_DATA_ATTRIBUTE_NAME,\r\nSIEURBD.ROLE_NAME AS BK_IAM_ROLE_NAME,\r\nSIU.IAM_USER_KEY AS IAM_USER_KEY,\r\nSIA.IAM_APPLICATION_KEY AS IAM_APPLICATION_KEY,\r\n'G' AS RESTRICT_OR_GRANT_FLG,\r\nCASE WHEN SIEURBD.STATUS='A'\r\nTHEN 'N'\r\nWHEN SIEURBD.STATUS='I'\r\nTHEN 'Y' END AS SOURCE_DELETED_FLG,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NIURBAM.BK_BIZ_DATA_ATTRIBUTE_NAME IS NOT NULL AND  NIURBAM.BK_IAM_ROLE_NAME IS NOT NULL AND\r\nNIURBAM.IAM_APPLICATION_KEY IS NOT NULL AND NIURBAM. IAM_USER_KEY IS NOT NULL\r\n  THEN 'U'  ELSE 'I' END DML_TYPE,\r\n  SIEURBD.UPDATE_DATE\r\nFROM $$STGDB.ST_IAM_EDWTD_USR_ROLE_BIZ_DATA SIEURBD\r\nINNER JOIN  $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (SIEURBD.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nINNER JOIN $$SECURITYVWDB.N_IAM_BUSINESS_DATA_ATTRIBUTE NIBDA\r\nON SIEURBD.BIZ_DATA_ATTRIB_NAME = NIBDA.BK_BIZ_DATA_ATTRIBUTE_NAME\r\nINNER JOIN $$SECURITYVWDB.N_IAM_ROLE NIR\r\nON SIEURBD.ROLE_NAME = NIR.BK_IAM_ROLE_NAME\r\nINNER JOIN $$ETLVWDB.SM_IAM_USER SIU\r\nON SIU.SK_IAM_USER_ID_INT=SIEURBD.IAM_USER_ID\r\nINNER JOIN $$ETLVWDB.SM_IAM_APPLICATION SIA\r\nON SIA.SK_APPLICATION_ID_INT=SIEURBD.TOOL_ID\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_USR_ROLE_BIZ_ATTR_MAP  NIURBAM\r\nON NIURBAM.BK_BIZ_DATA_ATTRIBUTE_NAME=SIEURBD.BIZ_DATA_ATTRIB_NAME\r\nAND NIURBAM.BK_IAM_ROLE_NAME=SIEURBD.ROLE_NAME\r\nAND NIURBAM.IAM_APPLICATION_KEY=SIA.IAM_APPLICATION_KEY\r\nAND NIURBAM. IAM_USER_KEY=SIU.IAM_USER_KEY\r\n\r\nUNION ALL\r\n\r\nSELECT\r\nEIEURBD.BIZ_DATA_ATTRIB_NAME AS BK_BIZ_DATA_ATTRIBUTE_NAME,\r\nEIEURBD.ROLE_NAME AS BK_IAM_ROLE_NAME,\r\nSIU.IAM_USER_KEY AS IAM_USER_KEY,\r\nSIA.IAM_APPLICATION_KEY AS IAM_APPLICATION_KEY,\r\n'G' AS RESTRICT_OR_GRANT_FLG,\r\nCASE WHEN EIEURBD.STATUS='A'\r\nTHEN 'N'\r\nWHEN EIEURBD.STATUS='I'\r\nTHEN 'Y' END AS SOURCE_DELETED_FLG,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN NIURBAM.BK_BIZ_DATA_ATTRIBUTE_NAME IS NOT NULL AND  NIURBAM.BK_IAM_ROLE_NAME IS NOT NULL AND\r\nNIURBAM.IAM_APPLICATION_KEY IS NOT NULL AND NIURBAM. IAM_USER_KEY IS NOT NULL\r\n  THEN 'U'  ELSE 'I' END DML_TYPE,\r\n  EIEURBD.UPDATE_DATE\r\nFROM $$EXCEPDB.EX_IAM_EDWTD_USR_ROLE_BIZ_DATA EIEURBD\r\nINNER JOIN  $$ETLVWDB.IAM_APPLICATION_CTRL IAC\r\nON (EIEURBD.TOOL_ID=IAC.TOOL_ID AND IAC.STATUS ='A')\r\nINNER JOIN $$SECURITYVWDB.N_IAM_BUSINESS_DATA_ATTRIBUTE NIBDA\r\nON EIEURBD.BIZ_DATA_ATTRIB_NAME = NIBDA.BK_BIZ_DATA_ATTRIBUTE_NAME\r\nINNER JOIN $$SECURITYVWDB.N_IAM_ROLE NIR\r\nON EIEURBD.ROLE_NAME = NIR.BK_IAM_ROLE_NAME\r\nINNER JOIN $$ETLVWDB.SM_IAM_USER SIU\r\nON SIU.SK_IAM_USER_ID_INT=EIEURBD.IAM_USER_ID\r\nINNER JOIN $$ETLVWDB.SM_IAM_APPLICATION SIA\r\nON SIA.SK_APPLICATION_ID_INT=EIEURBD.TOOL_ID\r\nLEFT OUTER JOIN $$SECURITYVWDB.N_IAM_USR_ROLE_BIZ_ATTR_MAP  NIURBAM\r\nON NIURBAM.BK_BIZ_DATA_ATTRIBUTE_NAME=EIEURBD.BIZ_DATA_ATTRIB_NAME\r\nAND NIURBAM.BK_IAM_ROLE_NAME=EIEURBD.ROLE_NAME\r\nAND NIURBAM.IAM_APPLICATION_KEY=SIA.IAM_APPLICATION_KEY\r\nAND NIURBAM. IAM_USER_KEY=SIU.IAM_USER_KEY\r\n)DT\r\n)OUTPUT \r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY OUTPUT.BK_BIZ_DATA_ATTRIBUTE_NAME,\r\nOUTPUT.BK_IAM_ROLE_NAME,OUTPUT.IAM_USER_KEY,OUTPUT.IAM_APPLICATION_KEY ORDER BY OUTPUT.UPDATE_DATE DESC) = 1",
