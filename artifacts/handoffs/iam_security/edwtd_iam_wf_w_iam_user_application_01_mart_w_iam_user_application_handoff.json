      "attributes": {
        "Sql Query": "select\t \r\nNIU.IAM_USER_KEY AS IAM_USER_KEY,\r\nSIA.IAM_APPLICATION_KEY AS IAM_APPLICATION_KEY, EDWTD_LOGIN_TYPE_CD, COALESCE(PURGE_USAGE_FLG, '=')  AS PURGE_USAGE_FLG,  COALESCE(ADMIN_ACCESS_FLG, '=') AS ADMIN_ACCESS_FLG, \r\nREVALIDATION_CD, COALESCE(PROXY_ACCESS_FLG, '=') AS PROXY_ACCESS_FLG, COALESCE(PARTY.CISCO_WORKER_PARTY_KEY, -999 ) AS BI_REPRESENTATIVE_PARTY_KEY, LOG_LEVEL_INT\r\nFROM\r\n(select\t   STG.USER_ID, STG.APPLICATION_ID, MAX(TD_LOGIN.ATTR_VALUE) AS EDWTD_LOGIN_TYPE_CD, MAX(PURGE.ATTR_VALUE) AS PURGE_USAGE_FLG, MAX(ADMIN_ACCESS.ATTR_VALUE) AS ADMIN_ACCESS_FLG, \r\nMAX(REVALID.ATTR_VALUE) AS REVALIDATION_CD, MAX(PROXY_ACCESS.ATTR_VALUE) AS PROXY_ACCESS_FLG, MAX(LOG_LEVEL.ATTR_VALUE) AS LOG_LEVEL_INT, MAX(BI_REP.ATTR_VALUE) AS BI_REP FROM\r\n$$STGDB.ST_IAM_EDWTD_USR_APP_ATTR STG\r\nleft outer join  $$STGDB.ST_IAM_EDWTD_USR_APP_ATTR  TD_LOGIN\r\n\ton\t STG.USER_ID=TD_LOGIN.USER_ID \r\n\tAND\t STG.APPLICATION_ID=TD_LOGIN.APPLICATION_ID \r\n\tAND\t TD_LOGIN.ATTR_NAME = 'TD_LOGIN'\r\nleft outer join  $$STGDB.ST_IAM_EDWTD_USR_APP_ATTR  PURGE\r\n\ton\t STG.USER_ID=PURGE.USER_ID \r\n\tAND\t STG.APPLICATION_ID=PURGE.APPLICATION_ID \r\n\tAND\t PURGE.ATTR_NAME = 'PURGE_USAGE_FLAG'\r\nLeft outer join  $$STGDB.ST_IAM_EDWTD_USR_APP_ATTR  ADMIN_ACCESS\r\n\ton\t STG.USER_ID=ADMIN_ACCESS.USER_ID \r\n\tAND\t STG.APPLICATION_ID=ADMIN_ACCESS.APPLICATION_ID \r\n\tAND\t ADMIN_ACCESS.ATTR_NAME = 'ADMIN_ACCESS'\r\nleft outer join  $$STGDB.ST_IAM_EDWTD_USR_APP_ATTR  REVALID\r\n\ton\t STG.USER_ID=REVALID.USER_ID \r\n\tAND\t STG.APPLICATION_ID=REVALID.APPLICATION_ID \r\n\tAND\t REVALID.ATTR_NAME = 'REVALIDATION_FLAG'\r\nLeft outer join  $$STGDB.ST_IAM_EDWTD_USR_APP_ATTR  PROXY_ACCESS\r\n\ton\t STG.USER_ID=PROXY_ACCESS.USER_ID \r\n\tAND\t STG.APPLICATION_ID=PROXY_ACCESS.APPLICATION_ID \r\n\tAND\t PROXY_ACCESS.ATTR_NAME = 'PROXY_ACCESS'\r\nleft outer join  $$STGDB.ST_IAM_EDWTD_USR_APP_ATTR  LOG_LEVEL\r\n\ton\t STG.USER_ID=LOG_LEVEL.USER_ID \r\n\tAND\t STG.APPLICATION_ID=LOG_LEVEL.APPLICATION_ID \r\n\tAND\t LOG_LEVEL.ATTR_NAME = 'LOG_LEVEL'\r\nleft outer join  $$STGDB.ST_IAM_EDWTD_USR_APP_ATTR  BI_REP\r\n\ton\t STG.USER_ID=BI_REP.USER_ID \r\n\tAND\t STG.APPLICATION_ID=BI_REP.APPLICATION_ID \r\n\tAND\t BI_REP.ATTR_NAME = 'BI_REP'\r\nGROUP BY 1,2) STG \r\nINNER JOIN $$SECURITYVWDB.N_IAM_USER NIU\r\n\tON\t STG.USER_ID = NIU.CCO_ID \r\nINNER JOIN $$SECURITYVWDB.N_IAM_APPLICATION SIA\r\n\tON\t STG.APPLICATION_ID=SIA.SK_APPLICATION_ID_INT\r\nLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY PARTY\r\n\tON STG.BI_REP=PARTY.CISCO_EMAIL_ADDRESS",
        "User Defined Join": "",
        "Source Filter": "",
