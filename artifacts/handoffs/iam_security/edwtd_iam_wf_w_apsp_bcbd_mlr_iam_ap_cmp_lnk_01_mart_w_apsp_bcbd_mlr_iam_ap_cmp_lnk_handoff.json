      "attributes": {
        "Sql Query": "SEL COMP.IAM_APPLICATION_COMPONENT_KEY, SM.BCBD_USER_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n 'I'    ACTION_CODE,\r\n'I'  DML_TYPE  \r\nFROM\t\r\n$$SECURITYVWDB.N_IAM_USER_ROLE_APP_COMP_MAP COMP\r\nINNER JOIN\r\n$$TRANSLATIONDB.SM_APSP_BCBD_USER SM\r\nON SM.IAM_USER_KEY = COMP.IAM_USER_KEY AND SM.IAM_USER_KEY <> -999  AND COMP.SOURCE_DELETED_FLG='N'\r\nINNER JOIN $$SECURITYVWDB.N_IAM_APPLICATION APP\r\n\tON\tAPP.IAM_APPLICATION_KEY=COMP.IAM_APPLICATION_KEY \r\n\tAND\tAPPLICATION_NAME='BI Cafe-2'\r\n\r\nUNION\r\n\r\nSEL COMP.IAM_APPLICATION_COMPONENT_KEY, SM.BCBD_USER_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n 'I'    ACTION_CODE,\r\n'I'  DML_TYPE  \r\nFROM\r\n$$STGDB.WI_ML_SECURITY_LOAD ST\r\nINNER JOIN\r\n$$TRANSLATIONDB.SM_APSP_BCBD_USER SM\r\nON SM.BK_BCBD_MAILER_ALIAS_ADDR = ST.USER_ID\r\nINNER JOIN $$SECURITYVWDB.N_IAM_ROLE_APP_COMPONENT_MAP COMP\r\nON ST.ROLE_NAME=COMP.BK_IAM_ROLE_NAME",
