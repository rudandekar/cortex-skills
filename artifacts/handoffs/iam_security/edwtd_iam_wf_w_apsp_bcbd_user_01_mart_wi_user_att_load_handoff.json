      "attributes": {
        "Sql Query": "SEL  DISTINCT SM.BCBD_USER_KEY, SM.BK_BCBD_USER_TYPE, ROLE_NAME RU_IAM_ROLE_NAME, -999 IAM_USER_KEY, \r\nNULL\tRU_APSP_BCBD_USER_GROUP_NAME,\r\nNULL\tRU_APSP_BCBD_THEATER_NAME,\r\nBK_BCBD_MAILER_ALIAS_ADDR\tRU_BCBD_MAILER_ALIAS_ADDR,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCAST(CURRENT_DATE AS DATE) START_TV_DT,\r\n'3500-01-01'       END_TV_DT,                                                                               \r\n'I'    ACTION_CODE,\r\n'I'  DML_TYPE FROM \r\n$$STGDB.WI_ML_SECURITY_LOAD SEC\r\nINNER JOIN $$TRANSLATIONDB.SM_APSP_BCBD_USER SM\r\nON  SEC.USER_ID=SM.BK_BCBD_MAILER_ALIAS_ADDR\r\nWHERE SM.BK_BCBD_USER_TYPE = 'MAILER ALIAS'",
