      "attributes": {
        "Sql Query": "SEL  DISTINCT SM.BCBD_USER_KEY, SM.BK_BCBD_USER_TYPE, NULL RU_IAM_ROLE_NAME, SM.IAM_USER_KEY, \r\nATT.USER_GROUP\tRU_APSP_BCBD_USER_GROUP_NAME,\r\nATT.THEATER_NAME\tRU_APSP_BCBD_THEATER_NAME,\r\nNULL\tRU_BCBD_MAILER_ALIAS_ADDR,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCAST(CURRENT_DATE AS DATE) START_TV_DT,\r\n'3500-01-01'       END_TV_DT,                                                                               \r\n'I'    ACTION_CODE,\r\n'I'  DML_TYPE FROM \r\n$$SECURITYVWDB.MT_APSP_BCBD_SECURITY SEC\r\nINNER JOIN $$SECURITYVWDB.N_IAM_USER USR\r\nON SEC.DD_CEC_ID=USR.DD_CEC_ID AND USR.SOURCE_DELETED_FLG='N' \r\nINNER JOIN $$TRANSLATIONDB.SM_APSP_BCBD_USER SM\r\nON  USR.IAM_USER_KEY=SM.IAM_USER_KEY\r\nLEFT OUTER JOIN $$STGDB.WI_USER_ATT_LOAD ATT\r\nON SEC.DD_CEC_ID=ATT.USER_ID\r\nWHERE SM.BK_BCBD_USER_TYPE = 'IAM USER'",
