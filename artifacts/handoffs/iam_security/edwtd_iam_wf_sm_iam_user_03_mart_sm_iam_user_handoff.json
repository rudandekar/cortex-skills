      "attributes": {
        "Sql Query": "SELECT \r\nRANK() OVER \r\n\t\t\t(ORDER BY \r\n\t\t\t\tSTUSER_BK.SK_IAM_USER_ID_INT) +  SMUSER_MAX.MAX_USER_SGK_VAL  IAM_USER_KEY,\r\nSTUSER_BK.SK_IAM_USER_ID_INT \t\tSK_IAM_USER_ID_INT,\r\nUSER \t\t\t\t\t\t\t\tEDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) \t\t\t\tEDW_CREATE_DTM\r\nFROM \r\n(\r\nSELECT \r\nDISTINCT SIUV.IAM_USER_ID \t\tSK_IAM_USER_ID_INT\r\nFROM \r\n$$STGDB.ST_IAM_EDWTD_USER SIUV\r\n)  STUSER_BK,\r\n(SELECT COALESCE(MAX(IAM_USER_KEY),0)  MAX_USER_SGK_VAL\r\n    FROM $$ETLVWDB.SM_IAM_USER) SMUSER_MAX\r\n\tWHERE NOT EXISTS\r\n\t\t(SELECT 1 FROM $$ETLVWDB.SM_IAM_USER SIM \r\n\t\t\tWHERE SIM.SK_IAM_USER_ID_INT=\tSTUSER_BK.SK_IAM_USER_ID_INT\r\n\t \t)\r\n\tAND  NOT EXISTS\r\n\t\t(SELECT 1 FROM  \r\n\t\t\t(SELECT \r\n\t\t\t\tDISTINCT EIUV.IAM_USER_ID\t\t\t\t\r\n\t\t \tFROM  \r\n\t\t\t$$EXCEPDB.EX_IAM_EDWTD_USER EIUV \r\n\t\t\t )EXCEP_BK\r\n\t\t\t WHERE STUSER_BK.SK_IAM_USER_ID_INT=EXCEP_BK.IAM_USER_ID)",
