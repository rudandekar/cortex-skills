      "attributes": {
        "Sql Query": "SELECT SIUV.IAM_USER_ID,\r\n SIUV.UNIVERSAL_ID,\r\n SIUV.CCO_ID,\r\n SIUV.EMPLID,\r\n SIUV.CPR_ACCESS_LEVEL,\r\n SIUV.IAM_STATUS,\r\n SIUV.CREATED_BY,\r\n SIUV.CREATE_DATE,\r\n SIUV.UPDATED_BY,\r\n SIUV.UPDATE_DATE,\r\n SIUV.ACTION_CODE,\r\n SIUV.BATCH_ID,\r\n SIUV.CREATE_DATETIME,\r\n'RI' EXCEPTION_TYPE  \r\nFROM\r\n $$STGDB.ST_IAM_EDWTD_USER SIUV\r\n WHERE NOT EXISTS (SELECT 1 FROM $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWPT \r\nWHERE NCWPT.BK_EMPLOYEE_ID=SIUV.EMPLID)  AND SIUV.CPR_ACCESS_LEVEL=4\r\nUNION ALL\r\nSELECT SIUV.IAM_USER_ID,\r\n SIUV.UNIVERSAL_ID,\r\n SIUV.CCO_ID,\r\n SIUV.EMPLID,\r\n SIUV.CPR_ACCESS_LEVEL,\r\n SIUV.IAM_STATUS,\r\n SIUV.CREATED_BY,\r\n SIUV.CREATE_DATE,\r\n SIUV.UPDATED_BY,\r\n SIUV.UPDATE_DATE,\r\n SIUV.ACTION_CODE,\r\n SIUV.BATCH_ID,\r\n SIUV.CREATE_DATETIME,\r\n'RI' EXCEPTION_TYPE  \r\nFROM\r\n$$STGDB.ST_IAM_EDWTD_USER SIUV\r\n WHERE NOT EXISTS (SELECT 1 FROM $$SERVICEVWDB.N_LDAP_USER NCWPT \r\nWHERE LOWER(NCWPT.LDAP_USER_ID)= SIUV.CCO_ID)  AND SIUV.CPR_ACCESS_LEVEL=3",
