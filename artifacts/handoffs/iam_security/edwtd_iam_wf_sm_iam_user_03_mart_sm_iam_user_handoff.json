      "attributes": {
        "Sql Query": "SELECT EIUV.IAM_USER_ID,\r\n EIUV.UNIVERSAL_ID,\r\n EIUV.CCO_ID,\r\n EIUV.EMPLID,\r\n EIUV.CPR_ACCESS_LEVEL,\r\n EIUV.IAM_STATUS,\r\n EIUV.CREATED_BY,\r\n EIUV.CREATE_DATE,\r\n EIUV.UPDATED_BY,\r\n EIUV.UPDATE_DATE,\r\n EIUV.ACTION_CODE,\r\n EIUV.BATCH_ID,\r\n EIUV.CREATE_DATETIME \r\nFROM\r\n $$EXCEPDB.EX_IAM_EDWTD_USER EIUV\r\n WHERE EXCEPTION_TYPE='RI'\r\n AND NOT EXISTS\r\n(SELECT 1 FROM $$STGDB.ST_IAM_EDWTD_USER SIUV\r\nWHERE SIUV.IAM_USER_ID=EIUV.IAM_USER_ID)\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY EIUV.IAM_USER_ID\tORDER BY EIUV.CREATE_DATETIME DESC)  =1",
