      "attributes": {
        "Sql Query": "SELECT  PARTNER.CEC_ID, \r\n                 PARTNER.APPLICATION_NAME,\r\n                 COUNT(*)  AS PARTNER_CTRY_COUNT,\r\nPARTNER.IAM_APPLICATION_KEY,\r\nPARTNER.IAM_USER_KEY\r\n                  FROM \r\n(SELECT \r\nDISTINCT NIU.DD_CEC_ID AS CEC_ID,\r\nAPP.APPLICATION_NAME AS APPLICATION_NAME,\r\nLNK.PARTNER_COUNTRY_PARTY_KEY,\r\nAPP.IAM_APPLICATION_KEY,\r\nNIU.IAM_USER_KEY\r\nFROM \r\n$$SECURITYVWDB.N_IAM_USER NIU,\r\n$$SECURITYVWDB.N_IAM_APPLICATION APP,\r\n$$SECURITYVWDB.N_IAM_PTNRS_HIER_LNK PARTNER,\r\n$$COMREFVWDB.N_CHANNEL_PARTNER_SITE LNK,\r\n$$COMREFVWDB.N_CHNL_PTNR_COUNTRY CTRY\r\nWHERE\r\nPARTNER.IAM_APPLICATION_KEY = APP.IAM_APPLICATION_KEY\r\nAND NIU.IAM_USER_KEY = PARTNER.IAM_USER_KEY\r\nAND PARTNER.PARTNER_SITE_PARTY_KEY=LNK.PARTNER_SITE_PARTY_KEY\r\nAND CTRY.PARTNER_COUNTRY_PARTY_KEY=LNK.PARTNER_COUNTRY_PARTY_KEY\r\nAND PARTNR_COUNTRY_REGISTERED_TYPE='R'\r\nAND PARTNER.SOURCE_DELETED_FLG='N')  PARTNER\r\nGROUP BY PARTNER.CEC_ID,\r\nPARTNER.APPLICATION_NAME,\r\nPARTNER.IAM_APPLICATION_KEY,\r\nPARTNER.IAM_USER_KEY",
        "User Defined Join": "",
