      "attributes": {
        "Sql Query": "SELECT\r\nEL.OBJECT_ID,\r\nEL.QUOTE_OBJECT_ID,\r\nCOALESCE(EL.BILLTO_LOCATION,-9999) as BILLTO_LOCATION,\r\nNULL AS PARTY_ID,\r\nEL.CUSTOMER_NAME,\r\nNULL AS CUST_ACCT_SITE_ID,\r\n EL.CUST_ACCOUNT_ID,\r\n '-999' AS ACCOUNT_NUMBER,\r\n 'UNKNOWN' AS ADDRESS1,\r\n NULL AS ADDRESS2,\r\n NULL AS ADDRESS3,\r\n NULL AS ADDRESS4,\r\n 'UNKNOWN' AS COUNTRY,\r\n NULL AS CITY,\r\n NULL AS POSTAL_CODE,\r\n NULL AS STATE,\r\n NULL AS PROVINCE,\r\n NULL AS COUNTY,\r\n EL.COUNTRY_DESC,\r\n EL.CREATED_ON,\r\n EL.CREATED_BY,\r\n EL.UPDATED_ON,\r\n EL.UPDATED_BY,\r\n EL.EDW_UPDATED_DATE\r\n FROM\r\n $$ETLVWDB.EL_INT_DMR_DEAL_BILL_TO_RNWL_KAFKA EL\r\n--QUALIFY ROW_NUMBER() OVER(PARTITION BY EL.QUOTE_OBJECT_ID ORDER BY EL.EDW_UPDATED_DATE DESC)=1\r\nWhere EL.EDW_UPDATED_DATE >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS where JOB_STREAM_ID='wf_ST_INT_DMR_DEAL_BILL_TO_KAFKA_RNWL')\r\nAND EL.QUOTE_OBJECT_ID >0",
