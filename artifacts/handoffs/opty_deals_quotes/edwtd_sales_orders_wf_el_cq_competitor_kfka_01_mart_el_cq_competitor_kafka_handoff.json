      "attributes": {
        "Sql Query": "SELECT\tDISTINCT 1 AS BATCH_ID,\r\n\t\t ST.OBJECT_ID AS OBJECT_ID ,\r\n\t\tST.PARENT_ID AS DEAL_OBJECT_ID ,\r\n\t\tTD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(  ST.COMPETITOR_NAME,\r\n\t\t'[^!-~a-zA-Z0-9]+',\r\n\t\t' ',1,0,\r\n\t\t'i') ,\r\n\t\tX'0d' ,\r\n\t\t' ') ,\r\n\t\tX'0a' ,\r\n\t\t' ') AS COMPETITOR_NAME,\r\n\t\tTD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(  ST.COMP_PROD_NAME,\r\n\t\t'[^!-~a-zA-Z0-9]+',\r\n\t\t' ',1,0,\r\n\t\t'i') ,\r\n\t\tX'0d' ,\r\n\t\t' ') ,\r\n\t\tX'0a' ,\r\n\t\t' ') AS COMP_PROD_NAME,\r\n\t\tTD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(  ST.COMP_TYPE,\r\n\t\t'[^!-~a-zA-Z0-9]+',\r\n\t\t' ',1,0,\r\n\t\t'i') ,\r\n\t\tX'0d' ,\r\n\t\t' ') ,\r\n\t\tX'0a' ,\r\n\t\t' ') AS COMP_TYPE,\r\n\t\tTD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(  ST.COMP_TECH,\r\n\t\t'[^!-~a-zA-Z0-9]+',\r\n\t\t' ',1,0,\r\n\t\t'i') ,\r\n\t\tX'0d' ,\r\n\t\t' ') ,\r\n\t\tX'0a' ,\r\n\t\t' ') AS COMP_TECH,\r\n\t\tTD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(  ST.COMP_ADD_INFO,\r\n\t\t'[^!-~a-zA-Z0-9]+',\r\n\t\t' ',1,0,\r\n\t\t'i') ,\r\n\t\tX'0d' ,\r\n\t\t' ') ,\r\n\t\tX'0a' ,\r\n\t\t' ') AS COMP_ADD_INFO,\r\n\t\tCOALESCE(ST.CREATED_BY,\r\n\t\tSTD.CREATED_BY) as  CREATED_BY,\r\n\t\tCAST(STD.CREATED_ON AS TIMESTAMP(0) FORMAT 'DD-MMM-YYYY') as CREATED_ON,\r\n\t\tSTD.UPDATED_BY as  UPDATED_BY,\r\n\t\tCAST(STD.UPDATED_ON AS TIMESTAMP(0) FORMAT 'DD-MMM-YYYY') as UPDATED_ON,\r\n\t\tCAST(LEFT(OREPLACE(STD.DM_UPDATE_DATE,\r\n\t\t'T',' '), 19) as TIMESTAMP(0)) as DM_UPDATE_DATE,\r\n\t\tST.SOURCE ,\r\n\t\tTD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(  ST.INITIATED_SOURCE,\r\n\t\t'[^!-~a-zA-Z0-9]+',\r\n\t\t' ',1,0,\r\n\t\t'i') ,\r\n\t\tX'0d' ,\r\n\t\t' ') ,\r\n\t\tX'0a' ,\r\n\t\t' ') AS INITIATED_SOURCE,\r\n\t\t'' AS COMP_PROD_EU_PRICE,\r\n\t\tCAST(STD.CREATED_ON AS TIMESTAMP(0) FORMAT 'DD-MMM-YYYY')AS CREATE_DATETIME ,\r\n\t\t'I' AS ACTION_CODE ,\r\n\t\tST.UPDATED_BY_KAFKA,\r\n\t\tCAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,\r\n\t\t'T',' '), 19) as TIMESTAMP(0)) AS UPDATED_ON_KAFKA,\r\n\t\tST.OFFSET_NUMBER,\r\n\t\tST.PARTITION_NUMBER,\r\n\t\tCURRENT_TIMESTAMP(0) as EDW_CREATE_DTM,\r\n\t\tUSER as EDW_CREATE_USER,\r\n\t\tST.MESSAGE_SEQUENCE_NUMBER,\r\n\t\tCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n\t\tUSER AS EDW_UPDATE_USER \r\nFROM\t $$STGDB.ST_CQ_COMPETITOR_KAFKA_FF ST \r\nINNER JOIN \r\n( SELECT OBJECT_ID ,CREATED_ON,CREATED_BY,UPDATED_ON,UPDATED_BY,dm_update_date\r\n\t\tFROM $$STGDB.ST_INT_CQ_DEAL_KAFKA_FF STD          \r\n\t\tGROUP BY 1,2,3,4,5,6 ) STD     \r\n\tON ST.PARENT_ID = STD.OBJECT_ID  \r\nWHERE\tNOT EXISTS (\r\n\tSELECT\t1 \r\n\tFROM\t$$ETLVWDB.EL_CQ_COMPETITOR_KAFKA EL \r\n\t/*WHERE\tST.PARENT_ID = EL.DEAL_OBJECT_ID*/         /*COMMENTED AS PART OF CCW DATA FIX AUG REL */\r\n\t  WHERE ST.OBJECT_ID = EL.OBJECT_ID                /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\n\t\tAND  ST.MESSAGE_SEQUENCE_NUMBER = EL.MESSAGE_SEQUENCE_NUMBER )",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
  ],
