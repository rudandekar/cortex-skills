      "attributes": {
        "Sql Query": "SELECT \r\nOBJECT_ID,\r\nQUOTE_OBJECT_ID, \r\nOREPLACE(CONTACT_EMAIL_ID,CHR(10),''),\r\nOREPLACE(CONTACT_FIRST_NAME,CHR(10),''),\r\nOREPLACE(CONTACT_LAST_NAME,CHR(10),''),\r\nOREPLACE(CONTACT_PHONE_NUMBER,CHR(10),''),\r\nCONTACT_JOB_TITLE,\r\nOREPLACE(OTHER_JOB_TITLE,CHR(10),''),\r\nCONTACT_TYPE,\r\nCONTACT_TYPE_NAME,\r\nCONTACT_CCO_ID,\r\nCREATED_ON, \r\nCREATED_BY, \r\nUPDATED_ON, \r\nUPDATED_BY, \r\nCOALESCE(PRIMARY_FLAG,'=') as PRIMARY_FLAG,\r\nOREPLACE(CONTACT_URL,CHR(10),''),\r\nEDW_UPDATED_DATE\r\nFROM\r\n$$ETLVWDB.EL_INT_RAW_PDR_DEAL_CONTCT_KFK EL\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY EL.QUOTE_OBJECT_ID,OBJECT_ID  ORDER BY EL.EDW_CREATE_DTM DESC,EL.MESSAGE_SEQUENCE_NUMBER DESC)=1\r\nWhere EL.EDW_CREATE_DTM >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS where JOB_STREAM_ID='wf_ST_INT_RAW_PDR_DEAL_CNTCT_KFK')",
