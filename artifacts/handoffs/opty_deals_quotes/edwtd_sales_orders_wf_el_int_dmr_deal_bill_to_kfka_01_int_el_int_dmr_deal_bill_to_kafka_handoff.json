      "attributes": {
        "Sql Query": "SELECT\r\n     1 AS OBJECT_ID ,\r\n      PARENT_ID AS QUOTE_OBJECT_ID,\r\n      TO_CHAR(BILLTO_LOCATION) AS BILLTO_LOCATION ,\r\n      PARTY_ID ,\r\n      CUSTOMER_NAME ,\r\n      CUST_ACCT_SITE_ID,\r\n      CUST_ACCOUNT_ID,\r\n      ACCOUNT_NUMBER ,\r\n      ADDRESS1,\r\n      ADDRESS2 ,\r\n      ADDRESS3 ,\r\n      ADDRESS4 ,\r\n      COUNTRY ,\r\n      CITY ,\r\n      POSTAL_CODE ,\r\n      STATE ,\r\n      PROVINCE ,\r\n      COUNTY ,\r\n      COUNTRY_DESC ,\r\n      CURRENT_TIMESTAMP(0) AS CREATED_ON,\r\n      'DMPROD' CREATED_BY ,\r\n      CURRENT_TIMESTAMP(0) AS UPDATED_ON ,\r\n      'DMMIGR' UPDATED_BY ,\r\n      CURRENT_TIMESTAMP(0) AS EDW_UPDATED_DATE ,\r\n      UPDATED_BY_KAFKA,\r\n      cast(left (UPDATED_ON_KAFKA,19) as timestamp(0)) AS UPDATED_ON_KAFKA,\r\n      OFFSET_NUMBER,\r\n      PARTITION_NUMBER,\r\n      CURRENT_TIMESTAMP(0) as EDW_CREATE_DTM,\r\n      USER as EDW_CREATE_USER\r\nMESSAGE_SEQUENCE_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER\r\n\t  FROM $$STGDB.ST_INT_DMR_DL_BILL_TO_KAFKA_FF DMR\r\n\t  WHERE\r\nNOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.EL_INT_DMR_DEAL_BILL_TO_KAFKA EL\r\nWHERE DMR.OBJECT_ID = EL.OBJECT_ID \r\nAND \r\nDMR.OFFSET_NUMBER = EL.OFFSET_NUMBER)",
