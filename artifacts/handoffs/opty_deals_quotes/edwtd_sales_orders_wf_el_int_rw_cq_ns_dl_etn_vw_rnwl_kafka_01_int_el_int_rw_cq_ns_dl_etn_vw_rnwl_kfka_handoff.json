      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\n1 AS BATCH_ID, \r\nDEAL_OBJECT_ID AS DEAL_OBJECT_ID, \r\nAPPROVAL_ROUTE, \r\nAPPROVAL_ROUTE_NAME, \r\nPRODUCT_COMP, \r\nTSS_CORE_COMP, \r\nAS_TRANSACTION_COMP, \r\nAS_SUBSCRIPTION_COMP, \r\nAS_FIXED_COMP, \r\nROS_COMP, \r\nSERVICE_COMPONENT, \r\nGET_WELL_PLAN_DESCR, \r\nCSTIV.UPDATED_BY_KAFKA, \r\ncast(left (CSTIV.UPDATED_ON_KAFKA,19) as timestamp(0)) as UPDATED_ON_KAFKA, \r\nCSTIV.OFFSET_NUMBER, \r\nCAST(CAST(EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) as EDW_CREATE_DTM,\r\nUSER as EDW_CREATE_USER ,\r\nCSTIV.PARTITION_NUMBER, \r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER \r\nFROM\r\n$$ETLVWDB.ST_SI_INT_RAW_CQ_NS_DL_EXTN_VW_RNWL CSTIV\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY CSTIV.DEAL_OBJECT_ID ORDER BY CSTIV.EDW_CREATE_DTM DESC,CSTIV.OFFSET_NUMBER DESC)=1\r\n WHERE\r\n CAST(CAST(EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS \r\nwhere JOB_STREAM_ID='wf_EL_INT_RW_CQ_NS_DL_ETN_VW_RNWL_KAFKA') and\r\nNOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.EL_INT_RW_CQ_NS_DL_ETN_VW_RNWL_KFKA EL\r\nWHERE CSTIV.DEAL_OBJECT_ID = EL.DEAL_OBJECT_ID)",
