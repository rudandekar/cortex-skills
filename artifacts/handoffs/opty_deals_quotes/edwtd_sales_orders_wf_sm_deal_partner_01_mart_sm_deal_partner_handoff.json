      "attributes": {
        "Sql Query": "SELECT \r\nRANK() OVER \r\n(ORDER BY STDEAL_BK.SK_DEAL_PARTNER_OBJECT_ID_INT,STDEAL_BK.SS_CODE) + SMDEAL_MAX.MAX_DEAL_SGK_VAL DEAL_PARTNER_KEY,\r\nSTDEAL_BK.SK_DEAL_PARTNER_OBJECT_ID_INT SK_DEAL_PARTNER_OBJECT_ID_INT,\r\nSTDEAL_BK.SS_CODE,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER\r\nFROM \r\n( \r\nSELECT \r\nDISTINCT OBJECT_ID SK_DEAL_PARTNER_OBJECT_ID_INT,'CCW' AS SS_CODE\r\nFROM \r\n$$STGDB.ST_INT_RAW_CQ_DEAL_PARTY_VW ) STDEAL_BK,\r\n(SELECT COALESCE(MAX(DEAL_PARTNER_KEY),0) MAX_DEAL_SGK_VAL \r\n    FROM $$ETLVWDB.SM_DEAL_PARTNER) SMDEAL_MAX\r\nWHERE NOT EXISTS\r\n       ( SELECT 1 FROM $$ETLVWDB.SM_DEAL_PARTNER SDP\r\n           WHERE SDP.SK_DEAL_PARTNER_OBJECT_ID_INT = STDEAL_BK.SK_DEAL_PARTNER_OBJECT_ID_INT\r\n\t\t  AND SDP.SS_CODE=STDEAL_BK.SS_CODE)",
