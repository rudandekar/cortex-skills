      "attributes": {
        "Sql Query": "SELECT CQ_LOV.LOV_INDEX, \r\nREPLACE(REPLACE(REPLACE(REPLACE(CQ_LOV.LOV_TYPE,CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') LOV_TYPE, \r\nREPLACE(REPLACE(REPLACE(REPLACE(REPLACE(CQ_LOV.LOV_VALUE, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' '), CHR(15712189), ' ') LOV_VALUE, \r\nCQ_LOV.ACTIVE, \r\nREPLACE(REPLACE(REPLACE(REPLACE(CQ_LOV.CREATED_BY,CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') CREATED_BY, \r\nCQ_LOV.CREATED_ON, \r\nREPLACE(REPLACE(REPLACE(REPLACE(CQ_LOV.UPDATED_BY,CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') UPDATED_BY, \r\nNVL(CQ_LOV.UPDATED_ON,sysdate), \r\nREPLACE(REPLACE(REPLACE(REPLACE(CQ_LOV.LOV_SUBTYPE,CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') LOV_SUBTYPE, \r\nCQ_LOV.LOV_ORDER, \r\nREPLACE(REPLACE(REPLACE(REPLACE(CQ_LOV.LOV_SUB_CATEGORY,CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') LOV_SUB_CATEGORY \r\nFROM\r\n CQ_LOV\r\n  WHERE NVL(CQ_LOV.UPDATED_ON,sysdate) > TO_DATE('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS')",
