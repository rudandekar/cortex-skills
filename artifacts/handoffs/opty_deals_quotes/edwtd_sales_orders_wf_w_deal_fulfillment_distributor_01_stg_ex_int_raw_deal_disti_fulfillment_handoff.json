      "attributes": {
        "Sql Query": "SELECT SRDF.OBJECT_ID, SRDF.DEAL_OBJECT_ID, SRDF.AUTHORIZATION_NUMBER, SRDF.DEVIATION_ID, SRDF.DEVIATION_STATUS, \r\nSRDF.DEV_PROCESS_DESCRIPTION, SRDF.DEV_PROCESS_REMARK, SRDF.DEV_PROCESS_STATUS, SRDF.DEV_RETRY_COUNT, SRDF.END_DATE, SRDF.LAST_UPDATE_DATE, \r\nSRDF.LINKED_DEVIATION_ID, SRDF.NEXT_ACTION, SRDF.QUEUE_OBJECT_ID, SRDF.QUOTE_OBJECT_ID, SRDF.REVISION_NUMBER, SRDF.SOURCE_PROFILE_ID, SRDF.START_DATE \r\nFROM\r\n$$STGDB.ST_INT_RAW_DEAL_DISTI_FULFILLM SRDF \r\nWHERE NOT EXISTS  (SELECT 1 FROM $$SLSORDVWDB.N_DEAL_QUOTE QUOTE \r\nWHERE QUOTE.SK_QUOTE_OBJECT_ID_INT = SRDF.QUOTE_OBJECT_ID AND QUOTE.SS_CODE <> 'CCWR')",
