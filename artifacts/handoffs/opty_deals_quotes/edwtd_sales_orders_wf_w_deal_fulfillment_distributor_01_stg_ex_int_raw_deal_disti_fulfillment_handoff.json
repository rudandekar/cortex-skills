      "attributes": {
        "Sql Query": "SELECT \r\n/* Commenting as part of CCWR STARTS SRDF.OBJECT_ID AS DEAL_FULFILLMENT_DISTRI_KEY, Commenting as part of CCWR ENDS */\r\nSM.DEAL_FULFILLMENT_DISTRI_KEY AS DEAL_FULFILLMENT_DISTRI_KEY,\r\nSRDF.OBJECT_ID AS SK_OBJECT_ID_INT,\r\nNDQ.BK_DEAL_ID,\t\r\nCOALESCE(NDQ.BK_QUOTE_NUM,'-999') AS BK_QUOTE_NUM,\r\nCOALESCE(SRDF.SOURCE_PROFILE_ID,'-999') AS SK_DISTRI_SRC_PROFILE_ID_INT,\r\nCOALESCE(SRDF.AUTHORIZATION_NUMBER,'UNKNOWN') AS DISTRI_AUTHORIZATION_NUM,\r\nCOALESCE(SRDF.LAST_UPDATE_DATE,CAST('3500-01-01 00:00:00' AS timestamp(0))) AS SRC_LAST_UPDATED_DTM,\r\nCOALESCE(SRDF.LAST_UPDATE_DATE,CAST('3500-01-01' AS DATE)) AS DV_SRC_LAST_UPDATED_DT,\r\nCURRENT_TIMESTAMP(0)EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'CCW' AS SS_CODE,\r\n'I' ACTION_CODE,\r\n'=' AS DML_TYEPE\r\nFROM  \r\n$$STGDB.ST_INT_RAW_DEAL_DISTI_FULFILLM SRDF\r\n/*INNER JOIN $$SLSORDDB.N_DEAL DEAL\r\nON DEAL.SK_DEAL_OBJECT_ID_INT=SRDF.DEAL_OBJECT_ID\r\nAND DEAL.SS_CODE <> 'CCWR'  -- Added filter condition as part of new CCWR data processing */ /*Commented as part of CCW data fix Aug rel*/\r\nINNER JOIN $$SLSORDVWDB.N_DEAL_QUOTE NDQ\r\nON NDQ.SK_QUOTE_OBJECT_ID_INT = SRDF.QUOTE_OBJECT_ID\r\nAND NDQ.SS_CODE <> 'CCWR'\r\nINNER JOIN $$ETLVWDB.SM_DEAL_FULFILLMENT_DISTRIBUTOR SM\r\nON SM.SK_OBJECT_ID_INT = SRDF.OBJECT_ID\r\nAND SM.SS_CODE <> 'CCWR'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY DEAL_FULFILLMENT_DISTRI_KEY ORDER BY SRDF.OBJECT_ID DESC)=1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
