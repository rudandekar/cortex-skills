      "attributes": {
        "Sql Query": "SELECT\t\r\nSDGDH.OPTY_NUMBER AS OPTY_NUMBER,\r\nSDGDH.DEAL_STATUS AS DEAL_STATUS,\r\nSDGDH.DEAL_REGISTRATION_DATE AS DEAL_REGISTRATION_DATE,\r\nCOALESCE(NOP.OPPORTUNITY_KEY,-999) AS OPPORTUNITY_KEY,\r\nCASE\tWHEN SDGDH.FINANCE_CONTROLLER=NCWP.CEC_ID THEN NCWP.CISCO_WORKER_PARTY_KEY \r\nELSE\t-999 \r\nEND\tAS RU_FN_CNTLR_CSCO_WRKR_PRTY_KEY,\r\nCASE\tWHEN SDGDH.LEGAL_ASSURER=NCWP.CEC_ID THEN NCWP.CISCO_WORKER_PARTY_KEY \r\nELSE\t-999 \r\nEND\tAS RU_LGL_ASRR_CSCO_WRKR_PRTY_KEY,\r\nCOALESCE(SDGDH.DEAL_SERVICE_VALUE,0) AS DEAL_SERVICE_VALUE,\r\nSDGDH.APPROVED_DATE_LAST,\r\nSDGDH.EXPIRATION_DATE AS EXPIRATION_DATE,\r\nSDGDH.STANDARD_NONSTANDARD AS STANDARD_NONSTANDARD,\r\nCASE\tWHEN SDGDH.DEAL_STATUS='Approved' THEN 'Y' \r\nELSE\t'N' \r\nEND\tAS APPROVED_ROLE,\r\nSDGDH.DEAL_LAST_UPDATE_DATE AS DEAL_LAST_UPDATE_DATE,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN ND.BK_DEAL_ID IS NULL THEN 'I' ELSE 'U' END AS DML_TYPE\r\nFROM\t\r\n$$STGDB.ST_DMR_GROMIT_DEAL_HEADER SDGDH \r\nLEFT OUTER JOIN\r\n$$SLSORDVWDB.N_OPPORTUNITY NOP \r\n\tON\tSDGDH.OPTY_NUMBER=NOP.BK_OPPORTUNITY_NUM \r\n\tLEFT OUTER JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY NCWP\r\n\tON\tSDGDH.FINANCE_CONTROLLER=NCWP.CEC_ID \r\n\tOR SDGDH.LEGAL_ASSURER=NCWP.CEC_ID\r\nLEFT OUTER JOIN $$SLSORDVWDB.N_DEAL ND\r\n\tON SDGDH.OPTY_NUMBER=ND.BK_DEAL_ID \r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY  SDGDH.OPTY_NUMBER \r\nORDER\tBY SDGDH.OPTY_NUMBER )=1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
