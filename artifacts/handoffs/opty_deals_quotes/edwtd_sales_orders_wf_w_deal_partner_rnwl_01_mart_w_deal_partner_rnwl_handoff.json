      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\nSM.DEAL_PARTNER_KEY AS DEAL_PARTNER_KEY,\r\nND.BK_DEAL_ID AS BK_DEAL_ID,\r\nCOALESCE(PT.PRIMARY_NAME,'UNKNOWN') AS SRC_RPRTD_PTNR_SITE_PTY_NAME,\r\n'Y'  AS PRIMARY_FLG,\r\n'UNKNOWN' AS SRC_RPRTD_DEAL_PARTNER_CCO_ID,\r\nRCDP.OBJECT_ID AS SK_DEAL_PARTNER_OBJECT_ID_INT,\r\nCOALESCE(PT.PARTNER_COUNTRY_PARTY_KEY,-999) AS RU_PARTNER_COUNTRY_PARTY_KEY,\r\nCOALESCE(PT.PARTNER_SITE_PARTY_KEY,-999) AS RU_PARTNER_SITE_PARTY_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'UNKNOWN' AS PARTNER_TYPE_CD,  \r\n'CCWR' as SS_CODE,\r\n'I' AS ACTION_CODE,\r\n'=' AS DML_TYPE\r\nFROM  $$STGDB.ST_INT_RAW_CQ_DEAL_PARTY_VW_RNWL  RCDP\r\nINNER JOIN $$ETLVWDB.SM_DEAL_PARTNER SM\r\nON SM.SK_DEAL_PARTNER_OBJECT_ID_INT=RCDP.OBJECT_ID\r\nAND SM.SS_CODE='CCWR' ---- added as part of CCWR changes\r\nINNER JOIN $$SLSORDVWDB.N_DEAL ND\r\nON ND.SK_DEAL_OBJECT_ID_INT = RCDP.DEAL_OBJECT_ID\r\nAND ND.SS_CODE = 'CCWR'   ---- added as part of CCWR changes\r\nLEFT JOIN ( SELECT PTNR.PARTNER_SITE_PARTY_KEY,PTNR.PARTNER_COUNTRY_PARTY_KEY,NP.PRIMARY_NAME,SK_SITE_USE_ID\r\nFROM $$COMREFVWDB.N_ERP_CUST_ACCT_LOC_USE_TV CUST \r\nINNER  JOIN $$COMREFVWDB.MT_PARTNER_HIERARCHY PTNR\r\nON PTNR.PARTNER_SITE_PARTY_KEY=CUST.CUSTOMER_PARTY_KEY\r\nINNER JOIN $$COMREFVWDB.N_PARTY NP\r\nON PTNR.PARTNER_SITE_PARTY_KEY=NP.PARTY_KEY\r\nWHERE NP.SS_CODE='CR'\r\nAND CUST.END_TV_DATE ='3500-01-01'\r\n)PT\r\nON RCDP.BILL_TO_ID=PT.SK_SITE_USE_ID",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
