      "attributes": {
        "Sql Query": "SELECT\tDISTINCT 1 AS BATCH_ID,\r\n\t\tST.PARENT_ID AS DEAL_OBJECT_ID,\r\n\t\tST.OBJECT_ID ,\r\n\t\tST.CONTACT_ID ,\r\n\t\tTD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(ST.CONTACT_NAME,'[^!-~a-zA-Z0-9 ]+','',1,0,'i') , X'0d' , '') , X'0a' , '') CONTACT_NAME , --Modified to retain space between first name and last name as part of CCW data fix Aug rel\r\n\t\tST.CONTACT_TYPE ,\r\n\t\t/*-- COMMENTED AS PART OF CCW DATA FIX AUG REL\r\n\t\t case \r\n\t\t\twhen ST.CREATED_ON is null then CAST(CAST(SD.CREATED_ON as DATE FORMAT  'DD-MMM-YYYY') as TIMESTAMP(0)) \r\n\t\t\telse ST.CREATED_ON  \r\n\t\tend as CREATED_ON,*/\r\n\t\tCOALESCE(ST.CREATED_ON,CAST('1900-01-01 00:00:00' as TIMESTAMP(0))) as CREATED_ON, /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\n\t\t/*COALESCE(ST.CREATED_BY,SD.CREATED_BY) as  CREATED_BY, -- COMMENTED AS PART OF CCW DATA FIX AUG REL*/\t\t\r\n\t\tST.CREATED_BY as CREATED_BY,\r\n\t\t/*CAST(CAST(ST.UPDATED_ON as DATE FORMAT  'DD-MMM-YYYY') as TIMESTAMP(0)) as UPDATED_ON, -- COMMENTED AS PART OF CCW DATA FIX AUG REL*/\r\n\t\tCOALESCE(ST.UPDATED_ON,CAST('1900-01-01 00:00:00' as TIMESTAMP(0))) as UPDATED_ON, /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\n\t\t/*COALESCE(ST.UPDATED_BY,SD.UPDATED_BY) as  UPDATED_BY,-- COMMENTED AS PART OF CCW DATA FIX AUG REL*/\r\n\t\tST.UPDATED_BY as UPDATED_BY, /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\n\t\tST.CONTACT_ROW ,\r\n\t\tST. DM_UPDATE_DATE,\r\n\t\tST.CONTACT_POSTN_ID ,\r\n\t\t'' AS SIEBEL_POSTN_ID ,\r\n        /*-- COMMENTED AS PART OF CCW DATA FIX AUG REL \r\n          case when ST.CREATE_DATETIME is null then CAST(CAST(SD.CREATE_DATETIME as DATE FORMAT  'DD-MMM-YYYY') as TIMESTAMP(0)) \r\n\t\t  else ST.CREATE_DATETIME  \r\n\t\t  end as CREATE_DATETIME,*/\r\n\t\tCOALESCE(ST.CREATE_DATETIME,CAST('1900-01-01 00:00:00' as TIMESTAMP(0))) as CREATE_DATETIME, /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\n\t\t'I' AS ACTION_CODE ,\r\n\t\tST.UPDATED_BY_KAFKA,\r\n\t\tCAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,\t\t'T',' '), 19) as TIMESTAMP(0)) AS UPDATED_ON_KAFKA,\r\n\t\tST.OFFSET_NUMBER,\r\n\t\tST.PARTITION_NUMBER,\r\n\t\tUSER AS EDW_CREATE_USER,\r\n\t\tCURRENT_TIMESTAMP(0) as EDW_CREATE_DTM,\r\n\t\tST.MESSAGE_SEQUENCE_NUMBER,\r\n\t\tCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n\t\tUSER AS EDW_UPDATE_USER  \r\nFROM\t $$STGDB.ST_CQ_DEAL_CONTACT_KAFKA_FF ST \r\n/* -- COMMENTED AS PART OF CCW DATA FIX AUG REL\r\n      INNER JOIN ( SELECT OBJECT_ID ,CREATED_ON,CREATED_BY,UPDATED_ON,UPDATED_BY,CREATE_DATETIME\r\n\t\tFROM $$STGDB.ST_INT_CQ_DEAL_KAFKA_FF SD          \r\n\t\tGROUP BY 1,2,3,4,5,6 ) SD    \r\n\tON ST.PARENT_ID = SD.OBJECT_ID */\r\nWHERE\tNOT EXISTS (\r\n\tSELECT\t1 \r\n\tFROM\t$$ETLVWDB.EL_CQ_DEAL_CONTACT_KAFKA EL \r\n\tWHERE\tST.PARENT_ID = EL.DEAL_OBJECT_ID \r\n\t\tAND ST.CONTACT_ID = EL.CONTACT_ID \r\n\t\tAND ST.MESSAGE_SEQUENCE_NUMBER = EL.MESSAGE_SEQUENCE_NUMBER)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
