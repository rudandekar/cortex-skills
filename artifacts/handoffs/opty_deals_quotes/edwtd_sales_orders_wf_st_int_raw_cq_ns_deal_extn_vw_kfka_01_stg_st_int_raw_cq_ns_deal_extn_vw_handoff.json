      "attributes": {
        "Sql Query": "SELECT BATCH_ID, \r\nEL.DEAL_OBJECT_ID, \r\nEL.APPROVAL_ROUTE, \r\nEL.APPROVAL_ROUTE_NAME,\r\nEL.PRODUCT_COMP, \r\nEL.TSS_CORE_COMP, \r\nEL.AS_TRANSACTION_COMP, \r\nEL.AS_SUBSCRIPTION_COMP, \r\nEL.AS_FIXED_COMP, \r\nEL.ROS_COMP, \r\nEL.PRODUCT_COMPONENT,\r\nEL.SERVICE_COMPONENT, \r\nCOALESCE(EL.CREATED_BY,'CCW') as  CREATED_BY, \r\nCOALESCE(EL.CREATED_ON, CURRENT_DATE) as CREATED_ON,\r\nCOALESCE(EL.UPDATED_BY,'CCW') as  UPDATED_BY, \r\nCOALESCE(EL.UPDATED_ON, CURRENT_DATE) as UPDATED_ON,\r\n EL.GET_WELL_PLAN_DESCR, \r\n EL.DSA_REGSTR_DATE, \r\n EL.DD_ENGAGE_DATE, \r\n EL.NS_SUMMARY_DESCR, \r\n EL.EXE_SUMMARY_INTERNAL_DESCR, \r\n EL.IS_SA_DEAL, \r\nCOALESCE(EL.CREATE_DATETIME, CURRENT_DATE) as CREATE_DATETIME,\r\nCOALESCE(EL.ACTION_CODE,'I') as  ACTION_CODE\r\nFROM\r\n$$ETLVWDB.EL_INT_RW_CQ_NS_DL_ETN_VW_KFKA EL\r\n QUALIFY ROW_NUMBER() OVER(PARTITION BY EL.DEAL_OBJECT_ID ORDER BY EL.EDW_CREATE_DTM DESC,EL.MESSAGE_SEQUENCE_NUMBER DESC)=1 /*Added EDW_CREATE_DTM as part of CCW data fix Aug rel*/\r\nWhere EL.EDW_CREATE_DTM >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS where JOB_STREAM_ID='wf_ST_INT_RAW_CQ_NS_DEAL_EXTN_VW_KFKA')",
        "User Defined Join": "",
        "Source Filter": "",
