      "attributes": {
        "Sql Query": "SELECT \r\n D_NSTERM.NSTERM_NAME AS BK_NON_STANDARD_TERM_NAME,\r\n DEAL.BK_DEAL_ID AS BK_DEAL_ID,\r\n CURRENT_TIMESTAMP(0),         \r\n USER,\r\n CURRENT_TIMESTAMP(0),         \r\n USER ,\r\n COALESCE(D_NSTERM.AS_SUBSCRIPTION,'N' ) AS AS_SUBSCRIPTION_FLG,\r\n COALESCE(D_NSTERM.AS_TRANSACTION,'N' ) AS AS_TRANSACTION_FLG,\r\n COALESCE(D_NSTERM.AS_FIXED,'N' ) AS AS_FIXED_FLG,\r\n COALESCE(D_NSTERM.TSS_CORE,'N' ) AS TSS_CORE_FLG,\r\n COALESCE(D_NSTERM.ROS,'N' ) AS ROS_FLG,\r\n 'I' AS ACTION_CODE,\r\n '=' AS DML_TYPE                \r\n FROM $$STGDB.ST_INT_RAW_CQ_DEALNSTERM_VW D_NSTERM\r\n INNER JOIN $$SLSORDVWDB.N_DEAL DEAL\r\n ON D_NSTERM.DEAL_OBJECT_ID = SK_DEAL_OBJECT_ID_INT\r\n AND DEAL.SS_CODE <> 'CCWR' -- to filter out CCWR Deals\r\n QUALIFY ROW_NUMBER() OVER (PARTITION BY DEAL.BK_DEAL_ID,D_NSTERM.NSTERM_NAME ORDER BY D_NSTERM.OBJECT_ID DESC)=1",
