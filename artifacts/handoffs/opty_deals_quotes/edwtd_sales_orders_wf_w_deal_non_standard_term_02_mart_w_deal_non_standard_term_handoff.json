      "attributes": {
        "Sql Query": "SELECT \r\n STG.OBJECT_ID, \r\n STG.NSTERM_ID, \r\n STG.NSTERM_NAME, \r\n STG.DEAL_OBJECT_ID, \r\n STG.CREATED_DATE, \r\n STG.CREATED_BY, \r\n STG.UPDATED_DATE, \r\n STG.UPDATED_BY ,\r\n 'RI' EXCEPTION_TYPE,\r\n STG.AS_SUBSCRIPTION,\r\n STG.AS_TRANSACTION,\r\n STG.AS_FIXED,\r\n STG.TSS_CORE,\r\n STG.ROS\r\n FROM\r\n $$STGDB.ST_INT_RAW_CQ_DEALNSTERM_VW STG\r\n WHERE NOT EXISTS\r\n (SELECT 1 FROM $$SLSORDVWDB.N_DEAL \r\n WHERE STG.DEAL_OBJECT_ID = SK_DEAL_OBJECT_ID_INT\r\n AND SS_CODE <> 'CCWR' -- to filter out CCWR Deals\r\n )",
