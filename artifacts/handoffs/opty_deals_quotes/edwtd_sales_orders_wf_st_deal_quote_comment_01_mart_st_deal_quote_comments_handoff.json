      "attributes": {
        "Sql Query": "SELECT \r\nSIDQC.DEAL_OBJECT_ID, \r\nSIDQC.DEAL_ID, \r\nSIDQC.QUOTE_ID, \r\nSIDQC.UPDATED_ON, \r\nSIDQC.CREATED_BY, \r\nSIDQC.CREATED_ON, \r\nSIDQC.IS_NEW, \r\nSIDQC.CREATED_ON_AS_DATE, \r\nSIDQC.NOTE_ID, \r\nSIDQC.REJECT_REASON_FLG, \r\nSIDQC.PARNTER_CMMNT, \r\nSIDQC.NOTES, \r\nSIDQC.QUOTE_OBJ_ID, \r\nSIDQC.ADDRESSED_TO, \r\nSIDQC.MESSAGE_SEQUENCE_NUMBER, \r\nSIDQC.UPDATED_ON_KAFKA, \r\nSIDQC.OFFSET_NUMBER, \r\nSIDQC.PARTITION_NUMBER, \r\nCAST(SIDQC.EDW_CREATE_DTM AS TIMESTAMP(0)) AS EDW_CREATE_DTM\r\nFROM  $$ETLVWDB.ST_SI_DEAL_QUOTE_COMMENTS SIDQC\r\nQUALIFY Row_Number() Over(PARTITION BY SIDQC.QUOTE_OBJ_ID,SIDQC.NOTE_ID \r\nORDER BY SIDQC.OFFSET_NUMBER,SIDQC.MESSAGE_SEQUENCE_NUMBER DESC)=1\r\nWHERE SIDQC.EDW_CREATE_DTM  >=\r\n(SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS WHERE JOB_STREAM_ID='wf_ST_DEAL_QUOTE_COMMENT')",
