      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\n COALESCE(ST.OBJECT_ID,-999) as OBJECT_ID ,\r\n COALESCE(ST.PARENT_ID, -999) AS QUOTE_OBJECT_ID,\r\n COALESCE(ST.PARTNER_BE_GEO_ID,ST.RESELLER_BE_GEO_ID) AS PARTNER_BE_GEO_ID,\r\nSTQ.CREATED_BY\tAS\tCREATED_BY ,\r\nCAST(LEFT(OREPLACE(STQ.CREATED_ON,'T',' '), 19) AS TIMESTAMP(0))AS CREATED_ON,\r\nSTQ.UPDATED_BY AS UPDATED_BY ,\r\nCAST(LEFT(OREPLACE(STQ.UPDATED_ON,'T',' '), 19) AS TIMESTAMP(0)) AS UPDATED_ON,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATED_DATE,\r\n '' AS CRP_PARTNER_CONV_FLAG,\r\nCAST( LEFT(OREPLACE(ST.DEAL_SUBMITTED_DATE,'T',' '), 19) AS TIMESTAMP(0)) AS DEAL_SUBMITTED_DATE,\r\n  '' AS CRP_PARTNER_SITE_ID,\r\nST.UPDATED_BY_KAFKA,\r\n CAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,'T',''), 19) AS TIMESTAMP(0)) AS  UPDATED_ON_KAFKA,\r\n ST.OFFSET_NUMBER,\r\nST.EDW_CREATE_DTM AS EDW_CREATE_DTM,\r\n USER AS EDW_CREATE_USER,\r\n ST.PARTITION_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCOALESCE(ST.BILLTO_ID,CAST(ST.RESELLER_BILL_TO AS INTEGER)),\r\nST.QUOTE_STATUS_ID,\r\nST.REF_ENTITY_NUMBER\r\n FROM $$ETLVWDB.ST_SI_INT_RW_CQ_QUTE_PTR_EX_RNWL_KFK ST \r\n INNER JOIN $$ETLVWDB.ST_SI_INT_CQ_SNGL_QUTE_VW_RNWL_KFKA STQ \r\n ON  COALESCE(ST.PARENT_ID, -999) = COALESCE(CAST(STQ.QUOTE_ID AS DEC(18,0)), -999)\r\n QUALIFY ROW_NUMBER() OVER(PARTITION BY ST.PARENT_ID,  COALESCE(ST.PARTNER_BE_GEO_ID,ST.RESELLER_BE_GEO_ID) ORDER BY ST.EDW_CREATE_DTM DESC, ST.OFFSET_NUMBER DESC)=1\r\nWHERE NOT EXISTS\r\n(SELECT 1 FROM\r\n$$ETLVWDB.EL_INT_RW_CQ_QUTE_PTNR_EX_RNWL_KFK EL\r\nWHERE ST.PARENT_ID = EL.QUOTE_OBJECT_ID\r\nAND  COALESCE(ST.PARTNER_BE_GEO_ID,ST.RESELLER_BE_GEO_ID)= EL.PARTNER_BE_GEO_ID\r\n)\r\nAND CAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS\r\nwhere JOB_STREAM_ID='wf_EL_INT_RW_CQ_QUTE_PTNR_EX_RNWL_KFK')\r\nAND ST.DEAL_REQUESTED_BY IS NOT NULL\r\nAND ST.PARENT_ID IS NOT NULL\r\nAND (ST.PARTNER_BE_GEO_ID IS NOT NULL OR ST.RESELLER_BE_GEO_ID IS NOT NULL)",
        "User Defined Join": "",
