      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\nCSTIV.DEAL_OBJECT_ID,\r\nCASE \r\n   WHEN (CSTIV.DEAL_OBJECT_ID = EL.DEAL_OBJECT_ID AND CSTIV.STATE=EL.STATE AND \r\n   CAST(LEFT(OREPLACE(CSTIV.TRANSITION_DATE,'T',' '), 19) as TIMESTAMP(0))=EL.TRANSITION_DATE)\r\n      THEN EL.OBJECT_ID\r\n   ELSE\r\n      (SELECT COALESCE(MAX(OBJECT_ID),0) as MAX_VAL_OBJECT_ID FROM \r\n      $$ETLVWDB.EL_CQ_STATE_TRNSTN_INT_VW_RNWL_KFKA ) + DENSE_RANK() OVER (ORDER BY CSTIV.DEAL_OBJECT_ID,CSTIV.STATE,CAST(LEFT(OREPLACE(CSTIV.TRANSITION_DATE,'T',' '), 19) as TIMESTAMP(0))) \r\n   END \r\nAS OBJECT_ID,\r\nCSTIV.STATE AS STATE,\r\nCAST(LEFT(OREPLACE(CSTIV.TRANSITION_DATE,'T',' '), 19) as TIMESTAMP(0)) as TRANSITION_DATE,\r\nCSTIV.UPDATED_BY_KAFKA AS UPDATED_BY_KAFKA,\r\ncast(left (CSTIV.UPDATED_ON_KAFKA,19) as timestamp(0)) as UPDATED_ON_KAFKA,\r\nCSTIV.OFFSET_NUMBER AS OFFSET_NUMBER,\r\nCAST(CAST(CSTIV.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0))AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCSTIV.PARTITION_NUMBER AS PARTITION_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER\r\nFROM\r\n$$ETLVWDB.ST_SI_CQ_STATE_TRN_INT_VW_RNWL_KFK CSTIV\r\nJOIN (sel OBJECT_ID from  $$ETLVWDB.ST_SI_INT_CQ_DEAL_RNWL_KAFKA group by 1) ICD\r\nON ICD.OBJECT_ID = CSTIV.DEAL_OBJECT_ID \r\nLEFT OUTER JOIN $$ETLVWDB.EL_CQ_STATE_TRNSTN_INT_VW_RNWL_KFKA EL -- added to populate OBJECT_ID\r\nON CSTIV.DEAL_OBJECT_ID = EL.DEAL_OBJECT_ID AND CSTIV.STATE=EL.STATE AND \r\nCAST(LEFT(OREPLACE(CSTIV.TRANSITION_DATE,'T',' '), 19) as TIMESTAMP(0))=EL.TRANSITION_DATE\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY CSTIV.DEAL_OBJECT_ID , CSTIV.STATE,CAST(LEFT(OREPLACE(CSTIV.TRANSITION_DATE,'T',' '), 19) as TIMESTAMP(0)) ORDER BY CSTIV.EDW_CREATE_DTM DESC, CSTIV.OFFSET_NUMBER DESC)=1\r\nWHERE  CAST(CAST(CSTIV.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS\r\nwhere JOB_STREAM_ID='wf_EL_CQ_STATE_TRNSTN_INT_VW_RNWL_KFKA') and\r\nNOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.EL_CQ_STATE_TRNSTN_INT_VW_RNWL_KFKA EL\r\nWHERE \r\n-- CSTIV.OFFSET_NUMBER = EL.OFFSET_NUMBER\r\n-- AND \r\nCSTIV.DEAL_OBJECT_ID = EL.DEAL_OBJECT_ID\r\nAND CSTIV.STATE=EL.STATE \r\nAND CAST(LEFT(OREPLACE(CSTIV.TRANSITION_DATE,'T',' '), 19) as TIMESTAMP(0))=EL.TRANSITION_DATE\r\n)",
        "User Defined Join": "",
