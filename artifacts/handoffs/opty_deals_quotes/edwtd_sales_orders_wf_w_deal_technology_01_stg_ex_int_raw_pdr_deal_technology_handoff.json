      "attributes": {
        "Sql Query": "SELECT \r\nSDT.OBJECT_ID AS DEAL_TECHNOLOGY_KEY,\r\nCOALESCE(SDT.OBJECT_ID,'-999') AS SK_OBJECT_ID_INT,\r\nDEAL.BK_DEAL_ID,\r\nCOALESCE(SDT.TECHNOLOGY,'UNKNOWN') AS BK_DEAL_TECH_NAME,\r\nCOALESCE(SDT.PERCENTAGE_OF_MIX,'0.00') AS BK_TECH_MIX_PCT,\r\nCOALESCE(SDT.CREATED_ON,CAST('3500-01-01 00:00:00' AS timestamp(0))) AS SRC_CREATED_DTM,\r\nCOALESCE(SDT.CREATED_ON,CAST('3500-01-01' AS DATE)) AS DV_SRC_CREATED_DT,\r\nCOALESCE(SDT.UPDATED_ON,CAST('3500-01-01 00:00:00' AS timestamp(0))) AS SRC_LAST_UPDATED_DTM,\r\nCOALESCE(SDT.UPDATED_ON,CAST('3500-01-01' AS DATE)) AS DV_SRC_LAST_UPDATED_DT,\r\nCURRENT_TIMESTAMP(0)EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' ACTION_CODE,         \r\n'=' AS DML_TYPE \r\nFROM \r\n$$STGDB.ST_INT_RAW_PDR_DEAL_TECHNOLOGY SDT\r\nINNER JOIN $$SLSORDDB.N_DEAL DEAL\r\nON DEAL.SK_DEAL_OBJECT_ID_INT = SDT.DEAL_OBJECT_ID",
