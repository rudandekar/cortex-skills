      "attributes": {
        "Sql Query": "SELECT \r\nOBJECT_ID,\r\nCOALESCE(SDT.OBJECT_ID,'-999') AS DEAL_OBJECT_ID,\r\nCOALESCE(SDT.CREATED_BY,'UNKNOWN') CREATED_BY,\r\nCOALESCE(SDT.CREATED_ON,CAST('3500-01-01 00:00:00' AS timestamp(0))) AS CREATED_ON,\r\nCOALESCE(SDT.PERCENTAGE_OF_MIX,'0:00') AS PERCENTAGE_OF_MIX,\r\nCOALESCE(SDT.TECHNOLOGY,'UNKNOWN') AS TECHNOLOGY,\r\nCOALESCE(SDT.UPDATED_BY,'UNKNOWN') UPDATED_BY,\r\nCOALESCE(SDT.UPDATED_ON,CAST('3500-01-01 00:00:00' AS timestamp(0))) AS UPDATED_ON\r\nFROM \r\n$$STGDB.ST_INT_RAW_PDR_DEAL_TECHNOLOGY SDT\r\nWHERE NOT EXISTS (\r\nSELECT 1 FROM $$SLSORDDB.N_DEAL DEAL\r\nWHERE DEAL.SK_DEAL_OBJECT_ID_INT = SDT.DEAL_OBJECT_ID)",
