      "attributes": {
        "Sql Query": "SELECT \r\nEL_CQ_DEAL_CONTACT.BATCH_ID,\r\nEL_CQ_DEAL_CONTACT.DEAL_OBJECT_ID,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.OBJECT_ID,-999) as OBJECT_ID, /*Modified -999 as number and not char, as part of CCW data fix Aug rel*/\r\nCOALESCE(CONTACT_ID,'UNKNOWN') as CONTACT_ID,\r\nCOALESCE(CONTACT_NAME,'UNKNOWN') as CONTACT_NAME,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.CONTACT_TYPE,0) as CONTACT_TYPE,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.CREATED_ON,CURRENT_DATE) as CREATED_ON,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.CREATED_BY,'CCW') as CREATED_BY,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.UPDATED_ON,CURRENT_DATE) as UPDATED_ON,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.UPDATED_BY,'CCW') as UPDATED_BY,\r\nEL_CQ_DEAL_CONTACT.CONTACT_ROW,\r\nEL_CQ_DEAL_CONTACT.DM_UPDATE_DATE,\r\nCONTACT_POSTN_ID,\r\nSIEBEL_POSTN_ID,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.CREATE_DATETIME,CURRENT_DATE) as CREATE_DATETIME,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.ACTION_CODE,'I') as ACTION_CODE\r\n\r\nFROM $$ETLVWDB.EL_CQ_DEAL_CONTACT_KAFKA EL_CQ_DEAL_CONTACT\r\nWhere EL_CQ_DEAL_CONTACT.EDW_CREATE_DTM >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS where JOB_STREAM_ID='wf_ST_CQ_DEAL_CONTACT_KAFKA')\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY EL_CQ_DEAL_CONTACT.DEAL_OBJECT_ID,EL_CQ_DEAL_CONTACT.OBJECT_ID\r\nORDER BY EL_CQ_DEAL_CONTACT.EDW_CREATE_DTM desc,EL_CQ_DEAL_CONTACT.MESSAGE_SEQUENCE_NUMBER DESC)=1 --added EDW_CREATE_DTM as part of CCW data fix Aug rel",
        "User Defined Join": "",
        "Source Filter": "",
