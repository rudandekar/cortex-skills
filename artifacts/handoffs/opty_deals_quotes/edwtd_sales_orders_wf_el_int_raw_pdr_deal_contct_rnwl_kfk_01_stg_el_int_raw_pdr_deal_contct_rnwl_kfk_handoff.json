      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\n(SELECT COALESCE(MAX(OBJECT_ID),0) as MAX_VAL_OBJECT_ID FROM \r\n$$ETLVWDB.EL_INT_RAW_PDR_DEAL_CONTCT_RNWL_KFK ) + ROW_NUMBER() OVER (ORDER BY ST.PARENT_ID,COALESCE(ST.CONTACT_CCO_ID, 'UNKNOWN')) AS OBJECT_ID,\r\nST.PARENT_ID AS QUOTE_OBJECT_ID,\r\nST.CONTACT_EMAIL_ID,\r\nST.CONTACT_FIRST_NAME,\r\nST.CONTACT_LAST_NAME,\r\nCOALESCE(ST.CONTACT_CCO_ID, 'UNKNOWN') AS CONTACT_CCO_ID,\r\nCAST(CAST(COALESCE(ST.CREATED_ON,'1900-01-01 00:00:00' ) AS VARCHAR(19)) AS TIMESTAMP(0))  as CREATED_ON,\r\nST.CREATED_BY as CREATED_BY,\r\nCAST(LEFT(OREPLACE(ST.UPDATED_ON,'T',' '), 19) as TIMESTAMP(0)) as UPDATED_ON,\r\nST.UPDATED_BY\tas\tUPDATED_BY,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATED_DATE,\r\nST.UPDATED_BY_KAFKA,\r\nCAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,'T',''), 19) as TIMESTAMP(0)) AS UPDATED_ON_KAFKA,\r\nST.OFFSET_NUMBER,\r\nST.PARTITION_NUMBER,\r\nCAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) as EDW_CREATE_DTM,\r\nUSER as EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER\r\nFROM\r\n( SELECT DISTINCT * FROM\r\n$$ETLVWDB.ST_SI_INT_RAW_PDR_DEAL_CNT_RNWL_KFK ST\r\n)ST \r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY ST.PARENT_ID ,COALESCE(ST.CONTACT_CCO_ID, 'UNKNOWN') ORDER BY ST.EDW_CREATE_DTM DESC, ST.OFFSET_NUMBER DESC)=1\r\nWhere NOT EXISTS\r\n(SELECT 1 FROM\r\n$$ETLVWDB.EL_INT_RAW_PDR_DEAL_CONTCT_RNWL_KFK EL\r\nWHERE ST.PARENT_ID = EL.QUOTE_OBJECT_ID\r\nAND COALESCE(ST.CONTACT_CCO_ID,'UNKNOWN')  = EL.CONTACT_CCO_ID)\r\nAND CAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS\r\nwhere JOB_STREAM_ID='wf_EL_INT_RAW_PDR_DEAL_CONTCT_RNWL_KFK')\r\nAND ST.PARENT_ID IS NOT NULL\r\nAND CONTACT_CCO_ID IS NOT NULL",
