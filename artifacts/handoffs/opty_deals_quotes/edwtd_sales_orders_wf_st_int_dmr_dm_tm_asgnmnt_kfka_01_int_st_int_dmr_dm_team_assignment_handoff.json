      "attributes": {
        "Sql Query": "SELECT \r\nIDDTA.OBJECT_ID, \r\nIDDTA.DEAL_OBJECT_ID, \r\nIDDTA.QUOTE_OBJECT_ID, \r\nIDDTA.ACCESS_GRANTOR_ID, \r\nIDDTA.MEMBER_ID, \r\nIDDTA.MEMBER_CEC_ID, \r\nCOALESCE(IDDTA.MEMBER_CCO_ID,-999) AS MEMBER_CCO_ID,  /*Added as part of CCW data fix Aug rel*/\r\nIDDTA.MEMBER_FIRST_NAME, \r\nIDDTA.MEMBER_LAST_NAME, \r\nIDDTA.MEMBER_ROLE, \r\nIDDTA.MEMBER_ACCESS_LEVEL, \r\nIDDTA.MEMBER_ACCESS_SCOPE, \r\nOREPLACE(IDDTA.MEMBER_TYPE,CHR(10),''),\r\nIDDTA.MEMBER_VISIBILITY, \r\nIDDTA.MEMBER_POSITION, \r\nIDDTA.EMAIL_SENT_FLAG, \r\nIDDTA.ACTIVE, \r\nIDDTA.CREATED_BY, \r\nIDDTA.CREATED_ON, \r\nIDDTA.UPDATED_BY, \r\nIDDTA.UPDATED_ON, \r\nIDDTA.EMAIL_CC,\r\nIDDTA.UPDATED_ON_KAFKA AS EDW_UPDATED_DATE\r\nFROM\r\n$$ETLVWDB.EL_INT_DMR_DM_TM_ASGINMNT_KFKA IDDTA\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY IDDTA.QUOTE_OBJECT_ID,IDDTA.OBJECT_ID ORDER BY IDDTA.EDW_CREATE_DTM DESC,IDDTA.MESSAGE_SEQUENCE_NUMBER DESC)=1 /*Added Create_dtm as part of CCW data fix Aug rel*/\r\nWhere IDDTA.EDW_CREATE_DTM >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS Where JOB_STREAM_ID='wf_ST_INT_DMR_DM_TM_ASGNMNT_KFKA')",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
