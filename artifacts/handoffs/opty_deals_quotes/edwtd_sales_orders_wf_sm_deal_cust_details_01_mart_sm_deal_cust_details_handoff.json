      "attributes": {
        "Sql Query": "SELECT \r\nRANK() OVER \r\n(ORDER BY STDEAL_BK.CUST_REGISTRY_ID,STDEAL_BK.SS_CODE,STDEAL_BK.BK_DEAL_ID) + SMDEAL_MAX.MAX_DEAL_SGK_VAL DEAL_CUST_DETAILS_KEY, /*ADDING BK_DEAL_ID AND CR_ID TO DERIVE SM KEY AS PART OF CCW DATA FIX AUG REL*/\r\n/*STDEAL_BK.SK_DEAL_CUST_OBJECT_ID_INT SK_DEAL_CUST_OBJECT_ID_INT,  COMMENTED AS PART OF CCW DATA FIX AUG REL */\r\nSTDEAL_BK.BK_DEAL_ID,\r\nSTDEAL_BK.CUST_REGISTRY_ID,\r\nSTDEAL_BK.SS_CODE,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER\r\nFROM \r\n( \r\nSELECT \r\nDISTINCT \r\n/*OBJECT_ID AS SK_DEAL_CUST_OBJECT_ID_INT,  COMMENTED AS PART OF CCW DATA FIX AUG REL */\r\n'CCW' AS SS_CODE,\r\nCR_ID AS CUST_REGISTRY_ID,\r\nOPTY_NUMBER AS BK_DEAL_ID\r\nFROM \r\n$$STGDB.ST_INT_RAW_DM_CUSTOMER ) STDEAL_BK,\r\n(SELECT COALESCE(MAX(DEAL_CUST_DETAILS_KEY),0) MAX_DEAL_SGK_VAL \r\n    FROM $$ETLVWDB.SM_DEAL_CUST_DETAILS) SMDEAL_MAX\r\nWHERE NOT EXISTS\r\n       ( SELECT 1 FROM $$ETLVWDB.SM_DEAL_CUST_DETAILS SDC\r\n           WHERE SDC.BK_DEAL_ID = STDEAL_BK.BK_DEAL_ID\r\n\t\t   AND COALESCE(SDC.CR_ID,-999) = COALESCE(STDEAL_BK.CUST_REGISTRY_ID,-999)\r\n\t\t  AND SDC.SS_CODE=STDEAL_BK.SS_CODE)",
        "User Defined Join": "",
