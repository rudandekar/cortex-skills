      "attributes": {
        "Sql Query": "SELECT \r\nCOALESCE(OBJECT_ID, -999) as OBJECT_ID,\r\nCOALESCE(NSTERM_ID, -999) as NSTERM_ID,\r\nCOALESCE(NSTERM_NAME, 'UNKNOWN') as NSTERM_NAME,\r\nCOALESCE(DEAL_OBJECT_ID, -999) as DEAL_OBJECT_ID,\r\nCOALESCE(CREATED_DATE, CAST('1900-01-01 00:00:00' AS TIMESTAMP(0))) as CREATED_DATE,\r\nCOALESCE(CREATED_BY, 'UNKNOWN') as CREATED_BY,\r\nCOALESCE(UPDATED_DATE, CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))) as UPDATED_DATE,\r\nCOALESCE(UPDATED_BY, 'UNKNOWN') as UPDATED_BY,\r\nAS_SUBSCRIPTION,\r\nAS_TRANSACTION,\r\nAS_FIXED,\r\nTSS_CORE,\r\nROS\r\nFROM $$ETLVWDB.EL_INT_RAW_CQ_DLNSTERM_VW_RNWL_KFK\r\nWhere EDW_CREATE_DTM >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS \r\nwhere JOB_STREAM_ID='wf_ST_INT_RAW_CQ_DEALNSTERM_VW_RNWL_KAFKA')",
