      "attributes": {
        "Sql Query": "SELECT \r\nCOALESCE(IRDC.OBJECT_ID, -999) as OBJECT_ID, \r\nCOALESCE(IRDC.DEAL_OBJECT_ID, -999) as DEAL_OBJECT_ID, \r\nDEAL.OPTY_NUMBER, /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\nnull as SIEBEL_COMPANY_ID, \r\nnull as CSC_COMP_TARGET_ID, \r\nnull as CSC_SITE_ID, \r\nnull as CSC_GLOBAL_ULTIMATE_ID, \r\nnull as ACCOUNT_TYPE, \r\nnull as STRUCTURED_ACCOUNT, \r\nOREPLACE(OREPLACE(IRDC.ACCOUNT_NAME,CHR(10),''),CHR(7),''),\r\nOREPLACE(OREPLACE(IRDC.ADDR,CHR(10),''),CHR(7),''),\r\nOREPLACE(OREPLACE(IRDC.ADDR_LINE_2,CHR(10),''),CHR(9),''),\r\nnull as ADDR_LINE_3, \r\nOREPLACE(OREPLACE(IRDC.CITY,CHR(10),''),CHR(9),''),\r\nOREPLACE(OREPLACE(IRDC.PROVINCE,CHR(10),''),CHR(9),''),\r\nOREPLACE(OREPLACE(IRDC.ZIPCODE,CHR(10),''),CHR(9),''),\r\nIRDC.COUNTRY, \r\nIRDC.COUNTY,\r\nIRDC.COUNTRY_CODE,\r\nnull as END_CUSTOMER_TYPE, \r\n'CCWR' as CREATED_BY, \r\nCURRENT_TIMESTAMP(0) as CREATED_ON, \r\n'CCWR' as UPDATED_BY, \r\nCURRENT_TIMESTAMP(0) as UPDATED_ON,\r\nIRDC.CR_ID,\r\nIRDC.EDW_UPDATED_DATE as EDW_UPDATED_DATE\r\nFROM \r\n$$ETLVWDB.EL_INT_RAW_DM_CUSTOMER_RNWL_KAFKA IRDC\r\n/*Added as part of CCW data fix aug rel*/\r\nINNER JOIN (select * from $$ETLVWDB.EL_INT_CQ_DEAL_RNWL_KAFKA\r\nQUALIFY ROW_NUMBER() OVER(PARTITION by OPTY_NUMBER order by EDW_CREATE_DTM desc,UPDATED_ON_KAFKA desc)=1\r\n)DEAL\r\nON IRDC.DEAL_OBJECT_ID = DEAL.OBJECT_ID\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY  IRDC.DEAL_OBJECT_ID ORDER BY IRDC.EDW_CREATE_DTM DESC,IRDC.OFFSET_NUMBER DESC)=1 /*Added as part of CCW data fix Aug rel*/\r\nWhere IRDC.EDW_CREATE_DTM >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS where JOB_STREAM_ID='wf_ST_INT_RAW_DM_CUST_RNWL_KFA')",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
