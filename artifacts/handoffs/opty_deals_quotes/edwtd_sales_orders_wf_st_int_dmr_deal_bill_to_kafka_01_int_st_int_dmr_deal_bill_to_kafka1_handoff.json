      "attributes": {
        "Sql Query": "SELECT EL_INT_DMR_DEAL_BILL_TO_KAFKA.OBJECT_ID, EL_INT_DMR_DEAL_BILL_TO_KAFKA.QUOTE_OBJECT_ID, \r\nCOALESCE(EL_INT_DMR_DEAL_BILL_TO_KAFKA.BILLTO_LOCATION,-9999) as BILLTO_LOCATION,\r\nEL_INT_DMR_DEAL_BILL_TO_KAFKA.PARTY_ID, EL_INT_DMR_DEAL_BILL_TO_KAFKA.CUSTOMER_NAME, \r\nEL_INT_DMR_DEAL_BILL_TO_KAFKA.CUST_ACCT_SITE_ID, EL_INT_DMR_DEAL_BILL_TO_KAFKA.CUST_ACCOUNT_ID, \r\nEL_INT_DMR_DEAL_BILL_TO_KAFKA.ACCOUNT_NUMBER, EL_INT_DMR_DEAL_BILL_TO_KAFKA.ADDRESS1, \r\nEL_INT_DMR_DEAL_BILL_TO_KAFKA.ADDRESS2, EL_INT_DMR_DEAL_BILL_TO_KAFKA.ADDRESS3, \r\nEL_INT_DMR_DEAL_BILL_TO_KAFKA.ADDRESS4, EL_INT_DMR_DEAL_BILL_TO_KAFKA.COUNTRY, \r\nEL_INT_DMR_DEAL_BILL_TO_KAFKA.CITY, EL_INT_DMR_DEAL_BILL_TO_KAFKA.POSTAL_CODE, \r\nEL_INT_DMR_DEAL_BILL_TO_KAFKA.STATE, EL_INT_DMR_DEAL_BILL_TO_KAFKA.PROVINCE, \r\nEL_INT_DMR_DEAL_BILL_TO_KAFKA.COUNTY, EL_INT_DMR_DEAL_BILL_TO_KAFKA.COUNTRY_DESC, \r\nEL_INT_DMR_DEAL_BILL_TO_KAFKA.CREATED_ON, \r\nEL_INT_DMR_DEAL_BILL_TO_KAFKA.CREATED_BY, EL_INT_DMR_DEAL_BILL_TO_KAFKA.UPDATED_ON, \r\nEL_INT_DMR_DEAL_BILL_TO_KAFKA.UPDATED_BY, EL_INT_DMR_DEAL_BILL_TO_KAFKA.EDW_UPDATED_DATE\r\n--EL_INT_DMR_DEAL_BILL_TO_KAFKA.UPDATED_BY_KAFKA, \r\n--EL_INT_DMR_DEAL_BILL_TO_KAFKA.UPDATED_ON_KAFKA, \r\n--EL_INT_DMR_DEAL_BILL_TO_KAFKA.OFFSET_NUMBER \r\nFROM\r\n $$ETLVWDB.EL_INT_DMR_DEAL_BILL_TO_KAFKA EL_INT_DMR_DEAL_BILL_TO_KAFKA\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY EL_INT_DMR_DEAL_BILL_TO_KAFKA.QUOTE_OBJECT_ID \r\nORDER BY EL_INT_DMR_DEAL_BILL_TO_KAFKA.EDW_CREATE_DTM DESC,EL_INT_DMR_DEAL_BILL_TO_KAFKA.MESSAGE_SEQUENCE_NUMBER DESC)=1 --Added create_dtm as part of CCW data fix Aug rel\r\nWhere EL_INT_DMR_DEAL_BILL_TO_KAFKA.EDW_CREATE_DTM >= \r\n(SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS where JOB_STREAM_ID='wf_ST_INT_DMR_DEAL_BILL_TO_KAFKA')",
        "User Defined Join": "",
