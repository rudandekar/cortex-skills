      "attributes": {
        "Sql Query": "SELECT  \r\n        CASE WHEN (ST.DEAL_OBJECT_ID = EL.DEAL_OBJECT_ID \r\n\t\tAND TD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(ST.MEMBER_CCO_ID,\r\n        '[^!-~a-zA-Z0-9]+',\r\n        ' ',1,0,\r\n        'i') ,\r\n        X'0d' ,\r\n        ' ') ,\r\n        X'0a' ,\r\n        ' ')=EL.MEMBER_CCO_ID)\r\n\t\tTHEN EL.OBJECT_ID\r\n\t\tELSE\r\n\t\t(SELECT COALESCE(MAX(OBJECT_ID),0) as MAX_VAL_OBJECT_ID FROM $$ETLONLYDB.EL_INT_DMR_DM_TM_ASGINMNT_RNWL_KFKA ) \r\n\t\t+ DENSE_RANK() OVER ( ORDER BY ST.DEAL_OBJECT_ID,TD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(ST.MEMBER_CCO_ID,\r\n        '[^!-~a-zA-Z0-9]+',\r\n        ' ',1,0,\r\n        'i') ,\r\n        X'0d' ,\r\n        ' ') ,\r\n        X'0a' ,\r\n        ' ')) END AS OBJECT_ID,\r\n\t\tST.DEAL_OBJECT_ID as DEAL_OBJECT_ID,\r\n        SQ.QUOTE_ID AS QUOTE_OBJECT_ID,\r\n        TD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(ST.MEMBER_CCO_ID,\r\n        '[^!-~a-zA-Z0-9]+',\r\n        ' ',1,0,\r\n        'i') ,\r\n        X'0d' ,\r\n        ' ') ,\r\n        X'0a' ,\r\n        ' ') AS MEMBER_CCO_ID,\r\n        TD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(ST.MEMBER_ROLE,\r\n        '[^!-~a-zA-Z0-9]+',\r\n        ' ',1,0,\r\n        'i') ,\r\n        X'0d' ,\r\n        ' ') ,\r\n        X'0a' ,\r\n        ' ') AS MEMBER_ROLE,\r\n\t\tCASE \r\n            WHEN ST.CREATED_ON IS NULL THEN CAST(LEFT(OREPLACE(SD.CREATED_ON,'T',' '), 19) as TIMESTAMP(0)) \r\n            ELSE CAST(LEFT(OREPLACE(ST.CREATED_ON,'T',' '), 19) as TIMESTAMP(0))   \r\n        END AS CREATED_ON,\r\n\t\tCOALESCE(ST.CREATED_BY,SD.CREATED_BY) as  CREATED_BY,\r\n        CAST(LEFT(OREPLACE(ST.UPDATED_ON,'T',' '), 19) as TIMESTAMP(0)) as UPDATED_ON,\r\n\t\tST.UPDATED_BY as  UPDATED_BY,\r\n        '1' as ACTIVE,\r\n        ST.UPDATED_BY_KAFKA,\r\n        CAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,'T',''), 19) as TIMESTAMP(0)) AS UPDATED_ON_KAFKA,\r\n        ST.OFFSET_NUMBER,\r\n        ST.PARTITION_NUMBER,\r\n        CAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) as EDW_CREATE_DTM,\r\n        USER as EDW_CREATE_USER,\r\n        CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n        USER AS EDW_UPDATE_USER \r\nFROM    $$ETLVWDB.ST_SI_INT_DMR_DM_TEM_ASIMNT_RNWL_KFK ST \r\n\tLEFT JOIN $$ETLVWDB.EL_INT_DMR_DM_TM_ASGINMNT_RNWL_KFKA EL\r\n\tON ST.DEAL_OBJECT_ID = EL.DEAL_OBJECT_ID\r\n\tAND TD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(ST.MEMBER_CCO_ID,\r\n        '[^!-~a-zA-Z0-9]+',\r\n        ' ',1,0,\r\n        'i') ,\r\n        X'0d' ,\r\n        ' ') ,\r\n        X'0a' ,\r\n        ' ')=EL.MEMBER_CCO_ID\r\nINNER JOIN (SEL OBJECT_ID, CREATED_BY, CREATED_ON,UPDATED_ON, UPDATED_BY FROM $$ETLVWDB.ST_SI_INT_CQ_DEAL_RNWL_KAFKA \r\nWHERE OBJECT_ID IN (SEL DEAL_OBJECT_ID FROM $$ETLVWDB.ST_SI_INT_DMR_DM_TEM_ASIMNT_RNWL_KFK ST)\r\nGROUP BY 1,2,3,4,5\r\n)SD \r\n    ON ST.DEAL_OBJECT_ID = SD.OBJECT_ID  \r\nINNER JOIN (SEL PARENT_ID, QUOTE_ID FROM  $$ETLVWDB.ST_SI_INT_CQ_SNGL_QUTE_VW_RNWL_KFKA\r\nWHERE PARENT_ID IN (SEL OBJECT_ID FROM  $$ETLVWDB.ST_SI_INT_CQ_DEAL_RNWL_KAFKA ) \r\nGROUP BY 1,2\r\n) SQ\r\n    on SQ.PARENT_ID=SD.OBJECT_ID \r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY ST.DEAL_OBJECT_ID,TD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(ST.MEMBER_CCO_ID,\r\n        '[^!-~a-zA-Z0-9]+',\r\n        ' ',1,0,\r\n        'i') ,\r\n        X'0d' ,\r\n        ' ') ,\r\n        X'0a' ,\r\n        ' ') ORDER BY ST.EDW_CREATE_DTM DESC,ST.OFFSET_NUMBER DESC)=1\r\nWHERE   \r\nCAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS \r\nwhere JOB_STREAM_ID='wf_EL_INT_DMR_DM_TM_ASGNMNT_RNWL_KFKA') and \r\nNOT EXISTS (\r\n    SELECT  1 \r\n    FROM    $$ETLVWDB.EL_INT_DMR_DM_TM_ASGINMNT_RNWL_KFKA EL \r\n    WHERE   ST.DEAL_OBJECT_ID = EL.DEAL_OBJECT_ID  \r\n        AND  TD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(ST.MEMBER_CCO_ID,\r\n        '[^!-~a-zA-Z0-9]+',\r\n        ' ',1,0,\r\n        'i') ,\r\n        X'0d' ,\r\n        ' ') ,\r\n        X'0a' ,\r\n        ' ')=EL.MEMBER_CCO_ID)",
        "User Defined Join": "",
