      "attributes": {
        "Sql Query": "SELECT DISTINCT       \r\n              COALESCE(DMR.OBJECT_ID, -999) AS OBJECT_ID ,\r\n\t\t      COALESCE(DMR.PARENT_ID, -999) AS QUOTE_OBJECT_ID,\r\n\t\t      COALESCE(TO_CHAR(DMR.BILLTO_LOCATION),RESELLER_BILL_TO) AS BILLTO_LOCATION ,\r\n\t\t      TD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(  DMR.CUSTOMER_NAME,\r\n\t\t'[^!-~a-zA-Z0-9]+',\r\n\t\t' ',1,0,\r\n\t\t'i') ,\r\n\t\tX'0d' ,\r\n\t\t' ') ,\r\n\t\tX'0a' ,\r\n\t\t' ') AS CUSTOMER_NAME ,\r\n\t\t      DMR.CUST_ACCOUNT_ID,\r\n\t\t      TD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(  DMR.COUNTRY_DESC,\r\n\t\t'[^!-~a-zA-Z0-9]+',\r\n\t\t' ',1,0,\r\n\t\t'i') ,\r\n\t\tX'0d' ,\r\n\t\t' ') ,\r\n\t\tX'0a' ,\r\n\t\t' ') AS COUNTRY_DESC ,\r\n\t\t      CAST(LEFT(OREPLACE(SD.CREATED_ON,\r\n\t\t'T',' '), 19) as TIMESTAMP(0)) as CREATED_ON,\r\n\t\t      COALESCE(DMR.CREATED_BY,\r\n\t\tSD.CREATED_BY) as  CREATED_BY,\r\n\t\t      CAST(LEFT(OREPLACE(SD.UPDATED_ON,\r\n\t\t'T',' '), 19) as TIMESTAMP(0)) as UPDATED_ON,\r\n\t\t      COALESCE(DMR.UPDATED_BY,SD.UPDATED_BY) as  UPDATED_BY,\r\n\t\t      DMR.EDW_UPDATED_DATE ,\r\n\t\t      DMR.UPDATED_BY_KAFKA,\r\n\t\t      cast(left (DMR.UPDATED_ON_KAFKA,19) as timestamp(0)) AS UPDATED_ON_KAFKA,\r\n\t\t      DMR.OFFSET_NUMBER,\r\n\t\t      DMR.PARTITION_NUMBER,\r\nCAST(CAST(DMR.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) as EDW_CREATE_DTM,\r\n\t\t      USER as EDW_CREATE_USER,\r\n\t\t       USER AS EDW_UPDATE_USER,\r\n\t\t\t   CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n\t\t\t   DMR.QUOTE_STATUS_ID,\r\n\t\t\t   DMR.REF_ENTITY_NUMBER\r\nFROM\t$$ETLVWDB.ST_SI_INT_DMR_DL_BILL_TO_RNWL_KAFKA DMR \r\n     INNER JOIN ( SELECT CAST (SD.QUOTE_ID as bigint) AS QUOTE_ID_INT ,CREATED_ON,CREATED_BY,UPDATED_ON,UPDATED_BY, OFFSET_NUMBER\r\n\t\tFROM $$ETLVWDB.ST_SI_INT_CQ_SNGL_QUTE_VW_RNWL_KFKA SD          \r\n\t\tGROUP BY 1,2,3,4,5,6 ) SD           \r\n\tON  COALESCE(DMR.PARENT_ID, -999) = COALESCE(SD.QUOTE_ID_INT, -999)\r\n\tAND  DMR.OFFSET_NUMBER = SD.OFFSET_NUMBER\r\nQUALIFY ROW_NUMBER() OVER(PARTITION by PARENT_ID, COALESCE(BILLTO_LOCATION,RESELLER_BILL_TO) ORDER BY EDW_CREATE_DTM DESC, DMR.OFFSET_NUMBER DESC)=1    \r\nWHERE\tNOT EXISTS (\r\n\tSELECT\t1 \r\n\tFROM\t$$ETLVWDB.EL_INT_DMR_DEAL_BILL_TO_RNWL_KAFKA EL \r\n\tWHERE\tDMR.PARENT_ID = EL.QUOTE_OBJECT_ID  \r\n\t\tAND  COALESCE(DMR.BILLTO_LOCATION,DMR.RESELLER_BILL_TO) = EL.BILLTO_LOCATION  )\r\n\t\tAND \r\nCAST(CAST(DMR.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS\r\nwhere JOB_STREAM_ID='wf_EL_INT_DMR_DEAL_BILL_TO_KFKA_RNWL')\r\nAND DMR.DEAL_REQUESTED_BY IS NOT NULL\r\nAND DMR.PARENT_ID IS NOT NULL",
        "User Defined Join": "",
        "Source Filter": "",
