      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\n  1 AS BATCH_ID,\r\n  ST.DEAL_OBJECT_ID AS DEAL_OBJECT_ID,\r\n    CASE \r\n    WHEN (ST.DEAL_OBJECT_ID = EL.DEAL_OBJECT_ID AND ST.OWNER_CEC_ID=EL.CONTACT_ID)\r\n      THEN EL.OBJECT_ID\r\n    ELSE\r\n      (SELECT COALESCE(MAX(OBJECT_ID),0) as MAX_VAL_OBJECT_ID FROM \r\n      $$ETLVWDB.EL_CQ_DEAL_CONTACT_RNWL_KAFKA ) + DENSE_RANK() OVER ( ORDER BY ST.DEAL_OBJECT_ID,ST.OWNER_CEC_ID) \r\n    END \r\n  AS OBJECT_ID,\r\n  ST.OWNER_CEC_ID as CONTACT_ID,\r\n  CAST(LEFT(OREPLACE(ST.CREATED_ON,'T',' '), 19) as TIMESTAMP(0)) as CREATED_ON,\r\n  ST.CREATED_BY as CREATED_BY,\r\n  CAST(LEFT(OREPLACE(ST.UPDATED_ON,'T',' '), 19) as TIMESTAMP(0)) as UPDATED_ON,\r\n  ST.UPDATED_BY as UPDATED_BY,\r\n  '' AS SIEBEL_POSTN_ID ,\r\n  'I' AS ACTION_CODE ,\r\n  ST.UPDATED_BY_KAFKA,\r\n  CAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,'T',' '), 19) as TIMESTAMP(0)) AS UPDATED_ON_KAFKA,\r\n  ST.OFFSET_NUMBER,\r\n  ST.PARTITION_NUMBER,\r\n  USER AS EDW_CREATE_USER,\r\n  CAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) as EDW_CREATE_DTM,\r\n  CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n  USER AS EDW_UPDATE_USER\r\nFROM $$ETLVWDB.ST_SI_INT_CQ_DEAL_RNWL_KAFKA ST\r\nLEFT OUTER JOIN $$ETLVWDB.EL_CQ_DEAL_CONTACT_RNWL_KAFKA EL -- added to populate OBJECT_ID\r\nON ST.DEAL_OBJECT_ID = EL.DEAL_OBJECT_ID AND ST.OWNER_CEC_ID = EL.CONTACT_ID\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY ST.DEAL_OBJECT_ID, ST.OWNER_CEC_ID ORDER BY ST.EDW_CREATE_DTM DESC,ST.OFFSET_NUMBER DESC)=1\r\nWHERE \r\nCAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS\r\nwhere JOB_STREAM_ID='wf_EL_CQ_DEAL_CONTACT_RNWL_KFKA') and\r\nNOT EXISTS (\r\nSELECT 1\r\nFROM $$ETLVWDB.EL_CQ_DEAL_CONTACT_RNWL_KAFKA EL\r\nWHERE ST.DEAL_OBJECT_ID = EL.DEAL_OBJECT_ID\r\nAND ST.OWNER_CEC_ID = EL.CONTACT_ID)",
        "User Defined Join": "",
