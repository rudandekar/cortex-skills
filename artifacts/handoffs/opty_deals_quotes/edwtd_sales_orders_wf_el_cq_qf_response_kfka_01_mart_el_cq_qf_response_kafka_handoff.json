      "attributes": {
        "Sql Query": "SELECT\tDISTINCT 1 AS BATCH_ID ,\r\n\t\tST.PARENT_ID AS DEAL_OBJECT_ID ,\r\n\t\tST.QUESTION_ID,\r\n\t\tST.VALUE_NAME ,\r\n\t\tSTD.CREATED_BY\tas\tCREATED_BY ,\r\n\t\tCAST(STD.CREATED_ON AS TIMESTAMP(0) FORMAT 'DD-MMM-YYYY')\tas CREATION_DATE,\r\n\t\t  STD.UPDATED_BY\tas\tLAST_UPDATED_BY ,\r\n\t\tCAST(STD.UPDATED_ON AS TIMESTAMP(0) FORMAT 'DD-MMM-YYYY')  as LAST_UPDATE_DATE ,\r\n\t\tCAST(STD.CREATED_ON AS TIMESTAMP(0) FORMAT 'DD-MMM-YYYY') as CREATE_DATETIME ,\r\n\t\t'I' AS ACTION_CODE,\r\n\t\tST.UPDATED_BY_KAFKA,\r\n\t\tCAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,\r\n\t\t'T',' '), 19) as TIMESTAMP(0)) AS UPDATED_ON_KAFKA,\r\n\t\tST.OFFSET_NUMBER,\r\n\t\tST.PARTITION_NUMBER,\r\n\t\tCURRENT_TIMESTAMP(0) as EDW_CREATE_DTM,\r\n\t\tUSER as EDW_CREATE_USER,\r\n\t\tST.MESSAGE_SEQUENCE_NUMBER,\r\n\t\tCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n\t\tUSER AS EDW_UPDATE_USER \r\nFROM\t$$STGDB.ST_CQ_QF_RESPONSE_KAFKA_FF ST \r\nINNER JOIN ( SELECT OBJECT_ID ,CREATED_ON,CREATED_BY,UPDATED_ON,UPDATED_BY\r\n\t\tFROM $$STGDB.ST_INT_CQ_DEAL_KAFKA_FF STD          \r\n\t\tGROUP BY 1,2,3,4,5 ) STD\r\n\tON ST.PARENT_ID=STD.object_id \r\nWHERE\tNOT EXISTS (\r\n\tSELECT\t1 \r\n\tFROM\t$$ETLVWDB.EL_CQ_QF_RESPONSE_KAFKA EL \r\n\tWHERE\tST.PARENT_ID = EL.DEAL_OBJECT_ID  \r\n\t\tAND  ST.OFFSET_NUMBER = EL.OFFSET_NUMBER \r\n\t\tAND  ST.QUESTION_ID = EL.QUESTION_ID \r\n\t\tAND  ST.VALUE_NAME = EL.VALUE_NAME \r\n\t\tAND  ST.MESSAGE_SEQUENCE_NUMBER = EL.MESSAGE_SEQUENCE_NUMBER )",
        "User Defined Join": "",
