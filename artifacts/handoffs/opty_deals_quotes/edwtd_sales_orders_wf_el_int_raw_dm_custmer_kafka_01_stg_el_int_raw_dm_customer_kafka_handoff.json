      "attributes": {
        "Sql Query": "select DISTINCT\r\nST.OBJECT_ID,\r\nST.PARENT_ID AS DEAL_OBJECT_ID,\r\nCOALESCE (  SIEBEL_COMPANY_ID,'NULL') AS SIEBEL_COMPANY_ID,\r\n'' AS CSC_COMP_TARGET_ID,\r\n'' AS CSC_SITE_ID,\r\n'' AS CSC_GLOBAL_ULTIMATE_ID,\r\nST.ACCOUNT_TYPE,\r\nST.STRUCTURED_ACCOUNT,\r\nST.ACCOUNT_NAME,\r\nST.ADDR,\r\nST.ADDR_LINE_2,\r\nST.ADDR_LINE_3,\r\nST.CITY,\r\nST.PROVINCE,\r\nST.ZIPCODE,\r\nST.COUNTRY,\r\nST.END_CUSTOMER_TYPE,\r\nST.CREATED_BY,\r\nST.CREATED_ON,\r\nST.UPDATED_BY,\r\nST.UPDATED_ON,\r\nST.CR_ID,\r\nCURRENT_TIMESTAMP(0) as EDW_UPDATED_DATE,\r\nST.UPDATED_BY_KAFKA,\r\nST.UPDATED_ON_KAFKA,\r\nST.OFFSET_NUMBER,\r\n CURRENT_TIMESTAMP(0) as EDW_CREATE_DTM,\r\n USER as EDW_CREATE_USER,\r\nST.COUNTY,\r\nST.PARTITION_NUMBER,\r\nST.MESSAGE_SEQUENCE_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER\r\nFROM $$STGDB.ST_INT_RAW_DM_CUSTOMER_KFK_FF ST\r\nWhere NOT EXISTS\r\n(SELECT 1 FROM\r\n$$ETLVWDB.EL_INT_RAW_DM_CUSTOMER_KAFKA EL\r\n/* WHERE ST.PARENT_ID = EL.DEAL_OBJECT_ID -- COMMENTED AS PART OF CCW DATA FIX AUG REL */\r\nWHERE ST.OBJECT_ID = EL.OBJECT_ID /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\nAND ST.MESSAGE_SEQUENCE_NUMBER = EL.MESSAGE_SEQUENCE_NUMBER\r\n)",
        "User Defined Join": "",
