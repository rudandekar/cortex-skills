      "attributes": {
        "Sql Query": "SELECT\r\n FR.BK_QUOTE_NUM AS BK_QUOTE_NUM,\r\n FR.SUMMARY_TYPE AS BK_SUMMARY_TYPE_CD,\r\n FR.TTL_EXTENDED_LIST_PRC_USD_AMT,\r\n FR.TTL_EXTENDED_NET_PRICE_USD_AMT,\r\n FR.TOTAL_DISCOUNT_PERCENT,\r\n FR.TOTAL_COST_USD_AMT,\r\n FR.STANDARD_COST_USD_AMT,\r\n FR.OVERHEAD_COST_USD_AMT,\r\n FR.ROYALTY_COST_USD_AMT,\r\n FR.GROSS_MARGIN_PERCENT,\r\n FR.GROSS_MARGIN_USD_AMT,\r\n FR.STANDARD_MARGIN_USD_AMT,\r\n FR.STANDARD_MARGIN_PERCENT,\r\n FR.NEGOTIATED_NET_PRICE_USD_AMT,\r\n FR.NEGOTIATED_DISCOUNT_PERCENT,\r\n FR.DSCNT_EXCLDNG_TRADE_IN_USD_AMT,\r\n FR.NET_PRC_EXCLDNG_TRD_IN_USD_AMT,\r\n FR.NET_PRC_EXCLDNG_CRDTS_USD_AMT,\r\n CURRENT_TIMESTAMP(0),\r\n USER,\r\n CURRENT_TIMESTAMP(0),\r\n USER,\r\n 'I' AS ACTION_CODE,\r\n '=' DML_TYPE\r\n FROM (\r\n    SELECT \r\n        NDQ.BK_QUOTE_NUM,\r\n        FIN_SUM.SUMMARY_TYPE,\r\n        FIN_SUM.EXT_LIST_PRICE AS TTL_EXTENDED_LIST_PRC_USD_AMT,\r\n        FIN_SUM.EXT_NET_PRICE AS TTL_EXTENDED_NET_PRICE_USD_AMT,\r\n        FIN_SUM.DISCOUNT_PERCENT AS TOTAL_DISCOUNT_PERCENT,\r\n        FIN_SUM.TOTAL_COST AS TOTAL_COST_USD_AMT,\r\n        FIN_SUM.STANDARD_COST AS STANDARD_COST_USD_AMT,\r\n        FIN_SUM.OVERHEAD_COST AS OVERHEAD_COST_USD_AMT,\r\n        FIN_SUM.ROYALTY_COST AS ROYALTY_COST_USD_AMT,\r\n        FIN_SUM.GROSS_MARGIN_PERCENT AS GROSS_MARGIN_PERCENT,\r\n        FIN_SUM.GROSS_MARGIN AS GROSS_MARGIN_USD_AMT,\r\n        FIN_SUM.STANDARD_MARGIN AS STANDARD_MARGIN_USD_AMT,\r\n        FIN_SUM.STANDARD_MARGIN_PERCENT AS STANDARD_MARGIN_PERCENT,\r\n        FIN_SUM.NEGOTIATED_NET_PRICE AS NEGOTIATED_NET_PRICE_USD_AMT,\r\n        FIN_SUM.NEGOTIATED_DISCOUNT AS NEGOTIATED_DISCOUNT_PERCENT,\r\n        FIN_SUM.DISCOUNT_EXCL_TRADE_IN AS DSCNT_EXCLDNG_TRADE_IN_USD_AMT,\r\n        FIN_SUM.NET_PRICE_EXCL_TRADE_IN AS NET_PRC_EXCLDNG_TRD_IN_USD_AMT,\r\n        FIN_SUM.NET_PRICE_EXCL_CREDITS AS NET_PRC_EXCLDNG_CRDTS_USD_AMT,\r\n        FIN_SUM.LAST_UPDATE_DATE,\r\n        FIN_SUM.REFERENCE_OBJECT_ID\r\n    FROM \r\n    (\r\n        SELECT * FROM $$STGDB.ST_INT_DM_DEAL_FINANCIAL_SUM ST\r\n        QUALIFY ROW_NUMBER() OVER(PARTITION BY REFERENCE_OBJECT_ID, SUMMARY_TYPE ORDER BY LAST_UPDATE_DATE DESC)=1\r\n    ) FIN_SUM\r\n    INNER JOIN (\r\n          SELECT NPS.BK_DEAL_ID, NPS.SK_SCENARIO_ID_INT, NPS.PRICING_SCENARIO_KEY, EL.REFERENCE_OBJECT_ID\r\n          FROM $$SLSORDVWDB.N_PRICING_SCENARIO NPS \r\n          INNER JOIN $$ETLVWDB.EL_PRICING_SCENARIO_REFERENCE_DTLS EL  \r\n          ON NPS.PRICING_SCENARIO_KEY = EL.PRICING_SCENARIO_KEY\r\n    ) NPS\r\n    ON NPS.SK_SCENARIO_ID_INT = FIN_SUM.REFERENCE_OBJECT_ID\r\n    INNER JOIN (\r\n         SELECT * FROM $$SLSORDVWDB.N_DEAL_QUOTE\r\n         QUALIFY ROW_NUMBER() OVER(PARTITION BY BK_DEAL_ID, SK_QUOTE_OBJECT_ID_INT ORDER BY EDW_CREATE_DTM DESC)=1\r\n    ) NDQ\r\n    ON NPS.REFERENCE_OBJECT_ID = NDQ.SK_QUOTE_OBJECT_ID_INT  \r\n    AND NPS.BK_DEAL_ID=NDQ.BK_DEAL_ID\r\n) FR\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY FR.BK_QUOTE_NUM, FR.SUMMARY_TYPE ORDER BY FR.LAST_UPDATE_DATE DESC NULLS LAST, FR.REFERENCE_OBJECT_ID DESC) = 1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
