      "attributes": {
        "Sql Query": "SELECT\r\nNSO.SOURCE_REPORTED_DEAL_ID AS DEAL_ID\r\n,Coalesce(Cast(NSO.RU_DV_CISCO_BOOKED_DT AS TIMESTAMP(0)),Cast('3500/01/01 00:00:00' AS TIMESTAMP(0))) AS CISCO_BOOKED_DATE\r\n,TRX.BK_SO_NUMBER_INT AS SALES_ORDER_NUMBER        \r\n,Coalesce(NSO.TRANSACTIONAL_CURRENCY_CD,'UNK') AS TRANSACTIONAL_CURRENCY_CD\r\n,'ERP' AS BKGS_MEASURE_TRANS_TYPE_CODE\r\n,'NEW' AS OPERATION\r\n,Coalesce(NSO.SALES_CHANNEL_CD,'UNKNOWN') AS SALES_CHANNEL_CODE\r\n,Coalesce(Cast(NSO.SO_SOURCE_CREATE_DTM AS TIMESTAMP(0)),Cast('3500/01/01 00:00:00' AS TIMESTAMP(0)))  AS ORDER_CREATION_DATE\r\n,Coalesce(Sum(TRX.DD_COMP_US_STANDARD_PRICE_AMT),0) AS ORDER_USD_LIST_PRICE_AMOUNT--DD_COMP_US_LIST_PRICE_AMOUNT\r\n,Coalesce(Sum(TRX.DD_COMP_US_STANDARD_PRICE_AMT/TRX.CONVERSION_RT),0) AS ORDER_LOCAL_LIST_PRICE_AMOUNT\r\n,Coalesce(Sum(TRX.DD_COMP_US_NET_PRICE_AMOUNT),0) AS ORDER_USD_NET_PRICE_AMOUNT\r\n,Coalesce(Sum(TRX.DD_COMP_US_NET_PRICE_AMOUNT/TRX.CONVERSION_RT),0) AS ORDER_LOCAL_NET_PRICE_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='N' THEN TRX.DD_COMP_US_NET_PRICE_AMOUNT \r\n              END       ),0) AS PRODUCT_USD_NET_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='N' THEN (TRX.DD_COMP_US_NET_PRICE_AMOUNT/TRX.CONVERSION_RT) \r\n              END       ),0) AS PRODUCT_LOCAL_NET_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='N' THEN (TRX.DD_COMP_US_STANDARD_PRICE_AMT) \r\n              END       ),0) AS PRODUCT_USD_LIST_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='N' THEN (TRX.DD_COMP_US_STANDARD_PRICE_AMT/TRX.CONVERSION_RT) \r\n              END       ),0) AS PRODUCT_LOCAL_LIST_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='Y' THEN TRX.DD_COMP_US_NET_PRICE_AMOUNT \r\n              END       ),0) AS SERVICE_USD_NET_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='Y' THEN (TRX.DD_COMP_US_NET_PRICE_AMOUNT/TRX.CONVERSION_RT) \r\n              END       ),0) AS SERVICE_LOCAL_NET_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='Y' THEN (TRX.DD_COMP_US_STANDARD_PRICE_AMT) \r\n              END       ),0) AS SERVICE_USD_LIST_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='Y' THEN (TRX.DD_COMP_US_STANDARD_PRICE_AMT/TRX.CONVERSION_RT) \r\n              END       ),0)  AS SERVICE_LOCAL_LIST_AMOUNT\r\n,Current_Timestamp(0) AS EDW_CREATE_DATETIME\r\n,USER AS EDW_CREATE_USER\r\n--,MAX(TRX.EDW_UPDATE_DTM) AS EDW_UPDATE_DTM\r\n,INCR1.EDW_UPDATE_DTM1 AS EDW_UPDATE_DTM\r\n,USER AS EDW_UPDATE_USER\r\nFROM \r\n(SELECT    SALES_ORDER_KEY \r\nFROM $$NRTNCRVWDB.MT_DRVD_NRT_BKG_TRX TRX \r\nWHERE  TRX.DV_ATTRIBUTION_CD IN ('STANDALONE','BUNDLE')\r\nAND TRX.EDW_UPDATE_DTM > '$$LastExtractDate'  \r\nGROUP BY 1\r\n) INCR  ,  /* WI_ERP_INCR */\r\n$$NRTNCRVWDB.MT_DRVD_NRT_BKG_TRX TRX,\r\n(SELECT Max(EDW_UPDATE_DTM) AS EDW_UPDATE_DTM1 \r\nFROM (SELECT EDW_UPDATE_DTM FROM $$NRTNCRVWDB.MT_DRVD_NRT_BKG_TRX TRX GROUP BY 1) A) INCR1,\r\n$$NRTNCRVWDB.N_SALES_ORDER_NRT NSO,\r\n$$NRTNCRVWDB.N_SALES_ORDER_LINE_NRT NSOL,\r\n$$COMREFVWDB.R_SALES_HIERARCHY RSH \r\nWHERE 1=1   \r\nAND INCR.SALES_ORDER_KEY =TRX.SALES_ORDER_KEY  \r\nAND TRX.SALES_ORDER_KEY =NSO.SALES_ORDER_KEY \r\nAND NSO.SALES_ORDER_KEY = NSOL.SALES_ORDER_KEY /* AND SS_CD <> 'OPL' */\r\nAND RSH.SALES_TERRITORY_KEY=TRX.SALES_TERRITORY_KEY \r\nAND NSOL.SALES_ORDER_LINE_KEY=TRX.DV_SALES_ORDER_LINE_KEY\r\nAND TRX.DV_ATTRIBUTION_CD IN ('STANDALONE','BUNDLE')\r\nAND NSO.SOURCE_REPORTED_DEAL_ID IS NOT NULL \r\nAND NSO.SALES_ORDER_TYPE_NAME     NOT LIKE ALL ( 'RMA%','Replacement%')\r\nAND NSOL.SALES_ORDER_LINE_CTGRY_TYPE_CD                       <> 'RETURN'\r\nAND RSH.L1_SALES_TERRITORY_DESCR NOT IN ('WW Distribution')\r\nAND NSO.SOLD_FOR_NET_PRICE_FLG <>'Y' /* Added as part of SFP Rel */     \r\nGROUP BY 1,2,3,4,5,6,7,8,21,22,24\r\n\r\nUNION ALL\r\n\r\n/* Added new Union as part of SFP Rel */\r\nSELECT\r\nNSO.SOURCE_REPORTED_DEAL_ID AS DEAL_ID\r\n,Coalesce(Cast(NSO.RU_DV_CISCO_BOOKED_DT AS TIMESTAMP(0)),Cast('3500/01/01 00:00:00' AS TIMESTAMP(0))) AS CISCO_BOOKED_DATE\r\n,TRX.BK_SO_NUMBER_INT AS SALES_ORDER_NUMBER        \r\n,Coalesce(NSO.TRANSACTIONAL_CURRENCY_CD,'UNK') AS TRANSACTIONAL_CURRENCY_CD\r\n,'ERP' AS BKGS_MEASURE_TRANS_TYPE_CODE\r\n,'NEW' AS OPERATION\r\n,Coalesce(NSO.SALES_CHANNEL_CD,'UNKNOWN') AS SALES_CHANNEL_CODE\r\n,Coalesce(Cast(NSO.SO_SOURCE_CREATE_DTM AS TIMESTAMP(0)),Cast('3500/01/01 00:00:00' AS TIMESTAMP(0)))  AS ORDER_CREATION_DATE\r\n,Coalesce(Sum(TRX.DD_COMP_US_STANDARD_PRICE_AMT),0) AS ORDER_USD_LIST_PRICE_AMOUNT--DD_COMP_US_LIST_PRICE_AMOUNT\r\n,Coalesce(Sum(TRX.DD_COMP_US_STANDARD_PRICE_AMT/TRX.CONVERSION_RT),0) AS ORDER_LOCAL_LIST_PRICE_AMOUNT\r\n,Coalesce(Sum(TRX.DD_COMP_US_NET_PRICE_AMOUNT),0) AS ORDER_USD_NET_PRICE_AMOUNT\r\n,Coalesce(Sum(TRX.DD_COMP_US_NET_PRICE_AMOUNT/TRX.CONVERSION_RT),0) AS ORDER_LOCAL_NET_PRICE_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='N' THEN TRX.DD_COMP_US_NET_PRICE_AMOUNT \r\n              END       ),0) AS PRODUCT_USD_NET_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='N' THEN (TRX.DD_COMP_US_NET_PRICE_AMOUNT/TRX.CONVERSION_RT) \r\n              END       ),0) AS PRODUCT_LOCAL_NET_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='N' THEN (TRX.DD_COMP_US_STANDARD_PRICE_AMT) \r\n              END       ),0) AS PRODUCT_USD_LIST_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='N' THEN (TRX.DD_COMP_US_STANDARD_PRICE_AMT/TRX.CONVERSION_RT) \r\n              END       ),0) AS PRODUCT_LOCAL_LIST_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='Y' THEN TRX.DD_COMP_US_NET_PRICE_AMOUNT \r\n              END       ),0) AS SERVICE_USD_NET_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='Y' THEN (TRX.DD_COMP_US_NET_PRICE_AMOUNT/TRX.CONVERSION_RT) \r\n              END       ),0) AS SERVICE_LOCAL_NET_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='Y' THEN (TRX.DD_COMP_US_STANDARD_PRICE_AMT) \r\n              END       ),0) AS SERVICE_USD_LIST_AMOUNT\r\n,Coalesce(Sum (CASE        \r\n              WHEN TRX.DD_SERVICE_FLAG='Y' THEN (TRX.DD_COMP_US_STANDARD_PRICE_AMT/TRX.CONVERSION_RT) \r\n              END       ),0)  AS SERVICE_LOCAL_LIST_AMOUNT\r\n,Current_Timestamp(0) AS EDW_CREATE_DATETIME\r\n,USER AS EDW_CREATE_USER\r\n--,MAX(TRX.EDW_UPDATE_DTM) AS EDW_UPDATE_DTM\r\n,INCR1.EDW_UPDATE_DTM1 AS EDW_UPDATE_DTM\r\n,USER AS EDW_UPDATE_USER\r\nFROM \r\n(SELECT    SALES_ORDER_KEY \r\nFROM $$NRTNCRVWDB.MT_DRVD_NRT_BKG_TRX TRX \r\nWHERE  TRX.DV_ATTRIBUTION_CD IN ('STANDALONE','BUNDLE')\r\nAND TRX.EDW_UPDATE_DTM > '$$LastExtractDate'  \r\nGROUP BY 1\r\n) INCR  ,  /* WI_ERP_INCR */\r\n$$NRTNCRVWDB.MT_DRVD_NRT_BKG_TRX TRX,\r\n(SELECT Max(EDW_UPDATE_DTM) AS EDW_UPDATE_DTM1 \r\nFROM (SELECT EDW_UPDATE_DTM FROM $$NRTNCRVWDB.MT_DRVD_NRT_BKG_TRX TRX GROUP BY 1) A) INCR1,\r\n$$NRTNCRVWDB.N_SALES_ORDER_NRT NSO,\r\n$$NRTNCRVWDB.N_SALES_ORDER_LINE_NRT NSOL,\r\n$$COMREFVWDB.R_SALES_HIERARCHY RSH \r\nWHERE 1=1   \r\nAND INCR.SALES_ORDER_KEY =TRX.SALES_ORDER_KEY  \r\nAND TRX.SALES_ORDER_KEY =NSO.SALES_ORDER_KEY \r\nAND NSO.SALES_ORDER_KEY = NSOL.SALES_ORDER_KEY /* AND SS_CD <> 'OPL' */\r\nAND RSH.SALES_TERRITORY_KEY=TRX.SALES_TERRITORY_KEY \r\nAND NSOL.SALES_ORDER_LINE_KEY=TRX.DV_SALES_ORDER_LINE_KEY\r\nAND TRX.DV_ATTRIBUTION_CD IN ('STANDALONE','BUNDLE')\r\nAND NSO.SOURCE_REPORTED_DEAL_ID IS NOT NULL \r\nAND NSO.SALES_ORDER_TYPE_NAME     NOT LIKE ALL ( 'RMA%','Replacement%')\r\nAND NSOL.SALES_ORDER_LINE_CTGRY_TYPE_CD                       <> 'RETURN'\r\n--AND RSH.L1_SALES_TERRITORY_DESCR NOT IN ('WW Distribution')\r\nAND NSO.SOLD_FOR_NET_PRICE_FLG ='Y'       \r\nGROUP BY 1,2,3,4,5,6,7,8,21,22,24",
