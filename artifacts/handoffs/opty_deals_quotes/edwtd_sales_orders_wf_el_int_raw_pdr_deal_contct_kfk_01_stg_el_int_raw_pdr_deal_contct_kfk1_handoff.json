      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\nST.OBJECT_ID,\r\nST.PARENT_ID AS QUOTE_OBJECT_ID,\r\nST.CONTACT_EMAIL_ID,\r\nST.CONTACT_FIRST_NAME,\r\nST.CONTACT_LAST_NAME,\r\nST.CONTACT_PHONE_NUMBER,\r\nST.CONTACT_JOB_TITLE,\r\nST.OTHER_JOB_TITLE,\r\nST.CONTACT_TYPE,\r\nST.CONTACT_TYPE_NAME,\r\nST.CONTACT_CCO_ID,\r\n---Case When ST.CREATED_ON IS NULL THEN cast(LEFT(OREPLACE(SQ.CREATED_ON,'T',' '), 19)  as timestamp(0)) else  CAST(CAST(ST.CREATED_ON as DATE FORMAT  'DD-MMM-YYYY') as TIMESTAMP(0))  END  as CREATED_ON, Commenting as part of CCW DATA FIXES\r\nCAST(CAST(COALESCE(ST.CREATED_ON,'1900-01-01 00:00:00' ) AS VARCHAR(19)) AS TIMESTAMP(0))  as CREATED_ON,\r\nCOALESCE(ST.CREATED_BY,'CCW') as CREATED_BY, /* Added as part of CCW data fix */\r\n---Case When ST.UPDATED_ON IS NULL THEN cast(LEFT(OREPLACE(SQ.UPDATED_ON,'T',' '), 19)  as timestamp(0)) else  CAST(CAST(ST.UPDATED_ON as DATE FORMAT  'DD-MMM-YYYY') as TIMESTAMP(0))  END  as UPDATED_ON,  Commenting as part of CCW DATA FIXES\r\nCAST(CAST(COALESCE(ST.UPDATED_ON,'1900-01-01 00:00:00' ) AS VARCHAR(19)) AS TIMESTAMP(0))  as UPDATED_ON, \r\nCOALESCE(ST.UPDATED_BY,'CCW') as UPDATED_BY, /* Added as part of CCW data fix */\r\nPRIMARY_FLAG,\r\nST.CONTACT_URL,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATED_DATE,\r\nST.UPDATED_BY_KAFKA,\r\nCAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,'T',''), 19) as TIMESTAMP(0)) AS UPDATED_ON_KAFKA,\r\nST.OFFSET_NUMBER,\r\nST.PARTITION_NUMBER,\r\nCURRENT_TIMESTAMP(0) as EDW_CREATE_DTM,\r\nUSER as EDW_CREATE_USER,\r\nST.MESSAGE_SEQUENCE_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER\r\nFROM\r\n$$STGDB.ST_INT_RAW_PDR_DEAL_CNT_KFK_FF ST \r\n/*INNER JOIN $$STGDB.ST_INT_CQ_SNGL_QUTE_VW_KFKA_FF SQ ON  ST.PARENT_ID = CAST(SQ.QUOTE_ID as DEC(18,0)) Commenting as part of CCW DATA fix Aug rel */\r\nWhere NOT EXISTS\r\n(SELECT 1 FROM\r\n$$ETLVWDB.EL_INT_RAW_PDR_DEAL_CONTCT_KFK EL\r\n/* WHERE ST.PARENT_ID = EL.QUOTE_OBJECT_ID   Commenting as part of CCW DATA fix Aug rel  */\r\nWHERE ST.OBJECT_ID = EL.OBJECT_ID\r\nAND ST.MESSAGE_SEQUENCE_NUMBER = EL.MESSAGE_SEQUENCE_NUMBER\r\n)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
