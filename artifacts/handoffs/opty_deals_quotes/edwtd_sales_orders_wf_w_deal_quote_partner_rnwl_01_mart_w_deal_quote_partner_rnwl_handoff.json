      "attributes": {
        "Sql Query": "SELECT\t\r\nNDQ.BK_QUOTE_NUM AS BK_QUOTE_NUM,\r\nCOALESCE(PT.PARTNER_SITE_PARTY_KEY,-999) AS PARTNER_SITE_PARTY_KEY,\r\nPARTNER_EX.DM_UPDATE_DATE AS SSOT_UPDATE_DTM,\r\nCOALESCE(PARTNER_EX.CREATED_BY,'UNKNOWN') AS SOURCE_REPORTED_CREATED_BY_ID,\r\nCOALESCE(PARTNER_EX.UPDATED_BY,'UNKNOWN') AS SOURCE_REPORTED_UPDATED_BY_ID,\r\nCOALESCE(PARTNER_EX.CREATED_ON,CURRENT_TIMESTAMP(0)) AS SOURCE_REPORTED_CREATED_ON_DTM,\r\nCOALESCE(PARTNER_EX.UPDATED_ON,CURRENT_TIMESTAMP(0)) AS SOURCE_REPORTED_UPDATED_ON_DTM,\r\nCOALESCE(PT.PRIMARY_NAME,'UNKNOWN') AS SOURCE_REPORTED_PARTNER_NAME,\r\nLTRIM(RTRIM(COALESCE(PARTNER_EX.PARTNER_BE_GEO_ID,'UNKNOWN'), '.')) AS SRC_REPORTED_BEGEO_PARTY_NAME,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\n-999 AS CRP_PTNR_SITE_PTY_KEY,\r\nCOALESCE(PARTNER_EX.DEAL_SUBMITTED_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP (0)) )AS CRP_PTNR_DEAL_SUBMITTED_DTM,\r\nCOALESCE(CAST(PARTNER_EX.DEAL_SUBMITTED_DATE as DATE FORMAT 'YYYY-MM-DD'),\r\n\tCAST('3500-01-01' AS DATE FORMAT 'YYYY-MM-DD')) AS DV_CRP_PTNR_DEAL_SUBMITTED_DT, \r\nCOALESCE(PARTNER_EX.CRP_PARTNER_CONV_FLAG,'=') as CRP_PTNR_CNVRT_TO_PRIMARY_FLG,\r\n'CCWR' AS SS_CODE,\r\n'I' AS ACTION_CODE,\r\n'=' AS DML_TYPE\r\nFROM\t$$STGDB.ST_INT_RAW_CQ_QUOTE_PARTNER_EX_RNWL PARTNER_EX\r\nINNER JOIN $$SLSORDVWDB.N_DEAL_QUOTE NDQ\r\nON\tNDQ.SK_QUOTE_OBJECT_ID_INT = PARTNER_EX.QUOTE_OBJECT_ID\r\nAND NDQ.SS_CODE = 'CCWR'\r\nLEFT JOIN ( SELECT PTNR.PARTNER_SITE_PARTY_KEY as PARTNER_SITE_PARTY_KEY,NP.PRIMARY_NAME as PRIMARY_NAME,CUST.SK_SITE_USE_ID as SK_SITE_USE_ID\r\nFROM $$COMREFVWDB.N_ERP_CUST_ACCT_LOC_USE_TV CUST \r\nINNER  JOIN $$COMREFVWDB.MT_PARTNER_HIERARCHY PTNR\r\nON PTNR.PARTNER_SITE_PARTY_KEY=CUST.CUSTOMER_PARTY_KEY\r\nINNER JOIN $$COMREFVWDB.N_PARTY NP\r\nON PTNR.PARTNER_SITE_PARTY_KEY=NP.PARTY_KEY\r\nAND NP.SS_CODE='CR'\r\nWHERE CUST.END_TV_DATE ='3500-01-01'\r\n)PT\r\nON PARTNER_EX.BILLTO_ID = PT.SK_SITE_USE_ID\r\n/*Commented as part of CCWR STARTS\r\nLEFT JOIN $$COMREFVWDB.N_PARTY NP\r\n\tON\tNP.PARTY_SSOT_PARTY_ID_INT=PARTNER_EX.PARTNER_SITE_ID  \r\n\tAND\tNP.SS_CODE='CR'\r\nLEFT JOIN $$COMREFVWDB.N_PARTY NP_CRP\r\n\tON\tNP_CRP.PARTY_SSOT_PARTY_ID_INT=PARTNER_EX.CRP_PARTNER_SITE_ID  \r\n\tAND\tNP_CRP.SS_CODE='CR'\r\n\tCommented as part of CCWR ENDS */",
        "User Defined Join": "",
        "Source Filter": "",
