        }
      ],
      "attributes": {
        "Sql Query": "SELECT \r\nRANK () OVER ( ORDER BY DISCOUNT.VALUE_NAME,DISCOUNT.BK_DEAL_ID,DISCOUNT.SK_QUESTION_ID_INT ) + MAX_VAL DEAL_QUESTION_RESPONSE_KEY, \r\nDISCOUNT.VALUE_NAME AS DEAL_QUESTION_RESPONSE_NAME,\r\nBK_DEAL_ID,\r\nSK_QUESTION_ID_INT,\r\nCURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\nUSER EDW_CREATE_USER\r\nFROM \r\n( \r\nSELECT VALUE_NAME,BK_DEAL_ID,SK_QUESTION_ID_INT FROM $$STGDB.ST_CQ_QF_RESPONSE_RNWL DISC\r\nINNER JOIN $$SLSORDVWDB.N_DEAL DEAL \r\nON DEAL.SK_DEAL_OBJECT_ID_INT =DISC.DEAL_OBJECT_ID\r\nAND DEAL.SS_CODE = 'CCWR' --- added as part of CCWR changes\r\nINNER  JOIN $$SLSORDVWDB.N_DEAL_QUESTION QUES \r\nON DISC.QUESTION_ID=QUES.SK_QUESTION_ID_INT\r\nAND QUES.SS_CODE = 'CCWR'\r\nwhere VALUE_NAME IS NOT NULL ) DISCOUNT,\r\n(SELECT COALESCE(MAX (DEAL_QUESTION_RESPONSE_KEY) , 0) MAX_VAL\r\nFROM $$TRANSLATIONDB.SM_DEAL_QUESTION_RESPONSE) SM\r\nWHERE NOT EXISTS ( \r\nSELECT 1 \r\nFROM $$TRANSLATIONDB.SM_DEAL_QUESTION_RESPONSE SM\r\nWHERE SM.DEAL_QUESTION_RESPONSE_NAME = DISCOUNT.VALUE_NAME\r\nand SM.SK_QUESTION_ID_INT=DISCOUNT.SK_QUESTION_ID_INT\r\nAND SM.BK_DEAL_ID=DISCOUNT.BK_DEAL_ID )",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    },
