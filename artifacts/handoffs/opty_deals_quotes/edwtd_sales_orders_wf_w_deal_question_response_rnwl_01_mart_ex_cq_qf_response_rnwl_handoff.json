      ],
      "attributes": {
        "Sql Query": "select \r\nSM.DEAL_QUESTION_RESPONSE_KEY,\r\nCOALESCE(VALUE_NAME,'UNKNOWN') AS DEAL_QUESTION_RESPONSE_NAME,\r\nCOALESCE(DEAL.BK_DEAL_ID,'UNKNOWN') AS DEAL_ID,\r\nCOALESCE(QUES.DEAL_QUESTION_KEY,-999) AS DEAL_QUESTION_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n'I' AS ACTION_CODE,\r\n'I' AS DML_TYPE\r\nFROM \r\n(\r\nSELECT\r\nBATCH_ID,\r\nDEAL_OBJECT_ID,\r\nQUESTION_ID,\r\nVALUE_NAME\r\nfrom\r\n$$STGDB.ST_CQ_QF_RESPONSE_RNWL \r\n/*   COMMENTED AS PART OF CCW DATA FIX AUG REL*/\r\n/*UNION ALL\r\nSELECT\r\nBATCH_ID,\r\nDEAL_OBJECT_ID,\r\nQUESTION_ID,\r\nVALUE_NAME\r\nfrom\r\n$$EXCEPDB.EX_CQ_QF_RESPONSE_RNWL*/\r\n) RES\r\nINNER JOIN $$SLSORDVWDB.N_DEAL DEAL \r\nON DEAL.SK_DEAL_OBJECT_ID_INT=RES.DEAL_OBJECT_ID\r\nAND DEAL.SS_CODE = 'CCWR' -- added to process CCWR DEALS\r\nINNER JOIN\r\n$$TRANSLATIONDB.SM_DEAL_QUESTION_RESPONSE SM\r\nON RES.VALUE_NAME = SM.DEAL_QUESTION_RESPONSE_NAME \r\nand SM.SK_QUESTION_ID_INT=RES.QUESTION_ID\r\nAND SM.BK_DEAL_ID= DEAL.BK_DEAL_ID \r\nINNER JOIN $$SLSORDVWDB.N_DEAL_QUESTION QUES  \r\nON QUES.SK_QUESTION_ID_INT=RES.QUESTION_ID\r\n AND QUES.SS_CODE = 'CCWR'",
        "User Defined Join": "",
