      "attributes": {
        "Sql Query": "select DISTINCT\r\nCASE WHEN (COALESCE(ST.DEAL_OBJECT_ID,-999) = COALESCE(EL.DEAL_OBJECT_ID,-999) \r\nAND ST.ACCOUNT_NAME=EL.ACCOUNT_NAME)\r\nTHEN EL.OBJECT_ID\r\nELSE\r\n(SELECT COALESCE(MAX(OBJECT_ID),0) as MAX_VAL_OBJECT_ID FROM $$ETLVWDB.EL_INT_RAW_DM_CUSTOMER_RNWL_KAFKA ) \r\n+ DENSE_RANK() OVER ( ORDER BY ST.DEAL_OBJECT_ID,ST.ACCOUNT_NAME) END AS OBJECT_ID,\r\nCOALESCE(ST.DEAL_OBJECT_ID,-999) AS DEAL_OBJECT_ID,\r\nST.ACCOUNT_NAME,\r\nST.ADDR,\r\nST.ADDR_LINE_2,\r\nST.CITY,\r\nST.PROVINCE,\r\nST.ZIPCODE,\r\nST.COUNTRY,\r\nST.COUNTY,\r\nST.COUNTRY_CODE,\r\nST.CR_ID,\r\nCURRENT_TIMESTAMP(0) as EDW_UPDATED_DATE,\r\nST.UPDATED_BY_KAFKA,\r\nST.UPDATED_ON_KAFKA,\r\nST.OFFSET_NUMBER,\r\nCAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) as EDW_CREATE_DTM,\r\nUSER as EDW_CREATE_USER,\r\nST.PARTITION_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER\r\nFROM $$ETLVWDB.ST_SI_INT_RAW_DM_CUSTOMER_RNWL_KFK ST\r\nLEFT JOIN $$ETLVWDB.EL_INT_RAW_DM_CUSTOMER_RNWL_KAFKA EL\r\nON COALESCE(ST.DEAL_OBJECT_ID,-999) = COALESCE(EL.DEAL_OBJECT_ID,-999) \r\nAND ST.ACCOUNT_NAME=EL.ACCOUNT_NAME\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY  ST.DEAL_OBJECT_ID,ST.ACCOUNT_NAME ORDER BY ST.EDW_CREATE_DTM DESC,ST.OFFSET_NUMBER DESC)=1\r\nWhere \r\nCAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS \r\nwhere JOB_STREAM_ID='wf_EL_INT_RAW_DM_CUSTMER_RNWL_KAFKA') and \r\nNOT EXISTS\r\n(SELECT 1 FROM\r\n$$ETLVWDB.EL_INT_RAW_DM_CUSTOMER_RNWL_KAFKA EL\r\nWHERE COALESCE(ST.DEAL_OBJECT_ID,-999) = COALESCE(EL.DEAL_OBJECT_ID,-999)\r\nAND ST.ACCOUNT_NAME=EL.ACCOUNT_NAME\r\n)",
