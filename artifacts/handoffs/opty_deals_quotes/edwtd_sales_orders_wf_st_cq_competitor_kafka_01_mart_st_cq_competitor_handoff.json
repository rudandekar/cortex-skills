      "attributes": {
        "Sql Query": "SELECT EL.BATCH_ID, \r\nEL.OBJECT_ID, \r\nEL.DEAL_OBJECT_ID, \r\nEL.COMPETITOR_NAME,\r\nEL.COMP_PROD_NAME,\r\nEL.COMP_TYPE,\r\nEL.COMP_TECH,\r\nEL.COMP_ADD_INFO, \r\nCOALESCE(EL.CREATED_BY,'UNKNOWN') AS CREATED_BY,\r\nEL.CREATED_ON,\r\nCOALESCE(EL.UPDATED_BY,'UNKNOWN') AS UPDATED_BY,\r\nEL.UPDATED_ON,\r\nEL.DM_UPDATE_DATE,\r\nEL.SOURCE, \r\nEL.INITIATED_SOURCE, \r\nEL.COMP_PROD_EU_PRICE, \r\nCOALESCE(EL.CREATE_DATETIME, CURRENT_TIMESTAMP(0)) as CREATE_DATETIME,\r\nCOALESCE(EL.ACTION_CODE,'I') as ACTION_CODE\r\nFROM\r\n$$ETLVWDB.EL_CQ_COMPETITOR_KAFKA EL\r\nWhere EL.EDW_CREATE_DTM >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS where JOB_STREAM_ID='wf_ST_CQ_COMPETITOR_KAFKA')\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY EL.DEAL_OBJECT_ID ,EL.COMPETITOR_NAME\r\n ORDER BY EL.EDW_CREATE_DTM DESC,EL.MESSAGE_SEQUENCE_NUMBER DESC)=1     \t/* ADDED AS PART OF CCW DATA FIX AUG REL Added New Attribute EDW_CREATE_DTM  In The ORDER BY Clause*/",
