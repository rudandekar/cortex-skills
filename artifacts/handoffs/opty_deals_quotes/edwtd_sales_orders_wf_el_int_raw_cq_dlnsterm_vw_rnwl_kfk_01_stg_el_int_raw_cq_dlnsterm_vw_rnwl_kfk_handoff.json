      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\nCAST(OBJECT_ID AS NUMBER)  as OBJECT_ID,                    \r\nNSTERM_ID as NSTERM_ID,                     \r\nNSTERM_NAME as NSTERM_NAME,                   \r\nDEAL_OBJECT_ID as DEAL_OBJECT_ID,                \r\nCAST(LEFT(OREPLACE(CREATED_ON,'T',' '), 19) as TIMESTAMP(0)) as CREATED_DATE,                  \r\nCREATED_BY as CREATED_BY,                    \r\nCAST(LEFT(OREPLACE(UPDATED_ON,'T',' '), 19) as TIMESTAMP(0)) as UPDATED_DATE,                  \r\nUPDATED_BY as UPDATED_BY,                    \r\nAS_SUBSCRIPTION as AS_SUBSCRIPTION,               \r\nAS_TRANSACTION as AS_TRANSACTION,                \r\nAS_FIXED as AS_FIXED,                      \r\nTSS_CORE as TSS_CORE,                      \r\nROS as ROS,                           \r\nUPDATED_BY_KAFKA as UPDATED_BY_KAFKA,              \r\ncast(left (UPDATED_ON_KAFKA,19) as timestamp(0)) as UPDATED_ON_KAFKA,\r\nOFFSET_NUMBER as OFFSET_NUMBER,\r\nCAST(CAST(EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) as EDW_CREATE_DTM,\r\nUSER as EDW_CREATE_USER,\r\nPARTITION_NUMBER as\tPARTITION_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER\r\nFROM\r\n$$ETLVWDB.ST_SI_INT_RAW_CQ_DLNSTR_VW_RNWL_KFK ST\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY DEAL_OBJECT_ID, NSTERM_ID ORDER BY EDW_CREATE_DTM DESC, OFFSET_NUMBER DESC)=1\r\nWHERE\r\nCAST(CAST(EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS\r\nwhere JOB_STREAM_ID='wf_EL_INT_RAW_CQ_DLNSTERM_VW_RNWL_KFK') and\r\nNOT EXISTS\r\n(SELECT 1 FROM\r\n$$ETLVWDB.EL_INT_RAW_CQ_DLNSTERM_VW_RNWL_KFK EL\r\nWHERE CAST(ST.DEAL_OBJECT_ID AS NUMBER)= EL.DEAL_OBJECT_ID \r\nAND\r\nST.NSTERM_ID = EL.NSTERM_ID\r\n)",
