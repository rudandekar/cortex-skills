      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\n1 AS BATCH_ID, \r\nPARENT_ID AS DEAL_OBJECT_ID, \r\nAPPROVAL_ROUTE, \r\nAPPROVAL_ROUTE_NAME, \r\nPRODUCT_COMP, \r\nTSS_CORE_COMP, \r\nAS_TRANSACTION_COMP, \r\nAS_SUBSCRIPTION_COMP, \r\nAS_FIXED_COMP, \r\nROS_COMP, \r\nPRODUCT_COMPONENT, \r\nSERVICE_COMPONENT, \r\nCOALESCE(CSTIV.CREATED_BY, SD.CREATED_BY) as CREATED_BY, \r\nCAST(CAST((Case When LEFT(OREPLACE(CSTIV.CREATED_ON,'T',' '), 19) IS NULL THEN SD.CREATED_ON ELSE LEFT(OREPLACE(CSTIV.CREATED_ON,'T',' '), 19) END) as DATE FORMAT  'DD-MMM-YYYY') as TIMESTAMP(0)) as CREATED_ON,\r\n--CAST(LEFT(OREPLACE(CSTIV.CREATED_ON,'T',' '), 19) as TIMESTAMP(0)) as CREATED_ON,\r\nCOALESCE(CSTIV.UPDATED_BY,SD.UPDATED_BY)\tas UPDATED_BY, \r\n--CAST(CAST((Case When CSTIV.UPDATED_ON IS NULL THEN SD.UPDATED_ON ELSE CSTIV.UPDATED_ON END) as DATE FORMAT  'DD-MMM-YYYY') as TIMESTAMP(0)) as UPDATED_ON, \r\nCAST(CAST (SD.UPDATED_ON as DATE FORMAT  'DD-MMM-YYYY') as TIMESTAMP(0)) as UPDATED_ON,\r\nGET_WELL_PLAN_DESCR, \r\nCAST(LEFT(OREPLACE(DSA_REGSTR_DATE,'T',' '), 19) as TIMESTAMP(0)) as DSA_REGSTR_DATE, \r\nCAST(LEFT(OREPLACE(DD_ENGAGE_DATE,'T',' '), 19) as TIMESTAMP(0)) as DD_ENGAGE_DATE, \r\nNS_SUMMARY_DESCR, \r\nTD_SYSFNLIB.OTRANSLATE(EXE_SUMMARY_INTERNAL_DESCR, '~','') AS EXE_SUMMARY_INTERNAL_DESCR, /*Added as part of CCW Data fix Aug rel*/\r\nIS_SA_DEAL, \r\nCSTIV.CREATE_DATETIME, \r\nACTION_CODE, \r\nCSTIV.UPDATED_BY_KAFKA, \r\ncast(left (CSTIV.UPDATED_ON_KAFKA,19) as timestamp(0)) as UPDATED_ON_KAFKA, \r\nCSTIV.OFFSET_NUMBER, \r\nCURRENT_TIMESTAMP(0) as EDW_CREATE_DTM,\r\nUSER as EDW_CREATE_USER ,\r\nCSTIV.PARTITION_NUMBER, \r\nCSTIV.MESSAGE_SEQUENCE_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER \r\nFROM\r\n$$STGDB.ST_INT_RAW_CQ_NS_DL_EXTN_VW_F CSTIV\r\nINNER JOIN $$STGDB.ST_INT_CQ_DEAL_KAFKA_FF SD ON CSTIV.PARENT_ID = SD.OBJECT_ID \r\n WHERE\r\nNOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.EL_INT_RW_CQ_NS_DL_ETN_VW_KFKA EL\r\nWHERE CSTIV.PARENT_ID = EL.DEAL_OBJECT_ID \r\nAND \r\nCSTIV.MESSAGE_SEQUENCE_NUMBER= EL.MESSAGE_SEQUENCE_NUMBER)",
        "User Defined Join": "",
        "Source Filter": "",
