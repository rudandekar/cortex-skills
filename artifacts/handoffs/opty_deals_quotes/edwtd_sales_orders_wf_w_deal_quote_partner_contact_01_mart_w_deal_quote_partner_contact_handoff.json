      "attributes": {
        "Sql Query": "SELECT\r\nNDQ.BK_QUOTE_NUM AS BK_QUOTE_NUM,\r\nSM.DEAL_QUOTE_PARTNER_CONTACT_KEY AS DEAL_QUOTE_PARTNER_CONTACT_KEY,\r\nCOALESCE(CONTACT_CCO_ID,'UNKNOWN') AS QUOTE_PARTNER_CONTACT_CCO_ID,\r\nPDR.CONTACT_FIRST_NAME AS QUOTE_PRTNR_CONTACT_FIRST_NAME,\r\nNDQP.PARTNER_SITE_PARTY_KEY AS PARTNER_SITE_PARTY_KEY,\r\nPDR.CONTACT_LAST_NAME AS QUOTE_PRTNR_CONTACT_LAST_NAME,\r\nCOALESCE(PDR.CONTACT_EMAIL_ID,'UNKNOWN') AS BK_QUOTE_PARTNER_EMAIL_ID,\r\nPDR.OTHER_JOB_TITLE AS QT_PTNR_CNTCT_JOB_TITLE_NAME,\r\nCOALESCE(PDR.CONTACT_TYPE_NAME,'UNKNOWN') AS QUOTE_PTNR_CNTCT_TYPE_CD,\r\nCOALESCE(PDR.PRIMARY_FLAG,'N') AS PRIMARY_FLG,\r\nPDR.OBJECT_ID AS SK_OBJECT_ID_INT,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCOALESCE(PDR.CONTACT_PHONE_NUMBER,'UNKNOWN') AS QUOTE_PTNR_CNTCT_PHONE_NUM,\r\nCOALESCE(PDR.CREATED_ON,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))) AS SRC_CREATED_DTM,\r\nCOALESCE(PDR.CREATED_ON,CAST('3500-01-01' AS DATE)) AS DV_SRC_CREATED_DT,\r\nCOALESCE(PDR.UPDATED_ON,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))) AS SRC_LAST_UPDATED_DTM,\r\nCOALESCE(PDR.UPDATED_ON,CAST('3500-01-01' AS DATE)) AS DV_SRC_LAST_UPDATED_DT,\r\nCOALESCE(PDR.CONTACT_URL,'UNKNOWN') AS QUOTE_PTNR_WEBSITE_URL_ADDR,\r\n'CCW' AS SS_CODE,\r\n'I' AS ACTION_CODE,\r\n'=' AS DML_TYPE\r\nFROM (SELECT * FROM $$STGDB.ST_INT_RAW_PDR_DEAL_CONTACT\r\nWHERE CONTACT_TYPE IN (1,4) AND PRIMARY_FLAG='Y'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY QUOTE_OBJECT_ID ORDER BY OBJECT_ID DESC)=1) PDR\r\nINNER JOIN $$SLSORDVWDB.N_DEAL_QUOTE NDQ\r\nON NDQ.SK_QUOTE_OBJECT_ID_INT = PDR.QUOTE_OBJECT_ID\r\nAND NDQ.SS_CODE = 'CCW'\r\nINNER JOIN (SELECT BK_QUOTE_NUM,PARTNER_SITE_PARTY_KEY FROM $$SLSORDVWDB.N_DEAL_QUOTE_PARTNER \r\nWHERE SS_CODE = 'CCW'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY BK_QUOTE_NUM ORDER BY PARTNER_SITE_PARTY_KEY DESC,EDW_UPDATE_DTM DESC)=1\r\n) NDQP\r\nON NDQP.BK_QUOTE_NUM = NDQ.BK_QUOTE_NUM\r\nINNER JOIN $$ETLVWDB.SM_DEAL_QUOTE_PARTNER_CONTACT SM\r\nON SM.SK_OBJECT_ID_INT = PDR.OBJECT_ID\r\nAND SM.SS_CODE = 'CCW'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY DEAL_QUOTE_PARTNER_CONTACT_KEY ORDER BY PDR.OBJECT_ID DESC)=1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
