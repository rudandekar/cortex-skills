      "attributes": {
        "Sql Query": "SELECT \r\nIDM.OPTY_ID, \r\nIDM.DEAL_TYPE, \r\nIDM.SHARE_NODE_ID, \r\nCOALESCE(IDM.CREATED_BY,'CCW') as  CREATED_BY, \r\nCOALESCE(IDM.CREATED_ON, CAST(CURRENT_TIMESTAMP(0)AS TIMESTAMP(0))) as CREATED_ON, /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\nCOALESCE(IDM.UPDATED_BY,'CCW') as  UPDATED_BY, \r\nCOALESCE(IDM.UPDATED_ON,  CAST(CURRENT_TIMESTAMP(0)AS TIMESTAMP(0))) as UPDATED_ON, /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\nIDM.THEATER, \r\nIDM.AREA, \r\nIDM.REGION, \r\nIDM.THEATER_NODE_ID, \r\nIDM.AREA_NODE_ID, \r\nIDM.REGION_NODE_ID, \r\nIDM.OPTY_NUMBER, \r\nIDM.LEVEL6_NODE, \r\nIDM.MARKET_SEGMENT, \r\nIDM.EDW_UPDATED_DATE \r\nFROM\r\n$$ETLVWDB.EL_INT_DEAL_MASTER_KAFKA IDM\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY IDM.OPTY_NUMBER ORDER BY IDM.EDW_CREATE_DTM DESC,IDM.MESSAGE_SEQUENCE_NUMBER DESC)=1 --Added Create dtm\r\nWhere IDM.EDW_CREATE_DTM >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS where JOB_STREAM_ID='wf_ST_INT_DEAL_MASTER_KAFKA')",
