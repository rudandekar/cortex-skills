      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\nCOALESCE(TO_CHAR(ST.DEAL_OBJECT_ID),'UNKNOWN') AS OPTY_ID,\r\nST.DEAL_TYPE,\r\nST.SHARE_NODE_ID as SHARE_NODE_ID,\r\nST.THEATER as THEATER,\r\nST.AREA as AREA,\r\nST.REGION as REGION,\r\nST.THEATER_NODE_ID as THEATER_NODE_ID,\r\nST.AREA_NODE_ID as AREA_NODE_ID,\r\nST.REGION_NODE_ID as REGION_NODE_ID,\r\nST.OPTY_NUMBER as OPTY_NUMBER,\r\nST.LEVEL6_NODE as LEVEL6_NODE,\r\nCURRENT_TIMESTAMP(0) as EDW_UPDATED_DATE,\r\nST.UPDATED_BY_KAFKA as UPDATED_BY_KAFKA,\r\ncast(left (ST.UPDATED_ON_KAFKA,19) as timestamp(0)) as UPDATED_ON_KAFKA,\r\nST.OFFSET_NUMBER as OFFSET_NUMBER,\r\nCAST(CAST(EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) as EDW_CREATE_DTM,\r\nUSER as EDW_CREATE_USER,\r\nST.PARTITION_NUMBER as PARTITION_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nST.MARKET_SEGMENT\r\nFROM\r\n$$ETLVWDB.ST_SI_INT_DEAL_MASTER_RNWL_KAFKA ST \r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY ST.OPTY_NUMBER ORDER BY ST.EDW_CREATE_DTM DESC,ST.OFFSET_NUMBER DESC)=1\r\nWHERE\r\nCAST(CAST(EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS \r\nwhere JOB_STREAM_ID='wf_EL_INT_DEAL_MASTER_RNWL_KAFKA') and \r\nNOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.EL_INT_DEAL_MASTER_RNWL_KAFKA EL\r\nWHERE ST.OPTY_NUMBER = EL.OPTY_NUMBER \r\n)",
        "User Defined Join": "",
