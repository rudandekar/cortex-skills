      "attributes": {
        "Sql Query": "SELECT\tDISTINCT \r\n\t\t\tST.DEAL_OBJECT_ID,\r\n\t\t\tCASE WHEN (ST.DEAL_OBJECT_ID = EL.DEAL_OBJECT_ID \r\n\t\t\tAND ST.BILL_TO_ID=EL.BILL_TO_ID)\r\n\t\t\tTHEN EL.OBJECT_ID\r\n\t\t\tELSE\r\n\t\t\t(SELECT COALESCE(MAX(OBJECT_ID),0) as MAX_VAL_OBJECT_ID FROM $$ETLVWDB.EL_INT_RAW_CQ_DL_PRTY_VW_RNWL_KFKA ) \r\n\t\t\t+ DENSE_RANK() OVER ( ORDER BY ST.DEAL_OBJECT_ID,ST.BILL_TO_ID) END AS OBJECT_ID,\r\n            ST.BILL_TO_BEGEO_ID,\r\n\t\t    ST.BILL_TO_ID,\r\n\t\t\tST.UPDATED_BY_KAFKA,\r\n\t\t\tCAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,'T',''), 19) as TIMESTAMP(0)) AS UPDATED_ON_KAFKA,\r\n\t\t\tST.OFFSET_NUMBER,\r\n\t\t\tST.PARTITION_NUMBER,\r\n\t\t\tCAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) as EDW_CREATE_DTM,\r\n\t\t\tUSER as EDW_CREATE_USER,\r\n\t\t\tCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n\t\t\tUSER AS EDW_UPDATE_USER \r\n\tFROM\t$$ETLVWDB.ST_SI_INT_RAW_CQ_DL_PRTY_VW_RNWL_KFK ST \r\n\tLEFT JOIN $$ETLVWDB.EL_INT_RAW_CQ_DL_PRTY_VW_RNWL_KFKA EL\r\n\tON ST.DEAL_OBJECT_ID = EL.DEAL_OBJECT_ID\r\n\tAND ST.BILL_TO_ID=EL.BILL_TO_ID\r\n\tQUALIFY ROW_NUMBER() OVER(PARTITION BY ST.DEAL_OBJECT_ID, ST.BILL_TO_ID ORDER BY ST.EDW_CREATE_DTM DESC, ST.OFFSET_NUMBER DESC)=1\r\n\twhere\r\n\tCAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS\r\n\twhere JOB_STREAM_ID='wf_EL_INT_RAW_CQ_DL_PRTY_VW_RNWL_KFKA') and\r\n \tNOT EXISTS (SELECT\t1 FROM\t$$ETLVWDB.EL_INT_RAW_CQ_DL_PRTY_VW_RNWL_KFKA EL \r\n\t\tWHERE\tST.DEAL_OBJECT_ID = EL.DEAL_OBJECT_ID  \r\n\t\tAND ST.BILL_TO_ID=EL.BILL_TO_ID)",
