      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\n(SELECT COALESCE(MAX(OBJECT_ID),0) FROM $$ETLVWDB.EL_INT_RAW_DEAL_DISTI_FULF_RNWL_KFK ) + DENSE_RANK() OVER ( ORDER BY ST.PARENT_ID,ST.SOURCE_PROFILE_ID  ) AS OBJECT_ID,\r\nSQ.DEAL_OBJECT_ID AS DEAL_OBJECT_ID,\t \r\nCOALESCE(ST.PARENT_ID, -999) AS QUOTE_OBJECT_ID,\r\nSOURCE_PROFILE_ID,\r\nST.UPDATED_BY_KAFKA,\r\nCAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,'T',' '), 19) AS TIMESTAMP(0)) AS UPDATED_ON_KAFKA,\r\nST.OFFSET_NUMBER,\r\nST.PARTITION_NUMBER, \r\nCAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nUSER AS EDW_UPDATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nST.REF_ENTITY_NUMBER,\r\nST.QUOTE_STATUS_ID\r\nFROM\r\n $$ETLVWDB.ST_SI_INT_RAW_DL_DISTI_FULF_RNWL_KFK ST\r\n /*Replacing ST with EL Logic*/\r\n INNER JOIN ( SELECT CAST(QUOTE_ID AS BIGINT) AS OBJECT_ID,DEAL_OBJECT_ID \r\n FROM $$ETLVWDB.EL_INT_CQ_SNGL_QUOTE_VW_RNWL_KFKA EL \r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY  EL.QUOTE_ID\r\nORDER BY EL.EDW_CREATE_DTM DESC)=1)  SQ ON COALESCE(ST.PARENT_ID, -999) = COALESCE(SQ.OBJECT_ID, -999)\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY ST.PARENT_ID , ST.SOURCE_PROFILE_ID ORDER BY ST.EDW_CREATE_DTM DESC , ST.OFFSET_NUMBER DESC)=1\r\nWHERE NOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.EL_INT_RAW_DEAL_DISTI_FULF_RNWL_KFK  EL\r\nWHERE \r\nEL.QUOTE_OBJECT_ID = ST.PARENT_ID \r\nAND ST.SOURCE_PROFILE_ID = EL.SOURCE_PROFILE_ID)\r\nAND CAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS\r\nwhere JOB_STREAM_ID=('wf_EL_INT_RAW_DEAL_DISTI_FULF_RNWL_KFK') )\r\nAND ST.DEAL_REQUESTED_BY IS NOT NULL\r\nAND ST.PARENT_ID IS NOT NULL",
        "User Defined Join": "",
