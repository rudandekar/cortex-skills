      ],
      "attributes": {
        "Sql Query": "SELECT \r\nDEAL.BK_DEAL_ID AS BK_DEAL_ID,\r\nCOALESCE(NCISCO.DD_PRIMARY_NAME,'UNKNOWN') AS BK_SRC_REPORTED_CONTACT_NAME,\r\n'UNKNOWN' as SRC_RPTD_CONTACT_TYPE_CD,\r\n'UNKNOWN' as SRC_RPTD_CONTACT_SUBTYPE_CD,\r\nCOALESCE(NCISCO.CISCO_WORKER_PARTY_KEY,-999) AS CONTACT_CISCO_WORKER_PARTY_KEY,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nCONT.ACTION_CODE,\r\n'I' DML_TYPE\r\nFROM \r\n(\r\nSELECT \r\nDEAL_OBJECT_ID,\r\nOBJECT_ID     ,                \r\nCONTACT_ID     ,               \r\nCONTACT_NAME    ,              \r\nCONTACT_TYPE   ,\r\nACTION_CODE\r\n  FROM $$STGDB.ST_CQ_DEAL_CONTACT_RNWL\r\n/*  COMMENTED AS PART OF CCWR DATA FIX AUG REL*/\r\n/*  UNION ALL \r\n  SELECT\r\nDEAL_OBJECT_ID, \r\nOBJECT_ID     ,                \r\nCONTACT_ID     ,               \r\nCONTACT_NAME    ,              \r\nCONTACT_TYPE   ,\r\nACTION_CODE\r\nFROM $$EXCEPDB.EX_CQ_DEAL_CONTACT_RNWL*/) CONT\r\nINNER JOIN $$SLSORDVWDB.N_DEAL DEAL \r\nON CONT.DEAL_OBJECT_ID=DEAL.SK_DEAL_OBJECT_ID_INT\r\nAND DEAL.SS_CODE='CCWR' -- added to process CCWR DEALS\r\nLEFT  JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY  NCISCO\r\nON NCISCO.CEC_ID=CONT.CONTACT_ID\r\nQUALIFY ROW_NUMBER () OVER (PARTITION BY BK_DEAL_ID,CONTACT_ID ORDER BY BK_DEAL_ID DESC)=1 /*Replaced contact_name with contact_id as part of ccw data fix aug rel*/",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
