      "attributes": {
        "Sql Query": "SELECT \r\nBATCH_ID                      ,\r\nDEAL_OBJECT_ID                ,\r\nOBJECT_ID                     ,\r\nCONTACT_ID                    ,\r\nCONTACT_NAME                  ,\r\nCONTACT_TYPE                  ,\r\nCREATED_ON                    ,\r\nCREATED_BY                    ,\r\nUPDATED_ON                    ,\r\nUPDATED_BY                    ,\r\nCONTACT_ROW                   ,\r\nDM_UPDATE_DATE                ,\r\nCONTACT_POSTN_ID              ,\r\nSIEBEL_POSTN_ID               ,\r\nCREATE_DATETIME               ,\r\nACTION_CODE                   ,\r\n'RI' AS EXCEPTION_TYPE            \r\nFROM $$STGDB.ST_CQ_DEAL_CONTACT_RNWL CONT\r\nWHERE NOT EXISTS ( SELECT 1 FROM $$SLSORDVWDB.N_DEAL  DEALS\r\nwhere   CONT.DEAL_OBJECT_ID=DEALS.SK_DEAL_OBJECT_ID_INT\r\nAND DEALS.SS_CODE='CCWR')",
        "User Defined Join": "",
