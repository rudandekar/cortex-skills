      "attributes": {
        "Sql Query": "SELECT /*+ PARALLEL(G,4) */\r\n G.HEADER_REQUEST_ID,\r\nG.HEADER_GUIDANCE_ID,\r\nG.LINE_REQUEST_ID,\r\nG.LINE_GUIDANCE_ID,\r\n G.DEAL_OBJECT_ID, \r\n G.QUOTE_OBJECT_ID, \r\n G.GUIDANCE_LEVEL, \r\n G.PRIMARY_PRODUCT_FAMILY, \r\n G.ORIGINAL_PRODUCT_FAMILY, \r\n G.LINE_OBJECT_ID, \r\n G.LINE_TYPE_ID, \r\n REPLACE(G.PART_NUMBER, CHR(10),' ')  PART_NUMBER,\r\n G.REQUESTED_DISCOUNT, \r\n G.GUIDANCE_DISCOUNT, \r\n G.DISCOUNT_DISCRETION, \r\n G.IS_FINAL, \r\n G.IN_SALES_DASHBOARD, \r\n G.UPDATED_BY, \r\n G.UPDATED_ON ,\r\n/****Below 7 columns Added as part of EDS EPS HANA DATA Foundation project****/\r\nG.STATUS,\r\nG.APPROVER_ROLE,\r\nG.BAND,\r\nG.BOOKINGS_UPSIDE,\r\nG.RECOMMENDATION,\r\nG.BOOKINGS_UPSIDE_PCT,\r\nG.BAROMETER_NEEDLE\r\nFROM\r\n XXCPD_APPS.XXSDG_QUOTE_LINE_GUIDANCE_V G\r\n  WHERE  G.UPDATED_ON > TO_DATE('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS')",
