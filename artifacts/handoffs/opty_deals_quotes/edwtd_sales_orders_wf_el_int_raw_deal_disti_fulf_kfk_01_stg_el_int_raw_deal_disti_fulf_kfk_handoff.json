      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\nST.OBJECT_ID  as OBJECT_ID,\r\n/*SQ.DEAL_OBJECT_ID AS DEAL_OBJECT_ID,*/       /*COMMENTED AS PART OF CCW DATA FIX AUG REL*/\r\nST.DEAL_OBJECT_ID AS DEAL_OBJECT_ID,           /* ADDED AS PART OF CCW DATA FIX AUG REL DEAL_OBJECT_ID IS TAKEN FROM EXISTIG DISTI_FULF_KFK_F ST*/\r\nAUTHORIZATION_NUMBER AS AUTHORIZATION_NUMBER,\r\nDEVIATION_ID,\r\nDEVIATION_STATUS AS DEVIATION_STATUS,\r\nDEV_PROCESS_DESCRIPTION,\r\nDEV_PROCESS_REMARK,\r\nDEVIATION_STATUS AS DEV_PROCESS_STATUS,\r\nDEV_RETRY_COUNT AS DEV_RETRY_COUNT,\r\nCAST(LEFT(OREPLACE(END_DATE,'T',' '), 19) as TIMESTAMP(0)) AS END_DATE,\r\nCAST(LEFT(OREPLACE(LAST_UPDATE_DATE,'T',' '), 19) as TIMESTAMP(0)) AS LAST_UPDATE_DATE,\r\nLINKED_DEVIATION_ID AS LINKED_DEVIATION_ID,\r\nNEXT_ACTION,\r\nQUEUE_OBJECT_ID,\r\nPARENT_ID AS QUOTE_OBJECT_ID,\r\nREVISION_NUMBER,\r\nSOURCE_PROFILE_ID,\r\nCAST(LEFT(OREPLACE(START_DATE,'T',' '), 19) as TIMESTAMP(0)) AS START_DATE,\r\nST.UPDATED_BY_KAFKA,\r\nCAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,'T',' '), 19) as TIMESTAMP(0)) AS UPDATED_ON_KAFKA,\r\nST.OFFSET_NUMBER,\r\nST.PARTITION_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nST.MESSAGE_SEQUENCE_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER\r\nFROM\r\n $$STGDB.ST_INT_RAW_DL_DISTI_FULF_KFK_F ST\r\n /*Replacing ST with EL Logic*/\r\n/*COMMENTED AS PART OF CCW DATA FIX AUG REL*/\r\n /*INNER JOIN ( SELECT CAST(QUOTE_ID AS BIGINT) AS OBJECT_ID,DEAL_OBJECT_ID \r\n FROM $$ETLVWDB.EL_INT_CQ_SNGL_QUOTE_VW_KFKA EL \r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY EL.DEAL_OBJECT_ID\r\nORDER BY EL.MESSAGE_SEQUENCE_NUMBER DESC)=1)  SQ ON ST.PARENT_ID = SQ.OBJECT_ID*/\r\nWHERE NOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.EL_INT_RAW_DEAL_DISTI_FULF_KFK  EL\r\nWHERE \r\n/*EL.QUOTE_OBJECT_ID = ST.PARENT_ID */      /*COMMENTED AS PART OF CCW DATA FIX AUG REL*/\r\nST.OBJECT_ID = EL.OBJECT_ID \t\t    /* ADDED AS PART OF CCW DATA FIX AUG REL ADDED OBJECT_ID CONDITION */ \r\nAND ST.MESSAGE_SEQUENCE_NUMBER = EL.MESSAGE_SEQUENCE_NUMBER)",
        "User Defined Join": "",
