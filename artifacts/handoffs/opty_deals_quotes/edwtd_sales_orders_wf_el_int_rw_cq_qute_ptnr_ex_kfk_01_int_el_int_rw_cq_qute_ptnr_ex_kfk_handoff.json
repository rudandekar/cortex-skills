      "attributes": {
        "Sql Query": "select DISTINCT\r\n ST.OBJECT_ID,\r\n ST.PARENT_ID AS QUOTE_OBJECT_ID,\r\n ST.PARTNER_BE_GEO_ID,\r\n ST.PARTNER_SITE_ID,\r\n ST.COUNTRY_CD,\r\n PARTNER_CONTACT_PAE_USER_ID,\r\n CAST(LEFT(OREPLACE(ST.DM_UPDATE_DATE,'T',' '), 19) as TIMESTAMP(0))  as DM_UPDATE_DATE,\r\n/*STQ.CREATED_BY\tas\tCREATED_BY ,*/                                            /*COMMENTED AS PART OF CCW DATA FIX AUG REL*/ \r\nCOALESCE(ST.CREATED_BY,'CCW') AS CREATED_BY,                                                            /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\n/*CAST(LEFT(OREPLACE(STQ.CREATED_ON,'T',' '), 19) as TIMESTAMP(0)) as CREATED_ON,*/       /*COMMENTED AS PART OF CCW DATA FIX AUG REL*/\r\nCOALESCE(CAST(ST.CREATED_ON AS TIMESTAMP(0) FORMAT 'DD-MMM-YYYY'), CAST('1900-01-01 00:00:00' AS TIMESTAMP(0))) AS CREATED_ON,  /*ADDED AS PART OF CCW DATA FIX AUG REL */\r\n/*STQ.UPDATED_BY as UPDATED_BY,*/ \t\t\t\t\t\t\t  /*COMMENTED AS PART OF CCW DATA FIX AUG REL*/\t\t\t\r\n'CCW' AS UPDATED_BY,\t\t\t\t\t\t\t\t\t  /* ADDED AS PART OF CCW DATA FIX AUG REL */\t\r\n/*CAST(LEFT(OREPLACE(STQ.UPDATED_ON,'T',' '), 19) as TIMESTAMP(0))  as UPDATED_ON,*/       /*COMMENTED AS PART OF CCW DATA FIX AUG REL*/\t\r\nCOALESCE(CAST(ST.UPDATED_ON AS TIMESTAMP(0) FORMAT 'DD-MMM-YYYY'),CAST('1900-01-01 00:00:00' AS TIMESTAMP(0))) AS UPDATED_ON,  /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\nCURRENT_TIMESTAMP(0) as EDW_UPDATED_DATE,\r\n '' AS CRP_PARTNER_CONV_FLAG,\r\nCAST( LEFT(OREPLACE(ST.DEAL_SUBMITTED_DATE,'T',' '), 19) as TIMESTAMP(0)) as DEAL_SUBMITTED_DATE,\r\nST.PDB_SITE_ID,\r\n'' AS CRP_PARTNER_SITE_ID,\r\nST. UPDATED_BY_KAFKA,\r\n CAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,'T',''), 19) as TIMESTAMP(0)) AS  UPDATED_ON_KAFKA,\r\n ST.OFFSET_NUMBER,\r\n CURRENT_TIMESTAMP(0) as EDW_CREATE_DTM,\r\n USER as EDW_CREATE_USER,\r\n ST.PARTITION_NUMBER,\r\nST.MESSAGE_SEQUENCE_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER\r\n FROM $$STGDB.ST_INT_RW_CQ_QUTE_PTR_EX_KFK_F ST \r\n/* INNER JOIN $$STGDB.ST_INT_CQ_SNGL_QUTE_VW_KFKA_FF STQ ON  ST.PARENT_ID = CAST(STQ.QUOTE_ID as DEC(18,0))*/            /*COMMENTED AS PART OF CCW DATA FIX AUG REL */\r\nWhere NOT EXISTS\r\n(SELECT 1 FROM\r\n$$ETLVWDB.EL_INT_RW_CQ_QUTE_PTNR_EX_KFK EL\r\nWHERE ST.OBJECT_ID = EL.OBJECT_ID \r\nAND ST.MESSAGE_SEQUENCE_NUMBER = EL.MESSAGE_SEQUENCE_NUMBER\r\n)",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
