      "attributes": {
        "Sql Query": "SELECT \r\n1 as BATCH_ID,\r\nCQ_DEAL_SUBMIT_H.DEAL_OBJECT_ID as DEAL_OBJECT_ID,\r\nCQ_DEAL_SUBMIT_H.OPTY_NUMBER as OPTY_NUMBER,\r\nCQ_DEAL_SUBMIT_H.SUBMIT_DATE as SUBMIT_DATE,\r\nCQ_DEAL_SUBMIT_H.SUBMIT_NUMBER as SUBMIT_NUMBER,\r\nCQ_DEAL_SUBMIT_H.SUBMIT_BY as SUBMIT_BY,\r\nCQ_DEAL_SUBMIT_H.APPR_ROUTE_HISTORY as APPR_ROUTE_HISTORY,\r\nCQ_DEAL_SUBMIT_H.REASON_FOR_APPROVAL as REASON_FOR_APPROVAL,\r\nCQ_DEAL_SUBMIT_H.PRODUCT_FAMILY as PRODUCT_FAMILY,\r\nCQ_DEAL_SUBMIT_H.SOTD_REASON as SOTD_REASON,\r\nCQ_DEAL_SUBMIT_H.COMMENTS as COMMENTS,\r\nCQ_DEAL_SUBMIT_H.PRICING_BAND as PRICING_BAND,\r\nCQ_DEAL_SUBMIT_H.FINAL_BAND as FINAL_BAND,\r\nCQ_DEAL_SUBMIT_H.DEAL_APPROVAL as DEAL_APPROVAL,\r\nCURRENT_TIMESTAMP(0) AS CREATE_DATETIME,\r\n'I' AS ACTION_CODE,\r\nCASE WHEN CQ_DEAL_SUBMIT_H.SS_CODE = 'CCWQUOTING' THEN 'CCW' WHEN CQ_DEAL_SUBMIT_H.SS_CODE ='CCWR' THEN 'CCWR' ELSE CQ_DEAL_SUBMIT_H.SS_CODE END AS SS_CODE\r\nFROM    \r\n$$ETLVWDB.ST_SI_CQ_DEAL_SUBMIT_H CQ_DEAL_SUBMIT_H\r\nWHERE CQ_DEAL_SUBMIT_H.EDW_CREATE_DTM >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS where JOB_STREAM_ID='wf_ST_CQ_DEAL_SUBMIT_H')\r\nQUALIFY ROW_NUMBER() over(partition by OPTY_NUMBER, DEAL_OBJECT_ID , SUBMIT_DATE order by OFFSET_NUMBER desc, EDW_CREATE_DTM desc ) = 1",
        "User Defined Join": "",
        "Source Filter": "",
