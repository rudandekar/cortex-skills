      "attributes": {
        "Sql Query": "SELECT\r\n(SELECT COALESCE(MAX(OBJECT_ID),0) as MAX_VAL_OBJECT_ID FROM \r\n$$ETLVWDB.EL_INT_RW_CQ_QUTE_LN_CNCS_KFKA_RNWL  ) + DENSE_RANK() OVER ( ORDER BY ST.QUOTE_ID, ST.QUOTE_LINE_OBJECT_ID,ST.CONCESSION_ID) AS OBJECT_ID,\r\nAPPR_NS_DISCOUNT_PCTG   AS\tAPPR_NS_DISCOUNT_PCTG  ,\r\nDISC_PERCENTAGE  AS\tDISC_PERCENTAGE  ,\r\nDISC_AMOUNT      AS\tDISC_AMOUNT      ,\r\nDISC_METHOD      AS\tDISC_METHOD      ,\r\nPROMOTION_CODE   AS\tPROMOTION_CODE   ,\r\nPROMOTION_NAME   AS\tPROMOTION_NAME   ,\r\nOPERAND_PER_QUANTITY    AS\tOPERAND_PER_QUANTITY   ,\r\nDISC_NAME,\r\nADJUSTED_AMOUNT  AS\tADJUSTED_AMOUNT,\r\nCAST(LEFT(OREPLACE(CREATION_DT,'T',' '), 19) AS TIMESTAMP(0)) AS\tCREATION_DT,\r\nQUOTE_LINE_OBJECT_ID,\t\r\n CAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\n\tST.UPDATED_BY_KAFKA AS UPDATED_BY_KAFKA,\r\n\tCASt(LEFT (ST.UPDATED_ON_KAFKA,19) AS timestamp(0)) AS UPDATED_ON_KAFKA,\r\n\t\tST.OFFSET_NUMBER AS OFFSET_NUMBER,\r\n\t\t\tST.PARTITION_NUMBER AS\tPARTITION_NUMBER,\r\n\t\t\tST.INSTANCE_ID AS INSTANCE_ID,\r\n\t\t\tST.CONCESSION_ID AS CONCESSION_ID, \r\n\t\t\tST.DISCOUNT_GROUP AS DISCOUNT_GROUP,\r\n\t\t\tST.QUOTE_ID,\r\n\t\t\tST.EXT_DISCOUNT_AMOUNT,\r\n\t\t\tST.UNROUNDED_EXT_AMOUNT\r\nFROM\r\n( SELECT * FROM $$ETLVWDB.ST_SI_INT_RW_CQ_QT_LN_CNCS_RNWL_KFK ST\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY ST.QUOTE_ID, ST.QUOTE_LINE_OBJECT_ID, ST.CONCESSION_ID ORDER BY ST.EDW_CREATE_DTM DESC, ST.OFFSET_NUMBER DESC)=1 ) ST\r\nINNER JOIN $$ETLVWDB.EL_INT_CQ_SNGL_QUOTE_VW_RNWL_KFKA EL\r\nON ST.QUOTE_ID = EL.OBJECT_ID\r\nWhere NOT EXISTS (\r\n\tSELECT\t1 FROM\t$$ETLVWDB.EL_INT_RW_CQ_QUTE_LN_CNCS_KFKA_RNWL EL \r\n\t\tWHERE\tST.QUOTE_ID = EL.QUOTE_ID\r\n\t\t AND ST.QUOTE_LINE_OBJECT_ID = EL.QUOTE_LINE_OBJECT_ID  \r\n\t\tAND ST.CONCESSION_ID  =EL.CONCESSION_ID  /*performance recommendations */\r\n\t\t)\r\n\tAND CAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS\r\nwhere JOB_STREAM_ID='wf_EL_INT_RW_CQ_QUTE_LN_CNCS_KFKA_RNWL')\r\nAND ST.QUOTE_LINE_OBJECT_ID IS NOT NULL\r\nAND ST.CONCESSION_ID IS NOT NULL",
        "User Defined Join": "",
        "Source Filter": "",
