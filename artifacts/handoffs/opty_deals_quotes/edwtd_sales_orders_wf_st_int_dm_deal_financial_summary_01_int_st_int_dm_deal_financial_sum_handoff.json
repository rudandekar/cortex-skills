      "attributes": {
        "Sql Query": "SELECT \r\nINT_DM_DEAL_FINANCIAL_SUMMARY.DEAL_ID as DEAL_ID,\r\n-999 as OBJECT_ID,\r\nINT_DM_DEAL_FINANCIAL_SUMMARY.REFERENCE_OBJECT_ID as REFERENCE_OBJECT_ID,  \r\n'UNKNOWN' AS REFERENCE_OBJECT_TYPE,\r\nINT_DM_DEAL_FINANCIAL_SUMMARY.SUMMARY_TYPE as SUMMARY_TYPE, \r\nCASE WHEN LENGTH(TRUNC(INT_DM_DEAL_FINANCIAL_SUMMARY.EXT_LIST_PRICE))>18 THEN -999 ELSE EXT_LIST_PRICE END as EXT_LIST_PRICE, \r\nINT_DM_DEAL_FINANCIAL_SUMMARY.DISCOUNT_PERCENT as DISCOUNT_PERCENT,\r\nCASE WHEN LENGTH(TRUNC(INT_DM_DEAL_FINANCIAL_SUMMARY.EXT_NET_PRICE))>18 THEN -999 ELSE EXT_NET_PRICE END as EXT_NET_PRICE, \r\nINT_DM_DEAL_FINANCIAL_SUMMARY.CREATED_BY as CREATED_BY, \r\nINT_DM_DEAL_FINANCIAL_SUMMARY.CREATION_DATE as CREATION_DATE, \r\nINT_DM_DEAL_FINANCIAL_SUMMARY.LAST_UPDATED_BY as LAST_UPDATED_BY, \r\nINT_DM_DEAL_FINANCIAL_SUMMARY.LAST_UPDATE_DATE as LAST_UPDATE_DATE,\r\n-999 AS TOTAL_COST,\r\n-999 AS  GROSS_MARGIN,\r\n-999 AS  GROSS_MARGIN_PERCENT,\r\n-999 AS  STANDARD_COST,\r\n-999 AS  OVERHEAD_COST,\r\n-999 AS  ROYALTY_COST,\r\n-999 AS  STANDARD_MARGIN,\r\n-999 AS  STANDARD_MARGIN_PERCENT,\r\n-999 AS  NEGOTIATED_NET_PRICE,\r\n-999 AS  NEGOTIATED_DISCOUNT,\r\n-999 AS  NET_PRICE_EXCL_TRADE_IN,\r\n-999 AS  DISCOUNT_EXCL_TRADE_IN,\r\n-999 AS  NET_PRICE_EXCL_CREDITS,\r\nCOALESCE(LAST_UPDATE_DATE, CREATION_DATE) as EDW_UPDATED_DATE,\r\nCASE WHEN INT_DM_DEAL_FINANCIAL_SUMMARY.SS_CODE = 'CCWQUOTING' THEN 'CCW' WHEN INT_DM_DEAL_FINANCIAL_SUMMARY.SS_CODE ='CCWR' THEN 'CCWR' ELSE INT_DM_DEAL_FINANCIAL_SUMMARY.SS_CODE END AS SS_CODE\r\nFROM\r\n$$ETLVWDB.ST_SI_INT_DM_DEAL_FINANCIAL_SUM AS INT_DM_DEAL_FINANCIAL_SUMMARY\r\nWHERE INT_DM_DEAL_FINANCIAL_SUMMARY.EDW_CREATE_DTM >=(SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS where JOB_STREAM_ID='wf_ST_INT_DM_DEAL_FINANCIAL_SUMMARY') \r\nQUALIFY ROW_NUMBER() over(partition by DEAL_ID, REFERENCE_OBJECT_ID, SUMMARY_TYPE order by OFFSET_NUMBER desc, EDW_CREATE_DTM desc)=1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
    }
