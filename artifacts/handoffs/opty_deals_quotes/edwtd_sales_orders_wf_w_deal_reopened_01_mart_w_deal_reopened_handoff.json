      "attributes": {
        "Sql Query": "SELECT \r\nND.BK_DEAL_ID AS BK_DEAL_ID,\r\nREOPEN_R.CREATED_ON AS BK_REOPEN_CREATED_ON_DTM,\r\nREOPEN_R.UPDATED_ON AS REOPEN_UPDATED_ON_DTM,\r\nREOPEN_R.REOPEN_REASON AS REOPEN_REASON_TXT,\r\nCOALESCE(REOPEN_R.UPDATED_ON,EDW_UPDATED_DATE) AS SOURCE_UPDATED_DTM,\r\nREOPEN_R.CREATED_ON AS SOURCE_CREATED_DTM,\r\nCOALESCE(REOPEN_R.UPDATED_BY,'UNKNOWN') AS SOURCE_UPDATED_BY_USER_ID,\r\nREOPEN_R.CREATED_BY AS SOURCE_CREATED_BY_USER_ID,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\n'I' AS ACTION_CODE,\r\n'=' AS DML_TYPE\r\nFROM (SELECT * FROM $$STGDB.ST_INT_DEAL_REOPEN_REASON \r\n\t\tQUALIFY ROW_NUMBER() OVER(PARTITION BY DEAL_OBJECT_ID, CREATED_ON ORDER BY CREATED_ON DESC)=1)REOPEN_R\r\nINNER JOIN $$SLSORDVWDB.N_DEAL ND\r\nON ND.SK_DEAL_OBJECT_ID_INT = REOPEN_R.DEAL_OBJECT_ID\r\nAND ND.SS_CODE <> 'CCWR'",
        "User Defined Join": "",
        "Source Filter": "",
