      "attributes": {
        "Sql Query": "select   \r\nDISTINCT  \r\n/* Commented & SM table logic added as part of CCWR changes DM_CUST.OBJECT_ID as DEAL_CUST_DETAILS_KEY, \r\n*/\r\nSM.DEAL_CUST_DETAILS_KEY as DEAL_CUST_DETAILS_KEY,\r\n DEAL.BK_DEAL_ID as BK_DEAL_ID , \r\n COALESCE(CAST( CAST(DM_CUST.CR_ID AS VARCHAR(9))AS INTEGER),'-999')   as CUST_REGISTRY_ID,\r\n  COALESCE(DM_CUST.STRUCTURED_ACCOUNT,'N') as STRUCTURED_ACCT_FLG,\r\n COALESCE(DM_CUST.ACCOUNT_NAME,'UNKNOWN') as CUST_ACCT_NAME,\r\n COALESCE(DM_CUST. ADDR,'UNKNOWN') as LINE_1_ADDR,\r\n COALESCE(DM_CUST.ADDR_LINE_2 ,'UNKNOWN') as LINE_2_ADDR,\r\n COALESCE(DM_CUST.ADDR_LINE_3,'UNKNOWN')   as LINE_3_ADDR,\r\n COALESCE(DM_CUST.CITY,'UNKNOWN')  as CITY_NAME,\r\n COALESCE(DM_CUST.PROVINCE,'UNKNOWN') as PROVINCE_NAME,\r\n COALESCE(DM_CUST.ZIPCODE,'-999')   as ZIP_CD,\r\n COALESCE(DM_CUST.COUNTRY ,'UNKNOWN')   as COUNTRY_NAME,\r\n COALESCE(DM_CUST.COUNTY ,'UNKNOWN')  as COUNTY_NAME,\r\n COALESCE(DM_CUST.END_CUSTOMER_TYPE,'UNKNOWN') as CUST_TYPE_CD,\r\n COALESCE(DM_CUST.CREATED_BY ,DEAL.RU_SOURCE_CREATED_BY_USER_ID)as CREATED_BY_USER_NAME,\r\n COALESCE(DM_CUST.CREATED_ON,DEAL.SOURCE_CREATED_DTM) as CREATED_ON_DTM,   \r\n COALESCE(DM_CUST.UPDATED_BY ,DEAL.RU_SOURCE_UPDATED_BY_USER_ID) as UPDATED_BY_USER_NAME,\r\n COALESCE(DM_CUST.UPDATED_ON ,DEAL.DEAL_LAST_UPDATED_DTM) as UPDATED_ON_DTM,\r\n -- cast(cast(CAST(CURRENT_TIMESTAMP AS TIMESTAMP(6)) as date) as timestamp(0))   as EDW_CREATE_DTM,\r\n  CURRENT_TIMESTAMP(0) as EDW_CREATE_DTM,\r\n /* 'E_SLSORD_BATCH' AS EDW_CREATE_USER, -- COMMENTED AS PART OF CCW DATA FIX AUG REL */\r\n USER AS EDW_CREATE_USER, /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\n -- cast(cast(CAST(CURRENT_TIMESTAMP AS TIMESTAMP(6)) as date) as timestamp(0))    AS EDW_UPDATE_DTM,\r\n  CURRENT_TIMESTAMP(0) as EDW_UPDATE_DTM,\r\n /* 'E_SLSORD_BATCH' AS EDW_UPDATE_USER, -- COMMENTED AS PART OF CCW DATA FIX AUG REL ,*/\r\n USER AS EDW_CREATE_USER, /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\n 'Y' AS ACTION_CODE,\r\n 'I' AS DML_TYPE \r\n from\r\n $$STGDB.ST_INT_RAW_DM_CUSTOMER DM_CUST\r\n /* \r\n INNER JOIN $$STGDB.ST_INT_DMR_DEAL_CUST_MAP CUST_MAP ON CUST_MAP.CUSTOMER_OBJECT_ID = DM_CUST.OBJECT_ID\r\n  -- COMMENTED AS PART OF CCW DATA FIX AUG REL */\r\n INNER JOIN $$SLSORDVWDB.N_DEAL DEAL \r\n ON DM_CUST.DEAL_OBJECT_ID = DEAL.SK_DEAL_OBJECT_ID_INT     \r\n AND DEAL.SS_CODE <> 'CCWR'\r\n INNER JOIN\r\n$$ETLVWDB.SM_DEAL_CUST_DETAILS SM\r\nON DM_CUST.OPTY_NUMBER = SM.BK_DEAL_ID\r\nAND DM_CUST.CR_ID = SM.CR_ID \r\nAND SM.SS_CODE = 'CCW'",
        "User Defined Join": "",
        "Source Filter": "",
