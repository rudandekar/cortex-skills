      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\nPARENT_ID AS DEAL_OBJECT_ID,\r\nCSTIV.OBJECT_ID AS OBJECT_ID,\r\nSTATE AS STATE,\r\nCAST(LEFT(OREPLACE(TRANSITION_DATE,'T',' '), 19) as TIMESTAMP(0)) as TRANSITION_DATE,\r\nTRANSITION_INITIATED_BY AS TRANSITION_INITIATED_BY,\r\nSOURCE,\r\nCSTIV.MDM_DEAL_STATUS AS MDM_DEAL_STATUS,\r\nPDR_DEAL_STATUS AS PDR_DEAL_STATUS,\r\nCSTIV.CREATED_BY AS CREATED_BY,\r\nCAST(LEFT(OREPLACE(CSTIV.CREATED_ON,'T',' '), 19) as TIMESTAMP(0)) as CREATED_ON,\r\nCSTIV.UPDATED_BY_KAFKA AS UPDATED_BY_KAFKA,\r\ncast(left (CSTIV.UPDATED_ON_KAFKA,19) as timestamp(0)) as UPDATED_ON_KAFKA,\r\nCSTIV.OFFSET_NUMBER AS OFFSET_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\nUSER AS EDW_CREATE_USER,\r\nCSTIV.PARTITION_NUMBER AS PARTITION_NUMBER,\r\nCSTIV.MESSAGE_SEQUENCE_NUMBER AS MESSAGE_SEQUENCE_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER\r\nFROM\r\n$$STGDB.ST_CQ_STATE_TRN_INT_VW_KFK_FF CSTIV\r\nJOIN (sel OBJECT_ID from  $$STGDB.ST_INT_CQ_DEAL_KAFKA_FF group by 1) ICD\r\nON ICD.OBJECT_ID = CSTIV.PARENT_ID \r\n--WHERE ICD.UPDATED_ON > TO_DATE('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS')\r\nWHERE\r\nNOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.EL_CQ_STATE_TRNSTN_INT_VW_KFKA EL\r\nWHERE CSTIV.OBJECT_ID = EL.OBJECT_ID \r\nAND \r\nCSTIV.OFFSET_NUMBER = EL.OFFSET_NUMBER\r\n/* AND \r\nCSTIV.PARENT_ID = EL.DEAL_OBJECT_ID Commenting as part of CCW DATA FIXES AUG RELEASE*/\r\nAND\r\nCSTIV.MESSAGE_SEQUENCE_NUMBER = EL.MESSAGE_SEQUENCE_NUMBER\r\n)",
        "User Defined Join": "",
