      "attributes": {
        "Sql Query": "SELECT OBJECT_ID, \r\nDEAL_OBJECT_ID, \r\nQUOTE_OBJECT_ID, \r\nSOURCE_PROFILE_ID, \r\nDEVIATION_ID, \r\nOREPLACE(OREPLACE(OREPLACE(OREPLACE(DEV_PROCESS_STATUS, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') DEV_PROCESS_STATUS,\r\nOREPLACE(OREPLACE(OREPLACE(OREPLACE(DEV_PROCESS_REMARK, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') DEV_PROCESS_REMARK,\r\nDEV_RETRY_COUNT, \r\nLINKED_DEVIATION_ID, \r\nOREPLACE(OREPLACE(OREPLACE(OREPLACE(AUTHORIZATION_NUMBER, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') AUTHORIZATION_NUMBER,\r\nREVISION_NUMBER, \r\nSTART_DATE, \r\nEND_DATE, \r\nOREPLACE(OREPLACE(OREPLACE(OREPLACE(NEXT_ACTION, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') NEXT_ACTION,\r\nLAST_UPDATE_DATE, \r\nQUEUE_OBJECT_ID, \r\nOREPLACE(OREPLACE(OREPLACE(OREPLACE(DEV_PROCESS_DESCRIPTION, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') DEV_PROCESS_DESCRIPTION,\r\nOREPLACE(OREPLACE(OREPLACE(OREPLACE(DEVIATION_STATUS, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') DEVIATION_STATUS\r\nFROM $$ETLVWDB.EL_INT_RAW_DEAL_DISTI_FULF_KFK\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY QUOTE_OBJECT_ID,OBJECT_ID  ORDER BY EDW_CREATE_DTM DESC ,MESSAGE_SEQUENCE_NUMBER DESC)=1           /* ADDED AS PART OF CCW DATA FIX AUG REL Added New Attribute EDW_CREATE_DTM  In The ORDER BY Clause*/\r\nWhere EDW_CREATE_DTM >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS where JOB_STREAM_ID='wf_ST_INT_RAW_DEAL_DISTI_FULF_KFK')",
