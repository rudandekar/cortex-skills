      "attributes": {
        "Sql Query": "SELECT\r\nDEAL_ID,DEAL_TYPE,DEAL_STATUS_DESC,CR_ID,EDW_CREATE_DTM\r\n,CREATED_BY,CREATED_ON,UPDATED_BY,UPDATED_ON,\r\nOPTY_ID\r\nFROM\r\n(\r\nSELECT  \r\nDEAL_ID\r\n,DEAL_TYPE\r\n,DEAL_STATUS_DESC\r\n,CR_ID\r\n,CAST(CAST(EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0))      EDW_CREATE_DTM\r\n,CREATED_BY\r\n,CAST(CAST(CREATED_ON AS VARCHAR(19)) AS TIMESTAMP(0 ))    CREATED_ON\r\n,UPDATED_BY\r\n,CAST(CAST(UPDATED_ON AS VARCHAR(19)) AS TIMESTAMP(0))      UPDATED_ON\r\n,OPTY_ID\r\nFROM\r\n$$ETLVWDB.ST_SI_REVCLOUD_QUOTE_HEADERS\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY DEAL_ID ORDER BY CAST(CAST(EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0))   DESC)=1\r\n)A  WHERE DEAL_ID IS NOT NULL AND \r\nCAST(CAST(EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0 ))    >=Cast('$$LastExtractDate' AS TIMESTAMP(0))",
        "User Defined Join": "",
        "Source Filter": "",
