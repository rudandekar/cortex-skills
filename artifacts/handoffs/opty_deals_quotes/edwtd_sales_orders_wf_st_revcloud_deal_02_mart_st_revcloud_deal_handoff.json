      "attributes": {
        "Sql Query": "SELECT DEAL_ID\r\n,RANK() OVER (ORDER BY DEAL_ID)*(-1)+(EDW_DEAL_OBJECT_ID_MIN)AS EDW_DEAL_OBJECT_ID\r\n,DEAL_TYPE\r\n,DEAL_STATUS_DESC\r\n,current_timestamp(0) EDW_CREATE_DTM\r\n,current_timestamp(0) EDW_UPDATE_DTM,\r\nOPTY_ID\r\nFROM  $$STGDB.ST_REVCLOUD_DEAL ST,\r\n(SELECT COALESCE(MIN(EDW_DEAL_OBJECT_ID),0) AS EDW_DEAL_OBJECT_ID_MIN \r\nFROM $$ETLVWDB.EL_REVCLOUD_DEAL)ABC\r\nWHERE NOT EXISTS(SELECT 1 FROM $$ETLVWDB.EL_REVCLOUD_DEAL EL \r\nWHERE ST.DEAL_ID=EL.DEAL_ID)",
