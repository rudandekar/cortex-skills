      "attributes": {
        "Sql Query": "SELECT\r\n SM_KEY.PRICING_SCENARIO_KEY AS PRICING_SCENARIO_KEY,\r\n SNGL_SCNE.DEAL_ID AS BK_DEAL_ID,\r\n SNGL_SCNE.SCENARIO_NAME AS SCENARIO_NAME,\r\n COALESCE(CAST(SCENARIO_STATE AS VARCHAR(50)),'UNKNOWN') AS SCENARIO_STATUS_CD,\r\n COALESCE(PUBLISHED_BY,'UNKNOWN') AS RU_PUBLISHED_BY_USER_ID,\r\n COALESCE(CAST(SCENARIO_TYPE AS VARCHAR(50)),'UNKNOWN') AS SCENARIO_TYPE_CD,\r\n COALESCE(LOV.LOV_VALUE,'UNKNOWN') AS CBN_STATUS_CD,\r\n UPDATED_ON AS SOURCE_SCENARIO_UPDATE_DTM,\r\n COALESCE(FULFILLMENT_TYPE,'UNKNOWN') AS FULLFILLMENT_TYPE_CD,\r\n COALESCE(IS_FINALIZED,'N') AS IS_FINALIZED_FLG,\r\n COALESCE(IS_STRINGENT,'N') AS IS_STRINGENT_FLG,\r\n /*COALESCE(ACTIVE,'N') AS ACTIVE_FLG,*/\r\n CASE WHEN COALESCE(SNGL_SCNE.ACTIVE,0) =1 THEN 'Y' ELSE 'N' END AS ACTIVE_FLG,\r\n COALESCE(PRICE_LST.ERP_PRICE_LIST_NAME,'UNKNOWN') AS BK_PRICE_LIST_NAME,\r\n COALESCE(SNGL_SCNE.CBN_DISTI_ID,-999)  AS CBN_PARTNER_SITE_PARTY_KEY,\r\n SNGL_SCNE.OBJECT_ID AS SK_SCENARIO_ID_INT,\r\n PUBLISHED_DATE AS RU_SCENARIO_PUBLISHED_DTM,\r\n CURRENT_TIMESTAMP(0),\r\n USER,\r\n CURRENT_TIMESTAMP(0),\r\n USER,\r\n 'I' AS ACTION_CODE,\r\n '=' AS DML_TYPE\r\n FROM $$STGDB.ST_INT_CQ_SNGL_SCENARIO_VW SNGL_SCNE\r\n INNER JOIN $$ETLVWDB.SM_PRICING_SCENARIO SM_KEY\r\n ON SM_KEY.SK_SCENARIO_ID_INT = SNGL_SCNE.OBJECT_ID\r\n /*AND SNGL_SCNE.PUBLISHED_DATE IS NOT NULL*/\r\n INNER JOIN $$SLSORDVWDB.N_DEAL DEAL\r\n ON DEAL.BK_DEAL_ID=SNGL_SCNE.DEAL_ID\r\n LEFT JOIN $$STGDB.ST_INT_RAW_PRICE_LIST PRICE_LST\r\n ON PRICE_LST.PRICE_LIST_ID =  SNGL_SCNE.PRICE_LIST_ID\r\n LEFT OUTER JOIN $$ETLVWDB.EL_CQ_LOV LOV\r\n ON LOV.LOV_INDEX=SNGL_SCNE.CBN_STATUS\r\n AND LOV.LOV_TYPE='CBN_STATUS'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
