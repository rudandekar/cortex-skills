      "attributes": {
        "Sql Query": "SELECT\tEL.QUOTE_OBJECT_ID, \r\n\t\tEL.DEAL_OBJECT_ID,\r\n\t\tEL.OFR_REWARD_CODE,\r\n\t\tEL.OFR_REWARD_ID,\r\n\t\tEL.OFR_REWARD_NAME,\r\n\t\tEL.OFR_REWARD_VERSION,\r\n\t\tEL.PROGRAM_NAME,\r\n\t\tEL.BATCH_ID,\r\n\t\tEL.CREATED_BY,\r\n\t\tEL.CREATED_ON,\r\n\t\tEL.UPDATED_BY,\r\n\t\tEL.UPDATED_ON,\r\n\t\tEL.IS_OFR_REWARD_SELECTED,\r\n\t\tEL.OFR_REWARD_VERSION_APPLIED,\r\n\t\tEL.CREATE_DATETIME,\r\n\t\tEL.ACTION_CODE,\r\n\t\tEL.AUTO_APPROVED,\r\n\t\tEL.STATUS\r\nFROM\r\n$$ETLVWDB.EL_INT_RW_CQ_OFFER_RWRD_KFK EL\r\nQUALIFY ROW_NUMBER() OVER(PARTITION BY EL.DEAL_OBJECT_ID,EL.OFR_REWARD_VERSION,EL.OFR_REWARD_CODE ORDER BY EL.EDW_CREATE_DTM DESC,EL.MESSAGE_SEQUENCE_NUMBER DESC)=1        /* ADDED AS PART OF CCW DATA FIX AUG REL Added New Attribute EDW_CREATE_DTM  In The ORDER BY Clause*/\r\nWhere EL.EDW_CREATE_DTM >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS where JOB_STREAM_ID='wf_ST_INT_RAW_CQ_OFFER_REWARD_KAFKA')",
