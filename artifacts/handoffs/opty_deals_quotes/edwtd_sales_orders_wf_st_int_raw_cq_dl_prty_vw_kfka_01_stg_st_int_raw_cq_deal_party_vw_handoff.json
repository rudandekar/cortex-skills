      "attributes": {
        "Sql Query": "SELECT * FROM (\r\nSELECT OBJECT_ID, \r\n DEAL_OBJECT_ID, \r\nPARTY_NAME, \r\nPARTY_TYPE_NAME,\r\n PRIMARY_FLAG, \r\n SITE_ID,\r\n PARTY_ID,\r\n PARTY_TYPE_LEVEL,\r\n CREATED_DATE,\r\nCOALESCE(CREATED_BY,'UNKNOWN') AS CREATED_BY,\r\n UPDATED_DATE, \r\nCOALESCE(UPDATED_BY,'UNKNOWN') AS UPDATED_BY\r\nFROM\r\n$$ETLVWDB.EL_INT_RAW_CQ_DL_PRTY_VW_KFKA \r\nQUALIFY Row_Number() Over(PARTITION BY DEAL_OBJECT_ID,OBJECT_ID ORDER BY EDW_CREATE_DTM DESC,MESSAGE_SEQUENCE_NUMBER DESC)=1    /* ADDED AS PART OF CCW DATA FIX AUG REL Added New Attribute EDW_CREATE_DTM  In The ORDER BY Clause*/\r\nWhere EDW_CREATE_DTM >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS where JOB_STREAM_ID='wf_ST_INT_RAW_CQ_DL_PRTY_VW_KFKA'))nav\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY OBJECT_ID ORDER BY DEAL_OBJECT_ID DESC)=1",
