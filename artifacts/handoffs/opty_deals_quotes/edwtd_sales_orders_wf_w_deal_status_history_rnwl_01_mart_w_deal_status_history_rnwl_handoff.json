      "attributes": {
        "Sql Query": "SELECT \r\n NAPPR.BK_DEAL_STATUS_CD,\r\n A.BK_DEAL_ID as BK_DEAL_ID,\r\n COALESCE(TRANSITION_DATE,CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))) AS BK_STATUS_TRX_DTM,\r\n COALESCE(SOURCE,'UNK') AS BK_DEAL_STATUS_SS_CD, /*FIX AS PART OF AUGUST RELEASE  changing default to UNK as it is getting truncated */\r\n COALESCE(CAST (TRANSITION_DATE AS DATE ),CAST('3000-01-01' AS DATE)) AS DV_STATUS_TRX_DT,\r\n COALESCE(CISCO_WORKER_PARTY_KEY,-999) AS CISCO_WORKER_PARTY_KEY ,\r\n CURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\n USER AS EDW_CREATE_USER,\r\n CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n USER AS EDW_UPDATE_USER\r\n FROM\r\n (\r\n SELECT \r\n ST.DEAL_OBJECT_ID ,\r\n BK_DEAL_ID, \r\n STATE , \r\n TRANSITION_DATE , \r\n TRANSITION_INITIATED_BY , \r\n CASE WHEN DEAL_TYPE = '1' THEN\r\n                'SFDC'\r\n             WHEN  (SOURCE = '1' AND DEAL_TYPE IN ('3', '4', '5', '6')) THEN\r\n                'PDR'\r\n             WHEN  (SOURCE = '2' AND DEAL_TYPE IN ('2', '5', '6')) THEN\r\n                'MDM' \r\n             ELSE\r\n                NVL(DEAL.ACTIVE_WORKFLOW_CD,'MDM')\r\n             END AS SOURCE,   \r\n SOURCE AS SOURCE_NUM,\r\n TRIM(DEAL_TYPE) AS DEAL_TYPE\r\n FROM $$STGDB.ST_CQ_STATE_TRANSITION_INT_VW_RNWL ST , $$SLSORDDB.N_DEAL  DEAL\r\n WHERE DEAL.sk_deal_object_id_int=St.Deal_object_ID \r\n AND DEAL.SS_CODE = 'CCWR' -- added to process CCWR DEALS\r\n QUALIFY  ROW_NUMBER ( ) OVER ( PARTITION BY DEAL.sk_deal_object_id_int , STATE ,TRANSITION_DATE\r\n ORDER  BY TRANSITION_DATE DESC ) = 1\r\n/*  Commented ad CCW DATA FIX as PART OF AUGUST RELEASE*/ \r\n/*Union All\r\n SELECT \r\n ST.DEAL_OBJECT_ID ,\r\n BK_DEAL_ID, \r\n STATE , \r\n TRANSITION_DATE , \r\n TRANSITION_INITIATED_BY , \r\n CASE WHEN DEAL_TYPE = '1' THEN\r\n                'SFDC'\r\n             WHEN  (SOURCE = '1' AND DEAL_TYPE IN ('3', '4', '5', '6')) THEN\r\n                'PDR'\r\n             WHEN  (SOURCE = '2' AND DEAL_TYPE IN ('2', '5', '6')) THEN\r\n                'MDM' \r\n             ELSE\r\n                NVL(DEAL.ACTIVE_WORKFLOW_CD,'MDM')\r\n             END AS SOURCE,   \r\n SOURCE AS SOURCE_NUM,\r\n TRIM(DEAL_TYPE) AS DEAL_TYPE\r\n FROM $$EXCEPDB.EX_CQ_STATE_TRANSITION_RNWL ST , $$SLSORDDB.N_DEAL  DEAL\r\n WHERE DEAL.sk_deal_object_id_int=St.Deal_object_ID \r\n AND DEAL.SS_CODE = 'CCWR' -- added to process CCWR DEALS\r\n QUALIFY  ROW_NUMBER ( ) OVER ( PARTITION BY DEAL.sk_deal_object_id_int , STATE  ,TRANSITION_DATE\r\n ORDER  BY TRANSITION_DATE DESC ) = 1 */\r\n ) A\r\n INNER  JOIN (   SELECT BK_DEAL_STATUS_CD,EL.LOV_INDEX  LOV_INDEX, EL.LOV_TYPE\r\n                             FROM     $$ETLVWDB.EL_CQ_LOV EL ,$$SLSORDVWDB.N_DEAL_STATUS  DECI\r\n                             WHERE  EL.LOV_VALUE=DECI.BK_DEAL_STATUS_CD\r\n                              AND      EL.LOV_TYPE IN('PDR_DEAL_STATUS','DEAL_STATUS')\r\n                         ) NAPPR\r\n ON  A.STATE=NAPPR.LOV_INDEX\r\n AND NAPPR.LOV_TYPE = DECODE(A.SOURCE_NUM,'1', 'PDR_DEAL_STATUS','DEAL_STATUS')\r\n LEFT JOIN  $$COMREFVWDB.N_CISCO_WORKER_PARTY PARTY\r\n ON PARTY.CEC_ID=A.TRANSITION_INITIATED_BY",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
