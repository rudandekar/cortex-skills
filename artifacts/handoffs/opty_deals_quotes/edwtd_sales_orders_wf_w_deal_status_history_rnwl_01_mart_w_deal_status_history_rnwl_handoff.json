      "attributes": {
        "Sql Query": "SELECT \r\n DEAL_OBJECT_ID           ,     \r\n OBJECT_ID                 ,    \r\n STATE                      ,   \r\n TRANSITION_DATE              , \r\n TRANSITION_INITIATED_BY       ,\r\n SOURCE                        ,\r\n /*CASE when SOURCE =1 then PDR_DEAL_STATUS else MDM_DEAL_STATUS  END as DEAL_STATUS,*/  /*COMMENTED AS PART OF CCWR DATA FIX AUG REL */\r\n/* ADDED AS PART OF CCWR DATA FIX AUG REL  ADDED FOUR ATTRIBUTES*/\r\n MDM_DEAL_STATUS,\r\n PDR_DEAL_STATUS,\r\n CREATED_BY,                 \r\n CREATED_ON,     \r\n 'RI' AS EXCEPTION_TYPE                \r\n FROM $$STGDB.ST_CQ_STATE_TRANSITION_INT_VW_RNWL STATE\r\n WHERE( NOT EXISTS (SELECT 1 FROM $$SLSORDDB. N_DEAL DEAL \r\n WHERE DEAL.SK_DEAL_OBJECT_ID_INT=STATE.DEAL_OBJECT_ID\r\n AND DEAL.SS_CODE = 'CCWR' -- added to process CCWR DEALS\r\n ))",
