      "attributes": {
        "Sql Query": "SELECT \r\n BATCH_ID,\r\n DEAL_OBJECT_ID,\r\n QUESTION_ID,\r\n COALESCE(VALUE_NAME, 'UNKNOWN'),\r\n CREATED_BY,\r\n CREATION_DATE,\r\n LAST_UPDATED_BY,\r\n LAST_UPDATE_DATE,\r\n CREATE_DATETIME,\r\n ACTION_CODE\r\n FROM  $$STGDB.ST_CQ_QF_RESPONSE RES\r\n WHERE NOT EXISTS (SELECT 1 FROM $$SLSORDVWDB.N_DEAL DEAL \r\n WHERE  DEAL.SK_DEAL_OBJECT_ID_INT=RES.DEAL_OBJECT_ID\r\n AND DEAL.SS_CODE <> 'CCWR' -- to filter out CCWR Deals\r\n )\r\n OR NOT EXISTS (SELECT 1 FROM $$SLSORDVWDB.N_DEAL_QUESTION QUES \r\n WHERE  SK_QUESTION_ID_INT=RES.QUESTION_ID)",
