        }
      ],
      "attributes": {
        "Sql Query": "select \r\n SM.DEAL_QUESTION_RESPONSE_KEY,\r\n COALESCE(VALUE_NAME,'UNKNOWN') AS DEAL_QUESTION_RESPONSE_NAME,\r\n COALESCE(DEAL.BK_DEAL_ID,'UNKNOWN') AS DEAL_ID,\r\n COALESCE(QUES.DEAL_QUESTION_KEY,-999) AS DEAL_QUESTION_KEY,\r\n CURRENT_TIMESTAMP(0) AS EDW_CREATE_DTM,\r\n USER AS EDW_CREATE_USER,\r\n CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n USER AS EDW_UPDATE_USER,\r\n 'I' AS ACTION_CODE,\r\n 'I' AS DML_TYPE\r\n FROM \r\n (\r\n SELECT\r\n BATCH_ID,\r\n DEAL_OBJECT_ID,\r\n QUESTION_ID,\r\n VALUE_NAME\r\n from\r\n $$STGDB.ST_CQ_QF_RESPONSE \r\n /*\r\n UNION ALL\r\n SELECT\r\n BATCH_ID,\r\n DEAL_OBJECT_ID,\r\n QUESTION_ID,\r\n VALUE_NAME\r\n from\r\n $$EXCEPDB.EX_CQ_QF_RESPONSE\tCCW DATA FIXES AUG RELEASE\r\n */\r\n ) RES\r\n INNER JOIN $$SLSORDVWDB.N_DEAL DEAL \r\n ON DEAL.SK_DEAL_OBJECT_ID_INT=RES.DEAL_OBJECT_ID\r\n AND DEAL.SS_CODE <> 'CCWR' -- to filter out CCWR Deals\r\n INNER JOIN\r\n $$TRANSLATIONDB.SM_DEAL_QUESTION_RESPONSE SM\r\n ON RES.VALUE_NAME = SM.DEAL_QUESTION_RESPONSE_NAME \r\n and SM.SK_QUESTION_ID_INT=RES.QUESTION_ID\r\n AND SM.BK_DEAL_ID= DEAL.BK_DEAL_ID \r\n INNER JOIN $$SLSORDVWDB.N_DEAL_QUESTION QUES  \r\n ON QUES.SK_QUESTION_ID_INT=RES.QUESTION_ID\r\n AND QUES.SS_CODE = 'CCW'",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
