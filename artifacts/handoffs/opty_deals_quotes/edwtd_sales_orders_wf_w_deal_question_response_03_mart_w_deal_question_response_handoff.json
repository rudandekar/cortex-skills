          "expression": ""
        }
      ],
      "attributes": {
        "Sql Query": "SELECT \r\n RANK () OVER ( ORDER BY DISCOUNT.VALUE_NAME,DISCOUNT.BK_DEAL_ID,DISCOUNT.SK_QUESTION_ID_INT ) + MAX_VAL DEAL_QUESTION_RESPONSE_KEY, \r\n DISCOUNT.VALUE_NAME AS DEAL_QUESTION_RESPONSE_NAME,\r\n BK_DEAL_ID,\r\n SK_QUESTION_ID_INT,\r\n CURRENT_TIMESTAMP(0) EDW_CREATE_DTM,\r\n USER EDW_CREATE_USER\r\n FROM \r\n ( \r\n SELECT VALUE_NAME,BK_DEAL_ID,SK_QUESTION_ID_INT FROM $$STGDB.ST_CQ_QF_RESPONSE DISC\r\n INNER JOIN $$SLSORDVWDB.N_DEAL DEAL \r\n ON DEAL.SK_DEAL_OBJECT_ID_INT =DISC.DEAL_OBJECT_ID\r\n AND DEAL.SS_CODE <> 'CCWR' -- to filter out CCWR Deals\r\n INNER JOIN $$SLSORDVWDB.N_DEAL_QUESTION QUES  \r\n ON DISC.QUESTION_ID=QUES.SK_QUESTION_ID_INT\r\nAND QUES.SS_CODE <> 'CCWR'\r\n where VALUE_NAME IS NOT NULL ) DISCOUNT,\r\n (SELECT COALESCE(MAX (DEAL_QUESTION_RESPONSE_KEY) , 0) MAX_VAL\r\n FROM $$TRANSLATIONDB.SM_DEAL_QUESTION_RESPONSE) SM\r\n WHERE NOT EXISTS ( \r\n SELECT 1 \r\n FROM $$TRANSLATIONDB.SM_DEAL_QUESTION_RESPONSE SM\r\n WHERE SM.DEAL_QUESTION_RESPONSE_NAME = DISCOUNT.VALUE_NAME\r\n and SM.SK_QUESTION_ID_INT=DISCOUNT.SK_QUESTION_ID_INT\r\n AND SM.BK_DEAL_ID=DISCOUNT.BK_DEAL_ID )",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
        "Select Distinct": "NO",
        "Is Partitionable": "NO",
        "Pre SQL": "",
        "Post SQL": "",
        "Output is deterministic": "NO",
        "Output is repeatable": "Never"
      }
