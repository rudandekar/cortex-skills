      "attributes": {
        "Sql Query": "SELECT REPLACE(REPLACE(REPLACE(REPLACE(CDEALPF.OPTY_NUMBER, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') OPTY_NUMBER,\r\nCDEALPF.DEAL_OBJECT_ID,\r\nREPLACE(REPLACE(REPLACE(REPLACE(CDEALPF.PRODUCT_FAMILY, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') PRODUCT_FAMILY,\r\nCDEALPF.PF_DISCOUNT_RULE_ID,\r\nREPLACE(REPLACE(REPLACE(REPLACE(CDEALPF.PF_DISCOUNT_BAND, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') PF_DISCOUNT_BAND,\r\nCDEALPF.CREATED_ON,\r\nCDEALPF.LAST_RUN_DATE,\r\nREPLACE(REPLACE(REPLACE(REPLACE(CDEALPF.DEAL_COMPONENT, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') DEAL_COMPONENT,\r\nREPLACE(REPLACE(REPLACE(REPLACE(CDEALPF.PR_SER_CATEGORY, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') PR_SER_CATEGORY,\r\nREPLACE(REPLACE(REPLACE(REPLACE(CDEALPF.FINAL_COMPONENT_BAND, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') FINAL_COMPONENT_BAND,\r\nREPLACE(REPLACE(REPLACE(REPLACE(CDEALPF.STRINGENT_PF, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') STRINGENT_PF,\r\nREPLACE(REPLACE(REPLACE(REPLACE(CDEALPF.DEAL_APPROVAL_BAND, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') DEAL_APPROVAL_BAND,\r\nCDEALPF.EXT_LIST_PRICE_GPL,\r\nCDEALPF.EXTENDED_LIST_PRICE,\r\nCDEALPF.EXTENDED_NET_PRICE,\r\nCDEALPF.PF_APPROVAL_RULE_ID,\r\nREPLACE(REPLACE(REPLACE(REPLACE(CDEALPF.PF_APPROVAL_BAND, CHR(9),' '),CHR(234),'e'),CHR(10),' '),CHR(13),' ') PF_APPROVAL_BAND\r\nFROM    \r\nCQ_DEAL_PF_BAND_RPT CDEALPF\r\nJOIN INT_CQ_DEAL ICDEAL\r\nON ICDEAL.OBJECT_ID = CDEALPF.DEAL_OBJECT_ID\r\nWHERE NVL(ICDEAL.UPDATED_ON,SYSDATE) > TO_DATE('$$LastExtractDate','MM/DD/YYYY HH24:MI:SS')",
