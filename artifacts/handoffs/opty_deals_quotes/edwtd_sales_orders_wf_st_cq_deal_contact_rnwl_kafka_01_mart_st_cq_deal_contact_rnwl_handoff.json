      "attributes": {
        "Sql Query": "SELECT \r\nEL_CQ_DEAL_CONTACT.BATCH_ID,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.DEAL_OBJECT_ID,-999) as DEAL_OBJECT_ID,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.OBJECT_ID,-999) as OBJECT_ID,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.CONTACT_ID,'UNKNOWN') as CONTACT_ID,\r\n'UNKNOWN' as CONTACT_NAME,\r\n-999 as CONTACT_TYPE,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.CREATED_ON,CURRENT_TIMESTAMP(0)) as CREATED_ON,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.CREATED_BY,'CCWR') as CREATED_BY,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.UPDATED_ON,CURRENT_TIMESTAMP(0)) as UPDATED_ON,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.UPDATED_BY,'CCWR') as UPDATED_BY,\r\nNULL as CONTACT_ROW,\r\nCURRENT_TIMESTAMP(0) as DM_UPDATE_DATE,\r\nNULL as CONTACT_POSTN_ID,\r\nEL_CQ_DEAL_CONTACT.SIEBEL_POSTN_ID,\r\nCURRENT_TIMESTAMP(0) as CREATE_DATETIME,\r\nCOALESCE(EL_CQ_DEAL_CONTACT.ACTION_CODE,'I') as ACTION_CODE\r\nFROM $$ETLVWDB.EL_CQ_DEAL_CONTACT_RNWL_KAFKA EL_CQ_DEAL_CONTACT\r\nWHERE CAST(EL_CQ_DEAL_CONTACT.EDW_CREATE_DTM AS TIMESTAMP) >=\r\nCAST((SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS WHERE JOB_STREAM_ID='wf_ST_CQ_DEAL_CONTACT_RNWL_KAFKA') AS TIMESTAMP)",
