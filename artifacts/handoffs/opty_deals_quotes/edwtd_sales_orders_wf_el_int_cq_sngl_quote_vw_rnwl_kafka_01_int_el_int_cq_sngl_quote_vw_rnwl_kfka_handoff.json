      "attributes": {
        "Sql Query": "SELECT  DISTINCT\r\n\tCOALESCE(QUOTE_ID, -999) AS OBJECT_ID,  \r\n\tCOALESCE(PARENT_ID , -999) AS DEAL_OBJECT_ID,\r\n\tCREATED_BY,\r\n\tCAST(LEFT(OREPLACE(CREATED_ON,'T',' '), 19) as TIMESTAMP(0)) AS CREATED_ON,\r\n\tUPDATED_BY,\r\n\tCAST(LEFT(OREPLACE(UPDATED_ON,'T',' '), 19) as TIMESTAMP(0)) AS UPDATED_ON,\r\n\t1 AS ACTIVE,\r\n\tPRICELISTID as PRICE_LIST_ID,\r\n\tCOALESCE(QUOTE_ID, -999) AS QUOTE_ID,\r\n\tQUOTE_NAME,\r\n\tIS_Q2O_ELIGIBLE,\r\n\tIS_DISTI_Q2O_ELIGIBLE,\r\n\tFULFILLMENT_TYPE,\r\n\tINTENDED_USE,\r\n\t'N' AS IS_STRINGENT,\r\n\t'Y'  AS  IS_FINALIZED,\r\n\tFEDERAL_FLG,\r\n\tUPDATED_BY_KAFKA,\r\n\tCAST(LEFT(OREPLACE(UPDATED_ON_KAFKA,'T',' '), 19) as TIMESTAMP(0)) AS UPDATED_ON_KAFKA,\r\n\tOFFSET_NUMBER,\r\n\tPARTITION_NUMBER,\r\n\tCAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) as EDW_CREATE_DTM,\r\n\tUSER as EDW_CREATE_USER,\r\n\tUSER AS EDW_UPDATE_USER\t,\r\n\tCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n\tQUOTE_STATUS_ID,\r\n    REF_ENTITY_NUMBER,\r\n\tCURRENCY_CODE,\r\n\tBUY_METHOD,\r\n\tCOALESCE (IS_PCM, 'FALSE') AS IS_PCM\r\n\tFROM \r\n\t$$ETLVWDB.ST_SI_INT_CQ_SNGL_QUTE_VW_RNWL_KFKA  ST\r\n\tQUALIFY ROW_NUMBER() OVER(PARTITION BY ST.QUOTE_ID ORDER BY ST.EDW_CREATE_DTM DESC, OFFSET_NUMBER DESC )=1\r\n\tWhere NOT EXISTS\r\n\t(SELECT 1 FROM \r\n\t$$ETLVWDB.EL_INT_CQ_SNGL_QUOTE_VW_RNWL_KFKA EL\r\n\tWHERE \r\n\tCAST(ST.QUOTE_ID  AS DECIMAL(18,0)) = EL.OBJECT_ID\r\n\t)\r\n\tAND CAST(CAST(ST.EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS\r\nwhere JOB_STREAM_ID='wf_EL_INT_CQ_SNGL_QUOTE_VW_RNWL_KAFKA')\r\nAND ST.DEAL_REQUESTED_BY IS NOT NULL\r\nAND ST.QUOTE_ID IS NOT NULL",
        "User Defined Join": "",
