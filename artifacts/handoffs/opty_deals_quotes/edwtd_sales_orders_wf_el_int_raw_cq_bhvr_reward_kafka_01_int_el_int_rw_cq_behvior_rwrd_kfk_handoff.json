      "attributes": {
        "Sql Query": "SELECT DISTINCT\r\nST.OBJECT_ID, \r\nST.BH_REWARD_CODE, \r\nST.BH_REWARD_VERSION, \r\nST.DEAL_OBJECT_ID, \r\nPROGRAM_NAME, \r\nST.BUNDLE_TYPE,\r\nST.BUNDLE_TYPE_DESC, \r\n/*CAST(SD.CREATED_ON AS TIMESTAMP(0) FORMAT 'DD-MMM-YYYY') as CREATED_ON,*/      /*COMMENTED AS PART OF CCW DATA FIX AUG REL*/\r\nCOALESCE(CAST(ST.CREATED_ON AS TIMESTAMP(0) FORMAT 'DD-MMM-YYYY'), CAST('1900-01-01 00:00:00' AS TIMESTAMP(0))) AS CREATED_ON,  /*ADDED AS PART OF CCW DATA FIX AUG REL */\r\n/*SD.CREATED_BY as\tCREATED_BY ,*/\t\r\nCOALESCE(CREATED_BY,'CCW') AS\tCREATED_BY,\t\t\t\t\t\t\t\t\t\t       /*ADDED AS PART OF CCW DATA FIX AUG REL*/\r\n/*CAST(SD.UPDATED_ON AS TIMESTAMP(0) FORMAT 'DD-MMM-YYYY') AS UPDATED_ON  ,*/ \t /*COMMENTED AS PART OF CCW DATA FIX AUG REL*/ \r\nCAST('1900-01-01 00:00:00' AS TIMESTAMP(0)) AS UPDATED_ON,  \t\t\t\t\t\t\t\t      /*ADDED AS PART OF CCW DATA FIX AUG REL */\r\n/*SD.UPDATED_BY AS UPDATED_BY, */\t\t\t\t\t\t /*COMMENTED AS PART OF CCW DATA FIX AUG REL*/\r\n'CCW' AS UPDATED_BY,\r\n1 AS BATCH_ID, \r\nCURRENT_TIMESTAMP(0) AS CREATE_DATETIME, \r\n'I' AS ACTION_CODE, \r\nST.PARENT_ID AS QUOTE_OBJECT_ID, \r\nST.BH_REWARD_ID, \r\nST.BH_REWARD_NAME, \r\nST.IS_BH_REWARD_SELECTABLE, \r\nST.IS_BH_REWARD_SELECTED, \r\nST.BH_REWARD_VERSION_APPLIED, \r\nST.IS_BH_REWARD_APPROVED, \r\nST.UPDATED_BY_KAFKA, \r\nCAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,'T',' '), 19) as TIMESTAMP(0)) AS UPDATED_ON_KAFKA, \r\nST.OFFSET_NUMBER, \r\nCURRENT_TIMESTAMP(0) as EDW_CREATE_DTM, \r\nUSER as EDW_CREATE_USER, \r\nST.PARTITION_NUMBER, \r\nST.MESSAGE_SEQUENCE_NUMBER,\r\nCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\nUSER AS EDW_UPDATE_USER,\r\nAUTO_APPROVED_FLAG\r\nFROM\r\n$$STGDB.ST_INT_RAW_CQ_BHVR_RWRD_KFKA_FF ST \r\n/*COMMENTED AS PART OF CCW DATA FIX AUG REL INNER JOIN COMMENTED*/\r\n/*INNER JOIN                    \r\n---INNER JOIN STGDB_DV1.ST_INT_CQ_DEAL_KAFKA_FF SD ON ST.DEAL_OBJECT_ID = SD.OBJECT_ID\r\n(SELECT OBJECT_ID , CREATED_BY , CREATED_ON , UPDATED_BY , UPDATED_ON FROM $$STGDB.ST_INT_CQ_DEAL_KAFKA_FF FF\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY OPTY_ID ORDER BY MESSAGE_SEQUENCE_NUMBER DESC)=1 )SD\r\n ON ST.DEAL_OBJECT_ID = SD.OBJECT_ID*/\r\n WHERE\r\nNOT EXISTS\r\n(SELECT 1 FROM $$ETLVWDB.EL_INT_RW_CQ_BEHVIOR_RWRD_KFK EL\r\nWHERE ST.OBJECT_ID  = EL.OBJECT_ID AND ST.MESSAGE_SEQUENCE_NUMBER = EL.MESSAGE_SEQUENCE_NUMBER)",
        "User Defined Join": "",
        "Source Filter": "",
