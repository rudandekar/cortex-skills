      "attributes": {
        "Sql Query": "SELECT\tDISTINCT ST.OBJECT_ID,\r\n\t\t\tST.PARENT_ID AS DEAL_OBJECT_ID,\r\n\t\t\tTD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(  ST.PARTY_NAME,\r\n\t\t\t'[^!-~a-zA-Z0-9]+',\r\n\t\t\t' ',1,0,\r\n\t\t\t'i') ,\r\n\t\t\tX'0d' ,\r\n\t\t\t' ') ,\r\n\t\t\tX'0a' ,\r\n\t\t\t' ') AS PARTY_NAME,\r\n\t\t\tTD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(  ST.PARTY_TYPE_NAME,\r\n\t\t\t'[^!-~a-zA-Z0-9]+',\r\n\t\t\t' ',1,0,\r\n\t\t\t'i') ,\r\n\t\t\tX'0d' ,\r\n\t\t\t' ') ,\r\n\t\t\tX'0a' ,\r\n\t\t\t' ') AS PARTY_TYPE_NAME,\r\n\t\t\tST.PRIMARY_FLAG,\r\n\t\t\tST.SITE_ID,\r\n\t\t\tST.PARTY_ID,\r\n\t\t\tTD_SYSFNLIB.OREPLACE(TD_SYSFNLIB.OREPLACE(REGEXP_REPLACE(  ST.PARTY_TYPE_LEVEL,\r\n\t\t\t'[^!-~a-zA-Z0-9]+',\r\n\t\t\t' ',1,0,\r\n\t\t\t'i') ,\r\n\t\t\tX'0d' ,\r\n\t\t\t' ') ,\r\n\t\t\tX'0a' ,\r\n\t\t\t' ') AS PARTY_TYPE_LEVEL,\r\n\t\t\t/*CAST(SD.CREATED_ON AS TIMESTAMP(0) FORMAT 'DD-MMM-YYYY') as CREATED_DATE ,*/                 /*COMMENTED AS PART OF CCW DATA FIX AUG REL*/\r\n\t\t\tCAST('1900-01-01 00:00:00' AS TIMESTAMP(0)) AS CREATED_ON,     /* ADDED AS PART OF CCW DATA FIX AUG REL */  \r\n\t\t\t/*SD.CREATED_BY \tas\tCREATED_BY ,*/\t\t/*COMMENTED AS PART OF CCW DATA FIX AUG REL*/\r\n\t\t\tCOALESCE(ST.CREATED_BY,'CCW') AS CREATED_BY,                 /* ADDED AS PART OF CCW DATA FIX AUG REL */  \r\n\t\t\t/*CAST(SD.UPDATED_ON AS TIMESTAMP(0) FORMAT 'DD-MMM-YYYY') as UPDATED_DATE,*/  /*COMMENTED AS PART OF CCW DATA FIX AUG REL*/\r\n\t\t\tCAST('1900-01-01 00:00:00' AS TIMESTAMP(0)) AS UPDATED_ON,        /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\n\t\t\t/*SD.UPDATED_BY as\tUPDATED_BY ,*/\t\t\t\t\t/*COMMENTED AS PART OF CCW DATA FIX AUG REL*/\r\n\t\t\t'CCW' AS UPDATED_BY,                    /* ADDED AS PART OF CCW DATA FIX AUG REL */\r\n\t\t\tST.UPDATED_BY_KAFKA,\r\n\t\t\tCAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,\r\n\t\t\t'T',''), 19) as TIMESTAMP(0)) AS UPDATED_ON_KAFKA,\r\n\t\t\tST.OFFSET_NUMBER,\r\n\t\t\tST.PARTITION_NUMBER,\r\n\t\t\tCURRENT_TIMESTAMP(0) as EDW_CREATE_DTM,\r\n\t\t\tUSER as EDW_CREATE_USER,\r\n\t\t\tST.MESSAGE_SEQUENCE_NUMBER,\r\n\t\t\tCURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n\t\t\tUSER AS EDW_UPDATE_USER \r\n\tFROM\t$$STGDB.ST_INT_RAW_CQ_DL_PRTY_VW_KFK_F ST \r\n\t/*INNER JOIN  STGDB.ST_INT_CQ_DEAL_KAFKA_FF SD     \r\n\t( SELECT OBJECT_ID ,CREATED_ON,CREATED_BY,UPDATED_ON,UPDATED_BY\r\n\t\tFROM $$STGDB.ST_INT_CQ_DEAL_KAFKA_FF SD          \r\n\t\tGROUP BY 1,2,3,4,5 ) SD  \r\n\t\tON ST.PARENT_ID = SD.OBJECT_ID */\r\n\tWhere\tNOT EXISTS (\r\n\t\tSELECT\t1 \r\n\t\tFROM\t$$ETLVWDB.EL_INT_RAW_CQ_DL_PRTY_VW_KFKA EL \r\n\t\tWHERE\tST.OBJECT_ID = EL.OBJECT_ID        /* ADDED AS PART OF CCW DATA FIX AUG REL */  \r\n            AND ST.PARENT_ID = EL.DEAL_OBJECT_ID  \r\n\t\t\tAND ST.MESSAGE_SEQUENCE_NUMBER = EL.MESSAGE_SEQUENCE_NUMBER )",
        "User Defined Join": "",
