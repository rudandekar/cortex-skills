      "attributes": {
        "Sql Query": "SELECT\r\nD_Q_L.BK_QUOTE_NUM AS BK_QUOTE_NUM,\r\nCOALESCE(Q_L_CONC.CONCESSION_ID,-999) AS BK_DEAL_CONCESSION_SOURCE_NUM,\r\nCOALESCE(Q_L_CONC.CONCESSION_TYPE,'UNKNOWN') AS CONCESSION_SOURCE_TYPE,\r\n'UNKNOWN' AS RU_TMIP_QUOTE_NUM,\r\n-999 AS BK_CONTRACT_NUMBER_INT,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\nCURRENT_TIMESTAMP(0),\r\nUSER,\r\n'I' AS ACTION_CODE,\r\n'=' AS DML_TYPE\r\nFROM $$STGDB.ST_INT_RAW_CQ_QUOTE_LNE_CONCES Q_L_CONC\r\nINNER JOIN $$SLSORDVWDB.N_DEAL_QUOTE_LINE D_Q_L\r\nON D_Q_L.SK_QUOTE_LINE_OBJECT_ID_INT = Q_L_CONC.QUOTE_LINE_OBJECT_ID\r\nAND D_Q_L.SS_CODE <> 'CCWR'\r\nAND Q_L_CONC.CONCESSION_APPLIED = 'Y'\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY BK_QUOTE_NUM, BK_DEAL_CONCESSION_SOURCE_NUM ORDER BY OBJECT_ID DESC )=1",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
