        "Sql Query": "SELECT W_DEAL_PARTNER.DEAL_PARTNER_KEY, W_DEAL_PARTNER.BK_DEAL_ID, W_DEAL_PARTNER.SRC_RPRTD_PTNR_SITE_PTY_NAME, W_DEAL_PARTNER.PRIMARY_FLG, W_DEAL_PARTNER.SRC_RPRTD_DEAL_PARTNER_CCO_ID, W_DEAL_PARTNER.SK_DEAL_PARTNER_OBJECT_ID_INT, W_DEAL_PARTNER.PARTNER_COUNTRY_PARTY_KEY, W_DEAL_PARTNER.PARTNER_SITE_PARTY_KEY, W_DEAL_PARTNER.EDW_CREATE_DTM, W_DEAL_PARTNER.EDW_CREATE_USER, W_DEAL_PARTNER.EDW_UPDATE_DTM, W_DEAL_PARTNER.EDW_UPDATE_USER,\r\nW_DEAL_PARTNER.PARTNER_TYPE_CD ,\r\nW_DEAL_PARTNER.SS_CODE\r\nFROM\r\n $$WORKDB.W_DEAL_PARTNER W_DEAL_PARTNER\r\n/* ADDED AS PART OF CCW DATA FIX AUG REL */  \r\n  WHERE NOT EXISTS\r\n  (SELECT 1 FROM $$SLSORDVWDB.N_DEAL_PARTNER NDP\r\n  WHERE W_DEAL_PARTNER.DEAL_PARTNER_KEY = NDP.DEAL_PARTNER_KEY\r\n AND NDP.SS_CODE = W_DEAL_PARTNER.SS_CODE)",
