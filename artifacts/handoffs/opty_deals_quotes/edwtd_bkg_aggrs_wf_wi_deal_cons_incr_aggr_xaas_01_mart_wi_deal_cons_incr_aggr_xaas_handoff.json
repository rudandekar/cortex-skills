      "attributes": {
        "Sql Query": "SELECT\r\nNXSSIS.BK_DEAL_ID AS DEAL_ID /* for XAAS not taking from NSO.SOURCE_REPORTED_DEAL_ID .. ?? */\r\n,COALESCE(CAST(NXSSIS.BOOKED_DT AS TIMESTAMP(0)),CAST('3500/01/01 00:00:00' AS TIMESTAMP(0))) AS CISCO_BOOKED_DATE  /* NSO.RU_DV_CISCO_BOOKED_DT */\r\n,CASE WHEN NXSSIS.TRX_SS_CD='MANUAL' THEN NXSSIS.FCM_ID_INT ELSE NXSSIS.BK_SALES_ORDER_ID_INT END AS SALES_ORDER_NUMBER  /* TRX.BK_SO_NUMBER_INT .. TRX.WEB_ORDER_ID */\r\n,COALESCE(NXSSIS.BK_TRXL_CURRENCY_CD,'UNK') AS TRANSACTIONAL_CURRENCY_CD /* NSO.TRANSACTIONAL_CURRENCY_CD */\r\n,'XAAS' AS BKGS_MEASURE_TRANS_TYPE_CODE\r\n,'NEW' AS OPERATION\r\n,COALESCE(NXSSIS.SALES_CHANNEL_CD,-9999) AS SALES_CHANNEL_CODE /* NSO.SALES_CHANNEL_CD */\r\n,COALESCE(CAST(NXSSIS.SOURCE_COMMIT_DTM AS TIMESTAMP(0)),CAST('3500/01/01 00:00:00' AS TIMESTAMP(0))) AS ORDER_CREATION_DATE /* NSO.SO_SOURCE_CREATE_DTM */\r\n,COALESCE(SUM(TRX.DD_COMP_US_LIST_PRICE_AMOUNT),0) AS ORDER_USD_LIST_PRICE_AMOUNT\r\n,COALESCE(SUM(TRX.DV_LOCAL_EXTND_LIST_PRICE_AMT),0) AS ORDER_LOCAL_LIST_PRICE_AMOUNT\r\n,COALESCE(SUM(TRX.DD_COMP_US_NET_PRICE_AMOUNT),0) AS ORDER_USD_NET_PRICE_AMOUNT\r\n,COALESCE(SUM(TRX.DD_COMP_US_NET_PRICE_AMOUNT/TRX.CONVERSION_RT),0) AS ORDER_LOCAL_NET_PRICE_AMOUNT\r\n,COALESCE(SUM (CASE        \r\n\tWHEN TRX.SERVICE_FLG='N' THEN TRX.DD_COMP_US_NET_PRICE_AMOUNT \r\n\tEND       ),0) AS PRODUCT_USD_NET_AMOUNT\r\n,COALESCE(SUM (CASE        \r\n\tWHEN TRX.SERVICE_FLG='N' THEN (TRX.DD_COMP_US_NET_PRICE_AMOUNT/TRX.CONVERSION_RT) \r\n\tEND       ),0) AS PRODUCT_LOCAL_NET_AMOUNT\r\n,COALESCE(SUM (CASE        \r\n\tWHEN TRX.SERVICE_FLG='N' THEN (TRX.DD_COMP_US_LIST_PRICE_AMOUNT) \r\n\tEND       ),0) AS PRODUCT_USD_LIST_AMOUNT\r\n,COALESCE(SUM (CASE        \r\n\tWHEN TRX.SERVICE_FLG='N' THEN (TRX.DD_COMP_US_LIST_PRICE_AMOUNT/TRX.CONVERSION_RT) \r\n\tEND       ),0) AS PRODUCT_LOCAL_LIST_AMOUNT\r\n,COALESCE(SUM (CASE        \r\n\tWHEN TRX.SERVICE_FLG='Y' THEN TRX.DD_COMP_US_NET_PRICE_AMOUNT \r\n\tEND       ),0) AS SERVICE_USD_NET_AMOUNT\r\n,COALESCE(SUM (CASE        \r\n\tWHEN TRX.SERVICE_FLG='Y' THEN (TRX.DD_COMP_US_NET_PRICE_AMOUNT/TRX.CONVERSION_RT) \r\n\tEND       ),0) AS SERVICE_LOCAL_NET_AMOUNT\r\n,COALESCE(SUM (CASE        \r\n\tWHEN TRX.SERVICE_FLG='Y' THEN (TRX.DD_COMP_US_LIST_PRICE_AMOUNT) \r\n\tEND       ),0) AS SERVICE_USD_LIST_AMOUNT\r\n,COALESCE(SUM (CASE        \r\n\tWHEN TRX.SERVICE_FLG='Y' THEN (TRX.DD_COMP_US_LIST_PRICE_AMOUNT/TRX.CONVERSION_RT) \r\n\tEND       ),0)  AS SERVICE_LOCAL_LIST_AMOUNT\r\n,CURRENT_TIMESTAMP(0) AS EDW_CREATE_DATETIME\r\n,USER AS EDW_CREATE_USER\r\n--,MAX(TRX.EDW_UPDATE_DATETIME) AS EDW_UPDATE_DATETIME\r\n,INCR1.EDW_UPDATE_DATETIME1 AS EDW_UPDATE_DATETIME\r\n,USER AS EDW_UPDATE_USER\r\nFROM \r\n(SELECT  DRVD_XAAS_BKGS_KEY, WEB_ORDER_ID  /* SALES_ORDER_KEY */\r\nFROM $$NRTNCRVWDB.MT_DRVD_XAAS_BKGS_TRX_NRT TRX \r\nWHERE  TRX.DV_ATTRIBUTION_CD IN ('STANDALONE','BUNDLE')\r\nAND (WEB_ORDER_ID IS NOT NULL AND WEB_ORDER_ID <> 'UNKNOWN') \r\nAND TRX.EDW_UPDATE_DATETIME > '$$LastExtractDate'  \r\nGROUP BY 1,2\r\n) INCR  ,  /* WI_ERP_INCR */\r\n$$NRTNCRVWDB.MT_DRVD_XAAS_BKGS_TRX_NRT TRX,\r\n(select MAX(EDW_UPDATE_DATETIME) as EDW_UPDATE_DATETIME1 \r\nfrom (select EDW_UPDATE_DATETIME from $$NRTNCRVWDB.MT_DRVD_XAAS_BKGS_TRX_NRT TRX group by 1) A) INCR1,\r\n$$NRTNCRVWDB.N_XAAS_SO_SBCR_ITM_STRX_NRT_TV NXSSIS,\r\n$$NRTNCRVWDB.N_SALES_ORDER_LINE_NRT NSOL,\r\n$$NRTNCRVWDB.N_SALES_ORDER_NRT NSO,\r\n$$COMREFVWDB.R_SALES_HIERARCHY RSH\r\nWHERE 1=1   \r\nAND INCR.DRVD_XAAS_BKGS_KEY =TRX.DRVD_XAAS_BKGS_KEY  \r\nAND INCR.WEB_ORDER_ID =TRX.WEB_ORDER_ID  \r\nAND TRX.DV_SO_SBSCRPTN_ITM_SLS_TRX_KEY = NXSSIS.SO_SBSCRPTN_ITM_SLS_TRX_KEY AND NXSSIS.END_TV_DTM=CAST('3500-01-01 00:00:00' AS TIMESTAMP(0))\r\n/* AND TRX.SALES_ORDER_KEY =NSO.SALES_ORDER_KEY */\r\nAND NXSSIS.MINOR_LN_EXAAS_SUBSCR_SOL_KEY =NSOL.SALES_ORDER_LINE_KEY\r\nAND RSH.SALES_TERRITORY_KEY=TRX.SALES_TERRITORY_KEY\r\nAND NSO.SALES_ORDER_KEY = NSOL.SALES_ORDER_KEY /* AND SS_CD = 'OPL' */\r\nAND TRX.DV_ATTRIBUTION_CD IN ('STANDALONE','BUNDLE')\r\nAND (NXSSIS.BK_DEAL_ID IS NOT NULL AND NXSSIS.BK_DEAL_ID <> 'UNKNOWN') /* for XAAS not taking from NSO.SOURCE_REPORTED_DEAL_ID .. ?? */\r\n/* AND NSO.SALES_ORDER_TYPE_NAME          <> 'RETURN' */\r\n/* AND NSOL.SO_LINE_TYPE_NAME                       <> 'RETURN' */\r\nAND RSH.L1_SALES_TERRITORY_DESCR NOT IN ('WW Distribution')\r\nGROUP BY 1,2,3,4,5,6,7,8,21,22,24",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
