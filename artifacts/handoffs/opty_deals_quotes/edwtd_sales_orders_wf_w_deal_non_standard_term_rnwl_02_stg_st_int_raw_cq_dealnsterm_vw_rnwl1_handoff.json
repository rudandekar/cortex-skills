      "attributes": {
        "Sql Query": "SELECT \r\nD_NSTERM.NSTERM_NAME AS BK_NON_STANDARD_TERM_NAME,\r\nDEAL.BK_DEAL_ID AS BK_DEAL_ID,\r\nCURRENT_TIMESTAMP(0),         \r\nUSER,\r\nCURRENT_TIMESTAMP(0),         \r\nUSER ,\r\nCOALESCE(D_NSTERM.AS_SUBSCRIPTION,'N' ) AS AS_SUBSCRIPTION_FLG,\r\nCOALESCE(D_NSTERM.AS_TRANSACTION,'N' ) AS AS_TRANSACTION_FLG,\r\nCOALESCE(D_NSTERM.AS_FIXED,'N' ) AS AS_FIXED_FLG,\r\nCOALESCE(D_NSTERM.TSS_CORE,'N' ) AS TSS_CORE_FLG,\r\nCOALESCE(D_NSTERM.ROS,'N' ) AS ROS_FLG,\r\n'I' AS ACTION_CODE,\r\n'=' AS DML_TYPE                \r\nFROM $$STGDB.ST_INT_RAW_CQ_DEALNSTERM_VW_RNWL D_NSTERM\r\nINNER JOIN $$SLSORDVWDB.N_DEAL DEAL\r\nON D_NSTERM.DEAL_OBJECT_ID = SK_DEAL_OBJECT_ID_INT\r\nAND DEAL.SS_CODE = 'CCWR' -- added to process CCWR DEALS\r\nQUALIFY ROW_NUMBER() OVER (PARTITION BY DEAL.BK_DEAL_ID,D_NSTERM.NSTERM_NAME ORDER BY D_NSTERM.DEAL_OBJECT_ID DESC)=1",
