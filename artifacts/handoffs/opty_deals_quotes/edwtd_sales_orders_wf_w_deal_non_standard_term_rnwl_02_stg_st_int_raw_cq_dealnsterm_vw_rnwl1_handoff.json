      "attributes": {
        "Sql Query": "SELECT \r\nSTG.OBJECT_ID, \r\nSTG.NSTERM_ID, \r\nSTG.NSTERM_NAME, \r\nSTG.DEAL_OBJECT_ID, \r\nSTG.CREATED_DATE, \r\nSTG.CREATED_BY, \r\nSTG.UPDATED_DATE, \r\nSTG.UPDATED_BY ,\r\n'RI' EXCEPTION_TYPE,\r\nSTG.AS_SUBSCRIPTION,\r\nSTG.AS_TRANSACTION,\r\nSTG.AS_FIXED,\r\nSTG.TSS_CORE,\r\nSTG.ROS\r\nFROM\r\n$$STGDB.ST_INT_RAW_CQ_DEALNSTERM_VW_RNWL STG\r\nWHERE NOT EXISTS\r\n(SELECT 1 FROM $$SLSORDVWDB.N_DEAL \r\nWHERE STG.DEAL_OBJECT_ID = SK_DEAL_OBJECT_ID_INT\r\nAND SS_CODE = 'CCWR' -- added to process CCWR DEALS\r\n)",
