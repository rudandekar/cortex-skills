      "attributes": {
        "Sql Query": "SELECT CONT.BATCH_ID, \r\n\t CONT.DEAL_OBJECT_ID, \r\n\t CONT.OBJECT_ID, \r\n\t CONT.CONTACT_ID, \r\n\tCOALESCE(CONT.CONTACT_NAME, 'UNKNOWN'), \r\n\t CONT.CONTACT_TYPE, \r\n\t CONT.CREATED_ON, \r\n\t CONT.CREATED_BY, \r\n\t CONT.UPDATED_ON, \r\n\t CONT.UPDATED_BY, \r\n\t CONT.CONTACT_ROW, \r\n\t CONT.DM_UPDATE_DATE, \r\n\t CONT.CONTACT_POSTN_ID, \r\n\t CONT.SIEBEL_POSTN_ID, \r\n\t CONT.CREATE_DATETIME, \r\n\t CONT.ACTION_CODE \r\nFROM\r\n $$STGDB.ST_CQ_DEAL_CONTACT CONT\r\nQUALIFY\tROW_NUMBER ( ) OVER ( PARTITION BY DEAL_OBJECT_ID ,\tCONTACT_NAME\r\nORDER\tBY UPDATED_ON DESC ) = 1",
