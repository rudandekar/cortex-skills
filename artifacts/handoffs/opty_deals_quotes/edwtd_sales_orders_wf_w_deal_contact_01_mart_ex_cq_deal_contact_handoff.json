      ],
      "attributes": {
        "Sql Query": "SELECT \r\n DEAL.BK_DEAL_ID AS BK_DEAL_ID,\r\n CONT.CONTACT_NAME AS BK_SRC_REPORTED_CONTACT_NAME,\r\n COALESCE (ELC.LOV_VALUE,'UNKNOWN') as SRC_RPTD_CONTACT_TYPE_CD,\r\n COALESCE(ELC.LOV_SUBTYPE,'UNKNOWN') as SRC_RPTD_CONTACT_SUBTYPE_CD,\r\n COALESCE(NCISCO.CISCO_WORKER_PARTY_KEY,-999) AS CONTACT_CISCO_WORKER_PARTY_KEY,\r\n CURRENT_TIMESTAMP(0)EDW_CREATE_DTM,\r\n USER AS EDW_CREATE_USER,\r\n CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n USER AS EDW_UPDATE_USER,\r\n CONT.ACTION_CODE,\r\n 'I' DML_TYPE\r\n FROM \r\n (\r\n SELECT \r\n DEAL_OBJECT_ID,\r\n OBJECT_ID     ,                \r\n CONTACT_ID     ,               \r\n CONTACT_NAME    ,              \r\n CONTACT_TYPE   ,\r\n ACTION_CODE\r\n   FROM $$STGDB.ST_CQ_DEAL_CONTACT\r\n/*  -- COMMENTED AS PART OF CCW DATA FIX AUG REL\r\n  UNION ALL \r\n   SELECT\r\n DEAL_OBJECT_ID, \r\n   OBJECT_ID     ,                \r\n CONTACT_ID     ,               \r\n CONTACT_NAME    ,              \r\n CONTACT_TYPE   ,\r\n ACTION_CODE\r\n FROM $$EXCEPDB.EX_CQ_DEAL_CONTACT*/ ) CONT\r\n INNER JOIN $$SLSORDVWDB.N_DEAL DEAL \r\n ON CONT.DEAL_OBJECT_ID=DEAL.SK_DEAL_OBJECT_ID_INT\r\n AND DEAL.SS_CODE <> 'CCWR' -- to filter out CCWR Deals\r\n LEFT  JOIN $$ETLVWDB.EL_CQ_LOV ELC\r\n ON CONT.CONTACT_TYPE=ELC.LOV_INDEX\r\n AND ELC.LOV_TYPE = 'DEAL_CONTACT'\r\n LEFT  JOIN $$COMREFVWDB.N_CISCO_WORKER_PARTY  NCISCO\r\n ON NCISCO.CEC_ID=CONT.CONTACT_ID\r\n QUALIFY ROW_NUMBER () OVER (PARTITION BY DEAL.BK_DEAL_ID,CONT.CONTACT_ID,ELC.LOV_VALUE,ELC.LOV_SUBTYPE ORDER BY EDW_UPDATE_DTM DESC)=1 /*Replaced contact_name with contact_id as part of ccw data fix aug rel*/",
        "User Defined Join": "",
        "Source Filter": "",
        "Number Of Sorted Ports": "0",
        "Tracing Level": "Normal",
