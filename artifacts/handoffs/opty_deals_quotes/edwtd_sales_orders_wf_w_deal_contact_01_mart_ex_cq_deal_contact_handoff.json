      "attributes": {
        "Sql Query": "SELECT \r\n BATCH_ID                      ,\r\n DEAL_OBJECT_ID                ,\r\n OBJECT_ID                     ,\r\n CONTACT_ID                    ,\r\n CONTACT_NAME                  ,\r\n CONTACT_TYPE                  ,\r\n CREATED_ON                    ,\r\n CREATED_BY                    ,\r\n UPDATED_ON                    ,\r\n UPDATED_BY                    ,\r\n CONTACT_ROW                   ,\r\n DM_UPDATE_DATE                ,\r\n CONTACT_POSTN_ID              ,\r\n SIEBEL_POSTN_ID               ,\r\n CREATE_DATETIME               ,\r\n ACTION_CODE                   ,\r\n 'RI' AS EXCEPTION_TYPE            \r\n FROM $$STGDB.ST_CQ_DEAL_CONTACT CONT\r\n WHERE NOT EXISTS ( SELECT 1 FROM $$SLSORDVWDB.N_DEAL  DEALS\r\n where   CONT.DEAL_OBJECT_ID=DEALS.SK_DEAL_OBJECT_ID_INT\r\n AND DEALS.SS_CODE <> 'CCWR' -- to filter out CCWR Deals\r\n )",
        "User Defined Join": "",
