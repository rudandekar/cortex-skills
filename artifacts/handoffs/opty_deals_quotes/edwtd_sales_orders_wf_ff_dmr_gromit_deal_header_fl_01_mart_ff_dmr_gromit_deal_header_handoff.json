      "attributes": {
        "Sql Query": "SELECT \r\nDGDH.DEAL_OBJECT_ID, \r\nDGDH.OPTY_NUMBER, \r\nDGDH.DEAL_NAME, \r\nDGDH.ACCOUNT_NAME,\r\nDGDH.THEATER, \r\nDGDH.SLA_FLAG, \r\nDGDH.STANDARD_NONSTANDARD,\r\nDGDH.FINANCE_CONTROLLER,\r\nDGDH.LEGAL_ASSURER, \r\nDGDH.OPPORTUNITY_OWNER, \r\nDGDH.DEAL_SERVICE_VALUE, \r\nDGDH.DEAL_STATUS, \r\nDGDH.MARKET_SEGMENT, \r\nDGDH.DEAL_LAST_UPDATE_DATE, \r\nDGDH.DEAL_REGISTRATION_DATE, \r\nDGDH.APPROVED_DATE_LAST, \r\nDGDH.EXPIRATION_DATE \r\nFROM\r\n(SELECT DEAL_OBJECT_ID,OPTY_NUMBER, \r\nDEAL_NAME,ACCOUNT_NAME,\r\nTHEATER,SLA_FLAG, \r\nSTANDARD_NONSTANDARD,\r\nFINANCE_CONTROLLER,\r\nLEGAL_ASSURER,OPPORTUNITY_OWNER, \r\nDEAL_SERVICE_VALUE,DEAL_STATUS, \r\nMARKET_SEGMENT,DEAL_LAST_UPDATE_DATE, \r\nDEAL_REGISTRATION_DATE, \r\nAPPROVED_DATE_LAST,EXPIRATION_DATE, ROW_NUMBER() OVER  (PARTITION BY DEAL_OBJECT_ID ORDER BY DEAL_LAST_UPDATE_DATE DESC) AS ROW_NUM FROM DMR_ADMIN.DMR_GROMIT_DEAL_HEADER)  DGDH\r\nWHERE DGDH.ROW_NUM=1",
