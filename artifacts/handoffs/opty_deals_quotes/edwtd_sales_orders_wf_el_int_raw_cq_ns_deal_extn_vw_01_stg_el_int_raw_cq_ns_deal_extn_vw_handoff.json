        "Sql Query": "select \r\nSTG.DEAL_OBJECT_ID,\r\nSTG.APPROVAL_ROUTE,\r\nSTG.APPROVAL_ROUTE_NAME,\r\nSTG.PRODUCT_COMP,\r\nSTG.TSS_CORE_COMP,\r\nSTG.AS_TRANSACTION_COMP,\r\nSTG.AS_SUBSCRIPTION_COMP,\r\nSTG.AS_FIXED_COMP,\r\nSTG.ROS_COMP,\r\nSTG.PRODUCT_COMPONENT,\r\nSTG.SERVICE_COMPONENT,\r\n CURRENT_TIMESTAMP(0) UPDATE_DATETIME,\r\nSTG.GET_WELL_PLAN_DESCR,\r\nSTG.FLAG_SPVTG,\r\nSTG.DSA_REGSTR_DATE,\r\nSTG.DD_ENGAGE_DATE,\r\nSTG.NS_SUMMARY_DESCR,\r\nSTG.EXE_SUMMARY_INTERNAL_DESCR,\r\nSTG.IS_SA_DEAL,\r\nSTG.CREATE_DATETIME\r\nFROM   (SELECT * FROM $$STGDB.ST_INT_RAW_CQ_NS_DEAL_EXTN_VW \r\n                   QUALIFY ROW_NUMBER() OVER (PARTITION BY DEAL_OBJECT_ID ORDER BY UPDATED_ON DESC)=1 )STG\r\nWHERE NOT EXISTS ( SELECT 1 FROM $$ETLVWDB.EL_INT_RAW_CQ_NS_DEAL_EXTN_VW  EL \r\nWHERE STG.DEAL_OBJECT_ID=EL.DEAL_OBJECT_ID)",
