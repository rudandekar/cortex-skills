      "attributes": {
        "Sql Query": "SELECT \r\n    DISTINCT 1 AS BATCH_ID ,\r\n    ST.DEAL_OBJECT_ID AS DEAL_OBJECT_ID ,\r\n    ST.QUESTION_ID,\r\n    ST.VALUE_NAME ,\r\n    STD.CREATED_BY  as  CREATED_BY ,\r\n    CAST(LEFT(OREPLACE(STD.CREATED_ON,'T',' '), 19) as TIMESTAMP(0)) as CREATION_DATE,\r\n    STD.UPDATED_BY  as  LAST_UPDATED_BY ,\r\n\tCAST(LEFT(OREPLACE(STD.UPDATED_ON,'T',' '), 19) as TIMESTAMP(0))   as LAST_UPDATE_DATE ,\r\n    CAST(LEFT(OREPLACE(STD.CREATED_ON,'T',' '), 19) as TIMESTAMP(0)) as CREATE_DATETIME ,\r\n    'I' AS ACTION_CODE,\r\n    ST.UPDATED_BY_KAFKA,\r\n    CAST(LEFT(OREPLACE(ST.UPDATED_ON_KAFKA,'T',' '), 19) as TIMESTAMP(0)) AS UPDATED_ON_KAFKA,\r\n    ST.OFFSET_NUMBER,\r\n    ST.PARTITION_NUMBER,\r\n    CAST(CAST(EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) as EDW_CREATE_DTM,\r\n    USER as EDW_CREATE_USER,\r\n    CURRENT_TIMESTAMP(0) AS EDW_UPDATE_DTM,\r\n    USER AS EDW_UPDATE_USER \r\nFROM  $$ETLVWDB.ST_SI_CQ_QF_RESPONSE_RNWL_KAFKA ST \r\nINNER JOIN ( SELECT OBJECT_ID ,CREATED_ON,CREATED_BY,UPDATED_ON,UPDATED_BY\r\n    FROM $$ETLVWDB.ST_SI_INT_CQ_DEAL_RNWL_KAFKA STD          \r\n    GROUP BY 1,2,3,4,5 ) STD\r\n  ON ST.DEAL_OBJECT_ID=STD.object_id \r\nQUALIFY\tROW_NUMBER() OVER(PARTITION BY ST.DEAL_OBJECT_ID,ST.QUESTION_ID,ST.VALUE_NAME ORDER BY ST.EDW_CREATE_DTM DESC, ST.OFFSET_NUMBER DESC)=1\r\nWHERE CAST(CAST(EDW_CREATE_DTM AS VARCHAR(19)) AS TIMESTAMP(0)) >= (SELECT LAST_EXTRACT_DATE FROM $$ETLVWDB.DW_JOB_STREAMS\r\nwhere JOB_STREAM_ID='wf_EL_CQ_QF_RESPONSE_RNWL_KFKA') and \r\nNOT EXISTS (\r\n  SELECT  1 \r\n  FROM  $$ETLVWDB.EL_CQ_QF_RESPONSE_RNWL_KAFKA EL \r\n  WHERE ST.DEAL_OBJECT_ID = EL.DEAL_OBJECT_ID  \r\n    AND  ST.QUESTION_ID = EL.QUESTION_ID \r\n    AND  ST.VALUE_NAME = EL.VALUE_NAME )",
        "User Defined Join": "",
        "Source Filter": "",
